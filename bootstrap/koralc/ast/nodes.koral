public type Program(
    declarations [Decl]List,
)

public type AccessModifier {
    Public(),
    Protected(),
    Private(),
}

public type TypeParameter(
    name String,
    constraints [TypeNode ref]List,
)

public type TypeNode {
    Identifier(name String),
    Reference(inner TypeNode ref),
    Pointer(inner TypeNode ref),
    WeakReference(inner TypeNode ref),
    Generic(base String, args [TypeNode ref]List),
    InferredSelf(),
    FunctionType(param_types [TypeNode ref]List, return_type TypeNode ref),
    ModuleQualified(module String, name String),
    ModuleQualifiedGeneric(module String, base String, args [TypeNode ref]List),
}

public type UnaryOperator {
    Not(),
    Negate(),
    BitwiseNot(),
}

public type ArithmeticOperator {
    Add(),
    Subtract(),
    Multiply(),
    Divide(),
    Remainder(),
}

public type ComparisonOperator {
    Equal(),
    NotEqual(),
    Greater(),
    GreaterEqual(),
    Less(),
    LessEqual(),
}

public type BitwiseOperator {
    BitAnd(),
    BitOr(),
    BitXor(),
    LeftShift(),
    RightShift(),
}

public type RangeOperator {
    Closed(),
    ClosedOpen(),
    OpenClosed(),
    Open(),
    From(),
    FromOpen(),
    To(),
    ToOpen(),
    Full(),
}

public type CompoundAssignmentOperator {
    AddAssign(),
    SubtractAssign(),
    MultiplyAssign(),
    DivideAssign(),
    RemainderAssign(),
    BitAndAssign(),
    BitOrAssign(),
    BitXorAssign(),
    LeftShiftAssign(),
    RightShiftAssign(),
}

public type ComparisonPatternOperator {
    Greater(),
    Less(),
    GreaterEqual(),
    LessEqual(),
}

public type TraitMember(
    name String,
    type_params [TypeParameter]List,
    access AccessModifier,
    params [Param]List,
    return_type TypeNode,
)

public type GivenMember(
    name String,
    type_params [TypeParameter]List,
    access AccessModifier,
    params [Param]List,
    return_type TypeNode,
    body [Expr ref]Option,
)

public type Decl {
    LetDecl(access AccessModifier, name String, mutable Bool, type_name TypeNode, initializer Expr ref, span SourceSpan),
    FunctionDecl(access AccessModifier, name String, type_params [TypeParameter]List, params [Param]List, return_type TypeNode, body Expr ref, span SourceSpan),
    IntrinsicFunctionDecl(access AccessModifier, name String, type_params [TypeParameter]List, params [Param]List, return_type TypeNode, span SourceSpan),
    ForeignFunctionDecl(access AccessModifier, name String, params [Param]List, return_type TypeNode, span SourceSpan),
    ForeignLetDecl(access AccessModifier, name String, mutable Bool, type_name TypeNode, span SourceSpan),
    TypeStructDecl(access AccessModifier, name String, type_params [TypeParameter]List, fields [Field]List, span SourceSpan),
    TypeEnumDecl(access AccessModifier, name String, type_params [TypeParameter]List, cases [EnumCase]List, span SourceSpan),
    TypeAliasDecl(access AccessModifier, name String, target TypeNode, span SourceSpan),
    IntrinsicTypeDecl(access AccessModifier, name String, type_params [TypeParameter]List, span SourceSpan),
    ForeignTypeDecl(access AccessModifier, name String, cname [String]Option, fields [[Field]List]Option, span SourceSpan),
    PathUsingDecl(access AccessModifier, path_segments [String]List, imported_symbol [String]Option, is_batch Bool, alias [String]Option, span SourceSpan),
    ParentUsingDecl(access AccessModifier, path_segments [String]List, imported_symbol [String]Option, is_batch Bool, alias [String]Option, span SourceSpan),
    FileUsingDecl(access AccessModifier, file_name String, alias [String]Option, span SourceSpan),
    ForeignUsingDecl(access AccessModifier, library String, span SourceSpan),
    TraitDecl(access AccessModifier, name String, type_params [TypeParameter]List, parents [TypeNode]List, members [TraitMember]List, span SourceSpan),
    GivenDecl(target_type TypeNode, type_params [TypeParameter]List, members [GivenMember]List, span SourceSpan),
    GivenTraitDecl(target_type TypeNode, type_params [TypeParameter]List, trait_type TypeNode, members [GivenMember]List, span SourceSpan),
    IntrinsicGivenDecl(target_type TypeNode, type_params [TypeParameter]List, members [GivenMember]List, span SourceSpan),
}

public type Param(
    name String,
    mutable Bool,
    type_name TypeNode,
    named Bool,
)

public type Field(
    access AccessModifier,
    name String,
    mutable Bool,
    type_name TypeNode,
    named Bool,
)

public type EnumCaseField(
    name String,
    type_name TypeNode,
    named Bool,
)

public type EnumCase(
    name String,
    fields [EnumCaseField]List,
)

public type InterpolatedStringPart {
    Literal(value String),
    Expression(expr Expr ref),
}

public type WhenArm(
    pattern PatternNode,
    body Expr ref,
)

public type ExprPair(
    first Expr ref,
    second Expr ref,
)

public type PatternElement(
    label [String]Option,
    pattern PatternNode ref,
)

public type LambdaParam(
    name String,
    type_annotation [TypeNode]Option,
)

public type ConditionClauseNode {
    BooleanCondition(expr Expr ref, span SourceSpan),
    PatternCondition(subject Expr ref, pattern PatternNode ref, span SourceSpan),
}

public type PatternNode {
    Wildcard(span SourceSpan),
    Variable(name String, mutable Bool, span SourceSpan),
    BoolLiteral(value Bool, span SourceSpan),
    IntegerLiteral(value String, span SourceSpan),
    NegativeIntegerLiteral(value String, span SourceSpan),
    StringLiteral(value String, span SourceSpan),
    RuneLiteral(value String, span SourceSpan),
    EnumCase(case_name String, elements [PatternElement]List, span SourceSpan),
    StructPattern(type_name String, elements [PatternElement]List, span SourceSpan),
    ComparisonPattern(op ComparisonPatternOperator, value String, span SourceSpan),
    AndPattern(left PatternNode ref, right PatternNode ref, span SourceSpan),
    OrPattern(left PatternNode ref, right PatternNode ref, span SourceSpan),
    NotPattern(pattern PatternNode ref, span SourceSpan),
}

public type PairBindingElement(
    name String,
    mutable Bool,
    type_name [TypeNode]Option,
    is_discard Bool,
    span SourceSpan,
)

public type Statement {
    LetStmt(name String, mutable Bool, type_name [TypeNode]Option, value Expr ref, span SourceSpan),
    PairLetStmt(first PairBindingElement, second PairBindingElement, value Expr ref, span SourceSpan),
    AssignmentStmt(target Expr ref, op [CompoundAssignmentOperator]Option, value Expr ref, span SourceSpan),
    ExprStmt(expr Expr ref, span SourceSpan),
    ReturnStmt(value [Expr ref]Option, span SourceSpan),
    BreakStmt(span SourceSpan),
    ContinueStmt(span SourceSpan),
    FinallyStmt(expr Expr ref, span SourceSpan),
    YieldStmt(expr Expr ref, span SourceSpan),
}

public type Expr {
    Identifier(name String, span SourceSpan),
    IntegerLiteral(value String, span SourceSpan),
    FloatLiteral(value String, span SourceSpan),
    StringLiteral(value String, span SourceSpan),
    RuneLiteral(value String, span SourceSpan),
    InterpolatedString(parts [InterpolatedStringPart]List, span SourceSpan),
    BoolLiteral(value Bool, span SourceSpan),
    CastExpr(type_node TypeNode, expr Expr ref, span SourceSpan),
    Unary(op UnaryOperator, expr Expr ref, span SourceSpan),
    RefExpr(expr Expr ref, span SourceSpan),
    PtrExpr(expr Expr ref, span SourceSpan),
    DerefExpr(expr Expr ref, span SourceSpan),
    ArithmeticExpr(left Expr ref, op ArithmeticOperator, right Expr ref, span SourceSpan),
    ComparisonExpr(left Expr ref, op ComparisonOperator, right Expr ref, span SourceSpan),
    BitwiseExpr(left Expr ref, op BitwiseOperator, right Expr ref, span SourceSpan),
    AndExpr(left Expr ref, right Expr ref, span SourceSpan),
    OrExpr(left Expr ref, right Expr ref, span SourceSpan),
    RangeExpr(op RangeOperator, left [Expr ref]Option, right [Expr ref]Option, span SourceSpan),
    OrElseExpr(operand Expr ref, default_expr Expr ref, span SourceSpan),
    OrReturnExpr(operand Expr ref, span SourceSpan),
    AndThenExpr(operand Expr ref, transform_expr Expr ref, span SourceSpan),
    IsExpr(subject Expr ref, pattern PatternNode, span SourceSpan),
    IsNotExpr(subject Expr ref, pattern PatternNode, span SourceSpan),
    CollectionLiteral(elements [Expr ref]List, span SourceSpan),
    DictLiteral(entries [ExprPair]List, span SourceSpan),
    EmptyLiteral(span SourceSpan),
    NamedArgument(label String, expr Expr ref, span SourceSpan),
    Call(callee Expr ref, args [Expr ref]List, span SourceSpan),
    MemberExpr(base Expr ref, member String, span SourceSpan),
    MemberPath(base Expr ref, path [String]List, span SourceSpan),
    GenericMethodCall(base Expr ref, method_type_args [TypeNode ref]List, method_name String, args [Expr ref]List, span SourceSpan),
    QualifiedMethodCall(base Expr ref, trait_name String, method_name String, args [Expr ref]List, span SourceSpan),
    QualifiedGenericMethodCall(base Expr ref, trait_name String, method_type_args [TypeNode ref]List, method_name String, args [Expr ref]List, span SourceSpan),
    GenericInstantiation(base String, type_args [TypeNode ref]List, span SourceSpan),
    StaticMethodCall(type_name String, type_args [TypeNode ref]List, method_name String, args [Expr ref]List, span SourceSpan),
    SubscriptExpr(base Expr ref, args [Expr ref]List, span SourceSpan),
    Block(statements [Statement]List, span SourceSpan),
    IfExpr(condition Expr ref, then_branch Expr ref, else_branch [Expr ref]Option, span SourceSpan),
    WhileExpr(condition Expr ref, body Expr ref, span SourceSpan),
    IfClauseChainExpr(clauses [ConditionClauseNode]List, then_branch Expr ref, else_branch [Expr ref]Option, span SourceSpan),
    WhileClauseChainExpr(clauses [ConditionClauseNode]List, body Expr ref, span SourceSpan),
    IfPatternExpr(subject Expr ref, pattern PatternNode, then_branch Expr ref, else_branch [Expr ref]Option, span SourceSpan),
    WhilePatternExpr(subject Expr ref, pattern PatternNode, body Expr ref, span SourceSpan),
    ForExpr(pattern PatternNode, iterable Expr ref, body Expr ref, span SourceSpan),
    WhenExpr(subject Expr ref, arms [WhenArm]List, span SourceSpan),
    LambdaExpr(params [LambdaParam]List, return_type [TypeNode]Option, body Expr ref, span SourceSpan),
    ImplicitMemberExpr(member_name String, args [Expr ref]List, span SourceSpan),
}

public let pattern_span(pattern PatternNode ref) SourceSpan = {
    return when pattern in {
        .Wildcard(span) then span,
        .Variable(_, _, span) then span,
        .BoolLiteral(_, span) then span,
        .IntegerLiteral(_, span) then span,
        .NegativeIntegerLiteral(_, span) then span,
        .StringLiteral(_, span) then span,
        .RuneLiteral(_, span) then span,
        .EnumCase(_, _, span) then span,
        .StructPattern(_, _, span) then span,
        .ComparisonPattern(_, _, span) then span,
        .AndPattern(_, _, span) then span,
        .OrPattern(_, _, span) then span,
        .NotPattern(_, span) then span,
    }
}

public let expr_span(expr Expr ref) SourceSpan = {
    return when expr in {
        .Identifier(_, span) then span,
        .IntegerLiteral(_, span) then span,
        .FloatLiteral(_, span) then span,
        .StringLiteral(_, span) then span,
        .RuneLiteral(_, span) then span,
        .InterpolatedString(_, span) then span,
        .BoolLiteral(_, span) then span,
        .CastExpr(_, _, span) then span,
        .Unary(_, _, span) then span,
        .RefExpr(_, span) then span,
        .PtrExpr(_, span) then span,
        .DerefExpr(_, span) then span,
        .ArithmeticExpr(_, _, _, span) then span,
        .ComparisonExpr(_, _, _, span) then span,
        .BitwiseExpr(_, _, _, span) then span,
        .AndExpr(_, _, span) then span,
        .OrExpr(_, _, span) then span,
        .RangeExpr(_, _, _, span) then span,
        .OrElseExpr(_, _, span) then span,
        .OrReturnExpr(_, span) then span,
        .AndThenExpr(_, _, span) then span,
        .IsExpr(_, _, span) then span,
        .IsNotExpr(_, _, span) then span,
        .CollectionLiteral(_, span) then span,
        .DictLiteral(_, span) then span,
        .EmptyLiteral(span) then span,
        .NamedArgument(_, _, span) then span,
        .Call(_, _, span) then span,
        .MemberExpr(_, _, span) then span,
        .MemberPath(_, _, span) then span,
        .GenericMethodCall(_, _, _, _, span) then span,
        .QualifiedMethodCall(_, _, _, _, span) then span,
        .QualifiedGenericMethodCall(_, _, _, _, _, span) then span,
        .GenericInstantiation(_, _, span) then span,
        .StaticMethodCall(_, _, _, _, span) then span,
        .SubscriptExpr(_, _, span) then span,
        .Block(_, span) then span,
        .IfExpr(_, _, _, span) then span,
        .WhileExpr(_, _, span) then span,
        .IfClauseChainExpr(_, _, _, span) then span,
        .WhileClauseChainExpr(_, _, span) then span,
        .IfPatternExpr(_, _, _, _, span) then span,
        .WhilePatternExpr(_, _, _, span) then span,
        .ForExpr(_, _, _, span) then span,
        .WhenExpr(_, _, span) then span,
        .LambdaExpr(_, _, _, span) then span,
        .ImplicitMemberExpr(_, _, span) then span,
    }
}
