// Module Resolver - resolves using declarations and builds the module tree.
// Mirrors compiler/Sources/KoralCompiler/Module/ModuleResolver.swift

using std::os { .. }

// ── ModuleError ───────────────────────────────────────────────────────────────

public type ModuleError {
    FileNotFound(file String, search_path String),
    SubmoduleNotFound(name String, parent_path String),
    MissingEntryFile(submod_name String, expected_path String),
    SuperOutOfBounds(),
    CircularDependency(path List[String]),
    InvalidModulePath(path String),
    DuplicateUsing(name String),
    ParseError(file String, message String),
    InvalidEntryFileName(filename String, reason String),
    AmbiguousModuleEntry(module_name String, file_entry String, dir_entry String),
}

given ModuleError {
    public message(self ref) String = {
        return when self in {
            .FileNotFound(file, search_path) then "File '\(file).koral' not found in '\(search_path)'",
            .SubmoduleNotFound(name, parent_path) then "Submodule '\(name)' not found (expected directory '\(parent_path)/\(name)/')",
            .MissingEntryFile(submod_name, expected_path) then "Submodule '\(submod_name)' is missing entry file '\(expected_path)'",
            .SuperOutOfBounds() then "'super' goes beyond the root module of the compilation unit",
            .CircularDependency(path) then "Circular dependency detected: \(join_path(path, " -> "))",
            .InvalidModulePath(path) then "Invalid module path: '\(path)'",
            .DuplicateUsing(name) then "Duplicate using declaration for '\(name)'",
            .ParseError(file, message) then "\(file): \(message)",
            .InvalidEntryFileName(filename, reason) then "Invalid entry file name '\(filename)': \(reason)",
            .AmbiguousModuleEntry(module_name, file_entry, dir_entry) then "Ambiguous module '\(module_name)': both file module '\(file_entry)' and directory module '\(dir_entry)' exist",
        }
    }
}

private type PendingUsing {
    Module(path_segments List[String], items List[UsingModuleItem]),
    File(file_name String),
}

// ── ModuleResolver ────────────────────────────────────────────────────────────

protected type ModuleResolverStorage(
    mut resolving_files List[String],
    mut manifest_module_aliases List[ResolvedModuleAliasRule],
)

public type ModuleResolver(protected mut storage mut ref ModuleResolverStorage)

public type ResolvedModuleGraph(
    root_module_path String,
    import_graph ImportGraph,
    loaded_nodes List[LoadedNode],
    loaded_nodes_with_path List[Pair[LoadedNode, List[String]]],
    node_source_paths List[String],
    module_paths List[List[String]],
    source_files List[String],
)

given ModuleResolver {
    public new() ModuleResolver = {
        let s = box(ModuleResolverStorage(List[String].new(), List[ResolvedModuleAliasRule].new()))
        return ModuleResolver(s)
    }

    public set_manifest_module_aliases(self mut ref, aliases List[ResolvedModuleAliasRule]) Void = {
        self.storage.manifest_module_aliases = aliases
    }

    private resolve_manifest_aliased_module_path(self ref, path_segments List[String]) List[String] = {
        if self.storage.manifest_module_aliases.is_empty() then {
            return path_segments
        }

        let mut best_match_count Int = -1
        let mut best_target = path_segments
        for rule in self.storage.manifest_module_aliases then {
            let alias_count = rule.alias_path_segments.count()
            if path_segments.count() < alias_count then {
                continue
            }

            let mut matched = true
            let mut i UInt = 0
            while i < alias_count then {
                if path_segments[i] <> rule.alias_path_segments[i] then {
                    matched = false
                    break
                }
                i += 1
            }
            if not matched then {
                continue
            }

            let alias_len = alias_count(Int)
            if alias_len <= best_match_count then {
                continue
            }

            let mut resolved = List[String].new()
            for segment in rule.target_path_segments then {
                resolved.push(segment)
            }
            let mut j = alias_count
            while j < path_segments.count() then {
                resolved.push(path_segments[j])
                j += 1
            }
            best_match_count = alias_len
            best_target = resolved
        }

        return best_target
    }

    // Locate child module entry: dir/<name>/<name>.koral or dir/<name>.koral
    // Returns Ok(path) or Error(message) if ambiguous or not found
    private locate_child_module_entry(self, parent_dir String, child_name String) Result[String] = {
        // Only valid PascalCase module identifiers participate in submodule lookup.
        // This avoids mistaking member names for module names.
        if validate_module_identifier(child_name) is .Some(_) then {
            return Result[String].Error(box("Invalid module identifier: \(child_name)"))
        }

        // Convert PascalCase identifier to snake_case file name
        let child_file_name = module_identifier_to_file_name(child_name)

        let dir_entry = parent_dir + "/" + child_file_name + "/" + child_file_name + ".koral"
        let file_entry = parent_dir + "/" + child_file_name + ".koral"

        let has_dir = path_exist(dir_entry.into_path())
        let has_file = path_exist(file_entry.into_path())

        // 歧义：两者都存在，报错
        if has_dir and has_file then {
            return Result[String].Error(box(
                ModuleError.AmbiguousModuleEntry(child_name, file_entry, dir_entry).message()
            ))
        }

        if has_dir then { return Result[String].Ok(dir_entry) }
        if has_file then { return Result[String].Ok(file_entry) }
        return Result[String].Error(box("Module '\(child_name)' not found in '\(parent_dir)'"))
    }

    // Resolve the entry file for a module starting from base_module with relative segments.
    private locate_module_entry(self, base_module ModuleInfo, relative_segments List[String]) Option[String] = {
        if relative_segments.is_empty() then { return Option[String].None() }

        // All segments must be valid PascalCase module identifiers
        for seg in relative_segments then {
            if validate_module_identifier(seg) is .Some(_) then {
                return Option[String].None()
            }
        }

        if relative_segments.count() == 1 then {
            return when self.locate_child_module_entry(base_module.directory(), relative_segments[0]) in {
                .Ok(p) then Option[String].Some(p),
                .Error(_) then Option[String].None(),
            }
        }

        // Build intermediate path
        let mut dir = base_module.directory()
        let mut i UInt = 0
        let last_idx = relative_segments.count() - 1
        for seg in relative_segments then {
            if i < last_idx then {
                dir = dir + "/" + module_identifier_to_file_name(seg)
            }
            i += 1
        }
        let last = relative_segments[last_idx]
        return when self.locate_child_module_entry(dir, last) in {
            .Ok(p) then Option[String].Some(p),
            .Error(_) then Option[String].None(),
        }
    }

    // Main entry: resolve a module from its entry file.
    public resolve_module_with_path(self, entry_file String, root_module_path Option[List[String]]) Result[CompilationUnit] = {
        let abs_path = when absolute_path(entry_file.into_path()) in {
            .Ok(p) then p.to_string(),
            .Error(e) then { return Result[CompilationUnit].Error(box("Cannot resolve path: \(entry_file)")) },
        }

        module_debug("[module] resolve_module: \(abs_path)")

        let filename = abs_path.into_path().with_ext_name("").base_name()

        if validate_module_name(filename) is .Some(reason) then {
            return Result[CompilationUnit].Error(box("Invalid entry file name '\(filename)': \(reason)"))
        }

        let mut root_path = when root_module_path in {
            .Some(path) then path,
            .None() then {
                let mut default_path = List[String].new()
                default_path.push(module_file_name_to_identifier(filename))
                yield default_path
            },
        }
        let root = ModuleInfo.new(root_path, abs_path, false)
        let unit = CompilationUnit.new(root)

        let _ = self.resolve_file(abs_path, root, unit) or return

        return Result[CompilationUnit].Ok(unit)
    }

    public resolve_module(self, entry_file String) Result[CompilationUnit] = {
        return self.resolve_module_with_path(entry_file, Option[List[String]].None())
    }

    public resolve_for_typecheck(self, entry_file String, no_std Bool) Result[ResolvedModuleGraph] = {
        let mut user_unit_opt = Option[CompilationUnit].None()
        let mut resolve_error = Option[ref Error].None()
        when self.resolve_module(entry_file) in {
            .Ok(u) then {
                user_unit_opt = Option[CompilationUnit].Some(u)
            },
            .Error(e) then {
                resolve_error = Option[ref Error].Some(e)
            },
        }
        if resolve_error is .Some(e) then {
            return Result[ResolvedModuleGraph].Error(e)
        }
        let user_unit = user_unit_opt or else {
            return Result[ResolvedModuleGraph].Error(box("module resolution failed"))
        }
        let user_unit_ref = box(user_unit)
        let std_unit = self.load_std_unit_for_typecheck(no_std, user_unit_ref.has_module("Std"))
        return Result[ResolvedModuleGraph].Ok(self.build_resolved_module_graph(std_unit, user_unit_ref))
    }

    private load_std_unit_for_typecheck(self, no_std Bool, user_has_std Bool) Option[ref CompilationUnit] = {
        if no_std or user_has_std then {
            return Option[ref CompilationUnit].None()
        }
        let std_path = find_std_entry_path() or else {
            return Option[ref CompilationUnit].None()
        }
        return when self.resolve_module(std_path) in {
            .Ok(unit) then Option[ref CompilationUnit].Some(box(unit)),
            .Error(_) then Option[ref CompilationUnit].None(),
        }
    }

    private collect_effective_std_nodes_with_path(
        self,
        std_unit Option[ref CompilationUnit],
        user_unit ref CompilationUnit,
    ) List[Pair[LoadedNode, List[String]]] = {
        let mut result = List[Pair[LoadedNode, List[String]]].new()
        when std_unit in {
            .Some(su) then {
                result = su.collect_all_nodes_with_path()
            },
            .None() then {
                if user_unit.has_module("Std") then {
                    result = user_unit.collect_nodes_with_path_for_module("Std")
                }
            },
        }
        let _ = self
        return result
    }

    private inject_std_prelude_imports(
        self,
        std_unit ref CompilationUnit,
        user_unit ref CompilationUnit,
        graph mut ref ImportGraph,
    ) Void = {
        self.inject_std_prelude_imports_from_root(std_unit.root_module().path_string(), user_unit, graph)
    }

    private inject_std_prelude_imports_from_root(
        self,
        std_root_key String,
        user_unit CompilationUnit,
        graph mut ref ImportGraph,
    ) Void = {
        let mut std_root_path = List[String].new()
        std_root_path.push(std_root_key)
        if user_unit.has_module(std_root_key) then {
            when user_unit.get_module(std_root_key) in {
                .Some(module) then {
                    std_root_path = module.path()
                },
                .None() then {},
            }
        }

        let mut seen = Set[String].new()
        let mut module_paths = List[List[String]].new()
        for pair in user_unit.collect_all_nodes_with_path() then {
            let key = join_path(pair.second, ".")
            if key <> std_root_key and not seen.contains(key) then {
                seen.insert(key)
                module_paths.push(pair.second)
            }
        }
        if user_unit.has_module(std_root_key) then {
            for pair in user_unit.collect_nodes_with_path_for_module(std_root_key) then {
                let key = join_path(pair.second, ".")
                if key <> std_root_key and not seen.contains(key) then {
                    seen.insert(key)
                    module_paths.push(pair.second)
                }
            }
        }

        for mod_path in module_paths then {
            let mut already = false
            for edge in graph.edges then {
                if string_list_eq(edge.source, mod_path) and
                   string_list_eq(edge.target, std_root_path) and
                   (when edge.kind in { .BatchImport() then true, _ then false }) and
                   (when edge.source_file in { .None() then true, _ then false }) then {
                    already = true
                    break
                }
            }
            if not already then {
                graph.add_module_import(mod_path, std_root_path, ImportKind.BatchImport(), Option[String].None())
            }
        }
        let _ = self
    }

    private collect_unique_module_paths(self, loaded_nodes_with_path List[Pair[LoadedNode, List[String]]]) List[List[String]] = {
        let mut seen = Set[String].new()
        let mut module_paths = List[List[String]].new()
        for pair in loaded_nodes_with_path then {
            let path = pair.second
            let key = join_path(path, ".")
            if not seen.contains(key) then {
                seen.insert(key)
                module_paths.push(path)
            }
        }
        let _ = self
        return module_paths
    }

    private collect_unique_sources(self, loaded_nodes List[LoadedNode]) List[String] = {
        let mut seen = Set[String].new()
        let mut source_files = List[String].new()
        for node in loaded_nodes then {
            if not seen.contains(node.source_file) then {
                seen.insert(node.source_file)
                source_files.push(node.source_file)
            }
        }
        let _ = self
        return source_files
    }

    private build_resolved_module_graph(
        self,
        std_unit Option[ref CompilationUnit],
        user_unit ref CompilationUnit,
    ) ResolvedModuleGraph = {
        let mut all_pairs = List[Pair[LoadedNode, List[String]]].new()
        for pair in self.collect_effective_std_nodes_with_path(std_unit, user_unit) then {
            all_pairs.push(pair)
        }
        for pair in user_unit.collect_all_nodes_with_path() then {
            all_pairs.push(pair)
        }

        let mut loaded_nodes = List[LoadedNode].new()
        let mut node_source_paths = List[String].new()
        for pair in all_pairs then {
            loaded_nodes.push(pair.first)
            node_source_paths.push(pair.first.source_file)
        }

        let mut merged_graph = ImportGraph.new()
        when std_unit in {
            .Some(su) then {
                merged_graph.merge(su.import_graph())
                self.inject_std_prelude_imports(su, user_unit, merged_graph.ref)
            },
            .None() then {
                if user_unit.has_module("Std") then {
                    self.inject_std_prelude_imports_from_root("Std", user_unit, merged_graph.ref)
                }
            },
        }
        merged_graph.merge(user_unit.import_graph())

        return ResolvedModuleGraph(
            user_unit.root_module().path_string(),
            merged_graph,
            loaded_nodes,
            all_pairs,
            node_source_paths,
            self.collect_unique_module_paths(all_pairs),
            self.collect_unique_sources(loaded_nodes),
        )
    }

    // Parse and process a single file into a module.
    private resolve_file(self, file String, module ModuleInfo, unit CompilationUnit) Result[Void] = {
        let normalized_file = when absolute_path(file.into_path()) in {
            .Ok(p) then p.to_string(),
            .Error(_) then file,
        }

        // Circular dependency: same compilation unit, just return
        for f in self.storage.resolving_files then {
            if f == normalized_file then {
                module_debug("[module] circular-skip: \(normalized_file)")
                return Result[Void].Ok({})
            }
        }

        self.storage.resolving_files.push(normalized_file)
        module_debug("[module] resolve_file: \(normalized_file)")
        let pending = self.collect_pending_usings(normalized_file, module) or else {
            self.storage.resolving_files.pop()
            return Result[Void].Error(it)
        }

        for using_decl in pending then {
            when using_decl in {
                .Module(path_segments, items) then {
                    self.record_module_using(path_segments, items, module, unit, normalized_file)
                },
                .File(file_name) then {
                    when self.resolve_file_merge(file_name, module, unit, normalized_file) in {
                        .Ok(_) then {},
                        .Error(e) then {
                            self.storage.resolving_files.pop()
                            return Result[Void].Error(e)
                        },
                    }
                },
            }
        }

        self.storage.resolving_files.pop()
        return Result[Void].Ok({})
    }

    private collect_pending_usings(self, normalized_file String, module ModuleInfo) Result[List[PendingUsing]] = {
        module_debug("[module] read: begin")

        let source = read_text_file(normalized_file.into_path()) or else {
            return Result[List[PendingUsing]].Error(box("Failed to read file: \(normalized_file)"))
        }
        module_debug("[module] read: done")
        module_debug("[module] lex: begin")

        let tokens = lex(source) or else {
            return Result[List[PendingUsing]].Error(box("\(normalized_file): \(it.message())"))
        }
        module_debug("[module] lex: done")
        module_debug("[module] parse: begin")

        let program = parse(tokens) or else {
            return Result[List[PendingUsing]].Error(box("\(normalized_file): \(it.message())"))
        }
        module_debug("[module] parse: done")
        module_debug("[module] decl-loop: begin")

        let mut pending = List[PendingUsing].new()
        for decl in program.declarations then {
            when decl in {
                .ModuleUsingDecl(path_segments, items, _) then {
                    pending.push(.Module(path_segments, items))
                },
                .FileUsingDecl(file_name, _) then {
                    pending.push(.File(file_name))
                },
                _ then {
                    module.add_node(decl, normalized_file)
                },
            }
        }

        module_debug("[module] decl-loop: done")
        return Result[List[PendingUsing]].Ok(pending)
    }

    private record_module_using(
        self,
        path_segments List[String],
        items List[UsingModuleItem],
        module ModuleInfo,
        unit CompilationUnit,
        current_file String,
    ) Void = {
        let import_source_file = Option[String].Some(current_file)
        let target_path = self.resolve_manifest_aliased_module_path(path_segments)
        for item in items then {
            when item.kind in {
                .AllPublic() then {
                    unit.add_import_edge(module.path(), target_path, ImportKind.BatchImport(), import_source_file)
                },
                .Symbol() then {
                    when item.name in {
                        .Some(symbol_name) then {
                            unit.add_symbol_import_edge(
                                module.path(),
                                target_path,
                                item.alias or else symbol_name,
                                ImportKind.MemberImport(),
                                import_source_file,
                                Option[String].Some(symbol_name),
                            )
                        },
                        .None() then {},
                    }
                },
            }
        }
        let _ = self
    }

    // Resolve file merge: using "file_name"
    // Resolves a normalized relative source path against the current file's directory and merges it.
    private resolve_file_merge(self, file_name String, module ModuleInfo, unit CompilationUnit, current_file String) Result[Void] = {
        let current_dir = current_file.into_path().dir_name().to_string()
        let merge_path = if file_name.ends_with(".koral") then file_name else file_name + ".koral"
        let file_path = current_dir.into_path().join(merge_path).normalize().to_string()

        if not path_exist(file_path.into_path()) then {
            return Result[Void].Error(box("File '\(file_name).koral' not found in '\(current_dir)'"))
        }

        if module.has_merged_submodule(file_path) then {
            return Result[Void].Error(box("Duplicate using: \"\(file_name)\""))
        }

        module.add_merged_submodule(file_path)
        return self.resolve_file(file_path, module, unit)
    }
}

// ── Helpers ───────────────────────────────────────────────────────────────────

// Convert PascalCase module identifier to snake_case file name
// e.g. "Primitives" -> "primitives", "BufReader" -> "buf_reader", "Std" -> "std"
public let module_identifier_to_file_name(identifier String) String = {
    if identifier.is_empty() then { return identifier }
    let mut result = String.new()
    let runes = identifier.to_runes()
    let mut first = true
    for ch in runes then {
        if ch.is_ascii_uppercase() then {
            if not first then {
                result.push_byte('_')
            }
            result.push_rune(ch.to_ascii_lowercase())
        } else {
            result.push_rune(ch)
        }
        first = false
    }
    return result
}

// Convert snake_case file name to PascalCase module identifier
// e.g. "primitives" -> "Primitives", "buf_reader" -> "BufReader"
public let module_file_name_to_identifier(filename String) String = {
    let mut result = String.new()
    let mut capitalize_next = true
    let runes = filename.to_runes()
    for ch in runes then {
        if ch == '_' then {
            capitalize_next = true
        } else if capitalize_next and ch.is_ascii_lowercase() then {
            result.push_rune(ch.to_ascii_uppercase())
            capitalize_next = false
        } else {
            result.push_rune(ch)
            capitalize_next = false
        }
    }
    return result
}

// Validate a PascalCase module identifier (used in source code)
// Returns Some(reason) if invalid, None if valid
private let validate_module_identifier(name String) Option[String] = {
    if name.is_empty() then {
        return .Some("Module name cannot be empty")
    }
    let runes = name.to_runes()
    let first = runes[0]
    if not first.is_ascii_uppercase() then {
        return .Some("Module name must start with an uppercase letter (A-Z)")
    }
    for ch in runes then {
        if not ch.is_ascii_uppercase() and not ch.is_ascii_lowercase() and not ch.is_ascii_digit() then {
            return .Some("Module name can only contain letters and digits")
        }
    }
    return .None()
}

// Remove leading "Self" or "self" segment from path
private let filter_self(segments List[String]) List[String] = {
    let mut out = List[String].new()
    let mut skip_first = true
    for seg in segments then {
        if skip_first and (seg == "Self" or seg == "self") then {
            skip_first = false
            continue
        }
        skip_first = false
        out.push(seg)
    }
    return out
}

private let module_debug(message String) Void = {
    if env("KORAL_DEBUG_MODULE") is .Some(v) and (v == "1" or v == "true" or v == "TRUE") then {
        eprintln(message)
    }
}
