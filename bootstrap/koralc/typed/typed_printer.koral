// Typed AST printer – produces a human-readable representation of a TypedProgram.

private let indent(level UInt) String = {
    let mut out = String.new()
    let mut i UInt = 0
    while i < level then {
        out.push_string("  ")
        i += 1
    }
    return out
}

private let access_text(access AccessModifier) String = {
    return when access in {
        .Public() then "public ",
        .Protected() then "",
        .Private() then "private ",
    }
}

private let typed_param_text_named(p TypedParam, type_names [UInt, String]Dict) String = {
    let mut_prefix = if p.mutable then "mut " else ""
    let separator = if p.named then ": " else " "
    return "\(mut_prefix)\(p.name)\(separator)\(type_display(p.param_type, type_names))"
}

private let typed_params_text_named(params [TypedParam]List, type_names [UInt, String]Dict) String = {
    let mut out = String.new()
    let mut first = true
    for p in params then {
        if not first then { out.push_string(", ") }
        out.push_string(typed_param_text_named(p, type_names))
        first = false
    }
    return out
}

private let typed_field_text_named(f TypedField, level UInt, type_names [UInt, String]Dict) String = {
    let mut_prefix = if f.mutable then "mut " else ""
    let separator = if f.named then ": " else " "
    return "\(indent(level))\(access_text(f.access))\(mut_prefix)\(f.name)\(separator)\(type_display(f.field_type, type_names))"
}

private let typed_enum_case_text_named(c TypedEnumCase, level UInt, type_names [UInt, String]Dict) String = {
    if c.fields.is_empty() then {
        return "\(indent(level))\(c.name)()"
    }
    let mut out = "\(indent(level))\(c.name)("
    let mut first = true
    for f in c.fields then {
        if not first then { out.push_string(", ") }
        let separator = if f.named then ": " else " "
        out.push_string("\(f.name)\(separator)\(type_display(f.field_type, type_names))")
        first = false
    }
    out.push_byte(')')
    return out
}

public let print_typed_program(program TypedProgram) Void = {
    for decl in program.declarations then {
        print_typed_decl_named(decl, 0, program.type_names)
    }
}

private let type_display(t Type, type_names [UInt, String]Dict) String = {
    return type_display_with_depth(t, type_names, (UInt)0)
}

private let type_display_with_depth(t Type, type_names [UInt, String]Dict, depth UInt) String = {
    if depth >= (UInt)12 then {
        return when t in {
            .StructureType(def_id) then when type_names.get(def_id.id) in {
                .Some(name) then name,
                .None() then "struct#\(def_id.id)",
            },
            .EnumType(def_id) then when type_names.get(def_id.id) in {
                .Some(name) then name,
                .None() then "enum#\(def_id.id)",
            },
            .OpaqueType(def_id) then "opaque#\(def_id.id)",
            .GenericStruct(template, _) then "[...]\(template)",
            .GenericEnum(template, _) then "[...]\(template)",
            .FunctionType(_, _) then "[...]Func",
            .ReferenceType(_) then "... ref",
            .PointerType(_) then "... ptr",
            .WeakReferenceType(_) then "... weakref",
            .TraitObject(trait_name) then trait_name,
            .TypeVar(tv) then tv.val.display(),
            .Unknown() then "?",
            _ then type_to_string(t),
        }
    }

    return when t in {
        .IntType() then "Int",
        .Int8Type() then "Int8",
        .Int16Type() then "Int16",
        .Int32Type() then "Int32",
        .Int64Type() then "Int64",
        .UIntType() then "UInt",
        .UInt8Type() then "UInt8",
        .UInt16Type() then "UInt16",
        .UInt32Type() then "UInt32",
        .UInt64Type() then "UInt64",
        .Float32Type() then "Float32",
        .Float64Type() then "Float64",
        .BoolType() then "Bool",
        .VoidType() then "Void",
        .NeverType() then "Never",
        .FunctionType(param_types, return_type) then {
            let mut out = "["
            let mut first = true
            for param_type in param_types then {
                if not first then { out.push_string(", ") }
                out.push_string(type_display_with_depth(param_type.val, type_names, depth + (UInt)1))
                first = false
            }
            out.push_string("]Func -> ")
            out.push_string(type_display_with_depth(return_type.val, type_names, depth + (UInt)1))
            yield out
        },
        .StructureType(def_id) then when type_names.get(def_id.id) in {
            .Some(name) then name,
            .None() then "struct#\(def_id.id)",
        },
        .EnumType(def_id) then when type_names.get(def_id.id) in {
            .Some(name) then name,
            .None() then "enum#\(def_id.id)",
        },
        .ReferenceType(inner) then "\(type_display_with_depth(inner.val, type_names, depth + (UInt)1)) ref",
        .PointerType(inner) then "\(type_display_with_depth(inner.val, type_names, depth + (UInt)1)) ptr",
        .WeakReferenceType(inner) then "\(type_display_with_depth(inner.val, type_names, depth + (UInt)1)) weakref",
        .OpaqueType(def_id) then "opaque#\(def_id.id)",
        .GenericParameter(name) then name,
        .GenericStruct(template, args) then {
            let mut out = "["
            let mut first = true
            for arg in args then {
                if not first then { out.push_string(", ") }
                out.push_string(type_display_with_depth(arg.val, type_names, depth + (UInt)1))
                first = false
            }
            out.push_byte(']')
            out.push_string(template)
            yield out
        },
        .GenericEnum(template, args) then {
            let mut out = "["
            let mut first = true
            for arg in args then {
                if not first then { out.push_string(", ") }
                out.push_string(type_display_with_depth(arg.val, type_names, depth + (UInt)1))
                first = false
            }
            out.push_byte(']')
            out.push_string(template)
            yield out
        },
        .TraitObject(trait_name) then trait_name,
        .TypeVar(tv) then tv.val.display(),
        .Unknown() then "?",
    }
}

private let print_typed_decl_named(decl TypedDecl, level UInt, type_names [UInt, String]Dict) Void = {
    when decl in {
        .LetDecl(access, name, mutable, decl_type, initializer, span) then {
            let mut_kw = if mutable then "mut " else ""
            println("\(indent(level))\(access_text(access))let \(mut_kw)\(name): \(type_display(decl_type, type_names)) =")
            print_typed_expr_named(initializer, level + 1, type_names)
        },
        .FunctionDecl(access, name, params, return_type, body, span) then {
            println("\(indent(level))\(access_text(access))fn \(name)(\(typed_params_text_named(params, type_names))): \(type_display(return_type, type_names)) =")
            print_typed_expr_named(body, level + 1, type_names)
        },
        .GenericFunctionDecl(access, name, params, return_type, body, span) then {
            println("\(indent(level))\(access_text(access))generic fn \(name)(\(typed_params_text_named(params, type_names))): \(type_display(return_type, type_names)) =")
            print_typed_expr_named(body, level + 1, type_names)
        },
        .IntrinsicFunctionDecl(access, name, params, return_type, span) then {
            println("\(indent(level))\(access_text(access))intrinsic fn \(name)(\(typed_params_text_named(params, type_names))): \(type_display(return_type, type_names))")
        },
        .ForeignFunctionDecl(access, name, params, return_type, span) then {
            println("\(indent(level))\(access_text(access))foreign fn \(name)(\(typed_params_text_named(params, type_names))): \(type_display(return_type, type_names))")
        },
        .ForeignLetDecl(access, name, mutable, decl_type, span) then {
            let mut_kw = if mutable then "mut " else ""
            println("\(indent(level))\(access_text(access))foreign let \(mut_kw)\(name): \(type_display(decl_type, type_names))")
        },
        .TypeStructDecl(access, name, fields, span) then {
            println("\(indent(level))\(access_text(access))struct \(name) {")
            for f in fields then {
                println(typed_field_text_named(f, level + 1, type_names))
            }
            println("\(indent(level))}")
        },
        .GenericTypeStructDecl(access, name, fields, span) then {
            println("\(indent(level))\(access_text(access))generic struct \(name) {")
            for f in fields then {
                println(typed_field_text_named(f, level + 1, type_names))
            }
            println("\(indent(level))}")
        },
        .TypeEnumDecl(access, name, cases, span) then {
            println("\(indent(level))\(access_text(access))enum \(name) {")
            for c in cases then {
                println(typed_enum_case_text_named(c, level + 1, type_names))
            }
            println("\(indent(level))}")
        },
        .GenericTypeEnumDecl(access, name, cases, span) then {
            println("\(indent(level))\(access_text(access))generic enum \(name) {")
            for c in cases then {
                println(typed_enum_case_text_named(c, level + 1, type_names))
            }
            println("\(indent(level))}")
        },
        .TypeAliasDecl(access, name, target, span) then {
            println("\(indent(level))\(access_text(access))type alias \(name) = \(type_display(target, type_names))")
        },
        .IntrinsicTypeDecl(access, name, span) then {
            println("\(indent(level))\(access_text(access))intrinsic type \(name)")
        },
        .ForeignTypeDecl(access, name, fields, span) then {
            when fields in {
                .Some(typed_fields) then {
                    if typed_fields.is_empty() then {
                        println("\(indent(level))\(access_text(access))foreign type \(name)")
                    } else {
                        println("\(indent(level))\(access_text(access))foreign type \(name) {")
                        for field in typed_fields then {
                            let mut_kw = if field.mutable then "mut " else ""
                            println("\(indent(level + 1))\(access_text(field.access))let \(mut_kw)\(field.name): \(type_display(field.field_type, type_names))")
                        }
                        println("\(indent(level))}")
                    }
                },
                .None() then {
                    println("\(indent(level))\(access_text(access))foreign type \(name)")
                },
            }
        },
        .UsingDecl(access, path_segments, span) then {
            let mut path = String.new()
            let mut first = true
            for seg in path_segments then {
                if not first then { path.push_byte('.') }
                path.push_string(seg)
                first = false
            }
            println("\(indent(level))using \(path)")
        },
        .ForeignUsingDecl(access, library, span) then {
            println("\(indent(level))foreign using \(library)")
        },
        .TraitDecl(access, name, members, span) then {
            println("\(indent(level))\(access_text(access))trait \(name) {")
            for m in members then {
                println("\(indent(level + 1))fn \(m.name)(\(typed_params_text_named(m.params, type_names))): \(type_display(m.return_type, type_names))")
            }
            println("\(indent(level))}")
        },
        .GivenDecl(target_type, members, span) then {
            println("\(indent(level))given \(type_display(target_type, type_names)) {")
            print_given_members_named(members, level + 1, type_names)
            println("\(indent(level))}")
        },
        .GivenTraitDecl(target_type, trait_name, trait_args, members, span) then {
            let mut trait_args_display = String.new()
            let mut first = true
            for trait_arg in trait_args then {
                if not first then { trait_args_display.push_string(", ") }
                trait_args_display.push_string(type_display(trait_arg, type_names))
                first = false
            }
            let trait_header = if trait_args_display.is_empty()
                then trait_name
                else "[\(trait_args_display)]\(trait_name)"
            println("\(indent(level))given \(type_display(target_type, type_names)) \(trait_header) {")
            print_given_members_named(members, level + 1, type_names)
            println("\(indent(level))}")
        },
        .IntrinsicGivenDecl(target_type, members, span) then {
            println("\(indent(level))intrinsic given \(type_display(target_type, type_names)) {")
            print_given_members_named(members, level + 1, type_names)
            println("\(indent(level))}")
        },
    }
}

private let print_given_members_named(members [TypedGivenMember]List, level UInt, type_names [UInt, String]Dict) Void = {
    for m in members then {
        when m.body in {
            .Some(b) then {
                println("\(indent(level))fn \(m.name)(\(typed_params_text_named(m.params, type_names))): \(type_display(m.return_type, type_names)) =")
                print_typed_expr_named(b, level + 1, type_names)
            },
            .None() then {
                println("\(indent(level))fn \(m.name)(\(typed_params_text_named(m.params, type_names))): \(type_display(m.return_type, type_names))")
            },
        }
    }
}

private let print_typed_expr_named(expr TypedExpr ref, level UInt, type_names [UInt, String]Dict) Void = {
    let prefix = indent(level)
    let type_ann = " :: \(type_display(expr.expr_type, type_names))"
    when expr.expr_kind in {
        .Variable(symbol) then {
            println("\(prefix)Variable(\(symbol.name) #\(symbol.def_id.id))\(type_ann)")
        },
        .IntegerLiteral(value) then {
            println("\(prefix)Int(\(value))\(type_ann)")
        },
        .FloatLiteral(value) then {
            println("\(prefix)Float(\(value))\(type_ann)")
        },
        .StringLiteral(value) then {
            println("\(prefix)String(\"\(value)\")\(type_ann)")
        },
        .BoolLiteral(value) then {
            let v = if value then "true" else "false"
            println("\(prefix)Bool(\(v))\(type_ann)")
        },
        .CastExpr(target_type, inner) then {
            println("\(prefix)Cast(\(type_display(target_type, type_names)))\(type_ann)")
            print_typed_expr_named(inner, level + 1, type_names)
        },
        .Unary(op, inner) then {
            println("\(prefix)Unary\(type_ann)")
            print_typed_expr_named(inner, level + 1, type_names)
        },
        .RefExpr(inner) then {
            println("\(prefix)Ref\(type_ann)")
            print_typed_expr_named(inner, level + 1, type_names)
        },
        .PtrExpr(inner) then {
            println("\(prefix)Ptr\(type_ann)")
            print_typed_expr_named(inner, level + 1, type_names)
        },
        .DerefExpr(inner) then {
            println("\(prefix)Deref\(type_ann)")
            print_typed_expr_named(inner, level + 1, type_names)
        },
        .ArithmeticExpr(left, op, right) then {
            println("\(prefix)Arithmetic\(type_ann)")
            print_typed_expr_named(left, level + 1, type_names)
            print_typed_expr_named(right, level + 1, type_names)
        },
        .ComparisonExpr(left, op, right) then {
            println("\(prefix)Comparison\(type_ann)")
            print_typed_expr_named(left, level + 1, type_names)
            print_typed_expr_named(right, level + 1, type_names)
        },
        .BitwiseExpr(left, op, right) then {
            println("\(prefix)Bitwise\(type_ann)")
            print_typed_expr_named(left, level + 1, type_names)
            print_typed_expr_named(right, level + 1, type_names)
        },
        .AndExpr(left, right) then {
            println("\(prefix)And\(type_ann)")
            print_typed_expr_named(left, level + 1, type_names)
            print_typed_expr_named(right, level + 1, type_names)
        },
        .OrExpr(left, right) then {
            println("\(prefix)Or\(type_ann)")
            print_typed_expr_named(left, level + 1, type_names)
            print_typed_expr_named(right, level + 1, type_names)
        },
        .RangeExpr(op, left, right) then {
            println("\(prefix)Range\(type_ann)")
        },
        .CollectionLiteral(elements) then {
            println("\(prefix)Collection[\(elements.count())]\(type_ann)")
        },
        .DictLiteral(entries) then {
            println("\(prefix)Dict[\(entries.count())]\(type_ann)")
        },
        .EmptyLiteral() then {
            println("\(prefix)Empty\(type_ann)")
        },
        .Call(callee, args) then {
            println("\(prefix)Call\(type_ann)")
            print_typed_expr_named(callee, level + 1, type_names)
            for a in args then {
                print_typed_expr_named(a, level + 1, type_names)
            }
        },
        .IntrinsicCall(node) then {
            when node in {
                .AllocMemory(count, result_type) then {
                    println("\(prefix)Intrinsic.alloc_memory -> \(type_display(result_type, type_names))\(type_ann)")
                    print_typed_expr_named(count, level + 1, type_names)
                },
                .DeallocMemory(pointer_expr) then {
                    println("\(prefix)Intrinsic.dealloc_memory\(type_ann)")
                    print_typed_expr_named(pointer_expr, level + 1, type_names)
                },
                .CopyMemory(dest, source, count) then {
                    println("\(prefix)Intrinsic.copy_memory\(type_ann)")
                    print_typed_expr_named(dest, level + 1, type_names)
                    print_typed_expr_named(source, level + 1, type_names)
                    print_typed_expr_named(count, level + 1, type_names)
                },
                .MoveMemory(dest, source, count) then {
                    println("\(prefix)Intrinsic.move_memory\(type_ann)")
                    print_typed_expr_named(dest, level + 1, type_names)
                    print_typed_expr_named(source, level + 1, type_names)
                    print_typed_expr_named(count, level + 1, type_names)
                },
                .InitMemory(pointer_expr, value_expr) then {
                    println("\(prefix)Intrinsic.init_memory\(type_ann)")
                    print_typed_expr_named(pointer_expr, level + 1, type_names)
                    print_typed_expr_named(value_expr, level + 1, type_names)
                },
                .DeinitMemory(pointer_expr) then {
                    println("\(prefix)Intrinsic.deinit_memory\(type_ann)")
                    print_typed_expr_named(pointer_expr, level + 1, type_names)
                },
                .TakeMemory(pointer_expr, result_type) then {
                    println("\(prefix)Intrinsic.take_memory -> \(type_display(result_type, type_names))\(type_ann)")
                    print_typed_expr_named(pointer_expr, level + 1, type_names)
                },
                .NullPtr(result_type) then {
                    println("\(prefix)Intrinsic.null_ptr -> \(type_display(result_type, type_names))\(type_ann)")
                },
            }
        },
        .MemberExpr(base, member) then {
            println("\(prefix)Member.\(member)\(type_ann)")
            print_typed_expr_named(base, level + 1, type_names)
        },
        .MemberPath(base, path) then {
            let mut path_str = String.new()
            let mut first = true
            for seg in path then {
                if not first then { path_str.push_byte('.') }
                path_str.push_string(seg)
                first = false
            }
            println("\(prefix)MemberPath.\(path_str)\(type_ann)")
            print_typed_expr_named(base, level + 1, type_names)
        },
        .Block(statements) then {
            println("\(prefix)Block\(type_ann)")
            for stmt in statements then {
                print_typed_stmt_named(stmt, level + 1, type_names)
            }
        },
        .IfExpr(condition, then_branch, else_branch) then {
            println("\(prefix)If\(type_ann)")
            print_typed_expr_named(condition, level + 1, type_names)
            print_typed_expr_named(then_branch, level + 1, type_names)
            if else_branch is .Some(eb) then { print_typed_expr_named(eb, level + 1, type_names) }
        },
        .WhileExpr(condition, body) then {
            println("\(prefix)While\(type_ann)")
            print_typed_expr_named(condition, level + 1, type_names)
            print_typed_expr_named(body, level + 1, type_names)
        },
        .IsExpr(subject, pattern) then {
            println("\(prefix)Is\(type_ann)")
            print_typed_expr_named(subject, level + 1, type_names)
        },
        .IsNotExpr(subject, pattern) then {
            println("\(prefix)IsNot\(type_ann)")
            print_typed_expr_named(subject, level + 1, type_names)
        },
        .IfPatternExpr(subject, pattern, then_branch, else_branch) then {
            println("\(prefix)IfPattern\(type_ann)")
            print_typed_expr_named(subject, level + 1, type_names)
            print_typed_expr_named(then_branch, level + 1, type_names)
            if else_branch is .Some(eb) then { print_typed_expr_named(eb, level + 1, type_names) }
        },
        .WhilePatternExpr(subject, pattern, body) then {
            println("\(prefix)WhilePattern\(type_ann)")
            print_typed_expr_named(subject, level + 1, type_names)
            print_typed_expr_named(body, level + 1, type_names)
        },
        .ForExpr(pattern, iterable, body) then {
            println("\(prefix)For\(type_ann)")
            print_typed_expr_named(iterable, level + 1, type_names)
            print_typed_expr_named(body, level + 1, type_names)
        },
        .WhenExpr(subject, arms) then {
            println("\(prefix)When\(type_ann)")
            print_typed_expr_named(subject, level + 1, type_names)
            for arm in arms then {
                println("\(indent(level + 1))arm :: \(type_display(arm.arm_type, type_names))")
                print_typed_expr_named(arm.body, level + 2, type_names)
            }
        },
        .LambdaExpr(params, return_type, body) then {
            println("\(prefix)Lambda(\(typed_params_text_named(params, type_names))): \(type_display(return_type, type_names))\(type_ann)")
            print_typed_expr_named(body, level + 1, type_names)
        },
        .ImplicitMemberExpr(member_name, args) then {
            println("\(prefix)ImplicitMember.\(member_name)\(type_ann)")
        },
        .StaticMethodCall(receiver_type, method, args) then {
            println("\(prefix)StaticCall \(type_display(receiver_type, type_names)).\(method.name)\(type_ann)")
        },
        .GenericMethodCall(base, receiver_type, method, args, dispatch_callsite) then {
            let callsite_text = when dispatch_callsite in {
                .Some(def_id) then " callsite=\(def_id.id)",
                .None() then "",
            }
            println("\(prefix)GenericMethodCall.\(method.name) receiver=\(type_display(receiver_type, type_names))\(callsite_text)\(type_ann)")
            print_typed_expr_named(base, level + 1, type_names)
        },
        .TraitObjectConversion(inner, trait_type, concrete_type) then {
            println("\(prefix)TraitObjectConversion concrete=\(type_display(concrete_type, type_names)) as \(type_display(trait_type, type_names))\(type_ann)")
            print_typed_expr_named(inner, level + 1, type_names)
        },
        .QualifiedMethodCall(base, trait_type, method, args, dispatch_callsite) then {
            let callsite_text = when dispatch_callsite in {
                .Some(def_id) then " callsite=\(def_id.id)",
                .None() then "",
            }
            println("\(prefix)QualifiedCall \(type_display(trait_type, type_names)).\(method.name)\(callsite_text)\(type_ann)")
            print_typed_expr_named(base, level + 1, type_names)
        },
        .GenericInstantiation(base_type, type_args) then {
            println("\(prefix)GenericInst \(type_display(base_type, type_names))\(type_ann)")
        },
    }
}

private let print_typed_stmt_named(stmt TypedStatement, level UInt, type_names [UInt, String]Dict) Void = {
    let prefix = indent(level)
    when stmt in {
        .LetStmt(symbol, value, span) then {
            let mut_kw = if symbol.is_mutable() then "mut " else ""
            println("\(prefix)let \(mut_kw)\(symbol.name) #\(symbol.def_id.id): \(type_display(symbol.symbol_type, type_names))")
            print_typed_expr_named(value, level + 1, type_names)
        },
        .PairLetStmt(first_symbol, second_symbol, value, span) then {
            println("\(prefix)pair-let")
            println("\(prefix)  first: \(typed_pair_binding_text(first_symbol, type_names))")
            println("\(prefix)  second: \(typed_pair_binding_text(second_symbol, type_names))")
            print_typed_expr_named(value, level + 1, type_names)
        },
        .AssignmentStmt(target, value, span) then {
            println("\(prefix)assign")
            print_typed_expr_named(target, level + 1, type_names)
            print_typed_expr_named(value, level + 1, type_names)
        },
        .ExprStmt(expr, span) then {
            print_typed_expr_named(expr, level, type_names)
        },
        .ReturnStmt(value, span) then {
            println("\(prefix)return")
            if value is .Some(v) then { print_typed_expr_named(v, level + 1, type_names) }
        },
        .BreakStmt(span) then {
            println("\(prefix)break")
        },
        .ContinueStmt(span) then {
            println("\(prefix)continue")
        },
        .FinallyStmt(expr, span) then {
            println("\(prefix)finally")
            print_typed_expr_named(expr, level + 1, type_names)
        },
        .YieldStmt(expr, span) then {
            println("\(prefix)yield")
            print_typed_expr_named(expr, level + 1, type_names)
        },
    }
}

private let typed_pair_binding_text(binding [Symbol ref]Option, type_names [UInt, String]Dict) String = {
    return when binding in {
        .Some(symbol) then {
            let mut_kw = if symbol.is_mutable() then "mut " else ""
            yield "\(mut_kw)\(symbol.name) #\(symbol.def_id.id): \(type_display(symbol.symbol_type, type_names))"
        },
        .None() then "_",
    }
}
