public type TokenKind {
    Identifier(name String),
    IntegerLiteral(value String),
    DurationLiteral(value String, unit String),
    FloatLiteral(value String),
    StringLiteral(value String),
    RuneLiteral(value String),

    KwLet(),
    KwMut(),
    KwType(),
    KwIf(),
    KwWhile(),
    KwFor(),
    KwWhen(),
    KwIs(),
    KwIn(),
    KwAs(),
    KwRef(),
    KwPtr(),
    KwDeref(),
    KwGiven(),
    KwTrait(),
    KwIntrinsic(),
    KwForeign(),
    KwUsing(),
    KwPrivate(),
    KwProtected(),
    KwPublic(),
    KwWeakref(),
    KwSelf(),
    KwSuper(),
    KwSelfType(),
    KwReturn(),
    KwBreak(),
    KwContinue(),
    KwFinally(),
    KwYield(),
    KwThen(),
    KwElse(),
    KwAnd(),
    KwOr(),
    KwNot(),
    KwTrue(),
    KwFalse(),

    Plus(),
    Minus(),
    Star(),
    Slash(),
    Percent(),
    Ampersand(),
    Pipe(),
    Caret(),
    Tilde(),
    LeftShift(),
    RightShift(),

    Assign(),
    PlusAssign(),
    MinusAssign(),
    StarAssign(),
    SlashAssign(),
    PercentAssign(),
    AmpersandAssign(),
    PipeAssign(),
    CaretAssign(),
    LeftShiftAssign(),
    RightShiftAssign(),
    EqualEqual(),
    NotEqual(),
    Greater(),
    Less(),
    GreaterEqual(),
    LessEqual(),

    Comma(),
    Dot(),
    Colon(),
    Semicolon(),

    LParen(),
    RParen(),
    LBracket(),
    RBracket(),
    LBrace(),
    RBrace(),

    Range(),
    RangeLess(),
    LessRange(),
    LessRangeLess(),
    UnboundedRange(),
    LessUnboundedRange(),
    UnboundedRangeLess(),
    FullRange(),

    Arrow(),

    Eof(),
}

public type Token(
    kind TokenKind,
    line UInt,
    column UInt,
    has_newline_before Bool,
)
