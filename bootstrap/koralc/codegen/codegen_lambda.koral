// codegen_lambda.koral - Lambda/闭包代码生成
//
// 实现 CodeGen 的 Lambda 表达式代码生成方法：
// - generate_lambda_expression: 区分无捕获和有捕获两种情况
// - generate_no_capture_lambda: 生成静态函数 + Closure{fn, NULL, NULL}
// - generate_capture_lambda: 生成 env struct、lambda 函数（首参 void* __env）、env drop 函数
// - generate_lambda_env_struct: 包含 __refcount 和所有捕获变量
// - 保存/恢复状态（buffer, indent, scope stack）
// - captured_var_aliases 机制：将捕获变量访问重定向到 __captured->{field}
//
// 参照 compiler/Sources/KoralCompiler/CodeGen/CodeGenLambda.swift
//
// Requirements: 8.1, 8.2, 8.3, 8.4, 8.5

given CodeGen {

    // ── Lambda 名称生成 ───────────────────────────────────────────────────────

    /// 生成唯一的 Lambda 函数名
    next_lambda_name(self ref) String = {
        let name = "__koral_lambda_\(self.lambda_counter)"
        self.lambda_counter += 1
        return name
    }

    // ── 捕获变量检测 ──────────────────────────────────────────────────────────

    /// 扫描 Lambda 体，收集所有被捕获的变量（不在参数列表中的外部变量）
    ///
    /// 返回捕获变量的 Symbol 列表（去重）
    collect_captured_variables(self, params [TypedParam]List, body TypedExpr ref) [Symbol]List = {
        // 收集参数的 def_id 集合（用于排除）
        let mut param_def_ids = [UInt]Set.new()
        for p in params then {
            // 参数的 def_id 在 lambda scope 中分配，通过名称匹配
            // 我们通过扫描 body 中的 Variable 节点来找到捕获变量
        }

        let mut captured = [Symbol]List.new()
        let mut seen_ids = [UInt]Set.new()
        let mut param_names = [String]Set.new()
        for p in params then {
            param_names.insert(p.name)
        }

        self.collect_captured_in_expr(body, param_names, seen_ids, captured)
        return captured
    }

    collect_pattern_binding_names(self, pattern PatternNode ref, names [String]Set ref) Void = {
        when deref pattern in {
            .Variable(name, _, _) then {
                names.insert(name)
            },
            .UnionCase(_, elements, _) then {
                for element in elements then {
                    self.collect_pattern_binding_names(element, names)
                }
            },
            .StructPattern(_, elements, _) then {
                for element in elements then {
                    self.collect_pattern_binding_names(element, names)
                }
            },
            .AndPattern(left, right, _) then {
                self.collect_pattern_binding_names(left, names)
                self.collect_pattern_binding_names(right, names)
            },
            .OrPattern(left, right, _) then {
                self.collect_pattern_binding_names(left, names)
                self.collect_pattern_binding_names(right, names)
            },
            .NotPattern(inner, _) then {
                self.collect_pattern_binding_names(inner, names)
            },
            _ then {},
        }
    }

    /// 递归扫描表达式，收集捕获变量
    ///
    /// seen_ids 同时用于：
    /// 1. 避免重复捕获同一变量
    /// 2. 标记在 lambda 体内部声明的局部变量（不应被捕获）
    collect_captured_in_expr(self, expr TypedExpr ref, param_names [String]Set, seen_ids [UInt]Set ref, captured [Symbol]List ref) Void = {
        when expr.expr_kind in {
            .Variable(symbol) then {
                // 只捕获局部变量（非函数、非类型符号）
                let is_local_var = when symbol.kind in {
                    .Variable(_) then true,
                    _ then false,
                }
                if is_local_var and not param_names.contains(symbol.name) and not seen_ids.contains(symbol.def_id.id) then {
                    // 检查是否为全局变量（全局变量不需要捕获）
                    let module_path = self.def_id_map.get_module_path(symbol.def_id) or else [String]List.new()
                    let source_file = self.def_id_map.get_source_file(symbol.def_id) or else ""
                    let is_global = not module_path.is_empty() or not source_file.is_empty()
                    if not is_global then {
                        // 检查是否为 pattern binding alias（模式绑定别名不应被捕获）
                        let c_ident = self.c_identifier_for_symbol(symbol)
                        let is_pattern_binding = when self.pattern_binding_aliases.get(c_ident) in {
                            .Some(_) then true,
                            .None() then false,
                        }
                        if not is_pattern_binding then {
                            seen_ids.insert(symbol.def_id.id)
                            captured.push(symbol)
                        }
                    }
                }
            },
            .LambdaExpr(inner_params, _, inner_body) then {
                // 嵌套 Lambda：收集其捕获变量（排除内层参数）
                let mut inner_param_names = param_names
                for p in inner_params then {
                    inner_param_names.insert(p.name)
                }
                self.collect_captured_in_expr(inner_body, inner_param_names, seen_ids, captured)
            },
            .Block(statements) then {
                // 顺序处理语句，LetStmt 声明的变量加入 seen_ids 以避免被捕获
                for stmt in statements then {
                    when stmt in {
                        .LetStmt(symbol, value_ref, _) then {
                            // 先扫描初始化表达式（变量尚未声明）
                            self.collect_captured_in_expr(value_ref, param_names, seen_ids, captured)
                            // 将声明的变量标记为局部变量（不应被捕获）
                            seen_ids.insert(symbol.def_id.id)
                        },
                        .PairLetStmt(first_symbol, second_symbol, value_ref, _) then {
                            self.collect_captured_in_expr(value_ref, param_names, seen_ids, captured)
                            when first_symbol in {
                                .Some(symbol) then {
                                    seen_ids.insert(symbol.def_id.id)
                                },
                                .None() then {},
                            }
                            when second_symbol in {
                                .Some(symbol) then {
                                    seen_ids.insert(symbol.def_id.id)
                                },
                                .None() then {},
                            }
                        },
                        _ then {
                            self.collect_captured_in_stmt(stmt, param_names, seen_ids, captured)
                        },
                    }
                }
            },
            .IfExpr(cond_ref, then_ref, else_opt) then {
                self.collect_captured_in_expr(cond_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(then_ref, param_names, seen_ids, captured)
                when else_opt in {
                    .Some(else_ref) then {
                        self.collect_captured_in_expr(else_ref, param_names, seen_ids, captured)
                    },
                    .None() then {},
                }
            },
            .WhileExpr(cond_ref, body_ref) then {
                self.collect_captured_in_expr(cond_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(body_ref, param_names, seen_ids, captured)
            },
            .Call(callee_ref, args) then {
                self.collect_captured_in_expr(callee_ref, param_names, seen_ids, captured)
                for arg in args then {
                    self.collect_captured_in_expr(arg, param_names, seen_ids, captured)
                }
            },
            .MemberExpr(base_ref, _) then {
                self.collect_captured_in_expr(base_ref, param_names, seen_ids, captured)
            },
            .MemberPath(base_ref, _) then {
                self.collect_captured_in_expr(base_ref, param_names, seen_ids, captured)
            },
            .ArithmeticExpr(left_ref, _, right_ref) then {
                self.collect_captured_in_expr(left_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(right_ref, param_names, seen_ids, captured)
            },
            .ComparisonExpr(left_ref, _, right_ref) then {
                self.collect_captured_in_expr(left_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(right_ref, param_names, seen_ids, captured)
            },
            .BitwiseExpr(left_ref, _, right_ref) then {
                self.collect_captured_in_expr(left_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(right_ref, param_names, seen_ids, captured)
            },
            .AndExpr(left_ref, right_ref) then {
                self.collect_captured_in_expr(left_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(right_ref, param_names, seen_ids, captured)
            },
            .OrExpr(left_ref, right_ref) then {
                self.collect_captured_in_expr(left_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(right_ref, param_names, seen_ids, captured)
            },
            .Unary(_, inner_ref) then {
                self.collect_captured_in_expr(inner_ref, param_names, seen_ids, captured)
            },
            .CastExpr(_, inner_ref) then {
                self.collect_captured_in_expr(inner_ref, param_names, seen_ids, captured)
            },
            .RefExpr(inner_ref) then {
                self.collect_captured_in_expr(inner_ref, param_names, seen_ids, captured)
            },
            .DerefExpr(inner_ref) then {
                self.collect_captured_in_expr(inner_ref, param_names, seen_ids, captured)
            },
            .PtrExpr(inner_ref) then {
                self.collect_captured_in_expr(inner_ref, param_names, seen_ids, captured)
            },
            .SubscriptExpr(base_ref, args) then {
                self.collect_captured_in_expr(base_ref, param_names, seen_ids, captured)
                for arg in args then {
                    self.collect_captured_in_expr(arg, param_names, seen_ids, captured)
                }
            },
            .WhenExpr(subject_ref, arms) then {
                self.collect_captured_in_expr(subject_ref, param_names, seen_ids, captured)
                for arm in arms then {
                    let mut arm_local_names = param_names
                    self.collect_pattern_binding_names(arm.pattern, arm_local_names)
                    self.collect_captured_in_expr(arm.body, arm_local_names, seen_ids, captured)
                }
            },
            .IsExpr(subject_ref, _) then {
                self.collect_captured_in_expr(subject_ref, param_names, seen_ids, captured)
            },
            .IsNotExpr(subject_ref, _) then {
                self.collect_captured_in_expr(subject_ref, param_names, seen_ids, captured)
            },
            .IfPatternExpr(subject_ref, _, then_ref, else_opt) then {
                self.collect_captured_in_expr(subject_ref, param_names, seen_ids, captured)
                let mut then_local_names = param_names
                when expr.expr_kind in {
                    .IfPatternExpr(_, pattern, _, _) then {
                        self.collect_pattern_binding_names(pattern, then_local_names)
                    },
                    _ then {},
                }
                self.collect_captured_in_expr(then_ref, then_local_names, seen_ids, captured)
                when else_opt in {
                    .Some(else_ref) then {
                        self.collect_captured_in_expr(else_ref, param_names, seen_ids, captured)
                    },
                    .None() then {},
                }
            },
            .WhilePatternExpr(subject_ref, pattern, body_ref) then {
                self.collect_captured_in_expr(subject_ref, param_names, seen_ids, captured)
                let mut body_local_names = param_names
                self.collect_pattern_binding_names(pattern, body_local_names)
                self.collect_captured_in_expr(body_ref, body_local_names, seen_ids, captured)
            },
            .ForExpr(pattern, iterable_ref, body_ref) then {
                self.collect_captured_in_expr(iterable_ref, param_names, seen_ids, captured)
                let mut body_local_names = param_names
                self.collect_pattern_binding_names(pattern, body_local_names)
                self.collect_captured_in_expr(body_ref, body_local_names, seen_ids, captured)
            },
            .ImplicitMemberExpr(_, args) then {
                for arg in args then {
                    self.collect_captured_in_expr(arg, param_names, seen_ids, captured)
                }
            },
            .StaticMethodCall(_, _, args) then {
                for arg in args then {
                    self.collect_captured_in_expr(arg, param_names, seen_ids, captured)
                }
            },
            .GenericMethodCall(base_ref, _, _, args) then {
                self.collect_captured_in_expr(base_ref, param_names, seen_ids, captured)
                for arg in args then {
                    self.collect_captured_in_expr(arg, param_names, seen_ids, captured)
                }
            },
            .QualifiedMethodCall(base_ref, _, _, args) then {
                self.collect_captured_in_expr(base_ref, param_names, seen_ids, captured)
                for arg in args then {
                    self.collect_captured_in_expr(arg, param_names, seen_ids, captured)
                }
            },
            .CollectionLiteral(elements) then {
                for elem in elements then {
                    self.collect_captured_in_expr(elem, param_names, seen_ids, captured)
                }
            },
            .MapLiteral(entries) then {
                for entry in entries then {
                    self.collect_captured_in_expr(entry.first, param_names, seen_ids, captured)
                    self.collect_captured_in_expr(entry.second, param_names, seen_ids, captured)
                }
            },
            .RangeExpr(_, left_opt, right_opt) then {
                when left_opt in {
                    .Some(left_ref) then {
                        self.collect_captured_in_expr(left_ref, param_names, seen_ids, captured)
                    },
                    .None() then {},
                }
                when right_opt in {
                    .Some(right_ref) then {
                        self.collect_captured_in_expr(right_ref, param_names, seen_ids, captured)
                    },
                    .None() then {},
                }
            },
            _ then {},
        }
    }

    /// 递归扫描语句，收集捕获变量
    collect_captured_in_stmt(self, stmt TypedStatement, param_names [String]Set, seen_ids [UInt]Set ref, captured [Symbol]List ref) Void = {
        when stmt in {
            .LetStmt(_, value_ref, _) then {
                self.collect_captured_in_expr(value_ref, param_names, seen_ids, captured)
            },
            .PairLetStmt(_, _, value_ref, _) then {
                self.collect_captured_in_expr(value_ref, param_names, seen_ids, captured)
            },
            .AssignmentStmt(target_ref, value_ref, _) then {
                self.collect_captured_in_expr(target_ref, param_names, seen_ids, captured)
                self.collect_captured_in_expr(value_ref, param_names, seen_ids, captured)
            },
            .ExprStmt(expr_ref, _) then {
                self.collect_captured_in_expr(expr_ref, param_names, seen_ids, captured)
            },
            .ReturnStmt(value_opt, _) then {
                when value_opt in {
                    .Some(value_ref) then {
                        self.collect_captured_in_expr(value_ref, param_names, seen_ids, captured)
                    },
                    .None() then {},
                }
            },
            .FinallyStmt(expr_ref, _) then {
                self.collect_captured_in_expr(expr_ref, param_names, seen_ids, captured)
            },
            .YieldStmt(expr_ref, _) then {
                self.collect_captured_in_expr(expr_ref, param_names, seen_ids, captured)
            },
            _ then {},
        }
    }

    // ── 原始 C 标识符（绕过捕获别名）────────────────────────────────────────

    /// 获取 Symbol 的原始 C 标识符，绕过 captured_var_aliases
    /// 用于 env struct 字段名和 env 初始化
    raw_c_identifier_for_symbol(self ref, symbol Symbol ref) String = {
        // 临时移除别名以获取基础名称
        let saved_opt = self.captured_var_aliases.get(symbol.def_id.id)
        self.captured_var_aliases.remove(symbol.def_id.id)
        let name = self.c_identifier_for_symbol(symbol)
        when saved_opt in {
            .Some(saved) then {
                self.captured_var_aliases.insert(symbol.def_id.id, saved)
            },
            .None() then {},
        }
        return name
    }

    // ── Lambda 函数体生成 ─────────────────────────────────────────────────────

    /// 生成 Lambda 函数体（等价于 Swift 的 generateFunctionBody）
    ///
    /// 1. push_scope
    /// 2. 注册参数到生命周期作用域
    /// 3. 生成 body 表达式
    /// 4. 如果非 Never：声明结果变量，copy/move body 结果
    /// 5. pop_scope
    /// 6. 如果非 void：生成 return 语句
    generate_lambda_body(self ref, params [TypedParam]List, body TypedExpr ref) Void = {
        self.push_scope()
        let is_explicit_drop_function = when self.current_function_c_name in {
            .Some(name) then {
                if name.ends_with("__k_drop") then {
                    yield true
                }
                let mut is_user_drop = false
                for entry in self.user_defined_drops then {
                    if entry.second == name then {
                        is_user_drop = true
                    }
                }
                yield is_user_drop
            },
            .None() then false,
        }

        for p in params then {
            let skip_param_cleanup = is_explicit_drop_function and p.name == "self"
            if skip_param_cleanup then {
                continue
            }
            self.register_variable(self.c_identifier_for_param(p), p.param_type)
        }

        let body_result = self.generate_expression_ssa(body)

        if self.type_is_never(body.expr_type) then {
            self.pop_scope()
            return
        }

        let effective_body_type = when self.current_function_return_type in {
            .Some(ret_type) then ret_type,
            .None() then body.expr_type,
        }

        if not self.type_is_void(effective_body_type) then {
            let needs_preserved_return = self.needs_drop(effective_body_type) and not body_result.is_empty()
            if needs_preserved_return then {
                let return_c_type = self.c_type_name(effective_body_type)
                let ret_var = self.next_temp()
                self.add_indent()
                self.buffer.push_string("\(return_c_type) \(ret_var);\n")
                self.append_copy_assignment(effective_body_type, body_result, ret_var)
                self.pop_scope()
                self.add_indent()
                self.buffer.push_string("return \(ret_var);\n")
                return
            }
            self.pop_scope()
            self.add_indent()
            self.buffer.push_string("return \(body_result);\n")
        } else {
            self.pop_scope()
        }
    }

    // ── generate_lambda_expression ────────────────────────────────────────────

    /// 生成 Lambda 表达式的 C 代码
    ///
    /// 区分无捕获和有捕获两种情况：
    /// - 无捕获：生成静态函数 + Closure{fn, NULL, NULL}
    /// - 有捕获：生成 env struct、lambda 函数（首参 void* __env）、env drop 函数
    ///
    /// Requirements: 8.1, 8.2, 8.3, 8.4, 8.5
    public generate_lambda_expression(self ref, params [TypedParam]List, return_type Type, body TypedExpr ref) String = {
        let lambda_name = self.next_lambda_name()

        // 检测捕获变量
        let captures = self.collect_captured_variables(params, body)

        if captures.is_empty() then {
            // 无捕获 Lambda
            self.generate_no_capture_lambda(lambda_name, params, return_type, body)
            let result = self.next_temp_with_init(
                "struct __koral_Closure",
                "{ .fn = (void*)\(lambda_name), .env = NULL, .drop = NULL }"
            )
            return result
        } else {
            // 有捕获 Lambda
            let env_struct_name = "\(lambda_name)_env"

            // 生成 env struct 定义
            self.generate_lambda_env_struct(env_struct_name, captures)

            // 生成 Lambda 函数（带 env 参数）
            self.generate_capture_lambda(lambda_name, env_struct_name, params, return_type, captures, body)

            // 分配并初始化 env
            let env_var = self.next_temp_with_init(
                "struct \(env_struct_name)*",
                "(struct \(env_struct_name)*)malloc(sizeof(struct \(env_struct_name)))"
            )
            self.add_indent()
            self.buffer.push_string("\(env_var)->__refcount = 1;\n")

            // 初始化捕获变量
            for sym in captures then {
                let raw_name = self.raw_c_identifier_for_symbol(sym)
                let mut current_expr = when self.captured_var_aliases.get(sym.def_id.id) in {
                    .Some(alias) then alias,
                    .None() then self.c_identifier_for_symbol(sym),
                }
                current_expr = when self.pattern_binding_aliases.get(current_expr) in {
                    .Some(alias) then alias,
                    .None() then {
                        let simple_name = sanitize_c_identifier(sym.name)
                        yield when self.pattern_binding_aliases.get(simple_name) in {
                            .Some(alias) then alias,
                            .None() then current_expr,
                        }
                    },
                }
                self.append_copy_assignment(sym.symbol_type, current_expr, "\(env_var)->\(raw_name)")
            }

            // 创建 Closure struct
            let result = self.next_temp_with_init(
                "struct __koral_Closure",
                "{ .fn = (void*)\(lambda_name), .env = \(env_var), .drop = __koral_\(env_struct_name)_drop }"
            )
            return result
        }
    }

    // ── generate_no_capture_lambda ────────────────────────────────────────────

    /// 生成无捕获 Lambda 函数
    ///
    /// 生成 static 函数定义，追加到 lambda_functions 缓冲区
    ///
    /// Requirements: 8.2
    public generate_no_capture_lambda(self ref, name String, params [TypedParam]List, return_type Type, body TypedExpr ref) Void = {
        let return_c_type = self.c_type_name(return_type)

        // 构建参数列表
        let mut param_parts = [String]List.new()
        for p in params then {
            let p_c_type = self.c_type_name(p.param_type)
            let p_c_name = self.c_identifier_for_param(p)
            param_parts.push("\(p_c_type) \(p_c_name)")
        }
        let params_str = if param_parts.is_empty() then "void" else param_parts.join_to_string(", ")

        let mut func_buffer = "\n// Lambda function (no capture)\n"
        func_buffer.push_string("static \(return_c_type) \(name)(\(params_str));\n")
        func_buffer.push_string("static \(return_c_type) \(name)(\(params_str)) {\n")

        // 保存当前状态
        let saved_buffer = self.buffer
        let saved_indent = self.indent
        let saved_lambda_counter = self.lambda_counter
        let saved_lambda_functions = self.lambda_functions
        let saved_lifetime_scope_stack = self.lifetime_scope_stack
        let saved_defer_scope_stack = self.defer_scope_stack
        let saved_loop_stack = self.loop_stack
        let saved_function_type_prefix = self.current_function_type_prefix
        let saved_function_c_name = self.current_function_c_name
        let saved_function_return_type = self.current_function_return_type

        // 重置状态
        self.buffer = String.new()
        self.indent = "  "
        self.lambda_functions = String.new()
        self.lifetime_scope_stack = [[[String, Type]Pair]List]List.new()
        self.defer_scope_stack = [[TypedExpr ref]List]List.new()
        self.loop_stack = [LoopContext]List.new()
        self.current_function_type_prefix = [String]Option.None()
        self.current_function_c_name = [String]Option.Some(name)
        self.current_function_return_type = [Type]Option.Some(return_type)

        // 生成函数体
        self.generate_lambda_body(params, body)

        func_buffer.push_string(self.buffer)
        func_buffer.push_string("}\n")

        // 处理嵌套 Lambda
        if not self.lambda_functions.is_empty() then {
            func_buffer = self.lambda_functions + func_buffer
        }

        // 恢复状态
        self.buffer = saved_buffer
        self.indent = saved_indent
        // lambda_counter 已在生成过程中递增，保留新值
        self.lambda_functions = saved_lambda_functions + func_buffer
        self.lifetime_scope_stack = saved_lifetime_scope_stack
        self.defer_scope_stack = saved_defer_scope_stack
        self.loop_stack = saved_loop_stack
        self.current_function_type_prefix = saved_function_type_prefix
        self.current_function_c_name = saved_function_c_name
        self.current_function_return_type = saved_function_return_type
    }

    // ── generate_capture_lambda ───────────────────────────────────────────────

    /// 生成有捕获 Lambda 函数
    ///
    /// 生成带 void* __env 首参的 static 函数，追加到 lambda_functions 缓冲区
    ///
    /// Requirements: 8.3, 8.5
    public generate_capture_lambda(self ref, name String, env_struct_name String, params [TypedParam]List, return_type Type, captures [Symbol]List, body TypedExpr ref) Void = {
        let return_c_type = self.c_type_name(return_type)

        // 构建参数列表（env 作为第一个参数）
        let mut param_parts = [String]List.new()
        param_parts.push("void* __env")
        for p in params then {
            let p_c_type = self.c_type_name(p.param_type)
            let p_c_name = self.c_identifier_for_param(p)
            param_parts.push("\(p_c_type) \(p_c_name)")
        }
        let params_str = param_parts.join_to_string(", ")

        let mut func_buffer = "\n// Lambda function (with capture)\n"
        func_buffer.push_string("static \(return_c_type) \(name)(\(params_str));\n")
        func_buffer.push_string("static \(return_c_type) \(name)(\(params_str)) {\n")
        func_buffer.push_string("  struct \(env_struct_name)* __captured = (struct \(env_struct_name)*)__env;\n")

        // 保存当前状态
        let saved_buffer = self.buffer
        let saved_indent = self.indent
        let saved_lambda_counter = self.lambda_counter
        let saved_lambda_functions = self.lambda_functions
        let saved_captured_var_aliases = self.captured_var_aliases
        let saved_lifetime_scope_stack = self.lifetime_scope_stack
        let saved_defer_scope_stack = self.defer_scope_stack
        let saved_loop_stack = self.loop_stack
        let saved_function_type_prefix = self.current_function_type_prefix
        let saved_function_c_name = self.current_function_c_name
        let saved_function_return_type = self.current_function_return_type

        // 重置状态
        self.buffer = String.new()
        self.indent = "  "
        self.lambda_functions = String.new()
        self.lifetime_scope_stack = [[[String, Type]Pair]List]List.new()
        self.defer_scope_stack = [[TypedExpr ref]List]List.new()
        self.loop_stack = [LoopContext]List.new()
        self.current_function_type_prefix = [String]Option.None()
        self.current_function_c_name = [String]Option.Some(name)
        self.current_function_return_type = [Type]Option.Some(return_type)

        // 设置捕获别名：qualifiedName() 将捕获变量解析为 __captured->field
        for sym in captures then {
            let field_name = self.raw_c_identifier_for_symbol(sym)
            self.captured_var_aliases.insert(sym.def_id.id, "__captured->\(field_name)")
        }

        // 生成函数体
        self.generate_lambda_body(params, body)

        func_buffer.push_string(self.buffer)
        func_buffer.push_string("}\n")

        // 处理嵌套 Lambda
        if not self.lambda_functions.is_empty() then {
            func_buffer = self.lambda_functions + func_buffer
        }

        // 恢复状态
        self.buffer = saved_buffer
        self.indent = saved_indent
        // lambda_counter 已在生成过程中递增，保留新值
        self.captured_var_aliases = saved_captured_var_aliases
        self.lambda_functions = saved_lambda_functions + func_buffer
        self.lifetime_scope_stack = saved_lifetime_scope_stack
        self.defer_scope_stack = saved_defer_scope_stack
        self.loop_stack = saved_loop_stack
        self.current_function_type_prefix = saved_function_type_prefix
        self.current_function_c_name = saved_function_c_name
        self.current_function_return_type = saved_function_return_type
    }

    // ── generate_lambda_env_struct ────────────────────────────────────────────

    /// 生成 Lambda 环境结构体
    ///
    /// 包含 __refcount 和所有捕获变量，以及 drop 函数
    ///
    /// Requirements: 8.4
    public generate_lambda_env_struct(self ref, name String, captures [Symbol]List) Void = {
        let mut struct_buffer = "\n// Lambda environment struct\n"
        struct_buffer.push_string("struct \(name) {\n")
        struct_buffer.push_string("  _Atomic intptr_t __refcount;\n")

        for sym in captures then {
            let field_name = self.raw_c_identifier_for_symbol(sym)
            let field_c_type = self.c_type_name(sym.symbol_type)
            struct_buffer.push_string("  \(field_c_type) \(field_name);\n")
        }

        struct_buffer.push_string("};\n")

        // Drop 函数：释放所有捕获字段，然后 free env struct
        struct_buffer.push_string("\nstatic void __koral_\(name)_drop(void* raw_env) {\n")
        struct_buffer.push_string("  struct \(name)* env = (struct \(name)*)raw_env;\n")

        for sym in captures then {
            let field_name = self.raw_c_identifier_for_symbol(sym)
            let field_expr = "env->\(field_name)"
            let drop_code = self.drop_code_for_captured_field(sym.symbol_type, field_expr)
            if not drop_code.is_empty() then {
                struct_buffer.push_string("  ")
                struct_buffer.push_string(drop_code)
            }
        }

        struct_buffer.push_string("  free(raw_env);\n")
        struct_buffer.push_string("}\n")

        // 追加到 lambda_env_structs 缓冲区
        self.lambda_env_structs.push_string(struct_buffer)
    }

    /// 生成捕获字段的 drop 代码
    drop_code_for_captured_field(self, field_type Type, field_expr String) String = {
        return when field_type in {
            .FunctionType(_, _) then "__koral_closure_release(\(field_expr));\n",
            .StructureType(def_id) then {
                let type_name = self.c_name_for_def_id(def_id)
                yield "__koral_\(type_name)_drop((struct __koral_Ref){ .ptr = (void*)&(\(field_expr)), .control = NULL });\n"
            },
            .UnionType(def_id) then {
                let type_name = self.c_name_for_def_id(def_id)
                yield "__koral_\(type_name)_drop((struct __koral_Ref){ .ptr = (void*)&(\(field_expr)), .control = NULL });\n"
            },
            .ReferenceType(_) then "__koral_release(\(field_expr).control);\n",
            .WeakReferenceType(_) then "__koral_weak_release(\(field_expr).control);\n",
            _ then "",
        }
    }
}
