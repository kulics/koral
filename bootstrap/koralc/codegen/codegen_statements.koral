// codegen_statements.koral - 语句代码生成
//
// 实现 CodeGen 的语句代码生成方法：
// - generate_statement：主入口，处理所有 TypedStatement 变体
//   - LetStmt：声明局部变量、初始化（lvalue 执行 copy）、注册到生命周期作用域
//   - AssignmentStmt：先 drop 旧值再赋新值，支持 MemberPath 目标的字段赋值
//   - ExprStmt：求值表达式并丢弃结果
//   - ReturnStmt：执行跨作用域清理后生成 return
//   - BreakStmt / ContinueStmt：执行到循环作用域的清理后生成 goto
//   - FinallyStmt：注册到当前作用域的 defer 栈
//   - YieldStmt：由 generate_block_scope 处理，此处为 no-op
//
// 参照 compiler/Sources/KoralCompiler/CodeGen/CodeGen.swift 中的 generateStatement 方法
//
// Requirements: 6.1, 6.2, 6.3, 6.4, 6.5, 6.6, 6.7, 6.8, 6.9

given CodeGen {
    /// 生成语句的 C 代码
    ///
    /// 主入口，根据语句类型分发到对应的处理逻辑。
    ///
    /// Requirements: 6.1, 6.2, 6.3, 6.4, 6.5, 6.6, 6.7, 6.8, 6.9
    public generate_statement(self mut ref, stmt TypedStatement) Void = {
        when stmt in {
            // ── LetStmt ───────────────────────────────────────────────────────
            // 声明局部变量，初始化（lvalue 执行 copy），注册到生命周期作用域
            //
            // Requirements: 6.1
            .LetStmt(symbol, value_ref, _) then {
                let value = value_ref
                let temp_marker = self.current_scope_temp_marker()

                // void/never 类型的值不能赋给变量
                if not self.type_is_void_or_never(value.expr_type) then {
                    let c_ident = self.qualified_name_value(symbol)
                    self.set_local_c_identifier(symbol.def_id, c_ident)
                    let finalized_type = when symbol.symbol_type in {
                        .VoidType() then value.expr_type,
                        .Unknown() then value.expr_type,
                        _ then symbol.symbol_type,
                    }
                    let c_type = self.c_type_name(finalized_type)
                    let mut value_result = if when symbol.kind in {
                            .Variable(variable_kind) then variable_kind is .SubscriptBaseBorrowAlias(),
                            _ then false,
                        }
                    then {
                        yield when value.expr_kind in {
                            .RefExpr(inner_ref) then if self.is_addressable_lvalue_expr(inner_ref) then {
                                let components = self.build_ref_components(inner_ref)
                                let borrow_ref = self.next_temp_with_decl(c_type)
                                self.add_indent()
                                self.buffer.push_string("\(borrow_ref).ptr = &\(components.first);\n")
                                self.add_indent()
                                self.buffer.push_string("\(borrow_ref).control = \(components.second);\n")
                                self.add_indent()
                                self.buffer.push_string("__koral_retain(\(borrow_ref).control);\n")
                                yield borrow_ref
                            } else self.generate_expression_ssa(value),
                            _ then self.generate_expression_ssa(value),
                        }
                    } else {
                        yield self.generate_expression_ssa(value)
                    }

                    when finalized_type in {
                        .ReferenceType(expected_inner_ref) then {
                            when expected_inner_ref.val in {
                                .TraitObject(trait_name, _) then {
                                    if value.expr_kind is not .TraitObjectConversion(_, _, _) then {
                                        when value.expr_type in {
                                            .ReferenceType(actual_inner_ref) then {
                                                when actual_inner_ref.val in {
                                                    .TraitObject(_, _) then {},
                                                    _ then {
                                                        value_result = self.generate_trait_object_conversion_from_ref_value(
                                                            value_result,
                                                            trait_name,
                                                            actual_inner_ref.val,
                                                            self.is_lvalue_expr(value),
                                                        )
                                                    },
                                                }
                                            },
                                            _ then {},
                                        }
                                    }
                                },
                                _ then {},
                            }
                        },
                        _ then {},
                    }

                    // 声明变量
                    self.push_indented_decl(c_type, c_ident)

                    self.append_copy_or_move_assignment(finalized_type, value_result, c_ident, self.is_lvalue_expr(value))

                    // 注册到生命周期作用域
                    self.register_variable(c_ident, finalized_type)

                    // 清理表达式求值期间产生的临时值（用户变量之前的部分）
                    // 用户变量是最后注册的，取 post_marker 后清理到 post_marker - 1
                    let post_marker = self.current_scope_temp_marker()
                    if post_marker > temp_marker + 1 then {
                        // 暂存用户变量条目（栈顶）
                        let scope_count = self.lifetime_scope_stack.count()
                        let vars = self.lifetime_scope_stack[scope_count - 1]
                        let user_entry = vars[vars.count() - 1]
                        vars.remove_at(vars.count() - 1)
                        // 清理临时值
                        self.cleanup_temporaries_in_current_scope(temp_marker)
                        // 恢复用户变量
                        vars.push(user_entry)
                    }
                } else {
                    let _ = self.generate_expression_ssa(value)
                    // void/never 类型：清理表达式求值期间产生的临时值
                    self.cleanup_temporaries_in_current_scope(temp_marker)
                }
            },

            .PairLetStmt(first_symbol, second_symbol, value_ref, _) then {
                let value = value_ref
                let pair_type = value.expr_type
                let pair_result = self.generate_expression_ssa(value)

                let first_type = self.lookup_field_type(pair_type, "first")
                let second_type = self.lookup_field_type(pair_type, "second")

                let pair_c_type = self.c_type_name(pair_type)
                let pair_ident = self.next_temp_with_decl(pair_c_type)
                self.append_copy_or_move_assignment(pair_type, pair_result, pair_ident, self.is_lvalue_expr(value))

                when first_symbol in {
                    .Some(symbol) then {
                        let c_ident = self.qualified_name_value(symbol)
                        self.set_local_c_identifier(symbol.def_id, c_ident)
                        let finalized_type = when symbol.symbol_type in {
                            .VoidType() then first_type,
                            .Unknown() then first_type,
                            _ then symbol.symbol_type,
                        }
                        let c_type = self.c_type_name(finalized_type)
                        self.push_indented_decl(c_type, c_ident)
                        self.append_copy_or_move_assignment(finalized_type, "\(pair_ident).first", c_ident, false)
                        self.register_variable(c_ident, finalized_type)
                    },
                    .None() then {
                        if self.needs_drop(first_type) then {
                            self.append_drop_statement(first_type, "\(pair_ident).first")
                        }
                    },
                }

                when second_symbol in {
                    .Some(symbol) then {
                        let c_ident = self.qualified_name_value(symbol)
                        self.set_local_c_identifier(symbol.def_id, c_ident)
                        let finalized_type = when symbol.symbol_type in {
                            .VoidType() then second_type,
                            .Unknown() then second_type,
                            _ then symbol.symbol_type,
                        }
                        let c_type = self.c_type_name(finalized_type)
                        self.push_indented_decl(c_type, c_ident)
                        self.append_copy_or_move_assignment(finalized_type, "\(pair_ident).second", c_ident, false)
                        self.register_variable(c_ident, finalized_type)
                    },
                    .None() then {
                        if self.needs_drop(second_type) then {
                            self.append_drop_statement(second_type, "\(pair_ident).second")
                        }
                    },
                }
            },

            // ── AssignmentStmt ────────────────────────────────────────────────
            // 先 drop 旧值，再赋新值；对 lvalue 源执行 copy
            // 支持 MemberPath 目标的字段赋值
            //
            // Requirements: 6.2, 6.3
            .AssignmentStmt(target_ref, value_ref, _) then {
                let target = target_ref
                let value = value_ref
                let temp_marker = self.current_scope_temp_marker()

                // 获取赋值目标的 C 左值路径
                let lhs_path = self.build_ref_components_path(target)

                // 求值右侧表达式
                let value_result = self.generate_expression_ssa(value)

                if self.type_is_void_or_never(value.expr_type) then {
                    // void/never 类型不需要赋值
                } else {
                    let is_lvalue = self.is_lvalue_expr(value)
                    let needs_drop = self.needs_drop(target.expr_type)

                    if needs_drop then {
                        let temp_name = self.next_temp()
                        let temp_type = self.c_type_name(target.expr_type)
                        self.push_indented_decl(temp_type, temp_name)

                        self.append_copy_or_move_assignment(target.expr_type, value_result, temp_name, is_lvalue)

                        self.add_indent()
                        self.append_drop_statement(target.expr_type, lhs_path)
                        self.append_copy_or_move_assignment(target.expr_type, temp_name, lhs_path, false)
                    } else {
                        self.append_copy_or_move_assignment(target.expr_type, value_result, lhs_path, is_lvalue)
                    }
                }

                self.cleanup_temporaries_in_current_scope(temp_marker)
            },

            // ── ExprStmt ──────────────────────────────────────────────────────
            // 求值表达式并丢弃结果；如果结果是 rvalue 且需要 drop，生成 drop 代码
            //
            // Requirements: 6.4
            .ExprStmt(expr_ref, _) then {
                let expr = expr_ref
                let temp_marker = self.current_scope_temp_marker()
                let result = self.generate_expression_ssa(expr)
                self.drop_expression_result_if_needed(expr.expr_type, result)
                self.cleanup_temporaries_in_current_scope(temp_marker)
            },

            .IfStmt(condition_ref, then_ref, else_opt, _) then {
                let raw_cond_result = self.generate_expression_ssa(condition_ref)
                let cond_result = self.adapt_expression_result_to_type(condition_ref, raw_cond_result, Type.BoolType())
                let saved_scope_state = self.snapshot_scope_state()
                self.push_indented_if_open(cond_result)
                self.with_indent(() -> {
                    self.push_scope()
                    let temp_marker = self.current_scope_temp_marker()
                    let _ = self.generate_expression_ssa(then_ref)
                    self.cleanup_temporaries_in_current_scope(temp_marker)
                    self.pop_scope()
                    self.restore_scope_state(saved_scope_state)
                })
                when else_opt in {
                    .Some(else_ref) then {
                        let saved_else_scope_state = self.snapshot_scope_state()
                        self.push_indented_string("} else {\n")
                        self.with_indent(() -> {
                            self.push_scope()
                            let temp_marker = self.current_scope_temp_marker()
                            let _ = self.generate_expression_ssa(else_ref)
                            self.cleanup_temporaries_in_current_scope(temp_marker)
                            self.pop_scope()
                            self.restore_scope_state(saved_else_scope_state)
                        })
                    },
                    .None() then {},
                }
                self.restore_scope_state(saved_scope_state)
                self.push_indented_string("}\n")
            },

            .WhileStmt(condition_ref, body_ref, _) then {
                let saved_scope_state = self.snapshot_scope_state()
                let label_prefix = self.next_temp()
                let start_label = "\(label_prefix)_start"
                let end_label = "\(label_prefix)_end"

                self.push_indented_label_block_open(start_label)
                self.with_indent(() -> {
                    self.push_scope()
                    let cond_scope_index = self.lifetime_scope_stack.count() - 1
                    let cond_result = self.generate_expression_ssa(condition_ref)
                    self.push_indented_if_open("!\(cond_result)")
                    self.with_indent(() -> {
                        self.emit_cleanup_for_scope(cond_scope_index)
                        self.push_indented_goto(end_label)
                    })
                    self.push_indented_string("}\n")
                    self.emit_cleanup_for_scope(cond_scope_index)
                    self.pop_scope_without_cleanup()
                    self.push_scope()
                    let scope_index = self.lifetime_scope_stack.count() - 1
                    self.push_loop_context(LoopContext(start_label, end_label, scope_index))
                    let temp_marker = self.current_scope_temp_marker()
                    let _ = self.generate_expression_ssa(body_ref)
                    self.cleanup_temporaries_in_current_scope(temp_marker)
                    let _ = self.pop_loop_context()
                    self.pop_scope()
                    self.push_indented_goto(start_label)
                })
                self.push_indented_string("}\n")
                self.push_indented_label_block_open(end_label)
                self.push_indented_string("}\n")
                self.restore_scope_state(saved_scope_state)
            },

            .WhenStmt(subject_ref, arms, _) then {
                let when_expr = make_typed_expr(TypedExprKind.WhenExpr(subject_ref, arms), Type.VoidType())
                let temp_marker = self.current_scope_temp_marker()
                let result = self.generate_expression_ssa(box(when_expr))
                self.drop_expression_result_if_needed(when_expr.expr_type, result)
                self.cleanup_temporaries_in_current_scope(temp_marker)
            },

            // ── ReturnStmt ────────────────────────────────────────────────────
            // 先执行从当前作用域到函数作用域的所有清理（finally + drop），再生成 return
            //
            // Requirements: 6.5
            .ReturnStmt(value_opt, _) then {
                when value_opt in {
                    .Some(value_ref) then {
                        let value = value_ref
                        // never 类型：只求值，不生成 return
                        if self.type_is_never(value.expr_type) then {
                            self.generate_expression_ssa(value)
                            return
                        }

                        // 求值返回表达式
                        self.escape_context.in_return_context = true
                        let value_result = self.generate_expression_ssa(value)
                        self.escape_context.in_return_context = false

                        // 将返回值保存到临时变量（在 cleanup 之前，避免 cleanup 破坏返回值）
                        let return_storage_type = when self.current_function_return_type in {
                            .Some(ret_t) then {
                                yield ret_t
                            },
                            .None() then value.expr_type,
                        }
                        let return_c_type = self.c_type_name(return_storage_type)
                        let ret_var = self.next_temp()
                        self.push_indented_decl(return_c_type, ret_var)

                        let adapted_return_value = self.adapt_expression_result_to_type(value, value_result, return_storage_type)

                        let return_is_lvalue = adapted_return_value == value_result and self.is_lvalue_expr(value) and not self.is_registered_for_cleanup(value_result)
                        self.append_copy_or_move_assignment(return_storage_type, adapted_return_value, ret_var, return_is_lvalue)

                        // 执行所有作用域的清理
                        self.emit_cleanup(0)

                        // 生成 return 语句
                        self.push_indented_return_value(ret_var)
                    },
                    .None() then {
                        // 无返回值：执行清理后直接 return
                        self.emit_cleanup(0)
                        self.push_indented_return_void()
                    },
                }
            },

            // ── BreakStmt ─────────────────────────────────────────────────────
            // 执行从当前作用域到循环作用域的清理，然后 goto 循环结束标签
            //
            // Requirements: 6.6
            .BreakStmt(_) then {
                when self.current_loop_context() in {
                    .Some(ctx) then {
                    self.emit_cleanup(ctx.scope_index)
                    self.push_indented_goto(ctx.end_label)
                    },
                    .None() then {},
                }
            },

            // ── ContinueStmt ──────────────────────────────────────────────────
            // 执行从当前作用域到循环作用域的清理，然后 goto 循环开始标签
            //
            // Requirements: 6.7
            .ContinueStmt(_) then {
                when self.current_loop_context() in {
                    .Some(ctx) then {
                    self.emit_cleanup(ctx.scope_index)
                    self.push_indented_goto(ctx.start_label)
                    },
                    .None() then {},
                }
            },

            // ── FinallyStmt ───────────────────────────────────────────────────
            // 将表达式注册到当前作用域的 defer 栈，在作用域退出时按 LIFO 顺序执行
            //
            // Requirements: 6.8
            .FinallyStmt(expr_ref, _) then {
                let defer_count = self.defer_scope_stack.count()
                if defer_count > 0 then {
                    let top = self.defer_scope_stack[defer_count - 1]
                    top.push(DeferredExpr(expr_ref, self.snapshot_pattern_binding_aliases()))
                }
            },

            // ── YieldStmt ─────────────────────────────────────────────────────
            // 将当前分支值写入活动 yield target，并跳转到目标结束标签
            //
            // Requirements: 6.9
            .YieldStmt(expr_ref, _) then {
                when self.current_yield_target() in {
                    .Some(target) then {
                    let value_result = self.generate_expression_ssa(expr_ref)
                    if self.needs_drop(expr_ref.expr_type)
                        and not value_result.is_empty()
                        and self.is_registered_for_cleanup(value_result)
                    then {
                        self.unregister_variable(value_result)
                    }
                    let adapted_value = self.adapt_expression_result_to_type(expr_ref, value_result, target.result_type)
                    self.assign_expr_result(expr_ref, adapted_value, target.result_type, target.result_var)
                    let cleanup_start = if self.lifetime_scope_stack.count() > target.base_scope_index + 1(UInt)
                        then target.base_scope_index + 1(UInt)
                        else self.lifetime_scope_stack.count() - 1(UInt)
                    if not self.lifetime_scope_stack.is_empty() and self.lifetime_scope_stack.count() - 1(UInt) >= cleanup_start then {
                        self.emit_cleanup(cleanup_start)
                    }
                    self.push_indented_goto(target.end_label)
                    },
                    .None() then {},
                }
            },
        }
    }

    // ── 辅助方法 ──────────────────────────────────────────────────────────────

    /// 判断表达式是否应按 lvalue 执行 copy/move。
    is_lvalue_expr(self, expr ref TypedExpr) Bool = {
        return typed_expr_value_category(expr) is .LValue()
    }

    /// 判断表达式是否是可取地址的真实 lvalue。
    ///
    /// 这用于 `ref` 形成、`ref_count`/`ref_is_borrow` 降低，以及 `self ref` 接收者借用。
    is_addressable_lvalue_expr(self, expr ref TypedExpr) Bool = {
        return when expr.expr_kind in {
            .Variable(_) then true,
            .MemberPath(base_ref, _) then self.is_addressable_lvalue_expr(base_ref),
            .DerefExpr(_) then true,
            _ then false,
        }
    }

    /// 获取赋值目标表达式的 C 左值路径
    ///
    /// 对于简单变量，返回其 C 标识符；
    /// 对于 MemberPath，调用 build_ref_components 获取字段路径。
    /// 此方法是 build_ref_components 的简化版，只返回路径字符串。
    build_ref_components_path(self mut ref, expr ref TypedExpr) String = {
        return when expr.expr_kind in {
            .Variable(symbol) then {
                // 先检查 lambda 捕获别名，再用 c_identifier_for_symbol
                let c_name = when self.captured_var_aliases.get(symbol.def_id.id) in {
                    .Some(alias) then alias,
                    .None() then {
                        let raw_name = self.c_identifier_for_symbol(symbol)
                        yield when self.captured_name_alias_opt(raw_name) in {
                            .Some(alias) then alias,
                            .None() then raw_name,
                        }
                    },
                }
                yield when self.pattern_binding_aliases.get(c_name) in {
                    .Some(alias) then alias,
                    .None() then c_name,
                }
            },
            .MemberPath(base_ref, path) then {
                let _ = base_ref
                let _ = path
                yield self.build_ref_components(expr).first
            },
            .DerefExpr(inner_ref) then {
                let _ = inner_ref
                yield self.build_ref_components(expr).first
            },
            _ then {
                // 其他情况：直接求值（用于 subscript 等）
                yield self.generate_expression_ssa(expr)
            },
        }
    }
}
