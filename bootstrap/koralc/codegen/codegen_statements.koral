// codegen_statements.koral - 语句代码生成
//
// 实现 CodeGen 的语句代码生成方法：
// - generate_statement：主入口，处理所有 TypedStatement 变体
//   - LetStmt：声明局部变量、初始化（lvalue 执行 copy）、注册到生命周期作用域
//   - AssignmentStmt：先 drop 旧值再赋新值，支持 MemberPath 目标的字段赋值
//   - ExprStmt：求值表达式并丢弃结果
//   - ReturnStmt：执行跨作用域清理后生成 return
//   - BreakStmt / ContinueStmt：执行到循环作用域的清理后生成 goto
//   - FinallyStmt：注册到当前作用域的 defer 栈
//   - YieldStmt：由 generate_block_scope 处理，此处为 no-op
//
// 参照 compiler/Sources/KoralCompiler/CodeGen/CodeGen.swift 中的 generateStatement 方法
//
// Requirements: 6.1, 6.2, 6.3, 6.4, 6.5, 6.6, 6.7, 6.8, 6.9

given CodeGen {

    /// 生成语句的 C 代码
    ///
    /// 主入口，根据语句类型分发到对应的处理逻辑。
    ///
    /// Requirements: 6.1, 6.2, 6.3, 6.4, 6.5, 6.6, 6.7, 6.8, 6.9
    public generate_statement(self ref, stmt TypedStatement) Void = {
        when stmt in {
            // ── LetStmt ───────────────────────────────────────────────────────
            // 声明局部变量，初始化（lvalue 执行 copy），注册到生命周期作用域
            //
            // Requirements: 6.1
            .LetStmt(symbol, value_ref, _) then {
                let value = value_ref
                let value_result = self.generate_expression_ssa(value)
                let inferred_value_type = if self.is_unresolved_codegen_type(value.expr_type) then self.infer_expr_type_for_codegen(value) else value.expr_type
                let value_result_scope_type = when self.lookup_registered_variable_type(value_result) in {
                    .Some(t) then t,
                    .None() then Type.Unknown(),
                }
                let literal_fallback_type = when value.expr_kind in {
                    .IntegerLiteral(_) then Type.IntType(),
                    .FloatLiteral(_) then Type.Float64Type(),
                    .RuneLiteral(_) then Type.RuneType(),
                    .StringLiteral(_) then Type.StringType(),
                    _ then Type.Unknown(),
                }

                // void/never 类型的值不能赋给变量
                if not self.type_is_void_or_never(inferred_value_type) then {
                    let c_ident = self.c_identifier_for_symbol(symbol)
                    // 当符号类型未知或未解析时，优先采用表达式推断类型，避免退化到 void*。
                    let effective_type = when symbol.symbol_type in {
                        .Unknown() then {
                            if not self.is_unresolved_codegen_type(value.expr_type) then {
                                yield value.expr_type
                            }
                            if self.is_unresolved_codegen_type(inferred_value_type) and not self.is_unresolved_codegen_type(value_result_scope_type) then {
                                yield value_result_scope_type
                            }
                            if self.is_unresolved_codegen_type(inferred_value_type) and not self.is_unresolved_codegen_type(literal_fallback_type) then {
                                yield literal_fallback_type
                            }
                            yield inferred_value_type
                        },
                        _ then {
                            if not self.is_unresolved_codegen_type(symbol.symbol_type) then {
                                yield symbol.symbol_type
                            }
                            if self.is_unresolved_codegen_type(symbol.symbol_type) and not self.is_unresolved_codegen_type(inferred_value_type) then {
                                yield inferred_value_type
                            }
                            if self.is_unresolved_codegen_type(symbol.symbol_type) and self.is_unresolved_codegen_type(inferred_value_type) and not self.is_unresolved_codegen_type(value_result_scope_type) then {
                                yield value_result_scope_type
                            }
                            if self.is_unresolved_codegen_type(symbol.symbol_type) and self.is_unresolved_codegen_type(inferred_value_type) and not self.is_unresolved_codegen_type(literal_fallback_type) then {
                                yield literal_fallback_type
                            }
                            yield symbol.symbol_type
                        },
                    }
                    let finalized_type = {
                        let maybe_void = self.c_type_name(effective_type) == "void*"
                        if maybe_void and not self.is_unresolved_codegen_type(inferred_value_type) then {
                            yield inferred_value_type
                        }
                        if maybe_void and not self.is_unresolved_codegen_type(value_result_scope_type) then {
                            yield value_result_scope_type
                        }
                        if maybe_void and not self.is_unresolved_codegen_type(literal_fallback_type) then {
                            yield literal_fallback_type
                        }
                        yield effective_type
                    }
                    let c_type = self.c_type_name(finalized_type)

                    // 声明变量
                    self.add_indent()
                    self.buffer.push_string("\(c_type) \(c_ident);\n")

                    // 初始化：lvalue 执行 copy，rvalue 直接赋值
                    let is_lvalue = self.is_lvalue_expr(value)
                    if is_lvalue and self.needs_drop(finalized_type) then {
                        self.append_copy_assignment(finalized_type, value_result, c_ident)
                    } else {
                        self.add_indent()
                        self.buffer.push_string("\(c_ident) = \(value_result);\n")
                    }

                    // 注册到生命周期作用域
                    self.register_variable(c_ident, finalized_type)
                }
            },

            // ── AssignmentStmt ────────────────────────────────────────────────
            // 先 drop 旧值，再赋新值；对 lvalue 源执行 copy
            // 支持 MemberPath 目标的字段赋值
            //
            // Requirements: 6.2, 6.3
            .AssignmentStmt(target_ref, value_ref, _) then {
                let target = target_ref
                let value = value_ref

                // 获取赋值目标的 C 左值路径
                let lhs_path = self.build_ref_components_path(target)

                // 求值右侧表达式
                let value_result = self.generate_expression_ssa(value)

                if self.type_is_void_or_never(value.expr_type) then {
                    // void/never 类型不需要赋值
                } else {
                    let is_lvalue = self.is_lvalue_expr(value)

                    // 先 drop 旧值（如果目标类型需要 drop）
                    if self.needs_drop(target.expr_type) then {
                        self.add_indent()
                        self.append_drop_statement(target.expr_type, lhs_path)
                    }

                    // 赋新值：lvalue 源执行 copy，rvalue 直接赋值
                    if is_lvalue and self.needs_drop(target.expr_type) then {
                        self.append_copy_assignment(target.expr_type, value_result, lhs_path)
                    } else {
                        self.add_indent()
                        self.buffer.push_string("\(lhs_path) = \(value_result);\n")
                    }
                }
            },

            // ── ExprStmt ──────────────────────────────────────────────────────
            // 求值表达式并丢弃结果；如果结果是 rvalue 且需要 drop，生成 drop 代码
            //
            // Requirements: 6.4
            .ExprStmt(expr_ref, _) then {
                let expr = expr_ref
                let result = self.generate_expression_ssa(expr)
                // 如果结果是 rvalue 且需要 drop，生成 drop 代码
                if self.needs_drop(expr.expr_type) and not result.is_empty() then {
                    self.add_indent()
                    self.append_drop_statement(expr.expr_type, result)
                }
            },

            // ── ReturnStmt ────────────────────────────────────────────────────
            // 先执行从当前作用域到函数作用域的所有清理（finally + drop），再生成 return
            //
            // Requirements: 6.5
            .ReturnStmt(value_opt, _) then {
                when value_opt in {
                    .Some(value_ref) then {
                        let value_raw = value_ref
                        let value = when value_raw.expr_kind in {
                            .WhenExpr(subject_ref, arms) then {
                                let ret_t_opt = self.current_function_return_type
                                yield when value_raw.expr_type in {
                                    .VoidType() then {
                                        yield when ret_t_opt in {
                                            .Some(ret_t) then {
                                                yield when ret_t in {
                                                    .VoidType() then value_raw,
                                                    .NeverType() then value_raw,
                                                    .Unknown() then value_raw,
                                                    _ then box(make_typed_expr(TypedExprKind.WhenExpr(subject_ref, arms), ret_t)),
                                                }
                                            },
                                            .None() then value_raw,
                                        }
                                    },
                                    .Unknown() then {
                                        yield when ret_t_opt in {
                                            .Some(ret_t) then {
                                                yield when ret_t in {
                                                    .VoidType() then value_raw,
                                                    .NeverType() then value_raw,
                                                    .Unknown() then value_raw,
                                                    _ then box(make_typed_expr(TypedExprKind.WhenExpr(subject_ref, arms), ret_t)),
                                                }
                                            },
                                            .None() then value_raw,
                                        }
                                    },
                                    _ then value_raw,
                                }
                            },
                            _ then value_raw,
                        }

                        // never 类型：只求值，不生成 return
                        if self.type_is_never(value.expr_type) then {
                            self.generate_expression_ssa(value)
                            return
                        }

                        // 求值返回表达式
                        let value_result = self.generate_expression_ssa(value)

                        // 当 value.expr_type 是 Unknown 时，直接返回 value_result
                        when value.expr_type in {
                            .Unknown() then {
                                // 执行所有作用域的清理
                                self.emit_cleanup(0)
                                // 生成 return 语句
                                self.add_indent()
                                self.buffer.push_string("return \(value_result);\n")
                                return
                            },
                            _ then {},
                        }

                        // 将返回值保存到临时变量（在 cleanup 之前，避免 cleanup 破坏返回值）
                        let ret_var = self.next_temp()
                        let c_type = self.c_type_name(value.expr_type)
                        self.add_indent()
                        self.buffer.push_string("\(c_type) \(ret_var);\n")

                        let is_lvalue = self.is_lvalue_expr(value)
                        if is_lvalue and self.needs_drop(value.expr_type) then {
                            self.append_copy_assignment(value.expr_type, value_result, ret_var)
                        } else {
                            self.add_indent()
                            self.buffer.push_string("\(ret_var) = \(value_result);\n")
                        }

                        // 执行所有作用域的清理
                        self.emit_cleanup(0)

                        // 生成 return 语句
                        self.add_indent()
                        self.buffer.push_string("return \(ret_var);\n")
                    },
                    .None() then {
                        // 无返回值：执行清理后直接 return
                        self.emit_cleanup(0)
                        self.add_indent()
                        self.buffer.push_string("return;\n")
                    },
                }
            },

            // ── BreakStmt ─────────────────────────────────────────────────────
            // 执行从当前作用域到循环作用域的清理，然后 goto 循环结束标签
            //
            // Requirements: 6.6
            .BreakStmt(_) then {
                let loop_count = self.loop_stack.count()
                if loop_count > 0 then {
                    let ctx = self.loop_stack.at(loop_count - 1)
                    self.emit_cleanup(ctx.scope_index)
                    self.add_indent()
                    self.buffer.push_string("goto \(ctx.end_label);\n")
                }
            },

            // ── ContinueStmt ──────────────────────────────────────────────────
            // 执行从当前作用域到循环作用域的清理，然后 goto 循环开始标签
            //
            // Requirements: 6.7
            .ContinueStmt(_) then {
                let loop_count = self.loop_stack.count()
                if loop_count > 0 then {
                    let ctx = self.loop_stack.at(loop_count - 1)
                    self.emit_cleanup(ctx.scope_index)
                    self.add_indent()
                    self.buffer.push_string("goto \(ctx.start_label);\n")
                }
            },

            // ── FinallyStmt ───────────────────────────────────────────────────
            // 将表达式注册到当前作用域的 defer 栈，在作用域退出时按 LIFO 顺序执行
            //
            // Requirements: 6.8
            .FinallyStmt(expr_ref, _) then {
                let defer_count = self.defer_scope_stack.count()
                if defer_count > 0 then {
                    let mut top = self.defer_scope_stack.at(defer_count - 1)
                    top.push(expr_ref)
                    self.defer_scope_stack.set_at(defer_count - 1, top)
                }
            },

            // ── YieldStmt ─────────────────────────────────────────────────────
            // yield 由 generate_block_scope 在块表达式层面处理，此处为 no-op
            //
            // Requirements: 6.9
            .YieldStmt(_, _) then {
                // yield 在 generate_block_scope 中处理，不在 generate_statement 中处理
            },
        }
    }

    // ── 辅助方法 ──────────────────────────────────────────────────────────────

    /// 判断表达式是否为 lvalue（需要 copy 的情况）
    ///
    /// 在 bootstrap 的 TypedExpr 中，lvalue 对应变量引用、成员访问等可取地址的表达式。
    /// 与 Swift 实现中的 valueCategory == .lvalue 对应。
    is_lvalue_expr(self, expr TypedExpr ref) Bool = {
        return when expr.expr_kind in {
            .Variable(_) then true,
            .MemberExpr(_, _) then true,
            .MemberPath(_, _) then true,
            .DerefExpr(_) then true,
            .SubscriptExpr(_, _) then true,
            _ then false,
        }
    }

    /// 获取赋值目标表达式的 C 左值路径
    ///
    /// 对于简单变量，返回其 C 标识符；
    /// 对于 MemberPath，调用 build_ref_components 获取字段路径。
    /// 此方法是 build_ref_components 的简化版，只返回路径字符串。
    build_ref_components_path(self ref, expr TypedExpr ref) String = {
        return when expr.expr_kind in {
            .Variable(symbol) then {
                // 检查 pattern binding aliases
                let c_name = self.c_identifier_for_symbol(symbol)
                yield when self.pattern_binding_aliases.get(c_name) in {
                    .Some(alias) then alias,
                    .None() then c_name,
                }
            },
            .MemberPath(base_ref, path) then {
                yield self.generate_member_path(base_ref, path)
            },
            .DerefExpr(inner_ref) then {
                let ref_result = self.generate_expression_ssa(inner_ref)
                let c_type = self.c_type_name(expr.expr_type)
                yield when inner_ref.expr_type in {
                    .ReferenceType(_) then "(*(\(c_type)*)\(ref_result).ptr)",
                    .PointerType(_) then "(*\(ref_result))",
                    _ then "(*(\(c_type)*)\(ref_result).ptr)",
                }
            },
            _ then {
                // 其他情况：直接求值（用于 subscript 等）
                yield self.generate_expression_ssa(expr)
            },
        }
    }
}
