type MIRValueCleanup(name String, cleanup_type Type)

type MIRValueEmission(expression String, cleanup Option[ref MIRValueCleanup])

type MIRPlaceAccess(path String, control String, cleanup Option[ref MIRValueCleanup])

type MIRLocalLifetimePlan(
    root_locals List[MIRLocalID],
    locals_by_scope Dict[UInt, List[MIRLocalID]],
    hoisted_declaration_locals List[MIRLocalID],
    block_local_declarations_by_block Dict[UInt, List[MIRLocalID]],
    block_local_declaration_locals Dict[UInt, Bool],
)

type MIRFunctionEmitPlan(
    local_names List[String],
    non_owning_local_ids ref Dict[UInt, Bool],
    init_flags List[String],
    lifetime_plan ref MIRLocalLifetimePlan,
)

private let is_borrowed_reference_like_type(t Type) Bool = {
    return when t in {
        .ReferenceType(_) then true,
        .MutableReferenceType(_) then true,
        .WeakReferenceType(_) then true,
        .MutableWeakReferenceType(_) then true,
        _ then false,
    }
}

private let is_reference_like_type(t Type) Bool = {
    return when t in {
        .ReferenceType(_) then true,
        .MutableReferenceType(_) then true,
        .WeakReferenceType(_) then true,
        .MutableWeakReferenceType(_) then true,
        .TraitObject(_, _) then true,
        _ then false,
    }
}

private let is_non_owning_local_value(value MIRValue, target_type Type) Bool = {
    return when value in {
        .Ref(_, _, allocation) then allocation is .StackBorrow(),
        .PlaceRead(_, ownership) then ownership is .Borrow() and is_borrowed_reference_like_type(target_type),
        _ then false,
    }
}

private let compute_non_owning_mir_locals(function ref MIRFunction) ref Dict[UInt, Bool] = {
    let mut result = Dict[UInt, Bool].new()
    for local in function.locals then {
        if local.storage is .Parameter() and is_borrowed_reference_like_type(local.local_type) then {
            result.insert(local.id.raw_value, true)
            continue
        }

        let mut saw_assignment = false
        let mut all_non_owning = true
        for block in function.blocks then {
            for statement in block.statements then {
                when statement in {
                    .Assign(place, value) then when place in {
                        .Local(local_id) then {
                            if local_id.raw_value == local.id.raw_value then {
                                saw_assignment = true
                                if not is_non_owning_local_value(value, local.local_type) then {
                                    all_non_owning = false
                                }
                            }
                        },
                        _ then {},
                    },
                    _ then {},
                }
            }
        }

        if saw_assignment and all_non_owning then {
            result.insert(local.id.raw_value, true)
        }
    }
    return box(result)
}

private let mir_current_scope_set(active_scopes ref List[MIRScopeID]) Set[UInt] = {
    let mut scope_set = Set[UInt].new()
    for scope in active_scopes then { scope_set.insert(scope.raw_value) }
    return scope_set
}

private let mir_record_local_use(
    use_scopes_by_local mut ref Dict[UInt, List[Set[UInt]]],
    use_blocks_by_local mut ref Dict[UInt, Set[UInt]],
    local MIRLocalID,
    block MIRBlockID,
    active_scopes ref List[MIRScopeID],
) Void = {
    let mut use_scopes = use_scopes_by_local.get(local.raw_value) or else List[Set[UInt]].new()
    use_scopes.push(mir_current_scope_set(active_scopes))
    use_scopes_by_local.insert(local.raw_value, use_scopes)

    let mut use_blocks = use_blocks_by_local.get(local.raw_value) or else Set[UInt].new()
    use_blocks.insert(block.raw_value)
    use_blocks_by_local.insert(local.raw_value, use_blocks)
}

private let mir_walk_operand_uses(
    use_scopes_by_local mut ref Dict[UInt, List[Set[UInt]]],
    use_blocks_by_local mut ref Dict[UInt, Set[UInt]],
    operand MIROperand,
    block MIRBlockID,
    active_scopes ref List[MIRScopeID],
) Void = {
    when operand in {
        .Local(local) then mir_record_local_use(use_scopes_by_local, use_blocks_by_local, local, block, active_scopes),
        _ then {},
    }
}

private let mir_walk_place_uses(
    use_scopes_by_local mut ref Dict[UInt, List[Set[UInt]]],
    use_blocks_by_local mut ref Dict[UInt, Set[UInt]],
    place MIRPlace,
    block MIRBlockID,
    active_scopes ref List[MIRScopeID],
) Void = {
    when place in {
        .Local(local) then mir_record_local_use(use_scopes_by_local, use_blocks_by_local, local, block, active_scopes),
        .Global(_) then {},
        .Field(base, _) then mir_walk_place_uses(use_scopes_by_local, use_blocks_by_local, base.val, block, active_scopes),
        .EnumPayload(base, _, _, _, _) then mir_walk_place_uses(use_scopes_by_local, use_blocks_by_local, base.val, block, active_scopes),
        .Deref(base, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, base.val, block, active_scopes),
        .PointerElement(base, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, base.val, block, active_scopes),
    }
}

private let mir_walk_intrinsic_uses(
    use_scopes_by_local mut ref Dict[UInt, List[Set[UInt]]],
    use_blocks_by_local mut ref Dict[UInt, Set[UInt]],
    intrinsic_node MIRIntrinsic,
    block MIRBlockID,
    active_scopes ref List[MIRScopeID],
) Void = {
    when intrinsic_node in {
        .AllocMemory(count, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, count.val, block, active_scopes),
        .DeallocMemory(pointer) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, pointer.val, block, active_scopes),
        .CopyMemory(dest, source, count) then {
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, dest.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, source.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, count.val, block, active_scopes)
        },
        .MoveMemory(dest, source, count) then {
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, dest.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, source.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, count.val, block, active_scopes)
        },
        .IsUniqueMutable(value) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, value.val, block, active_scopes),
        .RefCount(value) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, value.val, block, active_scopes),
        .MakeRef(pointer, owner, _) then {
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, pointer.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, owner.val, block, active_scopes)
        },
        .MakeMutRef(pointer, owner, _) then {
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, pointer.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, owner.val, block, active_scopes)
        },
        .DowngradeRef(value, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, value.val, block, active_scopes),
        .DowngradeMutRef(value, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, value.val, block, active_scopes),
        .UpgradeRef(value, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, value.val, block, active_scopes),
        .UpgradeMutRef(value, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, value.val, block, active_scopes),
        .InitMemory(pointer, value) then {
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, pointer.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, value.val, block, active_scopes)
        },
        .DeinitMemory(pointer) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, pointer.val, block, active_scopes),
        .TakeMemory(pointer, _) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, pointer.val, block, active_scopes),
        .NullPtr(_) then {},
        .SpawnThread(out_handle, out_tid, closure, stack_size) then {
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, out_handle.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, out_tid.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, closure.val, block, active_scopes)
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, stack_size.val, block, active_scopes)
        },
    }
}

private let mir_walk_value_uses(
    use_scopes_by_local mut ref Dict[UInt, List[Set[UInt]]],
    use_blocks_by_local mut ref Dict[UInt, Set[UInt]],
    value MIRValue,
    block MIRBlockID,
    active_scopes ref List[MIRScopeID],
) Void = {
    when value in {
        .Operand(operand) then mir_walk_operand_uses(use_scopes_by_local, use_blocks_by_local, operand, block, active_scopes),
        .PlaceRead(place, _) then mir_walk_place_uses(use_scopes_by_local, use_blocks_by_local, place, block, active_scopes),
        .Binary(operation) then {
            mir_walk_operand_uses(use_scopes_by_local, use_blocks_by_local, operation.left, block, active_scopes)
            mir_walk_operand_uses(use_scopes_by_local, use_blocks_by_local, operation.right, block, active_scopes)
        },
        .Unary(operation) then mir_walk_operand_uses(use_scopes_by_local, use_blocks_by_local, operation.operand, block, active_scopes),
        .Call(call) then {
            mir_walk_operand_uses(use_scopes_by_local, use_blocks_by_local, call.callee, block, active_scopes)
            for argument in call.arguments then {
                mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, argument.val, block, active_scopes)
            }
        },
        .Aggregate(aggregate) then {
            for field in aggregate.fields then {
                mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, field.val, block, active_scopes)
            }
        },
        .EnumCase(construction) then {
            for argument in construction.arguments then {
                mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, argument.val, block, active_scopes)
            }
        },
        .EnumTag(tag) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, tag.subject.val, block, active_scopes),
        .TraitObjectConversion(conversion) then mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, conversion.inner.val, block, active_scopes),
        .TraitMethodCall(call) then {
            mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, call.receiver.val, block, active_scopes)
            for argument in call.arguments then {
                mir_walk_value_uses(use_scopes_by_local, use_blocks_by_local, argument.val, block, active_scopes)
            }
        },
        .Ref(place, _, _) then mir_walk_place_uses(use_scopes_by_local, use_blocks_by_local, place, block, active_scopes),
        .Pointer(place) then mir_walk_place_uses(use_scopes_by_local, use_blocks_by_local, place, block, active_scopes),
        .Cast(operand, _) then mir_walk_operand_uses(use_scopes_by_local, use_blocks_by_local, operand, block, active_scopes),
        .Intrinsic(node) then mir_walk_intrinsic_uses(use_scopes_by_local, use_blocks_by_local, node, block, active_scopes),
        .Lambda(lambda) then {
            for source in lambda.capture_sources then {
                mir_walk_place_uses(use_scopes_by_local, use_blocks_by_local, source, block, active_scopes)
            }
        },
    }
}

type MIRFunctionCodeEmitter(
    codegen mut ref CodeGen,
    function ref MIRFunction,
    mut local_names List[String],
    mut non_owning_local_ids ref Dict[UInt, Bool],
    mut init_flags List[String],
    mut lifetime_plan ref MIRLocalLifetimePlan,
    mut lambda_counter UInt,
    mut nested_definitions String,
)

private let build_mir_function_emit_plan(
    codegen ref CodeGen,
    function ref MIRFunction,
) ref MIRFunctionEmitPlan = {
    let mut local_names = List[String].new()
    let mut non_owning_local_ids = compute_non_owning_mir_locals(function)
    let mut init_flags = List[String].new()

    for local in function.locals then {
        let name = when local.storage in {
            .Parameter() then when local.symbol in {
                .Some(symbol) then codegen.c_identifier_for_symbol(symbol),
                .None() then codegen.sanitize_codegen_identifier(local.name),
            },
            .Capture() then when local.symbol in {
                .Some(symbol) then codegen.c_identifier_for_symbol(symbol),
                .None() then codegen.sanitize_codegen_identifier(local.name),
            },
            _ then "__mir_\(codegen.sanitize_codegen_identifier(local.name))_\(local.id.raw_value)",
        }
        let is_non_owning = when non_owning_local_ids.get(local.id.raw_value) in {
            .Some(_) then true,
            .None() then false,
        }
        local_names.push(name)
        init_flags.push(
            if local.storage is not .Capture() and not codegen.type_is_void_or_never(local.local_type) and codegen.needs_drop(local.local_type) and not is_non_owning
                then "__mir_init_\(local.id.raw_value)"
                else ""
        )
    }

    let lifetime_plan = build_mir_lifetime_plan(function, codegen, init_flags)
    return box(MIRFunctionEmitPlan(
        local_names,
        non_owning_local_ids,
        init_flags,
        lifetime_plan,
    ))
}

given MIRFunctionCodeEmitter {
    public new(codegen mut ref CodeGen, function ref MIRFunction, plan ref MIRFunctionEmitPlan) MIRFunctionCodeEmitter = {
        return MIRFunctionCodeEmitter(
            codegen,
            function,
            plan.local_names,
            plan.non_owning_local_ids,
            plan.init_flags,
            plan.lifetime_plan,
            0(UInt),
            String.new(),
        )
    }

    public emit_body(self mut ref) Void = {
        self.emit_local_declarations()
        for block in self.function.blocks then {
            self.emit_block(block)
        }
    }

    public get_nested_definitions(self ref) String = {
        return self.nested_definitions
    }

    private local_info(self ref, local_id MIRLocalID) Option[ref MIRLocal] = {
        if local_id.raw_value < self.function.locals.count() then {
            return Option[ref MIRLocal].Some(self.function.locals[local_id.raw_value])
        }
        return Option[ref MIRLocal].None()
    }

    private init_flag(self ref, local_id MIRLocalID) Option[String] = {
        if local_id.raw_value < self.init_flags.count() then {
            let flag = self.init_flags[local_id.raw_value]
            if not flag.is_empty() then {
                return Option[String].Some(flag)
            }
        }
        return Option[String].None()
    }

    private emit_local_declarations(self mut ref) Void = {
        for local_id in self.lifetime_plan.hoisted_declaration_locals then {
            when self.local_info(local_id) in {
                .Some(local) then {
                    let name = self.local_name(local.id)
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(self.codegen.c_type_name(local.local_type))
                    self.codegen.buffer.push_string(" ")
                    self.codegen.buffer.push_string(name)
                    self.codegen.buffer.push_string(";\n")
                },
                .None() then {},
            }
        }
        for local in self.function.locals then {
            when self.init_flag(local.id) in {
                .Some(flag) then {
                    let initial = if local.storage is .Parameter() then "1" else "0"
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string("_Bool ")
                    self.codegen.buffer.push_string(flag)
                    self.codegen.buffer.push_string(" = ")
                    self.codegen.buffer.push_string(initial)
                    self.codegen.buffer.push_string(";\n")
                },
                .None() then {},
            }
        }
    }

    private emit_block(self mut ref, block ref MIRBasicBlock) Void = {
        let preserved_return_local = when block.terminator in {
            .ReturnValue(operand_opt) then when operand_opt in {
                .Some(operand) then self.local_id_from_operand(operand),
                .None() then Option[MIRLocalID].None(),
            },
            _ then Option[MIRLocalID].None(),
        }
        let wraps_block = when self.lifetime_plan.block_local_declarations_by_block.get(block.id.raw_value) in {
            .Some(locals) then not locals.is_empty(),
            .None() then false,
        }
        self.codegen.add_indent()
        if wraps_block then {
            self.codegen.buffer.push_string(self.block_label(block.id))
            self.codegen.buffer.push_string(": {\n")
            let saved_indent = self.codegen.indent
            self.codegen.indent = "\(self.codegen.indent)    "
            for statement in block.statements then {
                when statement in {
                    .ScopeExit(scope) then self.emit_scope_cleanup_preserving(scope, preserved_return_local),
                    _ then self.emit_statement(statement),
                }
            }
            self.emit_terminator(block.terminator)
            self.codegen.indent = saved_indent
            self.codegen.add_indent()
            self.codegen.buffer.push_string("}\n")
            return
        }
        self.codegen.buffer.push_string(self.block_label(block.id))
        self.codegen.buffer.push_string(":;\n")
        for statement in block.statements then {
            when statement in {
                .ScopeExit(scope) then self.emit_scope_cleanup_preserving(scope, preserved_return_local),
                _ then self.emit_statement(statement),
            }
        }
        self.emit_terminator(block.terminator)
    }

    private emit_statement(self mut ref, statement ref MIRStatement) Void = {
        when statement in {
            .Declare(local_id) then {
        when self.lifetime_plan.block_local_declaration_locals.get(local_id.raw_value) in {
                    .Some(_) then when self.local_info(local_id) in {
                        .Some(local) then {
                            let name = self.local_name(local_id)
                            self.codegen.add_indent()
                            self.codegen.buffer.push_string(self.codegen.c_type_name(local.local_type))
                            self.codegen.buffer.push_string(" ")
                            self.codegen.buffer.push_string(name)
                            self.codegen.buffer.push_string(";\n")
                        },
                        .None() then {},
                    },
                    .None() then {},
                }
            },
            .Assign(place, value) then self.emit_assign(place, value),
            .CompoundAssign(assignment) then self.emit_compound_assign(assignment),
            .Drop(place) then self.emit_drop(place),
            .Retain(value) then self.emit_retain(value),
            .Release(value) then self.emit_release(value),
            .Evaluate(value) then self.emit_evaluate(value),
            .ScopeEnter(_) then {},
            .ScopeExit(scope) then self.emit_scope_cleanup(scope),
            .DebugSource(_) then {},
        }
    }

    private emit_terminator(self mut ref, terminator MIRTerminator) Void = {
        when terminator in {
            .Goto(block) then self.emit_goto(block),
            .Branch(condition, then_block, else_block) then {
                let condition_expr = self.emit_operand_expression(condition)
                self.codegen.add_indent()
                self.codegen.buffer.push_string("if (")
                self.codegen.buffer.push_string(condition_expr)
                self.codegen.buffer.push_string(") { goto ")
                self.codegen.buffer.push_string(self.block_label(then_block))
                self.codegen.buffer.push_string("; }\n")
                self.codegen.add_indent()
                self.codegen.buffer.push_string("goto ")
                self.codegen.buffer.push_string(self.block_label(else_block))
                self.codegen.buffer.push_string(";\n")
            },
            .SwitchValue(operand, cases, default_block) then {
                let switch_expr = self.emit_operand_expression(operand)
                self.codegen.add_indent()
                self.codegen.buffer.push_string("switch (")
                self.codegen.buffer.push_string(switch_expr)
                self.codegen.buffer.push_string(") {\n")
                let saved_indent = self.codegen.indent
                self.codegen.indent = "\(self.codegen.indent)    "
                for switch_case in cases then {
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string("case ")
                    self.codegen.buffer.push_string(self.switch_case_expression(switch_case.value))
                    self.codegen.buffer.push_string(": goto ")
                    self.codegen.buffer.push_string(self.block_label(switch_case.target))
                    self.codegen.buffer.push_string(";\n")
                }
                self.codegen.add_indent()
                when default_block in {
                    .Some(block) then {
                        self.codegen.buffer.push_string("default: goto ")
                        self.codegen.buffer.push_string(self.block_label(block))
                        self.codegen.buffer.push_string(";\n")
                    },
                    .None() then self.codegen.buffer.push_string("default: __builtin_unreachable();\n"),
                }
                self.codegen.indent = saved_indent
                self.codegen.add_indent()
                self.codegen.buffer.push_string("}\n")
            },
            .ReturnValue(operand) then self.emit_return(operand),
            .Unreachable() then {
                self.codegen.add_indent()
                self.codegen.buffer.push_string("__builtin_unreachable();\n")
            },
        }
    }

    private emit_goto(self mut ref, block MIRBlockID) Void = {
        self.codegen.add_indent()
        self.codegen.buffer.push_string("goto ")
        self.codegen.buffer.push_string(self.block_label(block))
        self.codegen.buffer.push_string(";\n")
    }

    private emit_assign(self mut ref, place MIRPlace, value MIRValue) Void = {
        let access = self.emit_place_access(place)
        let emission = self.emit_value(value)
        let target_type = self.type_of_place(place)
        let source_type = self.type_of_value(value)
        // When MIR assigns a void constant to a struct/enum result (dead branch of when/if),
        // emit memset instead of invalid `struct_var = 0`.
        if self.is_void_constant(value) and self.codegen.needs_drop(target_type) then {
            when self.local_target_id(place) in {
                .Some(local_id) then when self.init_flag(local_id) in {
                    .Some(flag) then self.emit_guarded_drop(flag, target_type, access.path),
                    .None() then {},
                },
                .None() then {},
            }
            self.codegen.add_indent()
            self.codegen.buffer.push_string("memset(&(")
            self.codegen.buffer.push_string(access.path)
            self.codegen.buffer.push_string("), 0, sizeof(")
            self.codegen.buffer.push_string(access.path)
            self.codegen.buffer.push_string("));\n")
            when self.local_target_id(place) in {
                .Some(local_id) then self.set_init_flag(local_id, true),
                .None() then {},
            }
            return
        }
        when self.local_target_id(place) in {
            .Some(local_id) then when self.init_flag(local_id) in {
                .Some(flag) then self.emit_guarded_drop(flag, target_type, access.path),
                .None() then {},
            },
            .None() then {
                // Non-local (field/deref): use temp to avoid use-after-free when
                // source and destination alias the same location.
                if self.codegen.needs_drop(target_type) then {
                    let temp = self.codegen.next_temp_with_decl(self.codegen.c_type_name(target_type))
                    self.codegen.append_copy_or_move_assignment(target_type, emission.expression, temp, false)
                    self.codegen.add_indent()
                    self.codegen.append_drop_statement(target_type, access.path)
                    let store_is_lvalue = self.is_deref_place(place)
                    self.codegen.append_copy_or_move_assignment(target_type, temp, access.path, store_is_lvalue)
                    self.consume_moved_source(value)
                    self.emit_cleanup(access.cleanup)
                    self.emit_residual_cleanups(emission, true)
                    return
                }
            },
        }
        let assigned_expression = self.adapt_expression_for_target_type(
            emission.expression,
            source_type,
            target_type,
            false,
            value is .Operand(.Function(_)),
        )
        // When assigning through a deref (pointer/ref), the old value is released
        // but the new value must be retained. Use copy semantics (retain) for
        // deref places; for other non-local places (field access), move is fine.
        let store_is_lvalue = self.is_deref_place(place)
        self.codegen.append_copy_or_move_assignment(target_type, assigned_expression, access.path, store_is_lvalue)
        self.consume_moved_source(value)
        self.emit_cleanup(access.cleanup)
        self.emit_residual_cleanups(emission, true)
        when self.local_target_id(place) in {
            .Some(local_id) then self.set_init_flag(local_id, true),
            .None() then {},
        }
    }

    private is_void_constant(self ref, value MIRValue) Bool = {
        return when value in {
            .Operand(operand) then when operand in {
                .Constant(constant) then when constant in {
                    .Void() then true,
                    _ then false,
                },
                _ then false,
            },
            _ then false,
        }
    }

    private is_deref_place(self ref, place MIRPlace) Bool = {
        return when place in {
            .Deref(_, _) then true,
            .Field(base, _) then self.is_deref_place(base.val),
            .EnumPayload(base, _, _, _, _) then self.is_deref_place(base.val),
            .Local(_) then false,
            .Global(_) then false,
            .PointerElement(_, _) then false,
        }
    }

    private emit_compound_assign(self mut ref, assignment MIRCompoundAssignment) Void = {
        let access = self.emit_place_access(assignment.target)
        let emission = self.emit_value(assignment.value)
        let target_type = self.type_of_place(assignment.target)
        // Use checked shift for integer types to avoid C undefined behavior
        // when shift amount >= bit width.
        if (assignment.operator_kind is .LeftShiftAssign() or assignment.operator_kind is .RightShiftAssign()) and self.codegen.is_integer_type(target_type) then {
            let shift_op = if assignment.operator_kind is .LeftShiftAssign() then BitwiseOperator.LeftShift() else BitwiseOperator.RightShift()
            let func_name = self.codegen.checked_shift_func_name(shift_op, target_type)
            self.codegen.add_indent()
            self.codegen.buffer.push_string(access.path)
            self.codegen.buffer.push_string(" = ")
            self.codegen.buffer.push_string(func_name)
            self.codegen.buffer.push_string("(")
            self.codegen.buffer.push_string(access.path)
            self.codegen.buffer.push_string(", ")
            self.codegen.buffer.push_string(emission.expression)
            self.codegen.buffer.push_string(");\n")
        } else {
            let op = self.compound_op_to_c(assignment.operator_kind)
            self.codegen.add_indent()
            self.codegen.buffer.push_string(access.path)
            self.codegen.buffer.push_string(" ")
            self.codegen.buffer.push_string(op)
            self.codegen.buffer.push_string(" ")
            self.codegen.buffer.push_string(emission.expression)
            self.codegen.buffer.push_string(";\n")
        }
        self.consume_moved_source(assignment.value)
        self.emit_cleanup(access.cleanup)
        self.emit_residual_cleanups(emission, true)
    }

    private compound_op_to_c(self ref, op CompoundAssignmentOperator) String = {
        return when op in {
            .AddAssign() then "+=",
            .SubtractAssign() then "-=",
            .MultiplyAssign() then "*=",
            .DivideAssign() then "/=",
            .RemainderAssign() then "%=",
            .BitAndAssign() then "&=",
            .BitOrAssign() then "|=",
            .BitXorAssign() then "^=",
            .LeftShiftAssign() then "<<=",
            .RightShiftAssign() then ">>=",
        }
    }

    private emit_drop(self mut ref, place MIRPlace) Void = {
        let access = self.emit_place_access(place)
        let drop_type = self.type_of_place(place)
        when self.local_target_id(place) in {
            .Some(local_id) then when self.init_flag(local_id) in {
                .Some(flag) then self.emit_guarded_drop(flag, drop_type, access.path),
                .None() then {},
            },
            .None() then {
                self.codegen.add_indent()
                self.codegen.append_drop_statement(drop_type, access.path)
            },
        }
        self.emit_cleanup(access.cleanup)
    }

    private emit_retain(self mut ref, value MIRValue) Void = {
        let emission = self.emit_value_source(value)
        let value_type = self.type_of_value(value)
        when value_type in {
            .ReferenceType(_) or .MutableReferenceType(_) or .TraitObject(_, _) then {
                self.codegen.add_indent()
                self.codegen.buffer.push_string("if (((")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(").control)) { __koral_retain(((")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(").control)); }\n")
            },
            .WeakReferenceType(_) or .MutableWeakReferenceType(_) then {
                self.codegen.add_indent()
                self.codegen.buffer.push_string("if (((")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(").control)) { __koral_weak_retain(((")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(").control)); }\n")
            },
            .FunctionType(_, _) then {
                self.codegen.add_indent()
                self.codegen.buffer.push_string("__koral_closure_retain(")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(");\n")
            },
            _ then {},
        }
        self.emit_cleanup(emission.cleanup)
    }

    private emit_release(self mut ref, value MIRValue) Void = {
        let emission = self.emit_value_source(value)
        self.codegen.add_indent()
        self.codegen.append_drop_statement(self.type_of_value(value), emission.expression)
        self.emit_cleanup(emission.cleanup)
    }

    private emit_evaluate(self mut ref, value MIRValue) Void = {
        let emission = self.emit_value(value)
        let value_type = self.type_of_value(value)
        if self.codegen.needs_drop(value_type) then {
            when value in {
                .Operand(.Local(local_id)) then when self.init_flag(local_id) in {
                    .Some(flag) then self.emit_guarded_drop(flag, value_type, emission.expression),
                    .None() then {},
                },
                _ then {
                    self.codegen.add_indent()
                    self.codegen.append_drop_statement(value_type, emission.expression)
                },
            }
            self.emit_residual_cleanups(emission, true)
        } else {
            self.emit_cleanup(emission.cleanup)
        }
    }

    private emit_scope_cleanup(self mut ref, scope MIRScopeID) Void = {
        self.emit_scope_cleanup_preserving(scope, Option[MIRLocalID].None())
    }

    private emit_scope_cleanup_preserving(self mut ref, scope MIRScopeID, preserved Option[MIRLocalID]) Void = {
        when self.lifetime_plan.locals_by_scope.get(scope.raw_value) in {
            .Some(locals) then {
                let mut i = locals.count()
                while i > 0 then {
                    i -= 1
                    let local_id = locals[i]
                    let skip = when preserved in {
                        .Some(value) then value.raw_value == local_id.raw_value,
                        .None() then false,
                    }
                    if not skip then {
                        when self.init_flag(local_id) in {
                            .Some(flag) then when self.local_info(local_id) in {
                                .Some(local) then self.emit_guarded_drop(flag, local.local_type, self.local_name(local_id)),
                                .None() then {},
                            },
                            .None() then {},
                        }
                    }
                }
            },
            .None() then {},
        }
    }

    private emit_return(self mut ref, operand Option[MIROperand]) Void = {
        when operand in {
            .Some(op) then {
                let raw_emission = self.emit_operand_value(op)
                let return_type = self.type_of_operand(op)
                let emission = raw_emission
                let should_copy = self.should_copy_returned_operand(op, return_type)
                let return_expression = if should_copy then {
                    let temp = self.codegen.next_temp_with_decl(self.codegen.c_type_name(return_type))
                    self.codegen.append_copy_or_move_assignment(return_type, emission.expression, temp, true)
                    self.emit_root_cleanup(Option[MIRLocalID].None())
                    yield temp
                } else {
                    // Treat returning a local as moving ownership to the caller.
                    // Otherwise root cleanup can still drop the same local before
                    // the `return`, which is catastrophic for boxed/string values.
                    when self.local_id_from_operand(op) in {
                        .Some(local_id) then self.set_init_flag(local_id, false),
                        .None() then {},
                    }
                    self.emit_root_cleanup(self.local_id_from_operand(op))
                    // For borrowed reference parameters, retain before returning so the
                    // caller receives an owned reference. Without this, the caller and
                    // the callee parameter share the same control block, and both
                    // releases cause a double-free.
                    if self.is_parameter_operand(op) and is_reference_like_type(return_type) then {
                        self.codegen.add_indent()
                        self.codegen.buffer.push_string("if ((")
                        self.codegen.buffer.push_string(emission.expression)
                        self.codegen.buffer.push_string(").control) { __koral_retain((")
                        self.codegen.buffer.push_string(emission.expression)
                        self.codegen.buffer.push_string(").control); }\n")
                    }
                    yield emission.expression
                }
                self.codegen.add_indent()
                self.codegen.buffer.push_string("return ")
                self.codegen.buffer.push_string(return_expression)
                self.codegen.buffer.push_string(";\n")
                self.emit_residual_cleanups(emission, not should_copy)
            },
            .None() then {
                self.emit_root_cleanup(Option[MIRLocalID].None())
                self.codegen.add_indent()
                self.codegen.buffer.push_string("return;\n")
            },
        }
    }

    private emit_root_cleanup(self mut ref, preserved Option[MIRLocalID]) Void = {
        let mut i = self.function.locals.count()
        while i > 0 then {
            i -= 1
            let local = self.function.locals[i]
            let local_id = local.id
            let skip = when preserved in { .Some(p) then p.raw_value == local_id.raw_value, .None() then false }
            if skip then { continue }
            when self.init_flag(local_id) in {
                .Some(flag) then self.emit_guarded_drop(flag, local.local_type, self.local_name(local_id)),
                .None() then {},
            }
        }
    }

    private emit_guarded_drop(self mut ref, flag String, drop_type Type, expression String) Void = {
        self.codegen.add_indent()
        self.codegen.buffer.push_string("if (")
        self.codegen.buffer.push_string(flag)
        self.codegen.buffer.push_string(") {\n")
        let saved_indent = self.codegen.indent
        self.codegen.indent = "\(self.codegen.indent)    "
        self.codegen.add_indent()
        self.codegen.append_drop_statement(drop_type, expression)
        self.codegen.add_indent()
        self.codegen.buffer.push_string(flag)
        self.codegen.buffer.push_string(" = 0;\n")
        self.codegen.indent = saved_indent
        self.codegen.add_indent()
        self.codegen.buffer.push_string("}\n")
    }

    private emit_value(self mut ref, value MIRValue) MIRValueEmission = {
        return when value in {
            .Operand(operand) then self.emit_operand_value(operand),
            .PlaceRead(place, ownership) then self.emit_place_read(place, ownership, false),
            .Binary(operation) then self.emit_binary(operation),
            .Unary(operation) then self.emit_unary(operation),
            .Call(call) then self.emit_call(call),
            .Aggregate(aggregate) then self.emit_aggregate(aggregate),
            .EnumCase(construction) then self.emit_enum_case(construction),
            .EnumTag(tag) then self.emit_enum_tag(tag),
            .TraitObjectConversion(conversion) then self.emit_trait_object_conversion(conversion),
            .TraitMethodCall(call) then self.emit_trait_method_call(call),
            .Ref(place, kind, allocation) then self.emit_reference(place, kind, allocation),
            .Pointer(place) then self.emit_pointer(place),
            .Cast(operand, target_type) then self.emit_cast_operand(operand, target_type),
            .Intrinsic(node) then self.emit_intrinsic(node),
            .Lambda(lambda) then self.emit_lambda(lambda),
        }
    }

    private emit_value_source(self mut ref, value MIRValue) MIRValueEmission = {
        return when value in {
            .PlaceRead(place, ownership) then self.emit_place_read(place, ownership, true),
            _ then self.emit_value(value),
        }
    }

    private emit_operand_value(self mut ref, operand MIROperand) MIRValueEmission = {
        return MIRValueEmission(self.emit_operand_expression(operand), Option[ref MIRValueCleanup].None())
    }

    private emit_operand_expression(self mut ref, operand MIROperand) String = {
        return when operand in {
            .Local(local) then self.local_name(local),
            .Function(symbol) then self.codegen.callable_c_name(symbol),
            .Constant(constant) then self.constant_expression(constant),
        }
    }

    private constant_expression(self mut ref, constant MIRConstant) String = {
        return when constant in {
            .Integer(value, _) then self.codegen.sanitize_c_numeric_literal(value),
            .Float(value, _) then self.codegen.sanitize_c_numeric_literal(value),
            .StringLiteral(value, string_type) then self.codegen.generate_string_literal(value, string_type),
            .Boolean(value) then if value then "1" else "0",
            .Void() then "0",
        }
    }

    private emit_place_read(self mut ref, place MIRPlace, ownership MIROwnershipUse, source_mode Bool) MIRValueEmission = {
        let access = self.emit_place_access(place)
        let place_type = self.type_of_place(place)
        if ownership is .Move() then {
            self.consume_moved_place(place)
        }
        if source_mode or ownership is not .Copy() or not self.codegen.needs_drop(place_type) then {
            return MIRValueEmission(access.path, access.cleanup)
        }
        let temp = self.codegen.next_temp_with_decl(self.codegen.c_type_name(place_type))
        self.codegen.append_copy_or_move_assignment(place_type, access.path, temp, true)
        self.emit_cleanup(access.cleanup)
        return MIRValueEmission(temp, self.cleanup_for_temporary_result(temp, place_type))
    }

    private emit_binary(self mut ref, operation MIRBinaryOperation) MIRValueEmission = {
        let left = self.emit_operand_expression(operation.left)
        let right = self.emit_operand_expression(operation.right)
        let result_type = operation.result_type
        let c_type = self.codegen.c_type_name(result_type)
        let expression = when operation.operator_kind in {
            .Arithmetic(op, checked) then {
                let expr = if checked and self.codegen.is_integer_type(result_type) then self.codegen.next_temp_with_call_2(c_type, self.codegen.checked_arithmetic_func_name(op, result_type), left, right) else self.codegen.next_temp_with_infix_init(c_type, left, self.codegen.arithmetic_op_to_c(op), right)
                yield expr
            },
            .WrappingArithmetic(op) then self.codegen.next_temp_with_call_2(c_type, self.wrapping_arithmetic_func_name(op, result_type), left, right),
            .Comparison(op) then self.codegen.next_temp_with_infix_init(c_type, left, self.codegen.comparison_op_to_c(op), right),
            .LogicalAnd() then self.codegen.next_temp_with_infix_init("_Bool", left, "&&", right),
            .LogicalOr() then self.codegen.next_temp_with_infix_init("_Bool", left, "||", right),
            .Bitwise(op, checked_shift) then {
                let expr = if checked_shift and self.codegen.is_integer_type(result_type) and (op is .LeftShift() or op is .RightShift()) then self.codegen.next_temp_with_call_2(c_type, self.codegen.checked_shift_func_name(op, result_type), left, right) else self.codegen.next_temp_with_infix_init(c_type, left, self.codegen.bitwise_op_to_c(op), right)
                yield expr
            },
            .WrappingShift(op) then self.codegen.next_temp_with_call_2(c_type, self.wrapping_shift_func_name(op, result_type), left, right),
        }
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, result_type))
    }

    private wrapping_arithmetic_func_name(self ref, op ArithmeticOperator, t Type) String = {
        let op_name = when op in {
            .Add() then "add",
            .Subtract() then "sub",
            .Multiply() then "mul",
            .Divide() then "div",
            .Remainder() then "rem",
        }
        return "koral_wrapping_\(op_name)_\(self.codegen.type_suffix(t))"
    }

    private wrapping_shift_func_name(self ref, op BitwiseOperator, t Type) String = {
        let op_name = when op in {
            .LeftShift() then "shl",
            .RightShift() then "shr",
            _ then "shl",
        }
        return "koral_wrapping_\(op_name)_\(self.codegen.type_suffix(t))"
    }

    private emit_unary(self mut ref, operation MIRUnaryOperation) MIRValueEmission = {
        let operand = self.emit_operand_expression(operation.operand)
        let result_type = operation.result_type
        let expression = when operation.operator_kind in {
            .LogicalNot() then self.codegen.next_temp_with_init("_Bool", "!\(operand)"),
            .BitwiseNot() then self.codegen.next_temp_with_init(self.codegen.c_type_name(result_type), "~\(operand)"),
        }
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, result_type))
    }

    private emit_call(self mut ref, call MIRCall) MIRValueEmission = {
        let has_ownerships = call.argument_ownerships.count() == call.arguments.count()
        when call.callee in {
            .Function(symbol) then {
                let function_name = self.codegen.callable_c_name(symbol)
                if call.arguments.count() == 0 then {
                    let expression = self.emit_direct_call_0(function_name, call.result_type)
                    return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, call.result_type))
                }
                if call.arguments.count() == 1 then {
                    let ownership = if has_ownerships then call.argument_ownerships[0(UInt)] else MIROwnershipUse.Move()
                    let emission = self.emit_direct_call_argument(call.arguments[0(UInt)].val, ownership)
                    let expression = self.emit_direct_call_1(function_name, emission.expression, call.result_type)
                    if ownership is .Move() or ownership is .Take() then {
                        self.consume_moved_source(call.arguments[0(UInt)].val)
                    }
                    self.emit_residual_cleanups(emission, self.call_arg_consumed(ownership, call.arguments[0(UInt)].val))
                    return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, call.result_type))
                }
                if call.arguments.count() == 2 then {
                    let first_ownership = if has_ownerships then call.argument_ownerships[0(UInt)] else MIROwnershipUse.Move()
                    let second_ownership = if has_ownerships then call.argument_ownerships[1(UInt)] else MIROwnershipUse.Move()
                    let first = self.emit_direct_call_argument(call.arguments[0(UInt)].val, first_ownership)
                    let second = self.emit_direct_call_argument(call.arguments[1(UInt)].val, second_ownership)
                    let expression = self.emit_direct_call_2(function_name, first.expression, second.expression, call.result_type)
                    if first_ownership is .Move() or first_ownership is .Take() then {
                        self.consume_moved_source(call.arguments[0(UInt)].val)
                    }
                    if second_ownership is .Move() or second_ownership is .Take() then {
                        self.consume_moved_source(call.arguments[1(UInt)].val)
                    }
                    self.emit_residual_cleanups(first, self.call_arg_consumed(first_ownership, call.arguments[0(UInt)].val))
                    self.emit_residual_cleanups(second, self.call_arg_consumed(second_ownership, call.arguments[1(UInt)].val))
                    return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, call.result_type))
                }
            },
            _ then {},
        }

        let mut arg_values = List[String].new()
        let mut emissions = List[MIRValueEmission].new()
        let mut ownerships = List[MIROwnershipUse].new()
        let mut arg_i UInt = 0
        while arg_i < call.arguments.count() then {
            let arg = call.arguments[arg_i]
            let ownership = if has_ownerships then call.argument_ownerships[arg_i] else MIROwnershipUse.Move()
            ownerships.push(ownership)
            let emission = self.emit_direct_call_argument(arg.val, ownership)
            emissions.push(emission)
            arg_values.push(emission.expression)
            arg_i += 1
        }
        let expression = when call.callee in {
            .Function(symbol) then self.emit_direct_call(self.codegen.callable_c_name(symbol), arg_values, call.result_type),
            _ then self.emit_closure_call(self.emit_operand_expression(call.callee), self.type_of_operand(call.callee), arg_values, call.result_type),
        }
        let mut consume_i UInt = 0
        while consume_i < call.arguments.count() then {
            let ownership = ownerships[consume_i]
            if ownership is .Move() or ownership is .Take() then {
                self.consume_moved_source(call.arguments[consume_i].val)
            }
            consume_i += 1
        }
        let mut cleanup_i UInt = 0
        while cleanup_i < emissions.count() then {
            self.emit_residual_cleanups(emissions[cleanup_i], self.call_arg_consumed(ownerships[cleanup_i], call.arguments[cleanup_i].val))
            cleanup_i += 1
        }
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, call.result_type))
    }

    private emit_direct_call_argument(self mut ref, value MIRValue, ownership MIROwnershipUse) MIRValueEmission = {
        let value_type = self.type_of_value(value)
        return when ownership in {
            .Copy() then {
                let emission = self.emit_value(value)
                if not self.codegen.needs_drop(value_type) then {
                    yield emission
                }
                yield when value in {
                    .PlaceRead(_, place_ownership) then {
                        if place_ownership is .Copy() then {
                            yield emission
                        } else {
                            let temp = self.codegen.next_temp_with_decl(self.codegen.c_type_name(value_type))
                            self.codegen.append_copy_or_move_assignment(value_type, emission.expression, temp, true)
                            self.emit_cleanup(emission.cleanup)
                            yield MIRValueEmission(temp, self.cleanup_for_temporary_result(temp, value_type))
                        }
                    },
                    _ then {
                        let temp = self.codegen.next_temp_with_decl(self.codegen.c_type_name(value_type))
                        self.codegen.append_copy_or_move_assignment(value_type, emission.expression, temp, true)
                        self.emit_cleanup(emission.cleanup)
                        yield MIRValueEmission(temp, self.cleanup_for_temporary_result(temp, value_type))
                    },
                }
            },
            .Borrow() then self.emit_value_source(value),
            .Move() then self.emit_value_source(value),
            .Take() then self.emit_value_source(value),
        }
    }

    private call_arg_consumed(self ref, ownership MIROwnershipUse, value MIRValue) Bool = {
        return when ownership in {
            .Move() or .Take() then true,
            .Copy() then when value in {
                .PlaceRead(_, borrow_ownership) then borrow_ownership is not .Borrow(),
                _ then true,
            },
            .Borrow() then false,
        }
    }

    private emit_direct_call_0(self mut ref, function_name String, return_type Type) String = {
        if self.codegen.type_is_void_or_never(return_type) then {
            self.codegen.add_indent()
            self.codegen.buffer.push_string(function_name)
            self.codegen.buffer.push_string("();\n")
            return ""
        }
        return self.codegen.next_temp_with_call_0(self.codegen.c_type_name(return_type), function_name)
    }

    private emit_direct_call_1(self mut ref, function_name String, arg String, return_type Type) String = {
        if self.codegen.type_is_void_or_never(return_type) then {
            self.codegen.add_indent()
            self.codegen.buffer.push_string(function_name)
            self.codegen.buffer.push_string("(")
            self.codegen.buffer.push_string(arg)
            self.codegen.buffer.push_string(");\n")
            return ""
        }
        return self.codegen.next_temp_with_call_1(self.codegen.c_type_name(return_type), function_name, arg)
    }

    private emit_direct_call_2(self mut ref, function_name String, first_arg String, second_arg String, return_type Type) String = {
        if self.codegen.type_is_void_or_never(return_type) then {
            self.codegen.add_indent()
            self.codegen.buffer.push_string(function_name)
            self.codegen.buffer.push_string("(")
            self.codegen.buffer.push_string(first_arg)
            self.codegen.buffer.push_string(", ")
            self.codegen.buffer.push_string(second_arg)
            self.codegen.buffer.push_string(");\n")
            return ""
        }
        return self.codegen.next_temp_with_call_2(self.codegen.c_type_name(return_type), function_name, first_arg, second_arg)
    }

    private emit_direct_call(self mut ref, function_name String, arguments List[String], return_type Type) String = {
        if self.codegen.type_is_void_or_never(return_type) then {
            self.codegen.add_indent()
            self.codegen.buffer.push_string(function_name)
            self.codegen.buffer.push_string("(")
            self.codegen.push_joined_strings(arguments, ", ")
            self.codegen.buffer.push_string(");\n")
            return ""
        }
        return self.codegen.next_temp_with_call_args(self.codegen.c_type_name(return_type), function_name, arguments)
    }

    private emit_closure_call(self mut ref, closure_expr String, callee_type Type, arguments List[String], return_type Type) String = {
        let mut param_types = List[String].new()
        when callee_type in {
            .FunctionType(params, _) then for param in params then { param_types.push(self.codegen.c_type_name(param.param_type)) },
            _ then {},
        }
        let no_capture_sig = if param_types.is_empty() then "void" else join_strings(param_types, ", ")
        let mut with_capture_parts = List[String].new()
        with_capture_parts.push("void*")
        for p in param_types then { with_capture_parts.push(p) }
        let with_capture_sig = join_strings(with_capture_parts, ", ")
        let return_c_type = self.codegen.c_type_name(return_type)
        let mut args_with_env = List[String].new()
        args_with_env.push("\(closure_expr).env")
        for arg in arguments then { args_with_env.push(arg) }
        if self.codegen.type_is_void_or_never(return_type) then {
            self.codegen.add_indent()
            self.codegen.buffer.push_string("if (")
            self.codegen.buffer.push_string(closure_expr)
            self.codegen.buffer.push_string(".env == NULL) {\n")
            self.codegen.indent = "\(self.codegen.indent)    "
            self.codegen.add_indent()
            self.codegen.buffer.push_string("((")
            self.codegen.buffer.push_string(return_c_type)
            self.codegen.buffer.push_string(" (*)(")
            self.codegen.buffer.push_string(no_capture_sig)
            self.codegen.buffer.push_string("))(")
            self.codegen.buffer.push_string(closure_expr)
            self.codegen.buffer.push_string(".fn))(")
            self.codegen.push_joined_strings(arguments, ", ")
            self.codegen.buffer.push_string(");\n")
            self.codegen.indent = self.codegen.indent.substring(..self.codegen.indent.count() - 4(UInt))
            self.codegen.add_indent()
            self.codegen.buffer.push_string("} else {\n")
            self.codegen.indent = "\(self.codegen.indent)    "
            self.codegen.add_indent()
            self.codegen.buffer.push_string("((")
            self.codegen.buffer.push_string(return_c_type)
            self.codegen.buffer.push_string(" (*)(")
            self.codegen.buffer.push_string(with_capture_sig)
            self.codegen.buffer.push_string("))(")
            self.codegen.buffer.push_string(closure_expr)
            self.codegen.buffer.push_string(".fn))(")
            self.codegen.push_joined_strings(args_with_env, ", ")
            self.codegen.buffer.push_string(");\n")
            self.codegen.indent = self.codegen.indent.substring(..self.codegen.indent.count() - 4(UInt))
            self.codegen.add_indent()
            self.codegen.buffer.push_string("}\n")
            return ""
        }
        let result = self.codegen.next_temp_with_decl(return_c_type)
        self.codegen.add_indent()
        self.codegen.buffer.push_string("if (")
        self.codegen.buffer.push_string(closure_expr)
        self.codegen.buffer.push_string(".env == NULL) {\n")
        self.codegen.indent = "\(self.codegen.indent)    "
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(" = ((")
        self.codegen.buffer.push_string(return_c_type)
        self.codegen.buffer.push_string(" (*)(")
        self.codegen.buffer.push_string(no_capture_sig)
        self.codegen.buffer.push_string("))(")
        self.codegen.buffer.push_string(closure_expr)
        self.codegen.buffer.push_string(".fn))(")
        self.codegen.push_joined_strings(arguments, ", ")
        self.codegen.buffer.push_string(");\n")
        self.codegen.indent = self.codegen.indent.substring(..self.codegen.indent.count() - 4(UInt))
        self.codegen.add_indent()
        self.codegen.buffer.push_string("} else {\n")
        self.codegen.indent = "\(self.codegen.indent)    "
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(" = ((")
        self.codegen.buffer.push_string(return_c_type)
        self.codegen.buffer.push_string(" (*)(")
        self.codegen.buffer.push_string(with_capture_sig)
        self.codegen.buffer.push_string("))(")
        self.codegen.buffer.push_string(closure_expr)
        self.codegen.buffer.push_string(".fn))(")
        self.codegen.push_joined_strings(args_with_env, ", ")
        self.codegen.buffer.push_string(");\n")
        self.codegen.indent = self.codegen.indent.substring(..self.codegen.indent.count() - 4(UInt))
        self.codegen.add_indent()
        self.codegen.buffer.push_string("}\n")
        return result
    }

    private emit_aggregate(self mut ref, aggregate MIRAggregate) MIRValueEmission = {
        let mut fields = List[String].new()
        let mut emissions = List[MIRValueEmission].new()
        for field in aggregate.fields then {
            self.consume_moved_source(field.val)
            let emission = self.emit_value(field.val)
            emissions.push(emission)
            fields.push(emission.expression)
        }
        let expression = self.codegen.next_temp_with_braced_values(self.codegen.c_type_name(aggregate.aggregate_type), fields)
        for emission in emissions then { self.emit_residual_cleanups(emission, true) }
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, aggregate.aggregate_type))
    }

    private emit_enum_case(self mut ref, construction MIREnumConstruction) MIRValueEmission = {
        let expression = self.codegen.next_temp_with_decl(self.codegen.c_type_name(construction.enum_type))
        let case_info = self.enum_case_info(construction.enum_type, construction.case_name)
        self.codegen.add_indent()
        self.codegen.buffer.push_string(expression)
        self.codegen.buffer.push_string(".tag = ")
        self.codegen.buffer.push_string(case_info.first.to_string())
        self.codegen.buffer.push_string(";\n")
        let mut argument_index UInt = 0
        for field in case_info.second then {
            if not self.codegen.type_is_void(field.param_type) then {
                let arg_value = construction.arguments[argument_index].val
                let emission = self.emit_value(arg_value)
                let field_dest = "\(expression).data.\(self.codegen.sanitize_codegen_identifier(construction.case_name)).\(self.codegen.sanitize_codegen_identifier(field.name))"
                let assigned_expression = self.adapt_expression_for_target_type(
                    emission.expression,
                    self.type_of_value(arg_value),
                    field.param_type,
                    false,
                    arg_value is .Operand(.Function(_)),
                )
                self.codegen.append_copy_or_move_assignment(field.param_type, assigned_expression, field_dest, false)
                self.consume_moved_source(arg_value)
                self.emit_residual_cleanups(emission, true)
                argument_index += 1
            }
        }
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, construction.enum_type))
    }

    private emit_enum_tag(self mut ref, tag MIREnumTag) MIRValueEmission = {
        let subject = self.emit_value_source(tag.subject.val)
        let subject_expr = when self.type_of_value(tag.subject.val) in {
            .ReferenceType(inner) then "(*(\(self.codegen.c_type_name(inner.val))*)\(subject.expression).ptr)",
            .MutableReferenceType(inner) then "(*(\(self.codegen.c_type_name(inner.val))*)\(subject.expression).ptr)",
            .WeakReferenceType(inner) then "(*(\(self.codegen.c_type_name(inner.val))*)\(subject.expression).ptr)",
            .MutableWeakReferenceType(inner) then "(*(\(self.codegen.c_type_name(inner.val))*)\(subject.expression).ptr)",
            _ then subject.expression,
        }
        let expression = self.codegen.next_temp_with_init(self.codegen.c_type_name(Type.IntType()), "\(subject_expr).tag")
        self.emit_cleanup(subject.cleanup)
        return MIRValueEmission(expression, Option[ref MIRValueCleanup].None())
    }

    private emit_trait_object_conversion(self mut ref, conversion MIRTraitObjectConversion) MIRValueEmission = {
        let inner = self.emit_value_source(conversion.inner.val)
        let inner_type = self.type_of_value(conversion.inner.val)
        let should_retain = conversion.source_ownership is .Copy() or conversion.source_ownership is .Borrow()
        // If inner is a scalar type (not a ref), we need to heap-allocate it first
        let is_ref_type = when inner_type in {
            .ReferenceType(_) or .MutableReferenceType(_) or .WeakReferenceType(_) or .MutableWeakReferenceType(_) or .TraitObject(_, _) then true,
            _ then false,
        }
        let mut ref_expression = inner.expression
        if not is_ref_type then {
            // Merged layout: allocate control block + payload in one malloc
            let pointee_c_type = self.codegen.c_type_name(inner_type)
            let ref_temp = self.codegen.next_temp_with_decl("struct __koral_Ref")
            self.codegen.add_indent()
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".control = malloc(sizeof(struct __koral_Control) + sizeof(")
            self.codegen.buffer.push_string(pointee_c_type)
            self.codegen.buffer.push_string("));\n")
            self.codegen.add_indent()
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".ptr = (char*)")
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".control + sizeof(struct __koral_Control);\n")
            self.codegen.add_indent()
            self.codegen.buffer.push_string("((struct __koral_Control*)")
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".control)->strong_count = 1;\n")
            self.codegen.add_indent()
            self.codegen.buffer.push_string("((struct __koral_Control*)")
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".control)->weak_count = 1;\n")
            self.codegen.add_indent()
            self.codegen.buffer.push_string("((struct __koral_Control*)")
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".control)->ptr = ")
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".ptr;\n")
            self.codegen.add_indent()
            self.codegen.buffer.push_string("((struct __koral_Control*)")
            self.codegen.buffer.push_string(ref_temp)
            self.codegen.buffer.push_string(".control)->dtor = ")
            when inner_type in {
                .StructureType(def_id) then {
                    self.codegen.buffer.push_string("(__koral_Dtor)__koral_\(self.codegen.c_name_for_def_id(def_id))_drop;\n")
                },
                .EnumType(def_id) then {
                    self.codegen.buffer.push_string("(__koral_Dtor)__koral_\(self.codegen.c_name_for_def_id(def_id))_drop;\n")
                },
                _ then {
                    self.codegen.buffer.push_string("NULL;\n")
                },
            }
            let dest_expr = "*(" + pointee_c_type + "*)" + ref_temp + ".ptr"
            self.codegen.append_copy_or_move_assignment(inner_type, inner.expression, dest_expr, false)
            ref_expression = ref_temp
        }
        let expression = self.codegen.generate_trait_object_conversion_from_ref_value(ref_expression, conversion.trait_name, conversion.concrete_type, should_retain)
        if conversion.source_ownership is .Move() then {
            self.consume_moved_source(conversion.inner.val)
        }
        self.emit_residual_cleanups(inner, conversion.source_ownership is .Move())
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, conversion.result_type))
    }

    private trait_object_target_name(self ref, t Type) Option[String] = {
        return when t in {
            .TraitObject(trait_name, _) then Option[String].Some(trait_name),
            .ReferenceType(inner) then self.trait_object_target_name(inner.val),
            .MutableReferenceType(inner) then self.trait_object_target_name(inner.val),
            _ then Option[String].None(),
        }
    }

    private trait_object_source_concrete_type(self ref, t Type) Option[Type] = {
        let _ = self
        return when t in {
            .ReferenceType(inner) then if inner.val is .TraitObject(_, _)
                then Option[Type].None()
                else Option[Type].Some(inner.val),
            .MutableReferenceType(inner) then if inner.val is .TraitObject(_, _)
                then Option[Type].None()
                else Option[Type].Some(inner.val),
            _ then Option[Type].None(),
        }
    }

    private adapt_expression_for_target_type(
        self mut ref,
        expression String,
        source_type Type,
        target_type Type,
        retain_source Bool,
        bare_function_source Bool,
    ) String = {
        // Wrap bare function pointers in closure structs when target is FunctionType
        if target_type is .FunctionType(_, _) and source_type is .FunctionType(_, _) then {
            if bare_function_source then {
                return "(struct __koral_Closure){ .fn = (void*)\(expression), .env = NULL, .drop = NULL }"
            }
            return expression
        }
        return when self.trait_object_target_name(target_type) in {
            .Some(trait_name) then when self.trait_object_source_concrete_type(source_type) in {
                .Some(concrete_type) then self.codegen.generate_trait_object_conversion_from_ref_value(expression, trait_name, concrete_type, retain_source),
                .None() then expression,
            },
            .None() then expression,
        }
    }

    private emit_trait_method_call(self mut ref, call MIRTraitMethodCall) MIRValueEmission = {
        let receiver = self.emit_value_source(call.receiver.val)
        let mut arg_values = List[String].new()
        let mut arg_types = List[Type].new()
        let mut idx UInt = 0
        while idx < call.arguments.count() then {
            let emission = self.emit_value_source(call.arguments[idx].val)
            arg_values.push(emission.expression)
            arg_types.push(self.type_of_value(call.arguments[idx].val))
            if call.argument_ownerships[idx] is .Move() then {
                self.consume_moved_source(call.arguments[idx].val)
            }
            self.emit_residual_cleanups(emission, call.argument_ownerships[idx] is .Move())
            idx += 1
        }
        let expression = self.emit_trait_method_call_abi(receiver.expression, call.receiver_ownership, call.trait_name, self.type_list_to_ref_list(call.trait_type_args), call.method_name, call.method_index, arg_values, arg_types, call.result_type)
        if call.receiver_ownership is .Move() then {
            self.consume_moved_source(call.receiver.val)
        }
        self.emit_residual_cleanups(receiver, call.receiver_ownership is .Move())
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, call.result_type))
    }

    private emit_trait_method_call_abi(
        self mut ref,
        receiver_result String,
        receiver_ownership MIROwnershipUse,
        trait_name String,
        trait_type_args List[ref Type],
        method_name String,
        method_index Int,
        arg_values List[String],
        arg_types List[Type],
        result_type Type,
    ) String = {
        let members = self.codegen.get_ordered_trait_members_for_vtable(trait_name, self.codegen.trait_object_type_from_name(trait_name), trait_type_args)
        let mut dispatch_method_name = method_name
        let mut signature_return_type = result_type
        let mut signature_param_types = List[Type].new()
        if method_index >= 0 and method_index(UInt) < members.count() then {
            let member = members[method_index(UInt)]
            dispatch_method_name = member.name
            signature_return_type = member.return_type or else signature_return_type
            for p in member.parameters then { signature_param_types.push(p.param_type or else Type.Unknown()) }
        } else {
            for member in members then {
                if member.name == method_name then {
                    dispatch_method_name = member.name
                    signature_return_type = member.return_type or else signature_return_type
                    for p in member.parameters then { signature_param_types.push(p.param_type or else Type.Unknown()) }
                    break
                }
            }
        }

        let effective_return_type = when result_type in { .Unknown() then signature_return_type, _ then result_type }
        let mut method_param_types = List[String].new()
        method_param_types.push("struct __koral_Ref")
        let mut arg_index UInt = 0
        while arg_index < arg_values.count() then {
            let expected_type = if arg_index + 1 < signature_param_types.count() then signature_param_types[arg_index + 1] else arg_types[arg_index]
            method_param_types.push(self.codegen.c_type_name(expected_type))
            arg_index += 1
        }
        let ref_var = self.codegen.next_temp_with_init("struct __koral_Ref", "(struct __koral_Ref){ .ptr = \(receiver_result).ptr, .control = \(receiver_result).control }")
        if receiver_ownership is .Copy() or receiver_ownership is .Borrow() then {
            self.codegen.add_indent()
            self.codegen.buffer.push_string("__koral_retain(")
            self.codegen.buffer.push_string(ref_var)
            self.codegen.buffer.push_string(".control);\n")
        }
        let mut call_args = List[String].new()
        call_args.push(ref_var)
        for arg in arg_values then { call_args.push(arg) }
        let sanitized_method = self.codegen.sanitize_codegen_identifier(dispatch_method_name)
        let return_c_type = self.codegen.c_type_name(effective_return_type)
        let method_field_type = "\(return_c_type) (*\(sanitized_method))(\(join_strings(method_param_types, ", ")))"
        let vtable_struct = self.vtable_prefix_struct_type_for_mir_method(members, dispatch_method_name, method_field_type)
        let vt_call_target = "((\(vtable_struct)*)\(receiver_result).vtable)->\(sanitized_method)"
        if self.codegen.type_is_void_or_never(effective_return_type) then {
            self.codegen.add_indent()
            self.codegen.buffer.push_string(vt_call_target)
            self.codegen.buffer.push_string("(")
            self.codegen.push_joined_strings(call_args, ", ")
            self.codegen.buffer.push_string(");\n")
            return ""
        }
        return self.codegen.next_temp_with_call_args(return_c_type, vt_call_target, call_args)
    }

    private vtable_prefix_struct_type_for_mir_method(self ref, members List[MIRTraitVTableMethod], method_name String, method_field_type String) String = {
        let mut code = "struct { "
        if members.is_empty() then {
            code.push_string(method_field_type)
            code.push_string("; ")
            code.push_string("}")
            return code
        }
        for member in members then {
            let field_name = self.codegen.sanitize_codegen_identifier(member.name)
            if member.name == method_name then {
                code.push_string(method_field_type)
                code.push_string("; ")
                break
            }
            code.push_string("void (*")
            code.push_string(field_name)
            code.push_string(")(); ")
        }
        code.push_string("}")
        return code
    }

    private emit_reference(self mut ref, place MIRPlace, kind MIRReferenceKind, allocation MIRReferenceAllocation) MIRValueEmission = {
        let result_type = self.type_of_ref(place, kind)
        return when allocation in {
            .HeapOwned() then self.emit_heap_reference(place, result_type),
            .StackBorrow() then self.emit_borrowed_reference(place, result_type),
        }
    }

    private emit_borrowed_reference(self mut ref, place MIRPlace, result_type Type) MIRValueEmission = {
        let access = self.emit_place_access(place)
        let result = self.codegen.next_temp_with_decl(self.codegen.c_type_name(result_type))
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".ptr = &")
        self.codegen.buffer.push_string(access.path)
        self.codegen.buffer.push_string(";\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control = ")
        self.codegen.buffer.push_string(access.control)
        self.codegen.buffer.push_string(";\n")
        self.emit_cleanup(access.cleanup)
        return MIRValueEmission(result, Option[ref MIRValueCleanup].None())
    }

    private emit_heap_reference(self mut ref, place MIRPlace, result_type Type) MIRValueEmission = {
        let access = self.emit_place_access(place)
        let pointee_type = self.type_of_place(place)
        let pointee_c_type = self.codegen.c_type_name(pointee_type)
        let result = self.codegen.next_temp_with_decl(self.codegen.c_type_name(result_type))
        let should_transfer = self.can_transfer_owned_heap_reference(place)
        // Merged layout: allocate control block + payload in one malloc
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control = malloc(sizeof(struct __koral_Control) + sizeof(")
        self.codegen.buffer.push_string(pointee_c_type)
        self.codegen.buffer.push_string("));\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".ptr = (char*)")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control + sizeof(struct __koral_Control);\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string("((struct __koral_Control*)")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control)->strong_count = 1;\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string("((struct __koral_Control*)")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control)->weak_count = 1;\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string("((struct __koral_Control*)")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control)->ptr = ")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".ptr;\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string("((struct __koral_Control*)")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control)->dtor = ")
        when pointee_type in {
            .StructureType(def_id) then {
                self.codegen.buffer.push_string("(__koral_Dtor)__koral_\(self.codegen.c_name_for_def_id(def_id))_drop;\n")
            },
            .EnumType(def_id) then {
                self.codegen.buffer.push_string("(__koral_Dtor)__koral_\(self.codegen.c_name_for_def_id(def_id))_drop;\n")
            },
            _ then {
                self.codegen.buffer.push_string("NULL;\n")
            },
        }
        self.codegen.append_copy_or_move_assignment(pointee_type, access.path, "*(\(pointee_c_type)*)\(result).ptr", not should_transfer)
        if should_transfer then {
            self.consume_moved_place(place)
        }
        self.emit_cleanup(access.cleanup)
        return MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
    }

    private can_transfer_owned_heap_reference(self ref, place MIRPlace) Bool = {
        return when place in {
            .Local(local) then self.init_flag(local) is .Some(_),
            _ then false,
        }
    }

    private emit_pointer(self mut ref, place MIRPlace) MIRValueEmission = {
        let access = self.emit_place_access(place)
        let pointer_type = self.type_of_pointer(place)
        let expression = self.codegen.next_temp_with_init(self.codegen.c_type_name(pointer_type), "&\(access.path)")
        self.emit_cleanup(access.cleanup)
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, pointer_type))
    }

    private is_float_cast_source_type(self ref, t Type) Bool = {
        let _ = self
        return when t in {
            .Float32Type() then true,
            .Float64Type() then true,
            _ then false,
        }
    }

    private is_signed_int_cast_target_type(self ref, t Type) Bool = {
        let _ = self
        return when t in {
            .Int8Type() then true,
            .Int16Type() then true,
            .Int32Type() then true,
            .Int64Type() then true,
            .IntType() then true,
            _ then false,
        }
    }

    private is_unsigned_int_cast_target_type(self ref, t Type) Bool = {
        let _ = self
        return when t in {
            .UInt8Type() then true,
            .UInt16Type() then true,
            .UInt32Type() then true,
            .UInt64Type() then true,
            .UIntType() then true,
            _ then false,
        }
    }

    private float_cast_target_bounds(self ref, t Type) Option[Pair[String, String]] = {
        let _ = self
        return when t in {
            .Int8Type() then Option[Pair[String, String]].Some(Pair[String, String]("INT8_MIN", "INT8_MAX")),
            .Int16Type() then Option[Pair[String, String]].Some(Pair[String, String]("INT16_MIN", "INT16_MAX")),
            .Int32Type() then Option[Pair[String, String]].Some(Pair[String, String]("INT32_MIN", "INT32_MAX")),
            .Int64Type() then Option[Pair[String, String]].Some(Pair[String, String]("INT64_MIN", "INT64_MAX")),
            .IntType() then Option[Pair[String, String]].Some(Pair[String, String]("INTPTR_MIN", "INTPTR_MAX")),
            .UInt8Type() then Option[Pair[String, String]].Some(Pair[String, String]("0", "UINT8_MAX")),
            .UInt16Type() then Option[Pair[String, String]].Some(Pair[String, String]("0", "UINT16_MAX")),
            .UInt32Type() then Option[Pair[String, String]].Some(Pair[String, String]("0", "UINT32_MAX")),
            .UInt64Type() then Option[Pair[String, String]].Some(Pair[String, String]("0", "UINT64_MAX")),
            .UIntType() then Option[Pair[String, String]].Some(Pair[String, String]("0", "UINTPTR_MAX")),
            _ then Option[Pair[String, String]].None(),
        }
    }

    private emit_cast_operand(self mut ref, operand MIROperand, target_type Type) MIRValueEmission = {
        let source = self.emit_operand_value(operand)
        let source_type = self.type_of_operand(operand)
        let target_c_type = self.codegen.c_type_name(target_type)
        let expression = if self.is_float_cast_source_type(source_type)
            and (self.is_signed_int_cast_target_type(target_type) or self.is_unsigned_int_cast_target_type(target_type))
        then when self.float_cast_target_bounds(target_type) in {
            .Some(bounds) then {
                let float_value = self.codegen.next_temp_with_init("double", "(double)\(source.expression)")
                self.codegen.add_indent()
                self.codegen.buffer.push_string("if (!(\(float_value) >= (double)\(bounds.first) && \(float_value) <= (double)\(bounds.second))) {\n")
                self.codegen.add_indent()
                self.codegen.buffer.push_string("    __koral_panic_float_cast_overflow();\n")
                self.codegen.add_indent()
                self.codegen.buffer.push_string("}\n")
                yield self.codegen.next_temp_with_init(target_c_type, "(\(target_c_type))\(float_value)")
            },
            .None() then self.codegen.next_temp_with_init(target_c_type, "(\(target_c_type))\(source.expression)"),
        } else self.codegen.next_temp_with_init(target_c_type, "(\(target_c_type))\(source.expression)")
        self.emit_cleanup(source.cleanup)
        return MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, target_type))
    }

    private emit_intrinsic(self mut ref, node MIRIntrinsic) MIRValueEmission = {
        return when node in {
            .AllocMemory(count, result_type) then {
                let count_emission = self.emit_value_source(count.val)
                let element_type = self.pointer_element_type(result_type)
                let expression = self.codegen.next_temp_with_decl(self.codegen.c_type_name(result_type))
                self.codegen.add_indent()
                self.codegen.buffer.push_string(expression)
                self.codegen.buffer.push_string(" = malloc(")
                self.codegen.buffer.push_string(count_emission.expression)
                self.codegen.buffer.push_string(" * sizeof(")
                self.codegen.buffer.push_string(self.codegen.c_type_name(element_type))
                self.codegen.buffer.push_string("));\n")
                self.emit_cleanup(count_emission.cleanup)
                yield MIRValueEmission(expression, Option[ref MIRValueCleanup].None())
            },
            .DeallocMemory(pointer) then {
                let p = self.emit_value_source(pointer.val)
                self.codegen.add_indent()
                self.codegen.buffer.push_string("free(")
                self.codegen.buffer.push_string(p.expression)
                self.codegen.buffer.push_string(");\n")
                self.emit_cleanup(p.cleanup)
                yield MIRValueEmission("", Option[ref MIRValueCleanup].None())
            },
            .CopyMemory(dest, source, count) then self.emit_memory_transfer("memcpy", dest.val, source.val, count.val),
            .MoveMemory(dest, source, count) then self.emit_memory_transfer("memmove", dest.val, source.val, count.val),
            .IsUniqueMutable(value) then self.emit_is_unique(value.val),
            .RefCount(value) then self.emit_ref_count(value.val),
            .MakeRef(pointer, owner, result_type) then self.emit_make_ref(pointer.val, owner.val, result_type),
            .MakeMutRef(pointer, owner, result_type) then self.emit_make_ref(pointer.val, owner.val, result_type),
            .DowngradeRef(value, result_type) then self.emit_downgrade_ref(value.val, result_type),
            .DowngradeMutRef(value, result_type) then self.emit_downgrade_ref(value.val, result_type),
            .UpgradeRef(value, result_type) then self.emit_upgrade_ref(value.val, result_type),
            .UpgradeMutRef(value, result_type) then self.emit_upgrade_ref(value.val, result_type),
            .InitMemory(pointer, value) then {
                let p = self.emit_value_source(pointer.val)
                let v = self.emit_value_source(value.val)
                let element_type = self.pointer_element_type(self.type_of_value(pointer.val))
                self.codegen.append_copy_assignment(element_type, v.expression, "*(\(self.codegen.c_type_name(element_type))*)\(p.expression)")
                self.consume_moved_source(value.val)
                self.emit_cleanup(p.cleanup)
                self.emit_residual_cleanups(v, true)
                yield MIRValueEmission("", Option[ref MIRValueCleanup].None())
            },
            .DeinitMemory(pointer) then {
                let p = self.emit_value_source(pointer.val)
                let element_type = self.pointer_element_type(self.type_of_value(pointer.val))
                self.codegen.add_indent()
                self.codegen.append_drop_statement(element_type, "*(\(self.codegen.c_type_name(element_type))*)\(p.expression)")
                self.emit_cleanup(p.cleanup)
                yield MIRValueEmission("", Option[ref MIRValueCleanup].None())
            },
            .TakeMemory(pointer, result_type) then {
                let p = self.emit_value_source(pointer.val)
                let expression = self.codegen.next_temp_with_init(self.codegen.c_type_name(result_type), "*(\(self.codegen.c_type_name(result_type))*)\(p.expression)")
                self.emit_cleanup(p.cleanup)
                yield MIRValueEmission(expression, self.cleanup_for_temporary_result(expression, result_type))
            },
            .NullPtr(result_type) then {
                let expression = self.codegen.next_temp_with_init(self.codegen.c_type_name(result_type), "NULL")
                yield MIRValueEmission(expression, Option[ref MIRValueCleanup].None())
            },
            .SpawnThread(out_handle, out_tid, closure, stack_size) then self.emit_spawn_thread(out_handle.val, out_tid.val, closure.val, stack_size.val),
        }
    }

    private emit_lambda(self mut ref, lambda MIRLambda) MIRValueEmission = {
        // Resolve capture sources to C expression paths
        let mut capture_source_overrides = Dict[UInt, String].new()
        let mut capture_source_cleanups = List[ref MIRValueCleanup].new()
        let mut ci UInt = 0
        while ci < lambda.captures.count() then {
            let capture = lambda.captures[ci]
            let source = lambda.capture_sources[ci]
            let access = self.emit_place_access(source)
            capture_source_overrides.insert(capture.def_id.id, access.path)
            when access.cleanup in {
                .Some(cleanup) then capture_source_cleanups.push(cleanup),
                .None() then {},
            }
            ci += 1
        }
        let closure = self.generate_lambda_expression(lambda, capture_source_overrides)
        // Clean up capture source cleanups
        for cleanup_ref in capture_source_cleanups then {
            self.emit_cleanup(Option[ref MIRValueCleanup].Some(cleanup_ref))
        }
        return MIRValueEmission(closure, self.cleanup_for_temporary_result(closure, lambda.lambda_type))
    }

    private generate_lambda_expression(self mut ref, lambda MIRLambda, capture_source_overrides Dict[UInt, String]) String = {
        let lambda_name = self.next_lambda_name()
        // Extract function parameters and return type from lambda_type
        let (function_params, return_type) = when lambda.lambda_type in {
            .FunctionType(params, ret) then (params, ret.val),
            _ then (List[ref FunctionParamEntry].new(), Type.VoidType()),
        }

        if lambda.captures.is_empty() then {
            // No captures: generate a plain C function
            self.generate_no_capture_lambda_function(lambda_name, lambda.params, function_params, return_type, lambda.function)
            return self.codegen.next_temp_with_init("struct __koral_Closure", "{ .fn = (void*)\(lambda_name), .env = NULL, .drop = NULL }")
        }

        // With captures: generate env struct, capture function, heap-allocate env
        let env_struct_name = "\(lambda_name)_env"
        self.generate_lambda_env_struct(env_struct_name, lambda.captures)
        self.generate_capture_lambda_function(lambda_name, env_struct_name, lambda.params, function_params, return_type, lambda.captures, capture_source_overrides, lambda.function)

        // Heap-allocate env and populate captures
        let env_var = self.codegen.next_temp_with_init("struct \(env_struct_name)*", "(struct \(env_struct_name)*)malloc(sizeof(struct \(env_struct_name)))")
        self.codegen.add_indent()
        self.codegen.buffer.push_string(env_var)
        self.codegen.buffer.push_string("->__refcount = 1;\n")

        let mut ci UInt = 0
        while ci < lambda.captures.count() then {
            let capture = lambda.captures[ci]
            let field_name = self.capture_field_name(capture.val)
            let source = capture_source_overrides.get(capture.def_id.id) or else ""
            let dest = "\(env_var)->\(field_name)"
            self.codegen.append_copy_or_move_assignment(capture.symbol_type, source, dest, true)
            ci += 1
        }

        return self.codegen.next_temp_with_init("struct __koral_Closure", "{ .fn = (void*)\(lambda_name), .env = \(env_var), .drop = __koral_\(env_struct_name)_drop }")
    }

    private generate_no_capture_lambda_function(self mut ref, name String, params List[ref Symbol], function_params List[ref FunctionParamEntry], return_type Type, mir_function ref MIRFunction) Void = {
        let plan = build_mir_function_emit_plan(self.codegen, mir_function)
        let mut parameter_local_names = List[String].new()
        for local in mir_function.locals then {
            if local.storage is .Parameter() and parameter_local_names.count() < params.count() then {
                parameter_local_names.push(plan.local_names[local.id.raw_value])
            }
        }
        // Build parameter list
        let mut param_parts = List[String].new()
        let mut pi UInt = 0
        while pi < params.count() then {
            let param = params[pi]
            let c_type = if pi < function_params.count() then self.codegen.c_type_name(function_params[pi].param_type) else self.codegen.c_type_name(param.symbol_type)
            let param_name = if pi < parameter_local_names.count() then parameter_local_names[pi] else self.codegen.c_identifier_for_symbol(param.val)
            param_parts.push("\(c_type) \(param_name)")
            pi += 1
        }
        let param_str = if param_parts.is_empty() then "void" else join_strings(param_parts, ", ")
        let return_c_type = self.codegen.c_type_name(return_type)

        let saved_indent = self.codegen.indent
        self.codegen.indent = "    "
        let mut body_emitter = MIRFunctionCodeEmitter.new(self.codegen, mir_function, plan)
        let saved_buffer = self.codegen.buffer
        self.codegen.buffer = box(CodegenBuffer.new())
        body_emitter.emit_body()
        let body_text = self.codegen.buffer.to_string()
        self.codegen.buffer = saved_buffer
        let inner_nested = body_emitter.nested_definitions
        self.codegen.indent = saved_indent

        self.nested_definitions.push_string(inner_nested)
        self.nested_definitions.push_string("static \(return_c_type) \(name)(\(param_str)) {\n")
        self.nested_definitions.push_string(body_text)
        self.nested_definitions.push_string("}\n")
    }

    private generate_capture_lambda_function(self mut ref, name String, env_struct_name String, params List[ref Symbol], function_params List[ref FunctionParamEntry], return_type Type, captures List[ref Symbol], capture_source_overrides Dict[UInt, String], mir_function ref MIRFunction) Void = {
        let plan = build_mir_function_emit_plan(self.codegen, mir_function)
        let mut parameter_local_names = List[String].new()
        for local in mir_function.locals then {
            if local.storage is .Parameter() and parameter_local_names.count() < params.count() then {
                parameter_local_names.push(plan.local_names[local.id.raw_value])
            }
        }
        // Build parameter list with void* __env first
        let mut param_parts = List[String].new()
        param_parts.push("void* __env")
        let mut pi UInt = 0
        while pi < params.count() then {
            let param = params[pi]
            let c_type = if pi < function_params.count() then self.codegen.c_type_name(function_params[pi].param_type) else self.codegen.c_type_name(param.symbol_type)
            let param_name = if pi < parameter_local_names.count() then parameter_local_names[pi] else self.codegen.c_identifier_for_symbol(param.val)
            param_parts.push("\(c_type) \(param_name)")
            pi += 1
        }
        let param_str = join_strings(param_parts, ", ")
        let return_c_type = self.codegen.c_type_name(return_type)

        let saved_indent = self.codegen.indent
        self.codegen.indent = "    "
        let mut body_emitter = MIRFunctionCodeEmitter.new(self.codegen, mir_function, plan)
        let saved_buffer = self.codegen.buffer
        self.codegen.buffer = box(CodegenBuffer.new())
        // Override local names for captured variables
        for capture in captures then {
            let capture_name = "__captured->\(self.capture_field_name(capture.val))"
            for local in mir_function.locals then {
                when local.symbol in {
                    .Some(symbol) then {
                        if symbol.def_id.id == capture.def_id.id and local.storage is .Capture() then {
                            body_emitter.local_names[local.id.raw_value] = capture_name
                        }
                    },
                    .None() then {},
                }
            }
        }
        body_emitter.emit_body()
        let body_text = self.codegen.buffer.to_string()
        self.codegen.buffer = saved_buffer
        let inner_nested = body_emitter.nested_definitions
        self.codegen.indent = saved_indent

        self.nested_definitions.push_string(inner_nested)
        self.nested_definitions.push_string("static \(return_c_type) \(name)(\(param_str)) {\n")
        self.nested_definitions.push_string("    struct \(env_struct_name)* __captured = (struct \(env_struct_name)*)__env;\n")
        self.nested_definitions.push_string(body_text)
        self.nested_definitions.push_string("}\n")
    }

    private generate_lambda_env_struct(self mut ref, env_struct_name String, captures List[ref Symbol]) Void = {
        // Generate env struct definition
        self.nested_definitions.push_string("struct \(env_struct_name) {\n")
        self.nested_definitions.push_string("    _Atomic intptr_t __refcount;\n")
        for capture in captures then {
            let field_name = self.capture_field_name(capture.val)
            let c_type = self.codegen.c_type_name(capture.symbol_type)
            self.nested_definitions.push_string("    \(c_type) \(field_name);\n")
        }
        self.nested_definitions.push_string("};\n")

        // Generate drop function
        self.nested_definitions.push_string("static void __koral_\(env_struct_name)_drop(void* raw_env) {\n")
        self.nested_definitions.push_string("    struct \(env_struct_name)* env = (struct \(env_struct_name)*)raw_env;\n")
        for capture in captures then {
            let field_name = self.capture_field_name(capture.val)
            if self.codegen.needs_drop(capture.symbol_type) then {
                let saved_buffer = self.codegen.buffer
                self.codegen.buffer = box(CodegenBuffer.new())
                self.codegen.add_indent()
                self.codegen.append_drop_statement(capture.symbol_type, "env->\(field_name)")
                self.nested_definitions.push_string(self.codegen.buffer.to_string())
                self.codegen.buffer = saved_buffer
            }
        }
        self.nested_definitions.push_string("    free(raw_env);\n")
        self.nested_definitions.push_string("}\n")
    }

    private emit_place_access(self mut ref, place MIRPlace) MIRPlaceAccess = {
        return when place in {
            .Local(local) then {
                let name = self.local_name(local)
                yield MIRPlaceAccess(name, self.control_expression(self.type_of_place(place), name), Option[ref MIRValueCleanup].None())
            },
            .Global(def_id) then {
                let name = self.codegen.c_identifier_opt(def_id) or else self.codegen.sanitize_codegen_identifier(self.context_name(def_id))
                yield MIRPlaceAccess(name, self.control_expression(self.type_of_place(place), name), Option[ref MIRValueCleanup].None())
            },
            .Field(base, field) then {
                let base_access = self.emit_place_access(base.val)
                let field_name = self.codegen.sanitize_codegen_identifier(self.codegen.context.symbol_name(field))
                let path = when self.type_of_place(base.val) in {
                    .ReferenceType(inner) or .MutableReferenceType(inner) or .WeakReferenceType(inner) or .MutableWeakReferenceType(inner) then {
                        let mut path = String.new()
                        path.push_string("(*(")
                        path.push_string(self.codegen.c_type_name(inner.val))
                        path.push_string("*)")
                        path.push_string(base_access.path)
                        path.push_string(".ptr).")
                        path.push_string(field_name)
                        yield path
                    },
                    _ then {
                        let mut path = String.new()
                        path.push_string(base_access.path)
                        path.push_string(".")
                        path.push_string(field_name)
                        yield path
                    },
                }
                yield MIRPlaceAccess(path, base_access.control, base_access.cleanup)
            },
            .EnumPayload(base, case_name, field_name, _, _) then {
                let base_access = self.emit_place_access(base.val)
                let payload_base = when self.type_of_place(base.val) in {
                    .ReferenceType(inner) or .MutableReferenceType(inner) or .WeakReferenceType(inner) or .MutableWeakReferenceType(inner) then {
                        let mut payload_base = String.new()
                        payload_base.push_string("(*(")
                        payload_base.push_string(self.codegen.c_type_name(inner.val))
                        payload_base.push_string("*)")
                        payload_base.push_string(base_access.path)
                        payload_base.push_string(".ptr)")
                        yield payload_base
                    },
                    _ then base_access.path,
                }
                let mut path = String.new()
                path.push_string(payload_base)
                path.push_string(".data.")
                path.push_string(self.codegen.sanitize_codegen_identifier(case_name))
                path.push_string(".")
                path.push_string(self.codegen.sanitize_codegen_identifier(field_name))
                yield MIRPlaceAccess(path, base_access.control, base_access.cleanup)
            },
            .Deref(base, pointee) then {
                let base_emission = self.emit_value_source(base.val)
                let base_type = self.type_of_value(base.val)
                yield when base_type in {
                    .ReferenceType(_) or .MutableReferenceType(_) then {
                        let mut path = String.new()
                        path.push_string("(*(")
                        path.push_string(self.codegen.c_type_name(pointee))
                        path.push_string("*)")
                        path.push_string(base_emission.expression)
                        path.push_string(".ptr)")
                        let mut control = String.new()
                        control.push_string(base_emission.expression)
                        control.push_string(".control")
                        yield MIRPlaceAccess(path, control, base_emission.cleanup)
                    },
                    _ then {
                        let mut path = String.new()
                        path.push_string("(*(")
                        path.push_string(self.codegen.c_type_name(pointee))
                        path.push_string("*)")
                        path.push_string(base_emission.expression)
                        path.push_string(")")
                        yield MIRPlaceAccess(path, "NULL", base_emission.cleanup)
                    },
                }
            },
            .PointerElement(base, element) then {
                let base_emission = self.emit_value_source(base.val)
                let mut path = String.new()
                path.push_string("(*(")
                path.push_string(self.codegen.c_type_name(element))
                path.push_string("*)")
                path.push_string(base_emission.expression)
                path.push_string(")")
                yield MIRPlaceAccess(path, "NULL", base_emission.cleanup)
            },
        }
    }

    private type_of_place(self ref, place MIRPlace) Type = {
        return when place in {
            .Local(local) then when self.local_info(local) in { .Some(info) then info.local_type, .None() then Type.Unknown() },
            .Global(def_id) then self.codegen.context.get_symbol_type(def_id) or else Type.Unknown(),
            .Field(_, field) then field.symbol_type,
            .EnumPayload(_, _, _, _, field_type) then field_type,
            .Deref(_, pointee) then pointee,
            .PointerElement(_, element) then element,
        }
    }

    private type_of_value(self ref, value MIRValue) Type = {
        return when value in {
            .Operand(operand) then self.type_of_operand(operand),
            .PlaceRead(place, _) then self.type_of_place(place),
            .Binary(operation) then operation.result_type,
            .Unary(operation) then operation.result_type,
            .Call(call) then call.result_type,
            .Aggregate(aggregate) then aggregate.aggregate_type,
            .EnumCase(construction) then construction.enum_type,
            .EnumTag(_) then Type.IntType(),
            .TraitObjectConversion(conversion) then conversion.result_type,
            .TraitMethodCall(call) then call.result_type,
            .Ref(place, kind, _) then self.type_of_ref(place, kind),
            .Pointer(place) then self.type_of_pointer(place),
            .Cast(_, target_type) then target_type,
            .Intrinsic(node) then self.type_of_intrinsic(node),
            .Lambda(lambda) then lambda.lambda_type,
        }
    }

    private type_of_operand(self ref, operand MIROperand) Type = {
        return when operand in {
            .Local(local) then when self.local_info(local) in { .Some(info) then info.local_type, .None() then Type.Unknown() },
            .Function(symbol) then symbol.symbol_type,
            .Constant(constant) then when constant in {
                .Integer(_, t) then t,
                .Float(_, t) then t,
                .StringLiteral(_, t) then t,
                .Boolean(_) then Type.BoolType(),
                .Void() then Type.VoidType(),
            },
        }
    }

    private type_of_ref(self ref, place MIRPlace, kind MIRReferenceKind) Type = {
        let inner = self.type_of_place(place)
        return when kind in {
            .Mutable() then Type.MutableReferenceType(box(inner)),
            .Weak() then Type.WeakReferenceType(box(inner)),
            .MutableWeak() then Type.MutableWeakReferenceType(box(inner)),
            .Shared() then Type.ReferenceType(box(inner)),
        }
    }

    private type_of_pointer(self ref, place MIRPlace) Type = Type.PointerType(box(self.type_of_place(place)))

    private type_of_intrinsic(self ref, node MIRIntrinsic) Type = {
        return when node in {
            .AllocMemory(_, result_type) then result_type,
            .IsUniqueMutable(_) then Type.BoolType(),
            .RefCount(_) then Type.UIntType(),
            .MakeRef(_, _, result_type) then result_type,
            .MakeMutRef(_, _, result_type) then result_type,
            .DowngradeRef(_, result_type) then result_type,
            .DowngradeMutRef(_, result_type) then result_type,
            .UpgradeRef(_, result_type) then result_type,
            .UpgradeMutRef(_, result_type) then result_type,
            .TakeMemory(_, result_type) then result_type,
            .NullPtr(result_type) then result_type,
            .SpawnThread(_, _, _, _) then Type.Int32Type(),
            _ then Type.VoidType(),
        }
    }

    private local_target_id(self ref, place MIRPlace) Option[MIRLocalID] = when place in { .Local(local) then Option[MIRLocalID].Some(local), _ then Option[MIRLocalID].None() }
    private local_id_from_operand(self ref, operand MIROperand) Option[MIRLocalID] = when operand in { .Local(local) then Option[MIRLocalID].Some(local), _ then Option[MIRLocalID].None() }
    private local_name(self ref, local MIRLocalID) String = if local.raw_value < self.local_names.count() then self.local_names[local.raw_value] else "__mir_local_\(local.raw_value)"
    private block_label(self ref, block MIRBlockID) String = "__mir_bb_\(block.raw_value)"

    private is_parameter_operand(self ref, operand MIROperand) Bool = {
        return when operand in {
            .Local(local) then when self.local_info(local) in {
                .Some(info) then info.storage is .Parameter(),
                .None() then false,
            },
            _ then false,
        }
    }

    private root_local_of_place(self ref, place MIRPlace) Option[MIRLocalID] = {
        return when place in {
            .Local(local) then Option[MIRLocalID].Some(local),
            .Field(base, _) then self.root_local_of_place(base.val),
            .EnumPayload(base, _, _, _, _) then self.root_local_of_place(base.val),
            _ then Option[MIRLocalID].None(),
        }
    }

    private consume_moved_place(self mut ref, place MIRPlace) Void = {
        when self.root_local_of_place(place) in {
            .Some(local) then self.set_init_flag(local, false),
            .None() then {},
        }
    }

    private consume_moved_source(self mut ref, value MIRValue) Void = {
        when value in {
            .Operand(.Local(local)) then self.set_init_flag(local, false),
            .PlaceRead(place, ownership) then {
                if ownership is .Move() then {
                    self.consume_moved_place(place)
                }
            },
            _ then {},
        }
    }

    private next_lambda_name(self mut ref) String = {
        let name = "__koral_lambda_\(self.function.identifier.def_id.id)_\(self.lambda_counter)"
        self.lambda_counter += 1
        return name
    }

    private capture_field_name(self ref, symbol Symbol) String = {
        return self.codegen.c_identifier_for_symbol(symbol)
    }

    private should_copy_returned_operand(self ref, operand MIROperand, operand_type Type) Bool = {
        if not self.codegen.needs_drop(operand_type) then { return false }
        return when operand in {
            .Local(local) then when self.local_info(local) in {
                .Some(info) then if info.storage is .Capture()
                    then true
                    else self.non_owning_local_ids.get(local.raw_value) is .Some(_),
                .None() then false,
            },
            _ then false,
        }
    }

    private set_init_flag(self mut ref, local MIRLocalID, value Bool) Void = {
        when self.init_flag(local) in {
            .Some(flag) then {
                self.codegen.add_indent()
                self.codegen.buffer.push_string(flag)
                self.codegen.buffer.push_string(" = ")
                self.codegen.buffer.push_string(if value then "1" else "0")
                self.codegen.buffer.push_string(";\n")
            },
            .None() then {},
        }
    }

    private cleanup_for_temporary_result(self ref, expression String, cleanup_type Type) Option[ref MIRValueCleanup] = {
        if not expression.is_empty() and self.codegen.needs_drop(cleanup_type) then {
            return Option[ref MIRValueCleanup].Some(box(MIRValueCleanup(expression, cleanup_type)))
        }
        return Option[ref MIRValueCleanup].None()
    }

    private emit_cleanup(self mut ref, cleanup Option[ref MIRValueCleanup]) Void = {
        when cleanup in {
            .Some(item) then {
                self.codegen.add_indent()
                self.codegen.append_drop_statement(item.cleanup_type, item.name)
            },
            .None() then {},
        }
    }

    private emit_residual_cleanups(self mut ref, emission MIRValueEmission, consumed Bool) Void = {
        when emission.cleanup in {
            .Some(cleanup) then {
                if consumed and cleanup.name == emission.expression then {
                    return
                }
                self.codegen.add_indent()
                self.codegen.append_drop_statement(cleanup.cleanup_type, cleanup.name)
            },
            .None() then {},
        }
    }

    private control_expression(self ref, value_type Type, value String) String = {
        return when value_type in {
            .ReferenceType(_) or .MutableReferenceType(_) or .WeakReferenceType(_) or .MutableWeakReferenceType(_) or .TraitObject(_, _) then {
                let mut control = String.new()
                control.push_string(value)
                control.push_string(".control")
                yield control
            },
            _ then "NULL",
        }
    }

    private context_name(self ref, def_id DefId) String = self.codegen.context.get_name(def_id) or else "global_\(def_id.id)"

    private switch_case_expression(self mut ref, constant MIRConstant) String = self.constant_expression(constant)

    private enum_case_info(self ref, enum_type Type, case_name String) Pair[UInt, List[EnumCaseParam]] = {
        let def_id = when enum_type in { .EnumType(id) then id, _ then DefId(0(UInt)) }
        when self.codegen.context.get_enum_cases(def_id) in {
            .Some(cases) then {
                let mut index UInt = 0
                for c in cases then {
                    if c.name == case_name then { return Pair[UInt, List[EnumCaseParam]](index, c.params) }
                    index += 1
                }
            },
            .None() then {},
        }
        return Pair[UInt, List[EnumCaseParam]](0(UInt), List[EnumCaseParam].new())
    }

    private type_list_to_ref_list(self ref, args List[Type]) List[ref Type] = {
        let mut out = List[ref Type].new()
        for arg in args then { out.push(box(arg)) }
        return out
    }

    private pointer_element_type(self ref, pointer_type Type) Type = when pointer_type in { .PointerType(inner) then inner.val, .MutablePointerType(inner) then inner.val, _ then Type.VoidType() }

    private emit_memory_transfer(self mut ref, function_name String, dest MIRValue, source MIRValue, count MIRValue) MIRValueEmission = {
        let d = self.emit_value_source(dest)
        let s = self.emit_value_source(source)
        let c = self.emit_value_source(count)
        let element_type = self.pointer_element_type(self.type_of_value(dest))
        self.codegen.add_indent()
        self.codegen.buffer.push_string(function_name)
        self.codegen.buffer.push_string("(")
        self.codegen.buffer.push_string(d.expression)
        self.codegen.buffer.push_string(", ")
        self.codegen.buffer.push_string(s.expression)
        self.codegen.buffer.push_string(", ")
        self.codegen.buffer.push_string(c.expression)
        self.codegen.buffer.push_string(" * sizeof(")
        self.codegen.buffer.push_string(self.codegen.c_type_name(element_type))
        self.codegen.buffer.push_string("));\n")
        self.emit_cleanup(d.cleanup)
        self.emit_cleanup(s.cleanup)
        self.emit_cleanup(c.cleanup)
        return MIRValueEmission("", Option[ref MIRValueCleanup].None())
    }

    private emit_is_unique(self mut ref, value MIRValue) MIRValueEmission = {
        let emission = self.emit_value_source(value)
        let result = self.codegen.next_temp_with_decl("int")
        // The value is ptr mut ref T — a raw pointer to the ref struct.
        // Dereference to access the control block: ((struct __koral_Ref*)ptr)->control
        let value_type = self.type_of_value(value)
        let control = when value_type in {
            .MutablePointerType(_) or .PointerType(_) then "((struct __koral_Ref*)\(emission.expression))->control",
            _ then self.control_expression(value_type, emission.expression),
        }
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(" = 0;\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string("if (")
        self.codegen.buffer.push_string(control)
        self.codegen.buffer.push_string(") { ")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(" = (atomic_load(&((struct __koral_Control*)")
        self.codegen.buffer.push_string(control)
        self.codegen.buffer.push_string(")->strong_count) == 1); }\n")
        self.emit_cleanup(emission.cleanup)
        return MIRValueEmission(result, Option[ref MIRValueCleanup].None())
    }

    private emit_ref_count(self mut ref, value MIRValue) MIRValueEmission = {
        let emission = self.emit_value_source(value)
        let result = self.codegen.next_temp_with_decl(self.codegen.c_type_name(Type.UIntType()))
        let value_type = self.type_of_value(value)
        let control = when value_type in {
            .MutablePointerType(_) or .PointerType(_) then "((struct __koral_Ref*)\(emission.expression))->control",
            _ then self.control_expression(value_type, emission.expression),
        }
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(" = 0;\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string("if (")
        self.codegen.buffer.push_string(control)
        self.codegen.buffer.push_string(") { ")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(" = (")
        self.codegen.buffer.push_string(self.codegen.c_type_name(Type.UIntType()))
        self.codegen.buffer.push_string(")atomic_load(&((struct __koral_Control*)")
        self.codegen.buffer.push_string(control)
        self.codegen.buffer.push_string(")->strong_count); }\n")
        self.emit_cleanup(emission.cleanup)
        return MIRValueEmission(result, Option[ref MIRValueCleanup].None())
    }

    private emit_make_ref(self mut ref, pointer MIRValue, owner MIRValue, result_type Type) MIRValueEmission = {
        let p = self.emit_value_source(pointer)
        let o = self.emit_value_source(owner)
        let result = self.codegen.next_temp_with_decl(self.codegen.c_type_name(result_type))
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".ptr = (void*)")
        self.codegen.buffer.push_string(p.expression)
        self.codegen.buffer.push_string(";\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control = ")
        self.codegen.buffer.push_string(o.expression)
        self.codegen.buffer.push_string(".control;\n")
        self.codegen.add_indent()
        self.codegen.buffer.push_string("if (")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control) { __koral_retain(")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".control); }\n")
        self.emit_cleanup(p.cleanup)
        self.emit_cleanup(o.cleanup)
        return MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
    }

    private emit_runtime_unary_ref(self mut ref, function_name String, value MIRValue, result_type Type) MIRValueEmission = {
        let emission = self.emit_value_source(value)
        let result = self.codegen.next_temp_with_init(self.codegen.c_type_name(result_type), "\(function_name)(\(emission.expression))")
        self.emit_cleanup(emission.cleanup)
        return MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
    }

    private emit_downgrade_ref(self mut ref, value MIRValue, result_type Type) MIRValueEmission = {
        let emission = self.emit_value_source(value)
        return when self.type_of_value(value) in {
            .ReferenceType(inner) then if inner.val is .TraitObject(_, _) then {
                let result = self.codegen.next_temp_with_decl("struct __koral_TraitWeakRef")
                let weak_temp = self.codegen.next_temp_with_decl("struct __koral_WeakRef")
                self.codegen.add_indent()
                self.codegen.buffer.push_string(weak_temp)
                self.codegen.buffer.push_string(" = __koral_downgrade_ref((struct __koral_Ref){")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(".ptr, ")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(".control});\n")
                self.codegen.add_indent()
                self.codegen.buffer.push_string(result)
                self.codegen.buffer.push_string(".control = ")
                self.codegen.buffer.push_string(weak_temp)
                self.codegen.buffer.push_string(".control;\n")
                self.codegen.add_indent()
                self.codegen.buffer.push_string(result)
                self.codegen.buffer.push_string(".vtable = ")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(".vtable;\n")
                self.emit_cleanup(emission.cleanup)
                yield MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
            } else self.emit_runtime_unary_ref_from_emission("__koral_downgrade_ref", emission, result_type),
            .MutableReferenceType(inner) then if inner.val is .TraitObject(_, _) then {
                let result = self.codegen.next_temp_with_decl("struct __koral_TraitWeakRef")
                let weak_temp = self.codegen.next_temp_with_decl("struct __koral_WeakRef")
                self.codegen.add_indent()
                self.codegen.buffer.push_string(weak_temp)
                self.codegen.buffer.push_string(" = __koral_downgrade_ref((struct __koral_Ref){")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(".ptr, ")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(".control});\n")
                self.codegen.add_indent()
                self.codegen.buffer.push_string(result)
                self.codegen.buffer.push_string(".control = ")
                self.codegen.buffer.push_string(weak_temp)
                self.codegen.buffer.push_string(".control;\n")
                self.codegen.add_indent()
                self.codegen.buffer.push_string(result)
                self.codegen.buffer.push_string(".vtable = ")
                self.codegen.buffer.push_string(emission.expression)
                self.codegen.buffer.push_string(".vtable;\n")
                self.emit_cleanup(emission.cleanup)
                yield MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
            } else self.emit_runtime_unary_ref_from_emission("__koral_downgrade_ref", emission, result_type),
            _ then self.emit_runtime_unary_ref_from_emission("__koral_downgrade_ref", emission, result_type),
        }
    }

    private emit_runtime_unary_ref_from_emission(
        self mut ref,
        function_name String,
        emission MIRValueEmission,
        result_type Type,
    ) MIRValueEmission = {
        let result = self.codegen.next_temp_with_init(self.codegen.c_type_name(result_type), "\(function_name)(\(emission.expression))")
        self.emit_cleanup(emission.cleanup)
        return MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
    }

    private emit_upgrade_ref(self mut ref, value MIRValue, result_type Type) MIRValueEmission = {
        let emission = self.emit_value_source(value)
        let success = self.codegen.next_temp_with_decl("int")
        return when self.type_of_value(value) in {
            .WeakReferenceType(inner) then if inner.val is .TraitObject(_, _) then {
                let upgraded = self.codegen.next_temp_with_init("struct __koral_Ref", "__koral_upgrade_ref((struct __koral_WeakRef){\(emission.expression).control}, &\(success))")
                let result = self.codegen.next_temp_with_decl(self.codegen.c_type_name(result_type))
                self.codegen.add_indent()
                self.codegen.buffer.push_string("if (")
                self.codegen.buffer.push_string(success)
                self.codegen.buffer.push_string(") {\n")
                self.codegen.with_indent(() -> {
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".tag = 1;\n")
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".data.Some.value.ptr = ")
                    self.codegen.buffer.push_string(upgraded)
                    self.codegen.buffer.push_string(".ptr;\n")
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".data.Some.value.control = ")
                    self.codegen.buffer.push_string(upgraded)
                    self.codegen.buffer.push_string(".control;\n")
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".data.Some.value.vtable = ")
                    self.codegen.buffer.push_string(emission.expression)
                    self.codegen.buffer.push_string(".vtable;\n")
                })
                self.codegen.add_indent()
                self.codegen.buffer.push_string("} else {\n")
                self.codegen.with_indent(() -> {
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".tag = 0;\n")
                })
                self.codegen.add_indent()
                self.codegen.buffer.push_string("}\n")
                self.emit_cleanup(emission.cleanup)
                yield MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
            } else self.emit_plain_upgrade_ref(emission, success, result_type),
            .MutableWeakReferenceType(inner) then if inner.val is .TraitObject(_, _) then {
                let upgraded = self.codegen.next_temp_with_init("struct __koral_Ref", "__koral_upgrade_ref((struct __koral_WeakRef){\(emission.expression).control}, &\(success))")
                let result = self.codegen.next_temp_with_decl(self.codegen.c_type_name(result_type))
                self.codegen.add_indent()
                self.codegen.buffer.push_string("if (")
                self.codegen.buffer.push_string(success)
                self.codegen.buffer.push_string(") {\n")
                self.codegen.with_indent(() -> {
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".tag = 1;\n")
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".data.Some.value.ptr = ")
                    self.codegen.buffer.push_string(upgraded)
                    self.codegen.buffer.push_string(".ptr;\n")
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".data.Some.value.control = ")
                    self.codegen.buffer.push_string(upgraded)
                    self.codegen.buffer.push_string(".control;\n")
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".data.Some.value.vtable = ")
                    self.codegen.buffer.push_string(emission.expression)
                    self.codegen.buffer.push_string(".vtable;\n")
                })
                self.codegen.add_indent()
                self.codegen.buffer.push_string("} else {\n")
                self.codegen.with_indent(() -> {
                    self.codegen.add_indent()
                    self.codegen.buffer.push_string(result)
                    self.codegen.buffer.push_string(".tag = 0;\n")
                })
                self.codegen.add_indent()
                self.codegen.buffer.push_string("}\n")
                self.emit_cleanup(emission.cleanup)
                yield MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
            } else self.emit_plain_upgrade_ref(emission, success, result_type),
            _ then self.emit_plain_upgrade_ref(emission, success, result_type),
        }
    }

    private emit_plain_upgrade_ref(
        self mut ref,
        emission MIRValueEmission,
        success String,
        result_type Type,
    ) MIRValueEmission = {
        let upgraded = self.codegen.next_temp_with_init("struct __koral_Ref", "__koral_upgrade_ref(\(emission.expression), &\(success))")
        let result = self.codegen.next_temp_with_decl(self.codegen.c_type_name(result_type))
        self.codegen.add_indent()
        self.codegen.buffer.push_string("if (")
        self.codegen.buffer.push_string(success)
        self.codegen.buffer.push_string(") { ")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".tag = 1; ")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".data.Some.value = ")
        self.codegen.buffer.push_string(upgraded)
        self.codegen.buffer.push_string("; } else { ")
        self.codegen.buffer.push_string(result)
        self.codegen.buffer.push_string(".tag = 0; }\n")
        self.emit_cleanup(emission.cleanup)
        return MIRValueEmission(result, self.cleanup_for_temporary_result(result, result_type))
    }

    private emit_spawn_thread(self mut ref, out_handle MIRValue, out_tid MIRValue, closure MIRValue, stack_size MIRValue) MIRValueEmission = {
        let h = self.emit_value_source(out_handle)
        let t = self.emit_value_source(out_tid)
        let c = self.emit_value_source(closure)
        let s = self.emit_value_source(stack_size)
        let result = self.codegen.next_temp_with_init("int32_t", "__koral_spawn_thread(\(h.expression), \(t.expression), \(c.expression), \(s.expression))")
        self.emit_cleanup(h.cleanup)
        self.emit_cleanup(t.cleanup)
        self.emit_cleanup(c.cleanup)
        self.emit_cleanup(s.cleanup)
        return MIRValueEmission(result, Option[ref MIRValueCleanup].None())
    }
}

private let join_strings(values List[String], separator String) String = {
    let mut out = String.new()
    let mut first = true
    for value in values then {
        if not first then { out.push_string(separator) }
        out.push_string(value)
        first = false
    }
    return out
}

private let build_mir_lifetime_plan(function ref MIRFunction, codegen ref CodeGen, init_flags List[String]) ref MIRLocalLifetimePlan = {
    let mut root_locals = List[MIRLocalID].new()
    let mut locals_by_scope = Dict[UInt, List[MIRLocalID]].new()
    let mut hoisted_declaration_locals = List[MIRLocalID].new()
    let mut block_local_declarations_by_block = Dict[UInt, List[MIRLocalID]].new()
    let mut block_local_declaration_locals = Dict[UInt, Bool].new()
    let mut parent_scope_by_scope = Dict[UInt, MIRScopeID].new()
    let mut declared_scope_by_local = Dict[UInt, MIRScopeID].new()
    let mut active_scopes = List[MIRScopeID].new()
    let mut declared_block_by_local = Dict[UInt, MIRBlockID].new()
    let mut use_scopes_by_local = Dict[UInt, List[Set[UInt]]].new()
    let mut use_blocks_by_local = Dict[UInt, Set[UInt]].new()
    for block in function.blocks then {
        for statement in block.statements then {
            when statement in {
                .ScopeEnter(scope) then {
                    if not active_scopes.is_empty() then {
                        parent_scope_by_scope.insert(scope.raw_value, active_scopes[active_scopes.count() - 1(UInt)])
                    }
                    active_scopes.push(scope)
                },
                .ScopeExit(scope) then {
                    let mut idx = active_scopes.count()
                    while idx > 0 then {
                        idx -= 1
                        if active_scopes[idx].raw_value == scope.raw_value then {
                            active_scopes.remove_at(idx)
                            break
                        }
                    }
                },
                .Declare(local_id) then {
                    if declared_block_by_local.get(local_id.raw_value) is .None() then {
                        declared_block_by_local.insert(local_id.raw_value, block.id)
                    }
                    if not active_scopes.is_empty() then {
                        declared_scope_by_local.insert(local_id.raw_value, active_scopes[active_scopes.count() - 1(UInt)])
                    }
                    mir_record_local_use(use_scopes_by_local.ref, use_blocks_by_local.ref, local_id, block.id, active_scopes.ref)
                },
                .Assign(place, value) then {
                    mir_walk_place_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, place, block.id, active_scopes.ref)
                    mir_walk_value_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, value, block.id, active_scopes.ref)
                },
                .CompoundAssign(assignment) then {
                    mir_walk_place_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, assignment.target, block.id, active_scopes.ref)
                    mir_walk_value_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, assignment.value, block.id, active_scopes.ref)
                },
                .Drop(place) then mir_walk_place_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, place, block.id, active_scopes.ref),
                .Retain(value) then mir_walk_value_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, value, block.id, active_scopes.ref),
                .Release(value) then mir_walk_value_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, value, block.id, active_scopes.ref),
                .Evaluate(value) then mir_walk_value_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, value, block.id, active_scopes.ref),
                .DebugSource(_) then {},
            }
        }
        when block.terminator in {
            .Branch(condition, _, _) then mir_walk_operand_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, condition, block.id, active_scopes.ref),
            .SwitchValue(operand, _, _) then mir_walk_operand_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, operand, block.id, active_scopes.ref),
            .ReturnValue(operand) then when operand in {
                .Some(op) then mir_walk_operand_uses(use_scopes_by_local.ref, use_blocks_by_local.ref, op, block.id, active_scopes.ref),
                .None() then {},
            },
            _ then {},
        }
    }
    for local in function.locals then {
        if not codegen.type_is_void_or_never(local.local_type) and codegen.needs_drop(local.local_type) then {
            let mut scope = when declared_scope_by_local.get(local.id.raw_value) in {
                .Some(scope_id) then Option[MIRScopeID].Some(scope_id),
                .None() then Option[MIRScopeID].None(),
            }
            let use_scopes = use_scopes_by_local.get(local.id.raw_value) or else List[Set[UInt]].new()
            while scope is .Some(_) then {
                let scope_id = when scope in {
                    .Some(existing) then existing,
                    .None() then MIRScopeID(0(UInt)),
                }
                let mut used_outside = false
                for use_scope in use_scopes then {
                    if not use_scope.contains(scope_id.raw_value) then {
                        used_outside = true
                    }
                }
                if not used_outside then { break }
                scope = when parent_scope_by_scope.get(scope_id.raw_value) in {
                    .Some(parent_scope) then Option[MIRScopeID].Some(parent_scope),
                    .None() then Option[MIRScopeID].None(),
                }
            }
            when scope in {
                .Some(scope_id) then {
                    let mut scoped_locals = locals_by_scope.get(scope_id.raw_value) or else List[MIRLocalID].new()
                    scoped_locals.push(local.id)
                    locals_by_scope.insert(scope_id.raw_value, scoped_locals)
                },
                .None() then root_locals.push(local.id),
            }
        }
    }
    for local in function.locals then {
        if local.storage is not .Parameter() and local.storage is not .Capture() and not codegen.type_is_void_or_never(local.local_type) then {
            let has_init_flag = local.id.raw_value < init_flags.count() and not init_flags[local.id.raw_value].is_empty()
            let can_block_local = if not has_init_flag then when declared_block_by_local.get(local.id.raw_value) in {
                .Some(declaration_block) then when use_blocks_by_local.get(local.id.raw_value) in {
                    .Some(use_blocks) then use_blocks.count() == 1(UInt) and use_blocks.contains(declaration_block.raw_value),
                    .None() then false,
                },
                .None() then false,
            } else false
            if can_block_local then {
                when declared_block_by_local.get(local.id.raw_value) in {
                    .Some(declaration_block) then {
                        let mut block_locals = block_local_declarations_by_block.get(declaration_block.raw_value) or else List[MIRLocalID].new()
                        block_locals.push(local.id)
                        block_local_declarations_by_block.insert(declaration_block.raw_value, block_locals)
                        block_local_declaration_locals.insert(local.id.raw_value, true)
                    },
                    .None() then hoisted_declaration_locals.push(local.id),
                }
            } else {
                hoisted_declaration_locals.push(local.id)
            }
        }
    }
    return box(MIRLocalLifetimePlan(
        root_locals,
        locals_by_scope,
        hoisted_declaration_locals,
        block_local_declarations_by_block,
        block_local_declaration_locals
    ))
}

given CodeGen {
    public emit_mir_function_body(self mut ref, function ref MIRFunction) String = {
        let saved_indent = self.indent
        self.indent = "    "
        let plan = build_mir_function_emit_plan(self, function)
        let mut emitter = MIRFunctionCodeEmitter.new(self, function, plan)
        // Redirect body emission into a temporary buffer
        let saved_buffer = self.buffer
        self.buffer = box(CodegenBuffer.new())
        emitter.emit_body()
        let body_text = self.buffer.to_string()
        self.buffer = saved_buffer
        // Collect nested definitions (lambda env structs, nested functions)
        let nested = emitter.get_nested_definitions()
        if not nested.is_empty() then {
            self.nested_function_definitions.push_string(nested)
        }
        self.indent = saved_indent
        return body_text
    }

    public emit_mir_global_function(self mut ref, function ref MIRFunction) Void = {
        let c_name = self.callable_c_name(function.identifier)
        if self.emitted_function_names.contains(c_name) then { return }
        self.emitted_function_names.insert(c_name)
        if self.type_contains_generic(function.return_type) or self.params_contain_generic(function.params) then {
            panic("Generic MIR function body reached codegen: \(self.context.symbol_name(function.identifier)) :: \(self.context.type_display_name(function.identifier.symbol_type))")
        }

        let saved_type_prefix = self.current_function_type_prefix
        let concrete_return_type = self.concretize_codegen_type(function.return_type)
        let new_prefix = when self.method_owner_type(function.identifier.def_id) in {
            .Some(owner_type) then Option[String].Some(self.emitted_type_c_name_fallback(owner_type)),
            .None() then self.extract_type_prefix_from_c_name(c_name),
        }
        self.current_function_type_prefix = new_prefix

        let return_c_type = self.c_type_name(concrete_return_type)
        let params_str = self.build_param_list(function.params)
        // Generate the function body and collect nested definitions
        let body_text = self.emit_mir_function_body(function)

        // Emit nested definitions (lambda functions, env structs) before the function
        if not self.nested_function_definitions.is_empty() then {
            self.buffer.push_string(self.nested_function_definitions)
            self.nested_function_definitions = String.new()
        }

        self.buffer.push_string(return_c_type)
        self.buffer.push_string(" ")
        self.buffer.push_string(c_name)
        self.buffer.push_string("(")
        self.buffer.push_string(params_str)
        self.buffer.push_string(") {\n")
        self.buffer.push_string(body_text)
        self.buffer.push_string("}\n")

        self.current_function_type_prefix = saved_type_prefix
        return
    }
}
