// codegen.koral - CodeGen 核心类型与初始化
//
// 定义 CodeGen 类型及其核心状态，提供构造函数、C 标识符映射构建、
// 类型名称映射、临时变量生成和缓冲区操作等核心方法。
//
// 参照 compiler/Sources/KoralCompiler/CodeGen/CodeGen.swift

using "c_identifier_utils"
using "codegen_indexes"
using "codegen_expressions_literals"
using "codegen_memory"
using "codegen_types"
using "codegen_vtable"
using "codegen_mir"
using "codegen_generate"

// ── TypeDeclaration ───────────────────────────────────────────────────────────

/// 类型声明的轻量包装，用于依赖排序后的类型定义生成
type TypeDeclaration {
    Structure(name String, fields List[TypedField]),
    Enum(name String, cases List[TypedEnumCase]),
    ForeignStructure(name String, fields List[TypedField]),
}

given TypeDeclaration {
    /// 获取类型声明的 C 名称
    c_name(self) String = {
        return when self in {
            .Structure(name, _) then name,
            .Enum(name, _) then name,
            .ForeignStructure(name, _) then name,
        }
    }
}

// ── CodeGen ───────────────────────────────────────────────────────────────────

/// C 代码生成器
///
/// 接收 MIRProgram，遍历其 backend-facing globals/metadata，
/// 生成等价的 C 语言源代码字符串。
public type CodeGen(
    // 输入
    program ref MIRProgram,
    context CompilerContext,
    c_keywords Set[String],

    // 输出缓冲区
    mut buffer mut ref String,

    // 代码生成状态
    mut indent String,
    mut temp_var_counter UInt,

    // 用户 main 函数
    mut user_main_function_name Option[String],
    mut user_main_return_type Option[Type],

    // Vtable 追踪
    mut generated_vtable_instances Set[String],

    // 当前正在生成的函数的类型前缀（如 "_k__T_Deque"），用于解析 self 方法调用
    mut current_function_type_prefix Option[String],

    // 已输出函数实现名（避免同名函数重复定义）
    mut emitted_function_names Set[String],
)

given CodeGen {
    // ── 构造函数 ──────────────────────────────────────────────────────────────

    /// 构造 CodeGen 实例，初始化所有状态并构建 C 标识符映射
    public new(program ref MIRProgram, context CompilerContext) CodeGen = {
        let mut cg = CodeGen(
            program,
            context,
            make_c_keywords_set(),
            // buffer
            box(String.new()),
            // indent
            String.new(),
            // temp_var_counter
            0,
            // user_main_function_name
            Option[String].None(),
            // user_main_return_type
            Option[Type].None(),
            // generated_vtable_instances
            Set[String].new(),
            // current_function_type_prefix
            Option[String].None(),
            // emitted_function_names
            Set[String].new(),
        )
        return cg
    }

    sanitize_codegen_identifier(self, name String) String = {
        let mut result = String.new()
        for ch in name.runes() then {
            if ch.is_ascii_alphabetic() or ch.is_ascii_digit() or ch == '_' then {
                result.push_rune(ch)
            } else {
                result.push_rune('_')
            }
        }
        return self.escape_codegen_keyword(result)
    }

    escape_codegen_keyword(self, name String) String = {
        if name.is_empty() then {
            return name
        }

        let prefix = c_escape_prefix()
        if name.starts_with("_k__") then {
            return name
        }
        if self.c_keywords.contains(name) then {
            return prefix + name
        }
        if name.starts_with(prefix) then {
            return prefix + name
        }
        if name.starts_with("_") then {
            let runes = name.to_runes()
            if runes.count() >= 2 then {
                let second = runes[1]
                let is_upper = second >= 'A' and second <= 'Z'
                let is_underscore = second == '_'
                if is_upper or is_underscore then {
                    return prefix + name
                }
            }
        }
        return name
    }

    generate_codegen_identifier(self, module_path List[String], name String, is_private Bool, source_file String) String = {
        let mut result = String.new()
        let mut needs_separator = false

        if not module_path.is_empty() then {
            for seg in module_path then {
                if needs_separator then {
                    result.push_rune('_')
                }
                result.push_string(seg)
                needs_separator = true
            }
        }

        if is_private and not source_file.is_empty() then {
            if needs_separator then {
                result.push_rune('_')
            }
            result.push_string(generate_file_identifier(source_file))
            needs_separator = true
        }

        if needs_separator then {
            result.push_rune('_')
        }
        result.push_string(self.sanitize_codegen_identifier(name))
        return result
    }

    c_identifier_opt(self, def_id DefId) Option[String] = {
        return when self.context.get_cname(def_id) in {
            .Some(name) then Option[String].Some(name),
            .None() then when self.context.get_name(def_id) in {
                .Some(name) then Option[String].Some(self.sanitize_codegen_identifier(name)),
                .None() then Option[String].None(),
            },
        }
    }

    c_name_for_def_id(self, def_id DefId) String = {
        return when self.c_identifier_opt(def_id) in {
            .Some(name) then name,
            .None() then when self.context.get_cname(def_id) in {
                .Some(name) then name,
                .None() then when self.context.get_name(def_id) in {
                    .Some(name) then self.sanitize_codegen_identifier(name),
                    .None() then "T_\(def_id.id)",
                },
            },
        }
    }

    has_c_identifier(self, def_id DefId) Bool = {
        return self.c_identifier_opt(def_id).is_some()
    }

    concretize_codegen_type(self, t Type) Type = {
        return t
    }

    trait_object_type_from_name(self, trait_name String) Type = {
        let mut trait_type_args = List[ref Type].new()
        when self.program.traits.get(trait_name) in {
            .Some(info) then {
                for type_param in info.type_params then {
                    trait_type_args.push(box(Type.GenericParameter(type_param.name)))
                }
            },
            .None() then {},
        }
        return Type.TraitObject(trait_name, trait_type_args)
    }

    trait_name_of_trait_type(self, trait_type Type) String = {
        return when trait_type in {
            .ReferenceType(inner_ref) then self.trait_name_of_trait_type(inner_ref.val),
            .MutableReferenceType(inner_ref) then self.trait_name_of_trait_type(inner_ref.val),
            .WeakReferenceType(inner_ref) then self.trait_name_of_trait_type(inner_ref.val),
            .MutableWeakReferenceType(inner_ref) then self.trait_name_of_trait_type(inner_ref.val),
            .TraitObject(trait_name, _) then trait_name,
            _ then self.context.type_display_name(trait_type),
        }
    }

    trait_type_args_of_trait_type(self, trait_type Type) List[ref Type] = {
        return when trait_type in {
            .TraitObject(_, type_args) then type_args,
            _ then List[ref Type].new(),
        }
    }

    private apply_codegen_type_bindings(self, t Type, bindings Dict[String, Type]) Type = {
        if bindings.is_empty() then { return t }
        return when t in {
            .GenericParameter(name) then when bindings.get(name) in {
                .Some(bound) then bound,
                .None() then t,
            },
            .ReferenceType(inner_ref) then Type.ReferenceType(box(self.apply_codegen_type_bindings(inner_ref.val, bindings))),
            .MutableReferenceType(inner_ref) then Type.MutableReferenceType(box(self.apply_codegen_type_bindings(inner_ref.val, bindings))),
            .PointerType(inner_ref) then Type.PointerType(box(self.apply_codegen_type_bindings(inner_ref.val, bindings))),
            .MutablePointerType(inner_ref) then Type.MutablePointerType(box(self.apply_codegen_type_bindings(inner_ref.val, bindings))),
            .WeakReferenceType(inner_ref) then Type.WeakReferenceType(box(self.apply_codegen_type_bindings(inner_ref.val, bindings))),
            .MutableWeakReferenceType(inner_ref) then Type.MutableWeakReferenceType(box(self.apply_codegen_type_bindings(inner_ref.val, bindings))),
            .GenericStruct(template, args) then {
                let mut bound_args = List[ref Type].new()
                for arg_ref in args then { bound_args.push(box(self.apply_codegen_type_bindings(arg_ref.val, bindings))) }
                yield Type.GenericStruct(template, bound_args)
            },
            .GenericEnum(template, args) then {
                let mut bound_args = List[ref Type].new()
                for arg_ref in args then { bound_args.push(box(self.apply_codegen_type_bindings(arg_ref.val, bindings))) }
                yield Type.GenericEnum(template, bound_args)
            },
            .FunctionType(fn_params, return_type_ref) then {
                let mut bound_param_types = List[ref Type].new()
                for entry in fn_params then {
                    bound_param_types.push(box(self.apply_codegen_type_bindings(entry.param_type, bindings)))
                }
                yield make_function_type(bound_param_types, self.apply_codegen_type_bindings(return_type_ref.val, bindings))
            },
            _ then t,
        }
    }

    private append_generic_parameter_bindings(self, mut bindings Dict[String, Type], target_args List[ref Type], base_args List[ref Type]) Void = {
        let mut i UInt = 0
        let n = if target_args.count() < base_args.count() then target_args.count() else base_args.count()
        while i < n then {
            when target_args[i].val in {
                .GenericParameter(name) then { bindings.insert(name, base_args[i].val) },
                _ then {},
            }
            i += 1
        }
    }

    build_receiver_bindings(self, target_type Type, base_type Type) Dict[String, Type] = {
        let mut bindings = Dict[String, Type].new()
        let concrete_base_type = self.concretize_codegen_type(base_type)
        let effective_base_type = when concrete_base_type in {
            .StructureType(def_id) then when self.context.lookup_type(def_id) in {
                .Some(mapped_type) then mapped_type,
                .None() then when self.context.get_template_name(def_id) in {
                    .Some(template_name) then when self.context.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut type_arg_refs = List[ref Type].new()
                            for type_arg in type_args then { type_arg_refs.push(box(type_arg)) }
                            yield Type.GenericStruct(template_name, type_arg_refs)
                        },
                        .None() then concrete_base_type,
                    },
                    .None() then concrete_base_type,
                },
            },
            .EnumType(def_id) then when self.context.lookup_type(def_id) in {
                .Some(mapped_type) then mapped_type,
                .None() then when self.context.get_template_name(def_id) in {
                    .Some(template_name) then when self.context.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut type_arg_refs = List[ref Type].new()
                            for type_arg in type_args then { type_arg_refs.push(box(type_arg)) }
                            yield Type.GenericEnum(template_name, type_arg_refs)
                        },
                        .None() then concrete_base_type,
                    },
                    .None() then concrete_base_type,
                },
            },
            _ then concrete_base_type,
        }
        when target_type in {
            .GenericStruct(_, target_args) then when effective_base_type in {
                .GenericStruct(_, base_args) then self.append_generic_parameter_bindings(bindings, target_args, base_args),
                _ then {},
            },
            .GenericEnum(_, target_args) then when effective_base_type in {
                .GenericEnum(_, base_args) then self.append_generic_parameter_bindings(bindings, target_args, base_args),
                _ then {},
            },
            _ then {},
        }
        return bindings
    }

    private method_receiver_bindings(self, method_def_id DefId, concrete_receiver_type Type) Dict[String, Type] = {
        return when self.method_owner_type(method_def_id) in {
            .Some(target_type) then self.build_receiver_bindings(target_type, concrete_receiver_type),
            .None() then Dict[String, Type].new(),
        }
    }

    private bind_function_type(self, fn_type Type, receiver_bindings Dict[String, Type]) Type = {
        return when fn_type in {
            .FunctionType(fn_params, return_type_ref) then {
                let mut bound_param_types = List[ref Type].new()
                for entry in fn_params then {
                    bound_param_types.push(box(self.apply_codegen_type_bindings(entry.param_type, receiver_bindings)))
                }
                let bound_return_type = self.apply_codegen_type_bindings(return_type_ref.val, receiver_bindings)
                yield make_function_type(bound_param_types, bound_return_type)
            },
            _ then fn_type,
        }
    }

    bind_method_function_type(self, method_def_id DefId, concrete_receiver_type Type, fn_type Type) Type = {
        let receiver_bindings = self.method_receiver_bindings(method_def_id, concrete_receiver_type)
        return self.bind_function_type(fn_type, receiver_bindings)
    }

    function_type_param_count(self, fn_type Type) UInt = {
        return when fn_type in {
            .FunctionType(fn_params, _) then fn_params.count(),
            _ then 0(UInt),
        }
    }

    function_type_param_type(self, fn_type Type, index UInt) Option[Type] = {
        return when fn_type in {
            .FunctionType(fn_params, _) then if index < fn_params.count()
                then Option[Type].Some(fn_params[index].val.param_type)
                else Option[Type].None(),
            _ then Option[Type].None(),
        }
    }

    function_type_return_type(self, fn_type Type) Type = {
        return when fn_type in {
            .FunctionType(_, return_type_ref) then return_type_ref.val,
            _ then Type.Unknown(),
        }
    }

    function_param_specs(self, def_id DefId) List[FunctionParamSpec] = {
        return self.context.get_param_specs(def_id) or else List[FunctionParamSpec].new()
    }

    requested_or_symbol_result_type(self, requested_result_type Type, symbol_type Type) Type = {
        return when requested_result_type in {
            .Unknown() then symbol_type,
            .VoidType() then when symbol_type in {
                .VoidType() then requested_result_type,
                .NeverType() then requested_result_type,
                .Unknown() then requested_result_type,
                _ then symbol_type,
            },
            _ then requested_result_type,
        }
    }

    codegen_types_equal(self, lhs Type, rhs Type) Bool = {
        let left = self.concrete_layout_key_for_type(self.concretize_codegen_type(lhs))
        let right = self.concrete_layout_key_for_type(self.concretize_codegen_type(rhs))
        return left == right
    }

    private concrete_callable_symbol(self, def_id DefId, requested_result_type Type) Option[Symbol] = {
        return when self.c_identifier_opt(def_id) in {
            .Some(_) then {
                let result_type = when self.context.get_function_return_type(def_id) in {
                    .Some(return_type) then self.requested_or_symbol_result_type(requested_result_type, return_type),
                    .None() then requested_result_type,
                }
                yield Option[Symbol].Some(Symbol(def_id, result_type, SymbolKind.Function()))
            },
            .None() then Option[Symbol].None(),
        }
    }

    bound_concrete_method_symbol(self, def_id DefId, receiver_type Type, requested_result_type Type) Option[Symbol] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let bound_result_type = when self.context.get_function_type(def_id) in {
            .Some(function_type) then self.function_type_return_type(self.bind_method_function_type(def_id, concrete_receiver_type, function_type)),
            .None() then requested_result_type,
        }
        return self.concrete_callable_symbol(def_id, bound_result_type)
    }

    lookup_trait_method_def_id(self, concrete_type Type, trait_name String, method_name String) Option[DefId] = {
        let concrete_receiver_type = self.concretize_codegen_type(concrete_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        for entry in self.program.concrete_callables_by_def_id.iterator() then {
            let def_id = entry.first
            let info = entry.second
            if not (info.logical_name == method_name) then { continue }
            when info.owner_type in {
                .Some(owner_type) then {
                    let owner_key = self.concrete_receiver_lookup_key(self.concretize_codegen_type(owner_type))
                    if not (owner_key == receiver_key) then { continue }
                    when info.trait_conformance in {
                        .Some(conformance) then {
                            if conformance == trait_name then {
                                return Option[DefId].Some(def_id)
                            }
                        },
                        .None() then {},
                    }
                },
                .None() then {},
            }
        }

        return when self.program.traits.get(trait_name) in {
            .Some(trait_info) then {
                let mut found = Option[DefId].None()
                for parent_trait_name in trait_info.parent_traits then {
                    found = self.lookup_trait_method_def_id(concrete_receiver_type, parent_trait_name.name, method_name)
                    if found is .Some(_) then { break }
                }
                yield found
            },
            .None() then Option[DefId].None(),
        }
    }

    private lookup_receiver_method_def_id(self, receiver_type Type, method_name String) Option[DefId] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let concrete_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        let concrete_lookup_key = "\(concrete_key).\(method_name)"
        when self.program.static_method_lookup.get(concrete_lookup_key) in {
            .Some(def_id) then { return Option[DefId].Some(def_id) },
            .None() then {},
        }

        let receiver_key = self.receiver_type_lookup_name_fallback(concrete_receiver_type)
        let receiver_lookup_key = "\(receiver_key).\(method_name)"
        when self.program.static_method_lookup.get(receiver_lookup_key) in {
            .Some(def_id) then { return Option[DefId].Some(def_id) },
            .None() then {},
        }

        when concrete_receiver_type in {
            .GenericStruct(template_name, _) then {
                if template_name <> receiver_key then {
                    let template_lookup_key = "\(template_name).\(method_name)"
                    when self.program.static_method_lookup.get(template_lookup_key) in {
                        .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                        .None() then {},
                    }
                }
            },
            .GenericEnum(template_name, _) then {
                if template_name <> receiver_key then {
                    let template_lookup_key = "\(template_name).\(method_name)"
                    when self.program.static_method_lookup.get(template_lookup_key) in {
                        .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                        .None() then {},
                    }
                }
            },
            .StructureType(def_id) then when self.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    if template_name <> receiver_key then {
                        let template_lookup_key = "\(template_name).\(method_name)"
                        when self.program.static_method_lookup.get(template_lookup_key) in {
                            .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                            .None() then {},
                        }
                    }
                },
                .None() then {},
            },
            .EnumType(def_id) then when self.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    if template_name <> receiver_key then {
                        let template_lookup_key = "\(template_name).\(method_name)"
                        when self.program.static_method_lookup.get(template_lookup_key) in {
                            .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                            .None() then {},
                        }
                    }
                },
                .None() then {},
            },
            _ then {},
        }
        return Option[DefId].None()
    }

    private receiver_method_matches_lookup(self, def_id DefId, receiver_type Type) Bool = {
        if self.program.receiver_method_dispatch.get(def_id) is .Some(_) then { return true }

        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let concrete_receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        when self.method_owner_type(def_id) in {
            .Some(owner_type) then {
                let concrete_owner_type = self.concretize_codegen_type(owner_type)
                if self.concrete_receiver_lookup_key(concrete_owner_type) == concrete_receiver_key then when self.context.get_function_type(def_id) in {
                    .Some(function_type) then {
                        if self.function_type_param_count(function_type) > 0(UInt) then { return true }
                    },
                    .None() then {},
                }
            },
            .None() then {},
        }

        let receiver_base_type = when concrete_receiver_type in {
            .ReferenceType(inner_ref) then inner_ref.val,
            .MutableReferenceType(inner_ref) then inner_ref.val,
            .WeakReferenceType(inner_ref) then inner_ref.val,
            .MutableWeakReferenceType(inner_ref) then inner_ref.val,
            _ then concrete_receiver_type,
        }
        let receiver_base_key = self.concrete_receiver_lookup_key(receiver_base_type)

        return when self.context.get_function_type(def_id) in {
            .Some(function_type) then {
                if self.function_type_param_count(function_type) == 0(UInt) then { return false }
                let receiver_param_type = self.function_type_param_type(function_type, 0(UInt)) or else Type.Unknown()
                let concrete_param_type = self.concretize_codegen_type(receiver_param_type)
                let param_base_type = when concrete_param_type in {
                    .ReferenceType(inner_ref) then inner_ref.val,
                    .MutableReferenceType(inner_ref) then inner_ref.val,
                    .WeakReferenceType(inner_ref) then inner_ref.val,
                    .MutableWeakReferenceType(inner_ref) then inner_ref.val,
                    _ then concrete_param_type,
                }
                yield self.concrete_receiver_lookup_key(param_base_type) == receiver_base_key
            },
            .None() then false,
        }
    }

    private lookup_receiver_method_via_metadata(self, receiver_type Type, method_name String, requested_result_type Type) Option[Symbol] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        when self.lookup_receiver_method_def_id(concrete_receiver_type, method_name) in {
            .Some(def_id) then {
                if not self.receiver_method_matches_lookup(def_id, concrete_receiver_type) then {
                    return Option[Symbol].None()
                }
                return self.bound_concrete_method_symbol(def_id, concrete_receiver_type, requested_result_type)
            },
            .None() then {},
        }
        return Option[Symbol].None()
    }

    lookup_receiver_method(self, receiver_type Type, method_name String) Option[Symbol] = {
        if self.lookup_receiver_method_via_metadata(receiver_type, method_name, Type.Unknown()) is .Some(symbol) then {
            return Option[Symbol].Some(symbol)
        }
        when receiver_type in {
            .ReferenceType(_) then {},
            .MutableReferenceType(_) then {},
            .WeakReferenceType(_) then {},
            .MutableWeakReferenceType(_) then {},
            _ then {
                let mut_ref_type = Type.MutableReferenceType(box(receiver_type))
                when self.lookup_receiver_method_via_metadata(mut_ref_type, method_name, Type.Unknown()) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
                let shared_ref_type = Type.ReferenceType(box(receiver_type))
                when self.lookup_receiver_method_via_metadata(shared_ref_type, method_name, Type.Unknown()) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
        }
        return when receiver_type in {
            .ReferenceType(inner_ref) then self.lookup_receiver_method(inner_ref.val, method_name),
            .MutableReferenceType(inner_ref) then {
                let shared_ref_type = Type.ReferenceType(box(inner_ref.val))
                yield when self.lookup_receiver_method_via_metadata(shared_ref_type, method_name, Type.Unknown()) in {
                    .Some(symbol) then Option[Symbol].Some(symbol),
                    .None() then self.lookup_receiver_method(inner_ref.val, method_name),
                }
            },
            _ then Option[Symbol].None(),
        }
    }

    enum_case_name_matches(self, pattern_case_name String, enum_case_name String) Bool = {
        if enum_case_name == pattern_case_name then { return true }
        if enum_case_name.ends_with("_" + pattern_case_name) then { return true }
        let pattern_tail = when pattern_case_name.split_last_once(".") in {
            .Some(parts) then parts.second,
            .None() then pattern_case_name,
        }
        if enum_case_name == pattern_tail then { return true }
        if enum_case_name.ends_with("_" + pattern_tail) then { return true }
        let enum_tail = when enum_case_name.split_last_once("_") in {
            .Some(parts) then parts.second,
            .None() then enum_case_name,
        }
        return enum_tail == pattern_tail
    }

    def_ids_named(self, name String) List[DefId] = {
        let mut out = List[DefId].new()
        let mut id UInt = 1
        while id < self.context.next_def_id() then {
            let def_id = DefId(id)
            if self.context.get_name(def_id) is .Some(found_name) and found_name == name then {
                out.push(def_id)
            }
            id += 1
        }
        return out
    }

    type_def_ids_named(self, name String) List[DefId] = {
        let mut out = List[DefId].new()
        for def_id in self.def_ids_named(name) then {
            when self.context.get_kind(def_id) in {
                .Some(kind) then when kind in {
                    .TypeDef(_) then out.push(def_id),
                    .GenericTemplate(_) then out.push(def_id),
                    _ then {},
                },
                .None() then {},
            }
        }
        return out
    }

    private foreign_type_symbol_matches_def_id(self, symbol ref Symbol, def_id DefId) Bool = {
        let _ = self
        if symbol.def_id == def_id then { return true }
        return when symbol.symbol_type in {
            .StructureType(type_def_id) then type_def_id == def_id,
            .OpaqueType(type_def_id) then type_def_id == def_id,
            .EnumType(type_def_id) then type_def_id == def_id,
            _ then false,
        }
    }

    is_foreign_function_def_id(self, def_id DefId) Bool = {
        for global in self.program.globals then {
            when global in {
                .ForeignFunction(identifier, _, _) then {
                    if identifier.def_id == def_id then { return true }
                },
                _ then {},
            }
        }
        return false
    }

    is_foreign_global_var_def_id(self, def_id DefId) Bool = {
        for global in self.program.globals then {
            when global in {
                .ForeignGlobalVariable(identifier, _, _) then {
                    if identifier.def_id == def_id then { return true }
                },
                _ then {},
            }
        }
        return false
    }

    is_foreign_type_def_id(self, def_id DefId) Bool = {
        for global in self.program.globals then {
            when global in {
                .ForeignType(identifier) then {
                    if self.foreign_type_symbol_matches_def_id(identifier, def_id) then { return true }
                },
                .ForeignStruct(identifier, _) then {
                    if self.foreign_type_symbol_matches_def_id(identifier, def_id) then { return true }
                },
                _ then {},
            }
        }
        return false
    }

    normalize_codegen_lookup_name(self, name String) String = {
        return if name.starts_with("_k__k__") then name.substring(3..) else name
    }

    private concrete_callable_info(self, def_id DefId) Option[ConcreteCallableInfo] = {
        return self.program.concrete_callables_by_def_id.get(def_id)
    }

    method_owner_type(self, method_def_id DefId) Option[Type] = {
        return when self.concrete_callable_info(method_def_id) in {
            .Some(info) then info.owner_type,
            .None() then Option[Type].None(),
        }
    }

    callable_c_name(self, symbol ref Symbol) String = {
        return when self.concrete_callable_info(symbol.def_id) in {
            .Some(info) then when self.c_identifier_opt(symbol.def_id) in {
                .Some(c_id) then c_id,
                .None() then when info.owner_type in {
                    .Some(owner_type) then {
                        let owner_c_name = self.emitted_type_c_name_fallback(owner_type)
                        yield self.compose_method_c_name(owner_c_name, info.logical_name)
                    },
                    .None() then info.logical_name,
                },
            },
            .None() then when self.c_identifier_opt(symbol.def_id) in {
                .Some(c_id) then c_id,
                .None() then when self.method_owner_type(symbol.def_id) in {
                    .Some(owner_type) then {
                        let owner_c_name = self.emitted_type_c_name_fallback(owner_type)
                        let raw_method_name = self.context.symbol_name(symbol)
                        yield self.compose_method_c_name(owner_c_name, raw_method_name)
                    },
                    .None() then {
                        let raw_name = self.qualified_name(symbol)
                        yield when raw_name.find_last("_") in {
                            .Some(split_index) then {
                                let prefix = raw_name.substring(0..<split_index)
                                let suffix = raw_name.substring(split_index + 1..<raw_name.count())
                                yield self.compose_method_c_name(prefix, suffix)
                            },
                            .None() then raw_name,
                        }
                    },
                },
            },
        }
    }

    private codegen_layout_info(self, t Type) Option[TypeLayoutInfo] = {
        let _ = self
        let _ = t
        return Option[TypeLayoutInfo].None()
    }

    concrete_receiver_lookup_key(self, t Type) String = {
        let canonical_type = self.normalize_vtable_receiver_type(self.concretize_codegen_type(t))
        return self.concrete_layout_key_for_type(canonical_type)
    }

    concrete_type_c_name_fallback(self, t Type) Option[String] = {
        if self.codegen_layout_info(t) is .Some(layout) then {
            return Option[String].Some(layout.emitted_type_name)
        }

        return when t in {
            .StructureType(def_id) then {
                yield when self.c_identifier_opt(def_id) in {
                    .Some(name) then Option[String].Some(name),
                    .None() then when self.context.get_name(def_id) in {
                        .Some(name) then Option[String].Some(self.sanitize_codegen_identifier(name)),
                        .None() then Option[String].None(),
                    },
                }
            },
            .EnumType(def_id) then {
                yield when self.c_identifier_opt(def_id) in {
                    .Some(name) then Option[String].Some(name),
                    .None() then when self.context.get_name(def_id) in {
                        .Some(name) then Option[String].Some(self.sanitize_codegen_identifier(name)),
                        .None() then Option[String].None(),
                    },
                }
            },
            .GenericStruct(_, _) then {
                let layout_key = self.concrete_layout_key_for_type(self.concretize_codegen_type(t))
                yield Option[String].Some(self.sanitize_codegen_identifier(layout_key))
            },
            .GenericEnum(_, _) then {
                let layout_key = self.concrete_layout_key_for_type(self.concretize_codegen_type(t))
                yield Option[String].Some(self.sanitize_codegen_identifier(layout_key))
            },
            .OpaqueType(def_id) then {
                yield when self.context.lookup_type(def_id) in {
                    .Some(mapped_type) then self.concrete_type_c_name_fallback(mapped_type),
                    .None() then when self.c_identifier_opt(def_id) in {
                        .Some(name) then Option[String].Some(name),
                        .None() then when self.context.get_cname(def_id) in {
                            .Some(name) then Option[String].Some(name),
                            .None() then when self.context.get_name(def_id) in {
                                .Some(name) then Option[String].Some(self.sanitize_codegen_identifier(name)),
                                .None() then Option[String].None(),
                            },
                        },
                    },
                }
            },
            .ReferenceType(_) then Option[String].Some(self.concrete_layout_key_for_type(t)),
            .MutableReferenceType(_) then Option[String].Some(self.concrete_layout_key_for_type(t)),
            .PointerType(_) then Option[String].Some(self.concrete_layout_key_for_type(t)),
            .MutablePointerType(_) then Option[String].Some(self.concrete_layout_key_for_type(t)),
            .WeakReferenceType(_) then Option[String].Some(self.concrete_layout_key_for_type(t)),
            .MutableWeakReferenceType(_) then Option[String].Some(self.concrete_layout_key_for_type(t)),
            .IntType() then Option[String].Some("Int"),
            .Int8Type() then Option[String].Some("Int8"),
            .Int16Type() then Option[String].Some("Int16"),
            .Int32Type() then Option[String].Some("Int32"),
            .Int64Type() then Option[String].Some("Int64"),
            .UIntType() then Option[String].Some("UInt"),
            .UInt8Type() then Option[String].Some("UInt8"),
            .UInt16Type() then Option[String].Some("UInt16"),
            .UInt32Type() then Option[String].Some("UInt32"),
            .UInt64Type() then Option[String].Some("UInt64"),
            .Float32Type() then Option[String].Some("Float32"),
            .Float64Type() then Option[String].Some("Float64"),
            .BoolType() then Option[String].Some("Bool"),
            _ then Option[String].None(),
        }
    }

    receiver_type_lookup_name_fallback(self, t Type) String = {
        if self.codegen_layout_info(t) is .Some(layout) then {
            return layout.receiver_lookup_name
        }

        return when t in {
            .ReferenceType(inner_ref) then self.receiver_type_lookup_name_fallback(inner_ref.val),
            .MutableReferenceType(inner_ref) then self.receiver_type_lookup_name_fallback(inner_ref.val),
            .PointerType(inner_ref) then self.receiver_type_lookup_name_fallback(inner_ref.val),
            .MutablePointerType(inner_ref) then self.receiver_type_lookup_name_fallback(inner_ref.val),
            .WeakReferenceType(inner_ref) then self.receiver_type_lookup_name_fallback(inner_ref.val),
            .MutableWeakReferenceType(inner_ref) then self.receiver_type_lookup_name_fallback(inner_ref.val),
            .StructureType(def_id) then {
                yield when self.context.get_name(def_id) in {
                    .Some(name) then name,
                    .None() then "T_\(def_id.id)",
                }
            },
            .EnumType(def_id) then {
                yield when self.context.get_name(def_id) in {
                    .Some(name) then name,
                    .None() then "U_\(def_id.id)",
                }
            },
            .GenericStruct(template, _) then template,
            .GenericEnum(template, _) then template,
            .IntType() then "Int",
            .Int8Type() then "Int8",
            .Int16Type() then "Int16",
            .Int32Type() then "Int32",
            .Int64Type() then "Int64",
            .UIntType() then "UInt",
            .UInt8Type() then "UInt8",
            .UInt16Type() then "UInt16",
            .UInt32Type() then "UInt32",
            .UInt64Type() then "UInt64",
            .Float32Type() then "Float32",
            .Float64Type() then "Float64",
            .BoolType() then "Bool",
            .OpaqueType(def_id) then {
                yield when self.context.lookup_type(def_id) in {
                    .Some(mapped_type) then self.receiver_type_lookup_name_fallback(mapped_type),
                    .None() then when self.context.get_name(def_id) in {
                        .Some(name) then name,
                        .None() then self.context.type_display_name(t),
                    },
                }
            },
            _ then "Unknown",
        }
    }

    emitted_type_c_name_fallback(self, t Type) String = {
        if self.codegen_layout_info(t) is .Some(layout) then {
            return layout.emitted_type_name
        }
        return self.concrete_type_c_name_fallback(t) or else self.sanitize_codegen_identifier(self.context.type_display_name(t))
    }

    compose_method_c_name(self, type_c_name String, method_name String) String = {
        let sanitized_method = self.sanitize_codegen_identifier(method_name)
        let prefix = "\(type_c_name)_"
        let raw_name = if sanitized_method.starts_with(prefix)
            then sanitized_method
            else "\(type_c_name)_\(sanitized_method)"
        return self.normalize_codegen_lookup_name(raw_name)
    }

    /// 查找方法的 DefId（通过方法名和 target_type 的模块路径匹配）
    find_method_def_id(self, method_name String, target_type Type) Option[DefId] = {
        let target_module_path = self.target_type_module_path(target_type)

        // 遍历所有 DefId，找到名称为 method_name 且 DefKind 为 Function 的 DefId
        // 优先找与 target_type 在同一模块的 DefId
        let mut best_def_id_opt = Option[DefId].None()
        let mut id UInt = 1
        while id < self.context.next_def_id() then {
            let def_id = DefId(id)
            let name_match = if self.context.get_name(def_id) is .Some(n) then n == method_name else false
            if name_match then {
                let is_function = if self.context.get_kind(def_id) is .Some(k) then k is .Function() else false
                if is_function then {
                    // 检查这个 DefId 是否已经有可用的 C 标识符
                    let already_mapped = self.has_c_identifier(def_id)
                    if not already_mapped then {
                        let method_module_path = self.context.get_module_path(def_id) or else List[String].new()
                        // 检查模块路径是否匹配
                        let paths_match = self.module_paths_equal(method_module_path, target_module_path)
                        if paths_match then {
                            return Option[DefId].Some(def_id)
                        }
                        // 如果没有找到匹配的，保存第一个找到的作为回退
                        when best_def_id_opt in {
                            .None() then {
                                best_def_id_opt = Option[DefId].Some(def_id)
                            },
                            .Some(_) then {},
                        }
                    }
                }
            }
            id += 1
        }
        return best_def_id_opt
    }

    /// 比较两个模块路径是否相等
    module_paths_equal(self, a List[String], b List[String]) Bool = {
        if a.count() <> b.count() then { return false }
        let mut i UInt = 0
        while i < a.count() then {
            if a[i] <> b[i] then { return false }
            i += 1
        }
        return true
    }

    // 查找类型定义的 DefId（TypeDef 类型，排除函数/变量）
    find_type_def_id_by_name(self, name String) Option[DefId] = {
        let def_ids = self.type_def_ids_named(name)
        return when def_ids.get(0(UInt)) in {
            .Some(def_id) then Option[DefId].Some(def_id),
            .None() then Option[DefId].None(),
        }
    }

    target_type_module_path(self, target_type Type) List[String] = {
        return when target_type in {
            .StructureType(def_id) then self.context.get_module_path(def_id) or else List[String].new(),
            .EnumType(def_id) then self.context.get_module_path(def_id) or else List[String].new(),
            .OpaqueType(def_id) then when self.context.lookup_type(def_id) in {
                .Some(mapped_type) then self.target_type_module_path(mapped_type),
                .None() then List[String].new(),
            },
            _ then List[String].new(),
        }
    }

    concrete_layout_key_for_type(self, t Type) String = {
        return when t in {
            .ReferenceType(inner) then "ref_\(self.concrete_layout_key_for_type(inner.val))",
            .MutableReferenceType(inner) then "mutref_\(self.concrete_layout_key_for_type(inner.val))",
            .PointerType(inner) then "ptr_\(self.concrete_layout_key_for_type(inner.val))",
            .MutablePointerType(inner) then "mutptr_\(self.concrete_layout_key_for_type(inner.val))",
            .WeakReferenceType(inner) then "weakref_\(self.concrete_layout_key_for_type(inner.val))",
            .MutableWeakReferenceType(inner) then "mutweakref_\(self.concrete_layout_key_for_type(inner.val))",
            .FunctionType(fn_params, return_type) then {
                let param_types = param_entry_types(fn_params)
                let mut out = "fn"
                for pt in param_types then {
                    out.push_string("_")
                    out.push_string(self.concrete_layout_key_for_type(pt.val))
                }
                out.push_string("_")
                out.push_string(self.concrete_layout_key_for_type(return_type.val))
                yield out
            },
            .GenericStruct(template, args) then {
                let mut out = template
                for arg in args then {
                    out.push_string("_")
                    out.push_string(self.concrete_layout_key_for_type(arg.val))
                }
                yield out
            },
            .GenericEnum(template, args) then {
                let mut out = template
                for arg in args then {
                    out.push_string("_")
                    out.push_string(self.concrete_layout_key_for_type(arg.val))
                }
                yield out
            },
            .StructureType(def_id) then self.concrete_layout_key_for_def_id(def_id) or else layout_key(t),
            .EnumType(def_id) then self.concrete_layout_key_for_def_id(def_id) or else layout_key(t),
            .OpaqueType(def_id) then self.concrete_layout_key_for_def_id(def_id) or else layout_key(t),
            _ then layout_key(t),
        }
    }

    concrete_layout_key_for_def_id(self, def_id DefId) Option[String] = {
        let name = self.context.get_name(def_id) or else { return Option[String].None() }
        let module_path = self.context.get_module_path(def_id) or else List[String].new()
        let is_private = if self.context.get_access(def_id) is .Some(access) then access is .Private() else false
        let source_file = self.context.get_source_file(def_id) or else ""

        let mut out = String.new()
        let mut needs_separator = false
        if not module_path.is_empty() then {
            for seg in module_path then {
                if needs_separator then { out.push_byte('_') }
                out.push_string(seg)
                needs_separator = true
            }
        }
        if is_private and not source_file.is_empty() then {
            let mut hash UInt32 = 0
            for byte in source_file.bytes() then {
                hash = hash.wrapping_mul(31).wrapping_add(byte(UInt32))
            }
            if needs_separator then { out.push_byte('_') }
            out.push_byte('f')
            out.push_string(((hash % 10000)(UInt)).to_string())
            needs_separator = true
        }
        if needs_separator then { out.push_byte('_') }
        out.push_string(name)
        return Option[String].Some(out)
    }

    // 仅按单态化后的 concrete layout 查找类型 DefId。
    find_type_def_id_by_layout_or_template(self, t Type, template String) Option[DefId] = {
        let layout_name = self.concrete_layout_key_for_type(t)
        if self.find_type_def_id_by_name(layout_name) is .Some(def_id) then {
            return Option[DefId].Some(def_id)
        }

        return Option[DefId].None()
    }

    private concrete_struct_fields_from_program(self, def_id DefId) Option[List[TypedField]] = {
        for global in self.program.globals then {
            when global in {
                .StructDeclaration(identifier, fields) then {
                    if identifier.def_id.id == def_id.id then { return Option[List[TypedField]].Some(fields) }
                },
                .ForeignStruct(identifier, fields) then {
                    if identifier.def_id.id == def_id.id then { return Option[List[TypedField]].Some(fields) }
                },
                _ then {},
            }
        }
        return Option[List[TypedField]].None()
    }

    private concrete_enum_cases_from_program(self, def_id DefId) Option[List[TypedEnumCase]] = {
        for global in self.program.globals then {
            when global in {
                .EnumDeclaration(identifier, cases) then {
                    if identifier.def_id.id == def_id.id then { return Option[List[TypedEnumCase]].Some(cases) }
                },
                _ then {},
            }
        }
        return Option[List[TypedEnumCase]].None()
    }

    private lookup_enum_case_index_and_params(self, def_id DefId, case_name String) Option[Pair[UInt, List[EnumCaseParam]]] = {
        let enum_cases_opt = when self.context.get_enum_cases(def_id) in {
            .Some(enum_cases) then Option[List[EnumCaseInfo]].Some(enum_cases),
            .None() then {
                yield when self.concrete_enum_cases_from_program(def_id) in {
                    .Some(typed_cases) then {
                        let mut enum_cases = List[EnumCaseInfo].new()
                        for typed_case in typed_cases then {
                            let mut params = List[EnumCaseParam].new()
                            for field in typed_case.fields then {
                                params.push(EnumCaseParam(field.name, field.field_type, field.named))
                            }
                            enum_cases.push(EnumCaseInfo(typed_case.name, params))
                        }
                        yield Option[List[EnumCaseInfo]].Some(enum_cases)
                    },
                    .None() then Option[List[EnumCaseInfo]].None(),
                }
            },
        }

        return when enum_cases_opt in {
            .Some(enum_cases) then {
                let mut found_index UInt = 0
                let mut found_params = List[EnumCaseParam].new()
                let mut found = false
                let mut i UInt = 0
                for uc in enum_cases then {
                    if self.enum_case_name_matches(case_name, uc.name) then {
                        found_index = i
                        found_params = uc.params
                        found = true
                    }
                    i += 1
                }
                let resolved = when found in {
                    true then Option[Pair[UInt, List[EnumCaseParam]]].Some(Pair[UInt, List[EnumCaseParam]](found_index, found_params)),
                    false then Option[Pair[UInt, List[EnumCaseParam]]].None(),
                }
                yield resolved
            },
            .None() then Option[Pair[UInt, List[EnumCaseParam]]].None(),
        }
    }

    // ── 限定名与 C 标识符查询 ─────────────────────────────────────────────────

    /// 获取 Symbol 的 C 限定名（用于代码生成中的变量/函数引用）
    ///
    /// - Foreign 函数使用原始名称（或 cname）
    /// - 全局符号优先使用 mono 产出的 codegen_view 中的映射
    /// - 局部变量使用 `{name}_{defId}` 格式
    public qualified_name_value(self, symbol Symbol) String = {
        if self.is_foreign_function_def_id(symbol.def_id) then {
            return when self.c_identifier_opt(symbol.def_id) in {
                .Some(c_id) then c_id,
                .None() then self.context.symbol_name(symbol),
            }
        }

        let is_global = when symbol.kind in {
            .Function() then true,
            .TypeSymbol() then true,
            .Module() then true,
            .Variable(_) then {
                let module_path = self.context.get_module_path(symbol.def_id) or else List[String].new()
                let source_file = self.context.get_source_file(symbol.def_id) or else ""
                let access = self.context.get_access(symbol.def_id) or else AccessModifier.Protected()
                let is_private = access is .Private()
                yield not module_path.is_empty() or not source_file.is_empty() or is_private
            },
        }

        if is_global then {
            return when self.c_identifier_opt(symbol.def_id) in {
                .Some(c_id) then c_id,
                .None() then {
                    let symbol_name = self.context.symbol_name(symbol)
                    yield if symbol.kind is .Function() and self.current_function_type_prefix is .Some(type_prefix)
                        then "\(type_prefix)_\(self.sanitize_codegen_identifier(symbol_name))"
                        else if symbol_name.starts_with("_k__") then symbol_name else self.sanitize_codegen_identifier(symbol_name)
                },
            }
        }

        let base = self.sanitize_codegen_identifier(self.context.symbol_name(symbol))
        return "\(base)_\(symbol.def_id.id)"
    }

    public qualified_name(self, symbol ref Symbol) String = {
        return self.qualified_name_value(symbol)
    }

    /// 获取 Symbol 的 C 标识符（用于声明）
    public c_identifier_for_symbol_value(self, symbol Symbol) String = {
        if self.is_foreign_global_var_def_id(symbol.def_id) then {
            return when self.c_identifier_opt(symbol.def_id) in {
                .Some(c_id) then c_id,
                .None() then self.context.symbol_name(symbol),
            }
        }

        when symbol.kind in {
            .Variable(_) then {
                if self.c_identifier_opt(symbol.def_id) is .Some(c_id) then {
                    return c_id
                }
                let base = self.sanitize_codegen_identifier(self.context.symbol_name(symbol))
                if base == "_" then {
                    return "_\(symbol.def_id.id)"
                }
                return base
            },
            _ then {},
        }

        return when self.c_identifier_opt(symbol.def_id) in {
            .Some(c_id) then c_id,
            .None() then {
                let symbol_name = self.context.symbol_name(symbol)
                let c_name = if symbol_name.starts_with("_k__") then symbol_name else self.sanitize_codegen_identifier(symbol_name)
                yield c_name
            },
        }
    }

    public c_identifier_for_symbol(self, symbol ref Symbol) String = {
        return self.c_identifier_for_symbol_value(symbol)
    }

    public c_identifier_for_param(self, param TypedParam) String = {
        return self.sanitize_codegen_identifier(param.name)
    }

    // ── 类型名称映射 ──────────────────────────────────────────────────────────

    private ref_wrapper_c_type_name(self, inner_type Type, weak Bool) String = {
        return if self.type_looks_traitlike_for_storage(inner_type)
            then if weak then "struct __koral_TraitWeakRef" else "struct __koral_TraitRef"
            else if weak then "struct __koral_WeakRef" else "struct __koral_Ref"
    }

    private type_looks_traitlike_for_storage(self, t Type) Bool = {
        return when t in {
            .TraitObject(_, _) then true,
            .ReferenceType(inner_ref) then self.type_looks_traitlike_for_storage(inner_ref.val),
            .MutableReferenceType(inner_ref) then self.type_looks_traitlike_for_storage(inner_ref.val),
            .WeakReferenceType(inner_ref) then self.type_looks_traitlike_for_storage(inner_ref.val),
            .MutableWeakReferenceType(inner_ref) then self.type_looks_traitlike_for_storage(inner_ref.val),
            .OpaqueType(def_id) then when self.context.lookup_type(def_id) in {
                .Some(mapped_type) then self.type_looks_traitlike_for_storage(mapped_type),
                .None() then {
                    let trait_name = self.context.get_name(def_id) or else ""
                    yield when self.context.get_kind(def_id) in {
                        .Some(kind) then when kind in {
                            .TypeDef(type_kind) then when type_kind in {
                                .Trait() then true,
                                _ then self.program.traits.get(trait_name).is_some(),
                            },
                            _ then self.program.traits.get(trait_name).is_some(),
                        },
                        .None() then self.program.traits.get(trait_name).is_some(),
                    }
                },
            },
            _ then false,
        }
    }

    private storage_ref_wrapper_c_type_name(self, inner_type Type, weak Bool) Option[String] = {
        return if self.type_looks_traitlike_for_storage(inner_type)
            then Option[String].Some(if weak then "struct __koral_TraitWeakRef" else "struct __koral_TraitRef")
            else Option[String].None()
    }

    public storage_c_type_name(self, t Type) String = {
        let storage_c_type_opt = when t in {
            .ReferenceType(inner_ref) then self.storage_ref_wrapper_c_type_name(inner_ref.val, false),
            .MutableReferenceType(inner_ref) then self.storage_ref_wrapper_c_type_name(inner_ref.val, false),
            .WeakReferenceType(inner_ref) then self.storage_ref_wrapper_c_type_name(inner_ref.val, true),
            .MutableWeakReferenceType(inner_ref) then self.storage_ref_wrapper_c_type_name(inner_ref.val, true),
            .TraitObject(_, _) then Option[String].Some("struct __koral_TraitRef"),
            .OpaqueType(def_id) then if self.type_looks_traitlike_for_storage(Type.OpaqueType(def_id))
                then Option[String].Some("struct __koral_TraitRef")
                else Option[String].None(),
            _ then Option[String].None(),
        }
        return when storage_c_type_opt in {
            .Some(storage_c_type) then storage_c_type,
            .None() then self.c_type_name(t),
        }
    }

    private nominal_named_c_type_name(self, t Type) Option[String] = {
        return when t in {
            .StructureType(def_id) then {
                let c_name = when self.c_identifier_opt(def_id) in {
                    .Some(name) then name,
                    .None() then when self.context.get_name(def_id) in {
                        .Some(name) then self.sanitize_codegen_identifier(name),
                        .None() then "T_\(def_id.id)",
                    },
                }
                yield Option[String].Some("struct \(c_name)")
            },
            .EnumType(def_id) then {
                let c_name = when self.c_identifier_opt(def_id) in {
                    .Some(name) then name,
                    .None() then {
                        yield when self.context.get_name(def_id) in {
                            .Some(name) then self.sanitize_codegen_identifier(name),
                            .None() then "U_\(def_id.id)",
                        }
                    },
                }
                yield Option[String].Some("struct \(c_name)")
            },
            _ then Option[String].None(),
        }
    }

    private opaque_mapped_c_type_name(self, mapped_type Type) Option[String] = {
        return when mapped_type in {
            .TraitObject(_, _) then {
                yield Option[String].Some("struct __koral_TraitRef")
            },
            .ReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then Option[String].Some("struct __koral_TraitRef"),
                    _ then Option[String].None(),
                }
            },
            .MutableReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then Option[String].Some("struct __koral_TraitRef"),
                    _ then Option[String].None(),
                }
            },
            .WeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then Option[String].Some("struct __koral_TraitWeakRef"),
                    _ then Option[String].None(),
                }
            },
            .MutableWeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then Option[String].Some("struct __koral_TraitWeakRef"),
                    _ then Option[String].None(),
                }
            },
            _ then Option[String].None(),
        }
    }

    private opaque_fallback_c_type_name(self, def_id DefId) String = {
        return when self.c_identifier_opt(def_id) in {
            .Some(name) then name,
            .None() then {
                yield when self.context.get_name(def_id) in {
                    .Some(name) then self.sanitize_codegen_identifier(name),
                    .None() then "opaque_\(def_id.id)",
                }
            },
        }
    }

    private opaque_c_type_name(self, t Type) Option[String] = {
        return when t in {
            .OpaqueType(def_id) then {
                let mapped_c_type_opt = when self.context.lookup_type(def_id) in {
                    .Some(mapped_type) then self.opaque_mapped_c_type_name(mapped_type),
                    .None() then Option[String].None(),
                }
                yield when mapped_c_type_opt in {
                    .Some(mapped_c_type) then Option[String].Some(mapped_c_type),
                    .None() then Option[String].Some(self.opaque_fallback_c_type_name(def_id)),
                }
            },
            _ then Option[String].None(),
        }
    }

    private generic_nominal_c_type_name(self, t Type) Option[String] = {
        return when t in {
            .GenericStruct(template, _) then {
                let layout_key = self.concrete_layout_key_for_type(t)
                yield when self.find_type_def_id_by_layout_or_template(t, template) in {
                    .Some(def_id) then {
                        yield when self.c_identifier_opt(def_id) in {
                            .Some(name) then Option[String].Some("struct \(name)"),
                            .None() then Option[String].Some("struct \(self.sanitize_codegen_identifier(layout_key))"),
                        }
                    },
                    .None() then Option[String].Some("struct \(self.sanitize_codegen_identifier(layout_key))"),
                }
            },
            .GenericEnum(template, _) then {
                let layout_key = self.concrete_layout_key_for_type(t)
                yield when self.find_type_def_id_by_layout_or_template(t, template) in {
                    .Some(def_id) then {
                        yield when self.c_identifier_opt(def_id) in {
                            .Some(name) then Option[String].Some("struct \(name)"),
                            .None() then Option[String].Some("struct \(self.sanitize_codegen_identifier(layout_key))"),
                        }
                    },
                    .None() then Option[String].Some("struct \(self.sanitize_codegen_identifier(layout_key))"),
                }
            },
            _ then Option[String].None(),
        }
    }

    private nominal_c_type_name(self, t Type) Option[String] = {
        when self.nominal_named_c_type_name(t) in {
            .Some(name) then { return Option[String].Some(name) },
            .None() then {},
        }
        when self.opaque_c_type_name(t) in {
            .Some(name) then { return Option[String].Some(name) },
            .None() then {},
        }
        return self.generic_nominal_c_type_name(t)
    }

    private reference_like_c_type_name(self, t Type) Option[String] = {
        return when t in {
            .ReferenceType(inner_ref) then Option[String].Some(self.ref_wrapper_c_type_name(inner_ref.val, false)),
            .MutableReferenceType(inner_ref) then Option[String].Some(self.ref_wrapper_c_type_name(inner_ref.val, false)),
            .PointerType(inner) then Option[String].Some("\(self.c_type_name(inner.val))*"),
            .MutablePointerType(inner) then Option[String].Some("\(self.c_type_name(inner.val))*"),
            .WeakReferenceType(inner_ref) then Option[String].Some(self.ref_wrapper_c_type_name(inner_ref.val, true)),
            .MutableWeakReferenceType(inner_ref) then Option[String].Some(self.ref_wrapper_c_type_name(inner_ref.val, true)),
            .FunctionType(_, _) then Option[String].Some("struct __koral_Closure"),
            .TraitObject(_, _) then Option[String].Some("struct __koral_TraitRef"),
            _ then Option[String].None(),
        }
    }

    /// 将 Koral Type 映射到 C 类型名称字符串
    public c_type_name(self, t Type) String = {
        // 原始类型委托给 TypeHandler 的 primitive_c_type_name
        let kind = type_handler_kind_from(t)
        when kind in {
            .Primitive() then { return primitive_c_type_name(t) },
            _ then {},
        }
        when self.reference_like_c_type_name(t) in {
            .Some(name) then { return name },
            .None() then {},
        }
        when self.nominal_c_type_name(t) in {
            .Some(name) then { return name },
            .None() then {},
        }
        return "void*"
    }

    private nominal_type_from_c_type_name(self, c_type String) Option[Type] = {
        let raw_name = if c_type.starts_with("struct ")
            then c_type.substring(7..<c_type.count())
            else if c_type.starts_with("enum ")
                then c_type.substring(5..<c_type.count())
                else ""
        if raw_name.is_empty() then {
            return Option[Type].None()
        }

        let mut id UInt = 1
        while id < self.context.next_def_id() then {
            let def_id = DefId(id)
            let candidate = self.c_identifier_opt(def_id) or else ""
            if candidate == raw_name then {
                return when self.context.get_kind(def_id) in {
                    .Some(kind) then when kind in {
                        .TypeDef(type_kind) then when type_kind in {
                            .Structure() then Option[Type].Some(Type.StructureType(def_id)),
                            .Enum() then Option[Type].Some(Type.EnumType(def_id)),
                            .Opaque() then Option[Type].Some(Type.OpaqueType(def_id)),
                            _ then Option[Type].None(),
                        },
                        .GenericTemplate(template_kind) then when template_kind in {
                            .Structure() then Option[Type].Some(Type.StructureType(def_id)),
                            .Enum() then Option[Type].Some(Type.EnumType(def_id)),
                            _ then Option[Type].None(),
                        },
                        _ then Option[Type].None(),
                    },
                    .None() then Option[Type].None(),
                }
            }
            id += 1
        }
        return Option[Type].None()
    }

    // 将 C 类型字符串反向映射为内部 Type（用于临时变量类型跟踪）。
    private type_from_c_type_name(self mut ref, c_type String) Type = {
        return when c_type in {
            "int8_t" then Type.Int8Type(),
            "int16_t" then Type.Int16Type(),
            "int32_t" then Type.Int32Type(),
            "int64_t" then Type.Int64Type(),
            "intptr_t" then Type.IntType(),
            "uint8_t" then Type.UInt8Type(),
            "uint16_t" then Type.UInt16Type(),
            "uint32_t" then Type.UInt32Type(),
            "uint64_t" then Type.UInt64Type(),
            "uintptr_t" then Type.UIntType(),
            "float" then Type.Float32Type(),
            "double" then Type.Float64Type(),
            "int" then Type.BoolType(),
            "void" then Type.VoidType(),
            _ then {
                yield self.nominal_type_from_c_type_name(c_type) or else Type.Unknown()
            },
        }
    }

    // ── 临时变量生成 ──────────────────────────────────────────────────────────

    /// 生成下一个临时变量名（格式：`_t{N}`）
    public next_temp(self mut ref) String = {
        self.temp_var_counter += 1
        let mut name = String.new()
        name.push_string("_t")
        name.push_string(self.temp_var_counter.to_string())
        return name
    }

    /// 生成临时变量并在 buffer 中声明（格式：`{c_type} _t{N};`）
    /// 返回变量名
    public next_temp_with_decl(self mut ref, c_type String) String = {
        let name = self.next_temp()
        self.add_indent()
        self.buffer.push_string(c_type)
        self.buffer.push_rune(' ')
        self.buffer.push_string(name)
        self.buffer.push_string(";\n")
        return name
    }

    /// 生成临时变量并在 buffer 中声明并初始化（格式：`{c_type} _t{N} = {init_expr};`）
    /// 返回变量名
    public next_temp_with_init(self mut ref, c_type String, init_expr String) String = {
        let name = self.next_temp()
        self.add_indent()
        self.buffer.push_string(c_type)
        self.buffer.push_rune(' ')
        self.buffer.push_string(name)
        self.buffer.push_string(" = ")
        self.buffer.push_string(init_expr)
        self.buffer.push_string(";\n")
        return name
    }

    public next_temp_with_call_1(self mut ref, c_type String, func_name String, arg String) String = {
        let name = self.next_temp()
        self.add_indent()
        self.buffer.push_string(c_type)
        self.buffer.push_rune(' ')
        self.buffer.push_string(name)
        self.buffer.push_string(" = ")
        self.buffer.push_string(func_name)
        self.buffer.push_rune('(')
        self.buffer.push_string(arg)
        self.buffer.push_string(");\n")
        return name
    }

    public next_temp_with_call_2(self mut ref, c_type String, func_name String, first_arg String, second_arg String) String = {
        let name = self.next_temp()
        self.add_indent()
        self.buffer.push_string(c_type)
        self.buffer.push_rune(' ')
        self.buffer.push_string(name)
        self.buffer.push_string(" = ")
        self.buffer.push_string(func_name)
        self.buffer.push_rune('(')
        self.buffer.push_string(first_arg)
        self.buffer.push_string(", ")
        self.buffer.push_string(second_arg)
        self.buffer.push_string(");\n")
        return name
    }

    public next_temp_with_infix_init(self mut ref, c_type String, left String, op String, right String) String = {
        let name = self.next_temp()
        self.add_indent()
        self.buffer.push_string(c_type)
        self.buffer.push_rune(' ')
        self.buffer.push_string(name)
        self.buffer.push_string(" = ")
        self.buffer.push_string(left)
        self.buffer.push_rune(' ')
        self.buffer.push_string(op)
        self.buffer.push_rune(' ')
        self.buffer.push_string(right)
        self.buffer.push_string(";\n")
        return name
    }

    public next_temp_with_prefixed_value(self mut ref, c_type String, prefix String, value String) String = {
        let name = self.next_temp()
        self.add_indent()
        self.buffer.push_string(c_type)
        self.buffer.push_rune(' ')
        self.buffer.push_string(name)
        self.buffer.push_string(" = ")
        self.buffer.push_string(prefix)
        self.buffer.push_string(value)
        self.buffer.push_string(";\n")
        return name
    }

    // ── 缓冲区操作 ────────────────────────────────────────────────────────────

    /// 向 buffer 追加当前缩进
    public add_indent(self mut ref) Void = {
        self.buffer.push_string(self.indent)
    }

    /// 向 buffer 追加当前缩进与文本，适合频繁的一行输出场景
    public push_indented_string(self mut ref, text String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string(text)
    }

    public push_indented_decl(self mut ref, c_type String, name String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string(c_type)
        self.buffer.push_rune(' ')
        self.buffer.push_string(name)
        self.buffer.push_string(";\n")
    }

    public push_indented_assignment(self mut ref, dest String, source String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string(dest)
        self.buffer.push_string(" = ")
        self.buffer.push_string(source)
        self.buffer.push_string(";\n")
    }

    public push_indented_member_assignment(self mut ref, base String, member String, source String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string(base)
        self.buffer.push_rune('.')
        self.buffer.push_string(member)
        self.buffer.push_string(" = ")
        self.buffer.push_string(source)
        self.buffer.push_string(";\n")
    }

    public push_indented_control_assignment(self mut ref, ref_name String, field String, source String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string("((struct __koral_Control*)")
        self.buffer.push_string(ref_name)
        self.buffer.push_string(".control)->")
        self.buffer.push_string(field)
        self.buffer.push_string(" = ")
        self.buffer.push_string(source)
        self.buffer.push_string(";\n")
    }

    public push_indented_return_value(self mut ref, value String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string("return ")
        self.buffer.push_string(value)
        self.buffer.push_string(";\n")
    }

    public push_indented_return_void(self mut ref) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string("return;\n")
    }

    public push_indented_goto(self mut ref, label String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string("goto ")
        self.buffer.push_string(label)
        self.buffer.push_string(";\n")
    }

    public push_indented_if_open(self mut ref, condition String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string("if (")
        self.buffer.push_string(condition)
        self.buffer.push_string(") {\n")
    }

    public push_indented_label_block_open(self mut ref, label String) Void = {
        self.buffer.push_string(self.indent)
        self.buffer.push_string(label)
        self.buffer.push_string(": {\n")
    }

    /// 临时增加缩进，执行 body，然后恢复缩进
    public with_indent(self mut ref, body Func[Void]) Void = {
        self.indent.push_string("    ")
        body()
        // 移除最后 4 个字符（一级缩进）
        let len = self.indent.count()
        if len >= 4 then {
            self.indent = self.indent.substring(0..<(len - 4))
        }
    }

    /// 向 buffer 追加文本
    public append_to_buffer(self mut ref, text String) Void = {
        self.buffer.push_string(text)
    }

}
