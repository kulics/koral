// codegen_expressions_calls.koral - 函数调用代码生成
//
// 实现 CodeGen 的各种函数调用生成方法：
// - generate_call：主调用入口
// - generate_type_construction：类型构造函数调用
// - generate_function_call：普通函数调用
// - generate_closure_call：闭包调用
// - generate_subscript_call：下标调用
//
// Requirements: 5.16, 5.19, 5.20

given CodeGen {
    public generate_call(self ref, callee TypedExpr ref, args [TypedExpr ref]List, result_type Type) String = {
        // 泛型类型构造调用：[T]Type(...)
        when callee.expr_kind in {
            .GenericInstantiation(_, _) then {
                let ctor_type = when result_type in {
                    .Unknown() then callee.expr_type,
                    _ then result_type,
                }
                when ctor_type in {
                    .StructureType(_) then {
                        return self.generate_type_construction_from_args(args, ctor_type)
                    },
                    .GenericStruct(_, _) then {
                        return self.generate_type_construction_from_args(args, ctor_type)
                    },
                    .EnumType(_) then {
                        return self.generate_type_construction_from_args(args, ctor_type)
                    },
                    .GenericEnum(_, _) then {
                        return self.generate_type_construction_from_args(args, ctor_type)
                    },
                    _ then {},
                }
            },
            _ then {},
        }

        // 检查是否为闭包变量调用
        when callee.expr_kind in {
            .Variable(symbol) then {
                let inferred_result_type = when result_type in {
                    .Unknown() then {
                        yield when symbol.symbol_type in {
                            .FunctionType(_, return_type_ref) then return_type_ref.val,
                            _ then {
                                yield when self.def_id_map.get_signature(symbol.def_id) in {
                                    .Some(sig) then sig.return_type,
                                    .None() then result_type,
                                }
                            },
                        }
                    },
                    .VoidType() then {
                        let sig_ret = when self.def_id_map.get_signature(symbol.def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then result_type,
                        }
                        yield when sig_ret in {
                            .VoidType() then result_type,
                            .NeverType() then result_type,
                            .Unknown() then result_type,
                            _ then sig_ret,
                        }
                    },
                    _ then result_type,
                }

                // 检查是否为类型构造函数调用（TypeSymbol 或 Function kind 但对应结构体类型）
                when symbol.kind in {
                    .TypeSymbol() then {
                        let ctor_type = when result_type in {
                            .Unknown() then {
                                let ctor_module_path = self.def_id_map.get_module_path(symbol.def_id) or else [String]List.new()
                                yield when self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path) in {
                                    .Some(t) then t,
                                    .None() then {
                                        yield when self.lookup_struct_type_by_name(symbol.name) in {
                                            .Some(t) then t,
                                            .None() then result_type,
                                        }
                                    },
                                }
                            },
                            _ then result_type,
                        }
                        return self.generate_type_construction(symbol, args, ctor_type)
                    },
                    .Function() then {
                        // 检查是否是结构体构造函数：
                        // 1. result_type 是 StructureType 且 symbol 名称与类型名相同
                        // 2. 或者 result_type 是 Unknown 但 symbol 名称对应一个 Koral 结构体类型
                        let struct_type_opt = when result_type in {
                            .Unknown() then {
                                // 优先使用推断后的返回类型
                                yield when inferred_result_type in {
                                    .StructureType(_) then [Type]Option.Some(inferred_result_type),
                                    .GenericStruct(_, _) then [Type]Option.Some(inferred_result_type),
                                    _ then {
                                        // result_type 是 Unknown，尝试从 symbol 名称和模块路径查找结构体类型
                                        // 使用模块路径感知的查找，避免同名类型歧义（如 Path 在 Std.Os 和 Std.Os.Path 中都有定义）
                                        let ctor_module_path = self.def_id_map.get_module_path(symbol.def_id) or else [String]List.new()
                                        let type_opt = self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path)
                                        yield when type_opt in {
                                            .Some(t) then [Type]Option.Some(t),
                                            .None() then self.lookup_struct_type_by_name(symbol.name),
                                        }
                                    },
                                }
                            },
                            .StructureType(def_id) then {
                                yield if self.static_target_matches_name(result_type, symbol.name) then [Type]Option.Some(result_type) else [Type]Option.None()
                            },
                            .GenericStruct(template_name, _) then {
                                yield if symbol.name == template_name then [Type]Option.Some(result_type) else [Type]Option.None()
                            },
                            .EnumType(_) then {
                                yield if self.static_target_matches_name(result_type, symbol.name) then [Type]Option.Some(result_type) else [Type]Option.None()
                            },
                            .GenericEnum(template_name, _) then {
                                yield if symbol.name == template_name then [Type]Option.Some(result_type) else [Type]Option.None()
                            },
                            _ then [Type]Option.None(),
                        }
                        when struct_type_opt in {
                            .Some(struct_type) then {
                                return self.generate_type_construction(symbol, args, struct_type)
                            },
                            .None() then {},
                        }
                    },
                    _ then {},
                }
                // 检查是否为函数类型变量（闭包调用）
                when symbol.kind in {
                    .Variable(_) then {
                        when symbol.symbol_type in {
                            .FunctionType(func_params, return_type_ref) then {
                                let closure_var = self.generate_expression_ssa(callee)
                                return self.generate_closure_call(closure_var, func_params, return_type_ref.val, args)
                            },
                            _ then {},
                        }
                    },
                    _ then {},
                }
                // 普通函数调用
                return self.generate_function_call(symbol, args, inferred_result_type)
            },
            _ then {},
        }

        // 间接调用（如 lambda 表达式结果）
        when callee.expr_type in {
            .FunctionType(func_params, return_type_ref) then {
                let closure_result = self.generate_expression_ssa(callee)
                return self.generate_closure_call(closure_result, func_params, return_type_ref.val, args)
            },
            _ then {},
        }

        // MemberExpr 调用：base.method(args) → 查找方法并生成函数调用
        when callee.expr_kind in {
            .MemberExpr(base_ref, method_name) then {
                let base = base_ref
                let base_type = self.concretize_codegen_type(base.expr_type)
                // 特殊处理：仅 GenericEnum 的 GenericInstantiation 作为 base 时，
                // method_name 才是 enum case 构造器（例如 [T]Option.None()）。
                let is_generic_union_base = when base.expr_kind in {
                    .GenericInstantiation(_, _) then {
                        yield when base.expr_type in {
                            .GenericEnum(_, _) then true,
                            .EnumType(_) then true,
                            _ then false,
                        }
                    },
                    _ then false,
                }
                if is_generic_union_base then {
                    // 使用 base.expr_type 或 result_type 作为 enum 类型来构造
                    // base.expr_type 是 GenericEnum("Option", [T]) 等
                    let enum_type = when result_type in {
                        .Unknown() then base.expr_type,
                        _ then result_type,
                    }
                    return self.generate_enum_constructor(enum_type, method_name, args)
                }

                let static_receiver_type_opt = when base.expr_kind in {
                    .GenericInstantiation(_, _) then [Type]Option.Some(base.expr_type),
                    .Variable(symbol) then when symbol.kind in {
                        .TypeSymbol() then {
                            let inferred_type = when base.expr_type in {
                                .Unknown() then {
                                    yield when self.monomorphized_token_to_type(symbol.name) in {
                                        .Some(t) then t,
                                        .None() then {
                                            let module_path = self.def_id_map.get_module_path(symbol.def_id) or else [String]List.new()
                                            yield when self.lookup_struct_type_by_name_and_module(symbol.name, module_path) in {
                                                .Some(t) then t,
                                                .None() then {
                                                    yield when self.lookup_struct_type_by_name(symbol.name) in {
                                                        .Some(t) then t,
                                                        .None() then base.expr_type,
                                                    }
                                                },
                                            }
                                        },
                                    }
                                },
                                _ then base.expr_type,
                            }
                            yield [Type]Option.Some(inferred_type)
                        },
                        _ then [Type]Option.None(),
                    },
                    _ then [Type]Option.None(),
                }
                when static_receiver_type_opt in {
                    .Some(static_receiver_type) then {
                        let concrete_static_receiver_type = self.concretize_codegen_type(static_receiver_type)
                        let method_hint_opt = self.lookup_receiver_method(concrete_static_receiver_type, method_name)
                        let static_result_type = when result_type in {
                            .Unknown() then {
                                yield when method_hint_opt in {
                                    .Some(method_symbol) then method_symbol.symbol_type,
                                    .None() then result_type,
                                }
                            },
                            .VoidType() then {
                                yield when method_hint_opt in {
                                    .Some(method_symbol) then {
                                        yield when method_symbol.symbol_type in {
                                            .VoidType() then result_type,
                                            .NeverType() then result_type,
                                            .Unknown() then result_type,
                                            _ then method_symbol.symbol_type,
                                        }
                                    },
                                    .None() then result_type,
                                }
                            },
                            _ then result_type,
                        }
                        let method_symbol = when method_hint_opt in {
                            .Some(symbol) then symbol,
                            .None() then self.make_codegen_method_symbol(method_name, static_result_type),
                        }
                        return self.generate_static_method_call(concrete_static_receiver_type, method_symbol, args, static_result_type)
                    },
                    .None() then {},
                }

                let effective_base_type = base_type

                // TraitObject 方法调用：走 vtable 动态分发
                when effective_base_type in {
                    .TraitObject(trait_name) then {
                        let mut trait_ret_type = Type.Unknown()
                        let members = self.get_ordered_trait_members(trait_name)
                        for m in members then {
                            if m.name == method_name then {
                                trait_ret_type = m.return_type
                            }
                        }
                        when trait_ret_type in {
                            .Unknown() then {
                                when self.program.lookup_static_method(trait_name, method_name) in {
                                    .Some(def_id) then {
                                        when self.def_id_map.get_signature(def_id) in {
                                            .Some(sig) then { trait_ret_type = sig.return_type },
                                            .None() then {},
                                        }
                                    },
                                    .None() then {},
                                }
                            },
                            _ then {},
                        }
                        let effective_trait_result = when result_type in {
                            .Unknown() then trait_ret_type,
                            .VoidType() then {
                                yield when trait_ret_type in {
                                    .VoidType() then result_type,
                                    .NeverType() then result_type,
                                    .Unknown() then result_type,
                                    _ then trait_ret_type,
                                }
                            },
                            _ then result_type,
                        }
                        return self.generate_trait_method_call(base, trait_name, method_name, args, effective_trait_result)
                    },
                    _ then {},
                }

                let method_hint_opt = self.lookup_receiver_method(effective_base_type, method_name)
                let effective_result_type = when result_type in {
                    .Unknown() then {
                        yield when method_hint_opt in {
                            .Some(method_symbol) then method_symbol.symbol_type,
                            .None() then result_type,
                        }
                    },
                    .VoidType() then {
                        yield when method_hint_opt in {
                            .Some(method_symbol) then {
                                yield when method_symbol.symbol_type in {
                                    .VoidType() then result_type,
                                    .NeverType() then result_type,
                                    .Unknown() then result_type,
                                    _ then method_symbol.symbol_type,
                                }
                            },
                            .None() then result_type,
                        }
                    },
                    _ then result_type,
                }
                when method_hint_opt in {
                    .Some(method_symbol) then {
                        return self.generate_receiver_method_call(base, effective_base_type, method_symbol, args, effective_result_type)
                    },
                    .None() then {},
                }
            },
            _ then {},
        }

        // 默认：直接求值 callee
        return self.generate_expression_ssa(callee)
    }

    /// TypeSymbol 调用生成 (struct T){ arg1, arg2, ... } 的 C 代码
    public generate_type_construction(self ref, symbol Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        return self.generate_type_construction_from_args(args, result_type)
    }

    private generate_type_construction_from_args(self ref, args [TypedExpr ref]List, result_type Type) String = {
        let mut arg_results = [String]List.new()
        let mut arg_index UInt = 0
        for arg_ref in args then {
            let arg = arg_ref
            let arg_type = arg.expr_type
            let result = when arg.expr_kind in {
                .Variable(sym) then {
                    yield self.generate_expression_ssa(arg)
                },
                _ then self.generate_expression_ssa(arg),
            }
            let is_lvalue = self.is_lvalue_expr(arg)
            if is_lvalue and self.needs_drop(arg_type) then {
                // 引用类型：retain
                when arg_type in {
                    .ReferenceType(_) then {
                        self.add_indent()
                        self.buffer.push_string("__koral_retain(\(result).control);\n")
                        arg_results.push(result)
                    },
                    _ then {
                        let c_type = self.c_type_name(arg_type)
                        let copy_result = self.next_temp_with_decl(c_type)
                        self.append_copy_assignment(arg_type, result, copy_result)
                        arg_results.push(copy_result)
                    },
                }
            } else {
                arg_results.push(result)
            }
            arg_index += 1
        }

        let c_type = self.c_type_name(result_type)
        let args_str = arg_results.join_to_string(", ")
        return self.next_temp_with_init(c_type, "(\(c_type)){ \(args_str) }")
    }

    /// 生成普通函数调用代码
    ///
    /// Requirements: 5.16
    public generate_function_call(self ref, symbol Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        // Prefer struct construction when a callable symbol name resolves to a type
        // in the same module context (or globally), even if the symbol kind degraded
        // to Function during earlier lowering.
        let ctor_module_path = self.def_id_map.get_module_path(symbol.def_id) or else [String]List.new()
        let ctor_type_opt = when self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path) in {
            .Some(t) then [Type]Option.Some(t),
            .None() then self.lookup_struct_type_by_name(symbol.name),
        }
        when ctor_type_opt in {
            .Some(ctor_type) then {
                let should_construct = when result_type in {
                    .Unknown() then false,
                    .StructureType(_) then self.static_target_matches_name(result_type, symbol.name) or self.codegen_types_equal(result_type, ctor_type),
                    .GenericStruct(_, _) then true,
                    .EnumType(_) then self.static_target_matches_name(result_type, symbol.name) or self.codegen_types_equal(result_type, ctor_type),
                    .GenericEnum(_, _) then true,
                    _ then false,
                }
                if should_construct then {
                    let effective_ctor_type = when result_type in {
                        .Unknown() then ctor_type,
                        .StructureType(_) then result_type,
                        .GenericStruct(_, _) then result_type,
                        _ then ctor_type,
                    }
                    return self.generate_type_construction(symbol, args, effective_ctor_type)
                }
            },
            .None() then {},
        }

        // Intrinsic ref helpers are lowered inline in C and should not become
        // external symbol references.
        if symbol.name == "ref_is_borrow" and args.count() == 1 then {
            let arg = args.at((UInt)0)
            let arg_value = self.generate_expression_ssa(arg)
            let ref_value = when arg.expr_type in {
                .ReferenceType(_) then arg_value,
                _ then {
                    let mut lowered = arg_value
                    if self.is_lvalue_expr(arg) then {
                        let ref_result = self.next_temp_with_decl("struct __koral_Ref")
                        let components = self.build_ref_components(arg)
                        let lvalue_path = components.first
                        let control_path = components.second
                        self.add_indent()
                        self.buffer.push_string("\(ref_result).ptr = &\(lvalue_path);\n")
                        self.add_indent()
                        self.buffer.push_string("\(ref_result).control = \(control_path);\n")
                        lowered = ref_result
                    }
                    yield lowered
                },
            }
            let result = self.next_temp_with_init("int", "(\(ref_value).control == NULL)")
            self.register_variable(result, Type.BoolType())
            return result
        }

        if symbol.name == "ref_count" and args.count() == 1 then {
            let arg = args.at((UInt)0)
            let arg_value = self.generate_expression_ssa(arg)
            let ref_value = when arg.expr_type in {
                .ReferenceType(_) then arg_value,
                _ then {
                    let mut lowered = arg_value
                    if self.is_lvalue_expr(arg) then {
                        let ref_result = self.next_temp_with_decl("struct __koral_Ref")
                        let components = self.build_ref_components(arg)
                        let lvalue_path = components.first
                        let control_path = components.second
                        self.add_indent()
                        self.buffer.push_string("\(ref_result).ptr = &\(lvalue_path);\n")
                        self.add_indent()
                        self.buffer.push_string("\(ref_result).control = \(control_path);\n")
                        lowered = ref_result
                    }
                    yield lowered
                },
            }
            let result = self.next_temp_with_decl("intptr_t")
            self.add_indent()
            self.buffer.push_string("\(result) = 0;\n")
            self.add_indent()
            self.buffer.push_string("if (\(ref_value).control) {\n")
            self.with_indent(() -> {
                self.add_indent()
                self.buffer.push_string("\(result) = atomic_load(&((struct __koral_Control*)\(ref_value).control)->strong_count);\n")
            })
            self.add_indent()
            self.buffer.push_string("}\n")
            self.register_variable(result, Type.IntType())
            return result
        }

        if symbol.name == "downgrade_ref" and args.count() == 1 then {
            let arg = args.at((UInt)0)
            let arg_value = self.generate_expression_ssa(arg)
            let actual_result_type = when arg.expr_type in {
                .ReferenceType(inner_ref) then Type.WeakReferenceType(box(inner_ref.val)),
                _ then result_type,
            }
            when arg.expr_type in {
                .ReferenceType(inner_ref) then {
                    when inner_ref.val in {
                        .TraitObject(_) then {
                            let result = self.next_temp_with_decl("struct __koral_TraitWeakRef")
                            let temp_weak = self.next_temp_with_decl("struct __koral_WeakRef")
                            self.add_indent()
                            self.buffer.push_string("\(temp_weak) = __koral_downgrade_ref((struct __koral_Ref){\(arg_value).ptr, \(arg_value).control});\n")
                            self.add_indent()
                            self.buffer.push_string("\(result).control = \(temp_weak).control;\n")
                            self.add_indent()
                            self.buffer.push_string("\(result).vtable = \(arg_value).vtable;\n")
                            self.register_variable(result, actual_result_type)
                            return result
                        },
                        _ then {},
                    }
                },
                _ then {},
            }
            let result = self.next_temp_with_init("struct __koral_WeakRef", "__koral_downgrade_ref(\(arg_value))")
            self.register_variable(result, actual_result_type)
            return result
        }

        if symbol.name == "upgrade_ref" and args.count() == 1 then {
            let arg = args.at((UInt)0)
            let arg_value = self.generate_expression_ssa(arg)
            let success_var = self.next_temp_with_decl("int")
            let actual_result_type = when arg.expr_type in {
                .WeakReferenceType(inner_ref) then {
                    let mut option_args = [Type ref]List.new()
                    option_args.push(box(Type.ReferenceType(box(inner_ref.val))))
                    yield Type.GenericEnum("Option", option_args)
                },
                _ then result_type,
            }
            when arg.expr_type in {
                .WeakReferenceType(inner_ref) then {
                    when inner_ref.val in {
                        .TraitObject(_) then {
                            let upgraded_ref = self.next_temp_with_init("struct __koral_Ref", "__koral_upgrade_ref((struct __koral_WeakRef){\(arg_value).control}, &\(success_var))")
                            let c_type = self.c_type_name(actual_result_type)
                            let result = self.next_temp_with_decl(c_type)
                            self.add_indent()
                            self.buffer.push_string("if (\(success_var)) {\n")
                            self.with_indent(() -> {
                                self.add_indent()
                                self.buffer.push_string("\(result).tag = 1;\n")
                                self.add_indent()
                                self.buffer.push_string("\(result).data.Some.value.ptr = \(upgraded_ref).ptr;\n")
                                self.add_indent()
                                self.buffer.push_string("\(result).data.Some.value.control = \(upgraded_ref).control;\n")
                                self.add_indent()
                                self.buffer.push_string("\(result).data.Some.value.vtable = \(arg_value).vtable;\n")
                            })
                            self.add_indent()
                            self.buffer.push_string("} else {\n")
                            self.with_indent(() -> {
                                self.add_indent()
                                self.buffer.push_string("\(result).tag = 0;\n")
                            })
                            self.add_indent()
                            self.buffer.push_string("}\n")
                            self.register_variable(result, actual_result_type)
                            return result
                        },
                        _ then {},
                    }
                },
                _ then {},
            }
            let upgraded_ref = self.next_temp_with_init("struct __koral_Ref", "__koral_upgrade_ref(\(arg_value), &\(success_var))")
            let c_type = self.c_type_name(actual_result_type)
            let result = self.next_temp_with_decl(c_type)
            self.add_indent()
            self.buffer.push_string("if (\(success_var)) {\n")
            self.with_indent(() -> {
                self.add_indent()
                self.buffer.push_string("\(result).tag = 1;\n")
                self.add_indent()
                self.buffer.push_string("\(result).data.Some.value = \(upgraded_ref);\n")
            })
            self.add_indent()
            self.buffer.push_string("} else {\n")
            self.with_indent(() -> {
                self.add_indent()
                self.buffer.push_string("\(result).tag = 0;\n")
            })
            self.add_indent()
            self.buffer.push_string("}\n")
            self.register_variable(result, actual_result_type)
            return result
        }

        let raw_signature_opt = when self.def_id_map.get_signature(symbol.def_id) in {
            .Some(sig) then [FunctionSignature]Option.Some(sig),
            .None() then [FunctionSignature]Option.None(),
        }
        let func_name = self.qualified_name(symbol)
        let resolved_func_name = if symbol.name == "spawn_thread" then "__koral_spawn_thread" else func_name
        let mut concrete_receiver_type_opt = [Type]Option.None()
        if args.count() > 0 then {
            let resolved_def_id = self.def_id_by_c_name_index.get(resolved_func_name) or else symbol.def_id
            let has_method_owner = self.method_owner_type_by_def_id.contains_key(symbol.def_id.id)
                or self.method_owner_type_by_def_id.contains_key(resolved_def_id.id)
            let has_lowered_method = self.program.lowered_method_info_by_def_id.contains_key(symbol.def_id.id)
                or self.program.lowered_method_info_by_def_id.contains_key(resolved_def_id.id)
            let signature_omits_self = when raw_signature_opt in {
                .Some(sig) then sig.param_types.count() < args.count(),
                .None() then when self.lookup_function_signature_by_c_name(resolved_func_name) in {
                    .Some(sig) then sig.param_types.count() < args.count(),
                    .None() then false,
                },
            }
            if has_method_owner or has_lowered_method or signature_omits_self then {
                concrete_receiver_type_opt = [Type]Option.Some(self.concretize_codegen_type(args.at((UInt)0).expr_type))
            }
        }
        let signature_opt = when raw_signature_opt in {
            .Some(sig) then {
                yield when concrete_receiver_type_opt in {
                    .Some(concrete_receiver_type) then [FunctionSignature]Option.Some(self.bind_method_signature(symbol.def_id, concrete_receiver_type, sig)),
                    .None() then [FunctionSignature]Option.Some(sig),
                }
            },
            .None() then [FunctionSignature]Option.None(),
        }
        let mut effective_result_type = when result_type in {
            .Unknown() then {
                yield when signature_opt in {
                    .Some(sig) then {
                        let inferred_return = if not self.is_unresolved_codegen_type(sig.return_type) then sig.return_type else when self.lookup_function_signature_by_c_name(resolved_func_name) in {
                            .Some(c_sig) then c_sig.return_type,
                            .None() then result_type,
                        }
                        yield inferred_return
                    },
                    .None() then {
                        yield when self.lookup_function_signature_by_c_name(resolved_func_name) in {
                            .Some(c_sig) then c_sig.return_type,
                            .None() then result_type,
                        }
                    },
                }
            },
            .VoidType() then {
                let sig_ret = when signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then when self.lookup_function_signature_by_c_name(resolved_func_name) in {
                        .Some(c_sig) then c_sig.return_type,
                        .None() then result_type,
                    },
                }
                yield when sig_ret in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then sig_ret,
                }
            },
            _ then result_type,
        }
        when self.lookup_function_signature_by_c_name(resolved_func_name) in {
            .Some(c_sig) then {
                when result_type in {
                    .VoidType() then {},
                    .NeverType() then {},
                    _ then {
                        let current_unresolved = self.is_unresolved_codegen_type(effective_result_type)
                        let candidate_concrete = not self.is_unresolved_codegen_type(c_sig.return_type)
                        if current_unresolved and candidate_concrete then {
                            effective_result_type = c_sig.return_type
                        }
                    },
                }
            },
            .None() then {},
        }

        // 回退：当 result_type 仍为 Unknown 时，尝试把函数调用当作结构体构造
        // 这能覆盖某些单态化后丢失 TypeSymbol 的构造调用（如 DequeIterator(...)）。
        when effective_result_type in {
            .Unknown() then {
                let ctor_module_path = self.def_id_map.get_module_path(symbol.def_id) or else [String]List.new()
                let struct_type_opt = when self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path) in {
                    .Some(t) then [Type]Option.Some(t),
                    .None() then self.lookup_struct_type_by_name(symbol.name),
                }
                when struct_type_opt in {
                    .Some(struct_type) then {
                        return self.generate_type_construction(symbol, args, struct_type)
                    },
                    .None() then {},
                }
            },
            _ then {},
        }

        let mut param_results = [String]List.new()
        let mut arg_index = (UInt)0
        for arg_ref in args then {
            let arg = arg_ref
            when concrete_receiver_type_opt in {
                .Some(concrete_receiver_type) then {
                    if arg_index == 0 then {
                        let receiver_var = self.generate_expression_ssa(arg)
                        let receiver_is_lvalue = self.is_lvalue_expr(arg)
                        let receiver_components = if receiver_is_lvalue then {
                            yield self.build_ref_components(arg)
                        } else {
                            yield [String, String]Pair("", "NULL")
                        }
                        let remaining_arg_count = if args.count() > 0 then args.count() - (UInt)1 else (UInt)0
                        let receiver_arg = self.prepare_receiver_method_argument(receiver_var, concrete_receiver_type, receiver_is_lvalue, receiver_components.first, receiver_components.second, symbol, remaining_arg_count)
                        param_results.push(receiver_arg)
                        arg_index = arg_index + (UInt)1
                        continue
                    }
                },
                .None() then {},
            }
            let typed_expected_type_opt = when signature_opt in {
                .Some(sig) then {
                    yield if arg_index < sig.param_types.count() then [Type]Option.Some(sig.param_types.at(arg_index)) else [Type]Option.None()
                },
                .None() then [Type]Option.None(),
            }
            let expected_type_opt = when typed_expected_type_opt in {
                .Some(expected_type) then [Type]Option.Some(expected_type),
                .None() then {
                    yield when self.lookup_function_signature_by_c_name(resolved_func_name) in {
                        .Some(sig) then {
                            let inferred = if arg_index < sig.param_types.count() then [Type]Option.Some(sig.param_types.at(arg_index)) else [Type]Option.None()
                            yield inferred
                        },
                        .None() then [Type]Option.None(),
                    }
                },
            }
            let is_lvalue = self.is_lvalue_expr(arg)
            let lowered_arg = when expected_type_opt in {
                .Some(expected_type) then when expected_type in {
                    .TraitObject(_) then arg,
                    _ then when arg.expr_kind in {
                        .TraitObjectConversion(inner, _, _) then inner,
                        _ then arg,
                    },
                },
                .None() then arg,
            }
            let arg_type = lowered_arg.expr_type
            let result = self.generate_expression_ssa(lowered_arg)
            let effective_arg_type = when expected_type_opt in {
                .Some(expected_type) then {
                    yield if self.is_unresolved_codegen_type(arg_type) and not self.is_unresolved_codegen_type(expected_type)
                        then expected_type
                        else arg_type
                },
                .None() then arg_type,
            }
            let mut arg_value = result
            if is_lvalue and self.needs_drop(effective_arg_type) then {
                let c_type = self.c_type_name(effective_arg_type)
                let copy_result = self.next_temp_with_decl(c_type)
                self.append_copy_assignment(effective_arg_type, result, copy_result)
                arg_value = copy_result
            }

            when expected_type_opt in {
                .Some(expected_type) then {
                    arg_value = self.adapt_call_argument_to_expected_type(lowered_arg, arg_value, expected_type, is_lvalue)
                },
                .None() then {},
            }

            param_results.push(arg_value)
            arg_index = arg_index + (UInt)1
        }

        let args_str = param_results.join_to_string(", ")
        if self.type_is_void_or_never(effective_result_type) then {
            self.add_indent()
            self.buffer.push_string("\(resolved_func_name)(\(args_str));\n")
            return ""
        } else {
            let c_type = self.c_type_name(effective_result_type)
            let result = self.next_temp_with_init(c_type, "\(resolved_func_name)(\(args_str))")
            return result
        }
    }


    /// 生成闭包调用代码
    ///
    /// 根据 env == NULL 生成条件分支：
    /// - env == NULL：直接调用函数指针（无捕获）
    /// - env != NULL：将 env 作为第一个参数传入（有捕获）
    ///
    /// Requirements: 5.16
    public generate_closure_call(self ref, closure_var String, func_params [Type ref]List, return_type Type, args [TypedExpr ref]List) String = {
        // 求值参数，lvalue 执行 copy
        let mut arg_results = [String]List.new()
        let mut arg_index UInt = 0
        for arg_ref in args then {
            let arg = arg_ref
            let arg_type = arg.expr_type
            let result = self.generate_expression_ssa(arg)
            let is_lvalue = self.is_lvalue_expr(arg)
            let expected_type = if arg_index < func_params.count() then func_params.at(arg_index).val else arg_type
            let effective_arg_type = if self.is_unresolved_codegen_type(arg_type) and not self.is_unresolved_codegen_type(expected_type)
                then expected_type
                else arg_type
            let should_copy_lvalue = is_lvalue and not self.is_unresolved_codegen_type(effective_arg_type) and self.needs_drop(effective_arg_type)
            if should_copy_lvalue then {
                let c_type = self.c_type_name(effective_arg_type)
                let copy_result = self.next_temp_with_decl(c_type)
                self.append_copy_assignment(effective_arg_type, result, copy_result)
                arg_results.push(copy_result)
            } else {
                arg_results.push(result)
            }
            arg_index += 1
        }

        let return_c_type = self.c_type_name(return_type)

        // 构建无捕获函数指针类型：ReturnType (*)(Args...)
        let mut no_capture_param_types = [String]List.new()
        for param_type_ref in func_params then {
            no_capture_param_types.push(self.c_type_name(param_type_ref.val))
        }
        let no_capture_params_str = if no_capture_param_types.is_empty() then "void" else no_capture_param_types.join_to_string(", ")
        let no_capture_fn_ptr_type = "\(return_c_type) (*)(\(no_capture_params_str))"

        // 构建有捕获函数指针类型：ReturnType (*)(void*, Args...)
        let mut with_capture_param_types = [String]List.new()
        with_capture_param_types.push("void*")
        for param_type_ref in func_params then {
            with_capture_param_types.push(self.c_type_name(param_type_ref.val))
        }
        let with_capture_params_str = with_capture_param_types.join_to_string(", ")
        let with_capture_fn_ptr_type = "\(return_c_type) (*)(\(with_capture_params_str))"

        // 构建参数字符串
        let args_str = arg_results.join_to_string(", ")
        let args_with_env_str = if arg_results.is_empty() then "\(closure_var).env" else "\(closure_var).env, \(args_str)"
        // 生成条件调用
        if self.type_is_void_or_never(return_type) then {
            self.add_indent()
            self.buffer.push_string("if (\(closure_var).env == NULL) {\n")
            self.with_indent(() -> {
                self.add_indent()
                self.buffer.push_string("((\(no_capture_fn_ptr_type))(\(closure_var).fn))(\(args_str));\n")
            })
            self.add_indent()
            self.buffer.push_string("} else {\n")
            self.with_indent(() -> {
                self.add_indent()
                self.buffer.push_string("((\(with_capture_fn_ptr_type))(\(closure_var).fn))(\(args_with_env_str));\n")
            })
            self.add_indent()
            self.buffer.push_string("}\n")
            return ""
        } else {
            let result = self.next_temp_with_decl(return_c_type)
            self.add_indent()
            self.buffer.push_string("if (\(closure_var).env == NULL) {\n")
            self.with_indent(() -> {
                self.add_indent()
                self.buffer.push_string("\(result) = ((\(no_capture_fn_ptr_type))(\(closure_var).fn))(\(args_str));\n")
            })
            self.add_indent()
            self.buffer.push_string("} else {\n")
            self.with_indent(() -> {
                self.add_indent()
                self.buffer.push_string("\(result) = ((\(with_capture_fn_ptr_type))(\(closure_var).fn))(\(args_with_env_str));\n")
            })
            self.add_indent()
            self.buffer.push_string("}\n")
            return result
        }

    }

    // ── SubscriptExpr 生成 ────────────────────────────────────────────────────

    /// 生成下标表达式的 C 代码
    ///
    /// 将 base[args] 转换为 base.subscript(args) 方法调用。
    ///
    /// Requirements: 5.23
    public generate_subscript_call(self ref, base TypedExpr ref, args [TypedExpr ref]List, method Symbol ref, result_type Type) String = {
        let effective_result_type = when result_type in {
            .Unknown() then method.symbol_type,
            _ then result_type,
        }
        return self.generate_receiver_method_call(base, base.expr_type, method, args, effective_result_type)
    }

    // ── StaticMethodCall 生成 ─────────────────────────────────────────────────

    /// 生成静态方法调用的 C 代码
    ///
    /// Requirements: 5.31
}