// codegen_expressions_calls.koral - 函数调用代码生成
//
// 实现 CodeGen 的各种函数调用生成方法：
// - generate_call：主调用入口
// - generate_type_construction：类型构造函数调用
// - generate_function_call：普通函数调用
// - generate_closure_call：闭包调用
// - generate_subscript_call：下标调用
//
// Requirements: 5.16, 5.19, 5.20

given CodeGen {
    private direct_construction_target_type(self mut ref, callee TypedExpr ref, result_type Type) [Type]Option = {
        if not callee.expr_kind is .GenericInstantiation(_, _) then {
            return [Type]Option.None()
        }
        let ctor_type = when result_type in {
            .Unknown() then callee.expr_type,
            _ then result_type,
        }
        return when ctor_type in {
            .StructureType(_) then [Type]Option.Some(ctor_type),
            .GenericStruct(_, _) then [Type]Option.Some(ctor_type),
            .EnumType(_) then [Type]Option.Some(ctor_type),
            .GenericEnum(_, _) then [Type]Option.Some(ctor_type),
            _ then [Type]Option.None(),
        }
    }

    private inferred_variable_call_result_type(self, symbol Symbol ref, result_type Type) Type = {
        return when result_type in {
            .Unknown() then {
                yield when symbol.symbol_type in {
                    .FunctionType(_, return_type_ref) then return_type_ref.val,
                    _ then {
                        yield when self.context.get_signature(symbol.def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then result_type,
                        }
                    },
                }
            },
            .VoidType() then {
                let sig_ret = when self.context.get_signature(symbol.def_id) in {
                    .Some(sig) then sig.return_type,
                    .None() then result_type,
                }
                yield when sig_ret in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then sig_ret,
                }
            },
            _ then result_type,
        }
    }

    private variable_type_symbol_ctor_type(self, symbol Symbol ref, result_type Type) Type = {
        return when result_type in {
            .Unknown() then {
                let ctor_module_path = self.context.get_module_path(symbol.def_id) or else [String]List.new()
                yield when self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path) in {
                    .Some(t) then t,
                    .None() then {
                        yield when self.lookup_struct_type_by_name(symbol.name) in {
                            .Some(t) then t,
                            .None() then result_type,
                        }
                    },
                }
            },
            _ then result_type,
        }
    }

    private variable_function_ctor_type(self, symbol Symbol ref, inferred_result_type Type, result_type Type) [Type]Option = {
        return when result_type in {
            .Unknown() then {
                yield when inferred_result_type in {
                    .StructureType(_) then [Type]Option.Some(inferred_result_type),
                    .GenericStruct(_, _) then [Type]Option.Some(inferred_result_type),
                    _ then {
                        let ctor_module_path = self.context.get_module_path(symbol.def_id) or else [String]List.new()
                        let type_opt = self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path)
                        yield when type_opt in {
                            .Some(t) then [Type]Option.Some(t),
                            .None() then self.lookup_struct_type_by_name(symbol.name),
                        }
                    },
                }
            },
            .StructureType(_) then {
                yield if self.static_target_matches_name(result_type, symbol.name) then [Type]Option.Some(result_type) else [Type]Option.None()
            },
            .GenericStruct(template_name, _) then {
                yield if symbol.name == template_name then [Type]Option.Some(result_type) else [Type]Option.None()
            },
            .EnumType(_) then {
                yield if self.static_target_matches_name(result_type, symbol.name) then [Type]Option.Some(result_type) else [Type]Option.None()
            },
            .GenericEnum(template_name, _) then {
                yield if symbol.name == template_name then [Type]Option.Some(result_type) else [Type]Option.None()
            },
            _ then [Type]Option.None(),
        }
    }

    private effective_variable_call_result_type(self, inferred_result_type Type, result_type Type) Type = {
        if self.type_contains_generic(result_type) and not self.type_contains_generic(inferred_result_type) then {
            return inferred_result_type
        }
        return when result_type in {
            .Unknown() then inferred_result_type,
            .VoidType() then {
                yield when inferred_result_type in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then inferred_result_type,
                }
            },
            _ then result_type,
        }
    }

    private try_generate_variable_call(self mut ref, callee TypedExpr ref, symbol Symbol ref, args [TypedExpr ref]List, result_type Type) [String]Option = {
        let inferred_result_type = self.inferred_variable_call_result_type(symbol, result_type)

        when symbol.kind in {
            .TypeSymbol() then {
                let ctor_type = self.variable_type_symbol_ctor_type(symbol, result_type)
                return [String]Option.Some(self.generate_type_construction(symbol, args, ctor_type))
            },
            .Function() then {
                if self.variable_function_ctor_type(symbol, inferred_result_type, result_type) is .Some(struct_type) then {
                    return [String]Option.Some(self.generate_type_construction(symbol, args, struct_type))
                }
            },
            _ then {},
        }

        when symbol.kind in {
            .Variable(_) then {
                when symbol.symbol_type in {
                    .FunctionType(func_params, return_type_ref) then {
                        let closure_var = self.generate_expression_ssa(callee)
                        return [String]Option.Some(self.generate_closure_call(closure_var, func_params, return_type_ref.val, args))
                    },
                    _ then {},
                }
            },
            _ then {},
        }

        let effective_call_result_type = self.effective_variable_call_result_type(inferred_result_type, result_type)
        return [String]Option.Some(self.generate_function_call(symbol, args, effective_call_result_type))
    }

    private try_generate_indirect_closure_call(self mut ref, callee TypedExpr ref, args [TypedExpr ref]List) [String]Option = {
        return when callee.expr_type in {
            .FunctionType(func_params, return_type_ref) then {
                let closure_result = self.generate_expression_ssa(callee)
                yield [String]Option.Some(self.generate_closure_call(closure_result, func_params, return_type_ref.val, args))
            },
            _ then [String]Option.None(),
        }
    }

    private member_path_receiver_expr(self, base_ref TypedExpr ref, path [String]List) TypedExpr ref = {
        if path.count() == 1 then {
            return base_ref
        }

        let mut receiver_path = [String]List.new()
        let mut receiver_type = base_ref.expr_type
        let mut idx UInt = 0
        while idx + 1 < path.count() then {
            let segment = path[idx]
            receiver_path.push(segment)
            receiver_type = self.lookup_field_type(receiver_type, segment)
            idx += 1
        }
        return box(TypedExpr(box(TypedExprKind.MemberPath(base_ref, receiver_path)), receiver_type))
    }

    private member_path_enum_ctor_type(self, base TypedExpr ref, result_type Type) [Type]Option = {
        let is_generic_union_base = when base.expr_kind in {
            .GenericInstantiation(_, _) then {
                yield when base.expr_type in {
                    .GenericEnum(_, _) then true,
                    .EnumType(_) then true,
                    _ then false,
                }
            },
            _ then false,
        }
        if not is_generic_union_base then {
            return [Type]Option.None()
        }
        let enum_type = when result_type in {
            .Unknown() then base.expr_type,
            _ then result_type,
        }
        return [Type]Option.Some(enum_type)
    }

    private member_path_static_receiver_type(self, base TypedExpr ref) [Type]Option = {
        return when base.expr_kind in {
            .GenericInstantiation(_, _) then [Type]Option.Some(base.expr_type),
            .Variable(symbol) then when symbol.kind in {
                .TypeSymbol() then {
                    let inferred_type = when base.expr_type in {
                        .Unknown() then {
                            yield when self.monomorphized_token_to_type(symbol.name) in {
                                .Some(t) then t,
                                .None() then {
                                    let module_path = self.context.get_module_path(symbol.def_id) or else [String]List.new()
                                    yield when self.lookup_struct_type_by_name_and_module(symbol.name, module_path) in {
                                        .Some(t) then t,
                                        .None() then {
                                            yield when self.lookup_struct_type_by_name(symbol.name) in {
                                                .Some(t) then t,
                                                .None() then base.expr_type,
                                            }
                                        },
                                    }
                                },
                            }
                        },
                        _ then base.expr_type,
                    }
                    yield [Type]Option.Some(inferred_type)
                },
                _ then [Type]Option.None(),
            },
            _ then [Type]Option.None(),
        }
    }

    private trait_method_member_path_result_type(self, trait_name String, method_name String, result_type Type) Type = {
        let mut trait_ret_type = Type.Unknown()
        let members = self.get_ordered_trait_members(trait_name)
        for m in members then {
            if m.name == method_name then {
                trait_ret_type = m.return_type
            }
        }
        when trait_ret_type in {
            .Unknown() then {
                when self.program.lookup_static_method(trait_name, method_name) in {
                    .Some(def_id) then {
                        when self.context.get_signature(def_id) in {
                            .Some(sig) then { trait_ret_type = sig.return_type },
                            .None() then {},
                        }
                    },
                    .None() then {},
                }
            },
            _ then {},
        }
        return self.requested_or_symbol_result_type(result_type, trait_ret_type)
    }

    private try_generate_member_path_call(self mut ref, callee TypedExpr ref, base_ref TypedExpr ref, path [String]List, args [TypedExpr ref]List, result_type Type) [String]Option = {
        if path.is_empty() then {
            return [String]Option.Some(self.generate_expression_ssa(callee))
        }

        let method_name = path[path.count() - 1]
        let base = self.member_path_receiver_expr(base_ref, path)

        if self.member_path_enum_ctor_type(base, result_type) is .Some(enum_type) then {
            return [String]Option.Some(self.generate_enum_constructor(enum_type, method_name, args))
        }

        if self.member_path_static_receiver_type(base) is .Some(static_receiver_type) then {
            let concrete_static_receiver_type = self.concretize_codegen_type(static_receiver_type)
            let method_hint_opt = self.lookup_receiver_method(concrete_static_receiver_type, method_name)
            let static_result_type = when method_hint_opt in {
                .Some(method_symbol) then self.requested_or_symbol_result_type(result_type, method_symbol.symbol_type),
                .None() then result_type,
            }
            let method_symbol = when method_hint_opt in {
                .Some(symbol) then symbol,
                .None() then self.make_codegen_method_symbol(method_name, static_result_type),
            }
            return [String]Option.Some(self.generate_static_method_call(concrete_static_receiver_type, box(method_symbol), args, static_result_type))
        }

        let effective_base_type = self.concretize_codegen_type(base.expr_type)
        when effective_base_type in {
            .TraitObject(trait_name, trait_type_args) then {
                let effective_trait_result = self.trait_method_member_path_result_type(trait_name, method_name, result_type)
                return [String]Option.Some(self.generate_trait_method_call_typed(base, Type.TraitObject(trait_name, trait_type_args), method_name, args, effective_trait_result))
            },
            _ then {},
        }

        let method_hint_opt = self.lookup_receiver_method(effective_base_type, method_name)
        if method_hint_opt is .Some(method_symbol) then {
            let effective_result_type = self.requested_or_symbol_result_type(result_type, method_symbol.symbol_type)
            return [String]Option.Some(self.generate_receiver_method_call(base, effective_base_type, box(method_symbol), args, effective_result_type))
        }

        return [String]Option.None()
    }

    public generate_call(self mut ref, callee TypedExpr ref, args [TypedExpr ref]List, result_type Type) String = {
        if self.direct_construction_target_type(callee, result_type) is .Some(ctor_type) then {
            return self.generate_type_construction_from_args(args, ctor_type)
        }

        when callee.expr_kind in {
            .MethodReference(base, receiver_type, method, dispatch_callsite) then {
                return self.generate_generic_method_call(base, receiver_type, method, args, result_type, dispatch_callsite)
            },
            .TraitMethodPlaceholder(base, trait_type, method, dispatch_callsite) then {
                return self.generate_qualified_method_call_typed(base, trait_type, method, args, result_type, dispatch_callsite)
            },
            _ then {},
        }

        when callee.expr_kind in {
            .Variable(symbol) then {
                return self.try_generate_variable_call(callee, symbol, args, result_type) or else self.generate_expression_ssa(callee)
            },
            _ then {},
        }

        if self.try_generate_indirect_closure_call(callee, args) is .Some(closure_call) then {
            return closure_call
        }

        when callee.expr_kind in {
            .MemberPath(base_ref, path) then {
                if self.try_generate_member_path_call(callee, base_ref, path, args, result_type) is .Some(member_call) then {
                    return member_call
                }
            },
            _ then {},
        }

        return self.generate_expression_ssa(callee)
    }

    /// TypeSymbol 调用生成 (struct T){ arg1, arg2, ... } 的 C 代码
    public generate_type_construction(self mut ref, symbol Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        return self.generate_type_construction_from_args(args, result_type)
    }

    private generate_type_construction_from_args(self mut ref, args [TypedExpr ref]List, result_type Type) String = {
        let mut args_str = String.new()
        let mut first = true
        for arg_ref in args then {
            let arg = arg_ref
            let arg_type = arg.expr_type
            let result = when arg.expr_kind in {
                .Variable(sym) then {
                    yield self.generate_expression_ssa(arg)
                },
                _ then self.generate_expression_ssa(arg),
            }
            let is_lvalue = self.is_lvalue_expr(arg)
            let final_arg = self.transfer_owned_rvalue_cleanup(result, self.copy_owned_value_if_lvalue(is_lvalue, result, arg_type), arg_type, is_lvalue)
            if not first then {
                args_str.push_string(", ")
            }
            args_str.push_string(final_arg)
            first = false
        }

        let c_type = self.c_type_name(result_type)
        let result = self.next_temp_with_init(c_type, "(\(c_type)){ \(args_str) }")
        return result
    }

    /// 生成普通函数调用代码
    ///
    /// Requirements: 5.16
    public generate_function_call(self mut ref, symbol Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        // Prefer struct construction when a callable symbol name resolves to a type
        // in the same module context (or globally), even if the symbol kind degraded
        // to Function during earlier lowering.
        let ctor_module_path = self.context.get_module_path(symbol.def_id) or else [String]List.new()
        let ctor_type_opt = when self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path) in {
            .Some(t) then [Type]Option.Some(t),
            .None() then self.lookup_struct_type_by_name(symbol.name),
        }
        if ctor_type_opt is .Some(ctor_type) then {
            let should_construct = when result_type in {
                .Unknown() then false,
                .StructureType(_) then self.static_target_matches_name(result_type, symbol.name) or self.codegen_types_equal(result_type, ctor_type),
                .GenericStruct(_, _) then true,
                .EnumType(_) then self.static_target_matches_name(result_type, symbol.name) or self.codegen_types_equal(result_type, ctor_type),
                .GenericEnum(_, _) then true,
                _ then false,
            }
            if should_construct then {
                let effective_ctor_type = when result_type in {
                    .Unknown() then ctor_type,
                    .StructureType(_) then result_type,
                    .GenericStruct(_, _) then result_type,
                    _ then ctor_type,
                }
                return self.generate_type_construction(symbol, args, effective_ctor_type)
            }
        }

        if args.count() > 0 and symbol.def_id.id == 0 then {
            let raw_symbol_name = self.context.get_name(symbol.def_id) or else symbol.name
            let receiver_type = self.concretize_codegen_type(args[(UInt)0].val.expr_type)
            let lookup_receiver_type = when receiver_type in {
                .ReferenceType(inner) then self.concretize_codegen_type(inner.val),
                .MutableReferenceType(inner) then self.concretize_codegen_type(inner.val),
                .WeakReferenceType(inner) then self.concretize_codegen_type(inner.val),
                .MutableWeakReferenceType(inner) then self.concretize_codegen_type(inner.val),
                _ then receiver_type,
            }
            let method_name = raw_symbol_name
            let mut remaining_args = [TypedExpr ref]List.new()
            let mut arg_index UInt = (UInt)1
            while arg_index < args.count() then {
                remaining_args.push(args[arg_index])
                arg_index += (UInt)1
            }

            when self.lookup_receiver_method(lookup_receiver_type, method_name) in {
                .Some(concrete_method) then {
                    let effective_receiver_result_type = self.preferred_receiver_method_result_type(result_type, concrete_method.symbol_type)
                    return self.generate_receiver_method_call(args[(UInt)0], lookup_receiver_type, box(concrete_method), remaining_args, effective_receiver_result_type)
                },
                .None() then {},
            }
        }

        let raw_signature_opt = when self.context.get_signature(symbol.def_id) in {
            .Some(sig) then [FunctionSignature]Option.Some(sig),
            .None() then [FunctionSignature]Option.None(),
        }
        let resolved_func_name = self.callable_c_name(symbol)
        let mut concrete_receiver_type_opt = [Type]Option.None()
        if args.count() > 0 then {
            let has_method_owner = self.method_owner_type(symbol.def_id) is .Some(_)
            let has_lowered_method = self.program.has_lowered_method_info(symbol.def_id)
            let signature_omits_self = when raw_signature_opt in {
                .Some(sig) then sig.parameters.count() < args.count(),
                .None() then false,
            }
            if has_method_owner or has_lowered_method or signature_omits_self then {
                concrete_receiver_type_opt = [Type]Option.Some(self.concretize_codegen_type(args[(UInt)0].val.expr_type))
            }
        }
        let signature_opt = when raw_signature_opt in {
            .Some(sig) then {
                yield when concrete_receiver_type_opt in {
                    .Some(concrete_receiver_type) then [FunctionSignature]Option.Some(self.bind_method_signature(symbol.def_id, concrete_receiver_type, sig)),
                    .None() then [FunctionSignature]Option.Some(sig),
                }
            },
            .None() then [FunctionSignature]Option.None(),
        }
        let mut effective_result_type = when result_type in {
            .Unknown() then {
                yield when signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then result_type,
                }
            },
            .VoidType() then {
                let sig_ret = when signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then result_type,
                }
                yield when sig_ret in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then sig_ret,
                }
            },
            _ then result_type,
        }

        // 回退：当 result_type 仍为 Unknown 时，尝试把函数调用当作结构体构造
        // 这能覆盖某些单态化后丢失 TypeSymbol 的构造调用（如 DequeIterator(...)）。
        when effective_result_type in {
            .Unknown() then {
                let ctor_module_path = self.context.get_module_path(symbol.def_id) or else [String]List.new()
                let struct_type_opt = when self.lookup_struct_type_by_name_and_module(symbol.name, ctor_module_path) in {
                    .Some(t) then [Type]Option.Some(t),
                    .None() then self.lookup_struct_type_by_name(symbol.name),
                }
                when struct_type_opt in {
                    .Some(struct_type) then {
                        return self.generate_type_construction(symbol, args, struct_type)
                    },
                    .None() then {},
                }
            },
            _ then {},
        }

        let mut prepared_args = [String]List.new()
        let mut arg_index = (UInt)0
        for arg_ref in args then {
            let arg = arg_ref
            let mut prepared_arg = [String]Option.None()
            when concrete_receiver_type_opt in {
                .Some(concrete_receiver_type) then {
                    if arg_index == 0 then {
                        let remaining_arg_count = if args.count() > 0 then args.count() - (UInt)1 else (UInt)0
                        prepared_arg = [String]Option.Some(self.prepare_receiver_method_argument_expr(arg, concrete_receiver_type, symbol, remaining_arg_count))
                    }
                },
                .None() then {},
            }
            if prepared_arg is .None() then {
                let typed_expected_type_opt = when signature_opt in {
                    .Some(sig) then {
                        yield if arg_index < sig.parameters.count() then [Type]Option.Some(sig.parameters[arg_index].param_type) else [Type]Option.None()
                    },
                    .None() then [Type]Option.None(),
                }
                prepared_arg = [String]Option.Some(self.prepare_call_argument(arg, typed_expected_type_opt))
            }
            prepared_args.push(prepared_arg.unwrap())
            arg_index = arg_index + (UInt)1
        }

        let mut result = ""
        if self.type_is_void_or_never(effective_result_type) then {
            self.buffer.push_string(self.indent)
            self.buffer.push_string(resolved_func_name)
            self.buffer.push_rune('(')
        } else {
            let c_type = self.c_type_name(effective_result_type)
            result = self.next_temp_with_decl(c_type)
            self.buffer.push_string(self.indent)
            self.buffer.push_string(result)
            self.buffer.push_string(" = ")
            self.buffer.push_string(resolved_func_name)
            self.buffer.push_rune('(')
        }

        let mut first = true
        for prepared_arg in prepared_args then {
            if not first then {
                self.buffer.push_string(", ")
            }
            self.buffer.push_string(prepared_arg)
            first = false
        }
        self.buffer.push_string(");\n")
        return result
    }


    /// 生成闭包调用代码
    ///
    /// 根据 env == NULL 生成条件分支：
    /// - env == NULL：直接调用函数指针（无捕获）
    /// - env != NULL：将 env 作为第一个参数传入（有捕获）
    ///
    /// Requirements: 5.16
    public generate_closure_call(self mut ref, closure_var String, func_params [Type ref]List, return_type Type, args [TypedExpr ref]List) String = {
        // 闭包调用与普通函数调用共享同一套参数 lowering 逻辑。
        let mut args_str = String.new()
        let mut first_arg = true
        let mut arg_index UInt = 0
        for arg_ref in args then {
            let arg = arg_ref
            let expected_type_opt = if arg_index < func_params.count() then [Type]Option.Some(func_params[arg_index].val) else [Type]Option.None()
            let prepared_arg = self.prepare_call_argument(arg, expected_type_opt)
            if not first_arg then {
                args_str.push_string(", ")
            }
            args_str.push_string(prepared_arg)
            first_arg = false
            arg_index += 1
        }

        let return_c_type = self.c_type_name(return_type)

        // 构建无捕获函数指针类型：ReturnType (*)(Args...)
        let mut no_capture_params_str = String.new()
        let mut first_param = true
        for param_type_ref in func_params then {
            if not first_param then {
                no_capture_params_str.push_string(", ")
            }
            no_capture_params_str.push_string(self.c_type_name(param_type_ref.val))
            first_param = false
        }
        if first_param then {
            no_capture_params_str.push_string("void")
        }
        let no_capture_fn_ptr_type = "\(return_c_type) (*)(\(no_capture_params_str))"

        // 构建有捕获函数指针类型：ReturnType (*)(void*, Args...)
        let mut with_capture_params_str = String.new()
        with_capture_params_str.push_string("void*")
        for param_type_ref in func_params then {
            with_capture_params_str.push_string(", ")
            with_capture_params_str.push_string(self.c_type_name(param_type_ref.val))
        }
        let with_capture_fn_ptr_type = "\(return_c_type) (*)(\(with_capture_params_str))"

        // 构建参数字符串
        let final_args_str = args_str
        let args_with_env_str = if first_arg then "\(closure_var).env" else "\(closure_var).env, \(args_str)"
        // 生成条件调用
        if self.type_is_void_or_never(return_type) then {
            self.push_indented_if_open("\(closure_var).env == NULL")
            self.with_indent(() -> {
                self.push_indented_string("((\(no_capture_fn_ptr_type))(\(closure_var).fn))(\(final_args_str));\n")
            })
            self.push_indented_string("} else {\n")
            self.with_indent(() -> {
                self.push_indented_string("((\(with_capture_fn_ptr_type))(\(closure_var).fn))(\(args_with_env_str));\n")
            })
            self.push_indented_string("}\n")
            return ""
        } else {
        let result = self.next_temp_with_decl(return_c_type)
            self.push_indented_if_open("\(closure_var).env == NULL")
            self.with_indent(() -> {
                self.push_indented_string("\(result) = ((\(no_capture_fn_ptr_type))(\(closure_var).fn))(\(final_args_str));\n")
            })
            self.push_indented_string("} else {\n")
            self.with_indent(() -> {
                self.push_indented_string("\(result) = ((\(with_capture_fn_ptr_type))(\(closure_var).fn))(\(args_with_env_str));\n")
            })
            self.push_indented_string("}\n")
            return result
        }

    }

    // ── SubscriptExpr 生成 ────────────────────────────────────────────────────

    /// 生成下标表达式的 C 代码
    ///
    /// 将 base[args] 转换为 base.subscript(args) 方法调用。
    ///
    /// Requirements: 5.23
    public generate_subscript_call(self mut ref, base TypedExpr ref, args [TypedExpr ref]List, method Symbol ref, result_type Type) String = {
        let effective_result_type = when result_type in {
            .Unknown() then method.symbol_type,
            _ then result_type,
        }
        return self.generate_receiver_method_call(base, base.expr_type, method, args, effective_result_type)
    }

    // ── StaticMethodCall 生成 ─────────────────────────────────────────────────

    /// 生成静态方法调用的 C 代码
    ///
    /// Requirements: 5.31
}
