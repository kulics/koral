// codegen_expressions_dispatch.koral - 方法分发代码生成
//
// 实现 CodeGen 的静态方法调用、泛型方法调用、限定方法调用、
given CodeGen {
    private requested_or_symbol_result_type(self, requested_result_type Type, symbol_type Type) Type = {
        return when requested_result_type in {
            .Unknown() then symbol_type,
            .VoidType() then {
                yield when symbol_type in {
                    .VoidType() then requested_result_type,
                    .NeverType() then requested_result_type,
                    .Unknown() then requested_result_type,
                    _ then symbol_type,
                }
            },
            _ then requested_result_type,
        }
    }

    private preferred_receiver_method_result_type(self, requested_result_type Type, symbol_type Type) Type = {
        if self.type_contains_generic(requested_result_type) and not self.type_contains_generic(symbol_type) then {
            return symbol_type
        }
        return self.requested_or_symbol_result_type(requested_result_type, symbol_type)
    }

    private direct_callable_symbol(self, method Symbol ref) [Symbol]Option = {
        if method.def_id.id == 0 then {
            return [Symbol]Option.None()
        }
        return when self.c_identifier_opt(method.def_id) in {
            .Some(c_name) then [Symbol]Option.Some(Symbol(method.def_id, c_name, method.symbol_type, method.kind)),
            .None() then [Symbol]Option.None(),
        }
    }

    private concrete_callable_symbol(self, def_id DefId, fallback_result_type Type) [Symbol]Option = {
        return when self.c_identifier_opt(def_id) in {
            .Some(c_name) then {
                let result_type = when self.def_id_map.get_signature(def_id) in {
                    .Some(sig) then self.requested_or_symbol_result_type(fallback_result_type, sig.return_type),
                    .None() then fallback_result_type,
                }
                yield [Symbol]Option.Some(Symbol(def_id, c_name, result_type, SymbolKind.Function()))
            },
            .None() then [Symbol]Option.None(),
        }
    }

    private bound_concrete_method_symbol(self, def_id DefId, receiver_type Type, fallback_result_type Type) [Symbol]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let bound_result_type = when self.def_id_map.get_signature(def_id) in {
            .Some(sig) then self.bind_method_signature(def_id, concrete_receiver_type, sig).return_type,
            .None() then fallback_result_type,
        }
        return self.concrete_callable_symbol(def_id, bound_result_type)
    }

    private lookup_receiver_method_def_id(self, receiver_type Type, method_name String) [DefId]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        return when self.program.lookup_receiver_method(receiver_key, method_name) in {
            .Some(def_id) then [DefId]Option.Some(def_id),
            .None() then when concrete_receiver_type in {
                .ReferenceType(inner_ref) then self.lookup_receiver_method_def_id(inner_ref.val, method_name),
                _ then [DefId]Option.None(),
            },
        }
    }

    private lookup_trait_method_def_id(self, concrete_type Type, trait_name String, method_name String) [DefId]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(concrete_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        return when self.program.lookup_trait_method(receiver_key, trait_name, method_name) in {
            .Some(def_id) then [DefId]Option.Some(def_id),
            .None() then when self.program.traits.get(trait_name) in {
                .Some(trait_info) then {
                    let mut found = [DefId]Option.None()
                    for parent_trait_name in trait_info.parent_traits then {
                        found = self.lookup_trait_method_def_id(concrete_receiver_type, parent_trait_name, method_name)
                        if found is .Some(_) then { break }
                    }
                    yield found
                },
                .None() then [DefId]Option.None(),
            },
        }
    }

    private lookup_static_method_symbol(self, receiver_type Type, method_name String) [Symbol]Option = {
        return when self.lookup_receiver_method_def_id(receiver_type, method_name) in {
            .Some(def_id) then self.bound_concrete_method_symbol(def_id, receiver_type, Type.Unknown()),
            .None() then [Symbol]Option.None(),
        }
    }

    private try_generate_receiver_dispatch_call(self ref, base TypedExpr ref, base_type Type, args [TypedExpr ref]List, requested_result_type Type, dispatch_callsite [DefId]Option) [String]Option = {
        return when dispatch_callsite in {
            .Some(callsite_def_id) then when self.program.lookup_receiver_call_resolution(callsite_def_id) in {
                .Some(resolution) then {
                    yield when self.bound_concrete_method_symbol(resolution.method_def_id, base_type, requested_result_type) in {
                        .Some(dispatch_symbol) then {
                            let dispatch_result_type = self.requested_or_symbol_result_type(requested_result_type, dispatch_symbol.symbol_type)
                            yield [String]Option.Some(self.generate_receiver_method_call(base, base_type, dispatch_symbol, args, dispatch_result_type))
                        },
                        .None() then [String]Option.None(),
                    }
                },
                .None() then [String]Option.None(),
            },
            .None() then [String]Option.None(),
        }
    }

    private lookup_receiver_method_via_metadata(self, receiver_type Type, method_name String) [Symbol]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        when self.lookup_receiver_method_def_id(concrete_receiver_type, method_name) in {
            .Some(def_id) then {
                return self.bound_concrete_method_symbol(def_id, concrete_receiver_type, Type.Unknown())
            },
            .None() then {},
        }
        return [Symbol]Option.None()
    }


    public generate_static_method_call(self ref, receiver_type Type, method Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let resolved_symbol_opt = if method.def_id.id > 0 then {
            yield self.bound_concrete_method_symbol(method.def_id, concrete_receiver_type, method.symbol_type)
        } else {
            yield self.lookup_static_method_symbol(concrete_receiver_type, method.name)
        }
        if resolved_symbol_opt is .None() then {
            when concrete_receiver_type in {
                .EnumType(_) then {
                    return self.generate_enum_constructor(concrete_receiver_type, method.name, args)
                },
                .GenericEnum(_, _) then {
                    return self.generate_enum_constructor(concrete_receiver_type, method.name, args)
                },
                _ then {},
            }
        }
        let resolved_symbol = resolved_symbol_opt or else method.val
        let direct_signature_opt = when self.def_id_map.get_signature(resolved_symbol.def_id) in {
            .Some(sig) then [FunctionSignature]Option.Some(self.bind_method_signature(resolved_symbol.def_id, concrete_receiver_type, sig)),
            .None() then [FunctionSignature]Option.None(),
        }
        let debug_static_name = if resolved_symbol.def_id.id > 0 then {
            yield self.qualified_name(box(resolved_symbol))
        } else {
            let receiver_c_name = self.emitted_type_c_name_fallback(concrete_receiver_type)
            yield self.compose_method_c_name(receiver_c_name, resolved_symbol.name)
        }

        let mut effective_result_type = when result_type in {
            .Unknown() then {
                yield when direct_signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then resolved_symbol.symbol_type,
                }
            },
            .VoidType() then {
                let signature_return = when direct_signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then resolved_symbol.symbol_type,
                }
                yield when signature_return in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then signature_return,
                }
            },
            _ then result_type,
        }

        let call_signature_opt = when direct_signature_opt in {
            .Some(sig) then [FunctionSignature]Option.Some(sig),
            .None() then when self.def_id_map.get_signature(resolved_symbol.def_id) in {
                .Some(sig) then [FunctionSignature]Option.Some(sig),
                .None() then [FunctionSignature]Option.None(),
            },
        }
        let mut param_results = [String]List.new()
        let mut arg_index = (UInt)0
        for arg_ref in args then {
            let arg = arg_ref
            let result = self.generate_expression_ssa(arg)
            let expected_type_opt = when call_signature_opt in {
                .Some(sig) then {
                    yield if arg_index < sig.param_types.count() then [Type]Option.Some(sig.param_types.at(arg_index)) else [Type]Option.None()
                },
                .None() then [Type]Option.None(),
            }
            let is_lvalue = self.is_lvalue_expr(arg)
            let mut arg_value = result
            arg_value = self.copy_owned_value_if_lvalue(is_lvalue, result, arg.expr_type)

            if expected_type_opt is .Some(expected_type) then {
                arg_value = self.adapt_call_argument_to_expected_type(arg, arg_value, expected_type, is_lvalue)
            }

            param_results.push(arg_value)
            arg_index = arg_index + (UInt)1
        }
        let args_str = param_results.join_to_string(", ")
        if self.type_is_void_or_never(effective_result_type) then {
            self.add_indent()
            self.buffer.push_string("\(debug_static_name)(\(args_str));\n")
            return ""
        } else {
            let c_type = self.c_type_name(effective_result_type)
            let result = self.next_temp_with_init(c_type, "\(debug_static_name)(\(args_str))")
            return result
        }
    }

    // ── GenericMethodCall 生成 ────────────────────────────────────────────────

    /// 生成泛型方法调用的 C 代码
    ///
    /// base.method_name(args) → 查找方法符号，生成函数调用
    ///
    /// Requirements: 5.32
    public generate_generic_method_call(self ref, base TypedExpr ref, receiver_type Type, method Symbol ref, args [TypedExpr ref]List, result_type Type, dispatch_callsite [DefId]Option) String = {
        let base_expr_type = self.concretize_codegen_type(base.expr_type)
        let mut base_type = self.concretize_codegen_type(receiver_type)
        if self.type_contains_generic(receiver_type) and not self.type_contains_generic(base_expr_type) then {
            base_type = base_expr_type
        }
        let method_name = method.name
        let effective_result_type = self.requested_or_symbol_result_type(result_type, method.symbol_type)

        let base_declared_type = self.concretize_codegen_type(base.expr_type)
        when base_declared_type in {
            .TraitObject(trait_name) then {
                return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
            },
            _ then {},
        }

        let cast_trait_name_opt = when base.expr_kind in {
            .CastExpr(target_type, _) then when target_type in {
                .TraitObject(trait_name) then [String]Option.Some(trait_name),
                _ then [String]Option.None(),
            },
            _ then [String]Option.None(),
        }
        if cast_trait_name_opt is .Some(trait_name) then {
            return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
        }

        when base_type in {
            .TraitObject(trait_name) then {
                return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
            },
            _ then {},
        }

        if self.is_integer_type(base_type) then {
            let suffix = self.type_suffix(base_type)
            if method_name == "wrapping_neg" and args.count() == 0 then {
                let base_result = self.generate_expression_ssa(base)
                let c_type = self.c_type_name(base_type)
                let result = self.next_temp_with_init(c_type, "koral_wrapping_sub_\(suffix)(0, \(base_result))")
                return result
            }
            if args.count() == 1 then {
                let base_result = self.generate_expression_ssa(base)
                let arg_result = self.generate_expression_ssa(args.at((UInt)0))
                let runtime_name_opt = when method_name in {
                    "wrapping_add" then [String]Option.Some("koral_wrapping_add_\(suffix)"),
                    "wrapping_sub" then [String]Option.Some("koral_wrapping_sub_\(suffix)"),
                    "wrapping_mul" then [String]Option.Some("koral_wrapping_mul_\(suffix)"),
                    "wrapping_div" then [String]Option.Some("koral_wrapping_div_\(suffix)"),
                    "wrapping_rem" then [String]Option.Some("koral_wrapping_rem_\(suffix)"),
                    "wrapping_shl" then [String]Option.Some("koral_wrapping_shl_\(suffix)"),
                    "wrapping_shr" then [String]Option.Some("koral_wrapping_shr_\(suffix)"),
                    _ then [String]Option.None(),
                }
                if runtime_name_opt is .Some(runtime_name) then {
                    let c_type = self.c_type_name(base_type)
                    let result = self.next_temp_with_init(c_type, "\(runtime_name)(\(base_result), \(arg_result))")
                    return result
                }
            }
        }

        if self.try_generate_receiver_dispatch_call(base, base_type, args, result_type, dispatch_callsite) is .Some(dispatch_call) then {
            return dispatch_call
        }

        let mut method_opt = [Symbol]Option.None()
        method_opt = when self.direct_callable_symbol(method) in {
            .Some(symbol) then [Symbol]Option.Some(symbol),
            .None() then self.lookup_receiver_method(base_type, method_name),
        }
        if method_opt is .Some(method_symbol) then {
            let effective_result_type = self.preferred_receiver_method_result_type(result_type, method_symbol.symbol_type)
            return self.generate_receiver_method_call(base, base_type, method_symbol, args, effective_result_type)
        }

        if self.lookup_static_method_symbol(base_type, method_name) is .Some(static_symbol) then {
            let effective_static_result_type = self.requested_or_symbol_result_type(result_type, static_symbol.symbol_type)
            return self.generate_receiver_method_call(base, base_type, static_symbol, args, effective_static_result_type)
        }

        let member_type = self.lookup_field_type(base_type, method_name)
        when member_type in {
            .FunctionType(param_types, ret_ref) then {
                let closure_expr = box(TypedExpr(
                    box(TypedExprKind.MemberExpr(base, method_name)),
                    member_type,
                ))
                let closure_var = self.generate_expression_ssa(closure_expr)
                return self.generate_closure_call(closure_var, param_types, ret_ref.val, args)
            },
            _ then {},
        }

        return self.generate_expression_ssa(base)
    }

    // ── QualifiedMethodCall 生成 ──────────────────────────────────────────────

    /// 生成 trait 限定方法调用的 C 代码
    ///
    /// Requirements: 5.33
    private generate_trait_tool_argument(self ref, expr TypedExpr ref, expected_type Type) String = {
        return when expected_type in {
            .TraitObject(trait_name) then {
                yield when expr.expr_type in {
                    .TraitObject(_) then { yield self.generate_expression_ssa(expr) },
                    .ReferenceType(source_inner_ref) then {
                        yield when source_inner_ref.val in {
                            .TraitObject(_) then self.generate_cast_expr(expected_type, expr),
                            _ then self.generate_trait_object_conversion(expr, trait_name, expr.expr_type),
                        }
                    },
                    _ then {
                        let source_result = self.generate_expression_ssa(expr)
                        let concrete_type = expr.expr_type
                        let concrete_c_type = self.c_type_name(concrete_type)
                        let value_result = self.copy_expr_if_lvalue_owned(expr, source_result, concrete_type)
                        let stored_value = self.next_temp_with_init(concrete_c_type, value_result)
                        let trait_result = self.next_temp_with_decl("struct __koral_TraitRef")
                        let concrete_c_name = when self.concrete_type_c_name(concrete_type) in {
                            .Some(name) then name,
                            .None() then self.c_type_name(concrete_type),
                        }
                        let vtable_name = self.vtable_instance_name(trait_name, concrete_c_name)
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).ptr = (void*)&(\(stored_value));\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).control = NULL;\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).vtable = &\(vtable_name);\n")
                        yield trait_result
                    },
                }
            },
            _ then { yield self.generate_expression_ssa(expr) },
        }
    }

    public generate_qualified_method_call(self ref, base TypedExpr ref, trait_name String, method Symbol ref, args [TypedExpr ref]List, result_type Type, dispatch_callsite [DefId]Option) String = {
        let method_name = method.name
        let base_type = self.concretize_codegen_type(base.expr_type)
        let effective_result_type = self.requested_or_symbol_result_type(result_type, method.symbol_type)

        when base.expr_kind in {
            .Variable(sym) then {
                if sym.kind is .TypeSymbol() then {
                    if self.lookup_trait_method_def_id(base_type, trait_name, method_name) is .Some(actual_def_id) then {
                        let actual_symbol = self.bound_concrete_method_symbol(actual_def_id, base_type, effective_result_type) or else Symbol(actual_def_id, method_name, effective_result_type, SymbolKind.Function())
                        return self.generate_function_call(actual_symbol, args, actual_symbol.symbol_type)
                    }
                    return self.generate_static_method_call(base_type, method, args, effective_result_type)
                }
            },
            _ then {},
        }

        let base_is_trait_object = when base_type in {
            .TraitObject(_) then true,
            _ then false,
        }
        if self.try_generate_receiver_dispatch_call(base, base_type, args, result_type, dispatch_callsite) is .Some(dispatch_call) then {
            return dispatch_call
        }
        if not base_is_trait_object then {
            let mut all_args = [TypedExpr ref]List.new()
            let include_base_arg = when base.expr_kind in {
                .Variable(sym) then sym.kind is not .TypeSymbol(),
                _ then true,
            }
            if include_base_arg then {
                all_args.push(box(base))
            }
            for arg in args then {
                all_args.push(arg)
            }
            if include_base_arg then {
                if self.lookup_receiver_method(base_type, method_name) is .Some(concrete_method) then {
                    return self.generate_function_call(concrete_method, all_args, effective_result_type)
                }
                if self.lookup_trait_method_def_id(base_type, trait_name, method_name) is .Some(actual_def_id) then {
                    let actual_symbol = self.bound_concrete_method_symbol(actual_def_id, base_type, effective_result_type) or else Symbol(actual_def_id, method_name, effective_result_type, SymbolKind.Function())
                    return self.generate_function_call(actual_symbol, all_args, actual_symbol.symbol_type)
                }
            }
            let direct_symbol = when self.direct_callable_symbol(method) in {
                .Some(symbol) then symbol,
                .None() then method.val,
            }
            return self.generate_function_call(direct_symbol, all_args, effective_result_type)
        }

        return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
    }
    // ── 方法查找辅助方法 ──────────────────────────────────────────────────────

    /// 通过接收者类型和方法名查找方法符号
    ///
    /// 优先使用单态化阶段导出的 metadata 表。
    lookup_receiver_method(self, receiver_type Type, method_name String) [Symbol]Option = {
        let base_type = receiver_type
        if self.lookup_receiver_method_via_metadata(base_type, method_name) is .Some(symbol) then {
            return [Symbol]Option.Some(symbol)
        }
        return when receiver_type in {
            .ReferenceType(inner_ref) then self.lookup_receiver_method(inner_ref.val, method_name),
            _ then [Symbol]Option.None(),
        }
    }

    /// 生成类型零值初始化表达式。
    zero_init_expr_for_type(self, t Type) String = {
        let c_type = self.c_type_name(t)
        return when t in {
            .StructureType(_) then "(\(c_type)){0}",
            .EnumType(_) then "(\(c_type)){0}",
            .GenericStruct(_, _) then "(\(c_type)){0}",
            .GenericEnum(_, _) then "(\(c_type)){0}",
            .ReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitRef){0}",
                            _ then "(struct __koral_Ref){0}",
                        },
                        .None() then "(struct __koral_Ref){0}",
                    },
                    _ then "(struct __koral_Ref){0}",
                }
            },
            .TraitObject(_) then "(struct __koral_TraitRef){0}",
            .FunctionType(_, _) then "(struct __koral_Closure){0}",
            .PointerType(_) then "NULL",
            .WeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                            _ then "(struct __koral_WeakRef){0}",
                        },
                        .None() then "(struct __koral_WeakRef){0}",
                    },
                    _ then "(struct __koral_WeakRef){0}",
                }
            },
            .VoidType() then "",
            .NeverType() then "",
            _ then "(\(c_type))0",
        }
    }
}


/// 将 UInt8 格式化为 C 十六进制字节字面量，如 "0x41"
let format_hex_byte(b UInt8) String = {
    let hex_chars = "0123456789ABCDEF"
    let hi = (UInt)(b >> 4)
    let lo = (UInt)(b & (UInt8)0x0F)
    let hi_char = hex_chars.at(hi)
    let lo_char = hex_chars.at(lo)
    let mut result = "0x"
    result.push_byte(hi_char)
    result.push_byte(lo_char)
    return result
}

/// 将 Rune 字面量字符串转换为 C uint32_t 数值字符串
/// value 是原始字符（如 ":" 对应 58）
let rune_literal_to_c_value(value String) String = {
    let bytes = value.to_bytes()
    if bytes.is_empty() then {
        return "0"
    }
    let b0 = (UInt)bytes.at(0)
    // ASCII 字符：直接使用字节值
    if b0 < 128 then {
        return b0.to_string()
    }
    // 2-byte UTF-8: 110xxxxx 10xxxxxx
    if b0 < 224 and bytes.count() >= 2 then {
        let b1 = (UInt)bytes.at(1)
        let cp = ((b0 & 31) << 6) | (b1 & 63)
        return cp.to_string()
    }
    // 3-byte UTF-8: 1110xxxx 10xxxxxx 10xxxxxx
    if b0 < 240 and bytes.count() >= 3 then {
        let b1 = (UInt)bytes.at(1)
        let b2 = (UInt)bytes.at(2)
        let cp = ((b0 & 15) << 12) | ((b1 & 63) << 6) | (b2 & 63)
        return cp.to_string()
    }
    // 4-byte UTF-8: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx
    if b0 < 248 and bytes.count() >= 4 then {
        let b1 = (UInt)bytes.at(1)
        let b2 = (UInt)bytes.at(2)
        let b3 = (UInt)bytes.at(3)
        let cp = ((b0 & 7) << 18) | ((b1 & 63) << 12) | ((b2 & 63) << 6) | (b3 & 63)
        return cp.to_string()
    }
    return b0.to_string()
}