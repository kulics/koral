// codegen_expressions_dispatch.koral - 方法分发代码生成
//
// 实现 CodeGen 的静态方法调用、泛型方法调用、限定方法调用、
given CodeGen {
    private requested_or_symbol_result_type(self, requested_result_type Type, symbol_type Type) Type = {
        return when requested_result_type in {
            .Unknown() then symbol_type,
            .VoidType() then {
                yield when symbol_type in {
                    .VoidType() then requested_result_type,
                    .NeverType() then requested_result_type,
                    .Unknown() then requested_result_type,
                    _ then symbol_type,
                }
            },
            _ then requested_result_type,
        }
    }

    private semantic_receiver_method_name(self, method Symbol ref) [String]Option = {
        if method.def_id.id == 0 then {
            return [String]Option.None()
        }

        when self.program.receiver_method_dispatch.get(method.def_id.id) in {
            .Some(info) then {
                return [String]Option.Some(info.method_name)
            },
            .None() then {},
        }

        when self.program.lowered_method_info_by_def_id.get(method.def_id.id) in {
            .Some(info) then {
                return [String]Option.Some(info.method_name)
            },
            .None() then {},
        }

        return when self.def_id_map.get_name(method.def_id) in {
            .Some(name) then [String]Option.Some(name),
            .None() then [String]Option.None(),
        }
    }

    private canonical_receiver_method_name(self, receiver_type Type, raw_method_name String) String = {
        let receiver_key = self.concrete_receiver_lookup_key(receiver_type)
        let mut best_match = ""
        let mut best_len UInt = 0
        let mut ambiguous = false

        for entry in self.program.lowered_method_info_by_def_id.iterator() then {
            let def_id = DefId(entry.first)
            let info = entry.second
            let effective_receiver_type = when self.def_id_map.get_signature(def_id) in {
                .Some(sig) then {
                    yield if sig.param_types.count() == 0 then info.receiver_type else sig.param_types[(UInt)0]
                },
                .None() then info.receiver_type,
            }
            if self.concrete_receiver_lookup_key(effective_receiver_type) <> receiver_key then {
                continue
            }

            let candidate = info.method_name
            if candidate == raw_method_name then {
                return raw_method_name
            }

            let mut suffix = "_"
            suffix.push_string(candidate)
            if raw_method_name.ends_with(suffix) then {
                let candidate_len = candidate.count()
                if candidate_len > best_len then {
                    best_match = candidate
                    best_len = candidate_len
                    ambiguous = false
                } else if candidate_len == best_len and candidate <> best_match then {
                    ambiguous = true
                }
            }
        }

        if best_match.is_empty() or ambiguous then {
            return raw_method_name
        }
        return best_match
    }

    private preferred_receiver_method_result_type(self, requested_result_type Type, symbol_type Type) Type = {
        if self.type_contains_generic(requested_result_type) and not self.type_contains_generic(symbol_type) then {
            return symbol_type
        }
        return self.requested_or_symbol_result_type(requested_result_type, symbol_type)
    }

    private direct_callable_symbol(self, method Symbol ref) [Symbol]Option = {
        if method.def_id.id == 0 then {
            return [Symbol]Option.None()
        }
        return when self.c_identifier_opt(method.def_id) in {
            .Some(c_name) then [Symbol]Option.Some(Symbol(method.def_id, c_name, method.symbol_type, method.kind)),
            .None() then [Symbol]Option.None(),
        }
    }

    private concrete_callable_symbol(self, def_id DefId, fallback_result_type Type) [Symbol]Option = {
        return when self.c_identifier_opt(def_id) in {
            .Some(c_name) then {
                let result_type = when self.def_id_map.get_signature(def_id) in {
                    .Some(sig) then self.requested_or_symbol_result_type(fallback_result_type, sig.return_type),
                    .None() then fallback_result_type,
                }
                yield [Symbol]Option.Some(Symbol(def_id, c_name, result_type, SymbolKind.Function()))
            },
            .None() then [Symbol]Option.None(),
        }
    }

    private bound_concrete_method_symbol(self, def_id DefId, receiver_type Type, fallback_result_type Type) [Symbol]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let bound_result_type = when self.def_id_map.get_signature(def_id) in {
            .Some(sig) then self.bind_method_signature(def_id, concrete_receiver_type, sig).return_type,
            .None() then fallback_result_type,
        }
        return self.concrete_callable_symbol(def_id, bound_result_type)
    }

    private lookup_receiver_method_def_id(self, receiver_type Type, method_name String) [DefId]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        let indexed_key = "\(receiver_key).\(method_name)"
        return when self.program.codegen_view.lookup_receiver_method(indexed_key) in {
            .Some(def_id) then [DefId]Option.Some(def_id),
            .None() then when concrete_receiver_type in {
                .ReferenceType(inner_ref) then self.lookup_receiver_method_def_id(inner_ref.val, method_name),
                .MutableReferenceType(inner_ref) then self.lookup_receiver_method_def_id(inner_ref.val, method_name),
                _ then [DefId]Option.None(),
            },
        }
    }

    private lookup_trait_method_def_id(self, concrete_type Type, trait_name String, method_name String) [DefId]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(concrete_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        return when self.program.lookup_trait_method(receiver_key, trait_name, method_name) in {
            .Some(def_id) then [DefId]Option.Some(def_id),
            .None() then when self.program.traits.get(trait_name) in {
                .Some(trait_info) then {
                    let mut found = [DefId]Option.None()
                    for parent_trait_name in trait_info.parent_traits then {
                        found = self.lookup_trait_method_def_id(concrete_receiver_type, parent_trait_name, method_name)
                        if found is .Some(_) then { break }
                    }
                    yield found
                },
                .None() then [DefId]Option.None(),
            },
        }
    }

    private lookup_static_method_symbol(self, receiver_type Type, method_name String) [Symbol]Option = {
        return when self.lookup_receiver_method_def_id(receiver_type, method_name) in {
            .Some(def_id) then self.bound_concrete_method_symbol(def_id, receiver_type, Type.Unknown()),
            .None() then [Symbol]Option.None(),
        }
    }

    private try_generate_receiver_dispatch_call(self mut ref, base TypedExpr ref, base_type Type, args [TypedExpr ref]List, requested_result_type Type, dispatch_callsite [DefId]Option) [String]Option = {
        return when dispatch_callsite in {
            .Some(callsite_def_id) then when self.program.lookup_receiver_call_resolution(callsite_def_id) in {
                .Some(resolution) then {
                    yield when self.bound_concrete_method_symbol(resolution.method_def_id, base_type, requested_result_type) in {
                        .Some(dispatch_symbol) then {
                            let dispatch_result_type = self.requested_or_symbol_result_type(requested_result_type, dispatch_symbol.symbol_type)
                            yield [String]Option.Some(self.generate_receiver_method_call(base, base_type, box(dispatch_symbol), args, dispatch_result_type))
                        },
                        .None() then [String]Option.None(),
                    }
                },
                .None() then [String]Option.None(),
            },
            .None() then [String]Option.None(),
        }
    }

    private lookup_receiver_method_via_metadata(self, receiver_type Type, method_name String) [Symbol]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        when self.lookup_receiver_method_def_id(concrete_receiver_type, method_name) in {
            .Some(def_id) then {
                return self.bound_concrete_method_symbol(def_id, concrete_receiver_type, Type.Unknown())
            },
            .None() then {},
        }
        return [Symbol]Option.None()
    }

    private lookup_receiver_method_by_signature(self, receiver_type Type, args [TypedExpr ref]List, requested_result_type Type) [Symbol]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        if receiver_key.is_empty() then {
            return [Symbol]Option.None()
        }

        let mut key_prefix = receiver_key
        key_prefix.push_string(".")
        let expected_param_count = args.count() + (UInt)1
        let concrete_requested_result = self.concretize_codegen_type(requested_result_type)
        let mut matched = [Symbol]Option.None()

        for entry in self.program.codegen_view.receiver_method_by_key then {
            let indexed_key = entry.first
            if not indexed_key.starts_with(key_prefix) then {
                continue
            }
            let def_id = entry.second
            let symbol = when self.bound_concrete_method_symbol(def_id, concrete_receiver_type, requested_result_type) in {
                .Some(bound_symbol) then bound_symbol,
                .None() then {
                    continue
                },
            }
            let signature = when self.def_id_map.get_signature(def_id) in {
                .Some(sig) then sig,
                .None() then {
                    continue
                },
            }
            let bound_signature = self.bind_method_signature(def_id, concrete_receiver_type, signature)
            if bound_signature.param_types.count() <> expected_param_count then {
                continue
            }
            when concrete_requested_result in {
                .Unknown() then {},
                _ then {
                    if self.concrete_layout_key_for_type(bound_signature.return_type) <> self.concrete_layout_key_for_type(concrete_requested_result) then {
                        continue
                    }
                },
            }

            when matched in {
                .Some(existing) then {
                    if existing.def_id.id <> symbol.def_id.id then {
                        return [Symbol]Option.None()
                    }
                },
                .None() then {
                    matched = [Symbol]Option.Some(symbol)
                },
            }
        }

        return matched
    }


    public generate_static_method_call(self mut ref, receiver_type Type, method Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let logical_method_name = method.name
        let owner_matches_receiver = if method.def_id.id > 0 then when self.method_owner_type(method.def_id) in {
                .Some(owner_type) then self.concrete_receiver_lookup_key(owner_type) == self.concrete_receiver_lookup_key(concrete_receiver_type),
                .None() then false,
            } else false

        let mut resolved_symbol_opt = if owner_matches_receiver then {
            yield self.bound_concrete_method_symbol(method.def_id, concrete_receiver_type, method.symbol_type)
        } else [Symbol]Option.None()

        if resolved_symbol_opt is .None() then {
            resolved_symbol_opt = self.lookup_static_method_symbol(concrete_receiver_type, logical_method_name)
        }
        if resolved_symbol_opt is .None() then {
            resolved_symbol_opt = self.lookup_receiver_method(concrete_receiver_type, logical_method_name)
        }
        if resolved_symbol_opt is .None() then {
            when concrete_receiver_type in {
                .EnumType(_) then {
                    return self.generate_enum_constructor(concrete_receiver_type, logical_method_name, args)
                },
                .GenericEnum(_, _) then {
                    return self.generate_enum_constructor(concrete_receiver_type, logical_method_name, args)
                },
                _ then {},
            }
        }
        let resolved_symbol = resolved_symbol_opt or else Symbol(DefId(0), logical_method_name, method.symbol_type, method.kind)
        let direct_signature_opt = when self.def_id_map.get_signature(resolved_symbol.def_id) in {
            .Some(sig) then [FunctionSignature]Option.Some(self.bind_method_signature(resolved_symbol.def_id, concrete_receiver_type, sig)),
            .None() then [FunctionSignature]Option.None(),
        }
        let debug_static_name = if resolved_symbol.def_id.id > 0 then {
            yield self.callable_c_name(box(resolved_symbol))
        } else {
            let receiver_c_name = self.emitted_type_c_name_fallback(concrete_receiver_type)
            yield self.compose_method_c_name(receiver_c_name, resolved_symbol.name)
        }

        let mut effective_result_type = when result_type in {
            .Unknown() then {
                yield when direct_signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then resolved_symbol.symbol_type,
                }
            },
            .VoidType() then {
                let signature_return = when direct_signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then resolved_symbol.symbol_type,
                }
                yield when signature_return in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then signature_return,
                }
            },
            _ then result_type,
        }

        let call_signature_opt = when direct_signature_opt in {
            .Some(sig) then [FunctionSignature]Option.Some(sig),
            .None() then when self.def_id_map.get_signature(resolved_symbol.def_id) in {
                .Some(sig) then [FunctionSignature]Option.Some(sig),
                .None() then [FunctionSignature]Option.None(),
            },
        }
        let mut prepared_args = [String]List.new()
        let mut arg_index = (UInt)0
        for arg_ref in args then {
            let arg = arg_ref
            let expected_type_opt = when call_signature_opt in {
                .Some(sig) then {
                    yield if arg_index < sig.param_types.count() then [Type]Option.Some(sig.param_types[arg_index]) else [Type]Option.None()
                },
                .None() then [Type]Option.None(),
            }
            prepared_args.push(self.prepare_call_argument(arg, expected_type_opt))
            arg_index = arg_index + (UInt)1
        }

        let mut result = ""
        if self.type_is_void_or_never(effective_result_type) then {
            self.buffer.push_string(self.indent)
            self.buffer.push_string(debug_static_name)
            self.buffer.push_rune('(')
        } else {
            let c_type = self.c_type_name(effective_result_type)
            result = self.next_temp_with_decl(c_type)
            self.buffer.push_string(self.indent)
            self.buffer.push_string(result)
            self.buffer.push_string(" = ")
            self.buffer.push_string(debug_static_name)
            self.buffer.push_rune('(')
        }
        let mut first = true
        for prepared_arg in prepared_args then {
            if not first then {
                self.buffer.push_string(", ")
            }
            self.buffer.push_string(prepared_arg)
            first = false
        }
        self.buffer.push_string(");\n")
        return result
    }

    // ── GenericMethodCall 生成 ────────────────────────────────────────────────

    /// 生成泛型方法调用的 C 代码
    ///
    /// base.method_name(args) → 查找方法符号，生成函数调用
    ///
    /// Requirements: 5.32
    public generate_generic_method_call(self mut ref, base TypedExpr ref, receiver_type Type, method Symbol ref, args [TypedExpr ref]List, result_type Type, dispatch_callsite [DefId]Option) String = {
        let base_expr_type = self.concretize_codegen_type(base.expr_type)
        let mut base_type = self.concretize_codegen_type(receiver_type)
        if not self.type_contains_generic(base_expr_type)
            and self.concrete_layout_key_for_type(base_type) <> self.concrete_layout_key_for_type(base_expr_type)
        then {
            base_type = base_expr_type
        }
        let lookup_base_type = when base_type in {
            .ReferenceType(inner) then self.concretize_codegen_type(inner.val),
            .MutableReferenceType(inner) then self.concretize_codegen_type(inner.val),
            .WeakReferenceType(inner) then self.concretize_codegen_type(inner.val),
            .MutableWeakReferenceType(inner) then self.concretize_codegen_type(inner.val),
            _ then base_type,
        }
        let method_name = if method.def_id.id == 0 then self.canonical_receiver_method_name(lookup_base_type, method.name) else self.semantic_receiver_method_name(method) or else method.name
        let effective_result_type = self.requested_or_symbol_result_type(result_type, method.symbol_type)

        let base_declared_type = self.concretize_codegen_type(base.expr_type)
        when base_declared_type in {
            .TraitObject(trait_name) then {
                return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
            },
            _ then {},
        }

        let cast_trait_name_opt = when base.expr_kind in {
            .CastExpr(target_type, _) then when target_type in {
                .TraitObject(trait_name) then [String]Option.Some(trait_name),
                _ then [String]Option.None(),
            },
            _ then [String]Option.None(),
        }
        if cast_trait_name_opt is .Some(trait_name) then {
            return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
        }

        when base_type in {
            .TraitObject(trait_name) then {
                return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
            },
            _ then {},
        }

        if self.try_generate_receiver_dispatch_call(base, base_type, args, result_type, dispatch_callsite) is .Some(dispatch_call) then {
            return dispatch_call
        }

        let mut method_opt = [Symbol]Option.None()
        // Prefer receiver-type metadata lookup. A direct callable symbol can
        // point to a stale/mismatched concrete method when multiple
        // monomorphized variants exist for the same source method.
        method_opt = self.lookup_receiver_method(lookup_base_type, method_name)
        if method_opt is .None() then {
            method_opt = self.lookup_receiver_method_via_lowered_table(lookup_base_type, method_name, args, effective_result_type)
        }
        if method_opt is .None() then {
            when self.method_owner_type(method.def_id) in {
                .Some(owner_type) then {
                    let owner_key = self.concrete_receiver_lookup_key(owner_type)
                    let base_key = self.concrete_receiver_lookup_key(base_type)
                    let signature_receiver_matches = when self.def_id_map.get_signature(method.def_id) in {
                        .Some(sig) then {
                            yield if sig.param_types.count() == 0 then false else {
                                let declared_receiver_key = self.concrete_receiver_lookup_key(sig.param_types[(UInt)0])
                                yield declared_receiver_key == base_key
                            }
                        },
                        .None() then false,
                    }
                    if owner_key == base_key and signature_receiver_matches then {
                        method_opt = self.direct_callable_symbol(method)
                    }
                },
                .None() then {},
            }
        }
        if method_opt is .Some(method_symbol) then {
            let effective_result_type = self.preferred_receiver_method_result_type(result_type, method_symbol.symbol_type)
            return self.generate_receiver_method_call(base, lookup_base_type, box(method_symbol), args, effective_result_type)
        }

        if self.lookup_static_method_symbol(lookup_base_type, method_name) is .Some(static_symbol) then {
            let effective_static_result_type = self.requested_or_symbol_result_type(result_type, static_symbol.symbol_type)
            return self.generate_receiver_method_call(base, lookup_base_type, box(static_symbol), args, effective_static_result_type)
        }

        let global_method_name = self.canonical_method_name_global(method_name)
        when self.lookup_method_global_by_signature(global_method_name, args, effective_result_type) in {
            .Some(global_symbol) then {
                let matched_result_type = self.preferred_receiver_method_result_type(result_type, global_symbol.symbol_type)
                return self.generate_receiver_method_call(base, lookup_base_type, box(global_symbol), args, matched_result_type)
            },
            .None() then {},
        }

        let fallback_symbol = Symbol(DefId(0), method_name, method.symbol_type, method.kind)
        return self.generate_receiver_method_call(base, lookup_base_type, box(fallback_symbol), args, effective_result_type)

        let member_type = self.lookup_field_type(base_type, method_name)
        when member_type in {
            .FunctionType(param_types, ret_ref) then {
                let mut path = [String]List.new()
                path.push(method_name)
                let closure_expr = box(TypedExpr(
                    box(TypedExprKind.MemberPath(base, path)),
                    member_type,
                ))
                let closure_var = self.generate_expression_ssa(closure_expr)
                return self.generate_closure_call(closure_var, param_types, ret_ref.val, args)
            },
            _ then {},
        }

        return self.generate_expression_ssa(base)
    }

    private lookup_receiver_method_via_lowered_table(self, receiver_type Type, method_name String, args [TypedExpr ref]List, requested_result_type Type) [Symbol]Option = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        if receiver_key.is_empty() then {
            return [Symbol]Option.None()
        }

        let expected_param_count = args.count() + (UInt)1
        let concrete_requested_result = self.concretize_codegen_type(requested_result_type)
        let mut matched = [Symbol]Option.None()

        for entry in self.program.lowered_method_info_by_def_id.iterator() then {
            let def_id = DefId(entry.first)
            let info = entry.second
            if info.method_name <> method_name then {
                continue
            }
            let signature = when self.def_id_map.get_signature(def_id) in {
                .Some(sig) then sig,
                .None() then { continue },
            }
            let bound_signature = self.bind_method_signature(def_id, concrete_receiver_type, signature)
            if bound_signature.param_types.count() <> expected_param_count then {
                continue
            }
            let effective_receiver_type = if bound_signature.param_types.count() > 0 then
                    bound_signature.param_types[(UInt)0]
                else info.receiver_type
            if self.concrete_receiver_lookup_key(self.concretize_codegen_type(effective_receiver_type)) <> receiver_key then {
                continue
            }
            when concrete_requested_result in {
                .Unknown() then {},
                _ then {
                    if self.concrete_layout_key_for_type(bound_signature.return_type) <> self.concrete_layout_key_for_type(concrete_requested_result) then {
                        continue
                    }
                },
            }

            let symbol = self.bound_concrete_method_symbol(def_id, concrete_receiver_type, requested_result_type)
                or else Symbol(def_id, method_name, bound_signature.return_type, SymbolKind.Function())
            when matched in {
                .Some(existing) then {
                    if existing.def_id.id <> symbol.def_id.id then {
                        return [Symbol]Option.None()
                    }
                },
                .None() then {
                    matched = [Symbol]Option.Some(symbol)
                },
            }
        }

        return matched
    }

    private canonical_method_name_global(self, raw_method_name String) String = {
        let mut best_match = ""
        let mut best_len UInt = 0
        let mut ambiguous = false

        for entry in self.program.lowered_method_info_by_def_id.iterator() then {
            let candidate = entry.second.method_name
            if candidate == raw_method_name then {
                return raw_method_name
            }
            let mut suffix = "_"
            suffix.push_string(candidate)
            if raw_method_name.ends_with(suffix) then {
                let candidate_len = candidate.count()
                if candidate_len > best_len then {
                    best_match = candidate
                    best_len = candidate_len
                    ambiguous = false
                } else if candidate_len == best_len and candidate <> best_match then {
                    ambiguous = true
                }
            }
        }

        if best_match.is_empty() or ambiguous then {
            return raw_method_name
        }
        return best_match
    }

    private lookup_method_global_by_signature(self, method_name String, args [TypedExpr ref]List, requested_result_type Type) [Symbol]Option = {
        let expected_param_count = args.count() + (UInt)1
        let concrete_requested_result = self.concretize_codegen_type(requested_result_type)
        let mut matched = [Symbol]Option.None()

        for entry in self.program.lowered_method_info_by_def_id.iterator() then {
            let def_id = DefId(entry.first)
            let info = entry.second
            if info.method_name <> method_name then {
                continue
            }
            let signature = when self.def_id_map.get_signature(def_id) in {
                .Some(sig) then sig,
                .None() then { continue },
            }
            if signature.param_types.count() <> expected_param_count then {
                continue
            }

            let mut params_match = true
            let mut i UInt = (UInt)0
            while i < args.count() then {
                let expected_arg = self.concretize_codegen_type(signature.param_types[i + (UInt)1])
                let actual_arg = self.concretize_codegen_type(args[i].val.expr_type)
                let expected_key = self.concrete_layout_key_for_type(expected_arg)
                let actual_key = self.concrete_layout_key_for_type(actual_arg)
                let actual_unresolved = when actual_arg in {
                    .Unknown() then true,
                    .TypeVar(_) then true,
                    .GenericParameter(_) then true,
                    _ then false,
                }
                let expected_unresolved = when expected_arg in {
                    .Unknown() then true,
                    .TypeVar(_) then true,
                    .GenericParameter(_) then true,
                    _ then false,
                }
                if not actual_unresolved and not expected_unresolved and expected_key <> actual_key then {
                    params_match = false
                    break
                }
                i += (UInt)1
            }
            if not params_match then {
                continue
            }

            when concrete_requested_result in {
                .Unknown() then {},
                _ then {
                    if self.concrete_layout_key_for_type(signature.return_type) <> self.concrete_layout_key_for_type(concrete_requested_result) then {
                        continue
                    }
                },
            }

            let owner_type = if signature.param_types.count() > 0 then signature.param_types[(UInt)0] else info.receiver_type
            let concrete_owner_type = self.concretize_codegen_type(owner_type)
            let symbol = self.bound_concrete_method_symbol(def_id, concrete_owner_type, requested_result_type)
                or else Symbol(def_id, method_name, signature.return_type, SymbolKind.Function())

            when matched in {
                .Some(existing) then {
                    if existing.def_id.id <> symbol.def_id.id then {
                        return [Symbol]Option.None()
                    }
                },
                .None() then {
                    matched = [Symbol]Option.Some(symbol)
                },
            }
        }

        return matched
    }

    // ── QualifiedMethodCall 生成 ──────────────────────────────────────────────

    /// 生成 trait 限定方法调用的 C 代码
    ///
    /// Requirements: 5.33
    private generate_trait_tool_argument(self mut ref, expr TypedExpr ref, expected_type Type) String = {
        return when expected_type in {
            .TraitObject(trait_name) then {
                yield when expr.expr_type in {
                    .TraitObject(_) then { yield self.generate_expression_ssa(expr) },
                    .ReferenceType(source_inner_ref) then {
                        yield when source_inner_ref.val in {
                            .TraitObject(_) then self.generate_cast_expr(expected_type, expr),
                            _ then self.generate_trait_object_conversion(expr, trait_name, expr.expr_type),
                        }
                    },
                    _ then {
                        let source_result = self.generate_expression_ssa(expr)
                        let concrete_type = expr.expr_type
                        let concrete_c_type = self.c_type_name(concrete_type)
                        let value_result = self.copy_expr_if_lvalue_owned(expr, source_result, concrete_type)
                        let stored_value = self.next_temp_with_init(concrete_c_type, value_result)
                        let trait_result = self.next_temp_with_decl("struct __koral_TraitRef")
                        let concrete_c_name = when self.concrete_type_c_name(concrete_type) in {
                            .Some(name) then name,
                            .None() then self.c_type_name(concrete_type),
                        }
                        let vtable_name = self.vtable_instance_name(trait_name, concrete_c_name)
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).ptr = (void*)&(\(stored_value));\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).control = NULL;\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).vtable = &\(vtable_name);\n")
                        yield trait_result
                    },
                }
            },
            _ then { yield self.generate_expression_ssa(expr) },
        }
    }

    public generate_qualified_method_call(self mut ref, base TypedExpr ref, trait_name String, method Symbol ref, args [TypedExpr ref]List, result_type Type, dispatch_callsite [DefId]Option) String = {
        let method_name = method.name
        let base_type = self.concretize_codegen_type(base.expr_type)
        let effective_result_type = self.requested_or_symbol_result_type(result_type, method.symbol_type)

        when base.expr_kind in {
            .Variable(sym) then {
                if sym.kind is .TypeSymbol() then {
                    if self.lookup_trait_method_def_id(base_type, trait_name, method_name) is .Some(actual_def_id) then {
                        let actual_symbol = self.bound_concrete_method_symbol(actual_def_id, base_type, effective_result_type) or else Symbol(actual_def_id, method_name, effective_result_type, SymbolKind.Function())
                        return self.generate_function_call(box(actual_symbol), args, actual_symbol.symbol_type)
                    }
                    return self.generate_static_method_call(base_type, method, args, effective_result_type)
                }
            },
            _ then {},
        }

        let base_is_trait_object = when base_type in {
            .TraitObject(_) then true,
            _ then false,
        }
        if self.try_generate_receiver_dispatch_call(base, base_type, args, result_type, dispatch_callsite) is .Some(dispatch_call) then {
            return dispatch_call
        }
        if not base_is_trait_object then {
            let mut all_args = [TypedExpr ref]List.new()
            let include_base_arg = when base.expr_kind in {
                .Variable(sym) then sym.kind is not .TypeSymbol(),
                _ then true,
            }
            if include_base_arg then {
                all_args.push(box(base))
            }
            for arg in args then {
                all_args.push(arg)
            }
            if include_base_arg then {
                if self.lookup_receiver_method(base_type, method_name) is .Some(concrete_method) then {
                    return self.generate_receiver_method_call(base, base_type, box(concrete_method), args, effective_result_type)
                }
                if self.lookup_trait_method_def_id(base_type, trait_name, method_name) is .Some(actual_def_id) then {
                    let actual_symbol = self.bound_concrete_method_symbol(actual_def_id, base_type, effective_result_type) or else Symbol(actual_def_id, method_name, effective_result_type, SymbolKind.Function())
                    return self.generate_receiver_method_call(base, base_type, box(actual_symbol), args, actual_symbol.symbol_type)
                }
            }
            let direct_symbol = when self.direct_callable_symbol(method) in {
                .Some(symbol) then symbol,
                .None() then method.val,
            }
            return self.generate_function_call(box(direct_symbol), all_args, effective_result_type)
        }

        return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
    }
    // ── 方法查找辅助方法 ──────────────────────────────────────────────────────

    /// 通过接收者类型和方法名查找方法符号
    ///
    /// 优先使用单态化阶段导出的 metadata 表。
    lookup_receiver_method(self, receiver_type Type, method_name String) [Symbol]Option = {
        let base_type = receiver_type
        if self.lookup_receiver_method_via_metadata(base_type, method_name) is .Some(symbol) then {
            return [Symbol]Option.Some(symbol)
        }
        return when receiver_type in {
            .ReferenceType(inner_ref) then self.lookup_receiver_method(inner_ref.val, method_name),
            .MutableReferenceType(inner_ref) then self.lookup_receiver_method(inner_ref.val, method_name),
            _ then [Symbol]Option.None(),
        }
    }

    /// 生成类型零值初始化表达式。
    zero_init_expr_for_type(self, t Type) String = {
        let c_type = self.c_type_name(t)
        return when t in {
            .StructureType(_) then "(\(c_type)){0}",
            .EnumType(_) then "(\(c_type)){0}",
            .GenericStruct(_, _) then "(\(c_type)){0}",
            .GenericEnum(_, _) then "(\(c_type)){0}",
            .ReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitRef){0}",
                            _ then "(struct __koral_Ref){0}",
                        },
                        .None() then "(struct __koral_Ref){0}",
                    },
                    _ then "(struct __koral_Ref){0}",
                }
            },
            .MutableReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitRef){0}",
                            _ then "(struct __koral_Ref){0}",
                        },
                        .None() then "(struct __koral_Ref){0}",
                    },
                    _ then "(struct __koral_Ref){0}",
                }
            },
            .TraitObject(_) then "(struct __koral_TraitRef){0}",
            .FunctionType(_, _) then "(struct __koral_Closure){0}",
            .PointerType(_) then "NULL",
            .MutablePointerType(_) then "NULL",
            .WeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                            _ then "(struct __koral_WeakRef){0}",
                        },
                        .None() then "(struct __koral_WeakRef){0}",
                    },
                    _ then "(struct __koral_WeakRef){0}",
                }
            },
            .MutableWeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                            _ then "(struct __koral_WeakRef){0}",
                        },
                        .None() then "(struct __koral_WeakRef){0}",
                    },
                    _ then "(struct __koral_WeakRef){0}",
                }
            },
            .VoidType() then "",
            .NeverType() then "",
            _ then "(\(c_type))0",
        }
    }
}


/// 将 UInt8 格式化为 C 十六进制字节字面量，如 "0x41"
let format_hex_byte(b UInt8) String = {
    let hex_chars = "0123456789ABCDEF"
    let hi = (UInt)(b >> 4)
    let lo = (UInt)(b & (UInt8)0x0F)
    let hi_char = hex_chars[hi]
    let lo_char = hex_chars[lo]
    let mut result = "0x"
    result.push_byte(hi_char)
    result.push_byte(lo_char)
    return result
}

/// 将 Rune 字面量字符串转换为 C uint32_t 数值字符串
/// value 是原始字符（如 ":" 对应 58）
let rune_literal_to_c_value(value String) String = {
    let bytes = value.to_bytes()
    if bytes.is_empty() then {
        return "0"
    }
    let b0 = (UInt)bytes[0]
    // ASCII 字符：直接使用字节值
    if b0 < 128 then {
        return b0.to_string()
    }
    // 2-byte UTF-8: 110xxxxx 10xxxxxx
    if b0 < 224 and bytes.count() >= 2 then {
        let b1 = (UInt)bytes[1]
        let cp = ((b0 & 31) << 6) | (b1 & 63)
        return cp.to_string()
    }
    // 3-byte UTF-8: 1110xxxx 10xxxxxx 10xxxxxx
    if b0 < 240 and bytes.count() >= 3 then {
        let b1 = (UInt)bytes[1]
        let b2 = (UInt)bytes[2]
        let cp = ((b0 & 15) << 12) | ((b1 & 63) << 6) | (b2 & 63)
        return cp.to_string()
    }
    // 4-byte UTF-8: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx
    if b0 < 248 and bytes.count() >= 4 then {
        let b1 = (UInt)bytes[1]
        let b2 = (UInt)bytes[2]
        let b3 = (UInt)bytes[3]
        let cp = ((b0 & 7) << 18) | ((b1 & 63) << 12) | ((b2 & 63) << 6) | (b3 & 63)
        return cp.to_string()
    }
    return b0.to_string()
}
