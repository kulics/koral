// codegen_expressions_dispatch.koral - 方法分发与集合字面量代码生成
//
// 实现 CodeGen 的静态方法调用、泛型方法调用、限定方法调用、
given CodeGen {
    private receiver_has_trait_conformance(self, base_type Type, trait_name String, is_string_type Bool) Bool = {
        for node in self.program.global_nodes then {
            when node in {
                .GivenTraitDecl(target_type, candidate_trait_name, _, _, _) then {
                    if candidate_trait_name <> trait_name then {
                        continue
                    }
                    let types_match = if is_string_type then {
                        yield when target_type in {
                            .StructureType(def_id) then {
                                yield when self.def_id_map.get_name(def_id) in {
                                    .Some(n) then n == "String",
                                    .None() then false,
                                }
                            },
                            .StringType() then true,
                            _ then false,
                        }
                    } else {
                        yield self.codegen_types_equal(target_type, base_type)
                    }
                    if types_match then {
                        return true
                    }
                },
                _ then {},
            }
        }
        return false
    }

    public generate_static_method_call(self ref, receiver_type Type, method Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let receiver_key = self.receiver_type_lookup_name(concrete_receiver_type)
        let method_name = method.name
        let fallback_receiver_type_opt = when result_type in {
            .OpaqueType(_) then {
                yield if self.codegen_types_equal(result_type, concrete_receiver_type)
                    then [Type]Option.None()
                    else [Type]Option.Some(result_type)
            },
            .StructureType(_) then {
                yield if self.codegen_types_equal(result_type, concrete_receiver_type)
                    then [Type]Option.None()
                    else [Type]Option.Some(result_type)
            },
            .GenericStruct(_, _) then {
                yield if self.codegen_types_equal(result_type, concrete_receiver_type)
                    then [Type]Option.None()
                    else [Type]Option.Some(result_type)
            },
            .EnumType(_) then {
                yield if self.codegen_types_equal(result_type, concrete_receiver_type)
                    then [Type]Option.None()
                    else [Type]Option.Some(result_type)
            },
            .GenericEnum(_, _) then {
                yield if self.codegen_types_equal(result_type, concrete_receiver_type)
                    then [Type]Option.None()
                    else [Type]Option.Some(result_type)
            },
            _ then [Type]Option.None(),
        }
        let method_signature_opt = when self.static_method_signature(receiver_type, method) in {
            .Some(sig) then [FunctionSignature]Option.Some(sig),
            .None() then when fallback_receiver_type_opt in {
                .Some(fallback_receiver_type) then self.static_method_signature(fallback_receiver_type, method),
                .None() then [FunctionSignature]Option.None(),
            },
        }
        let direct_signature_opt = method_signature_opt
        let c_name = when self.static_method_c_name(receiver_type, method) in {
            .Some(name) then name,
            .None() then when self.public_static_method_c_name(receiver_type, method_name) in {
                .Some(name) then name,
                .None() then when fallback_receiver_type_opt in {
                    .Some(fallback_receiver_type) then when self.static_method_c_name(fallback_receiver_type, method) in {
                        .Some(name) then name,
                        .None() then when self.public_static_method_c_name(fallback_receiver_type, method_name) in {
                            .Some(name) then name,
                            .None() then when self.lookup_static_method_c_id(receiver_key, method_name) in {
                                .Some(name) then name,
                                .None() then when self.c_identifier_by_def_id.get(method.def_id.id) in {
                                    .Some(name) then name,
                                    .None() then method.name,
                                },
                            },
                        },
                    },
                    .None() then when self.lookup_static_method_c_id(receiver_key, method_name) in {
                        .Some(name) then name,
                        .None() then when self.c_identifier_by_def_id.get(method.def_id.id) in {
                            .Some(name) then name,
                            .None() then method.name,
                        },
                    },
                },
            },
        }
        let resolved_c_name = c_name
        let debug_static_name = resolved_c_name

        let mut effective_result_type = when result_type in {
            .Unknown() then {
                yield when direct_signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then when self.lookup_function_signature_by_c_name(c_name) in {
                        .Some(sig) then sig.return_type,
                        .None() then method.symbol_type,
                    },
                }
            },
            .VoidType() then {
                let signature_return = when direct_signature_opt in {
                    .Some(sig) then sig.return_type,
                    .None() then when self.lookup_function_signature_by_c_name(c_name) in {
                        .Some(sig) then sig.return_type,
                        .None() then method.symbol_type,
                    },
                }
                yield when signature_return in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then signature_return,
                }
            },
            _ then result_type,
        }

        // If we resolved a concrete callable signature, prefer its return type to
        // keep local temp typing consistent with the emitted C function prototype.
        when self.lookup_function_signature_by_c_name(resolved_c_name) in {
            .Some(sig) then {
                when result_type in {
                    .VoidType() then {},
                    .NeverType() then {},
                    _ then { effective_result_type = sig.return_type },
                }
            },
            .None() then {},
        }

        when effective_result_type in {
            .Unknown() then {
                if receiver_key == "Float64" then {
                    effective_result_type = Type.Float64Type()
                } else if receiver_key == "Float32" then {
                    effective_result_type = Type.Float32Type()
                }
            },
            _ then {},
        }
        if self.c_type_name(effective_result_type) == "void*" then {
            if receiver_key == "Float64" then {
                effective_result_type = Type.Float64Type()
            } else if receiver_key == "Float32" then {
                effective_result_type = Type.Float32Type()
            }
        }

        let call_signature_opt = when direct_signature_opt in {
            .Some(sig) then [FunctionSignature]Option.Some(sig),
            .None() then when self.lookup_function_signature_by_c_name(resolved_c_name) in {
                .Some(sig) then [FunctionSignature]Option.Some(sig),
                .None() then when self.def_id_map.get_signature(method.def_id) in {
                    .Some(sig) then [FunctionSignature]Option.Some(sig),
                    .None() then [FunctionSignature]Option.None(),
                },
            },
        }
        let mut param_results = [String]List.new()
        let mut arg_index = (UInt)0
        for arg_ref in args then {
            let arg = arg_ref
            let result = self.generate_expression_ssa(arg)
            let expected_type_opt = when call_signature_opt in {
                .Some(sig) then {
                    yield if arg_index < sig.param_types.count() then [Type]Option.Some(sig.param_types.at(arg_index)) else [Type]Option.None()
                },
                .None() then [Type]Option.None(),
            }
            let is_lvalue = self.is_lvalue_expr(arg)
            let mut arg_value = result
            if is_lvalue and self.needs_drop(arg.expr_type) then {
                let c_type = self.c_type_name(arg.expr_type)
                let copy_result = self.next_temp_with_decl(c_type)
                self.append_copy_assignment(arg.expr_type, result, copy_result)
                arg_value = copy_result
            }

            when expected_type_opt in {
                .Some(expected_type) then {
                    arg_value = self.adapt_call_argument_to_expected_type(arg, arg_value, expected_type, is_lvalue)
                },
                .None() then {
                    when call_signature_opt in {
                        .None() then {},
                        .Some(_) then {},
                    }
                },
            }

            param_results.push(arg_value)
            arg_index = arg_index + (UInt)1
        }
        let args_str = param_results.join_to_string(", ")
        if self.type_is_void_or_never(effective_result_type) then {
            self.add_indent()
            self.buffer.push_string("\(debug_static_name)(\(args_str));\n")
            return ""
        } else {
            let c_type = self.c_type_name(effective_result_type)
            let result = self.next_temp_with_init(c_type, "\(debug_static_name)(\(args_str))")
            return result
        }
    }

    // ── GenericMethodCall 生成 ────────────────────────────────────────────────

    private coerce_erased_generic_method_result(self, c_name String, call_expr String, result_type Type) String = {
        let is_erased_unwrap =
            c_name.ends_with("_Result_unwrap")
            or c_name.ends_with("_Result_expect")
            or c_name.ends_with("_Result_unwrap_or")
            or c_name.ends_with("_Option_unwrap")
            or c_name.ends_with("_Option_expect")
            or c_name.ends_with("_Option_unwrap_or")
        if not is_erased_unwrap then { return call_expr }

        let c_type = self.c_type_name(result_type)
        return when result_type in {
            .StructureType(_) then "*(\(c_type)*)\(call_expr)",
            .EnumType(_) then "*(\(c_type)*)\(call_expr)",
            .GenericStruct(_, _) then "*(\(c_type)*)\(call_expr)",
            .GenericEnum(_, _) then "*(\(c_type)*)\(call_expr)",
            .IntType() then "(intptr_t)\(call_expr)",
            .Int8Type() then "(int8_t)(intptr_t)\(call_expr)",
            .Int16Type() then "(int16_t)(intptr_t)\(call_expr)",
            .Int32Type() then "(int32_t)(intptr_t)\(call_expr)",
            .Int64Type() then "(int64_t)(intptr_t)\(call_expr)",
            .UIntType() then "(uintptr_t)\(call_expr)",
            .UInt8Type() then "(uint8_t)(uintptr_t)\(call_expr)",
            .UInt16Type() then "(uint16_t)(uintptr_t)\(call_expr)",
            .UInt32Type() then "(uint32_t)(uintptr_t)\(call_expr)",
            .UInt64Type() then "(uint64_t)(uintptr_t)\(call_expr)",
            .BoolType() then "((int)((uintptr_t)\(call_expr) != 0))",
            _ then "(\(c_type))\(call_expr)",
        }
    }

    /// 生成泛型方法调用的 C 代码
    ///
    /// base.method_name(args) → 查找方法符号，生成函数调用
    ///
    /// Requirements: 5.32
    public generate_generic_method_call(self ref, base TypedExpr ref, receiver_type Type, method Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        let base_expr_type = self.concretize_codegen_type(base.expr_type)
        let mut base_type = self.concretize_codegen_type(receiver_type)
        if self.type_contains_generic(receiver_type) and not self.type_contains_generic(base_expr_type) then {
            base_type = base_expr_type
        }
        let method_name = method.name
        let effective_result_type = when result_type in {
            .Unknown() then method.symbol_type,
            _ then result_type,
        }

        let base_declared_type = self.concretize_codegen_type(base.expr_type)
        when base_declared_type in {
            .TraitObject(trait_name) then {
                return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
            },
            _ then {},
        }

        let cast_trait_name_opt = when base.expr_kind in {
            .CastExpr(target_type, _) then when target_type in {
                .TraitObject(trait_name) then [String]Option.Some(trait_name),
                _ then [String]Option.None(),
            },
            _ then [String]Option.None(),
        }
        when cast_trait_name_opt in {
            .Some(trait_name) then {
                return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
            },
            .None() then {},
        }

        when base_type in {
            .TraitObject(trait_name) then {
                let effective_result_type = when result_type in {
                    .Unknown() then method.symbol_type,
                    _ then result_type,
                }
                return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
            },
            _ then {},
        }

        if self.is_integer_type(base_type) then {
            let suffix = self.type_suffix(base_type)
            if method_name == "wrapping_neg" and args.count() == 0 then {
                let base_result = self.generate_expression_ssa(base)
                let c_type = self.c_type_name(base_type)
                let result = self.next_temp_with_init(c_type, "koral_wrapping_sub_\(suffix)(0, \(base_result))")
                return result
            }
            if args.count() == 1 then {
                let base_result = self.generate_expression_ssa(base)
                let arg_result = self.generate_expression_ssa(args.at((UInt)0))
                let runtime_name_opt = when method_name in {
                    "wrapping_add" then [String]Option.Some("koral_wrapping_add_\(suffix)"),
                    "wrapping_sub" then [String]Option.Some("koral_wrapping_sub_\(suffix)"),
                    "wrapping_mul" then [String]Option.Some("koral_wrapping_mul_\(suffix)"),
                    "wrapping_div" then [String]Option.Some("koral_wrapping_div_\(suffix)"),
                    "wrapping_rem" then [String]Option.Some("koral_wrapping_rem_\(suffix)"),
                    "wrapping_shl" then [String]Option.Some("koral_wrapping_shl_\(suffix)"),
                    "wrapping_shr" then [String]Option.Some("koral_wrapping_shr_\(suffix)"),
                    _ then [String]Option.None(),
                }
                when runtime_name_opt in {
                    .Some(runtime_name) then {
                        let c_type = self.c_type_name(base_type)
                        let result = self.next_temp_with_init(c_type, "\(runtime_name)(\(base_result), \(arg_result))")
                        return result
                    },
                    .None() then {},
                }
            }
        }

        let mut method_opt = [Symbol]Option.None()
        if method.def_id.id > (UInt)0 then {
            when self.c_identifier_by_def_id.get(method.def_id.id) in {
                .Some(c_name) then {
                    method_opt = [Symbol]Option.Some(Symbol(method.def_id, c_name, method.symbol_type, method.kind))
                },
                .None() then {
                    method_opt = self.lookup_receiver_method(base_type, method_name)
                },
            }
        } else {
            method_opt = self.lookup_receiver_method(base_type, method_name)
        }
        when method_opt in {
            .Some(method_symbol) then {
                let effective_result_type = when result_type in {
                    _ then {
                        let inferred_result_type = if self.type_contains_generic(result_type)
                            and not self.type_contains_generic(method_symbol.symbol_type)
                            then method_symbol.symbol_type
                            else when result_type in {
                            .Unknown() then method_symbol.symbol_type,
                            .VoidType() then {
                                yield when method_symbol.symbol_type in {
                                    .VoidType() then result_type,
                                    .NeverType() then result_type,
                                    .Unknown() then result_type,
                                    _ then method_symbol.symbol_type,
                                }
                            },
                            _ then result_type,
                        }
                        yield inferred_result_type
                    },
                }
                let mut all_args = [TypedExpr ref]List.new()
                all_args.push(box(base))
                for arg in args then {
                    all_args.push(arg)
                }
                return self.generate_function_call(method_symbol, all_args, effective_result_type)
            },
            .None() then {},
        }

        let mut lookup_type_names = [String]List.new()
        let primary_lookup_name = self.receiver_type_lookup_name(base_type)
        if not primary_lookup_name.is_empty() and primary_lookup_name <> "Unknown" then {
            lookup_type_names.push(primary_lookup_name)
        }
        let display_lookup_name = self.def_id_map.type_display_name(base_type)
        if not display_lookup_name.is_empty() and display_lookup_name <> primary_lookup_name then {
            lookup_type_names.push(display_lookup_name)
        }
        when base_type in {
            .StructureType(def_id) then {
                when self.def_id_map.get_template_name(def_id) in {
                    .Some(template_name) then {
                        if not lookup_type_names.contains(template_name) then {
                            lookup_type_names.push(template_name)
                        }
                    },
                    .None() then {},
                }
            },
            .EnumType(def_id) then {
                when self.def_id_map.get_template_name(def_id) in {
                    .Some(template_name) then {
                        if not lookup_type_names.contains(template_name) then {
                            lookup_type_names.push(template_name)
                        }
                    },
                    .None() then {},
                }
            },
            _ then {},
        }

        for lookup_type_name in lookup_type_names then {
            when self.program.lookup_static_method(lookup_type_name, method_name) in {
                .Some(def_id) then {
                    let static_symbol_name = when self.c_identifier_by_def_id.get(def_id.id) in {
                        .Some(c_name) then c_name,
                        .None() then self.def_id_map.get_name(def_id) or else method_name,
                    }
                    let static_symbol_type = when self.def_id_map.get_signature(def_id) in {
                        .Some(sig) then sig.return_type,
                        .None() then method.symbol_type,
                    }
                    let static_symbol = Symbol(def_id, static_symbol_name, static_symbol_type, SymbolKind.Function())
                    let mut all_args = [TypedExpr ref]List.new()
                    all_args.push(box(base))
                    for arg in args then {
                        all_args.push(arg)
                    }
                    let effective_result_type = when result_type in {
                        .Unknown() then static_symbol_type,
                        _ then result_type,
                    }
                    return self.generate_function_call(static_symbol, all_args, effective_result_type)
                },
                .None() then {},
            }
        }

        if method.def_id.id > (UInt)0 then {
            when self.c_identifier_by_def_id.get(method.def_id.id) in {
                .Some(c_name) then {
                    let mut all_args = [TypedExpr ref]List.new()
                    all_args.push(box(base))
                    for arg in args then {
                        all_args.push(arg)
                    }
                    let fallback_result_type = when result_type in {
                        .Unknown() then method.symbol_type,
                        _ then result_type,
                    }
                    let bound_symbol = Symbol(method.def_id, c_name, method.symbol_type, method.kind)
                    return self.generate_function_call(bound_symbol, all_args, fallback_result_type)
                },
                .None() then {},
            }
        }

        let lowered_receiver_type = self.normalize_vtable_receiver_type(base_type)
        let lowered_method_key = self.trait_impl_lookup_key(layout_key(lowered_receiver_type), "", method_name)
        when self.trait_impl_c_name_by_key_index.get(lowered_method_key) in {
            .Some(c_name) then {
                let mut all_args = [TypedExpr ref]List.new()
                all_args.push(box(base))
                for arg in args then {
                    all_args.push(arg)
                }
                let lowered_result_type = when self.lookup_function_signature_by_c_name(c_name) in {
                    .Some(sig) then sig.return_type,
                    .None() then when result_type in {
                        .Unknown() then method.symbol_type,
                        _ then result_type,
                    },
                }
                let lowered_def_id = self.def_id_by_c_name_index.get(c_name) or else method.def_id
                let lowered_symbol = Symbol(lowered_def_id, c_name, lowered_result_type, SymbolKind.Function())
                return self.generate_function_call(lowered_symbol, all_args, lowered_result_type)
            },
            .None() then {},
        }

        let member_type = self.lookup_field_type(base_type, method_name)
        when member_type in {
            .FunctionType(param_types, ret_ref) then {
                let closure_expr = box(TypedExpr(
                    box(TypedExprKind.MemberExpr(base, method_name)),
                    member_type,
                ))
                let closure_var = self.generate_expression_ssa(closure_expr)
                return self.generate_closure_call(closure_var, param_types, ret_ref.val, args)
            },
            _ then {},
        }

        return self.generate_expression_ssa(base)
    }

    // ── QualifiedMethodCall 生成 ──────────────────────────────────────────────

    /// 生成 trait 限定方法调用的 C 代码
    ///
    /// Requirements: 5.33
    private generate_trait_tool_argument(self ref, expr TypedExpr ref, expected_type Type) String = {
        return when expected_type in {
            .TraitObject(trait_name) then {
                yield when expr.expr_type in {
                    .TraitObject(_) then { yield self.generate_expression_ssa(expr) },
                    .ReferenceType(source_inner_ref) then {
                        yield when source_inner_ref.val in {
                            .TraitObject(_) then self.generate_cast_expr(expected_type, expr),
                            _ then self.generate_trait_object_conversion(expr, trait_name, expr.expr_type),
                        }
                    },
                    _ then {
                        let source_result = self.generate_expression_ssa(expr)
                        let concrete_type = expr.expr_type
                        let concrete_c_type = self.c_type_name(concrete_type)
                        let value_result = if self.is_lvalue_expr(expr) and self.needs_drop(concrete_type) then {
                            let copied_value = self.next_temp_with_decl(concrete_c_type)
                            self.append_copy_assignment(concrete_type, source_result, copied_value)
                            yield copied_value
                        } else {
                            yield source_result
                        }
                        let stored_value = self.next_temp_with_init(concrete_c_type, value_result)
                        let trait_result = self.next_temp_with_decl("struct __koral_TraitRef")
                        let concrete_c_name = when self.concrete_type_c_name(concrete_type) in {
                            .Some(name) then name,
                            .None() then self.c_type_name(concrete_type),
                        }
                        let vtable_name = self.vtable_instance_name(trait_name, concrete_c_name)
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).ptr = (void*)&(\(stored_value));\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).control = NULL;\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).vtable = &\(vtable_name);\n")
                        yield trait_result
                    },
                }
            },
            _ then { yield self.generate_expression_ssa(expr) },
        }
    }

    public generate_qualified_method_call(self ref, base TypedExpr ref, trait_name String, method Symbol ref, args [TypedExpr ref]List, result_type Type) String = {
        let method_name = method.name
        let base_type = self.concretize_codegen_type(base.expr_type)
        let effective_result_type = when result_type in {
            .Unknown() then method.symbol_type,
            .VoidType() then {
                yield when method.symbol_type in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then method.symbol_type,
                }
            },
            _ then result_type,
        }

        when base.expr_kind in {
            .Variable(sym) then {
                if sym.kind is .TypeSymbol() then {
                    return self.generate_static_method_call(base_type, method, args, effective_result_type)
                }
            },
            _ then {},
        }

        let base_is_trait_object = when base_type in {
            .TraitObject(_) then true,
            _ then false,
        }
        if not base_is_trait_object then {
            let mut all_args = [TypedExpr ref]List.new()
            let include_base_arg = when base.expr_kind in {
                .Variable(sym) then sym.kind is not .TypeSymbol(),
                _ then true,
            }
            if include_base_arg then {
                all_args.push(box(base))
            }
            for arg in args then {
                all_args.push(arg)
            }
            if include_base_arg then {
                when self.lookup_receiver_method(base_type, method_name) in {
                    .Some(concrete_method) then {
                        return self.generate_function_call(concrete_method, all_args, effective_result_type)
                    },
                    .None() then {},
                }
            }
            let direct_symbol = when self.c_identifier_by_def_id.get(method.def_id.id) in {
                .Some(c_name) then Symbol(method.def_id, c_name, method.symbol_type, method.kind),
                .None() then method.val,
            }
            return self.generate_function_call(direct_symbol, all_args, effective_result_type)
        }

        return self.generate_trait_method_call(base, trait_name, method_name, args, effective_result_type)
    }


    // ── CollectionLiteral 生成 ────────────────────────────────────────────────

    /// 生成集合字面量的 C 代码
    ///
    /// [a, b, c] → List.new() + push(a) + push(b) + push(c)
    ///
    /// Requirements: 5.35
    public generate_collection_literal(self ref, elements [TypedExpr ref]List, result_type Type) String = {
        let type_name = self.receiver_type_lookup_name(result_type)
        let new_c_id_opt = self.lookup_static_method_c_id(type_name, "new")
        let c_type = self.c_type_name(result_type)

        let result = when new_c_id_opt in {
            .Some(new_name) then self.next_temp_with_init(c_type, "\(new_name)()"),
            .None() then self.next_temp_with_init(c_type, "Std_\(sanitize_c_identifier(type_name))_new()"),
        }

        // List 字面量用 push，Set 字面量用 insert。
        let element_method_opt = when self.lookup_receiver_method(result_type, "push") in {
            .Some(push_symbol) then [Symbol]Option.Some(push_symbol),
            .None() then self.lookup_receiver_method(result_type, "insert"),
        }
        when element_method_opt in {
            .Some(element_symbol) then {
                let element_method_name = self.qualified_name(element_symbol)
                let receiver_arg = when self.def_id_map.get_signature(element_symbol.def_id) in {
                    .Some(sig) then {
                        yield if sig.param_types.count() > 0 then {
                            yield when sig.param_types.at((UInt)0) in {
                                .ReferenceType(_) then {
                                    let ref_result = self.next_temp_with_decl(self.c_type_name(sig.param_types.at((UInt)0)))
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).ptr = &\(result);\n")
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).control = NULL;\n")
                                    yield ref_result
                                },
                                .WeakReferenceType(_) then {
                                    let ref_result = self.next_temp_with_decl(self.c_type_name(sig.param_types.at((UInt)0)))
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).ptr = &\(result);\n")
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).control = NULL;\n")
                                    yield ref_result
                                },
                                _ then { yield result },
                            }
                        } else {
                            yield result
                        }
                    },
                    .None() then { yield result },
                }
                for elem_ref in elements then {
                    let elem = elem_ref
                    let elem_result = self.generate_expression_ssa(elem)
                    let is_lvalue = self.is_lvalue_expr(elem)
                    let final_elem = if is_lvalue and self.needs_drop(elem.expr_type) then {
                        let elem_c_type = self.c_type_name(elem.expr_type)
                        let copy_result = self.next_temp_with_decl(elem_c_type)
                        self.append_copy_assignment(elem.expr_type, elem_result, copy_result)
                        yield copy_result
                    } else {
                        yield elem_result
                    }
                    self.add_indent()
                    self.buffer.push_string("\(element_method_name)(\(receiver_arg), \(final_elem));\n")
                }
            },
            .None() then {
                let mut fallback_name = "std_\(sanitize_c_identifier(type_name))_push"
                if self.lookup_receiver_method(result_type, "insert") is .Some(_) then {
                    fallback_name = "std_\(sanitize_c_identifier(type_name))_insert"
                }
                for elem_ref in elements then {
                    let elem = elem_ref
                    let elem_result = self.generate_expression_ssa(elem)
                    self.add_indent()
                    self.buffer.push_string("\(fallback_name)(\(result), \(elem_result));\n")
                }
            },
        }

        return result
    }

    // ── DictLiteral 生成 ───────────────────────────────────────────────────────

    /// 生成 Dict 字面量的 C 代码
    ///
    /// [k1: v1, k2: v2] → Dict.new() + insert(k1, v1) + insert(k2, v2)
    ///
    /// Requirements: 5.36
    public generate_dict_literal(self ref, entries [TypedExprPair]List, result_type Type) String = {
        let type_name = self.receiver_type_lookup_name(result_type)
        let new_c_id_opt = self.lookup_static_method_c_id(type_name, "new")
        let c_type = self.c_type_name(result_type)

        let result = when new_c_id_opt in {
            .Some(new_name) then self.next_temp_with_init(c_type, "\(new_name)()"),
            .None() then self.next_temp_with_init(c_type, "Std_\(sanitize_c_identifier(type_name))_new()"),
        }

        let insert_method_opt = self.lookup_receiver_method(result_type, "insert")
        when insert_method_opt in {
            .Some(insert_symbol) then {
                let insert_name = self.qualified_name(insert_symbol)
                let receiver_arg = when self.def_id_map.get_signature(insert_symbol.def_id) in {
                    .Some(sig) then {
                        yield if sig.param_types.count() > 0 then {
                            yield when sig.param_types.at((UInt)0) in {
                                .ReferenceType(_) then {
                                    let ref_result = self.next_temp_with_decl(self.c_type_name(sig.param_types.at((UInt)0)))
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).ptr = &\(result);\n")
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).control = NULL;\n")
                                    yield ref_result
                                },
                                .WeakReferenceType(_) then {
                                    let ref_result = self.next_temp_with_decl(self.c_type_name(sig.param_types.at((UInt)0)))
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).ptr = &\(result);\n")
                                    self.add_indent()
                                    self.buffer.push_string("\(ref_result).control = NULL;\n")
                                    yield ref_result
                                },
                                _ then { yield result },
                            }
                        } else {
                            yield result
                        }
                    },
                    .None() then { yield result },
                }
                for entry in entries then {
                    let key = entry.first
                    let value = entry.second
                    let key_result = self.generate_expression_ssa(key)
                    let value_result = self.generate_expression_ssa(value)
                    let is_key_lvalue = self.is_lvalue_expr(key)
                    let final_key = if is_key_lvalue and self.needs_drop(key.expr_type) then {
                        let key_c_type = self.c_type_name(key.expr_type)
                        let copy_result = self.next_temp_with_decl(key_c_type)
                        self.append_copy_assignment(key.expr_type, key_result, copy_result)
                        yield copy_result
                    } else {
                        yield key_result
                    }
                    let is_val_lvalue = self.is_lvalue_expr(value)
                    let final_value = if is_val_lvalue and self.needs_drop(value.expr_type) then {
                        let val_c_type = self.c_type_name(value.expr_type)
                        let copy_result = self.next_temp_with_decl(val_c_type)
                        self.append_copy_assignment(value.expr_type, value_result, copy_result)
                        yield copy_result
                    } else {
                        yield value_result
                    }
                    self.add_indent()
                    self.buffer.push_string("\(insert_name)(\(receiver_arg), \(final_key), \(final_value));\n")
                }
            },
            .None() then {
                let insert_fallback = "std_\(sanitize_c_identifier(type_name))_insert"
                for entry in entries then {
                    let key = entry.first
                    let value = entry.second
                    let key_result = self.generate_expression_ssa(key)
                    let value_result = self.generate_expression_ssa(value)
                    self.add_indent()
                    self.buffer.push_string("\(insert_fallback)(\(result), \(key_result), \(value_result));\n")
                }
            },
        }

        return result
    }


    // ── 方法查找辅助方法 ──────────────────────────────────────────────────────

    /// 通过接收者类型和方法名查找方法符号
    ///
    /// 遍历 program.global_nodes 中的 GivenDecl/GivenTraitDecl，
    /// 找到匹配的方法并返回其 Symbol。
    lookup_receiver_method(self, receiver_type Type, method_name String) [Symbol]Option = {
        let base_type = receiver_type
        let lowered_receiver_type = self.normalize_vtable_receiver_type(base_type)
        let lowered_method_key = self.trait_impl_lookup_key(layout_key(lowered_receiver_type), "", method_name)
        when self.trait_impl_c_name_by_key_index.get(lowered_method_key) in {
            .Some(c_name) then {
                let def_id = self.def_id_by_c_name_index.get(c_name) or else DefId(0)
                let effective_return_type = when self.lookup_function_signature_by_c_name(c_name) in {
                    .Some(sig) then sig.return_type,
                    .None() then Type.Unknown(),
                }
                return [Symbol]Option.Some(Symbol(def_id, c_name, effective_return_type, SymbolKind.Function()))
            },
            .None() then {},
        }
        let generic_param_receiver = when base_type in {
            .GenericParameter(_) then true,
            _ then false,
        }
        let concrete_receiver = when base_type in {
            .StructureType(_) then true,
            .EnumType(_) then true,
            _ then false,
        }

        // StringType() は StructureType(String_def_id) と等価として扱う
        // type checker では String は StringType() として表現されるが、
        // GivenDecl では StructureType(String_def_id) として表現される
        let is_string_type = when base_type in {
            .StringType() then true,
            .StructureType(def_id) then {
                // StructureType で名前が "String" の場合も StringType として扱う
                yield when self.def_id_map.get_name(def_id) in {
                    .Some(n) then n == "String",
                    .None() then false,
                }
            },
            _ then false,
        }

        when base_type in {
            .StructureType(_) then {
                let type_prefix = when self.concrete_type_c_name(base_type) in {
                    .Some(name) then name,
                    .None() then self.receiver_type_lookup_name(base_type),
                }
                let expected_c_name = self.compose_method_c_name(type_prefix, method_name)
                let def_id_opt = when self.find_def_id_by_name(expected_c_name) in {
                    .Some(def_id) then [DefId]Option.Some(def_id),
                    .None() then self.find_def_id_by_c_name(expected_c_name),
                }
                when def_id_opt in {
                    .Some(def_id) then {
                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then Type.Unknown(),
                        }
                        return [Symbol]Option.Some(Symbol(
                            def_id,
                            expected_c_name,
                            effective_return_type,
                            SymbolKind.Function(),
                        ))
                    },
                    .None() then {},
                }
            },
            .EnumType(_) then {
                let type_prefix = when self.concrete_type_c_name(base_type) in {
                    .Some(name) then name,
                    .None() then self.receiver_type_lookup_name(base_type),
                }
                let expected_c_name = self.compose_method_c_name(type_prefix, method_name)
                let def_id_opt = when self.find_def_id_by_name(expected_c_name) in {
                    .Some(def_id) then [DefId]Option.Some(def_id),
                    .None() then self.find_def_id_by_c_name(expected_c_name),
                }
                when def_id_opt in {
                    .Some(def_id) then {
                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then Type.Unknown(),
                        }
                        return [Symbol]Option.Some(Symbol(
                            def_id,
                            expected_c_name,
                            effective_return_type,
                            SymbolKind.Function(),
                        ))
                    },
                    .None() then {},
                }
            },
            .GenericStruct(_, _) then {
                let layout_prefix = sanitize_c_identifier(layout_key(base_type))
                let layout_method_c_name = self.compose_method_c_name(layout_prefix, method_name)
                let layout_def_id_opt = when self.find_def_id_by_name(layout_method_c_name) in {
                    .Some(def_id) then [DefId]Option.Some(def_id),
                    .None() then self.find_def_id_by_c_name(layout_method_c_name),
                }
                when layout_def_id_opt in {
                    .Some(def_id) then {
                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then Type.Unknown(),
                        }
                        return [Symbol]Option.Some(Symbol(
                            def_id,
                            layout_method_c_name,
                            effective_return_type,
                            SymbolKind.Function(),
                        ))
                    },
                    .None() then {},
                }

                let type_prefix = when self.concrete_type_c_name(base_type) in {
                    .Some(name) then name,
                    .None() then sanitize_c_identifier(layout_key(base_type)),
                }
                let expected_c_name = self.compose_method_c_name(type_prefix, method_name)
                let def_id_opt = when self.find_def_id_by_name(expected_c_name) in {
                    .Some(def_id) then [DefId]Option.Some(def_id),
                    .None() then self.find_def_id_by_c_name(expected_c_name),
                }
                when def_id_opt in {
                    .Some(def_id) then {
                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then Type.Unknown(),
                        }
                        return [Symbol]Option.Some(Symbol(
                            def_id,
                            expected_c_name,
                            effective_return_type,
                            SymbolKind.Function(),
                        ))
                    },
                    .None() then {},
                }
            },
            .GenericEnum(_, _) then {
                let layout_prefix = sanitize_c_identifier(layout_key(base_type))
                let layout_method_c_name = self.compose_method_c_name(layout_prefix, method_name)
                let layout_def_id_opt = when self.find_def_id_by_name(layout_method_c_name) in {
                    .Some(def_id) then [DefId]Option.Some(def_id),
                    .None() then self.find_def_id_by_c_name(layout_method_c_name),
                }
                when layout_def_id_opt in {
                    .Some(def_id) then {
                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then Type.Unknown(),
                        }
                        return [Symbol]Option.Some(Symbol(
                            def_id,
                            layout_method_c_name,
                            effective_return_type,
                            SymbolKind.Function(),
                        ))
                    },
                    .None() then {},
                }

                let type_prefix = when self.concrete_type_c_name(base_type) in {
                    .Some(name) then name,
                    .None() then sanitize_c_identifier(layout_key(base_type)),
                }
                let expected_c_name = self.compose_method_c_name(type_prefix, method_name)
                let def_id_opt = when self.find_def_id_by_name(expected_c_name) in {
                    .Some(def_id) then [DefId]Option.Some(def_id),
                    .None() then self.find_def_id_by_c_name(expected_c_name),
                }
                when def_id_opt in {
                    .Some(def_id) then {
                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                            .Some(sig) then sig.return_type,
                            .None() then Type.Unknown(),
                        }
                        return [Symbol]Option.Some(Symbol(
                            def_id,
                            expected_c_name,
                            effective_return_type,
                            SymbolKind.Function(),
                        ))
                    },
                    .None() then {},
                }
            },
            _ then {},
        }

        for node in self.program.global_nodes then {
            when node in {
                .GivenDecl(target_type, members, _) then {
                    // StringType の場合、StructureType で名前が "String" のものもマッチ
                    // また StringType() 自体もマッチ
                    let types_match = if is_string_type then {
                        yield when target_type in {
                            .StructureType(def_id) then {
                                yield when self.def_id_map.get_name(def_id) in {
                                    .Some(n) then n == "String",
                                    .None() then false,
                                }
                            },
                            .StringType() then true,
                            _ then false,
                        }
                    } else {
                        // GenericParameter（例如 given[W Writer] 中的 W）
                        // 在 codegen 阶段不再携带约束信息；
                        // 允许其匹配 TraitObject given，以便解析 W.write / W.write_all。
                        let generic_param_match = if generic_param_receiver then when target_type in {
                            .TraitObject(_) then true,
                            _ then false,
                        } else false
                        let trait_target_match = when target_type in {
                            .TraitObject(trait_name) then self.receiver_has_trait_conformance(base_type, trait_name, is_string_type),
                            _ then false,
                        }
                        // 先尝试精确匹配（def_id 相同）
                        let exact_match = if generic_param_match then false else self.codegen_types_equal(target_type, base_type)
                        let template_match = if exact_match then false else {
                            yield when target_type in {
                                .GenericStruct(target_template, target_args) then {
                                    yield when base_type in {
                                        .GenericStruct(base_template, base_args) then target_template == base_template and target_args.count() == base_args.count(),
                                        .StructureType(_) then {
                                            let display_name = self.def_id_map.type_display_name(base_type)
                                            let lookup_name = self.receiver_type_lookup_name(base_type)
                                            let concrete_name = when self.concrete_type_c_name(base_type) in {
                                                .Some(name) then name,
                                                .None() then "",
                                            }
                                            yield display_name == target_template or display_name.starts_with(target_template) or lookup_name == target_template or lookup_name.starts_with(target_template) or concrete_name == target_template or concrete_name.starts_with(target_template + "_")
                                        },
                                        _ then false,
                                    }
                                },
                                .GenericEnum(target_template, target_args) then {
                                    yield when base_type in {
                                        .GenericEnum(base_template, base_args) then target_template == base_template and target_args.count() == base_args.count(),
                                        .EnumType(_) then {
                                            let display_name = self.def_id_map.type_display_name(base_type)
                                            let lookup_name = self.receiver_type_lookup_name(base_type)
                                            let concrete_name = when self.concrete_type_c_name(base_type) in {
                                                .Some(name) then name,
                                                .None() then "",
                                            }
                                            yield display_name == target_template or display_name.starts_with(target_template) or lookup_name == target_template or lookup_name.starts_with(target_template) or concrete_name == target_template or concrete_name.starts_with(target_template + "_")
                                        },
                                        _ then false,
                                    }
                                },
                                _ then false,
                            }
                        }
                        // 如果精确匹配失败，尝试名称匹配（适用于泛型类型，如 [T]List 和 [UInt8]List 都叫 "List"）
                        let name_match = if exact_match then false else if self.type_contains_generic(target_type) then false else {
                            let target_name = when target_type in {
                                .StructureType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .EnumType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .GenericStruct(template, _) then template,
                                .GenericEnum(template, _) then template,
                                .StringType() then "String",
                                _ then "",
                            }
                            let base_name = when base_type in {
                                .StructureType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .EnumType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .GenericStruct(template, _) then template,
                                .GenericEnum(template, _) then template,
                                .StringType() then "String",
                                _ then "",
                            }
                            let direct = target_name <> "" and target_name == base_name
                            let mono_from_base = target_name <> "" and base_name <> "" and target_name.starts_with(base_name + "_")
                            let generic_from_target = target_name <> "" and base_name <> "" and base_name.starts_with(target_name + "_")
                            let compatible = if concrete_receiver then direct or generic_from_target else direct or mono_from_base or generic_from_target
                            yield compatible
                        }
                        yield generic_param_match or trait_target_match or exact_match or template_match or name_match
                    }
                    let module_compatible = when target_type in {
                        .StructureType(target_def_id) then {
                            yield when base_type in {
                                .StructureType(base_def_id) then {
                                    let target_module = self.def_id_map.get_module_path(target_def_id) or else [String]List.new()
                                    let base_module = self.def_id_map.get_module_path(base_def_id) or else [String]List.new()
                                    yield self.module_paths_equal(target_module, base_module)
                                },
                                _ then true,
                            }
                        },
                        .EnumType(target_def_id) then {
                            yield when base_type in {
                                .EnumType(base_def_id) then {
                                    let target_module = self.def_id_map.get_module_path(target_def_id) or else [String]List.new()
                                    let base_module = self.def_id_map.get_module_path(base_def_id) or else [String]List.new()
                                    yield self.module_paths_equal(target_module, base_module)
                                },
                                _ then true,
                            }
                        },
                        _ then true,
                    }
                    if types_match and module_compatible then {
                        for m in members then {
                            if m.name == method_name then {
                                // 用 target_type 的 C 名称 + 方法名構建正確的 C 標識符
                                let target_is_generic_template = self.type_contains_generic(target_type)
                                let base_is_concrete_instance = not self.type_contains_generic(base_type)
                                let target_is_trait_tool = when target_type in {
                                    .TraitObject(_) then true,
                                    _ then false,
                                }
                                let prefer_concrete_c_name = target_is_trait_tool or (target_is_generic_template and base_is_concrete_instance)
                                let type_c_name = if prefer_concrete_c_name then {
                                    yield when self.concrete_type_c_name(base_type) in {
                                        .Some(name) then name,
                                        .None() then sanitize_c_identifier(layout_key(base_type)),
                                    }
                                } else {
                                    yield when self.concrete_type_c_name(target_type) in {
                                        .Some(name) then {
                                            yield if name.starts_with("_k__k__") then name.substring(3...) else name
                                        },
                                        .None() then {
                                            let display = self.def_id_map.type_display_name(target_type)
                                            yield if display.starts_with("_k__") then display else sanitize_c_identifier(display)
                                        },
                                    }
                                }
                                let expected_c_name = self.compose_method_c_name(type_c_name, m.name)
                                let receiver_bindings = self.build_receiver_bindings(target_type, base_type)
                                let bound_return_type = self.apply_codegen_type_bindings(m.return_type, receiver_bindings)
                                // 在 c_identifier_by_def_id 中查找匹配的 DefId
                                let def_id_opt = self.find_def_id_by_c_name(expected_c_name)
                                when def_id_opt in {
                                    .Some(def_id) then {
                                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                                            .Some(sig) then self.apply_codegen_type_bindings(sig.return_type, receiver_bindings),
                                            .None() then bound_return_type,
                                        }
                                        return [Symbol]Option.Some(Symbol(
                                            def_id,
                                            expected_c_name,
                                            effective_return_type,
                                            SymbolKind.Function(),
                                        ))
                                    },
                                    .None() then {},
                                }
                            }
                        }
                    }
                },
                .GivenTraitDecl(target_type, _, _, members, _) then {
                    let types_match = if is_string_type then {
                        yield when target_type in {
                            .StructureType(def_id) then {
                                yield when self.def_id_map.get_name(def_id) in {
                                    .Some(n) then n == "String",
                                    .None() then false,
                                }
                            },
                            .StringType() then true,
                            _ then false,
                        }
                    } else {
                        let generic_trait_compatible = if generic_param_receiver then when target_type in {
                            .TraitObject(_) then true,
                            _ then false,
                        } else false
                        // 先尝试精确匹配（def_id 相同）
                        let exact_match = if generic_trait_compatible then true else self.codegen_types_equal(target_type, base_type)
                        let template_match = if exact_match then false else {
                            yield when target_type in {
                                .GenericStruct(target_template, target_args) then {
                                    yield when base_type in {
                                        .GenericStruct(base_template, base_args) then target_template == base_template and target_args.count() == base_args.count(),
                                        .StructureType(_) then {
                                            let display_name = self.def_id_map.type_display_name(base_type)
                                            let lookup_name = self.receiver_type_lookup_name(base_type)
                                            let concrete_name = when self.concrete_type_c_name(base_type) in {
                                                .Some(name) then name,
                                                .None() then "",
                                            }
                                            yield display_name == target_template or display_name.starts_with(target_template) or lookup_name == target_template or lookup_name.starts_with(target_template) or concrete_name == target_template or concrete_name.starts_with(target_template + "_")
                                        },
                                        _ then false,
                                    }
                                },
                                .GenericEnum(target_template, target_args) then {
                                    yield when base_type in {
                                        .GenericEnum(base_template, base_args) then target_template == base_template and target_args.count() == base_args.count(),
                                        .EnumType(_) then {
                                            let display_name = self.def_id_map.type_display_name(base_type)
                                            let lookup_name = self.receiver_type_lookup_name(base_type)
                                            let concrete_name = when self.concrete_type_c_name(base_type) in {
                                                .Some(name) then name,
                                                .None() then "",
                                            }
                                            yield display_name == target_template or display_name.starts_with(target_template) or lookup_name == target_template or lookup_name.starts_with(target_template) or concrete_name == target_template or concrete_name.starts_with(target_template + "_")
                                        },
                                        _ then false,
                                    }
                                },
                                _ then false,
                            }
                        }
                        // 如果精确匹配失败，尝试名称匹配（适用于泛型类型）
                        let name_match = if exact_match then false else if self.type_contains_generic(target_type) then false else {
                            let target_name = when target_type in {
                                .StructureType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .EnumType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .GenericStruct(template, _) then template,
                                .GenericEnum(template, _) then template,
                                .StringType() then "String",
                                _ then "",
                            }
                            let base_name = when base_type in {
                                .StructureType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .EnumType(def_id) then self.def_id_map.get_name(def_id) or else "",
                                .GenericStruct(template, _) then template,
                                .GenericEnum(template, _) then template,
                                .StringType() then "String",
                                _ then "",
                            }
                            let direct = target_name <> "" and target_name == base_name
                            let mono_from_base = target_name <> "" and base_name <> "" and target_name.starts_with(base_name + "_")
                            let generic_from_target = target_name <> "" and base_name <> "" and base_name.starts_with(target_name + "_")
                            yield if concrete_receiver then direct or generic_from_target else direct or mono_from_base or generic_from_target
                        }
                        yield exact_match or template_match or name_match
                    }
                    let module_compatible = when target_type in {
                        .StructureType(target_def_id) then {
                            yield when base_type in {
                                .StructureType(base_def_id) then {
                                    let target_module = self.def_id_map.get_module_path(target_def_id) or else [String]List.new()
                                    let base_module = self.def_id_map.get_module_path(base_def_id) or else [String]List.new()
                                    yield self.module_paths_equal(target_module, base_module)
                                },
                                _ then true,
                            }
                        },
                        .EnumType(target_def_id) then {
                            yield when base_type in {
                                .EnumType(base_def_id) then {
                                    let target_module = self.def_id_map.get_module_path(target_def_id) or else [String]List.new()
                                    let base_module = self.def_id_map.get_module_path(base_def_id) or else [String]List.new()
                                    yield self.module_paths_equal(target_module, base_module)
                                },
                                _ then true,
                            }
                        },
                        _ then true,
                    }
                    if types_match and module_compatible then {
                        for m in members then {
                            if m.name == method_name then {
                                // 用 target_type 的 C 名称 + 方法名構建正確的 C 標識符
                                let target_is_generic_template = self.type_contains_generic(target_type)
                                let base_is_concrete_instance = not self.type_contains_generic(base_type)
                                let prefer_concrete_c_name = target_is_generic_template and base_is_concrete_instance
                                let type_c_name = if target_is_generic_template then {
                                    yield when self.concrete_type_c_name(base_type) in {
                                        .Some(name) then name,
                                        .None() then sanitize_c_identifier(layout_key(base_type)),
                                    }
                                } else {
                                    yield when self.concrete_type_c_name(target_type) in {
                                        .Some(name) then {
                                            yield if name.starts_with("_k__k__") then name.substring(3...) else name
                                        },
                                        .None() then {
                                            let display = self.def_id_map.type_display_name(target_type)
                                            yield if display.starts_with("_k__") then display else sanitize_c_identifier(display)
                                        },
                                    }
                                }
                                let expected_c_name = self.compose_method_c_name(type_c_name, m.name)
                                let receiver_bindings = self.build_receiver_bindings(target_type, base_type)
                                let bound_return_type = self.apply_codegen_type_bindings(m.return_type, receiver_bindings)
                                // 在 c_identifier_by_def_id 中查找匹配的 DefId
                                let def_id_opt = self.find_def_id_by_c_name(expected_c_name)
                                when def_id_opt in {
                                    .Some(def_id) then {
                                        let effective_return_type = when self.def_id_map.get_signature(def_id) in {
                                            .Some(sig) then self.apply_codegen_type_bindings(sig.return_type, receiver_bindings),
                                            .None() then bound_return_type,
                                        }
                                        return [Symbol]Option.Some(Symbol(
                                            def_id,
                                            expected_c_name,
                                            effective_return_type,
                                            SymbolKind.Function(),
                                        ))
                                    },
                                    .None() then {},
                                }
                            }
                        }
                    }
                },
                _ then {},
            }
        }
        return when receiver_type in {
            .ReferenceType(inner_ref) then self.lookup_receiver_method(inner_ref.val, method_name),
            _ then [Symbol]Option.None(),
        }
    }

    /// 生成类型零值初始化表达式。
    zero_init_expr_for_type(self, t Type) String = {
        let c_type = self.c_type_name(t)
        return when t in {
            .StructureType(_) then "(\(c_type)){0}",
            .EnumType(_) then "(\(c_type)){0}",
            .GenericStruct(_, _) then "(\(c_type)){0}",
            .GenericEnum(_, _) then "(\(c_type)){0}",
            .ReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitRef){0}",
                            _ then "(struct __koral_Ref){0}",
                        },
                        .None() then "(struct __koral_Ref){0}",
                    },
                    _ then "(struct __koral_Ref){0}",
                }
            },
            .TraitObject(_) then "(struct __koral_TraitRef){0}",
            .FunctionType(_, _) then "(struct __koral_Closure){0}",
            .PointerType(_) then "NULL",
            .WeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                    .OpaqueType(def_id) then when self.def_id_map.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_) then "(struct __koral_TraitWeakRef){0}",
                            _ then "(struct __koral_WeakRef){0}",
                        },
                        .None() then "(struct __koral_WeakRef){0}",
                    },
                    _ then "(struct __koral_WeakRef){0}",
                }
            },
            .StringType() then "(\(c_type)){0}",
            .VoidType() then "",
            .NeverType() then "",
            _ then "(\(c_type))0",
        }
    }

    /// 通过类型名和方法名查找静态方法的 C 标识符
    lookup_static_method_c_id(self, type_name String, method_name String) [String]Option = {
        let indexed_key = self.static_method_lookup_key(type_name, method_name)
        when self.static_method_c_name_by_key_index.get(indexed_key) in {
            .Some(c_name) then { return [String]Option.Some(c_name) },
            .None() then {},
        }
        let def_id_opt = self.program.lookup_static_method(type_name, method_name)
        when def_id_opt in {
            .Some(def_id) then {
                when self.c_identifier_by_def_id.get(def_id.id) in {
                    .Some(c_name) then {
                        let normalized = if c_name.starts_with("_k__k__") then c_name.substring(3...) else c_name
                        return [String]Option.Some(normalized)
                    },
                    .None() then {},
                }
            },
            .None() then {},
        }

        return [String]Option.None()
    }

    /// 获取类型的接收者查找名称（用于方法查找）
    receiver_type_lookup_name(self, t Type) String = {
        return when t in {
            .ReferenceType(inner_ref) then self.receiver_type_lookup_name(inner_ref.val),
            .StructureType(def_id) then {
                yield when self.def_id_map.get_name(def_id) in {
                    .Some(name) then name,
                    .None() then "T_\(def_id.id)",
                }
            },
            .EnumType(def_id) then {
                yield when self.def_id_map.get_name(def_id) in {
                    .Some(name) then name,
                    .None() then "U_\(def_id.id)",
                }
            },
            .GenericStruct(template, _) then template,
            .GenericEnum(template, _) then template,
            .StringType() then "String",
            .IntType() then "Int",
            .Int8Type() then "Int8",
            .Int16Type() then "Int16",
            .Int32Type() then "Int32",
            .Int64Type() then "Int64",
            .UIntType() then "UInt",
            .UInt8Type() then "UInt8",
            .UInt16Type() then "UInt16",
            .UInt32Type() then "UInt32",
            .UInt64Type() then "UInt64",
            .Float32Type() then "Float32",
            .Float64Type() then "Float64",
            .BoolType() then "Bool",
            .RuneType() then "Rune",
            .OpaqueType(def_id) then {
                yield when self.def_id_map.lookup_type(def_id) in {
                    .Some(mapped_type) then self.receiver_type_lookup_name(mapped_type),
                    .None() then when self.def_id_map.get_name(def_id) in {
                        .Some(name) then name,
                        .None() then self.def_id_map.type_display_name(t),
                    },
                }
            },
            _ then "Unknown",
        }
    }
}


/// 将 UInt8 格式化为 C 十六进制字节字面量，如 "0x41"
let format_hex_byte(b UInt8) String = {
    let hex_chars = "0123456789ABCDEF"
    let hi = (UInt)(b >> 4)
    let lo = (UInt)(b & (UInt8)0x0F)
    let hi_char = hex_chars.at(hi)
    let lo_char = hex_chars.at(lo)
    let mut result = "0x"
    result.push_byte(hi_char)
    result.push_byte(lo_char)
    return result
}

/// 将 Rune 字面量字符串转换为 C uint32_t 数值字符串
/// value 是原始字符（如 ":" 对应 58）
let rune_literal_to_c_value(value String) String = {
    let bytes = value.to_bytes()
    if bytes.is_empty() then {
        return "0"
    }
    let b0 = (UInt)bytes.at(0)
    // ASCII 字符：直接使用字节值
    if b0 < 128 then {
        return b0.to_string()
    }
    // 2-byte UTF-8: 110xxxxx 10xxxxxx
    if b0 < 224 and bytes.count() >= 2 then {
        let b1 = (UInt)bytes.at(1)
        let cp = ((b0 & 31) << 6) | (b1 & 63)
        return cp.to_string()
    }
    // 3-byte UTF-8: 1110xxxx 10xxxxxx 10xxxxxx
    if b0 < 240 and bytes.count() >= 3 then {
        let b1 = (UInt)bytes.at(1)
        let b2 = (UInt)bytes.at(2)
        let cp = ((b0 & 15) << 12) | ((b1 & 63) << 6) | (b2 & 63)
        return cp.to_string()
    }
    // 4-byte UTF-8: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx
    if b0 < 248 and bytes.count() >= 4 then {
        let b1 = (UInt)bytes.at(1)
        let b2 = (UInt)bytes.at(2)
        let b3 = (UInt)bytes.at(3)
        let cp = ((b0 & 7) << 18) | ((b1 & 63) << 12) | ((b2 & 63) << 6) | (b3 & 63)
        return cp.to_string()
    }
    return b0.to_string()
}