// codegen_expressions_dispatch.koral - 方法分发代码生成
//
// 实现 CodeGen 的静态方法调用、泛型方法调用、限定方法调用、
given CodeGen {
    private push_static_method_lookup_alias(self, aliases List[String], alias String) List[String] = {
        let _ = self
        if alias.is_empty() then {
            return aliases
        }
        for existing in aliases then {
            if existing == alias then {
                return aliases
            }
        }
        let mut updated = aliases
        updated.push(alias)
        return updated
    }

    private static_method_lookup_aliases(self, receiver_type Type) List[String] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let mut aliases = List[String].new()
        aliases = self.push_static_method_lookup_alias(aliases, self.concrete_receiver_lookup_key(concrete_receiver_type))
        aliases = self.push_static_method_lookup_alias(aliases, self.receiver_type_lookup_name_fallback(concrete_receiver_type))

        when concrete_receiver_type in {
            .GenericStruct(template_name, _) then {
                aliases = self.push_static_method_lookup_alias(aliases, template_name)
            },
            .GenericEnum(template_name, _) then {
                aliases = self.push_static_method_lookup_alias(aliases, template_name)
            },
            _ then {},
        }

        return aliases
    }

    private trait_dispatch_type_opt(self, receiver_type Type) Option[Type] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        return when concrete_receiver_type in {
            .TraitObject(_, _) then Option[Type].Some(concrete_receiver_type),
            .OpaqueType(def_id) then when self.context.lookup_type(def_id) in {
                .Some(mapped_type) then when mapped_type in {
                    .TraitObject(_, _) then Option[Type].Some(mapped_type),
                    _ then Option[Type].None(),
                },
                .None() then Option[Type].None(),
            },
            .ReferenceType(inner_ref) then self.trait_dispatch_type_opt(inner_ref.val),
            .MutableReferenceType(inner_ref) then self.trait_dispatch_type_opt(inner_ref.val),
            .WeakReferenceType(inner_ref) then self.trait_dispatch_type_opt(inner_ref.val),
            .MutableWeakReferenceType(inner_ref) then self.trait_dispatch_type_opt(inner_ref.val),
            _ then Option[Type].None(),
        }
    }

    private requested_or_symbol_result_type(self, requested_result_type Type, symbol_type Type) Type = {
        return when requested_result_type in {
            .Unknown() then symbol_type,
            .VoidType() then {
                yield when symbol_type in {
                    .VoidType() then requested_result_type,
                    .NeverType() then requested_result_type,
                    .Unknown() then requested_result_type,
                    _ then symbol_type,
                }
            },
            _ then requested_result_type,
        }
    }

    private semantic_receiver_method_name(self, method ref Symbol) Option[String] = {
        if method.def_id.id == 0 then {
            return Option[String].None()
        }

        // Primary: structured dispatch info from sema/mono
        when self.program.semantic_receiver_method_dispatch().get(method.def_id.id) in {
            .Some(info) then {
                return Option[String].Some(info.method_name)
            },
            .None() then {},
        }

        // Fallback: concrete callable metadata from mono
        when self.program.lookup_concrete_callable(method.def_id) in {
            .Some(info) then {
                return Option[String].Some(info.logical_name)
            },
            .None() then {},
        }

        // Last resort: name from context
        return self.context.get_name(method.def_id)
    }

    private preferred_receiver_method_result_type(self, requested_result_type Type, symbol_type Type) Type = {
        if self.type_contains_generic(requested_result_type) and not self.type_contains_generic(symbol_type) then {
            return symbol_type
        }
        return self.requested_or_symbol_result_type(requested_result_type, symbol_type)
    }

    private direct_callable_symbol(self, method ref Symbol) Option[Symbol] = {
        if method.def_id.id == 0 then {
            return Option[Symbol].None()
        }
        return when self.c_identifier_opt(method.def_id) in {
            .Some(_) then Option[Symbol].Some(Symbol(method.def_id, method.symbol_type, method.kind)),
            .None() then Option[Symbol].None(),
        }
    }

    private is_raw_trait_method(self, trait_name String, method_name String) Bool = {
        let raw_members = self.get_ordered_raw_trait_members(trait_name)
        for member in raw_members then {
            if member.name == method_name then {
                return true
            }
        }
        return false
    }

    private concrete_callable_symbol(self, def_id DefId, requested_result_type Type) Option[Symbol] = {
        return when self.c_identifier_opt(def_id) in {
            .Some(c_name) then {
                let result_type = when self.context.get_function_return_type(def_id) in {
                    .Some(return_type) then self.requested_or_symbol_result_type(requested_result_type, return_type),
                    .None() then requested_result_type,
                }
                yield Option[Symbol].Some(Symbol(def_id, result_type, SymbolKind.Function()))
            },
            .None() then Option[Symbol].None(),
        }
    }

    private require_bound_concrete_method_symbol(self, def_id DefId, receiver_type Type, requested_result_type Type, error_context String) Symbol = {
        return self.bound_concrete_method_symbol(def_id, receiver_type, requested_result_type)
            or else panic("CodeGen dispatch error: unresolved concrete method symbol for \(error_context) (def #\(def_id.id))")
    }

    private method_signature_compatible_with_call(
        self,
        def_id DefId,
        receiver_type Type,
        args List[ref TypedExpr],
        requested_result_type Type,
    ) Bool = {
        return when self.context.get_function_type(def_id) in {
            .Some(raw_function_type) then {
                let function_type = self.bind_method_function_type(def_id, receiver_type, raw_function_type)
                let param_count = self.function_type_param_count(function_type)
                if param_count <> args.count() and param_count <> args.count() + 1(UInt) then {
                    return false
                }
                if param_count == args.count() + 1(UInt) then {
                    let receiver_param_type = self.function_type_param_type(function_type, 0(UInt)) or else Type.Unknown()
                    if not self.receiver_param_type_matches_call_receiver(receiver_param_type, receiver_type) then {
                        return false
                    }
                }
                let arg_offset = if param_count == args.count() then 0(UInt) else 1(UInt)
                let mut arg_index UInt = 0
                while arg_index < args.count() then {
                    let expected_type = self.function_type_param_type(function_type, arg_index + arg_offset) or else Type.Unknown()
                    if not self.codegen_argument_type_compatible(expected_type, args[arg_index].val.expr_type) then {
                        return false
                    }
                    arg_index += 1
                }
                let concrete_requested_result = self.concretize_codegen_type(requested_result_type)
                if not self.type_contains_generic(concrete_requested_result)
                    and not is_placeholder_inferred_type(concrete_requested_result)
                then when concrete_requested_result in {
                    .Unknown() then {},
                    .VoidType() then {},
                    _ then {
                        let concrete_return_type = self.concretize_codegen_type(self.function_type_return_type(function_type))
                        if not self.codegen_types_equal(concrete_return_type, concrete_requested_result) then {
                            return false
                        }
                    },
                }
                return true
            },
            .None() then false,
        }
    }

    private receiver_param_type_matches_call_receiver(self, receiver_param_type Type, receiver_type Type) Bool = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        return when receiver_param_type in {
            .ReferenceType(inner_ref) then when concrete_receiver_type in {
                .ReferenceType(actual_inner) then self.concrete_receiver_lookup_key(inner_ref.val) == self.concrete_receiver_lookup_key(actual_inner.val),
                .MutableReferenceType(actual_inner) then self.concrete_receiver_lookup_key(inner_ref.val) == self.concrete_receiver_lookup_key(actual_inner.val),
                _ then false,
            },
            .MutableReferenceType(inner_ref) then when concrete_receiver_type in {
                .MutableReferenceType(actual_inner) then self.concrete_receiver_lookup_key(inner_ref.val) == self.concrete_receiver_lookup_key(actual_inner.val),
                _ then false,
            },
            .WeakReferenceType(inner_ref) then when concrete_receiver_type in {
                .WeakReferenceType(actual_inner) then self.concrete_receiver_lookup_key(inner_ref.val) == self.concrete_receiver_lookup_key(actual_inner.val),
                .MutableWeakReferenceType(actual_inner) then self.concrete_receiver_lookup_key(inner_ref.val) == self.concrete_receiver_lookup_key(actual_inner.val),
                _ then false,
            },
            .MutableWeakReferenceType(inner_ref) then when concrete_receiver_type in {
                .MutableWeakReferenceType(actual_inner) then self.concrete_receiver_lookup_key(inner_ref.val) == self.concrete_receiver_lookup_key(actual_inner.val),
                _ then false,
            },
            _ then self.concrete_receiver_lookup_key(receiver_param_type) == self.concrete_receiver_lookup_key(concrete_receiver_type),
        }
    }

    private codegen_argument_type_compatible(self, expected_type Type, actual_type Type) Bool = {
        let concrete_expected = self.concretize_codegen_type(expected_type)
        let concrete_actual = self.concretize_codegen_type(actual_type)
        if self.codegen_types_equal(concrete_expected, concrete_actual) then {
            return true
        }

        when concrete_expected in {
            .FunctionType(expected_params, expected_return_type) then when concrete_actual in {
                .FunctionType(actual_params, actual_return_type) then {
                    let expected_param_types = param_entry_types(expected_params)
                    let actual_param_types = param_entry_types(actual_params)
                    if expected_param_types.count() <> actual_param_types.count() then {
                        return false
                    }
                    let mut param_index UInt = 0
                    while param_index < expected_param_types.count() then {
                        if not self.codegen_types_equal(
                            self.concretize_codegen_type(expected_param_types[param_index].val),
                            self.concretize_codegen_type(actual_param_types[param_index].val)
                        ) then {
                            return false
                        }
                        param_index += 1
                    }
                    return self.codegen_types_equal(
                        self.concretize_codegen_type(expected_return_type.val),
                        self.concretize_codegen_type(actual_return_type.val)
                    )
                },
                _ then {},
            },
            _ then {},
        }

        let expected_c_type = self.c_type_name(concrete_expected)
        let actual_c_type = self.c_type_name(concrete_actual)
        if expected_c_type == "struct __koral_Closure" and actual_c_type == "struct __koral_Closure" then {
            return true
        }
        return false
    }

    private bound_concrete_method_symbol(self, def_id DefId, receiver_type Type, requested_result_type Type) Option[Symbol] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let bound_result_type = when self.context.get_function_type(def_id) in {
            .Some(function_type) then self.function_type_return_type(self.bind_method_function_type(def_id, concrete_receiver_type, function_type)),
            .None() then requested_result_type,
        }
        return self.concrete_callable_symbol(def_id, bound_result_type)
    }

    private lookup_receiver_method_def_id(self, receiver_type Type, method_name String) Option[DefId] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let concrete_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        let direct_indexed_key = "\(concrete_key).\(method_name)"
        when self.program.lookup_receiver_method_by_indexed_key(direct_indexed_key) in {
            .Some(def_id) then { return Option[DefId].Some(def_id) },
            .None() then {},
        }
        // Try simple name first (matches Swift's context.getName(defId))
        let receiver_key = self.receiver_type_lookup_name_fallback(concrete_receiver_type)
        let indexed_key = "\(receiver_key).\(method_name)"
        when self.program.lookup_receiver_method_by_indexed_key(indexed_key) in {
            .Some(def_id) then { return Option[DefId].Some(def_id) },
            .None() then {},
        }
        // Try template name for generic instantiations (e.g. "List" for "List_Std_String")
        // This matches Swift's dual lookup with [qualifiedName, plainName].
        when concrete_receiver_type in {
            .GenericStruct(template_name, _) then {
                if template_name <> receiver_key then {
                    let template_key = "\(template_name).\(method_name)"
                    when self.program.lookup_receiver_method_by_indexed_key(template_key) in {
                        .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                        .None() then {},
                    }
                }
            },
            .GenericEnum(template_name, _) then {
                if template_name <> receiver_key then {
                    let template_key = "\(template_name).\(method_name)"
                    when self.program.lookup_receiver_method_by_indexed_key(template_key) in {
                        .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                        .None() then {},
                    }
                }
            },
            .StructureType(def_id) then {
                when self.context.get_template_name(def_id) in {
                    .Some(template_name) then {
                        if template_name <> receiver_key then {
                            let template_key = "\(template_name).\(method_name)"
                            when self.program.lookup_receiver_method_by_indexed_key(template_key) in {
                                .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                                .None() then {},
                            }
                        }
                    },
                    .None() then {},
                }
            },
            .EnumType(def_id) then {
                when self.context.get_template_name(def_id) in {
                    .Some(template_name) then {
                        if template_name <> receiver_key then {
                            let template_key = "\(template_name).\(method_name)"
                            when self.program.lookup_receiver_method_by_indexed_key(template_key) in {
                                .Some(found_def_id) then { return Option[DefId].Some(found_def_id) },
                                .None() then {},
                            }
                        }
                    },
                    .None() then {},
                }
            },
            _ then {},
        }
        return Option[DefId].None()
    }

    private lookup_trait_method_def_id(self, concrete_type Type, trait_name String, method_name String) Option[DefId] = {
        let concrete_receiver_type = self.concretize_codegen_type(concrete_type)
        let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        return when self.program.lookup_trait_method(receiver_key, trait_name, method_name) in {
            .Some(def_id) then Option[DefId].Some(def_id),
            .None() then when self.program.semantic_traits().get(trait_name) in {
                .Some(trait_info) then {
                    let mut found = Option[DefId].None()
                    for parent_trait_name in trait_info.parent_traits then {
                        found = self.lookup_trait_method_def_id(concrete_receiver_type, parent_trait_name.name, method_name)
                        if found is .Some(_) then { break }
                    }
                    yield found
                },
                .None() then Option[DefId].None(),
            },
        }
    }

    private lookup_static_method_symbol(self, receiver_type Type, method_name String, requested_result_type Type) Option[Symbol] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        for alias in self.static_method_lookup_aliases(concrete_receiver_type) then {
            when self.program.lookup_static_method(alias, method_name) in {
                .Some(def_id) then {
                    return self.bound_concrete_method_symbol(def_id, concrete_receiver_type, requested_result_type)
                },
                .None() then {},
            }
        }
        return when self.lookup_receiver_method_def_id(concrete_receiver_type, method_name) in {
            .Some(def_id) then self.bound_concrete_method_symbol(def_id, concrete_receiver_type, requested_result_type),
            .None() then Option[Symbol].None(),
        }
    }

    private try_generate_receiver_dispatch_call(self mut ref, base ref TypedExpr, base_type Type, args List[ref TypedExpr], requested_result_type Type, dispatch_callsite Option[DefId]) Option[String] = {
        return when dispatch_callsite in {
            .Some(callsite_def_id) then when self.program.semantic_receiver_method_dispatch().get(callsite_def_id.id) in {
                .Some(dispatch_info) then {
                    if not self.method_signature_compatible_with_call(dispatch_info.method_def_id, base_type, args, requested_result_type) then {
                        return Option[String].None()
                    }
                    yield when self.bound_concrete_method_symbol(dispatch_info.method_def_id, base_type, requested_result_type) in {
                        .Some(dispatch_symbol) then {
                            let dispatch_result_type = self.requested_or_symbol_result_type(requested_result_type, dispatch_symbol.symbol_type)
                            yield Option[String].Some(self.generate_receiver_method_call(base, base_type, box(dispatch_symbol), args, dispatch_result_type))
                        },
                        .None() then Option[String].None(),
                    }
                },
                .None() then Option[String].None(),
            },
            .None() then Option[String].None(),
        }
    }

    private lookup_receiver_method_via_metadata(self, receiver_type Type, method_name String, requested_result_type Type) Option[Symbol] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        when self.lookup_receiver_method_def_id(concrete_receiver_type, method_name) in {
            .Some(def_id) then {
                if not self.receiver_method_matches_lookup(def_id, concrete_receiver_type) then {
                    return Option[Symbol].None()
                }
                return self.bound_concrete_method_symbol(def_id, concrete_receiver_type, requested_result_type)
            },
            .None() then {},
        }
        return Option[Symbol].None()
    }

    private receiver_method_matches_lookup(self, def_id DefId, receiver_type Type) Bool = {
        if self.program.semantic_receiver_method_dispatch().get(def_id.id) is .Some(_) then {
            return true
        }

        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let concrete_receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
        when self.method_owner_type(def_id) in {
            .Some(owner_type) then {
                let concrete_owner_type = self.concretize_codegen_type(owner_type)
                if self.concrete_receiver_lookup_key(concrete_owner_type) == concrete_receiver_key then when self.context.get_function_type(def_id) in {
                    .Some(function_type) then {
                        if self.function_type_param_count(function_type) > 0(UInt) then {
                            return true
                        }
                    },
                    .None() then {},
                }
            },
            .None() then {},
        }
        let receiver_base_type = when concrete_receiver_type in {
            .ReferenceType(inner_ref) then inner_ref.val,
            .MutableReferenceType(inner_ref) then inner_ref.val,
            .WeakReferenceType(inner_ref) then inner_ref.val,
            .MutableWeakReferenceType(inner_ref) then inner_ref.val,
            _ then concrete_receiver_type,
        }
        let receiver_base_key = self.concrete_receiver_lookup_key(receiver_base_type)

        return when self.context.get_function_type(def_id) in {
            .Some(function_type) then {
                if self.function_type_param_count(function_type) == 0(UInt) then {
                    return false
                }
                let receiver_param_type = self.function_type_param_type(function_type, 0(UInt)) or else Type.Unknown()
                let concrete_param_type = self.concretize_codegen_type(receiver_param_type)
                let param_base_type = when concrete_param_type in {
                    .ReferenceType(inner_ref) then inner_ref.val,
                    .MutableReferenceType(inner_ref) then inner_ref.val,
                    .WeakReferenceType(inner_ref) then inner_ref.val,
                    .MutableWeakReferenceType(inner_ref) then inner_ref.val,
                    _ then concrete_param_type,
                }
                yield self.concrete_receiver_lookup_key(param_base_type) == receiver_base_key
            },
            .None() then false,
        }
    }

    private lookup_receiver_method_by_signature(
        self,
        receiver_type Type,
        method_name String,
        args List[ref TypedExpr],
        requested_result_type Type,
    ) Option[Symbol] = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        for entry in self.program.concrete_callable_index().iterator() then {
            let def_id = DefId(entry.first)
            let concrete = entry.second
            if concrete.logical_name <> method_name then {
                continue
            }
            if not self.receiver_method_matches_lookup(def_id, concrete_receiver_type) then {
                continue
            }
            if not self.method_signature_compatible_with_call(def_id, concrete_receiver_type, args, requested_result_type) then {
                continue
            }
            when self.bound_concrete_method_symbol(def_id, concrete_receiver_type, requested_result_type) in {
                .Some(symbol) then { return Option[Symbol].Some(symbol) },
                .None() then {},
            }
        }
        return Option[Symbol].None()
    }


    public generate_static_method_call(self mut ref, receiver_type Type, method_name String, method ref Symbol, args List[ref TypedExpr], result_type Type) String = {
        let concrete_receiver_type = self.concretize_codegen_type(receiver_type)
        let logical_method_name = if not method_name.is_empty() then method_name else self.context.symbol_name(method)
        let owner_matches_receiver = if method.def_id.id > 0 then when self.context.get_function_param_type(method.def_id, 0(UInt)) in {
            .Some(receiver_param_type) then self.receiver_param_type_matches_call_receiver(receiver_param_type, concrete_receiver_type),
            .None() then false,
            } else false

        let mut resolved_symbol_opt = if owner_matches_receiver then {
            yield self.bound_concrete_method_symbol(method.def_id, concrete_receiver_type, method.symbol_type)
        } else Option[Symbol].None()

        if resolved_symbol_opt is .None() then {
            resolved_symbol_opt = self.lookup_static_method_symbol(concrete_receiver_type, logical_method_name, method.symbol_type)
        }
        if resolved_symbol_opt is .None() then {
            resolved_symbol_opt = self.lookup_receiver_method_by_signature(concrete_receiver_type, logical_method_name, args, method.symbol_type)
        }
        if resolved_symbol_opt is .None() then {
            resolved_symbol_opt = self.lookup_receiver_method(concrete_receiver_type, logical_method_name)
        }
        if resolved_symbol_opt is .None() then {
            when concrete_receiver_type in {
                .EnumType(_) then {
                    return self.generate_enum_constructor(concrete_receiver_type, logical_method_name, args)
                },
                .GenericEnum(_, _) then {
                    return self.generate_enum_constructor(concrete_receiver_type, logical_method_name, args)
                },
                _ then {},
            }
        }
        if resolved_symbol_opt is .None() then {
            let receiver_key = self.concrete_receiver_lookup_key(concrete_receiver_type)
            panic("CodeGen dispatch error: unresolved static method '\(logical_method_name)' for receiver '\(receiver_key)'")
        }
        let resolved_symbol = resolved_symbol_opt or else {
            let def_id = self.context.allocate_unindexed(logical_method_name, DefKind.Function())
            yield Symbol(def_id, method.symbol_type, method.kind)
        }
        let direct_function_type_opt = when self.context.get_function_type(resolved_symbol.def_id) in {
            .Some(function_type) then Option[Type].Some(self.bind_method_function_type(resolved_symbol.def_id, concrete_receiver_type, function_type)),
            .None() then Option[Type].None(),
        }
        let debug_static_name = if resolved_symbol.def_id.id > 0 then {
            yield self.callable_c_name(box(resolved_symbol))
        } else {
            let receiver_c_name = self.emitted_type_c_name_fallback(concrete_receiver_type)
            yield self.compose_method_c_name(receiver_c_name, self.context.symbol_name(resolved_symbol))
        }

        let mut effective_result_type = when result_type in {
            .Unknown() then {
                yield when direct_function_type_opt in {
                    .Some(function_type) then self.function_type_return_type(function_type),
                    .None() then resolved_symbol.symbol_type,
                }
            },
            .VoidType() then {
                let signature_return = when direct_function_type_opt in {
                    .Some(function_type) then self.function_type_return_type(function_type),
                    .None() then resolved_symbol.symbol_type,
                }
                yield when signature_return in {
                    .VoidType() then result_type,
                    .NeverType() then result_type,
                    .Unknown() then result_type,
                    _ then signature_return,
                }
            },
            _ then result_type,
        }

        let call_function_type_opt = when direct_function_type_opt in {
            .Some(function_type) then Option[Type].Some(function_type),
            .None() then when self.context.get_function_type(resolved_symbol.def_id) in {
                .Some(function_type) then Option[Type].Some(function_type),
                .None() then Option[Type].None(),
            },
        }
        let mut prepared_args = List[String].new()
        let mut arg_index = 0(UInt)
        for arg_ref in args then {
            let arg = arg_ref
            let expected_type_opt = when call_function_type_opt in {
                .Some(function_type) then self.function_type_param_type(function_type, arg_index),
                .None() then Option[Type].None(),
            }
            let prepared_arg = if arg_index == 0(UInt) then {
                yield when expected_type_opt in {
                    .Some(expected_type) then if self.receiver_param_type_matches_call_receiver(expected_type, arg.expr_type) or self.expected_is_any_ref(expected_type) then {
                            let concrete_arg_type = self.concretize_codegen_type(arg.expr_type)
                            yield self.prepare_receiver_method_argument_expr(arg, concrete_arg_type, box(resolved_symbol), args.count() - 1(UInt))
                        } else self.prepare_call_argument(arg, expected_type_opt),
                    .None() then self.prepare_call_argument(arg, expected_type_opt),
                }
            } else self.prepare_call_argument(arg, expected_type_opt)
            prepared_args.push(prepared_arg)
            arg_index = arg_index + 1(UInt)
        }

        let mut result = ""
        if self.type_is_void_or_never(effective_result_type) then {
            self.buffer.push_string(self.indent)
            self.buffer.push_string(debug_static_name)
            self.buffer.push_rune('(')
        } else {
            let c_type = self.c_type_name(effective_result_type)
            result = self.next_temp_with_decl(c_type)
            self.buffer.push_string(self.indent)
            self.buffer.push_string(result)
            self.buffer.push_string(" = ")
            self.buffer.push_string(debug_static_name)
            self.buffer.push_rune('(')
        }
        let mut first = true
        for prepared_arg in prepared_args then {
            if not first then {
                self.buffer.push_string(", ")
            }
            self.buffer.push_string(prepared_arg)
            first = false
        }
        self.buffer.push_string(");\n")
        return result
    }

    // ── GenericMethodCall 生成 ────────────────────────────────────────────────

    /// 生成泛型方法调用的 C 代码
    ///
    /// base.method_name(args) → 查找方法符号，生成函数调用
    ///
    /// Requirements: 5.32
    public generate_generic_method_call(self mut ref, base ref TypedExpr, receiver_type Type, method ref Symbol, args List[ref TypedExpr], result_type Type, dispatch_callsite Option[DefId]) String = {
        let base_expr_type = self.concretize_codegen_type(base.expr_type)
        let mut base_type = self.concretize_codegen_type(receiver_type)
        if not self.type_contains_generic(base_expr_type)
            and self.concrete_layout_key_for_type(base_type) <> self.concrete_layout_key_for_type(base_expr_type)
        then {
            base_type = base_expr_type
        }
        let lookup_base_type = base_type
        let fallback_method_name = self.context.symbol_name(method)
        let method_name = if method.def_id.id == 0 then fallback_method_name else self.semantic_receiver_method_name(method) or else fallback_method_name
        let effective_result_type = self.requested_or_symbol_result_type(result_type, method.symbol_type)
        let direct_dispatch_base = when base.expr_kind in {
            .TraitObjectConversion(inner, _, _) then {
                yield when lookup_base_type in {
                    .TraitObject(_, _) then base,
                    _ then inner,
                }
            },
            _ then base,
        }
        let base_declared_type = self.concretize_codegen_type(base.expr_type)
        when base_declared_type in {
            .TraitObject(trait_name, trait_type_args) then {
                return self.generate_trait_method_call_typed(base, Type.TraitObject(trait_name, trait_type_args), method_name, args, effective_result_type)
            },
            _ then {},
        }

        let cast_trait_type_opt = when base.expr_kind in {
            .CastExpr(target_type, _) then when target_type in {
                .TraitObject(_, _) then Option[Type].Some(target_type),
                _ then Option[Type].None(),
            },
            _ then Option[Type].None(),
        }
        if cast_trait_type_opt is .Some(cast_trait_type) then {
            return self.generate_trait_method_call_typed(base, cast_trait_type, method_name, args, effective_result_type)
        }

        when self.trait_dispatch_type_opt(base_declared_type) in {
            .Some(trait_type) then {
                return self.generate_trait_method_call_typed(base, trait_type, method_name, args, effective_result_type)
            },
            .None() then {},
        }

        when base_type in {
            .TraitObject(trait_name, trait_type_args) then {
                return self.generate_trait_method_call_typed(base, Type.TraitObject(trait_name, trait_type_args), method_name, args, effective_result_type)
            },
            _ then {},
        }

        let mut method_opt = Option[Symbol].None()
        // Prefer the concrete method already bound on the AST node when it still
        // matches the current receiver/arguments/result. This avoids name-only
        // metadata lookup picking a stale specialization of a generic method.
        when self.method_owner_type(method.def_id) in {
            .Some(owner_type) then {
                let signature_receiver_matches = when self.context.get_function_param_type(method.def_id, 0(UInt)) in {
                    .Some(receiver_param_type) then {
                        yield self.receiver_param_type_matches_call_receiver(receiver_param_type, base_type)
                    },
                    .None() then false,
                }
                let direct_signature_matches_call = self.method_signature_compatible_with_call(method.def_id, base_type, args, effective_result_type)
                let _ = owner_type
                if signature_receiver_matches
                    and direct_signature_matches_call
                    and self.program.lookup_concrete_callable(method.def_id) is .Some(_)
                then {
                    method_opt = self.bound_concrete_method_symbol(method.def_id, base_type, effective_result_type)
                }
            },
            .None() then {},
        }
        if method_opt is .None() then {
            when self.direct_callable_symbol(method) in {
                .Some(direct_symbol) then {
                    if self.method_signature_compatible_with_call(direct_symbol.def_id, base_type, args, effective_result_type) then {
                        method_opt = when self.bound_concrete_method_symbol(direct_symbol.def_id, base_type, effective_result_type) in {
                            .Some(bound_symbol) then Option[Symbol].Some(bound_symbol),
                            .None() then Option[Symbol].Some(direct_symbol),
                        }
                    }
                },
                .None() then {},
            }
        }
        if method_opt is .None() then {
            if self.try_generate_receiver_dispatch_call(direct_dispatch_base, base_type, args, result_type, dispatch_callsite) is .Some(dispatch_call) then {
                return dispatch_call
            }
        }
        if method_opt is .None() then {
            method_opt = self.lookup_receiver_method_by_signature(lookup_base_type, method_name, args, effective_result_type)
        }
        if method_opt is .None() then {
            method_opt = self.lookup_receiver_method(lookup_base_type, method_name)
        }
        if method_opt is .Some(method_symbol) then {
            let effective_result_type = self.preferred_receiver_method_result_type(result_type, method_symbol.symbol_type)
            return self.generate_receiver_method_call(direct_dispatch_base, lookup_base_type, box(method_symbol), args, effective_result_type)
        }
        let receiver_key = self.concrete_receiver_lookup_key(lookup_base_type)
        panic("CodeGen dispatch error: unresolved receiver method '\(method_name)' for receiver '\(receiver_key)'")
    }



    // ── QualifiedMethodCall 生成 ──────────────────────────────────────────────

    /// 生成 trait 限定方法调用的 C 代码
    ///
    /// Requirements: 5.33
    private generate_trait_tool_argument(self mut ref, expr ref TypedExpr, expected_type Type) String = {
        return when expected_type in {
            .TraitObject(trait_name, _) then {
                yield when expr.expr_type in {
                    .TraitObject(_, _) then { yield self.generate_expression_ssa(expr) },
                    .ReferenceType(source_inner_ref) then {
                        yield when source_inner_ref.val in {
                            .TraitObject(_, _) then self.generate_cast_expr(expected_type, expr),
                            _ then self.generate_trait_object_conversion_typed(expr, expected_type, expr.expr_type),
                        }
                    },
                    _ then {
                        let source_result = self.generate_expression_ssa(expr)
                        let concrete_type = expr.expr_type
                        let normalized_concrete_type = self.trait_vtable_receiver_type(trait_name, concrete_type)
                        let concrete_c_type = self.c_type_name(concrete_type)
                        let value_result = self.copy_expr_if_lvalue_owned(expr, source_result, concrete_type)
                        let stored_value = self.next_temp_with_init(concrete_c_type, value_result)
                        let trait_result = self.next_temp_with_decl("struct __koral_TraitRef")
                        let concrete_c_name = when self.concrete_type_c_name(normalized_concrete_type) in {
                            .Some(name) then name,
                            .None() then self.c_type_name(normalized_concrete_type),
                        }
                        let vtable_name = self.vtable_instance_name(trait_name, concrete_c_name)
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).ptr = (void*)&(\(stored_value));\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).control = NULL;\n")
                        self.add_indent()
                        self.buffer.push_string("\(trait_result).vtable = &\(vtable_name);\n")
                        yield trait_result
                    },
                }
            },
            _ then { yield self.generate_expression_ssa(expr) },
        }
    }

    public generate_qualified_method_call(self mut ref, base ref TypedExpr, trait_name String, method ref Symbol, args List[ref TypedExpr], result_type Type, dispatch_callsite Option[DefId]) String = {
        let mut trait_type = self.trait_object_type_from_name(trait_name)
        when base.expr_type in {
            .TraitObject(base_trait_name, base_trait_args) then {
                if base_trait_name == trait_name then {
                    trait_type = Type.TraitObject(base_trait_name, base_trait_args)
                }
            },
            _ then {},
        }
        when base.expr_kind in {
            .CastExpr(target_type, _) then when target_type in {
                .TraitObject(cast_trait_name, _) then {
                    if cast_trait_name == trait_name then {
                        trait_type = target_type
                    }
                },
                _ then {},
            },
            _ then {},
        }
        return self.generate_qualified_method_call_typed(base, trait_type, method, args, result_type, dispatch_callsite)
    }

    public generate_qualified_method_call_typed(self mut ref, base ref TypedExpr, trait_type Type, method ref Symbol, args List[ref TypedExpr], result_type Type, dispatch_callsite Option[DefId]) String = {
        let trait_name = self.trait_name_from_type(trait_type)
        let method_name = self.context.symbol_name(method)
        let base_type = self.concretize_codegen_type(base.expr_type)
        let effective_result_type = self.requested_or_symbol_result_type(result_type, method.symbol_type)
        when base.expr_kind in {
            .Variable(sym) then {
                if sym.kind is .TypeSymbol() then {
                    if self.lookup_trait_method_def_id(base_type, trait_name, method_name) is .Some(actual_def_id) then {
                        let actual_symbol = self.require_bound_concrete_method_symbol(actual_def_id, base_type, effective_result_type, "qualified static dispatch \(trait_name).\(method_name)")
                        return self.generate_function_call(box(actual_symbol), args, actual_symbol.symbol_type)
                    }
                    return self.generate_static_method_call(base_type, method_name, method, args, effective_result_type)
                }
            },
            _ then {},
        }

        let base_is_trait_object = when base_type in {
            .TraitObject(_, _) then true,
            _ then false,
        }
        if not base_is_trait_object then {
            let mut all_args = List[ref TypedExpr].new()
            let include_base_arg = when base.expr_kind in {
                .Variable(sym) then sym.kind is not .TypeSymbol(),
                _ then true,
            }
            if include_base_arg then {
                all_args.push(base)
            }
            for arg in args then {
                all_args.push(arg)
            }
            if include_base_arg then {
                if self.lookup_trait_method_def_id(base_type, trait_name, method_name) is .Some(actual_def_id) then {
                    let actual_symbol = self.require_bound_concrete_method_symbol(actual_def_id, base_type, effective_result_type, "qualified receiver dispatch \(trait_name).\(method_name)")
                    return self.generate_receiver_method_call(base, base_type, box(actual_symbol), args, actual_symbol.symbol_type)
                }
                if self.lookup_receiver_method(base_type, method_name) is .Some(concrete_method) then {
                    return self.generate_receiver_method_call(base, base_type, box(concrete_method), args, effective_result_type)
                }
                when self.lookup_receiver_method_by_signature(base_type, method_name, args, effective_result_type) in {
                    .Some(concrete_method) then {
                        return self.generate_receiver_method_call(base, base_type, box(concrete_method), args, effective_result_type)
                    },
                    .None() then {},
                }
            }
            let direct_symbol = when self.direct_callable_symbol(method) in {
                .Some(symbol) then symbol,
                .None() then method.val,
            }
            return self.generate_function_call(box(direct_symbol), all_args, effective_result_type)
        }
        if self.try_generate_receiver_dispatch_call(base, base_type, args, result_type, dispatch_callsite) is .Some(dispatch_call) then {
            return dispatch_call
        }

        if not self.is_raw_trait_method(trait_name, method_name) then {
            let concrete_base = when base.expr_kind in {
                .TraitObjectConversion(inner, _, _) then inner,
                _ then base,
            }
            let concrete_base_type = self.concretize_codegen_type(concrete_base.expr_type)
            if self.lookup_trait_method_def_id(concrete_base_type, trait_name, method_name) is .Some(actual_def_id) then {
                let actual_symbol = self.require_bound_concrete_method_symbol(actual_def_id, concrete_base_type, effective_result_type, "qualified helper dispatch \(trait_name).\(method_name)")
                return self.generate_receiver_method_call(concrete_base, concrete_base_type, box(actual_symbol), args, actual_symbol.symbol_type)
            }
            if self.lookup_receiver_method(concrete_base_type, method_name) is .Some(concrete_method) then {
                return self.generate_receiver_method_call(concrete_base, concrete_base_type, box(concrete_method), args, effective_result_type)
            }
            when self.lookup_receiver_method_by_signature(concrete_base_type, method_name, args, effective_result_type) in {
                .Some(concrete_method) then {
                    return self.generate_receiver_method_call(concrete_base, concrete_base_type, box(concrete_method), args, effective_result_type)
                },
                .None() then {},
            }

            let mut all_args = List[ref TypedExpr].new()
            all_args.push(concrete_base)
            for arg in args then {
                all_args.push(arg)
            }
            let direct_symbol = when self.direct_callable_symbol(method) in {
                .Some(symbol) then symbol,
                .None() then method.val,
            }
            return self.generate_function_call(box(direct_symbol), all_args, effective_result_type)
        }

        return self.generate_trait_method_call_typed(base, trait_type, method_name, args, effective_result_type)
    }
    // ── 方法查找辅助方法 ──────────────────────────────────────────────────────

    /// 通过接收者类型和方法名查找方法符号
    ///
    /// 优先使用单态化阶段导出的 metadata 表。
    lookup_receiver_method(self, receiver_type Type, method_name String) Option[Symbol] = {
        let base_type = receiver_type
        if self.lookup_receiver_method_via_metadata(base_type, method_name, Type.Unknown()) is .Some(symbol) then {
            return Option[Symbol].Some(symbol)
        }
        when receiver_type in {
            .ReferenceType(_) then {},
            .MutableReferenceType(_) then {},
            .WeakReferenceType(_) then {},
            .MutableWeakReferenceType(_) then {},
            _ then {
                let mut_ref_type = Type.MutableReferenceType(box(receiver_type))
                when self.lookup_receiver_method_via_metadata(mut_ref_type, method_name, Type.Unknown()) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
                let shared_ref_type = Type.ReferenceType(box(receiver_type))
                when self.lookup_receiver_method_via_metadata(shared_ref_type, method_name, Type.Unknown()) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
        }
        return when receiver_type in {
            .ReferenceType(inner_ref) then self.lookup_receiver_method(inner_ref.val, method_name),
            .MutableReferenceType(inner_ref) then {
                let shared_ref_type = Type.ReferenceType(box(inner_ref.val))
                yield when self.lookup_receiver_method_via_metadata(shared_ref_type, method_name, Type.Unknown()) in {
                    .Some(symbol) then Option[Symbol].Some(symbol),
                    .None() then self.lookup_receiver_method(inner_ref.val, method_name),
                }
            },
            _ then Option[Symbol].None(),
        }
    }

    /// 生成类型零值初始化表达式。
    zero_init_expr_for_type(self, t Type) String = {
        let c_type = self.c_type_name(t)
        return when t in {
            .StructureType(_) then "(\(c_type)){0}",
            .EnumType(_) then "(\(c_type)){0}",
            .GenericStruct(_, _) then "(\(c_type)){0}",
            .GenericEnum(_, _) then "(\(c_type)){0}",
            .ReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then "(struct __koral_TraitRef){0}",
                    .OpaqueType(def_id) then when self.context.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_, _) then "(struct __koral_TraitRef){0}",
                            _ then "(struct __koral_Ref){0}",
                        },
                        .None() then "(struct __koral_Ref){0}",
                    },
                    _ then "(struct __koral_Ref){0}",
                }
            },
            .MutableReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then "(struct __koral_TraitRef){0}",
                    .OpaqueType(def_id) then when self.context.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_, _) then "(struct __koral_TraitRef){0}",
                            _ then "(struct __koral_Ref){0}",
                        },
                        .None() then "(struct __koral_Ref){0}",
                    },
                    _ then "(struct __koral_Ref){0}",
                }
            },
            .TraitObject(_, _) then "(struct __koral_TraitRef){0}",
            .FunctionType(_, _) then "(struct __koral_Closure){0}",
            .PointerType(_) then "NULL",
            .MutablePointerType(_) then "NULL",
            .WeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then "(struct __koral_TraitWeakRef){0}",
                    .OpaqueType(def_id) then when self.context.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_, _) then "(struct __koral_TraitWeakRef){0}",
                            _ then "(struct __koral_WeakRef){0}",
                        },
                        .None() then "(struct __koral_WeakRef){0}",
                    },
                    _ then "(struct __koral_WeakRef){0}",
                }
            },
            .MutableWeakReferenceType(inner_ref) then {
                yield when inner_ref.val in {
                    .TraitObject(_, _) then "(struct __koral_TraitWeakRef){0}",
                    .OpaqueType(def_id) then when self.context.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .TraitObject(_, _) then "(struct __koral_TraitWeakRef){0}",
                            _ then "(struct __koral_WeakRef){0}",
                        },
                        .None() then "(struct __koral_WeakRef){0}",
                    },
                    _ then "(struct __koral_WeakRef){0}",
                }
            },
            .VoidType() then "",
            .NeverType() then "",
            _ then "(\(c_type))0",
        }
    }
}


/// 将 UInt8 格式化为 C 十六进制字节字面量，如 "0x41"
let format_hex_byte(b UInt8) String = {
    let hex_chars = "0123456789ABCDEF"
    let hi = (b >> 4)(UInt)
    let lo = (b & 0x0F(UInt8))(UInt)
    let hi_char = hex_chars[hi]
    let lo_char = hex_chars[lo]
    let mut result = "0x"
    result.push_byte(hi_char)
    result.push_byte(lo_char)
    return result
}

/// 将 Rune 字面量字符串转换为 C uint32_t 数值字符串
/// value 是原始字符（如 ":" 对应 58）
let rune_literal_to_c_value(value String) String = {
    let bytes = value.to_bytes()
    if bytes.is_empty() then {
        return "0"
    }
    let b0 = bytes[0](UInt)
    // ASCII 字符：直接使用字节值
    if b0 < 128 then {
        return b0.to_string()
    }
    // 2-byte UTF-8: 110xxxxx 10xxxxxx
    if b0 < 224 and bytes.count() >= 2 then {
        let b1 = bytes[1](UInt)
        let cp = ((b0 & 31) << 6) | (b1 & 63)
        return cp.to_string()
    }
    // 3-byte UTF-8: 1110xxxx 10xxxxxx 10xxxxxx
    if b0 < 240 and bytes.count() >= 3 then {
        let b1 = bytes[1](UInt)
        let b2 = bytes[2](UInt)
        let cp = ((b0 & 15) << 12) | ((b1 & 63) << 6) | (b2 & 63)
        return cp.to_string()
    }
    // 4-byte UTF-8: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx
    if b0 < 248 and bytes.count() >= 4 then {
        let b1 = bytes[1](UInt)
        let b2 = bytes[2](UInt)
        let b3 = bytes[3](UInt)
        let cp = ((b0 & 7) << 18) | ((b1 & 63) << 12) | ((b2 & 63) << 6) | (b3 & 63)
        return cp.to_string()
    }
    return b0.to_string()
}
