type MIRYieldTargetContext(
    result_local Option[MIRLocalID],
    join_block MIRBlockID,
    base_scope_depth UInt,
)

type MIRLoopBuilderContext(
    continue_block MIRBlockID,
    break_block MIRBlockID,
    scope_depth UInt,
)

type MIRFunctionBuilder(
    program ref MonomorphizedProgram,
    identifier ref Symbol,
    params List[TypedParam],
    captured_symbols List[ref Symbol],
    return_type Type,
    kind MIRFunctionKind,
    body ref TypedExpr,
    context CompilerContext,
    mut next_local_id UInt,
    mut next_block_id UInt,
    mut next_scope_id UInt,
    mut locals List[MIRLocal],
    mut blocks List[MIRBasicBlock],
    mut current_block_index UInt,
    mut terminated_blocks Set[UInt],
    mut local_by_def_id Dict[UInt, MIRLocalID],
    mut parameter_local_by_name Dict[String, MIRLocalID],
    mut pattern_place_by_def_id Dict[UInt, MIRPlace],
    mut pattern_place_by_name Dict[String, MIRPlace],
    mut loop_stack List[MIRLoopBuilderContext],
    mut scope_stack List[MIRScopeID],
    mut yield_target_stack List[MIRYieldTargetContext],
    mut pattern_subject_operand Option[MIROperand],
    mut pattern_subject_tag Option[MIROperand],
    mut pattern_comparison_local Option[MIRLocalID],
)

given MIRFunctionBuilder {
    public new(
        program ref MonomorphizedProgram,
        identifier ref Symbol,
        params List[TypedParam],
        captured_symbols List[ref Symbol],
        return_type Type,
        kind MIRFunctionKind,
        body ref TypedExpr,
        context CompilerContext,
    ) MIRFunctionBuilder = {
        return MIRFunctionBuilder(
            program,
            identifier,
            params,
            captured_symbols,
            return_type,
            kind,
            body,
            context,
            0(UInt),
            0(UInt),
            0(UInt),
            List[MIRLocal].new(),
            List[MIRBasicBlock].new(),
            0(UInt),
            Set[UInt].new(),
            Dict[UInt, MIRLocalID].new(),
            Dict[String, MIRLocalID].new(),
            Dict[UInt, MIRPlace].new(),
            Dict[String, MIRPlace].new(),
            List[MIRLoopBuilderContext].new(),
            List[MIRScopeID].new(),
            List[MIRYieldTargetContext].new(),
            Option[MIROperand].None(),
            Option[MIROperand].None(),
            Option[MIRLocalID].None(),
        )
    }

    public lower(self mut ref) ref MIRFunction = {
        let entry = self.append_block()
        let _ = entry
        for param in self.params then {
            let local = self.make_local(param.name, param.param_type, if param.mutable then MIRMutability.Mutable() else MIRMutability.Immutable(), MIRStorage.Parameter(), Option[ref Symbol].None())
            self.parameter_local_by_name.insert(param.name, local.id)
            self.append_statement(MIRStatement.Declare(local.id))
        }
        for capture in self.captured_symbols then {
            let local = self.make_local(
                self.context.symbol_name(capture),
                capture.symbol_type,
                if capture.is_mutable() then MIRMutability.Mutable() else MIRMutability.Immutable(),
                MIRStorage.Capture(),
                Option[ref Symbol].Some(capture),
            )
            self.local_by_def_id.insert(capture.def_id.id, local.id)
            self.append_statement(MIRStatement.Declare(local.id))
        }
        let result = self.lower_expression(self.body)
        self.finish_implicit_return(result)
        return box(MIRFunction(
            self.identifier,
            self.params,
            self.return_type,
            self.kind,
            MIRBlockID(0(UInt)),
            self.boxed_locals(),
            self.boxed_blocks(),
        ))
    }

    private append_block(self mut ref) MIRBlockID = {
        let id = MIRBlockID(self.next_block_id)
        self.next_block_id += 1
        self.blocks.push(MIRBasicBlock(id, List[ref MIRStatement].new(), MIRTerminator.Unreachable()))
        self.current_block_index = self.blocks.count() - 1(UInt)
        return id
    }

    private make_block(self mut ref) MIRBlockID = self.append_block()

    private current_block_id(self ref) MIRBlockID = self.blocks[self.current_block_index].id

    private current_block_is_terminated(self ref) Bool = self.terminated_blocks.contains(self.current_block_id().raw_value)

    private set_current_block(self mut ref, id MIRBlockID) Void = {
        let mut index UInt = 0
        while index < self.blocks.count() then {
            if self.blocks[index].id.raw_value == id.raw_value then {
                self.current_block_index = index
                return
            }
            index += 1
        }
    }

    private append_statement(self mut ref, statement MIRStatement) Void = {
        if self.current_block_is_terminated() then { return }
        self.append_statement_to_block(self.blocks[self.current_block_index], statement)
    }

    private terminate(self mut ref, terminator MIRTerminator) Void = {
        if self.current_block_is_terminated() then { return }
        let block_id = self.current_block_id()
        self.set_block_terminator(self.blocks[self.current_block_index], terminator)
        self.terminated_blocks.insert(block_id.raw_value)
    }

    private append_statement_to_block(self mut ref, block mut ref MIRBasicBlock, statement MIRStatement) Void = {
        let _ = self
        block.statements.push(box(statement))
    }

    private set_block_terminator(self mut ref, block mut ref MIRBasicBlock, terminator MIRTerminator) Void = {
        let _ = self
        block.terminator = terminator
    }

    private make_local(
        self mut ref,
        name String,
        local_type Type,
        mutability MIRMutability,
        storage MIRStorage,
        symbol Option[ref Symbol],
    ) MIRLocal = {
        let local = MIRLocal(MIRLocalID(self.next_local_id), name, local_type, mutability, storage, symbol)
        self.next_local_id += 1
        self.locals.push(local)
        return local
    }

    private make_temporary(self mut ref, local_type Type, name_hint String) MIRLocal = {
        return self.make_local("\(name_hint)_\(self.next_local_id)", local_type, MIRMutability.Mutable(), MIRStorage.Temporary(), Option[ref Symbol].None())
    }

    private boxed_locals(self ref) List[ref MIRLocal] = {
        let mut boxed = List[ref MIRLocal].with_capacity(self.locals.count())
        for local in self.locals then {
            boxed.push(box(local))
        }
        return boxed
    }

    private boxed_blocks(self ref) List[ref MIRBasicBlock] = {
        let mut boxed = List[ref MIRBasicBlock].with_capacity(self.blocks.count())
        for block in self.blocks then {
            boxed.push(box(block))
        }
        return boxed
    }

    private make_scope_id(self mut ref) MIRScopeID = {
        let scope = MIRScopeID(self.next_scope_id)
        self.next_scope_id += 1
        return scope
    }

    private finish_implicit_return(self mut ref, result Option[MIRExprResult]) Void = {
        if self.current_block_is_terminated() then { return }
        if self.type_is_never(self.body.expr_type) or self.type_is_never(self.return_type) then {
            self.terminate(MIRTerminator.Unreachable())
            return
        }
        if self.type_is_void(self.return_type) then {
            self.terminate(MIRTerminator.ReturnValue(Option[MIROperand].None()))
            return
        }
        when self.return_operand(result) in {
            .Some(operand) then self.terminate(MIRTerminator.ReturnValue(Option[MIROperand].Some(operand))),
            .None() then self.terminate(MIRTerminator.Unreachable()),
        }
    }

    private return_operand(self mut ref, result Option[MIRExprResult]) Option[MIROperand] = {
        return when result in {
            .Some(value) then when value.operand in {
                .Some(operand) then Option[MIROperand].Some(self.adapt_operand_to_expected_type(operand, value.result_type, self.return_type)),
                .None() then when value.place in {
                    .Some(place) then when place in {
                        .Local(local) then {
                            let local_type = self.type_of_local(local)
                            yield if local_type == self.return_type
                                then Option[MIROperand].Some(MIROperand.Local(local))
                                else Option[MIROperand].Some(self.materialize(self.read_place_for_expected_type(place, local_type, self.return_type), self.return_type))
                        },
                        _ then Option[MIROperand].Some(self.materialize(self.read_place_for_expected_type(place, value.result_type, self.return_type), self.return_type)),
                    },
                    .None() then Option[MIROperand].None(),
                },
            },
            .None() then Option[MIROperand].None(),
        }
    }

    private type_of_local(self ref, local_id MIRLocalID) Type = {
        for local in self.locals then {
            if local.id.raw_value == local_id.raw_value then {
                return local.local_type
            }
        }
        return Type.Unknown()
    }

    private deref_expected_type(self ref, actual_type Type, expected_type Type) Option[Type] = {
        let _ = self
        return when actual_type in {
            .ReferenceType(inner_ref) then if inner_ref.val == expected_type then Option[Type].Some(inner_ref.val) else Option[Type].None(),
            .MutableReferenceType(inner_ref) then if inner_ref.val == expected_type then Option[Type].Some(inner_ref.val) else Option[Type].None(),
            .WeakReferenceType(inner_ref) then if inner_ref.val == expected_type then Option[Type].Some(inner_ref.val) else Option[Type].None(),
            .MutableWeakReferenceType(inner_ref) then if inner_ref.val == expected_type then Option[Type].Some(inner_ref.val) else Option[Type].None(),
            _ then Option[Type].None(),
        }
    }

    private read_place_for_expected_type(self mut ref, place MIRPlace, actual_type Type, expected_type Type) MIRValue = {
        return when self.deref_expected_type(actual_type, expected_type) in {
            .Some(pointee_type) then {
                let deref_place = MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), pointee_type)
                yield MIRValue.PlaceRead(deref_place, MIROwnershipUse.Copy())
            },
            .None() then MIRValue.PlaceRead(place, MIROwnershipUse.Copy()),
        }
    }

    private adapt_operand_to_expected_type(self mut ref, operand MIROperand, actual_type Type, expected_type Type) MIROperand = {
        return when self.deref_expected_type(actual_type, expected_type) in {
            .Some(pointee_type) then {
                yield when operand in {
                    .Local(local_id) then {
                        let deref_place = MIRPlace.Deref(box(MIRValue.PlaceRead(MIRPlace.Local(local_id), MIROwnershipUse.Borrow())), pointee_type)
                        yield self.materialize(MIRValue.PlaceRead(deref_place, MIROwnershipUse.Copy()), expected_type)
                    },
                    _ then operand,
                }
            },
            .None() then operand,
        }
    }

    private lower_expression(self mut ref, expression ref TypedExpr) Option[MIRExprResult] = {
        if self.current_block_is_terminated() then { return Option[MIRExprResult].None() }
        return when expression.expr_kind in {
            .IntegerLiteral(value) then Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Constant(MIRConstant.Integer(value, expression.expr_type))), Option[MIRPlace].None())),
            .FloatLiteral(value) then Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Constant(MIRConstant.Float(value, expression.expr_type))), Option[MIRPlace].None())),
            .StringLiteral(value) then Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Constant(MIRConstant.StringLiteral(value, expression.expr_type))), Option[MIRPlace].None())),
            .BoolLiteral(value) then Option[MIRExprResult].Some(MIRExprResult(Type.BoolType(), ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Constant(MIRConstant.Boolean(value))), Option[MIRPlace].None())),
            .Variable(symbol) then {
                yield when symbol.kind in {
                    .Function() then Option[MIRExprResult].Some(MIRExprResult(symbol.symbol_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Function(symbol)), Option[MIRPlace].None())),
                    _ then {
                        let place = self.lower_place(expression) or else MIRPlace.Global(symbol.def_id)
                        let result_place = when symbol.symbol_type in {
                            .ReferenceType(inner_ref) then if inner_ref.val == expression.expr_type
                                then MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner_ref.val)
                                else place,
                            .MutableReferenceType(inner_ref) then if inner_ref.val == expression.expr_type
                                then MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner_ref.val)
                                else place,
                            .WeakReferenceType(inner_ref) then if inner_ref.val == expression.expr_type
                                then MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner_ref.val)
                                else place,
                            .MutableWeakReferenceType(inner_ref) then if inner_ref.val == expression.expr_type
                                then MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner_ref.val)
                                else place,
                            _ then place,
                        }
                        yield Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, typed_expr_value_category(expression), Option[MIROperand].None(), Option[MIRPlace].Some(result_place)))
                    },
                }
            },
            .Block(statements) then self.lower_block(statements, expression.expr_type),
            .IfExpr(condition, then_branch, else_branch) then self.lower_if_expression(condition, then_branch, else_branch, expression.expr_type),
            .WhenExpr(subject, arms) then self.lower_when_expression(subject, arms, expression.expr_type),
            .ArithmeticExpr(left, op, right) then Option[MIRExprResult].Some(self.lower_binary(left, right, expression.expr_type, MIRBinaryOperator.Arithmetic(op, true))),
            .WrappingArithmeticExpr(left, op, right) then Option[MIRExprResult].Some(self.lower_binary(left, right, expression.expr_type, MIRBinaryOperator.WrappingArithmetic(op))),
            .WrappingShiftExpr(left, op, right) then Option[MIRExprResult].Some(self.lower_binary(left, right, expression.expr_type, MIRBinaryOperator.WrappingShift(op))),
            .ComparisonExpr(left, op, right) then Option[MIRExprResult].Some(self.lower_binary(left, right, expression.expr_type, MIRBinaryOperator.Comparison(op))),
            .BitwiseExpr(left, op, right) then Option[MIRExprResult].Some(self.lower_binary(left, right, expression.expr_type, MIRBinaryOperator.Bitwise(op, true))),
            .AndExpr(left, right) then self.lower_short_circuit(left, right, expression.expr_type, false),
            .OrExpr(left, right) then self.lower_short_circuit(left, right, expression.expr_type, true),
            .Unary(op, inner) then Option[MIRExprResult].Some(self.lower_unary_or_negate(op, inner, expression.expr_type)),
            .CastExpr(target_type, inner) then {
                let operand = self.lower_operand(inner)
                let result = self.materialize(MIRValue.Cast(operand, target_type), target_type)
                yield Option[MIRExprResult].Some(MIRExprResult(target_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
            },
            .RefExpr(inner) then self.lower_ref_expression(inner, expression.expr_type),
            .PtrExpr(inner) then {
                yield when self.lower_place(inner) in {
                    .Some(place) then {
                        let result = self.materialize(MIRValue.Pointer(place), expression.expr_type)
                        yield Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
                    },
                    .None() then self.void_result(),
                }
            },
            .DerefExpr(_) then {
                yield when self.lower_place(expression) in {
                    .Some(place) then Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, ValueCategory.LValue(), Option[MIROperand].None(), Option[MIRPlace].Some(place))),
                    .None() then self.void_result(),
                }
            },
            .MemberPath(_, _) then {
                yield when self.lower_place(expression) in {
                    .Some(place) then Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, typed_expr_value_category(expression), Option[MIROperand].None(), Option[MIRPlace].Some(place))),
                    .None() then when self.lower_materialized_member_path_place(expression) in {
                        .Some(place) then Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, typed_expr_value_category(expression), Option[MIROperand].None(), Option[MIRPlace].Some(place))),
                        .None() then self.void_result(),
                    },
                }
            },
            .Call(callee, args) then self.lower_call(callee, args, expression.expr_type),
            .GenericCall(function_symbol, _, args) then self.finish_call_from_typed_args(MIROperand.Function(function_symbol), args, expression.expr_type),
            .StaticMethodCall(receiver_type, method_name, _, _, _, _) then Option[MIRExprResult].None(),
            .TypeConstruction(identifier, _, args) then self.lower_type_construction(identifier, args, expression.expr_type),
            .EnumConstruction(enum_type, case_name, args) then self.lower_enum_construction(enum_type, case_name, args),
            .MethodReference(base_expr, _, method, _, _, _) then {
                // If the method takes only self (1 param), call it with base as receiver.
                // If it takes more params, return as a function value.
                let param_count = when method.symbol_type in {
                    .FunctionType(params, _) then params.count(),
                    _ then 0(UInt),
                }
                if param_count <= 1(UInt) then {
                    let result_type = when method.symbol_type in {
                        .FunctionType(_, ret) then ret.val,
                        _ then expression.expr_type,
                    }
                    let base_emission = self.lower_value(base_expr)
                    let mut call_values = List[ref MIRValue].new()
                    let mut call_ownerships = List[MIROwnershipUse].new()
                    call_values.push(box(base_emission))
                    call_ownerships.push(self.ownership_use(base_expr))
                    return self.finish_call(MIROperand.Function(method), call_values, call_ownerships, result_type)
                } else {
                    yield Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Function(method)), Option[MIRPlace].None()))
                }
            },
            .TraitMethodPlaceholder(_, _, method, _, _) then Option[MIRExprResult].Some(MIRExprResult(expression.expr_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Function(method)), Option[MIRPlace].None())),
            .TraitObjectConversion(inner, trait_type, concrete_type) then self.lower_trait_object_conversion(inner, trait_type, concrete_type, expression.expr_type),
            .TraitMethodCall(receiver, trait_type, method_name, method_index, args) then self.lower_trait_method_call(receiver, trait_type, method_name, method_index, args, expression.expr_type),
            .IntrinsicCall(node) then self.lower_intrinsic_call(node),
            .LambdaExpr(params, return_type, body) then self.lower_lambda_expression(params, return_type, body, expression.expr_type),
            .GenericInstantiation(_, _) then self.void_result(),
            .IsExpr(subject, pattern, negated) then Option[MIRExprResult].Some(self.lower_pattern_test(subject, pattern, negated, expression.expr_type)),
        }
    }

    private void_result(self ref) Option[MIRExprResult] = {
        return Option[MIRExprResult].Some(MIRExprResult(Type.VoidType(), ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Constant(MIRConstant.Void())), Option[MIRPlace].None()))
    }

    private lower_block(self mut ref, statements ref List[ref TypedStatement], block_type Type) Option[MIRExprResult] = {
        let scope = self.make_scope_id()
        self.scope_stack.push(scope)
        self.append_statement(MIRStatement.ScopeEnter(scope))
        let has_result = not self.type_is_void_or_never(block_type)
        let mut result_local = Option[MIRLocalID].None()
        let block_body = self.current_block_id()
        let join_block = self.make_block()
        self.set_current_block(block_body)
        if has_result then {
            let local = self.make_temporary(block_type, "block_result")
            self.append_statement(MIRStatement.Declare(local.id))
            result_local = Option[MIRLocalID].Some(local.id)
            self.yield_target_stack.push(MIRYieldTargetContext(result_local, join_block, self.scope_stack.count()))
        }
        let mut last_result = Option[MIRExprResult].None()
        let mut index UInt = 0
        while index < statements.count() then {
            let is_last = index + 1(UInt) == statements.count()
            let stmt = statements[index]
            when stmt in {
                .ExprStmt(expr, _) then {
                    if is_last and has_result then {
                        last_result = self.lower_expression(expr)
                        when result_local in {
                            .Some(local_id) then when last_result in {
                                .Some(value) then self.assign_branch_result(value, local_id),
                                .None() then {},
                            },
                            .None() then {},
                        }
                    } else {
                        self.lower_statement(stmt)
                    }
                },
                .IfStmt(condition, then_branch, else_branch, _) then {
                    if is_last and has_result then {
                        last_result = self.lower_if_expression(condition, then_branch, else_branch, block_type)
                        when result_local in {
                            .Some(local_id) then when last_result in {
                                .Some(value) then self.assign_branch_result(value, local_id),
                                .None() then {},
                            },
                            .None() then {},
                        }
                    } else self.lower_statement(stmt)
                },
                .WhenStmt(subject, arms, _) then {
                    if is_last and has_result then {
                        last_result = self.lower_when_expression(subject, arms, block_type)
                        when result_local in {
                            .Some(local_id) then when last_result in {
                                .Some(value) then self.assign_branch_result(value, local_id),
                                .None() then {},
                            },
                            .None() then {},
                        }
                    } else self.lower_statement(stmt)
                },
                .YieldStmt(_, _) then self.lower_statement(stmt),
                _ then self.lower_statement(stmt),
            }
            index += 1
        }
        if has_result then {
            let _ = self.yield_target_stack.pop()
        }
        self.append_statement(MIRStatement.ScopeExit(scope))
        let _ = self.scope_stack.pop()
        if not self.current_block_is_terminated() then {
            self.terminate(MIRTerminator.Goto(join_block))
        }
        self.set_current_block(join_block)
        return when result_local in {
            .Some(local_id) then Option[MIRExprResult].Some(MIRExprResult(block_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Local(local_id)), Option[MIRPlace].None())),
            .None() then self.void_result(),
        }
    }

    private lower_statement(self mut ref, statement ref TypedStatement) Void = {
        if self.current_block_is_terminated() then { return }
        when statement in {
            .LetStmt(symbol, value, _) then self.lower_variable_declaration(symbol, value),
            .PairLetStmt(first_symbol, second_symbol, value, _) then self.lower_pair_variable_declaration(first_symbol, second_symbol, value),
            .AssignmentStmt(target, value, _) then self.lower_assignment(target, value),
            .ExprStmt(expr, _) then {
                when self.lower_expression(expr) in {
                    .Some(result) then when result.operand in {
                        .Some(operand) then self.append_statement(MIRStatement.Evaluate(MIRValue.Operand(operand))),
                        .None() then when result.place in {
                            .Some(place) then self.append_statement(MIRStatement.Evaluate(MIRValue.PlaceRead(place, self.ownership_use(expr)))),
                            .None() then {},
                        },
                    },
                    .None() then {},
                }
            },
            .IfStmt(condition, then_branch, else_branch, _) then { let _ = self.lower_if_expression(condition, then_branch, else_branch, Type.VoidType()) },
            .WhileStmt(condition, body, _) then self.lower_while(condition, body),
            .WhenStmt(subject, arms, _) then { let _ = self.lower_when_expression(subject, arms, Type.VoidType()) },
            .ReturnStmt(value, _) then self.lower_return(value),
            .BreakStmt(_) then self.lower_break(),
            .ContinueStmt(_) then self.lower_continue(),
            .FinallyStmt(expr, _) then { let _ = self.lower_expression(expr) },
            .YieldStmt(expr, _) then self.lower_yield(expr),
        }
    }

    private lower_variable_declaration(self mut ref, symbol ref Symbol, value ref TypedExpr) Void = {
        if self.type_is_void_or_never(value.expr_type) then {
            let _ = self.lower_expression(value)
            return
        }
        let local = self.make_local(self.context.symbol_name(symbol), symbol.symbol_type, if symbol.is_mutable() then MIRMutability.Mutable() else MIRMutability.Immutable(), MIRStorage.Local(), Option[ref Symbol].Some(symbol))
        self.local_by_def_id.insert(symbol.def_id.id, local.id)
        self.append_statement(MIRStatement.Declare(local.id))
        self.append_statement(MIRStatement.Assign(MIRPlace.Local(local.id), self.lower_value(value)))
    }

    private lower_pair_variable_declaration(self mut ref, first_symbol Option[ref Symbol], second_symbol Option[ref Symbol], value ref TypedExpr) Void = {
        let operand = self.materialize(self.lower_value(value), value.expr_type)
        when first_symbol in {
            .Some(symbol) then self.lower_pair_binding(symbol, operand, value.expr_type, "first"),
            .None() then {},
        }
        when second_symbol in {
            .Some(symbol) then self.lower_pair_binding(symbol, operand, value.expr_type, "second"),
            .None() then {},
        }
    }

    private lower_pair_binding(self mut ref, symbol ref Symbol, pair_operand MIROperand, pair_type Type, field_name String) Void = {
        let local = self.make_local(self.context.symbol_name(symbol), symbol.symbol_type, if symbol.is_mutable() then MIRMutability.Mutable() else MIRMutability.Immutable(), MIRStorage.Local(), Option[ref Symbol].Some(symbol))
        self.local_by_def_id.insert(symbol.def_id.id, local.id)
        self.append_statement(MIRStatement.Declare(local.id))
        let field_symbol = self.make_synthetic_symbol(field_name, symbol.symbol_type)
        let pair_local = self.materialize(MIRValue.Operand(pair_operand), pair_type)
        self.append_statement(MIRStatement.Assign(MIRPlace.Local(local.id), MIRValue.PlaceRead(MIRPlace.Field(box(MIRPlace.Local(when pair_local in { .Local(id) then id, _ then MIRLocalID(0(UInt)) })), box(field_symbol)), MIROwnershipUse.Copy())))
    }

    private lower_assignment(self mut ref, target ref TypedExpr, value ref TypedExpr) Void = {
        when self.lower_place(target) in {
            .Some(place) then self.append_statement(MIRStatement.Assign(place, self.lower_value(value))),
            .None() then { let _ = self.lower_expression(value) },
        }
    }

    private lower_return(self mut ref, value Option[ref TypedExpr]) Void = {
        when value in {
            .Some(expr) then {
                when expr.expr_kind in {
                    .RefExpr(inner) then when self.lower_place(inner) in {
                        .Some(place) then {
                            let kind = self.reference_kind(expr.expr_type)
                            let operand = self.materialize(MIRValue.Ref(place, kind, MIRReferenceAllocation.HeapOwned()), expr.expr_type)
                            self.emit_scope_exits(0(UInt))
                            self.terminate(MIRTerminator.ReturnValue(Option[MIROperand].Some(operand)))
                            return
                        },
                        .None() then {},
                    },
                    _ then {},
                }
                let operand = self.lower_operand(expr)
                self.emit_scope_exits(0(UInt))
                self.terminate(MIRTerminator.ReturnValue(Option[MIROperand].Some(operand)))
            },
            .None() then {
                self.emit_scope_exits(0(UInt))
                self.terminate(MIRTerminator.ReturnValue(Option[MIROperand].None()))
            },
        }
    }

    private lower_break(self mut ref) Void = {
        if self.loop_stack.is_empty() then { return }
        let loop = self.loop_stack[self.loop_stack.count() - 1(UInt)]
        self.emit_scope_exits(loop.scope_depth)
        self.terminate(MIRTerminator.Goto(loop.break_block))
    }

    private lower_continue(self mut ref) Void = {
        if self.loop_stack.is_empty() then { return }
        let loop = self.loop_stack[self.loop_stack.count() - 1(UInt)]
        self.emit_scope_exits(loop.scope_depth)
        self.terminate(MIRTerminator.Goto(loop.continue_block))
    }

    private lower_yield(self mut ref, value ref TypedExpr) Void = {
        if self.yield_target_stack.is_empty() then { return }
        let target = self.yield_target_stack[self.yield_target_stack.count() - 1(UInt)]
        when target.result_local in {
            .Some(local_id) then self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), self.lower_value(value))),
            .None() then { let _ = self.lower_expression(value) },
        }
        self.emit_scope_exits(target.base_scope_depth)
        self.terminate(MIRTerminator.Goto(target.join_block))
    }

    private emit_scope_exits(self mut ref, base_scope_depth UInt) Void = {
        let mut depth = self.scope_stack.count()
        while depth > base_scope_depth then {
            let scope = self.scope_stack[depth - 1(UInt)]
            self.append_statement(MIRStatement.ScopeExit(scope))
            depth -= 1
        }
    }

    private assign_branch_result(self mut ref, result MIRExprResult, local_id MIRLocalID) Void = {
        when result.operand in {
            .Some(operand) then self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), MIRValue.Operand(operand))),
            .None() then when result.place in {
                .Some(place) then self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), MIRValue.PlaceRead(place, MIROwnershipUse.Copy()))),
                .None() then {},
            },
        }
    }

    private lower_if_expression(self mut ref, condition ref TypedExpr, then_branch ref TypedExpr, else_branch Option[ref TypedExpr], result_type Type) Option[MIRExprResult] = {
        let condition_operand = self.lower_operand_for_expected_type(condition, Type.BoolType())
        let condition_block = self.current_block_id()
        let has_result = not self.type_is_void_or_never(result_type)
        let mut result_local = Option[MIRLocalID].None()
        if has_result then {
            let local = self.make_temporary(result_type, "if_result")
            self.append_statement(MIRStatement.Declare(local.id))
            result_local = Option[MIRLocalID].Some(local.id)
        }
        let then_block = self.make_block()
        let else_block = self.make_block()
        let join_block = self.make_block()
        self.set_current_block(condition_block)
        self.terminate(MIRTerminator.Branch(condition_operand, then_block, else_block))
        self.set_current_block(then_block)
        self.lower_branch_body(then_branch, result_local)
        if not self.current_block_is_terminated() then { self.terminate(MIRTerminator.Goto(join_block)) }
        self.set_current_block(else_block)
        when else_branch in {
            .Some(else_expr) then self.lower_branch_body(else_expr, result_local),
            .None() then {},
        }
        if not self.current_block_is_terminated() then { self.terminate(MIRTerminator.Goto(join_block)) }
        self.set_current_block(join_block)
        return when result_local in {
            .Some(local_id) then Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Local(local_id)), Option[MIRPlace].None())),
            .None() then self.void_result(),
        }
    }

    private lower_branch_body(self mut ref, expression ref TypedExpr, result_local Option[MIRLocalID]) Void = {
        when result_local in {
            .Some(local_id) then {
                // Direct value assignment avoids creating intermediate temporaries,
                // matching Swift compiler's lowerBranchBody optimization.
                let value = self.lower_value(expression)
                self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), value))
            },
            .None() then {
                let _ = self.lower_expression(expression)
            },
        }
    }

    private lower_while(self mut ref, condition ref TypedExpr, body ref TypedExpr) Void = {
        let predecessor_block = self.current_block_id()
        let condition_block = self.make_block()
        let body_block = self.make_block()
        let exit_block = self.make_block()
        self.set_current_block(predecessor_block)
        self.terminate(MIRTerminator.Goto(condition_block))
        self.set_current_block(condition_block)
        let condition_operand = self.lower_operand(condition)
        self.terminate(MIRTerminator.Branch(condition_operand, body_block, exit_block))
        self.set_current_block(body_block)
        self.loop_stack.push(MIRLoopBuilderContext(condition_block, exit_block, self.scope_stack.count()))
        let _ = self.lower_expression(body)
        let _ = self.loop_stack.pop()
        if not self.current_block_is_terminated() then { self.terminate(MIRTerminator.Goto(condition_block)) }
        self.set_current_block(exit_block)
    }

    /// Check if a when expression can be lowered to SwitchValue instead of branch chains.
    /// This is possible when all patterns are simple enum case patterns (with conditionless
    /// payloads) or simple integer/boolean literal patterns, with at most one wildcard/default.
    private can_lower_to_switch_value(self ref, subject ref TypedExpr, arms ref List[ref TypedWhenArm]) Bool = {
        if arms.count() < 2(UInt) then { return false }
        let subject_type = subject.expr_type
        // Dereference reference types
        let matched_type = when subject_type in {
            .ReferenceType(inner) then inner.val,
            .MutableReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then subject_type,
        }
        let mut enum_count UInt = 0
        let mut literal_count UInt = 0
        for arm in arms then {
            when arm.pattern in {
                .Wildcard() then {},
                .Variable(_) then {},
                .EnumCase(_, _, elements) then {
                    if not (matched_type is .EnumType(_)) then { return false }
                    for element in elements then {
                        if not typed_pattern_is_conditionless_payload(element.pattern) then { return false }
                    }
                    enum_count += 1
                },
                .IntegerLiteral(_) then {
                    let is_int = when matched_type in {
                        .IntType() then true,
                        .Int8Type() then true,
                        .Int16Type() then true,
                        .Int32Type() then true,
                        .Int64Type() then true,
                        .UIntType() then true,
                        .UInt8Type() then true,
                        .UInt16Type() then true,
                        .UInt32Type() then true,
                        .UInt64Type() then true,
                        _ then false,
                    }
                    if not is_int then { return false }
                    literal_count += 1
                },
                .BoolLiteral(_) then {
                    if not (matched_type is .BoolType()) then { return false }
                    literal_count += 1
                },
                _ then { return false },
            }
        }
        return (enum_count + literal_count) >= 2(UInt)
    }

    /// Extract the switch constant for a pattern.
    private switch_constant_for_pattern(self ref, pattern ref TypedPattern) Option[MIRConstant] = {
        return when pattern in {
            .EnumCase(_, tag_index, _) then Option[MIRConstant].Some(MIRConstant.Integer(tag_index.to_string(), Type.IntType())),
            .IntegerLiteral(value) then Option[MIRConstant].Some(MIRConstant.Integer(value, Type.IntType())),
            .BoolLiteral(value) then Option[MIRConstant].Some(MIRConstant.Boolean(value)),
            _ then Option[MIRConstant].None(),
        }
    }

    /// Lower a when expression with simple enum/literal patterns to SwitchValue.
    /// This replaces a linear chain of branch checks with a single switch dispatch,
    /// significantly reducing the number of MIR locals and C stack frame size.
    private lower_switch_when_expression(self mut ref, subject ref TypedExpr, arms ref List[ref TypedWhenArm], result_type Type) Option[MIRExprResult] = {
        let subject_value = self.lower_value(subject)
        let subject_operand = self.materialize(subject_value, subject.expr_type)
        let has_result = not self.type_is_void_or_never(result_type)
        let mut result_local = Option[MIRLocalID].None()
        if has_result then {
            let local = self.make_temporary(result_type, "when_result")
            self.append_statement(MIRStatement.Declare(local.id))
            result_local = Option[MIRLocalID].Some(local.id)
        }
        let dispatch_block = self.current_block_id()

        // Dereference reference types to get the actual subject
        let (matched_value, matched_type) = when subject.expr_type in {
            .ReferenceType(inner) then {
                let deref = MIRValue.PlaceRead(MIRPlace.Deref(box(MIRValue.PlaceRead(MIRPlace.Local(when subject_operand in { .Local(id) then id, _ then MIRLocalID(0(UInt)) }), MIROwnershipUse.Borrow())), inner.val), MIROwnershipUse.Borrow())
                yield Pair[MIRValue, Type](deref, inner.val)
            },
            .MutableReferenceType(inner) then {
                let deref = MIRValue.PlaceRead(MIRPlace.Deref(box(MIRValue.PlaceRead(MIRPlace.Local(when subject_operand in { .Local(id) then id, _ then MIRLocalID(0(UInt)) }), MIROwnershipUse.Borrow())), inner.val), MIROwnershipUse.Borrow())
                yield Pair[MIRValue, Type](deref, inner.val)
            },
            _ then Pair[MIRValue, Type](MIRValue.PlaceRead(MIRPlace.Local(when subject_operand in { .Local(id) then id, _ then MIRLocalID(0(UInt)) }), MIROwnershipUse.Borrow()), subject.expr_type),
        }

        // Extract switch operand: enum tag for enums, direct value for int/bool
        let switch_operand = when matched_type in {
            .EnumType(_) then {
                let tag_value = MIRValue.EnumTag(MIREnumTag(box(matched_value), matched_type))
                yield self.materialize(tag_value, Type.IntType())
            },
            _ then self.materialize(matched_value, matched_type),
        }

        let join_block = self.make_block()
        let mut switch_cases = List[MIRSwitchCase].new()
        let mut default_block = Option[MIRBlockID].None()

        // Create case blocks and build switch cases
        for arm in arms then {
            let case_block = self.make_block()
            when arm.pattern in {
                .Wildcard() then { default_block = Option[MIRBlockID].Some(case_block) },
                .Variable(_) then { default_block = Option[MIRBlockID].Some(case_block) },
                _ then {
                    when self.switch_constant_for_pattern(arm.pattern) in {
                        .Some(constant) then { switch_cases.push(MIRSwitchCase(constant, case_block)) },
                        .None() then {},
                    }
                },
            }
        }

        // Create default block if not explicitly provided
        let effective_default = when default_block in {
            .Some(db) then db,
            .None() then {
                let unreachable_block = self.make_block()
                let saved_block = self.current_block_index
                self.set_current_block(unreachable_block)
                self.terminate(MIRTerminator.Unreachable())
                self.current_block_index = saved_block
                yield unreachable_block
            },
        }

        // Emit the switch terminator from the original dispatch block.
        self.set_current_block(dispatch_block)
        self.terminate(MIRTerminator.SwitchValue(switch_operand, switch_cases, Option[MIRBlockID].Some(effective_default)))

        // Emit case bodies
        for arm in arms then {
            let case_block = when arm.pattern in {
                .Wildcard() then default_block,
                .Variable(_) then default_block,
                .EnumCase(_, tag_index, _) then {
                    let target_value = MIRConstant.Integer(tag_index.to_string(), Type.IntType())
                    let mut found = Option[MIRBlockID].None()
                    for sc in switch_cases then {
                        when sc.value in {
                            .Integer(v, _) then {
                                if v == tag_index.to_string() then {
                                    found = Option[MIRBlockID].Some(sc.target)
                                }
                            },
                            _ then {},
                        }
                    }
                    yield found
                },
                .IntegerLiteral(value) then {
                    let mut found = Option[MIRBlockID].None()
                    for sc in switch_cases then {
                        when sc.value in {
                            .Integer(v, _) then {
                                if v == value then {
                                    found = Option[MIRBlockID].Some(sc.target)
                                }
                            },
                            _ then {},
                        }
                    }
                    yield found
                },
                .BoolLiteral(value) then {
                    let mut found = Option[MIRBlockID].None()
                    for sc in switch_cases then {
                        when sc.value in {
                            .Boolean(v) then {
                                if v == value then {
                                    found = Option[MIRBlockID].Some(sc.target)
                                }
                            },
                            _ then {},
                        }
                    }
                    yield found
                },
                _ then Option[MIRBlockID].None(),
            }

            when case_block in {
                .Some(cb) then {
                    self.set_current_block(cb)
                    let subject_place = MIRPlace.Local(when subject_operand in { .Local(id) then id, _ then MIRLocalID(0(UInt)) })
                    let branch_result_local = result_local
                    self.with_pattern_bindings(arm.pattern, subject_place, subject.expr_type, () -> {
                        self.lower_branch_body(arm.body, branch_result_local)
                    })
                    if not self.current_block_is_terminated() then { self.terminate(MIRTerminator.Goto(join_block)) }
                },
                .None() then {},
            }
        }

        self.set_current_block(join_block)
        return when result_local in {
            .Some(local_id) then Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Local(local_id)), Option[MIRPlace].None())),
            .None() then self.void_result(),
        }
    }

    private lower_when_expression(self mut ref, subject ref TypedExpr, arms ref List[ref TypedWhenArm], result_type Type) Option[MIRExprResult] = {
        // Use SwitchValue lowering for simple enum/literal patterns
        if self.can_lower_to_switch_value(subject, arms) then {
            return self.lower_switch_when_expression(subject, arms, result_type)
        }
        let subject_value = self.lower_value(subject)
        let subject_operand = self.materialize(subject_value, subject.expr_type)
        let has_result = not self.type_is_void_or_never(result_type)
        let mut result_local = Option[MIRLocalID].None()
        if has_result then {
            let local = self.make_temporary(result_type, "when_result")
            self.append_statement(MIRStatement.Declare(local.id))
            result_local = Option[MIRLocalID].Some(local.id)
        }
        let dispatch_block = self.current_block_id()
        let join_block = self.make_block()
        let mut next_test_block = dispatch_block
        // Pre-materialize subject operand for reuse across all pattern conditions,
        // matching Swift compiler's lowerSimpleWhenExpression optimization.
        let saved_pattern_subject = self.pattern_subject_operand
        let saved_pattern_tag = self.pattern_subject_tag
        let saved_comparison_local = self.pattern_comparison_local
        self.pattern_subject_operand = Option[MIROperand].Some(subject_operand)
        self.pattern_subject_tag = Option[MIROperand].None()
        // Create a reusable comparison result local to reduce MIR local count.
        // All pattern comparisons in this when expression share this single local.
        let cmp_local = self.make_temporary(Type.BoolType(), "when_cmp")
        self.append_statement(MIRStatement.Declare(cmp_local.id))
        self.pattern_comparison_local = Option[MIRLocalID].Some(cmp_local.id)
        let mut index UInt = 0
        while index < arms.count() then {
            self.set_current_block(next_test_block)
            let condition = self.lower_pattern_condition(MIRPlace.Local(when subject_operand in { .Local(id) then id, _ then MIRLocalID(0(UInt)) }), subject.expr_type, arms[index].pattern, false)
            let condition_block = self.current_block_id()
            let body_block = self.make_block()
            let next_block = if index + 1(UInt) == arms.count() then join_block else self.make_block()
            self.set_current_block(condition_block)
            self.terminate(MIRTerminator.Branch(condition, body_block, next_block))
            self.set_current_block(body_block)
            let arm = arms[index]
            let subject_place = MIRPlace.Local(when subject_operand in { .Local(id) then id, _ then MIRLocalID(0(UInt)) })
            let branch_result_local = result_local
            self.with_pattern_bindings(arm.pattern, subject_place, subject.expr_type, () -> {
                self.lower_branch_body(arm.body, branch_result_local)
            })
            if not self.current_block_is_terminated() then { self.terminate(MIRTerminator.Goto(join_block)) }
            next_test_block = next_block
            index += 1
        }
        self.pattern_subject_operand = saved_pattern_subject
        self.pattern_subject_tag = saved_pattern_tag
        self.pattern_comparison_local = saved_comparison_local
        self.set_current_block(join_block)
        return when result_local in {
            .Some(local_id) then Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Local(local_id)), Option[MIRPlace].None())),
            .None() then self.void_result(),
        }
    }

    private lower_pattern_test(self mut ref, subject ref TypedExpr, pattern ref TypedPattern, negated Bool, result_type Type) MIRExprResult = {
        let subject_value = self.lower_value(subject)
        let subject_operand = self.materialize(subject_value, subject.expr_type)
        let condition = self.lower_pattern_condition(MIRPlace.Local(when subject_operand in { .Local(id) then id, _ then MIRLocalID(0(UInt)) }), subject.expr_type, pattern, negated)
        let result = self.materialize(MIRValue.Operand(condition), result_type)
        return MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None())
    }

    private lower_pattern_condition(self mut ref, subject_place MIRPlace, subject_type Type, pattern ref TypedPattern, negated Bool) MIROperand = {
        when pattern in {
            .NotPattern(inner) then { return self.lower_pattern_condition(subject_place, subject_type, inner, not negated) },
            _ then {},
        }

        let operand = when pattern in {
            .Wildcard() then self.pattern_bool(true),
            .Variable(_) then self.pattern_bool(true),
            .BoolLiteral(value) then self.pattern_compare(subject_place, subject_type, MIROperand.Constant(MIRConstant.Boolean(value)), ComparisonOperator.Equal()),
            .IntegerLiteral(value) then self.pattern_compare(subject_place, subject_type, MIROperand.Constant(MIRConstant.Integer(value, subject_type)), ComparisonOperator.Equal()),
            .NegativeIntegerLiteral(value) then self.pattern_compare(subject_place, subject_type, MIROperand.Constant(MIRConstant.Integer("-\(value)", subject_type)), ComparisonOperator.Equal()),
            .EnumCase(case_name, tag_index, elements) then self.lower_enum_case_pattern_condition(subject_place, subject_type, case_name, tag_index, elements),
            .StructPattern(_, elements) then self.lower_struct_pattern_condition(subject_place, subject_type, elements),
            .ComparisonPattern(op, value) then {
                let comparison_op = when op in {
                    .Greater() then ComparisonOperator.Greater(),
                    .Less() then ComparisonOperator.Less(),
                    .GreaterEqual() then ComparisonOperator.GreaterEqual(),
                    .LessEqual() then ComparisonOperator.LessEqual(),
                }
                yield self.pattern_compare(subject_place, subject_type, MIROperand.Constant(MIRConstant.Integer(value, subject_type)), comparison_op)
            },
            .AndPattern(left, right) then {
                let left_condition = self.lower_pattern_condition(subject_place, subject_type, left, false)
                let right_condition = self.lower_pattern_condition(subject_place, subject_type, right, false)
                yield self.pattern_binary(left_condition, MIRBinaryOperator.LogicalAnd(), right_condition)
            },
            .OrPattern(left, right) then {
                let left_condition = self.lower_pattern_condition(subject_place, subject_type, left, false)
                let right_condition = self.lower_pattern_condition(subject_place, subject_type, right, false)
                yield self.pattern_binary(left_condition, MIRBinaryOperator.LogicalOr(), right_condition)
            },
            .StringLiteral(_) then self.pattern_bool(false),
            .RuneLiteral(_) then self.pattern_bool(false),
            .NotPattern(_) then self.pattern_bool(false),
        }
        return self.pattern_maybe_negate(operand, negated)
    }

    private pattern_bool(self ref, value Bool) MIROperand = {
        return MIROperand.Constant(MIRConstant.Boolean(value))
    }

    private pattern_compare(self mut ref, subject_place MIRPlace, subject_type Type, expected MIROperand, op ComparisonOperator) MIROperand = {
        // Reuse the pre-materialized subject operand when available to avoid
        // creating redundant temporaries across when/if branches.
        let subject_operand = when self.pattern_subject_operand in {
            .Some(op) then op,
            .None() then self.materialize(MIRValue.PlaceRead(subject_place, MIROwnershipUse.Borrow()), subject_type),
        }
        let comparison_value = MIRValue.Binary(MIRBinaryOperation(subject_operand, MIRBinaryOperator.Comparison(op), expected, Type.BoolType()))
        // Reuse a single comparison result local across all arms when available.
        // This significantly reduces MIR local count for pattern-heavy code.
        when self.pattern_comparison_local in {
            .Some(local_id) then {
                self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), comparison_value))
                return MIROperand.Local(local_id)
            },
            .None() then {
                return self.materialize(comparison_value, Type.BoolType())
            },
        }
    }

    private pattern_binary(self mut ref, left MIROperand, op MIRBinaryOperator, right MIROperand) MIROperand = {
        let value = MIRValue.Binary(MIRBinaryOperation(left, op, right, Type.BoolType()))
        if self.pattern_comparison_local is .Some(local_id) then {
            self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), value))
            return MIROperand.Local(local_id)
        }
        return self.materialize(value, Type.BoolType())
    }

    private pattern_maybe_negate(self mut ref, operand MIROperand, negated Bool) MIROperand = {
        if negated then {
            let value = MIRValue.Unary(MIRUnaryOperation(MIRUnaryOperator.LogicalNot(), operand, Type.BoolType()))
            if self.pattern_comparison_local is .Some(local_id) then {
                self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), value))
                return MIROperand.Local(local_id)
            }
            return self.materialize(value, Type.BoolType())
        }
        return operand
    }

    private lower_enum_case_pattern_condition(
        self mut ref,
        subject_place MIRPlace,
        subject_type Type,
        case_name String,
        tag_index UInt,
        elements ref List[ref TypedPatternElement],
    ) MIROperand = {
        // Reuse the cached tag operand when available to avoid creating redundant
        // temporaries across when/if branches (matches Swift compiler optimization).
        let tag_operand = when self.pattern_subject_tag in {
            .Some(cached) then cached,
            .None() then {
                let subject_source = when self.pattern_subject_operand in {
                    .Some(op) then MIRValue.Operand(op),
                    .None() then MIRValue.PlaceRead(subject_place, MIROwnershipUse.Borrow()),
                }
                let tag_value = MIRValue.EnumTag(MIREnumTag(box(subject_source), subject_type))
                let tag = self.materialize(tag_value, Type.IntType())
                self.pattern_subject_tag = Option[MIROperand].Some(tag)
                yield tag
            },
        }
        let expected_tag = MIROperand.Constant(MIRConstant.Integer(tag_index.to_string(), Type.IntType()))
        let tag_comparison = MIRValue.Binary(MIRBinaryOperation(tag_operand, MIRBinaryOperator.Comparison(ComparisonOperator.Equal()), expected_tag, Type.BoolType()))
        // Reuse comparison local when available to reduce MIR local count.
        let tag_condition = when self.pattern_comparison_local in {
            .Some(local_id) then {
                self.append_statement(MIRStatement.Assign(MIRPlace.Local(local_id), tag_comparison))
                yield MIROperand.Local(local_id)
            },
            .None() then self.materialize(tag_comparison, Type.BoolType()),
        }

        if self.pattern_elements_are_conditionless(elements) then {
            return tag_condition
        }

        let mut case_info_opt = Option[EnumCaseInfo].None()
        when subject_type in {
            .EnumType(def_id) then {
                when self.context.get_enum_cases(def_id) in {
                    .Some(cases) then {
                        if tag_index < cases.count() then {
                            case_info_opt = Option[EnumCaseInfo].Some(cases[tag_index])
                        }
                    },
                    .None() then {},
                }
            },
            _ then {},
        }

        when case_info_opt in {
            .Some(case_info) then {
                if not (case_info.params.count() == elements.count()) then { return self.pattern_bool(false) }
                let result_local = self.make_temporary(Type.BoolType(), "pattern_match")
                self.append_statement(MIRStatement.Declare(result_local.id))
                let branch_block = self.current_block_id()
                let payload_block = self.make_block()
                let failed_block = self.make_block()
                let join_block = self.make_block()

                self.set_current_block(branch_block)
                self.terminate(MIRTerminator.Branch(tag_condition, payload_block, failed_block))

                self.set_current_block(payload_block)
                let mut payload_result = self.pattern_bool(true)
                let mut idx UInt = 0
                while idx < elements.count() then {
                    let param = case_info.params[idx]
                    let payload_place = MIRPlace.EnumPayload(box(subject_place), case_name, param.name, idx, param.param_type)
                    let payload_condition = self.lower_pattern_condition(payload_place, param.param_type, elements[idx].pattern, false)
                    payload_result = self.pattern_binary(payload_result, MIRBinaryOperator.LogicalAnd(), payload_condition)
                    idx += 1
                }
                if not self.current_block_is_terminated() then {
                    self.append_statement(MIRStatement.Assign(MIRPlace.Local(result_local.id), MIRValue.Operand(payload_result)))
                    self.terminate(MIRTerminator.Goto(join_block))
                }

                self.set_current_block(failed_block)
                self.append_statement(MIRStatement.Assign(MIRPlace.Local(result_local.id), MIRValue.Operand(self.pattern_bool(false))))
                self.terminate(MIRTerminator.Goto(join_block))

                self.set_current_block(join_block)
                return MIROperand.Local(result_local.id)
            },
            .None() then {
                if not elements.is_empty() then { return self.pattern_bool(false) }
            },
        }

        return tag_condition
    }

    private pattern_elements_are_conditionless(self ref, elements ref List[ref TypedPatternElement]) Bool = {
        for element in elements then {
            if not typed_pattern_is_conditionless_payload(element.pattern) then { return false }
        }
        return true
    }

    private lower_struct_pattern_condition(self mut ref, subject_place MIRPlace, subject_type Type, elements ref List[ref TypedPatternElement]) MIROperand = {
        let mut fields_opt = Option[List[StructField]].None()
        when subject_type in {
            .StructureType(def_id) then { fields_opt = self.context.get_struct_fields(def_id) },
            _ then {},
        }
        when fields_opt in {
            .Some(fields) then {
                if fields.count() < elements.count() then { return self.pattern_bool(false) }
                let mut condition = self.pattern_bool(true)
                let mut idx UInt = 0
                while idx < elements.count() then {
                    let field = fields[idx]
                    let field_symbol = self.make_synthetic_symbol(field.name, field.field_type)
                    let field_place = MIRPlace.Field(box(subject_place), box(field_symbol))
                    let field_condition = self.lower_pattern_condition(field_place, field.field_type, elements[idx].pattern, false)
                    condition = self.pattern_binary(condition, MIRBinaryOperator.LogicalAnd(), field_condition)
                    idx += 1
                }
                return condition
            },
            .None() then {},
        }
        return if elements.is_empty() then self.pattern_bool(true) else self.pattern_bool(false)
    }

    private with_pattern_bindings(
        self mut ref,
        pattern ref TypedPattern,
        subject_place MIRPlace,
        subject_type Type,
        body Func[Void],
    ) Void = {
        let saved_pattern_places = self.pattern_place_by_def_id
        let saved_pattern_names = self.pattern_place_by_name
        self.bind_pattern_variables(pattern, subject_place, subject_type)
        body()
        self.pattern_place_by_def_id = saved_pattern_places
        self.pattern_place_by_name = saved_pattern_names
    }

    private pattern_match_place(self ref, place MIRPlace, subject_type Type) Pair[MIRPlace, Type] = {
        let _ = self
        return when subject_type in {
            .ReferenceType(inner) then Pair[MIRPlace, Type](MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner.val), inner.val),
            .MutableReferenceType(inner) then Pair[MIRPlace, Type](MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner.val), inner.val),
            .WeakReferenceType(inner) then Pair[MIRPlace, Type](MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner.val), inner.val),
            .MutableWeakReferenceType(inner) then Pair[MIRPlace, Type](MIRPlace.Deref(box(MIRValue.PlaceRead(place, MIROwnershipUse.Borrow())), inner.val), inner.val),
            _ then Pair[MIRPlace, Type](place, subject_type),
        }
    }

    private bind_pattern_variables(self mut ref, pattern ref TypedPattern, subject_place MIRPlace, subject_type Type) Void = {
        let matched = self.pattern_match_place(subject_place, subject_type)
        let matched_place = matched.first
        let matched_type = matched.second
        when pattern in {
            .Variable(symbol) then {
                if symbol.symbol_type is not .VoidType() then {
                    let place = if symbol.symbol_type == subject_type then subject_place else matched_place
                    self.pattern_place_by_def_id.insert(symbol.def_id.id, place)
                    self.pattern_place_by_name.insert(self.context.symbol_name(symbol), place)
                }
            },
            .EnumCase(case_name, tag_index, elements) then {
                let mut case_info_opt = Option[EnumCaseInfo].None()
                when matched_type in {
                    .EnumType(def_id) then {
                        when self.context.get_enum_cases(def_id) in {
                            .Some(cases) then {
                                if tag_index < cases.count() then {
                                    case_info_opt = Option[EnumCaseInfo].Some(cases[tag_index])
                                }
                            },
                            .None() then {},
                        }
                    },
                    _ then {},
                }
                when case_info_opt in {
                    .Some(case_info) then {
                        if not (case_info.params.count() == elements.count()) then { return }
                        let mut idx UInt = 0
                        while idx < elements.count() then {
                            let param = case_info.params[idx]
                            let payload_place = MIRPlace.EnumPayload(box(matched_place), case_name, param.name, idx, param.param_type)
                            self.bind_pattern_variables(elements[idx].pattern, payload_place, param.param_type)
                            idx += 1
                        }
                    },
                    .None() then {},
                }
            },
            .StructPattern(_, elements) then {
                let mut fields_opt = Option[List[StructField]].None()
                when matched_type in {
                    .StructureType(def_id) then { fields_opt = self.context.get_struct_fields(def_id) },
                    _ then {},
                }
                when fields_opt in {
                    .Some(fields) then {
                        if fields.count() < elements.count() then { return }
                        let mut idx UInt = 0
                        while idx < elements.count() then {
                            let field = fields[idx]
                            let field_symbol = self.make_synthetic_symbol(field.name, field.field_type)
                            let field_place = MIRPlace.Field(box(matched_place), box(field_symbol))
                            self.bind_pattern_variables(elements[idx].pattern, field_place, field.field_type)
                            idx += 1
                        }
                    },
                    .None() then {},
                }
            },
            .AndPattern(left, right) then {
                self.bind_pattern_variables(left, matched_place, matched_type)
                self.bind_pattern_variables(right, matched_place, matched_type)
            },
            .OrPattern(left, _) then self.bind_pattern_variables(left, matched_place, matched_type),
            .NotPattern(_) then {},
            _ then {},
        }
    }

    private pattern_binding_type(self ref, symbol ref Symbol, subject_type Type) Type = {
        return if self.context.contains_generic_parameter(symbol.symbol_type)
            and not self.context.contains_generic_parameter(subject_type)
        then subject_type else symbol.symbol_type
    }

    private lower_binary(self mut ref, left ref TypedExpr, right ref TypedExpr, result_type Type, operator_kind MIRBinaryOperator) MIRExprResult = {
        let left_expected = when left.expr_type in {
            .ReferenceType(inner_ref) then right.expr_type,
            .MutableReferenceType(inner_ref) then right.expr_type,
            .WeakReferenceType(inner_ref) then right.expr_type,
            .MutableWeakReferenceType(inner_ref) then right.expr_type,
            _ then left.expr_type,
        }
        let right_expected = when right.expr_type in {
            .ReferenceType(inner_ref) then left.expr_type,
            .MutableReferenceType(inner_ref) then left.expr_type,
            .WeakReferenceType(inner_ref) then left.expr_type,
            .MutableWeakReferenceType(inner_ref) then left.expr_type,
            _ then right.expr_type,
        }
        let left_operand = self.lower_operand_for_expected_type(left, left_expected)
        let right_operand = self.lower_operand_for_expected_type(right, right_expected)
        let result = self.materialize(MIRValue.Binary(MIRBinaryOperation(left_operand, operator_kind, right_operand, result_type)), result_type)
        return MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None())
    }

    private lower_short_circuit(self mut ref, left ref TypedExpr, right ref TypedExpr, result_type Type, short_circuit_value Bool) Option[MIRExprResult] = {
        let result_local = self.make_temporary(result_type, "logic_result")
        self.append_statement(MIRStatement.Declare(result_local.id))
        let left_operand = self.lower_operand_for_expected_type(left, Type.BoolType())
        self.append_statement(MIRStatement.Assign(MIRPlace.Local(result_local.id), MIRValue.Operand(left_operand)))
        let eval_right = self.make_block()
        let join = self.make_block()
        if short_circuit_value then {
            self.terminate(MIRTerminator.Branch(left_operand, join, eval_right))
        } else {
            self.terminate(MIRTerminator.Branch(left_operand, eval_right, join))
        }
        self.set_current_block(eval_right)
        self.append_statement(MIRStatement.Assign(MIRPlace.Local(result_local.id), MIRValue.Operand(self.lower_operand_for_expected_type(right, Type.BoolType()))))
        self.terminate(MIRTerminator.Goto(join))
        self.set_current_block(join)
        return Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(MIROperand.Local(result_local.id)), Option[MIRPlace].None()))
    }

    private lower_unary_or_negate(self mut ref, op UnaryOperator, inner ref TypedExpr, result_type Type) MIRExprResult = {
        let operand = if op is .Not() then self.lower_operand_for_expected_type(inner, Type.BoolType()) else self.lower_operand(inner)
        let value = when op in {
            .Not() then MIRValue.Unary(MIRUnaryOperation(MIRUnaryOperator.LogicalNot(), operand, result_type)),
            .BitwiseNot() then MIRValue.Unary(MIRUnaryOperation(MIRUnaryOperator.BitwiseNot(), operand, result_type)),
            .Negate() then MIRValue.Binary(MIRBinaryOperation(MIROperand.Constant(if self.is_float_type(result_type) then MIRConstant.Float("0.0", result_type) else MIRConstant.Integer("0", result_type)), MIRBinaryOperator.Arithmetic(ArithmeticOperator.Subtract(), true), operand, result_type)),
        }
        let result = self.materialize(value, result_type)
        return MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None())
    }

    private lower_call(self mut ref, callee ref TypedExpr, args ref List[ref TypedExpr], result_type Type) Option[MIRExprResult] = {
        when callee.expr_kind in {
            .MethodReference(base, _, method, _, _, _) then {
                when self.concrete_method_symbol(method, base.expr_type, callee.expr_type, result_type) in {
                    .Some(callable_method) then {
                        let mut values = List[ref MIRValue].new()
                        let mut ownerships = List[MIROwnershipUse].new()
                        values.push(box(self.lower_method_receiver_argument(base, callable_method)))
                        ownerships.push(self.ownership_use(base))
                        for arg in args then {
                            values.push(box(self.lower_value(arg)))
                            ownerships.push(self.ownership_use(arg))
                        }
                        return self.finish_call(MIROperand.Function(box(callable_method)), values, ownerships, result_type)
                    },
                    .None() then {
                        // Fallback: construct a concrete method symbol from arg/result types.
                        // This handles cases where callee_type is not FunctionType but the
                        // method can still be called (e.g., extension methods on concrete types).
                        let mut param_types = List[ref Type].new()
                        param_types.push(box(base.expr_type))
                        for arg in args then { param_types.push(box(arg.expr_type)) }
                        let concrete_type = Type.FunctionType(types_to_param_entries(param_types), box(result_type))
                        if not self.context.contains_generic_parameter(concrete_type) then {
                            let fallback_method = Symbol(method.def_id, concrete_type, method.kind)
                            let mut values = List[ref MIRValue].new()
                            let mut ownerships = List[MIROwnershipUse].new()
                            values.push(box(self.lower_method_receiver_argument(base, fallback_method)))
                            ownerships.push(self.ownership_use(base))
                            for arg in args then {
                                values.push(box(self.lower_value(arg)))
                                ownerships.push(self.ownership_use(arg))
                            }
                            return self.finish_call(MIROperand.Function(box(fallback_method)), values, ownerships, result_type)
                        }
                    },
                }
            },
            _ then {},
        }
        let callee_operand = self.lower_operand(callee)
        let lowered = self.lower_call_arguments(callee_operand, args)
        return self.finish_call(callee_operand, lowered.first, lowered.second, result_type)
    }

    private semantic_method_name(self ref, method ref Symbol) String = {
        if method.def_id.id > 0 then {
            when self.program.receiver_method_dispatch.get(method.def_id) in {
                .Some(info) then { return info.method_name },
                .None() then {},
            }
            when self.program.concrete_callables_by_def_id.get(method.def_id) in {
                .Some(info) then { return info.logical_name },
                .None() then {},
            }
            when self.context.get_name(method.def_id) in {
                .Some(name) then { return name },
                .None() then {},
            }
        }
        return self.context.symbol_name(method)
    }

    private receiver_lookup_type(self ref, t Type) Type = {
        return when t in {
            .OpaqueType(def_id) then {
                yield when self.context.lookup_type(def_id) in {
                    .Some(mapped) then self.receiver_lookup_type(mapped),
                    .None() then t,
                }
            },
            .ReferenceType(inner_ref) then Type.ReferenceType(box(self.receiver_lookup_type(inner_ref.val))),
            .MutableReferenceType(inner_ref) then Type.MutableReferenceType(box(self.receiver_lookup_type(inner_ref.val))),
            .PointerType(inner_ref) then Type.PointerType(box(self.receiver_lookup_type(inner_ref.val))),
            .MutablePointerType(inner_ref) then Type.MutablePointerType(box(self.receiver_lookup_type(inner_ref.val))),
            .WeakReferenceType(inner_ref) then Type.WeakReferenceType(box(self.receiver_lookup_type(inner_ref.val))),
            .MutableWeakReferenceType(inner_ref) then Type.MutableWeakReferenceType(box(self.receiver_lookup_type(inner_ref.val))),
            _ then t,
        }
    }

    private normalized_method_lookup_receiver_type(self ref, t Type) Type = {
        let resolved = self.receiver_lookup_type(t)
        return when resolved in {
            .ReferenceType(inner_ref) then when self.receiver_lookup_type(inner_ref.val) in {
                .ReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                .MutableReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                .WeakReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                .MutableWeakReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                _ then resolved,
            },
            .MutableReferenceType(inner_ref) then when self.receiver_lookup_type(inner_ref.val) in {
                .ReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                .MutableReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                .WeakReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                .MutableWeakReferenceType(_) then self.normalized_method_lookup_receiver_type(inner_ref.val),
                _ then resolved,
            },
            _ then resolved,
        }
    }

    private concrete_layout_key_for_def_id(self ref, def_id DefId) Option[String] = {
        let name = self.context.get_name(def_id) or else { return Option[String].None() }
        let module_path = self.context.get_module_path(def_id) or else List[String].new()
        let is_private = when self.context.get_access(def_id) in {
            .Some(access) then access is .Private(),
            .None() then false,
        }
        let source_file = self.context.get_source_file(def_id) or else ""

        let mut parts = List[String].new()
        if not module_path.is_empty() then {
            let mut path_str = String.new()
            let mut first = true
            for seg in module_path then {
                if not first then { path_str.push_byte('_') }
                path_str.push_string(seg)
                first = false
            }
            parts.push(path_str)
        }
        if is_private and not source_file.is_empty() then {
            let mut hash UInt32 = 0
            for byte in source_file.bytes() then {
                hash = hash.wrapping_mul(31).wrapping_add(byte(UInt32))
            }
            parts.push("f\((hash % 10000)(UInt))")
        }
        parts.push(name)

        let mut out = String.new()
        let mut first = true
        for part in parts then {
            if not first then { out.push_byte('_') }
            out.push_string(part)
            first = false
        }
        return Option[String].Some(out)
    }

    private concrete_layout_key_for_type(self ref, t Type) String = {
        return when t in {
            .ReferenceType(inner) then "ref_\(self.concrete_layout_key_for_type(inner.val))",
            .MutableReferenceType(inner) then "mutref_\(self.concrete_layout_key_for_type(inner.val))",
            .PointerType(inner) then "ptr_\(self.concrete_layout_key_for_type(inner.val))",
            .MutablePointerType(inner) then "mutptr_\(self.concrete_layout_key_for_type(inner.val))",
            .WeakReferenceType(inner) then "weakref_\(self.concrete_layout_key_for_type(inner.val))",
            .MutableWeakReferenceType(inner) then "mutweakref_\(self.concrete_layout_key_for_type(inner.val))",
            .FunctionType(fn_params, return_type) then {
                let param_types = param_entry_types(fn_params)
                let mut out = "fn"
                for pt in param_types then {
                    out.push_string("_")
                    out.push_string(self.concrete_layout_key_for_type(pt.val))
                }
                out.push_string("_")
                out.push_string(self.concrete_layout_key_for_type(return_type.val))
                yield out
            },
            .GenericStruct(template, args) then {
                let mut out = template
                for arg in args then {
                    out.push_string("_")
                    out.push_string(self.concrete_layout_key_for_type(arg.val))
                }
                yield out
            },
            .GenericEnum(template, args) then {
                let mut out = template
                for arg in args then {
                    out.push_string("_")
                    out.push_string(self.concrete_layout_key_for_type(arg.val))
                }
                yield out
            },
            .StructureType(def_id) then self.concrete_layout_key_for_def_id(def_id) or else layout_key(t),
            .EnumType(def_id) then self.concrete_layout_key_for_def_id(def_id) or else layout_key(t),
            .OpaqueType(def_id) then self.concrete_layout_key_for_def_id(def_id) or else layout_key(t),
            _ then layout_key(t),
        }
    }

    private concrete_receiver_lookup_key(self ref, receiver_type Type) String = {
        return self.concrete_layout_key_for_type(self.receiver_lookup_type(receiver_type))
    }

    private method_owner_matches_receiver(self ref, owner_type Type, receiver_type Type) Bool = {
        let owner_key = self.concrete_receiver_lookup_key(owner_type)
        if owner_key == self.concrete_receiver_lookup_key(receiver_type) then {
            return true
        }
        return when receiver_type in {
            .ReferenceType(inner) then owner_key == self.concrete_receiver_lookup_key(inner.val),
            .MutableReferenceType(inner) then owner_key == self.concrete_receiver_lookup_key(inner.val),
            .WeakReferenceType(inner) then owner_key == self.concrete_receiver_lookup_key(inner.val),
            .MutableWeakReferenceType(inner) then owner_key == self.concrete_receiver_lookup_key(inner.val),
            _ then false,
        }
    }

    private resolve_static_method_symbol(
        self ref,
        receiver_type Type,
        method_name String,
        method ref Symbol,
        args ref List[ref TypedExpr],
        result_type Type,
    ) Symbol = {
        let _ = receiver_type
        let _ = method_name
        return when self.context.get_function_type(method.def_id) in {
            .Some(function_type) then Symbol(method.def_id, function_type, method.kind),
            .None() then {
                let mut param_types = List[ref Type].new()
                for arg in args then {
                    param_types.push(box(arg.expr_type))
                }
                let concrete_type = Type.FunctionType(types_to_param_entries(param_types), box(result_type))
                yield if self.context.contains_generic_parameter(concrete_type)
                    then Symbol(method.def_id, method.symbol_type, method.kind)
                    else Symbol(method.def_id, concrete_type, method.kind)
            },
        }
    }

    private concrete_method_symbol(self ref, method ref Symbol, receiver_type Type, callee_type Type, result_type Type) Option[Symbol] = {
        let method_name = self.semantic_method_name(method)
        let raw_receiver_type = when receiver_type in {
            .Unknown() then when callee_type in {
                .FunctionType(params, _) then if not params.is_empty() then params[0(UInt)].param_type else Type.Unknown(),
                _ then Type.Unknown(),
            },
            _ then receiver_type,
        }
        let effective_receiver_type = self.normalized_method_lookup_receiver_type(raw_receiver_type)
        when self.lookup_concrete_method_symbol(effective_receiver_type, method_name, result_type) in {
            .Some(symbol) then { return Option[Symbol].Some(symbol) },
            .None() then {},
        }

        when self.context.get_function_type(method.def_id) in {
            .Some(function_type) then { return Option[Symbol].Some(Symbol(method.def_id, function_type, method.kind)) },
            .None() then {},
        }

        return when callee_type in {
            .FunctionType(params, _) then {
                let concrete_type = Type.FunctionType(params, box(result_type))
                if self.context.contains_generic_parameter(concrete_type) then {
                    yield Option[Symbol].None()
                } else {
                    yield Option[Symbol].Some(Symbol(method.def_id, concrete_type, method.kind))
                }
            },
            _ then Option[Symbol].None(),
        }
    }

    private lookup_concrete_method_symbol(self ref, receiver_type Type, method_name String, result_type Type) Option[Symbol] = {
        if receiver_type is .Unknown() then {
            return Option[Symbol].None()
        }
        for entry in self.program.concrete_callables_by_def_id.iterator() then {
            let def_id = entry.first
            let info = entry.second
            let logical_name = info.logical_name
            let suffix_match = if logical_name.ends_with("_" + method_name) then {
                let prefix_len = logical_name.count() - method_name.count() - 1
                let prefix = logical_name.substring(0..<prefix_len)
                if prefix.is_empty() then {
                    yield false
                } else {
                    let first = prefix.to_runes()[0(UInt)]
                    yield first >= 'A' and first <= 'Z'
                }
            } else {
                yield false
            }
            if logical_name <> method_name and not suffix_match then {
                continue
            }
            when info.owner_type in {
                .Some(owner_type) then {
                    if not self.method_owner_matches_receiver(owner_type, receiver_type) then {
                        continue
                    }
                    when self.context.get_function_type(def_id) in {
                        .Some(function_type) then { return Option[Symbol].Some(Symbol(def_id, function_type, SymbolKind.Function())) },
                        .None() then {
                            let mut param_types = List[ref Type].new()
                            when receiver_type in {
                                .Unknown() then {},
                                _ then param_types.push(box(receiver_type)),
                            }
                            let concrete_type = Type.FunctionType(types_to_param_entries(param_types), box(result_type))
                            if not self.context.contains_generic_parameter(concrete_type) then {
                                return Option[Symbol].Some(Symbol(def_id, concrete_type, SymbolKind.Function()))
                            }
                        },
                    }
                },
                .None() then {},
            }
        }
        return Option[Symbol].None()
    }

    private lower_call_arguments(self mut ref, callee MIROperand, args ref List[ref TypedExpr]) Pair[List[ref MIRValue], List[MIROwnershipUse]] = {
        let param_types = self.function_parameter_types(callee)
        let mut values = List[ref MIRValue].new()
        let mut ownerships = List[MIROwnershipUse].new()
        let mut index UInt = 0
        while index < args.count() then {
            let expected_type = if index < param_types.count() then Option[Type].Some(param_types[index]) else Option[Type].None()
            values.push(box(self.lower_call_argument(args[index], expected_type)))
            ownerships.push(self.ownership_use(args[index]))
            index += 1
        }
        return Pair[List[ref MIRValue], List[MIROwnershipUse]](values, ownerships)
    }

    private lower_call_argument(self mut ref, arg ref TypedExpr, expected_type Option[Type]) MIRValue = {
        when self.lower_borrowed_reference_argument(arg, expected_type) in {
            .Some(borrowed) then { return borrowed },
            .None() then {},
        }
        return self.lower_value(arg)
    }

    private lower_method_receiver_argument(self mut ref, base ref TypedExpr, method Symbol) MIRValue = {
        let method_type = self.context.get_function_type(method.def_id) or else method.symbol_type
        return when method_type in {
            .FunctionType(params, _) then {
                if not params.is_empty() then {
                    when self.lower_borrowed_reference_argument(base, Option[Type].Some(params[0(UInt)].param_type)) in {
                        .Some(borrowed) then { return borrowed },
                        .None() then {},
                    }
                }
                yield self.lower_value(base)
            }
            _ then self.lower_value(base),
        }
    }

    private lower_borrowed_reference_argument(self mut ref, arg ref TypedExpr, expected_type Option[Type]) Option[MIRValue] = {
        return when expected_type in {
            .Some(t) then when t in {
                .ReferenceType(inner) then {
                    when arg.expr_kind in {
                        .RefExpr(ref_inner) then {
                            if ref_inner.expr_type == t then {
                                return Option[MIRValue].Some(self.lower_value(ref_inner))
                            }
                        },
                        _ then {},
                    }
                    if arg.expr_type == inner.val then {
                        when self.lower_place(arg) in {
                            .Some(place) then { return Option[MIRValue].Some(MIRValue.Ref(place, MIRReferenceKind.Shared(), MIRReferenceAllocation.StackBorrow())) },
                            .None() then {},
                        }
                    }
                    yield if arg.expr_type == t then Option[MIRValue].Some(self.lower_value(arg)) else Option[MIRValue].None()
                },
                .MutableReferenceType(inner) then {
                    when arg.expr_kind in {
                        .RefExpr(ref_inner) then {
                            if ref_inner.expr_type == t then {
                                return Option[MIRValue].Some(self.lower_value(ref_inner))
                            }
                        },
                        _ then {},
                    }
                    if arg.expr_type == inner.val then {
                        when self.lower_place(arg) in {
                            .Some(place) then { return Option[MIRValue].Some(MIRValue.Ref(place, MIRReferenceKind.Mutable(), MIRReferenceAllocation.StackBorrow())) },
                            .None() then {},
                        }
                    }
                    yield if arg.expr_type == t then Option[MIRValue].Some(self.lower_value(arg)) else Option[MIRValue].None()
                },
                .WeakReferenceType(inner) then {
                    when arg.expr_kind in {
                        .RefExpr(ref_inner) then {
                            if ref_inner.expr_type == t then {
                                return Option[MIRValue].Some(self.lower_value(ref_inner))
                            }
                        },
                        _ then {},
                    }
                    if arg.expr_type == inner.val then {
                        when self.lower_place(arg) in {
                            .Some(place) then { return Option[MIRValue].Some(MIRValue.Ref(place, MIRReferenceKind.Weak(), MIRReferenceAllocation.StackBorrow())) },
                            .None() then {},
                        }
                    }
                    yield if arg.expr_type == t then Option[MIRValue].Some(self.lower_value(arg)) else Option[MIRValue].None()
                },
                .MutableWeakReferenceType(inner) then {
                    when arg.expr_kind in {
                        .RefExpr(ref_inner) then {
                            if ref_inner.expr_type == t then {
                                return Option[MIRValue].Some(self.lower_value(ref_inner))
                            }
                        },
                        _ then {},
                    }
                    if arg.expr_type == inner.val then {
                        when self.lower_place(arg) in {
                            .Some(place) then { return Option[MIRValue].Some(MIRValue.Ref(place, MIRReferenceKind.MutableWeak(), MIRReferenceAllocation.StackBorrow())) },
                            .None() then {},
                        }
                    }
                    yield if arg.expr_type == t then Option[MIRValue].Some(self.lower_value(arg)) else Option[MIRValue].None()
                },
                _ then Option[MIRValue].None(),
            },
            .None() then Option[MIRValue].None(),
        }
    }

    private function_parameter_types(self ref, callee MIROperand) List[Type] = {
        let callee_type = self.type_of_operand(callee)
        return when callee_type in {
            .FunctionType(params, _) then {
                let mut out = List[Type].new()
                for param in params then { out.push(param.param_type) }
                yield out
            },
            _ then List[Type].new(),
        }
    }

    private type_of_operand(self ref, operand MIROperand) Type = {
        let _ = self
        return when operand in {
            .Function(symbol) then symbol.symbol_type,
            _ then Type.Unknown(),
        }
    }

    private finish_call(self mut ref, callee MIROperand, values List[ref MIRValue], ownerships List[MIROwnershipUse], result_type Type) Option[MIRExprResult] = {
        let value = MIRValue.Call(MIRCall(callee, values, ownerships, result_type))
        if self.type_is_never(result_type) then {
            self.append_statement(MIRStatement.Evaluate(value))
            self.terminate(MIRTerminator.Unreachable())
            return Option[MIRExprResult].None()
        }
        if self.type_is_void(result_type) then {
            self.append_statement(MIRStatement.Evaluate(value))
            return self.void_result()
        }
        let result = self.materialize(value, result_type)
        return Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
    }

    private finish_call_from_typed_args(self mut ref, callee MIROperand, args ref List[ref TypedExpr], result_type Type) Option[MIRExprResult] = {
        let lowered = self.lower_call_arguments(callee, args)
        return self.finish_call(callee, lowered.first, lowered.second, result_type)
    }

    private lower_type_construction(self mut ref, identifier ref Symbol, args ref List[ref TypedExpr], result_type Type) Option[MIRExprResult] = {
        let mut values = List[ref MIRValue].new()
        let mut ownerships = List[MIROwnershipUse].new()
        for arg in args then {
            values.push(box(self.lower_value(arg)))
            ownerships.push(self.ownership_use(arg))
        }
        let aggregate_type = self.recover_type_construction_result_type(identifier, args, result_type)
        let result = self.materialize(MIRValue.Aggregate(MIRAggregate(aggregate_type, values, ownerships)), aggregate_type)
        return Option[MIRExprResult].Some(MIRExprResult(aggregate_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
    }

    private lower_enum_construction(self mut ref, enum_type Type, case_name String, args ref List[ref TypedExpr]) Option[MIRExprResult] = {
        let mut values = List[ref MIRValue].new()
        for arg in args then { values.push(box(self.lower_value(arg))) }
        let result = self.materialize(MIRValue.EnumCase(MIREnumConstruction(enum_type, case_name, values)), enum_type)
        return Option[MIRExprResult].Some(MIRExprResult(enum_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
    }

    private lower_ref_expression(self mut ref, inner ref TypedExpr, result_type Type) Option[MIRExprResult] = {
        return when self.lower_place(inner) in {
            .Some(place) then {
                let result = self.materialize(MIRValue.Ref(place, self.reference_kind(result_type), MIRReferenceAllocation.StackBorrow()), result_type)
                yield Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
            },
            .None() then {
                let source_local = self.make_temporary(inner.expr_type, "ref_source")
                self.append_statement(MIRStatement.Declare(source_local.id))
                self.append_statement(MIRStatement.Assign(MIRPlace.Local(source_local.id), self.lower_value(inner)))
                let result = self.materialize(MIRValue.Ref(MIRPlace.Local(source_local.id), self.reference_kind(result_type), MIRReferenceAllocation.HeapOwned()), result_type)
                yield Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
            },
        }
    }

    private lower_trait_object_conversion(self mut ref, inner ref TypedExpr, trait_type Type, concrete_type Type, result_type Type) Option[MIRExprResult] = {
        let trait_name = when trait_type in { .TraitObject(name, _) then name, .ReferenceType(inner_ref) then when inner_ref in { .TraitObject(name, _) then name, _ then "" }, _ then "" }
        let trait_args = self.trait_object_type_args(trait_type)
        let value = MIRValue.TraitObjectConversion(MIRTraitObjectConversion(box(self.lower_value(inner)), self.ownership_use(inner), trait_name, trait_args, concrete_type, result_type))
        let result = self.materialize(value, result_type)
        return Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
    }

    private lower_trait_method_call(self mut ref, receiver ref TypedExpr, trait_type Type, method_name String, method_index Int, args ref List[ref TypedExpr], result_type Type) Option[MIRExprResult] = {
        let trait_name = when trait_type in { .TraitObject(name, _) then name, .ReferenceType(inner_ref) then when inner_ref in { .TraitObject(name, _) then name, _ then "" }, _ then "" }
        let trait_args = self.trait_object_type_args(trait_type)
        let mut values = List[ref MIRValue].new()
        let mut ownerships = List[MIROwnershipUse].new()
        for arg in args then {
            values.push(box(self.lower_value(arg)))
            ownerships.push(self.ownership_use(arg))
        }
        let value = MIRValue.TraitMethodCall(MIRTraitMethodCall(box(self.lower_value(receiver)), self.ownership_use(receiver), trait_name, trait_args, method_name, method_index, values, ownerships, result_type))
        if self.type_is_void(result_type) then {
            self.append_statement(MIRStatement.Evaluate(value))
            return self.void_result()
        }
        let result = self.materialize(value, result_type)
        return Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
    }

    private lower_intrinsic_call(self mut ref, intrinsic_node TypedIntrinsic) Option[MIRExprResult] = {
        let node = self.lower_intrinsic(intrinsic_node)
        let result_type = self.intrinsic_result_type(intrinsic_node)
        if self.type_is_void(result_type) then {
            self.append_statement(MIRStatement.Evaluate(MIRValue.Intrinsic(node)))
            return self.void_result()
        }
        let result = self.materialize(MIRValue.Intrinsic(node), result_type)
        return Option[MIRExprResult].Some(MIRExprResult(result_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
    }

    private lower_intrinsic(self mut ref, intrinsic_node TypedIntrinsic) MIRIntrinsic = {
        return when intrinsic_node in {
            .AllocMemory(count, result_type) then MIRIntrinsic.AllocMemory(box(self.lower_value(count)), result_type),
            .DeallocMemory(pointer_expr) then MIRIntrinsic.DeallocMemory(box(self.lower_value(pointer_expr))),
            .CopyMemory(dest, source, count) then MIRIntrinsic.CopyMemory(box(self.lower_value(dest)), box(self.lower_value(source)), box(self.lower_value(count))),
            .MoveMemory(dest, source, count) then MIRIntrinsic.MoveMemory(box(self.lower_value(dest)), box(self.lower_value(source)), box(self.lower_value(count))),
            .IsUniqueMutable(value) then MIRIntrinsic.IsUniqueMutable(box(self.lower_uniqueness_probe_value(value))),
            .RefCount(value) then MIRIntrinsic.RefCount(box(self.lower_value(value))),
            .MakeRef(pointer_expr, owner_expr, result_type) then MIRIntrinsic.MakeRef(box(self.lower_value(pointer_expr)), box(self.lower_value(owner_expr)), result_type),
            .MakeMutRef(pointer_expr, owner_expr, result_type) then MIRIntrinsic.MakeMutRef(box(self.lower_value(pointer_expr)), box(self.lower_value(owner_expr)), result_type),
            .DowngradeRef(value, result_type) then MIRIntrinsic.DowngradeRef(box(self.lower_value(value)), result_type),
            .DowngradeMutRef(value, result_type) then MIRIntrinsic.DowngradeMutRef(box(self.lower_value(value)), result_type),
            .UpgradeRef(value, result_type) then MIRIntrinsic.UpgradeRef(box(self.lower_value(value)), result_type),
            .UpgradeMutRef(value, result_type) then MIRIntrinsic.UpgradeMutRef(box(self.lower_value(value)), result_type),
            .InitMemory(pointer_expr, value_expr) then MIRIntrinsic.InitMemory(box(self.lower_value(pointer_expr)), box(self.lower_value(value_expr))),
            .DeinitMemory(pointer_expr) then MIRIntrinsic.DeinitMemory(box(self.lower_value(pointer_expr))),
            .TakeMemory(pointer_expr, result_type) then MIRIntrinsic.TakeMemory(box(self.lower_value(pointer_expr)), result_type),
            .NullPtr(result_type) then MIRIntrinsic.NullPtr(result_type),
            .SpawnThread(out_handle, out_tid, closure, stack_size) then MIRIntrinsic.SpawnThread(box(self.lower_value(out_handle)), box(self.lower_value(out_tid)), box(self.lower_value(closure)), box(self.lower_value(stack_size))),
        }
    }

    private intrinsic_result_type(self ref, intrinsic_node TypedIntrinsic) Type = {
        return when intrinsic_node in {
            .AllocMemory(_, result_type) then result_type,
            .IsUniqueMutable(_) then Type.BoolType(),
            .RefCount(_) then Type.UIntType(),
            .MakeRef(_, _, result_type) then result_type,
            .MakeMutRef(_, _, result_type) then result_type,
            .DowngradeRef(_, result_type) then result_type,
            .DowngradeMutRef(_, result_type) then result_type,
            .UpgradeRef(_, result_type) then result_type,
            .UpgradeMutRef(_, result_type) then result_type,
            .TakeMemory(_, result_type) then result_type,
            .NullPtr(result_type) then result_type,
            .SpawnThread(_, _, _, _) then Type.Int32Type(),
            _ then Type.VoidType(),
        }
    }

    private lower_lambda_expression(self mut ref, params List[TypedParam], return_type Type, body ref TypedExpr, lambda_type Type) Option[MIRExprResult] = {
        let mut captures = List[ref Symbol].new()
        let mut capture_sources = List[MIRPlace].new()
        self.collect_captures(body, params, captures.ref)
        for capture in captures then { capture_sources.push(self.capture_place(capture)) }
        let mut param_symbols = List[ref Symbol].new()
        for param in params then {
            let symbol = box(Symbol(self.context.allocate_unindexed(param.name, DefKind.Variable()), param.param_type, SymbolKind.Variable(if param.mutable then VariableKind.MutableValue() else VariableKind.Value())))
            param_symbols.push(symbol)
        }
        let function_type = Type.FunctionType(types_to_param_entries(self.param_types_to_refs(params)), box(return_type))
        let lambda_identifier = box(Symbol(self.context.allocate_unindexed("__mir_lambda_\(self.identifier.def_id.id)_\(self.next_local_id)_\(self.next_block_id)", DefKind.Function()), function_type, SymbolKind.Function()))
        let mut builder = MIRFunctionBuilder.new(self.program, lambda_identifier, params, captures, return_type, MIRFunctionKind.Global(), body, self.context)
        let nested = builder.lower()
        let value = MIRValue.Lambda(MIRLambda(param_symbols, captures, capture_sources, nested, lambda_type))
        let result = self.materialize(value, lambda_type)
        return Option[MIRExprResult].Some(MIRExprResult(lambda_type, ValueCategory.RValue(), Option[MIROperand].Some(result), Option[MIRPlace].None()))
    }

    private param_types_to_refs(self ref, params List[TypedParam]) List[ref Type] = {
        let mut out = List[ref Type].new()
        for param in params then { out.push(box(param.param_type)) }
        return out
    }

    private lower_value(self mut ref, expression ref TypedExpr) MIRValue = {
        when expression.expr_kind in {
            .RefExpr(inner) then when self.lower_place(inner) in {
                .Some(place) then { return MIRValue.Ref(place, self.reference_kind(expression.expr_type), MIRReferenceAllocation.StackBorrow()) },
                .None() then {},
            },
            .PtrExpr(inner) then when self.lower_place(inner) in {
                .Some(place) then { return MIRValue.Pointer(place) },
                .None() then {},
            },
            _ then {},
        }
        return when self.lower_expression(expression) in {
            .Some(result) then when result.operand in {
                .Some(operand) then MIRValue.Operand(operand),
                .None() then when result.place in {
                    .Some(place) then MIRValue.PlaceRead(place, MIROwnershipUse.Copy()),
                    .None() then MIRValue.Operand(MIROperand.Constant(MIRConstant.Void())),
                },
            },
            .None() then MIRValue.Operand(MIROperand.Constant(MIRConstant.Void())),
        }
    }

    private lower_borrowed_source_value(self mut ref, expression ref TypedExpr) MIRValue = {
        if expression.expr_kind is .CastExpr(_, inner) and self.is_ownership_preserving_place_cast(inner.expr_type, expression.expr_type) then {
            return self.lower_borrowed_source_value(inner)
        }
        return when self.lower_expression(expression) in {
            .Some(result) then when result.place in {
                .Some(place) then MIRValue.PlaceRead(place, MIROwnershipUse.Borrow()),
                .None() then when result.operand in {
                    .Some(operand) then when operand in {
                        .Local(local_id) then MIRValue.PlaceRead(MIRPlace.Local(local_id), MIROwnershipUse.Borrow()),
                        _ then MIRValue.Operand(operand),
                    },
                    .None() then MIRValue.Operand(MIROperand.Constant(MIRConstant.Void())),
                },
            },
            .None() then MIRValue.Operand(MIROperand.Constant(MIRConstant.Void())),
        }
    }

    private lower_uniqueness_probe_value(self mut ref, expression ref TypedExpr) MIRValue = {
        return self.lower_borrowed_source_value(expression)
    }

    private lower_operand(self mut ref, expression ref TypedExpr) MIROperand = {
        return when self.lower_expression(expression) in {
            .Some(result) then when result.operand in {
                .Some(operand) then operand,
                .None() then when result.place in {
                    .Some(place) then self.materialize(MIRValue.PlaceRead(place, MIROwnershipUse.Copy()), result.result_type),
                    .None() then MIROperand.Constant(MIRConstant.Void()),
                },
            },
            .None() then MIROperand.Constant(MIRConstant.Void()),
        }
    }

    private lower_operand_for_expected_type(self mut ref, expression ref TypedExpr, expected_type Type) MIROperand = {
        return when self.lower_expression(expression) in {
            .Some(result) then when result.operand in {
                .Some(operand) then self.adapt_operand_to_expected_type(operand, result.result_type, expected_type),
                .None() then when result.place in {
                    .Some(place) then self.materialize(self.read_place_for_expected_type(place, result.result_type, expected_type), expected_type),
                    .None() then MIROperand.Constant(MIRConstant.Void()),
                },
            },
            .None() then MIROperand.Constant(MIRConstant.Void()),
        }
    }

    private materialize(self mut ref, value MIRValue, result_type Type) MIROperand = {
        if self.type_is_void_or_never(result_type) then { return MIROperand.Constant(MIRConstant.Void()) }
        let local = self.make_temporary(result_type, "tmp")
        self.append_statement(MIRStatement.Declare(local.id))
        self.append_statement(MIRStatement.Assign(MIRPlace.Local(local.id), value))
        return MIROperand.Local(local.id)
    }

    private lower_place(self mut ref, expression ref TypedExpr) Option[MIRPlace] = {
        return when expression.expr_kind in {
            .Variable(symbol) then {
                when self.pattern_place_by_def_id.get(symbol.def_id.id) in {
                    .Some(place) then { return Option[MIRPlace].Some(place) },
                    .None() then {},
                }
                let name = self.context.symbol_name(symbol)
                when self.pattern_place_by_name.get(name) in {
                    .Some(place) then { return Option[MIRPlace].Some(place) },
                    .None() then {},
                }
                when self.local_by_def_id.get(symbol.def_id.id) in {
                    .Some(local_id) then { return Option[MIRPlace].Some(MIRPlace.Local(local_id)) },
                    .None() then {},
                }
                when self.parameter_local_by_name.get(name) in {
                    .Some(local_id) then {
                        self.local_by_def_id.insert(symbol.def_id.id, local_id)
                        return Option[MIRPlace].Some(MIRPlace.Local(local_id))
                    },
                    .None() then {},
                }
                // Fallback: if the symbol is a variable (not a true global),
                // create a MIR local for it. This handles cases where pattern
                // bindings are missing (e.g., for-loop variables).
                let is_top_level_variable = when symbol.kind in {
                    .Variable(_) then {
                        let has_module_path = self.context.get_module_path(symbol.def_id) is .Some(_)
                        let has_source_file = self.context.get_source_file(symbol.def_id) is .Some(_)
                        yield has_module_path or has_source_file
                    },
                    _ then false,
                }
                yield when symbol.kind in {
                    .Variable(_) then if is_top_level_variable
                        then Option[MIRPlace].Some(MIRPlace.Global(symbol.def_id))
                        else {
                            let local = self.make_local(name, symbol.symbol_type, if symbol.is_mutable() then MIRMutability.Mutable() else MIRMutability.Immutable(), MIRStorage.Local(), Option[ref Symbol].Some(symbol))
                            self.local_by_def_id.insert(symbol.def_id.id, local.id)
                            yield Option[MIRPlace].Some(MIRPlace.Local(local.id))
                        },
                    _ then Option[MIRPlace].Some(MIRPlace.Global(symbol.def_id)),
                }
            },
            .MemberPath(base, path) then {
                let mut base_place = when base.expr_type in {
                    .ReferenceType(inner) then MIRPlace.Deref(box(self.lower_borrowed_source_value(base)), inner.val),
                    .MutableReferenceType(inner) then MIRPlace.Deref(box(self.lower_borrowed_source_value(base)), inner.val),
                    .WeakReferenceType(inner) then MIRPlace.Deref(box(self.lower_borrowed_source_value(base)), inner.val),
                    .MutableWeakReferenceType(inner) then MIRPlace.Deref(box(self.lower_borrowed_source_value(base)), inner.val),
                    .PointerType(inner) then MIRPlace.Deref(box(self.lower_borrowed_source_value(base)), inner.val),
                    .MutablePointerType(inner) then MIRPlace.Deref(box(self.lower_borrowed_source_value(base)), inner.val),
                    _ then self.lower_place(base) or else { return Option[MIRPlace].None() },
                }
                let mut current_type = base.expr_type
                for segment in path then {
                    let field_type = self.lookup_field_type(current_type, segment)
                    let field_symbol = self.make_synthetic_symbol(segment, field_type)
                    base_place = MIRPlace.Field(box(base_place), box(field_symbol))
                    current_type = field_type
                }
                yield Option[MIRPlace].Some(base_place)
            },
            .DerefExpr(inner) then {
                let pointee = self.deref_pointee_type(inner.expr_type, expression.expr_type)
                yield Option[MIRPlace].Some(MIRPlace.Deref(box(self.lower_borrowed_source_value(inner)), pointee))
            },
            .CastExpr(_, inner) then self.lower_place(inner),
            _ then Option[MIRPlace].None(),
        }
    }

    private lower_materialized_member_path_place(self mut ref, expression ref TypedExpr) Option[MIRPlace] = {
        return when expression.expr_kind in {
            .MemberPath(base, path) then {
                let lowered_base = self.lower_expression(base)
                let base_result = when lowered_base in {
                    .Some(result) then result,
                    .None() then { return Option[MIRPlace].None() },
                }
                let base_place = when base_result.place in {
                    .Some(place) then Option[MIRPlace].Some(place),
                    .None() then when base_result.operand in {
                        .Some(operand) then when operand in {
                            .Local(local_id) then Option[MIRPlace].Some(MIRPlace.Local(local_id)),
                            _ then {
                                let local = self.make_temporary(base.expr_type, "member_base")
                                self.append_statement(MIRStatement.Declare(local.id))
                                self.append_statement(MIRStatement.Assign(MIRPlace.Local(local.id), MIRValue.Operand(operand)))
                                yield Option[MIRPlace].Some(MIRPlace.Local(local.id))
                            },
                        },
                        .None() then Option[MIRPlace].None(),
                    },
                }
                let mut place = when base_place in {
                    .Some(existing_place) then existing_place,
                    .None() then { return Option[MIRPlace].None() },
                }
                let mut current_type = base.expr_type
                for field in path then {
                    let field_type = self.lookup_field_type(current_type, field)
                    let field_symbol = self.make_synthetic_symbol(field, field_type)
                    place = MIRPlace.Field(box(place), box(field_symbol))
                    current_type = field_type
                }
                yield Option[MIRPlace].Some(place)
            },
            _ then Option[MIRPlace].None(),
        }
    }

    private make_synthetic_symbol(self mut ref, name String, symbol_type Type) Symbol = {
        return Symbol(self.context.allocate_unindexed(name, DefKind.Variable()), symbol_type, SymbolKind.Variable(VariableKind.Value()))
    }

    private capture_place(self mut ref, symbol ref Symbol) MIRPlace = {
        return when self.local_by_def_id.get(symbol.def_id.id) in {
            .Some(local_id) then MIRPlace.Local(local_id),
            .None() then MIRPlace.Global(symbol.def_id),
        }
    }

    private collect_captures(self mut ref, expr ref TypedExpr, params List[TypedParam], out mut ref List[ref Symbol]) Void = {
        let mut param_names = Set[String].new()
        for p in params then { param_names.insert(p.name) }
        self.collect_captures_expr(expr, param_names, out)
    }

    private collect_captures_expr(self mut ref, expr ref TypedExpr, param_names Set[String], out mut ref List[ref Symbol]) Void = {
        when expr.expr_kind in {
            .Variable(symbol) then {
                let name = self.context.symbol_name(symbol)
                if not param_names.contains(name) and self.local_by_def_id.get(symbol.def_id.id) is .Some(_) then {
                    let mut seen = false
                    let mut capture_index UInt = 0
                    while capture_index < out.count() then {
                        if out[capture_index].def_id.id == symbol.def_id.id then { seen = true }
                        capture_index += 1
                    }
                    if not seen then { out.push(symbol) }
                }
            },
            .Block(statements) then for stmt in statements then { self.collect_captures_stmt(stmt, param_names, out) },
            .IfExpr(c, t, e) then {
                self.collect_captures_expr(c, param_names, out)
                self.collect_captures_expr(t, param_names, out)
                when e in { .Some(x) then self.collect_captures_expr(x, param_names, out), .None() then {} }
            },
            .WhenExpr(subject, arms) then {
                self.collect_captures_expr(subject, param_names, out)
                for arm in arms then { self.collect_captures_expr(arm.body, param_names, out) }
            },
            .Call(callee, args) then {
                self.collect_captures_expr(callee, param_names, out)
                for arg in args then { self.collect_captures_expr(arg, param_names, out) }
            },
            .GenericCall(_, _, args) then for arg in args then { self.collect_captures_expr(arg, param_names, out) },
            .StaticMethodCall(_, _, _, _, _, args) then for arg in args then { self.collect_captures_expr(arg, param_names, out) },
            .TraitMethodCall(receiver, _, _, _, args) then {
                self.collect_captures_expr(receiver, param_names, out)
                for arg in args then { self.collect_captures_expr(arg, param_names, out) }
            },
            .TraitObjectConversion(inner, _, _) then self.collect_captures_expr(inner, param_names, out),
            .MethodReference(base, _, _, _, _, _) then self.collect_captures_expr(base, param_names, out),
            .TraitMethodPlaceholder(base, _, _, _, _) then self.collect_captures_expr(base, param_names, out),
            .RefExpr(inner) then self.collect_captures_expr(inner, param_names, out),
            .PtrExpr(inner) then self.collect_captures_expr(inner, param_names, out),
            .DerefExpr(inner) then self.collect_captures_expr(inner, param_names, out),
            .CastExpr(_, inner) then self.collect_captures_expr(inner, param_names, out),
            .Unary(_, inner) then self.collect_captures_expr(inner, param_names, out),
            .MemberPath(base, _) then self.collect_captures_expr(base, param_names, out),
            .ArithmeticExpr(l, _, r) then {
                self.collect_captures_expr(l, param_names, out)
                self.collect_captures_expr(r, param_names, out)
            },
            .WrappingArithmeticExpr(l, _, r) then {
                self.collect_captures_expr(l, param_names, out)
                self.collect_captures_expr(r, param_names, out)
            },
            .WrappingShiftExpr(l, _, r) then {
                self.collect_captures_expr(l, param_names, out)
                self.collect_captures_expr(r, param_names, out)
            },
            .ComparisonExpr(l, _, r) then {
                self.collect_captures_expr(l, param_names, out)
                self.collect_captures_expr(r, param_names, out)
            },
            .BitwiseExpr(l, _, r) then {
                self.collect_captures_expr(l, param_names, out)
                self.collect_captures_expr(r, param_names, out)
            },
            .AndExpr(l, r) then {
                self.collect_captures_expr(l, param_names, out)
                self.collect_captures_expr(r, param_names, out)
            },
            .OrExpr(l, r) then {
                self.collect_captures_expr(l, param_names, out)
                self.collect_captures_expr(r, param_names, out)
            },
            .IsExpr(subject, _, _) then self.collect_captures_expr(subject, param_names, out),
            .LambdaExpr(_, _, _) then {},
            .IntrinsicCall(_) then {},
            _ then {},
        }
    }

    private collect_captures_stmt(self mut ref, stmt ref TypedStatement, param_names Set[String], out mut ref List[ref Symbol]) Void = {
        when stmt in {
            .LetStmt(_, value, _) then self.collect_captures_expr(value, param_names, out),
            .PairLetStmt(_, _, value, _) then self.collect_captures_expr(value, param_names, out),
            .AssignmentStmt(target, value, _) then {
                self.collect_captures_expr(target, param_names, out)
                self.collect_captures_expr(value, param_names, out)
            },
            .ExprStmt(expr, _) then self.collect_captures_expr(expr, param_names, out),
            .IfStmt(c, t, e, _) then {
                self.collect_captures_expr(c, param_names, out)
                self.collect_captures_expr(t, param_names, out)
                when e in { .Some(x) then self.collect_captures_expr(x, param_names, out), .None() then {} }
            },
            .WhileStmt(c, b, _) then {
                self.collect_captures_expr(c, param_names, out)
                self.collect_captures_expr(b, param_names, out)
            },
            .WhenStmt(subject, arms, _) then {
                self.collect_captures_expr(subject, param_names, out)
                for arm in arms then { self.collect_captures_expr(arm.body, param_names, out) }
            },
            .ReturnStmt(value, _) then when value in { .Some(expr) then self.collect_captures_expr(expr, param_names, out), .None() then {} },
            .FinallyStmt(expr, _) then self.collect_captures_expr(expr, param_names, out),
            .YieldStmt(expr, _) then self.collect_captures_expr(expr, param_names, out),
            _ then {},
        }
    }

    private ownership_use(self ref, expression ref TypedExpr) MIROwnershipUse = {
        return if typed_expr_value_category(expression) is .LValue() then MIROwnershipUse.Copy() else MIROwnershipUse.Move()
    }

    private reference_kind(self ref, t Type) MIRReferenceKind = {
        return when t in {
            .MutableReferenceType(_) then MIRReferenceKind.Mutable(),
            .WeakReferenceType(_) then MIRReferenceKind.Weak(),
            .MutableWeakReferenceType(_) then MIRReferenceKind.MutableWeak(),
            _ then MIRReferenceKind.Shared(),
        }
    }

    private is_ownership_preserving_place_cast(self ref, source_type Type, target_type Type) Bool = {
        let _ = self
        return when source_type in {
            .ReferenceType(_) then target_type is .ReferenceType(_) or target_type is .MutableReferenceType(_),
            .MutableReferenceType(_) then target_type is .ReferenceType(_) or target_type is .MutableReferenceType(_),
            .WeakReferenceType(_) then target_type is .WeakReferenceType(_) or target_type is .MutableWeakReferenceType(_),
            .MutableWeakReferenceType(_) then target_type is .WeakReferenceType(_) or target_type is .MutableWeakReferenceType(_),
            _ then source_type == target_type,
        }
    }

    private recover_type_construction_result_type(self ref, identifier ref Symbol, args List[ref TypedExpr], fallback Type) Type = {
        if not self.context.contains_generic_parameter(fallback) then {
            return fallback
        }

        let identifier_type = identifier.symbol_type
        if not self.context.contains_generic_parameter(identifier_type) then {
            return identifier_type
        }

        let type_name = when self.context.get_template_name(identifier.def_id) in {
            .Some(name) then name,
            .None() then self.context.get_name(identifier.def_id) or else "",
        }
        if args.count() == 2(UInt) and (type_name == "Pair" or type_name.ends_with(".Pair")) then {
            let mut pair_args = List[ref Type].new()
            pair_args.push(box(args[0(UInt)].expr_type))
            pair_args.push(box(args[1(UInt)].expr_type))
            return Type.GenericStruct("Pair", pair_args)
        }

        return fallback
    }

    private trait_object_type_args(self ref, t Type) List[Type] = {
        return when t in {
            .TraitObject(_, args) then self.copy_type_args(args),
            .ReferenceType(inner) then self.trait_object_type_args(inner.val),
            .MutableReferenceType(inner) then self.trait_object_type_args(inner.val),
            _ then List[Type].new(),
        }
    }

    private copy_type_args(self ref, args List[ref Type]) List[Type] = {
        let mut out = List[Type].new()
        for arg in args then { out.push(arg.val) }
        return out
    }

    private deref_pointee_type(self ref, container Type, fallback Type) Type = {
        return when container in {
            .ReferenceType(inner) then inner.val,
            .MutableReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            .PointerType(inner) then inner.val,
            .MutablePointerType(inner) then inner.val,
            _ then fallback,
        }
    }

    private lookup_field_type(self ref, t Type, field_name String) Type = {
        return when t in {
            .StructureType(def_id) then when self.context.get_struct_fields(def_id) in {
                .Some(fields) then {
                    for field in fields then { if field.name == field_name then { return field.field_type } }
                    yield Type.Unknown()
                },
                .None() then Type.Unknown(),
            },
            .ReferenceType(inner) then self.lookup_field_type(inner.val, field_name),
            .MutableReferenceType(inner) then self.lookup_field_type(inner.val, field_name),
            _ then Type.Unknown(),
        }
    }

    private type_is_void(self ref, t Type) Bool = t is .VoidType()
    private type_is_never(self ref, t Type) Bool = t is .NeverType()
    private type_is_void_or_never(self ref, t Type) Bool = self.type_is_void(t) or self.type_is_never(t)
    private is_float_type(self ref, t Type) Bool = t is .Float32Type() or t is .Float64Type()
}

given MIROperand {
    local_id_or_zero(self) MIRLocalID = {
        return when self in {
            .Local(id) then id,
            _ then MIRLocalID(0(UInt)),
        }
    }
}
