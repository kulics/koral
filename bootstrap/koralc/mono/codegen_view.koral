// Codegen view types shared between monomorphization output and code generation.
// This is the canonical read-only projection consumed by bootstrap codegen.

public type CallableCodegenInfo(
    def_id DefId,
    emitted_c_name String,
    function_type Type,
    owner_type Option[Type],
    trait_conformance Option[String],
    normalized_receiver_type Option[Type],
    is_foreign Bool,
)

public type TypeLayoutInfo(
    canonical_type Type,
    canonical_type_key String,
    emitted_type_name String,
    c_type_name String,
    receiver_lookup_name String,
    display_name String,
    drop_c_name Option[String],
    vtable_type_name Option[String],
    underlying_type Option[Type],
    is_foreign_type Bool,
)
