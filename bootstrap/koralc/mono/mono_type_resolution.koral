// Type resolution and substitution for the monomorphization phase.
// Implements substitute_type, resolve_parameterized_type, resolve_type_node,
// and resolve_types_in_global_node.
//

// ── substitute_type ───────────────────────────────────────────────────────────

// Recursively traverse a Type, replacing GenericParameter with concrete types
// from the substitution map.
//
// Handles all Type variants:
//   - GenericParameter: look up in substitution map, return concrete type or keep as-is
//   - FunctionType: substitute param types and return type
//   - ReferenceType: substitute inner type
//   - PointerType: substitute inner type
//   - WeakReferenceType: substitute inner type
//   - GenericStruct: substitute each type arg
//   - GenericEnum: substitute each type arg
//   - All primitive/concrete types: return unchanged
//
public let substitute_type(mono Monomorphizer ref, t Type, substitution [String, Type]Dict) Type = {
    return when t in {
        // GenericParameter: look up in substitution map.
        .GenericParameter(name) then {
            yield when substitution.get(name) in {
                .Some(concrete) then concrete,
                .None() then t,
            }
        },

        // FunctionType: substitute param types and return type.
        .FunctionType(param_types, return_type) then {
            let mut new_param_types = [Type ref]List.new()
            for pt in param_types then {
                let substituted = substitute_type(mono, pt.val, substitution)
                new_param_types.push(box(substituted))
            }
            let new_return_type = substitute_type(mono, return_type.val, substitution)
            yield Type.FunctionType(new_param_types, box(new_return_type))
        },

        // ReferenceType: substitute inner type.
        .ReferenceType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.ReferenceType(box(new_inner))
        },

        // PointerType: substitute inner type.
        .PointerType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.PointerType(box(new_inner))
        },

        // WeakReferenceType: substitute inner type.
        .WeakReferenceType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.WeakReferenceType(box(new_inner))
        },

        // GenericStruct: substitute each type arg.
        // If this generic name is a trait placeholder bound via __trait__:<name>,
        // rewrite it to the concrete receiver type.
        .GenericStruct(template, args) then {
            let trait_key = "__trait__:\(template)"
            yield when substitution.get(trait_key) in {
                .Some(concrete) then concrete,
                .None() then {
                    let mut new_args = [Type ref]List.new()
                    for a in args then {
                        let substituted = substitute_type(mono, a.val, substitution)
                        new_args.push(box(substituted))
                    }
                    yield Type.GenericStruct(template, new_args)
                },
            }
        },

        // GenericEnum: substitute each type arg.
        // Mirror GenericStruct trait-placeholder rewrite for completeness.
        .GenericEnum(template, args) then {
            let trait_key = "__trait__:\(template)"
            yield when substitution.get(trait_key) in {
                .Some(concrete) then concrete,
                .None() then {
                    let mut new_args = [Type ref]List.new()
                    for a in args then {
                        let substituted = substitute_type(mono, a.val, substitution)
                        new_args.push(box(substituted))
                    }
                    yield Type.GenericEnum(template, new_args)
                },
            }
        },

        // All primitive and concrete types: return unchanged.
        .TraitObject(trait_name) then {
            let trait_key = "__trait__:\(trait_name)"
            yield when substitution.get(trait_key) in {
                .Some(concrete) then concrete,
                .None() then t,
            }
        },
        _ then t,
    }
}

// ── resolve_parameterized_type ────────────────────────────────────────────────

// Resolve a parameterized type (GenericStruct/GenericEnum) to a concrete type.
//
// - GenericStruct: look up struct template and instantiate, return concrete StructureType
// - GenericEnum: look up enum template and instantiate, return concrete EnumType
// - ReferenceType: recursively resolve inner type and wrap as reference
// - PointerType: recursively resolve inner type and wrap as pointer
// - WeakReferenceType: recursively resolve inner type and wrap as weak reference
// - FunctionType: recursively resolve param types and return type
// - If type args still contain generic params, preserve original type
// - All other types: return unchanged
//
private let normalize_trait_placeholder_type(mono Monomorphizer ref, t Type) Type = {
    return when t in {
        .GenericStruct(template_name, args) then {
            let trait_name_opt = when mono.storage.input.generic_templates.traits.get(template_name) in {
                .Some(_) then [String]Option.Some(template_name),
                .None() then {
                    let mut matched = [String]Option.None()
                    for entry in mono.storage.input.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = [String]Option.Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name),
                .None() then {
                    let mut normalized_args = [Type ref]List.new()
                    for arg_ref in args then {
                        normalized_args.push(box(normalize_trait_placeholder_type(mono, arg_ref.val)))
                    }
                    yield Type.GenericStruct(template_name, normalized_args)
                },
            }
        },
        .GenericEnum(template_name, args) then {
            let trait_name_opt = when mono.storage.input.generic_templates.traits.get(template_name) in {
                .Some(_) then [String]Option.Some(template_name),
                .None() then {
                    let mut matched = [String]Option.None()
                    for entry in mono.storage.input.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = [String]Option.Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name),
                .None() then {
                    let mut normalized_args = [Type ref]List.new()
                    for arg_ref in args then {
                        normalized_args.push(box(normalize_trait_placeholder_type(mono, arg_ref.val)))
                    }
                    yield Type.GenericEnum(template_name, normalized_args)
                },
            }
        },
        .ReferenceType(inner) then Type.ReferenceType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .PointerType(inner) then Type.PointerType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .WeakReferenceType(inner) then Type.WeakReferenceType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .FunctionType(param_types, return_type) then {
            let mut normalized_params = [Type ref]List.new()
            for param_type in param_types then {
                normalized_params.push(box(normalize_trait_placeholder_type(mono, param_type.val)))
            }
            let normalized_return = normalize_trait_placeholder_type(mono, return_type.val)
            yield Type.FunctionType(normalized_params, box(normalized_return))
        },
        _ then t,
    }
}

private let canonicalize_type_arguments(mono Monomorphizer ref, args [Type ref]List) [Type ref]List = {
    let mut canonical_args = [Type ref]List.new()
    for arg_ref in args then {
        let canonical_arg = canonical_type_for_generic_binding(mono, arg_ref.val)
        canonical_args.push(box(canonical_arg))
    }
    return canonical_args
}

private let resolve_def_id_backed_type(
    mono Monomorphizer ref,
    def_id DefId,
    fallback Type,
    is_struct Bool,
) Type = {
    let reconstructed = when mono.storage.def_id_map.get_template_name(def_id) in {
        .Some(template_name) then {
            yield when mono.storage.def_id_map.get_type_arguments(def_id) in {
                .Some(type_args) then {
                    let mut resolved_args = [Type ref]List.new()
                    for type_arg in type_args then {
                        resolved_args.push(box(resolve_parameterized_type(mono, type_arg)))
                    }
                    let canonical_args = canonicalize_type_arguments(mono, resolved_args)
                    yield if args_have_generic_parameter(canonical_args) then {
                        yield if is_struct then Type.GenericStruct(template_name, canonical_args) else Type.GenericEnum(template_name, canonical_args)
                    } else if is_struct then {
                        yield when mono.storage.input.generic_templates.lookup_struct(template_name) in {
                            .Some(struct_template) then mono.instantiate_struct_impl(struct_template, canonical_args),
                            .None() then when mono.storage.input.generic_templates.concrete_struct_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericStruct(template_name, canonical_args),
                            },
                        }
                    } else {
                        yield when mono.storage.input.generic_templates.lookup_enum(template_name) in {
                            .Some(enum_template) then mono.instantiate_enum_impl(enum_template, canonical_args),
                            .None() then when mono.storage.input.generic_templates.concrete_enum_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericEnum(template_name, canonical_args),
                            },
                        }
                    }
                },
                .None() then fallback,
            }
        },
        .None() then {
            yield when mono.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped) then {
                    let resolved_mapped = resolve_parameterized_type(mono, mapped)
                    yield if layout_key(resolved_mapped) == layout_key(fallback) then fallback else resolved_mapped
                },
                .None() then fallback,
            }
        },
    }
    return reconstructed
}

public let resolve_parameterized_type(mono Monomorphizer ref, t Type) Type = {
    return when t in {
        // GenericStruct: look up struct template and instantiate.
        .GenericStruct(template_name, args) then {
            // Trait names can appear in GenericStruct form during sema output
            // (e.g. [T]Iterator). Treat them as trait objects in mono/type
            // resolution so codegen does not attempt to materialize fake
            // concrete layouts like Iterator_Int.
            let trait_name_opt = when mono.storage.input.generic_templates.traits.get(template_name) in {
                .Some(_) then [String]Option.Some(template_name),
                .None() then {
                    let mut matched = [String]Option.None()
                    for entry in mono.storage.input.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = [String]Option.Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name),
                .None() then {
                    let mut resolved_args = [Type ref]List.new()
                    for arg_ref in args then {
                        let normalized_arg = normalize_trait_placeholder_type(mono, arg_ref.val)
                        resolved_args.push(box(normalized_arg))
                    }
                    let canonical_args = canonicalize_type_arguments(mono, resolved_args)
                    yield if args_have_generic_parameter(canonical_args)
                        then Type.GenericStruct(template_name, canonical_args)
                        else when mono.storage.input.generic_templates.lookup_struct(template_name) in {
                        .Some(struct_template) then {
                            yield mono.instantiate_struct_impl(struct_template, canonical_args)
                        },
                        .None() then {
                            // Check concrete struct types registry.
                            yield when mono.storage.input.generic_templates.concrete_struct_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericStruct(template_name, canonical_args),
                            }
                        },
                    }
                },
            }
        },

        // GenericEnum: look up enum template and instantiate.
        .GenericEnum(template_name, args) then {
            let trait_name_opt = when mono.storage.input.generic_templates.traits.get(template_name) in {
                .Some(_) then [String]Option.Some(template_name),
                .None() then {
                    let mut matched = [String]Option.None()
                    for entry in mono.storage.input.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = [String]Option.Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name),
                .None() then {
                    let mut resolved_args = [Type ref]List.new()
                    for arg_ref in args then {
                        let normalized_arg = normalize_trait_placeholder_type(mono, arg_ref.val)
                        resolved_args.push(box(normalized_arg))
                    }
                    let canonical_args = canonicalize_type_arguments(mono, resolved_args)
                    yield if args_have_generic_parameter(canonical_args)
                        then Type.GenericEnum(template_name, canonical_args)
                        else when mono.storage.input.generic_templates.lookup_enum(template_name) in {
                        .Some(enum_template) then {
                            yield mono.instantiate_enum_impl(enum_template, canonical_args)
                        },
                        .None() then {
                            // Check concrete enum types registry.
                            yield when mono.storage.input.generic_templates.concrete_enum_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericEnum(template_name, canonical_args),
                            }
                        },
                    }
                },
            }
        },

        // ReferenceType: recursively resolve inner type.
        .ReferenceType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            yield Type.ReferenceType(box(resolved_inner))
        },

        // PointerType: recursively resolve inner type.
        .PointerType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            yield Type.PointerType(box(resolved_inner))
        },

        // WeakReferenceType: recursively resolve inner type.
        .WeakReferenceType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            yield Type.WeakReferenceType(box(resolved_inner))
        },

        // FunctionType: recursively resolve param types and return type.
        .FunctionType(param_types, return_type) then {
            let mut new_param_types = [Type ref]List.new()
            for pt in param_types then {
                let resolved = resolve_parameterized_type(mono, pt.val)
                new_param_types.push(box(resolved))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type.val)
            yield Type.FunctionType(new_param_types, box(resolved_return))
        },

        .StructureType(def_id) then resolve_def_id_backed_type(mono, def_id, t, true),

        .EnumType(def_id) then resolve_def_id_backed_type(mono, def_id, t, false),

        .OpaqueType(def_id) then {
            yield when mono.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped) then {
                    let resolved_mapped = resolve_parameterized_type(mono, mapped)
                    yield if layout_key(resolved_mapped) == layout_key(t) then t else resolved_mapped
                },
                .None() then t,
            }
        },

        // All other types: return unchanged.
        _ then t,
    }
}

// ── resolve_type_node ─────────────────────────────────────────────────────────

// Resolve a TypeNode to a concrete Type using the substitution map.
//
// Priority for TypeNode.Identifier:
//   1. Type substitution map (generic parameter replacement)
//   2. Built-in types (Int, Bool, String, etc.)
//   3. Concrete type registry (struct/enum types)
//
public let resolve_type_node(mono Monomorphizer ref, node TypeNode, substitution [String, Type]Dict) Type = {
    return when node in {
        // TypeNode.Identifier: priority: substitution map → built-in types → concrete registry
        //
        .Identifier(name) then {
            yield when substitution.get(name) in {
                .Some(concrete) then concrete,
                .None() then {
                    yield when resolve_builtin_type(name) in {
                        .Some(t) then t,
                        .None() then {
                            yield when mono.storage.input.generic_templates.concrete_struct_types.get(name) in {
                                .Some(t) then t,
                                .None() then {
                                    yield when mono.storage.input.generic_templates.concrete_enum_types.get(name) in {
                                        .Some(t) then t,
                                        .None() then {
                                            yield when mono.storage.instantiated_types.get(name) in {
                                                .Some(t) then t,
                                                .None() then {
                                                    // Keep trait identifiers resolvable during monomorphization
                                                    // so types like Error ref are preserved as trait-object refs.
                                                    yield when mono.storage.input.generic_templates.traits.get(name) in {
                                                        .Some(_) then Type.TraitObject(name),
                                                        .None() then Type.Unknown(),
                                                    }
                                                },
                                            }
                                        },
                                    }
                                },
                            }
                        },
                    }
                },
            }
        },

        // TypeNode.Generic: recursively resolve type args and instantiate.
        .Generic(base, args) then {
            let mut resolved_args = [Type ref]List.new()
            for arg in args then {
                let resolved = resolve_type_node(mono, arg.val, substitution)
                resolved_args.push(box(resolved))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            yield when mono.storage.input.generic_templates.lookup_struct(base) in {
                .Some(struct_template) then mono.instantiate_struct_impl(struct_template, canonical_args),
                .None() then {
                    yield when mono.storage.input.generic_templates.lookup_enum(base) in {
                        .Some(enum_template) then mono.instantiate_enum_impl(enum_template, canonical_args),
                        .None() then Type.GenericStruct(base, canonical_args),
                    }
                },
            }
        },

        // TypeNode.Reference: recursively resolve inner type and wrap.
        .Reference(inner) then {
            let resolved_inner = resolve_type_node(mono, inner.val, substitution)
            yield Type.ReferenceType(box(resolved_inner))
        },

        // TypeNode.Pointer: recursively resolve inner type and wrap.
        .Pointer(inner) then {
            let resolved_inner = resolve_type_node(mono, inner.val, substitution)
            yield Type.PointerType(box(resolved_inner))
        },

        // TypeNode.WeakReference: recursively resolve inner type and wrap.
        .WeakReference(inner) then {
            let resolved_inner = resolve_type_node(mono, inner.val, substitution)
            yield Type.WeakReferenceType(box(resolved_inner))
        },

        // TypeNode.FunctionType: recursively resolve param types and return type.
        .FunctionType(param_types, return_type) then {
            let mut resolved_params = [Type ref]List.new()
            for pt in param_types then {
                let resolved = resolve_type_node(mono, pt.val, substitution)
                resolved_params.push(box(resolved))
            }
            let resolved_return = resolve_type_node(mono, return_type.val, substitution)
            yield Type.FunctionType(resolved_params, box(resolved_return))
        },

        // TypeNode.InferredSelf: look up `Self` in substitution map.
        .InferredSelf() then {
            yield when substitution.get("Self") in {
                .Some(self_type) then self_type,
                .None() then Type.Unknown(),
            }
        },

        // TypeNode.ModuleQualified: ignore module path, resolve type name.
        .ModuleQualified(_, name) then {
            yield resolve_type_node(mono, TypeNode.Identifier(name), substitution)
        },

        // TypeNode.ModuleQualifiedGeneric: ignore module path, resolve as generic.
        .ModuleQualifiedGeneric(_, base, args) then {
            yield resolve_type_node(mono, TypeNode.Generic(base, args), substitution)
        },
    }
}

// ── resolve_builtin_type ──────────────────────────────────────────────────────

// Dict a type name string to a built-in Type variant.
// Returns None if the name is not a built-in type.
private let resolve_builtin_type(name String) [Type]Option = {
    return when name in {
        "Int"     then [Type]Option.Some(Type.IntType()),
        "Int8"    then [Type]Option.Some(Type.Int8Type()),
        "Int16"   then [Type]Option.Some(Type.Int16Type()),
        "Int32"   then [Type]Option.Some(Type.Int32Type()),
        "Int64"   then [Type]Option.Some(Type.Int64Type()),
        "UInt"    then [Type]Option.Some(Type.UIntType()),
        "UInt8"   then [Type]Option.Some(Type.UInt8Type()),
        "UInt16"  then [Type]Option.Some(Type.UInt16Type()),
        "UInt32"  then [Type]Option.Some(Type.UInt32Type()),
        "UInt64"  then [Type]Option.Some(Type.UInt64Type()),
        "Float32" then [Type]Option.Some(Type.Float32Type()),
        "Float64" then [Type]Option.Some(Type.Float64Type()),
        "Bool"    then [Type]Option.Some(Type.BoolType()),
        "Void"    then [Type]Option.Some(Type.VoidType()),
        "Never"   then [Type]Option.Some(Type.NeverType()),
        _         then [Type]Option.None(),
    }
}

// ── collect_vtable_request_if_needed ─────────────────────────────────────────

private let normalize_vtable_conformance_actual_type(mono Monomorphizer ref, actual Type) Type = {
    return when actual in {
        .StructureType(def_id) then {
            let layout_name = mono.storage.def_id_map.get_name(def_id) or else ""
            yield when mono.storage.def_id_map.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.def_id_map.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut args = [Type ref]List.new()
                            for type_arg in type_args then {
                                args.push(box(type_arg))
                            }
                            yield Type.GenericStruct(template_name, args)
                        },
                        .None() then actual,
                    }
                },
                .None() then {
                    yield when mono.storage.layout_to_template_info.get(layout_name) in {
                        .Some(info) then {
                            let mut args = [Type ref]List.new()
                            for type_arg in info.args then {
                                args.push(box(type_arg.val))
                            }
                            yield Type.GenericStruct(info.base_name, args)
                        },
                        .None() then actual,
                    }
                },
            }
        },
        .EnumType(def_id) then {
            let layout_name = mono.storage.def_id_map.get_name(def_id) or else ""
            yield when mono.storage.def_id_map.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.def_id_map.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut args = [Type ref]List.new()
                            for type_arg in type_args then {
                                args.push(box(type_arg))
                            }
                            yield Type.GenericEnum(template_name, args)
                        },
                        .None() then actual,
                    }
                },
                .None() then {
                    yield when mono.storage.layout_to_template_info.get(layout_name) in {
                        .Some(info) then {
                            let mut args = [Type ref]List.new()
                            for type_arg in info.args then {
                                args.push(box(type_arg.val))
                            }
                            yield Type.GenericEnum(info.base_name, args)
                        },
                        .None() then actual,
                    }
                },
            }
        },
        _ then actual,
    }
}

private let collect_vtable_conformance_bindings(pattern Type, actual Type, bindings [String, Type]Dict ref) Bool = {
    return when pattern in {
        .GenericParameter(name) then {
            yield when bindings.get(name) in {
                .Some(bound) then layout_key(bound) == layout_key(actual),
                .None() then {
                    bindings.insert(name, actual)
                    yield true
                },
            }
        },
        .ReferenceType(pattern_inner) then when actual in {
            .ReferenceType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .WeakReferenceType(pattern_inner) then when actual in {
            .WeakReferenceType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .PointerType(pattern_inner) then when actual in {
            .PointerType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .GenericStruct(pattern_template, pattern_args) then when actual in {
            .GenericStruct(actual_template, actual_args) then {
                let mut all_match = pattern_template == actual_template and pattern_args.count() == actual_args.count()
                if all_match then {
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not collect_vtable_conformance_bindings(pattern_args.at(i).val, actual_args.at(i).val, bindings) then {
                            all_match = false
                            break
                        }
                        i += 1
                    }
                }
                yield all_match
            },
            _ then false,
        },
        .GenericEnum(pattern_template, pattern_args) then when actual in {
            .GenericEnum(actual_template, actual_args) then {
                let mut all_match = pattern_template == actual_template and pattern_args.count() == actual_args.count()
                if all_match then {
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not collect_vtable_conformance_bindings(pattern_args.at(i).val, actual_args.at(i).val, bindings) then {
                            all_match = false
                            break
                        }
                        i += 1
                    }
                }
                yield all_match
            },
            _ then false,
        },
        _ then layout_key(pattern) == layout_key(actual),
    }
}

private let resolve_vtable_trait_args(mono Monomorphizer ref, concrete_type Type, trait_name String) [Type ref]List = {
    let mut out = [Type ref]List.new()
    let normalized_concrete_type = normalize_vtable_conformance_actual_type(mono, resolve_parameterized_type(mono, concrete_type))
    for node in mono.storage.input.program.declarations then {
        when node in {
            .GivenTraitDecl(target_type, node_trait_name, trait_args, _, _) then {
                if node_trait_name <> trait_name then {
                    continue
                }
                let mut bindings = [String, Type]Dict.new()
                if not collect_vtable_conformance_bindings(target_type, normalized_concrete_type, bindings.ref) then {
                    continue
                }
                for trait_arg in trait_args then {
                    out.push(box(resolve_parameterized_type(mono, substitute_type(mono, trait_arg, bindings))))
                }
                return out
            },
            _ then {},
        }
    }
    return out
}

// If the given type is a TraitObject, record a VtableRequest for it.
// Called during type resolution whenever a field or parameter type resolves
// to a trait object type.
private let collect_vtable_request_if_needed(mono Monomorphizer ref, t Type) Void = {
    when t in {
        .TraitObject(trait_name) then {
            let req = VtableRequest(t, trait_name, [Type ref]List.new())
            mono.storage.vtable_requests.push(req)
        },
        _ then {},
    }
}

let collect_concrete_vtable_request(mono Monomorphizer ref, concrete_type Type, trait_name String) Void = {
    if has_generic_parameter(concrete_type) then {
        return
    }
    when concrete_type in {
        .TraitObject(_) then {},
        .Unknown() then {},
        _ then {
            let trait_type_args = resolve_vtable_trait_args(mono, concrete_type, trait_name)
            mono.storage.vtable_requests.push(VtableRequest(concrete_type, trait_name, trait_type_args))
            mono.instantiate_trait_vtable_methods_impl(concrete_type, trait_name)
        },
    }
}

private let mono_unwrap_receiver_value_type(mono Monomorphizer ref, t Type) Type = {
    let resolved = resolve_parameterized_type(mono, t)
    return when resolved in {
        .ReferenceType(inner) then resolve_parameterized_type(mono, inner.val),
        .WeakReferenceType(inner) then resolve_parameterized_type(mono, inner.val),
        .PointerType(inner) then resolve_parameterized_type(mono, inner.val),
        _ then resolved,
    }
}

private let concrete_trait_receiver_type(mono Monomorphizer ref, expr TypedExpr ref) Type = {
    return when expr.expr_kind in {
        .TraitObjectConversion(inner, _, concrete_type) then {
            let stored_type = resolve_parameterized_type(mono, concrete_type)
            let inner_type = mono_unwrap_receiver_value_type(mono, inner.expr_type)
            yield prefer_more_concrete_type(mono, stored_type, inner_type)
        },
        _ then mono_unwrap_receiver_value_type(mono, expr.expr_type),
    }
}

private let collect_qualified_method_vtable_requests(
    mono Monomorphizer ref,
    trait_name String,
    method_name String,
    base TypedExpr ref,
    args [TypedExpr ref]List,
) Void = {
    let concrete_base_type = concrete_trait_receiver_type(mono, base)
    collect_concrete_vtable_request(mono, concrete_base_type, trait_name)

    when mono.storage.input.generic_templates.traits.get(trait_name) in {
        .Some(trait_info) then {
            for member in trait_info.members then {
                if member.name <> method_name then {
                    continue
                }
                let mut arg_index UInt = 0
                let mut param_index UInt = 1
                while arg_index < args.count() and param_index < member.params.count() then {
                    let expected_param_type = resolve_parameterized_type(mono, member.params.at(param_index).param_type)
                    when expected_param_type in {
                        .TraitObject(param_trait_name) then {
                            let arg_type = concrete_trait_receiver_type(mono, args.at(arg_index))
                            collect_concrete_vtable_request(mono, arg_type, param_trait_name)
                        },
                        _ then {},
                    }
                    arg_index += 1
                    param_index += 1
                }
                return
            }
        },
        .None() then {},
    }
}

private let resolve_concrete_qualified_trait_member(
    mono Monomorphizer ref,
    concrete_type Type,
    trait_name String,
    method_name String,
) [TypedTraitMember]Option = {
    let resolved_concrete_type = resolve_parameterized_type(mono, concrete_type)
    let trait_type_args = resolve_vtable_trait_args(mono, resolved_concrete_type, trait_name)

    return when mono.storage.input.generic_templates.traits.get(trait_name) in {
        .Some(trait_info) then {
            let mut bindings = [String, Type]Dict.new()
            bindings.insert("Self", resolved_concrete_type)

            let mut trait_arg_index UInt = 0
            while trait_arg_index < trait_info.type_params.count() and trait_arg_index < trait_type_args.count() then {
                bindings.insert(trait_info.type_params.at(trait_arg_index).name, trait_type_args.at(trait_arg_index).val)
                trait_arg_index += 1
            }

            for member in trait_info.members then {
                if member.name <> method_name then {
                    continue
                }

                let mut resolved_params = [TypedParam]List.new()
                for param in member.params then {
                    let resolved_param_type = resolve_parameterized_type(mono, substitute_type(mono, param.param_type, bindings))
                    resolved_params.push(TypedParam(param.name, param.mutable, resolved_param_type, param.named))
                }

                let resolved_return_type = resolve_parameterized_type(mono, substitute_type(mono, member.return_type, bindings))
                yield [TypedTraitMember]Option.Some(TypedTraitMember(member.name, resolved_params, resolved_return_type))
            }

            yield [TypedTraitMember]Option.None()
        },
        .None() then [TypedTraitMember]Option.None(),
    }
}

private let mono_resolve_qualified_method_return_type(
    mono Monomorphizer ref,
    concrete_type Type,
    trait_name String,
    method_name String,
    fallback Type,
) Type = {
    let fallback_type = resolve_parameterized_type(mono, fallback)
    return when resolve_concrete_qualified_trait_member(mono, concrete_type, trait_name, method_name) in {
        .Some(member) then prefer_more_concrete_type(mono, member.return_type, fallback_type),
        .None() then fallback_type,
    }
}

private let ensure_receiver_dispatch_callsite(
    mono Monomorphizer ref,
    dispatch_callsite [DefId]Option,
    receiver_type Type,
    method Symbol,
) [DefId]Option = {
    if method.def_id.id == 0 then {
        return dispatch_callsite
    }

    let resolved_receiver_type = resolve_parameterized_type(mono, receiver_type)
    if resolved_receiver_type is .TraitObject(_) then {
        return dispatch_callsite
    }

    let callsite_def_id = when dispatch_callsite in {
        .Some(existing) then existing,
        .None() then {
            let callsite_name = "__receiver_dispatch_\(method.name)_\(mono.storage.def_id_map.next_id)"
            yield mono.storage.def_id_map.allocate(callsite_name, DefKind.Function())
        },
    }

    if not mono.storage.receiver_method_dispatch.contains_key(callsite_def_id.id) then {
        mono.storage.receiver_method_dispatch.insert(
            callsite_def_id.id,
            ReceiverMethodDispatchInfo(method.def_id, method.name, [ReceiverMethodOwner]Option.None()),
        )
    }
    return [DefId]Option.Some(callsite_def_id)
}

private let collect_implicit_member_vtable_requests(
    mono Monomorphizer ref,
    enum_type Type,
    case_name String,
    args [TypedExpr ref]List,
) Void = {
    let resolved_enum_type = resolve_parameterized_type(mono, enum_type)

    let mut case_params = [EnumCaseParam]List.new()
    when resolved_enum_type in {
        .EnumType(def_id) then {
            when mono.storage.def_id_map.get_enum_cases(def_id) in {
                .Some(cases) then {
                    for c in cases then {
                        if c.name == case_name or c.name.ends_with(".\(case_name)") then {
                            case_params = c.params
                            break
                        }
                    }
                },
                .None() then {},
            }
        },
        _ then {},
    }

    let mut idx UInt = 0
    while idx < args.count() and idx < case_params.count() then {
        let expected_type = resolve_parameterized_type(mono, case_params.at(idx).param_type)
        when expected_type in {
            .ReferenceType(expected_inner_ref) then {
                when expected_inner_ref.val in {
                    .TraitObject(trait_name) then {
                        let actual_type = resolve_parameterized_type(mono, args.at(idx).expr_type)
                        let concrete_type = when actual_type in {
                            .ReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .WeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            _ then actual_type,
                        }
                        collect_concrete_vtable_request(mono, concrete_type, trait_name)
                    },
                    _ then {},
                }
            },
            .TraitObject(trait_name) then {
                let actual_type = resolve_parameterized_type(mono, args.at(idx).expr_type)
                collect_concrete_vtable_request(mono, actual_type, trait_name)
            },
            _ then {},
        }
        idx += 1
    }
}

private let resolve_symbol_type(mono Monomorphizer ref, symbol Symbol ref) Symbol = {
    let resolved = resolve_parameterized_type(mono, symbol.symbol_type)
    let registered = when mono.storage.def_id_map.get_symbol_type(symbol.def_id) in {
        .Some(t) then resolve_parameterized_type(mono, t),
        .None() then resolved,
    }
    let chosen = when resolved in {
        .VoidType() then registered,
        .Unknown() then registered,
        _ then when registered in {
            .VoidType() then resolved,
            .Unknown() then resolved,
            _ then prefer_more_concrete_type(mono, resolved, registered),
        },
    }
    return Symbol(symbol.def_id, symbol.name, chosen, symbol.kind)
}

private let mono_is_unresolved_expr_type(mono Monomorphizer ref, t Type) Bool = {
    return when t in {
        .VoidType() then true,
        .GenericStruct(_, args) then {
            for arg_ref in args then {
                if mono_is_unresolved_expr_type(mono, arg_ref.val) then {
                    return true
                }
            }
            yield is_placeholder_inferred_type(t)
        },
        .GenericEnum(_, args) then {
            for arg_ref in args then {
                if mono_is_unresolved_expr_type(mono, arg_ref.val) then {
                    return true
                }
            }
            yield is_placeholder_inferred_type(t)
        },
        .StructureType(def_id) then {
            let display_name = mono.storage.def_id_map.type_display_name(t)
            let type_name = mono.storage.def_id_map.get_name(def_id) or else display_name
            if type_name.contains("__") or display_name.contains("__") then {
                return true
            }
            yield when mono.storage.def_id_map.get_type_arguments(def_id) in {
                .Some(type_args) then {
                    for type_arg in type_args then {
                        if mono_is_unresolved_expr_type(mono, type_arg) then {
                            return true
                        }
                    }
                    yield is_placeholder_inferred_type(t)
                },
                .None() then is_placeholder_inferred_type(t),
            }
        },
        .EnumType(def_id) then {
            let display_name = mono.storage.def_id_map.type_display_name(t)
            let type_name = mono.storage.def_id_map.get_name(def_id) or else display_name
            if type_name.contains("__") or display_name.contains("__") then {
                return true
            }
            yield when mono.storage.def_id_map.get_type_arguments(def_id) in {
                .Some(type_args) then {
                    for type_arg in type_args then {
                        if mono_is_unresolved_expr_type(mono, type_arg) then {
                            return true
                        }
                    }
                    yield is_placeholder_inferred_type(t)
                },
                .None() then is_placeholder_inferred_type(t),
            }
        },
        _ then is_placeholder_inferred_type(t),
    }
}

private let is_concrete_integer_type(t Type) Bool = {
    return when t in {
        .IntType() then true,
        .Int8Type() then true,
        .Int16Type() then true,
        .Int32Type() then true,
        .Int64Type() then true,
        .UIntType() then true,
        .UInt8Type() then true,
        .UInt16Type() then true,
        .UInt32Type() then true,
        .UInt64Type() then true,
        _ then false,
    }
}

private let is_concrete_float_type(t Type) Bool = {
    return when t in {
        .Float32Type() then true,
        .Float64Type() then true,
        _ then false,
    }
}

private let is_concrete_numeric_type(t Type) Bool = {
    return is_concrete_integer_type(t) or is_concrete_float_type(t)
}

private let prefer_more_concrete_type(mono Monomorphizer ref, primary Type, fallback Type) Type = {
    let primary_has_generics = has_generic_parameter(primary)
    let fallback_has_generics = has_generic_parameter(fallback)
    let primary_is_unresolved = mono_is_unresolved_expr_type(mono, primary)
    let fallback_is_unresolved = mono_is_unresolved_expr_type(mono, fallback)
    let primary_is_placeholder = when primary in {
        .StructureType(def_id) then {
            let display_name = mono.storage.def_id_map.type_display_name(primary)
            let type_name = mono.storage.def_id_map.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        .EnumType(def_id) then {
            let display_name = mono.storage.def_id_map.type_display_name(primary)
            let type_name = mono.storage.def_id_map.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        _ then false,
    }
    let fallback_is_placeholder = when fallback in {
        .StructureType(def_id) then {
            let display_name = mono.storage.def_id_map.type_display_name(fallback)
            let type_name = mono.storage.def_id_map.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        .EnumType(def_id) then {
            let display_name = mono.storage.def_id_map.type_display_name(fallback)
            let type_name = mono.storage.def_id_map.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        _ then false,
    }
    let primary_is_parameterized = when primary in {
        .GenericStruct(_, _) then true,
        .GenericEnum(_, _) then true,
        .TraitObject(_) then true,
        _ then false,
    }
    let fallback_is_nominal = when fallback in {
        .StructureType(_) then true,
        .EnumType(_) then true,
        _ then false,
    }
    if primary_is_parameterized and fallback_is_nominal then {
        return fallback
    }
    if primary_is_unresolved and not fallback_is_unresolved then {
        return fallback
    }
    if fallback_is_unresolved and not primary_is_unresolved then {
        return primary
    }
    if primary_has_generics and not fallback_has_generics then {
        return fallback
    }
    if primary_is_placeholder and not fallback_is_placeholder then {
        return fallback
    }
    when primary in {
        .Unknown() then {
            return fallback
        },
        _ then {},
    }
    return primary
}

private let resolved_method_return_type(mono Monomorphizer ref, method Symbol, fallback Type) Type = {
    let method_return_type = resolve_parameterized_type(mono, method.symbol_type)
    let fallback_type = resolve_parameterized_type(mono, fallback)
    when mono.storage.def_id_map.get_signature(method.def_id) in {
        .Some(sig) then {
            let signature_return_type = resolve_parameterized_type(mono, sig.return_type)
            let preferred_type = prefer_more_concrete_type(mono, signature_return_type, method_return_type)
            return prefer_more_concrete_type(mono, preferred_type, fallback_type)
        },
        .None() then {},
    }
    return prefer_more_concrete_type(mono, method_return_type, fallback_type)
}

private let resolve_types_in_statement(mono Monomorphizer ref, stmt TypedStatement) TypedStatement = {
    return when stmt in {
        .LetStmt(symbol, value, span) then {
            let new_symbol = resolve_symbol_type(mono, symbol)
            let resolved_value = resolve_types_in_expression(mono, value)
            let concrete_symbol_type = resolve_parameterized_type(mono, new_symbol.symbol_type)
            let mut effective_symbol_type = prefer_more_concrete_type(mono, concrete_symbol_type, resolved_value.expr_type)
            if mono_is_unresolved_expr_type(mono, concrete_symbol_type) and not mono_is_unresolved_expr_type(mono, resolved_value.expr_type) then {
                effective_symbol_type = resolved_value.expr_type
            }
            if new_symbol.def_id.id > 0 then {
                let symbol_kind = when mono.storage.def_id_map.get_symbol_kind(new_symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then new_symbol.kind,
                }
                let symbol_method_kind = when mono.storage.def_id_map.get_symbol_method_kind(new_symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then MethodKind.Normal(),
                }
                let symbol_mutable = when mono.storage.def_id_map.get_symbol_mutable(new_symbol.def_id) in {
                    .Some(mutable) then mutable,
                    .None() then false,
                }
                mono.storage.def_id_map.set_symbol_info(new_symbol.def_id, SymbolInfo(effective_symbol_type, symbol_kind, symbol_method_kind, symbol_mutable))
            }
            yield TypedStatement.LetStmt(box(Symbol(new_symbol.def_id, new_symbol.name, effective_symbol_type, new_symbol.kind)), resolved_value, span)
        },
        .PairLetStmt(first_symbol, second_symbol, value, span) then {
            let resolved_value = resolve_types_in_expression(mono, value)
            let new_first_symbol = when first_symbol in {
                .Some(symbol) then {
                    let resolved_symbol = resolve_symbol_type(mono, symbol)
                    yield [Symbol ref]Option.Some(box(Symbol(resolved_symbol.def_id, resolved_symbol.name, resolved_symbol.symbol_type, resolved_symbol.kind)))
                },
                .None() then [Symbol ref]Option.None(),
            }
            let new_second_symbol = when second_symbol in {
                .Some(symbol) then {
                    let resolved_symbol = resolve_symbol_type(mono, symbol)
                    yield [Symbol ref]Option.Some(box(Symbol(resolved_symbol.def_id, resolved_symbol.name, resolved_symbol.symbol_type, resolved_symbol.kind)))
                },
                .None() then [Symbol ref]Option.None(),
            }
            yield TypedStatement.PairLetStmt(new_first_symbol, new_second_symbol, resolved_value, span)
        },
        .AssignmentStmt(target, value, span) then {
            yield TypedStatement.AssignmentStmt(resolve_types_in_expression(mono, target), resolve_types_in_expression(mono, value), span)
        },
        .ExprStmt(expr, span) then {
            yield TypedStatement.ExprStmt(resolve_types_in_expression(mono, expr), span)
        },
        .ReturnStmt(value, span) then {
            let new_value = when value in {
                .Some(expr) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, expr)),
                .None() then [TypedExpr ref]Option.None(),
            }
            yield TypedStatement.ReturnStmt(new_value, span)
        },
        .FinallyStmt(expr, span) then {
            yield TypedStatement.FinallyStmt(resolve_types_in_expression(mono, expr), span)
        },
        .YieldStmt(expr, span) then {
            yield TypedStatement.YieldStmt(resolve_types_in_expression(mono, expr), span)
        },
        _ then stmt,
    }
}

public let resolve_types_in_expression(mono Monomorphizer ref, expr TypedExpr ref) TypedExpr ref = {
    when expr.expr_kind in {
        .Variable(symbol) then {
            let new_symbol = resolve_symbol_type(mono, symbol)
            return box(TypedExpr(box(TypedExprKind.Variable(box(new_symbol))), new_symbol.symbol_type))
        },
        .RefExpr(inner) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            return box(TypedExpr(box(TypedExprKind.RefExpr(new_inner)), Type.ReferenceType(box(resolve_parameterized_type(mono, new_inner.expr_type)))))
        },
        .PtrExpr(inner) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            return box(TypedExpr(box(TypedExprKind.PtrExpr(new_inner)), Type.PointerType(box(resolve_parameterized_type(mono, new_inner.expr_type)))))
        },
        .DerefExpr(inner) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            let resolved_type = when new_inner.expr_type in {
                .ReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                .WeakReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                .PointerType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                _ then resolve_parameterized_type(mono, expr.expr_type),
            }
            return box(TypedExpr(box(TypedExprKind.DerefExpr(new_inner)), resolved_type))
        },
        .Call(callee, args) then {
            let new_callee = resolve_types_in_expression(mono, callee)
            let mut new_args = [TypedExpr ref]List.new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            when new_callee.expr_kind in {
                .MemberExpr(base_expr, member_name) then {
                    let resolved_base = resolve_types_in_expression(mono, base_expr)
                    let receiver_type = resolve_parameterized_type(mono, resolved_base.expr_type)
                    let dummy_method = Symbol(DefId(0), member_name, Type.Unknown(), SymbolKind.Function())
                    let bound_method = try_bind_generic_method_call(
                        mono,
                        receiver_type,
                        dummy_method,
                        new_args,
                        resolve_parameterized_type(mono, expr.expr_type),
                    )
                    if bound_method.def_id.id > 0 then {
                        let resolved_type = resolved_method_return_type(mono, bound_method, expr.expr_type)
                        let dispatch_callsite = ensure_receiver_dispatch_callsite(mono, .None(), receiver_type, bound_method)
                        return box(TypedExpr(
                            box(TypedExprKind.GenericMethodCall(resolved_base, receiver_type, box(bound_method), new_args, dispatch_callsite)),
                            resolved_type,
                        ))
                    }
                },
                _ then {},
            }
            let bound_callee = bind_generic_function_call_callee(mono, new_callee, new_args, resolve_parameterized_type(mono, expr.expr_type))
            let resolved_type = when bound_callee.expr_type in {
                .FunctionType(_, return_type_ref) then resolve_parameterized_type(mono, return_type_ref.val),
                _ then resolve_parameterized_type(mono, expr.expr_type),
            }
            return box(TypedExpr(box(TypedExprKind.Call(bound_callee, new_args)), resolved_type))
        },
        .GenericMethodCall(base, receiver_type, method, args, dispatch_callsite) then {
            let new_base = resolve_types_in_expression(mono, base)
            let base_expr_type = resolve_parameterized_type(mono, new_base.expr_type)
            let base_receiver_type = when new_base.expr_kind in {
                .GenericMethodCall(_, _, base_method, _, _) then {
                    yield when mono.storage.def_id_map.get_signature(base_method.def_id) in {
                        .Some(sig) then prefer_more_concrete_type(mono, resolve_parameterized_type(mono, sig.return_type), base_expr_type),
                        .None() then base_expr_type,
                    }
                },
                .QualifiedMethodCall(_, _, base_method, _, _) then {
                    yield when mono.storage.def_id_map.get_signature(base_method.def_id) in {
                        .Some(sig) then prefer_more_concrete_type(mono, resolve_parameterized_type(mono, sig.return_type), base_expr_type),
                        .None() then base_expr_type,
                    }
                },
                _ then base_expr_type,
            }
            let new_receiver_type = receiver_type
            let effective_receiver_type = when base_receiver_type in {
                .TraitObject(_) then base_receiver_type,
                _ then {
                    let receiver_mismatch_prefers_base = layout_key(new_receiver_type) <> layout_key(base_receiver_type)
                        and not has_generic_parameter(base_receiver_type)
                        and when base_receiver_type in {
                            .StructureType(_) then true,
                            .EnumType(_) then true,
                            _ then false,
                        }
                    let mut selected_receiver_type = prefer_more_concrete_type(mono, new_receiver_type, base_receiver_type)
                    if receiver_mismatch_prefers_base then {
                        selected_receiver_type = base_receiver_type
                    }
                    yield selected_receiver_type
                },
            }
            let new_method = resolve_symbol_type(mono, method)
            let mut new_args = [TypedExpr ref]List.new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            let bound_method = try_bind_generic_method_call(mono, effective_receiver_type, new_method, new_args, resolve_parameterized_type(mono, expr.expr_type))
            let resolved_type = resolved_method_return_type(mono, bound_method, expr.expr_type)
            let effective_dispatch_callsite = ensure_receiver_dispatch_callsite(mono, dispatch_callsite, effective_receiver_type, bound_method)
            return box(TypedExpr(box(TypedExprKind.GenericMethodCall(new_base, effective_receiver_type, box(bound_method), new_args, effective_dispatch_callsite)), resolved_type))
        },
        .TraitObjectConversion(inner, trait_type, concrete_type) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            let mut new_trait_type = resolve_parameterized_type(mono, trait_type)
            when trait_type in {
                .TraitObject(original_trait_name) then { new_trait_type = Type.TraitObject(original_trait_name) },
                _ then {},
            }
            let new_concrete_type = resolve_parameterized_type(mono, concrete_type)
            when new_trait_type in {
                .TraitObject(trait_name) then collect_concrete_vtable_request(mono, new_concrete_type, trait_name),
                _ then {},
            }
            return box(TypedExpr(box(TypedExprKind.TraitObjectConversion(new_inner, new_trait_type, new_concrete_type)), new_trait_type))
        },
        .QualifiedMethodCall(base, trait_type, method, args, dispatch_callsite) then {
            let new_base = resolve_types_in_expression(mono, base)
            let mut new_trait_type = resolve_parameterized_type(mono, trait_type)
            when trait_type in {
                .TraitObject(original_trait_name) then { new_trait_type = Type.TraitObject(original_trait_name) },
                _ then {},
            }
            let resolved_method = resolve_symbol_type(mono, method)
            let new_method = Symbol(resolved_method.def_id, method.name, resolved_method.symbol_type, resolved_method.kind)
            let mut new_args = [TypedExpr ref]List.new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            let concrete_base_type = concrete_trait_receiver_type(mono, new_base)
            when new_trait_type in {
                .TraitObject(trait_name) then collect_qualified_method_vtable_requests(mono, trait_name, method.name, new_base, new_args),
                _ then {},
            }
            let resolved_type = when new_trait_type in {
                .TraitObject(trait_name) then mono_resolve_qualified_method_return_type(mono, concrete_base_type, trait_name, method.name, expr.expr_type),
                _ then resolved_method_return_type(mono, new_method, expr.expr_type),
            }
            let effective_dispatch_callsite = when new_trait_type in {
                .TraitObject(_) then [DefId]Option.None(),
                _ then ensure_receiver_dispatch_callsite(mono, dispatch_callsite, concrete_base_type, new_method),
            }
            return box(TypedExpr(box(TypedExprKind.QualifiedMethodCall(new_base, new_trait_type, box(new_method), new_args, effective_dispatch_callsite)), resolved_type))
        },
        _ then {},
    }
    let resolved_kind = resolve_expr_kind(mono, expr)
    let resolved_type = when resolved_kind.val in {
        .Variable(symbol) then symbol.symbol_type,
        .CollectionLiteral(elements) then {
            let declared_type = resolve_parameterized_type(mono, expr.expr_type)
            let inferred_collection_type = if not is_placeholder_inferred_type(declared_type) then {
                yield declared_type
            } else {
                let mut element_type = Type.Unknown()
                for element in elements then {
                    let candidate_raw = resolve_parameterized_type(mono, element.expr_type)
                    let candidate = if is_placeholder_inferred_type(candidate_raw) then when element.expr_kind in {
                        .IntegerLiteral(_) then Type.IntType(),
                        .FloatLiteral(_) then Type.Float64Type(),
                        .BoolLiteral(_) then Type.BoolType(),
                        _ then candidate_raw,
                    } else candidate_raw
                    if is_placeholder_inferred_type(element_type) and not is_placeholder_inferred_type(candidate) then {
                        element_type = candidate
                    }
                }
                yield if not is_placeholder_inferred_type(element_type) then {
                    let mut args = [Type ref]List.new()
                    args.push(box(element_type))
                    yield resolve_parameterized_type(mono, Type.GenericStruct("List", args))
                } else declared_type
            }
            yield inferred_collection_type
        },
        .DictLiteral(entries) then {
            let declared_type = resolve_parameterized_type(mono, expr.expr_type)
            let inferred_dict_type = if not is_placeholder_inferred_type(declared_type) then {
                yield declared_type
            } else {
                let mut key_type = Type.Unknown()
                let mut value_type = Type.Unknown()
                for entry in entries then {
                    let key_candidate_raw = resolve_parameterized_type(mono, entry.first.expr_type)
                    let value_candidate_raw = resolve_parameterized_type(mono, entry.second.expr_type)
                    let key_candidate = if is_placeholder_inferred_type(key_candidate_raw) then when entry.first.expr_kind in {
                        .IntegerLiteral(_) then Type.IntType(),
                        .FloatLiteral(_) then Type.Float64Type(),
                        .BoolLiteral(_) then Type.BoolType(),
                        _ then key_candidate_raw,
                    } else key_candidate_raw
                    let value_candidate = if is_placeholder_inferred_type(value_candidate_raw) then when entry.second.expr_kind in {
                        .IntegerLiteral(_) then Type.IntType(),
                        .FloatLiteral(_) then Type.Float64Type(),
                        .BoolLiteral(_) then Type.BoolType(),
                        _ then value_candidate_raw,
                    } else value_candidate_raw
                    if is_placeholder_inferred_type(key_type) and not is_placeholder_inferred_type(key_candidate) then {
                        key_type = key_candidate
                    }
                    if is_placeholder_inferred_type(value_type) and not is_placeholder_inferred_type(value_candidate) then {
                        value_type = value_candidate
                    }
                }
                yield if not is_placeholder_inferred_type(key_type) and not is_placeholder_inferred_type(value_type) then {
                    let mut args = [Type ref]List.new()
                    args.push(box(key_type))
                    args.push(box(value_type))
                    yield resolve_parameterized_type(mono, Type.GenericStruct("Dict", args))
                } else declared_type
            }
            yield inferred_dict_type
        },
        .ArithmeticExpr(left, _, right) then {
            let left_t = left.expr_type
            let right_t = right.expr_type
            let declared_type = resolve_parameterized_type(mono, expr.expr_type)
            let mut result_type = declared_type
            if layout_key(left_t) == layout_key(right_t) then {
                result_type = left_t
            } else if mono_is_unresolved_expr_type(mono, declared_type) then {
                if is_concrete_numeric_type(left_t) then {
                    result_type = left_t
                } else if is_concrete_numeric_type(right_t) then {
                    result_type = right_t
                }
            }
            yield result_type
        },
        .BitwiseExpr(left, _, right) then {
            let left_t = left.expr_type
            let right_t = right.expr_type
            let declared_type = resolve_parameterized_type(mono, expr.expr_type)
            let mut result_type = declared_type
            if layout_key(left_t) == layout_key(right_t) then {
                result_type = left_t
            } else if mono_is_unresolved_expr_type(mono, declared_type) then {
                if is_concrete_integer_type(left_t) then {
                    result_type = left_t
                } else if is_concrete_integer_type(right_t) then {
                    result_type = right_t
                }
            }
            yield result_type
        },
        .MemberExpr(base, member_name) then resolve_member_field_type(mono, base.expr_type, member_name, expr.expr_type),
        .MemberPath(base, path) then resolve_member_path_type(mono, base.expr_type, path, expr.expr_type),
        _ then resolve_parameterized_type(mono, expr.expr_type),
    }

    when resolved_kind.val in {
        .CollectionLiteral(elements) then {
            if not is_placeholder_inferred_type(resolved_type) and not has_generic_parameter(resolved_type) then {
                let template_name = resolve_static_call_template_name(mono, resolved_type)
                let static_args = [TypedExpr ref]List.new()
                enqueue_extension_method_for_static_call(mono, resolved_type, "new", template_name, static_args, resolved_type)

                let push_method = Symbol(DefId(0), "push", Type.Unknown(), SymbolKind.Function())
                let insert_method = Symbol(DefId(0), "insert", Type.Unknown(), SymbolKind.Function())
                for element in elements then {
                    let mut push_args = [TypedExpr ref]List.new()
                    push_args.push(element)
                    try_bind_generic_method_call(mono, resolved_type, push_method, push_args, Type.Unknown())

                    let mut insert_args = [TypedExpr ref]List.new()
                    insert_args.push(element)
                    try_bind_generic_method_call(mono, resolved_type, insert_method, insert_args, Type.Unknown())
                }
            }
        },
        .DictLiteral(entries) then {
            if not is_placeholder_inferred_type(resolved_type) and not has_generic_parameter(resolved_type) then {
                let template_name = resolve_static_call_template_name(mono, resolved_type)
                let static_args = [TypedExpr ref]List.new()
                enqueue_extension_method_for_static_call(mono, resolved_type, "new", template_name, static_args, resolved_type)

                let insert_method = Symbol(DefId(0), "insert", Type.Unknown(), SymbolKind.Function())
                for entry in entries then {
                    let mut insert_args = [TypedExpr ref]List.new()
                    insert_args.push(entry.first)
                    insert_args.push(entry.second)
                    try_bind_generic_method_call(mono, resolved_type, insert_method, insert_args, Type.Unknown())
                }
            }
        },
        _ then {},
    }

    return box(TypedExpr(resolved_kind, resolved_type))
}

private let resolve_member_field_type(
    mono Monomorphizer ref,
    base_type Type,
    member_name String,
    fallback Type,
) Type = {
    let resolved_base = resolve_parameterized_type(mono, base_type)
    when resolved_base in {
        .ReferenceType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .WeakReferenceType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .PointerType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .GenericStruct(template_name, args) then {
            if template_name == "Pair" and args.count() == (UInt)2 then {
                when member_name in {
                    "first" then {
                        return resolve_parameterized_type(mono, args.at((UInt)0).val)
                    },
                    "second" then {
                        return resolve_parameterized_type(mono, args.at((UInt)1).val)
                    },
                    _ then {},
                }
            }
            when mono.storage.input.generic_templates.lookup_struct(template_name) in {
                .Some(template) then {
                    let mut subst = [String, Type]Dict.new()
                    let mut i UInt = 0
                    while i < template.type_parameters.count() and i < args.count() then {
                        subst.insert(template.type_parameters.at(i).name, args.at(i).val)
                        i += 1
                    }
                    for field in template.fields then {
                        if field.name == member_name then {
                            return resolve_parameterized_type(mono, mono.resolve_type_node_impl(field.field_type, subst))
                        }
                    }
                },
                .None() then {},
            }
        },
        .StructureType(def_id) then {
            when mono.storage.def_id_map.get_struct_fields(def_id) in {
                .Some(fields) then {
                    for field in fields then {
                        if field.name == member_name then {
                            return resolve_parameterized_type(mono, field.field_type)
                        }
                    }
                },
                .None() then {},
            }
        },
        _ then {},
    }
    return resolve_parameterized_type(mono, fallback)
}

private let resolve_member_path_type(
    mono Monomorphizer ref,
    base_type Type,
    path [String]List,
    fallback Type,
) Type = {
    let mut current = resolve_parameterized_type(mono, base_type)
    for member_name in path then {
        current = resolve_member_field_type(mono, current, member_name, fallback)
    }
    return current
}

private let mono_enum_case_name_matches(pattern_case_name String, enum_case_name String) Bool = {
    if enum_case_name == pattern_case_name then { return true }
    if enum_case_name.ends_with("_" + pattern_case_name) then { return true }

    let pattern_tail = when pattern_case_name.split_last_once(".") in {
        .Some(parts) then parts.second,
        .None() then pattern_case_name,
    }
    if enum_case_name == pattern_tail then { return true }
    if enum_case_name.ends_with("_" + pattern_tail) then { return true }

    let enum_tail = when enum_case_name.split_last_once("_") in {
        .Some(parts) then parts.second,
        .None() then enum_case_name,
    }
    return enum_tail == pattern_tail
}

private let mono_get_enum_case_field_types(
    mono Monomorphizer ref,
    subject_type Type,
    case_name String,
) [Type]List = {
    let inner_type = when subject_type in {
        .ReferenceType(inner) then inner.val,
        .WeakReferenceType(inner) then inner.val,
        _ then subject_type,
    }
    return when inner_type in {
        .EnumType(def_id) then when mono.storage.def_id_map.get_enum_cases(def_id) in {
            .Some(cases) then {
                let mut result = [Type]List.new()
                for case_info in cases then {
                    if mono_enum_case_name_matches(case_name, case_info.name) then {
                        for param in case_info.params then {
                            result.push(resolve_parameterized_type(mono, param.param_type))
                        }
                    }
                }
                yield result
            },
            .None() then [Type]List.new(),
        },
        .GenericEnum(template_name, args) then {
            yield when mono.storage.input.generic_templates.lookup_enum(template_name) in {
                .Some(enum_template) then when mono.storage.def_id_map.get_enum_cases(enum_template.def_id) in {
                    .Some(cases) then {
                        let mut bindings = [String, Type]Dict.new()
                        let mut i UInt = 0
                        let param_count = enum_template.type_parameters.count()
                        let arg_count = args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = enum_template.type_parameters.at(i)
                            bindings.insert(tp.name, args.at(i).val)
                            i += 1
                        }
                        let mut result = [Type]List.new()
                        for case_info in cases then {
                            if mono_enum_case_name_matches(case_name, case_info.name) then {
                                for param in case_info.params then {
                                    let concrete_param_type = resolve_parameterized_type(mono, substitute_type(mono, param.param_type, bindings))
                                    result.push(concrete_param_type)
                                }
                            }
                        }
                        yield result
                    },
                    .None() then [Type]List.new(),
                },
                .None() then [Type]List.new(),
            }
        },
        _ then [Type]List.new(),
    }
}

private let mono_get_struct_pattern_field_types(
    mono Monomorphizer ref,
    subject_type Type,
    type_name String,
) [Type]List = {
    let inner_type = when subject_type in {
        .ReferenceType(inner) then inner.val,
        .WeakReferenceType(inner) then inner.val,
        _ then subject_type,
    }
    return when inner_type in {
        .StructureType(def_id) then {
            let actual_name = mono.storage.def_id_map.get_name(def_id) or else mono.storage.def_id_map.type_display_name(inner_type)
            let mut result = [Type]List.new()
            if actual_name == type_name then {
                when mono.storage.def_id_map.get_struct_fields(def_id) in {
                    .Some(fields) then {
                        for field in fields then {
                            result.push(resolve_parameterized_type(mono, field.field_type))
                        }
                    },
                    .None() then {},
                }
            }
            yield result
        },
        .GenericStruct(template_name, args) then {
            let mut result = [Type]List.new()
            if template_name == type_name then {
                when mono.storage.input.generic_templates.lookup_struct(template_name) in {
                    .Some(struct_template) then when mono.storage.def_id_map.get_struct_fields(struct_template.def_id) in {
                        .Some(fields) then {
                            let mut bindings = [String, Type]Dict.new()
                            let mut i UInt = 0
                            let param_count = struct_template.type_parameters.count()
                            let arg_count = args.count()
                            let n = if param_count < arg_count then param_count else arg_count
                            while i < n then {
                                let tp = struct_template.type_parameters.at(i)
                                bindings.insert(tp.name, args.at(i).val)
                                i += 1
                            }
                            for field in fields then {
                                result.push(resolve_parameterized_type(mono, substitute_type(mono, field.field_type, bindings)))
                            }
                        },
                        .None() then {},
                    },
                    .None() then {},
                }
            }
            yield result
        },
        _ then [Type]List.new(),
    }
}

private let mono_collect_pattern_binding_types(
    mono Monomorphizer ref,
    pattern PatternNode ref,
    subject_type Type,
    bindings [String, Type]Dict ref,
) Void = {
    let concrete_subject_type = resolve_parameterized_type(mono, subject_type)
    when pattern in {
        .Variable(name, _, _) then {
            if name <> "_" then {
                bindings.insert(name, concrete_subject_type)
            }
        },
        .EnumCase(case_name, elements, _) then {
            let field_types = mono_get_enum_case_field_types(mono, concrete_subject_type, case_name)
            let mut i UInt = 0
            for element in elements then {
                let field_type = when field_types.get(i) in {
                    .Some(t) then t,
                    .None() then Type.Unknown(),
                }
                mono_collect_pattern_binding_types(mono, element.pattern, field_type, bindings)
                i += 1
            }
        },
        .StructPattern(type_name, elements, _) then {
            let field_types = mono_get_struct_pattern_field_types(mono, concrete_subject_type, type_name)
            let mut i UInt = 0
            for element in elements then {
                let field_type = when field_types.get(i) in {
                    .Some(t) then t,
                    .None() then Type.Unknown(),
                }
                mono_collect_pattern_binding_types(mono, element.pattern, field_type, bindings)
                i += 1
            }
        },
        .AndPattern(left, right, _) then {
            mono_collect_pattern_binding_types(mono, left, concrete_subject_type, bindings)
            mono_collect_pattern_binding_types(mono, right, concrete_subject_type, bindings)
        },
        .OrPattern(left, right, _) then {
            mono_collect_pattern_binding_types(mono, left, concrete_subject_type, bindings)
            mono_collect_pattern_binding_types(mono, right, concrete_subject_type, bindings)
        },
        .NotPattern(inner, _) then {
            mono_collect_pattern_binding_types(mono, inner, concrete_subject_type, bindings)
        },
        _ then {},
    }
}

private let mono_register_pattern_binding_symbol_type(
    mono Monomorphizer ref,
    symbol Symbol ref,
    bindings [String, Type]Dict,
) Void = {
    if symbol.def_id.id == 0 then { return }
    when bindings.get(symbol.name) in {
        .Some(bound_type) then {
            let current_type = resolve_symbol_type(mono, symbol).symbol_type
            if mono_is_unresolved_expr_type(mono, current_type) and not mono_is_unresolved_expr_type(mono, bound_type) then {
                let symbol_kind = when mono.storage.def_id_map.get_symbol_kind(symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then symbol.kind,
                }
                let symbol_method_kind = when mono.storage.def_id_map.get_symbol_method_kind(symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then MethodKind.Normal(),
                }
                let symbol_mutable = when mono.storage.def_id_map.get_symbol_mutable(symbol.def_id) in {
                    .Some(mutable) then mutable,
                    .None() then false,
                }
                mono.storage.def_id_map.set_symbol_info(symbol.def_id, SymbolInfo(bound_type, symbol_kind, symbol_method_kind, symbol_mutable))
            }
        },
        .None() then {},
    }
}

private let mono_register_pattern_binding_types_in_statement(
    mono Monomorphizer ref,
    stmt TypedStatement,
    bindings [String, Type]Dict,
) Void = {
    when stmt in {
        .LetStmt(_, value, _) then mono_register_pattern_binding_types_in_expr(mono, value, bindings),
        .PairLetStmt(_, _, value, _) then mono_register_pattern_binding_types_in_expr(mono, value, bindings),
        .AssignmentStmt(target, value, _) then {
            mono_register_pattern_binding_types_in_expr(mono, target, bindings)
            mono_register_pattern_binding_types_in_expr(mono, value, bindings)
        },
        .ExprStmt(expr, _) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
        .ReturnStmt(value, _) then when value in {
            .Some(expr) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
            .None() then {},
        },
        .FinallyStmt(expr, _) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
        .YieldStmt(expr, _) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
        _ then {},
    }
}

private let mono_register_pattern_binding_types_in_expr(
    mono Monomorphizer ref,
    expr TypedExpr ref,
    bindings [String, Type]Dict,
) Void = {
    when expr.expr_kind in {
        .Variable(symbol) then mono_register_pattern_binding_symbol_type(mono, symbol, bindings),
        .CastExpr(_, inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .TraitObjectConversion(inner, _, _) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .Unary(_, inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .RefExpr(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .PtrExpr(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .DerefExpr(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .ArithmeticExpr(left, _, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .ComparisonExpr(left, _, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .BitwiseExpr(left, _, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .AndExpr(left, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .OrExpr(left, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .IsExpr(subject, _) then mono_register_pattern_binding_types_in_expr(mono, subject, bindings),
        .IsNotExpr(subject, _) then mono_register_pattern_binding_types_in_expr(mono, subject, bindings),
        .RangeExpr(_, left, right) then {
            when left in { .Some(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings), .None() then {} }
            when right in { .Some(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings), .None() then {} }
        },
        .CollectionLiteral(elements) then for element in elements then { mono_register_pattern_binding_types_in_expr(mono, element, bindings) },
        .DictLiteral(entries) then for entry in entries then {
            mono_register_pattern_binding_types_in_expr(mono, entry.first, bindings)
            mono_register_pattern_binding_types_in_expr(mono, entry.second, bindings)
        },
        .Call(callee, args) then {
            mono_register_pattern_binding_types_in_expr(mono, callee, bindings)
            for arg in args then { mono_register_pattern_binding_types_in_expr(mono, arg, bindings) }
        },
        .MemberExpr(base, _) then mono_register_pattern_binding_types_in_expr(mono, base, bindings),
        .MemberPath(base, _) then mono_register_pattern_binding_types_in_expr(mono, base, bindings),
        .Block(statements) then for stmt in statements then { mono_register_pattern_binding_types_in_statement(mono, stmt, bindings) },
        .IfExpr(condition, then_branch, else_branch) then {
            mono_register_pattern_binding_types_in_expr(mono, condition, bindings)
            mono_register_pattern_binding_types_in_expr(mono, then_branch, bindings)
            when else_branch in { .Some(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings), .None() then {} }
        },
        .WhileExpr(condition, body) then {
            mono_register_pattern_binding_types_in_expr(mono, condition, bindings)
            mono_register_pattern_binding_types_in_expr(mono, body, bindings)
        },
        .IfPatternExpr(subject, _, then_branch, else_branch) then {
            mono_register_pattern_binding_types_in_expr(mono, subject, bindings)
            mono_register_pattern_binding_types_in_expr(mono, then_branch, bindings)
            when else_branch in { .Some(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings), .None() then {} }
        },
        .WhilePatternExpr(subject, _, body) then {
            mono_register_pattern_binding_types_in_expr(mono, subject, bindings)
            mono_register_pattern_binding_types_in_expr(mono, body, bindings)
        },
        .ForExpr(_, iterable, body) then {
            mono_register_pattern_binding_types_in_expr(mono, iterable, bindings)
            mono_register_pattern_binding_types_in_expr(mono, body, bindings)
        },
        .WhenExpr(subject, arms) then {
            mono_register_pattern_binding_types_in_expr(mono, subject, bindings)
            for arm in arms then { mono_register_pattern_binding_types_in_expr(mono, arm.body, bindings) }
        },
        .LambdaExpr(_, _, body) then mono_register_pattern_binding_types_in_expr(mono, body, bindings),
        .ImplicitMemberExpr(_, args) then for arg in args then { mono_register_pattern_binding_types_in_expr(mono, arg, bindings) },
        .StaticMethodCall(_, _, args) then for arg in args then { mono_register_pattern_binding_types_in_expr(mono, arg, bindings) },
        .GenericMethodCall(base, _, _, args, _) then {
            mono_register_pattern_binding_types_in_expr(mono, base, bindings)
            for arg in args then { mono_register_pattern_binding_types_in_expr(mono, arg, bindings) }
        },
        .QualifiedMethodCall(base, _, _, args, _) then {
            mono_register_pattern_binding_types_in_expr(mono, base, bindings)
            for arg in args then { mono_register_pattern_binding_types_in_expr(mono, arg, bindings) }
        },
        .IntrinsicCall(node) then {
            when node in {
                .AllocMemory(count, _) then mono_register_pattern_binding_types_in_expr(mono, count, bindings),
                .DeallocMemory(pointer_expr) then mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings),
                .CopyMemory(dest, source, count) then {
                    mono_register_pattern_binding_types_in_expr(mono, dest, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, source, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, count, bindings)
                },
                .MoveMemory(dest, source, count) then {
                    mono_register_pattern_binding_types_in_expr(mono, dest, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, source, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, count, bindings)
                },
                .InitMemory(pointer_expr, value_expr) then {
                    mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, value_expr, bindings)
                },
                .DeinitMemory(pointer_expr) then mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings),
                .TakeMemory(pointer_expr, _) then mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings),
                .NullPtr(_) then {},
            }
        },
        _ then {},
    }
}

// Try to bind a generic top-level function call callee to a concrete instantiated
// function symbol using call-site argument types.
private let bind_generic_function_call_callee(
    mono Monomorphizer ref,
    callee TypedExpr ref,
    args [TypedExpr ref]List,
    expected_return_type Type,
) TypedExpr ref = {
    when callee.expr_kind in {
        .Variable(symbol) then {
            // Swift-aligned fast path: only reuse an existing concrete callee when
            // the full call shape is already concrete and matches exactly.
            if symbol.def_id.id > 0 then {
                when mono.storage.remapped_function_def_ids.get(symbol.def_id.id) in {
                    .Some(remapped_list) then {
                        let mut call_param_types = [Type ref]List.new()
                        let mut can_disambiguate = not is_placeholder_inferred_type(expected_return_type)
                        for arg in args then {
                            let arg_type = resolve_parameterized_type(mono, arg.expr_type)
                            if is_placeholder_inferred_type(arg_type) then {
                                can_disambiguate = false
                            }
                            call_param_types.push(box(arg_type))
                        }

                        if can_disambiguate then {
                            let expected_call_type = Type.FunctionType(call_param_types, box(resolve_parameterized_type(mono, expected_return_type)))
                            for remapped in remapped_list then {
                                let candidate_def_id = remapped.first
                                let candidate_type = resolve_parameterized_type(mono, remapped.second)
                                if layout_key(candidate_type) == layout_key(expected_call_type) then {
                                    let concrete_name = when mono.storage.def_id_map.get_name(candidate_def_id) in {
                                        .Some(name) then name,
                                        .None() then symbol.name,
                                    }
                                    let concrete_symbol = Symbol(candidate_def_id, concrete_name, candidate_type, SymbolKind.Function())
                                    return box(TypedExpr(box(TypedExprKind.Variable(box(concrete_symbol))), candidate_type))
                                }
                            }
                        }
                    },
                    .None() then {},
                }
            }

            // Find generic function template by DefId first to avoid collisions
            // between helpers that share the same textual name across modules.
            let template_opt = if symbol.def_id.id > 0 then mono.storage.input.generic_templates.lookup_function_by_def_id(symbol.def_id)
                else [GenericFunctionTemplate]Option.None()
            let template = when template_opt in {
                .Some(t) then t,
                .None() then {
                    if symbol.def_id.id > 0 and not has_generic_parameter(resolve_parameterized_type(mono, symbol.symbol_type)) then {
                        return callee
                    }
                    yield when mono.storage.input.generic_templates.lookup_function(symbol.name) in {
                        .Some(by_name) then by_name,
                        .None() then { return callee },
                    }
                },
            }

            // Symbols may lose template DefId during substitution passes.
            // Keep name-based binding so generic helper calls can still be
            // instantiated in monomorphization, matching Swift's call flow.
            if template.type_parameters.is_empty() then { return callee }

            let mut inferred = [String, Type]Dict.new()
            let mut type_param_names = [String]List.new()
            for tp in template.type_parameters then {
                type_param_names.push(tp.name)
            }

            // Infer generic type arguments from template parameter TypeNodes and call args.
            let mut i UInt = 0
            while i < template.parameters.count() and i < args.count() then {
                let expected_node = template.parameters.at(i).param_type
                let actual = resolve_parameterized_type(mono, args.at(i).expr_type)
                collect_generic_bindings_from_type_node(mono, expected_node, actual, template.type_parameters, inferred.ref)
                i += 1
            }

            let concrete_expected_return = resolve_parameterized_type(mono, expected_return_type)
            if not has_generic_parameter(concrete_expected_return) then {
                let mut pattern_param_types = [Type ref]List.new()
                when template.checked_parameters in {
                    .Some(checked_params) then {
                        for param in checked_params then {
                            pattern_param_types.push(box(param.symbol_type))
                        }
                    },
                    .None() then {
                        for param in template.parameters then {
                            pattern_param_types.push(box(resolve_type_node(mono, param.param_type, [String, Type]Dict.new())))
                        }
                    },
                }

                let pattern_return_type = when template.checked_return_type in {
                    .Some(checked_ret) then checked_ret,
                    .None() then resolve_type_node(mono, template.return_type, [String, Type]Dict.new()),
                }

                let mut actual_param_types = [Type ref]List.new()
                for arg in args then {
                    actual_param_types.push(box(resolve_parameterized_type(mono, arg.expr_type)))
                }

                let pattern_call_type = Type.FunctionType(pattern_param_types, box(pattern_return_type))
                let actual_call_type = Type.FunctionType(actual_param_types, box(concrete_expected_return))
                let _matched = unify_generic_type_pattern(mono, pattern_call_type, actual_call_type, type_param_names, inferred.ref)
            }

            // Generic intrinsic functions are runtime-provided, but their symbol
            // type still needs concrete substitutions so downstream codegen uses
            // the right ref/weakref/option layouts.
            let is_intrinsic_template = when template.checked_body in {
                .None() then true,
                .Some(_) then false,
            }
            if is_intrinsic_template then {
                let intrinsic_type = when template.checked_return_type in {
                    .Some(ret_ty) then {
                        let mut ps = [Type ref]List.new()
                        when template.checked_parameters in {
                            .Some(params) then {
                                for p in params then {
                                    let param_type = resolve_parameterized_type(mono, substitute_type(mono, p.symbol_type, inferred))
                                    ps.push(box(param_type))
                                }
                            },
                            .None() then {
                                when symbol.symbol_type in {
                                    .FunctionType(param_types, _) then {
                                        for p in param_types then {
                                            let param_type = resolve_parameterized_type(mono, substitute_type(mono, p.val, inferred))
                                            ps.push(box(param_type))
                                        }
                                    },
                                    _ then {},
                                }
                            },
                        }
                        let resolved_return = resolve_parameterized_type(mono, substitute_type(mono, ret_ty, inferred))
                        yield Type.FunctionType(ps, box(resolved_return))
                    },
                    .None() then resolve_parameterized_type(mono, substitute_type(mono, symbol.symbol_type, inferred)),
                }
                let intrinsic_symbol = Symbol(template.def_id, symbol.name, intrinsic_type, SymbolKind.Function())
                return box(TypedExpr(box(TypedExprKind.Variable(box(intrinsic_symbol))), intrinsic_type))
            }

            let mut type_args = [Type ref]List.new()
            for tp in template.type_parameters then {
                let inferred_arg = when inferred.get(tp.name) in {
                    .Some(t) then resolve_parameterized_type(mono, t),
                    .None() then {
                        // Fallback to expected call return type when template return is this type parameter.
                        let from_expected_return = when template.return_type in {
                            .Identifier(ret_name) then ret_name == tp.name,
                            .ModuleQualified(_, ret_name) then ret_name == tp.name,
                            _ then false,
                        }
                        let constrained_by_params = template_type_parameter_constrained_by_parameters(template, tp.name)
                        yield if from_expected_return and not constrained_by_params and not has_generic_parameter(concrete_expected_return)
                            then concrete_expected_return
                            else Type.GenericParameter(tp.name)
                    },
                }
                let canonical_arg = canonical_type_for_generic_binding(mono, inferred_arg)
                if has_generic_parameter(canonical_arg) then {
                    return callee
                }
                type_args.push(box(canonical_arg))
            }

            if args_have_generic_parameter(type_args) then {
                return callee
            }

            let instantiated = mono.instantiate_function_impl(template, type_args)
            if instantiated.mangled_name.is_empty() then { return callee }

            let bound_symbol = when mono.storage.instantiated_function_symbols.get(instantiated.mangled_name) in {
                .Some(sym) then sym,
                .None() then { return callee },
            }
            let concrete_type = when mono.storage.def_id_map.get_signature(bound_symbol.def_id) in {
                .Some(sig) then {
                    let mut ps = [Type ref]List.new()
                    for p in sig.param_types then { ps.push(box(p)) }
                    yield Type.FunctionType(ps, box(sig.return_type))
                },
                .None() then bound_symbol.symbol_type,
            }
            let concrete_symbol = Symbol(bound_symbol.def_id, bound_symbol.name, concrete_type, SymbolKind.Function())
            return box(TypedExpr(box(TypedExprKind.Variable(box(concrete_symbol))), concrete_type))
        },
        _ then {},
    }
    return callee
}

// Collect GenericParameter -> concrete Type bindings by structurally matching a
// template parameter TypeNode against an actual call-site type.
private let collect_generic_bindings_from_type_node(
    mono Monomorphizer ref,
    expected_node TypeNode,
    actual Type,
    type_params [TypeParameterDecl]List,
    bindings [String, Type]Dict ref,
) Void = {
    when expected_node in {
        .Identifier(name) then {
            if is_type_parameter_name(name, type_params) then {
                when bindings.get(name) in {
                    .Some(existing) then {
                        if is_placeholder_inferred_type(existing) and not is_placeholder_inferred_type(actual) then {
                            bindings.insert(name, actual)
                        }
                    },
                    .None() then {
                        bindings.insert(name, actual)
                    },
                }
            }
        },
        .Reference(inner) then {
            when actual in {
                .ReferenceType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                _ then {},
            }
        },
        .Pointer(inner) then {
            when actual in {
                .PointerType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                _ then {},
            }
        },
        .WeakReference(inner) then {
            when actual in {
                .WeakReferenceType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                _ then {},
            }
        },
        .Generic(base, args) then {
            when actual in {
                .GenericStruct(act_base, act_args) then {
                    if base == act_base then {
                        let mut i UInt = 0
                        while i < args.count() and i < act_args.count() then {
                            collect_generic_bindings_from_type_node(mono, args.at(i).val, act_args.at(i).val, type_params, bindings)
                            i += 1
                        }
                    }
                },
                .StructureType(def_id) then {
                    when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then {
                            if template_name == base then {
                                when mono.storage.def_id_map.get_type_arguments(def_id) in {
                                    .Some(act_args) then {
                                        let mut i UInt = 0
                                        while i < args.count() and i < act_args.count() then {
                                            collect_generic_bindings_from_type_node(mono, args.at(i).val, act_args.at(i), type_params, bindings)
                                            i += 1
                                        }
                                    },
                                    .None() then {},
                                }
                            }
                        },
                        .None() then {},
                    }
                },
                .GenericEnum(act_base, act_args) then {
                    if base == act_base then {
                        let mut i UInt = 0
                        while i < args.count() and i < act_args.count() then {
                            collect_generic_bindings_from_type_node(mono, args.at(i).val, act_args.at(i).val, type_params, bindings)
                            i += 1
                        }
                    }
                },
                .EnumType(def_id) then {
                    when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then {
                            if template_name == base then {
                                when mono.storage.def_id_map.get_type_arguments(def_id) in {
                                    .Some(act_args) then {
                                        let mut i UInt = 0
                                        while i < args.count() and i < act_args.count() then {
                                            collect_generic_bindings_from_type_node(mono, args.at(i).val, act_args.at(i), type_params, bindings)
                                            i += 1
                                        }
                                    },
                                    .None() then {},
                                }
                            }
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }
        },
        .FunctionType(param_nodes, ret_node) then {
            when actual in {
                .FunctionType(param_types, ret_type) then {
                    let mut i UInt = 0
                    while i < param_nodes.count() and i < param_types.count() then {
                        collect_generic_bindings_from_type_node(mono, param_nodes.at(i).val, param_types.at(i).val, type_params, bindings)
                        i += 1
                    }
                    collect_generic_bindings_from_type_node(mono, ret_node.val, ret_type.val, type_params, bindings)
                },
                _ then {},
            }
        },
        .ModuleQualified(_, name) then {
            if is_type_parameter_name(name, type_params) then {
                when bindings.get(name) in {
                    .Some(existing) then {
                        if is_placeholder_inferred_type(existing) and not is_placeholder_inferred_type(actual) then {
                            bindings.insert(name, actual)
                        }
                    },
                    .None() then {
                        bindings.insert(name, actual)
                    },
                }
            }
        },
        .ModuleQualifiedGeneric(_, base, args) then {
            // Treat qualified generics the same structurally for binding.
            collect_generic_bindings_from_type_node(mono, TypeNode.Generic(base, args), actual, type_params, bindings)
        },
        .InferredSelf() then {},
    }
}

private let is_type_parameter_name(name String, type_params [TypeParameterDecl]List) Bool = {
    for tp in type_params then {
        if tp.name == name then { return true }
    }
    return false
}

private let type_node_mentions_type_parameter(node TypeNode, type_param_name String) Bool = {
    return when node in {
        .Identifier(name) then name == type_param_name,
        .Reference(inner) then type_node_mentions_type_parameter(inner.val, type_param_name),
        .Pointer(inner) then type_node_mentions_type_parameter(inner.val, type_param_name),
        .WeakReference(inner) then type_node_mentions_type_parameter(inner.val, type_param_name),
        .Generic(_, args) then {
            for arg in args then {
                if type_node_mentions_type_parameter(arg.val, type_param_name) then { return true }
            }
            yield false
        },
        .FunctionType(param_nodes, ret_node) then {
            for p in param_nodes then {
                if type_node_mentions_type_parameter(p.val, type_param_name) then { return true }
            }
            yield type_node_mentions_type_parameter(ret_node.val, type_param_name)
        },
        .ModuleQualified(_, name) then name == type_param_name,
        .ModuleQualifiedGeneric(_, base, args) then {
            if base == type_param_name then { return true }
            for arg in args then {
                if type_node_mentions_type_parameter(arg.val, type_param_name) then { return true }
            }
            yield false
        },
        .InferredSelf() then false,
    }
}

private let template_type_parameter_constrained_by_parameters(template GenericFunctionTemplate, type_param_name String) Bool = {
    for param in template.parameters then {
        if type_node_mentions_type_parameter(param.param_type, type_param_name) then {
            return true
        }
    }
    return false
}

let is_placeholder_inferred_type(t Type) Bool = {
    return when t in {
        .Unknown() then true,
        .TypeVar(_) then true,
        .GenericParameter(_) then true,
        _ then false,
    }
}

private let canonical_type_for_generic_binding(mono Monomorphizer ref, t Type) Type = {
    return when t in {
        .StructureType(def_id) then {
            let reconstructed = when mono.storage.def_id_map.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.def_id_map.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut canonical_args = [Type ref]List.new()
                            for type_arg in type_args then {
                                canonical_args.push(box(canonical_type_for_generic_binding(mono, type_arg)))
                            }
                            yield [Type]Option.Some(Type.GenericStruct(template_name, canonical_args))
                        },
                        .None() then [Type]Option.None(),
                    }
                },
                .None() then [Type]Option.None(),
            }
            yield when reconstructed in {
                .Some(reconstructed_type) then reconstructed_type,
                .None() then when mono.storage.def_id_map.lookup_type(def_id) in {
                    .Some(mapped) then canonical_type_for_generic_binding(mono, mapped),
                    .None() then t,
                },
            }
        },
        .EnumType(def_id) then {
            let reconstructed = when mono.storage.def_id_map.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.def_id_map.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut canonical_args = [Type ref]List.new()
                            for type_arg in type_args then {
                                canonical_args.push(box(canonical_type_for_generic_binding(mono, type_arg)))
                            }
                            yield [Type]Option.Some(Type.GenericEnum(template_name, canonical_args))
                        },
                        .None() then [Type]Option.None(),
                    }
                },
                .None() then [Type]Option.None(),
            }
            yield when reconstructed in {
                .Some(reconstructed_type) then reconstructed_type,
                .None() then when mono.storage.def_id_map.lookup_type(def_id) in {
                    .Some(mapped) then canonical_type_for_generic_binding(mono, mapped),
                    .None() then t,
                },
            }
        },
        .OpaqueType(def_id) then {
            yield when mono.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped) then canonical_type_for_generic_binding(mono, mapped),
                .None() then t,
            }
        },
        .ReferenceType(inner_ref) then Type.ReferenceType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .WeakReferenceType(inner_ref) then Type.WeakReferenceType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .PointerType(inner_ref) then Type.PointerType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .FunctionType(param_types, return_type_ref) then {
            let mut new_params = [Type ref]List.new()
            for param_type in param_types then {
                new_params.push(box(canonical_type_for_generic_binding(mono, param_type.val)))
            }
            yield Type.FunctionType(new_params, box(canonical_type_for_generic_binding(mono, return_type_ref.val)))
        },
        .GenericStruct(name, args) then {
            let mut new_args = [Type ref]List.new()
            for arg in args then {
                new_args.push(box(canonical_type_for_generic_binding(mono, arg.val)))
            }
            yield Type.GenericStruct(name, new_args)
        },
        .GenericEnum(name, args) then {
            let mut new_args = [Type ref]List.new()
            for arg in args then {
                new_args.push(box(canonical_type_for_generic_binding(mono, arg.val)))
            }
            yield Type.GenericEnum(name, new_args)
        },
        _ then t,
    }
}

private let is_generic_type_param_name(name String, type_param_names [String]List) Bool = {
    for param_name in type_param_names then {
        if param_name == name then { return true }
    }
    return false
}

private let unify_generic_type_pattern(
    mono Monomorphizer ref,
    pattern Type,
    actual Type,
    type_param_names [String]List,
    inferred [String, Type]Dict ref,
) Bool = {
    let normalized_actual = canonical_type_for_generic_binding(mono, actual)
    return when pattern in {
        .GenericParameter(name) then {
            yield if not is_generic_type_param_name(name, type_param_names) then layout_key(pattern) == layout_key(normalized_actual) else when inferred.get(name) in {
                .Some(existing) then layout_key(existing) == layout_key(normalized_actual),
                .None() then {
                    inferred.insert(name, normalized_actual)
                    yield true
                },
            }
        },
        .ReferenceType(pattern_inner) then {
            yield when normalized_actual in {
                .ReferenceType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .WeakReferenceType(pattern_inner) then {
            yield when normalized_actual in {
                .WeakReferenceType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .PointerType(pattern_inner) then {
            yield when normalized_actual in {
                .PointerType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .GenericStruct(pattern_name, pattern_args) then {
            let actual_args_opt = when normalized_actual in {
                .GenericStruct(actual_name, actual_args) then {
                    yield if actual_name == pattern_name then [[Type ref]List]Option.Some(actual_args) else [[Type ref]List]Option.None()
                },
                .StructureType(def_id) then {
                    yield when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then {
                            yield if template_name == pattern_name then when mono.storage.def_id_map.get_type_arguments(def_id) in {
                                .Some(type_args) then {
                                    let mut args = [Type ref]List.new()
                                    for type_arg in type_args then { args.push(box(type_arg)) }
                                    yield [[Type ref]List]Option.Some(args)
                                },
                                .None() then [[Type ref]List]Option.None(),
                            } else [[Type ref]List]Option.None()
                        },
                        .None() then [[Type ref]List]Option.None(),
                    }
                },
                _ then [[Type ref]List]Option.None(),
            }
            yield when actual_args_opt in {
                .Some(actual_args) then {
                    if pattern_args.count() <> actual_args.count() then { return false }
                    let mut matches = true
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not unify_generic_type_pattern(mono, pattern_args.at(i).val, actual_args.at(i).val, type_param_names, inferred) then {
                            matches = false
                        }
                        i += 1
                    }
                    yield matches
                },
                .None() then false,
            }
        },
        .GenericEnum(pattern_name, pattern_args) then {
            let actual_args_opt = when normalized_actual in {
                .GenericEnum(actual_name, actual_args) then {
                    yield if actual_name == pattern_name then [[Type ref]List]Option.Some(actual_args) else [[Type ref]List]Option.None()
                },
                .EnumType(def_id) then {
                    yield when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then {
                            yield if template_name == pattern_name then when mono.storage.def_id_map.get_type_arguments(def_id) in {
                                .Some(type_args) then {
                                    let mut args = [Type ref]List.new()
                                    for type_arg in type_args then { args.push(box(type_arg)) }
                                    yield [[Type ref]List]Option.Some(args)
                                },
                                .None() then [[Type ref]List]Option.None(),
                            } else [[Type ref]List]Option.None()
                        },
                        .None() then [[Type ref]List]Option.None(),
                    }
                },
                _ then [[Type ref]List]Option.None(),
            }
            yield when actual_args_opt in {
                .Some(actual_args) then {
                    if pattern_args.count() <> actual_args.count() then { return false }
                    let mut matches = true
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not unify_generic_type_pattern(mono, pattern_args.at(i).val, actual_args.at(i).val, type_param_names, inferred) then {
                            matches = false
                        }
                        i += 1
                    }
                    yield matches
                },
                .None() then false,
            }
        },
        .FunctionType(pattern_params, pattern_return) then {
            yield when normalized_actual in {
                .FunctionType(actual_params, actual_return) then {
                    if pattern_params.count() <> actual_params.count() then { return false }
                    let mut matches = true
                    let mut i UInt = 0
                    while i < pattern_params.count() then {
                        if not unify_generic_type_pattern(mono, pattern_params.at(i).val, actual_params.at(i).val, type_param_names, inferred) then {
                            matches = false
                        }
                        i += 1
                    }
                    yield matches and unify_generic_type_pattern(mono, pattern_return.val, actual_return.val, type_param_names, inferred)
                },
                _ then false,
            }
        },
        _ then layout_key(pattern) == layout_key(normalized_actual),
    }
}

// Collect GenericParameter -> concrete Type bindings by structurally matching an
// expected template type against an actual call-site type.
private let collect_generic_type_bindings(expected Type, actual Type, bindings [String, Type]Dict ref) Void = {
    when expected in {
        .GenericParameter(name) then {
            when bindings.get(name) in {
                .Some(existing) then {
                    if is_placeholder_inferred_type(existing) and not is_placeholder_inferred_type(actual) then {
                        bindings.insert(name, actual)
                    }
                },
                .None() then {
                    bindings.insert(name, actual)
                },
            }
        },
        .ReferenceType(exp_inner) then {
            when actual in {
                .ReferenceType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .WeakReferenceType(exp_inner) then {
            when actual in {
                .WeakReferenceType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .PointerType(exp_inner) then {
            when actual in {
                .PointerType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .FunctionType(exp_params, exp_ret) then {
            when actual in {
                .FunctionType(act_params, act_ret) then {
                    let mut i UInt = 0
                    while i < exp_params.count() and i < act_params.count() then {
                        collect_generic_type_bindings(exp_params.at(i).val, act_params.at(i).val, bindings)
                        i += 1
                    }
                    collect_generic_type_bindings(exp_ret.val, act_ret.val, bindings)
                },
                _ then {},
            }
        },
        .GenericStruct(exp_name, exp_args) then {
            when actual in {
                .GenericStruct(act_name, act_args) then {
                    if exp_name == act_name then {
                        let mut i UInt = 0
                        while i < exp_args.count() and i < act_args.count() then {
                            collect_generic_type_bindings(exp_args.at(i).val, act_args.at(i).val, bindings)
                            i += 1
                        }
                    }
                },
                _ then {},
            }
        },
        .GenericEnum(exp_name, exp_args) then {
            when actual in {
                .GenericEnum(act_name, act_args) then {
                    if exp_name == act_name then {
                        let mut i UInt = 0
                        while i < exp_args.count() and i < act_args.count() then {
                            collect_generic_type_bindings(exp_args.at(i).val, act_args.at(i).val, bindings)
                            i += 1
                        }
                    }
                },
                _ then {},
            }
        },
        _ then {},
    }
}

private let resolve_expr_kind(mono Monomorphizer ref, expr TypedExpr ref) TypedExprKind ref = {
    return when expr.expr_kind in {
        .Variable(symbol) then box(TypedExprKind.Variable(box(resolve_symbol_type(mono, symbol)))),
        .CastExpr(target_type, inner) then {
            let new_target = resolve_parameterized_type(mono, target_type)
            let resolved_inner = resolve_types_in_expression(mono, inner)
            when new_target in {
                .TraitObject(trait_name) then {
                    let actual_type = resolve_parameterized_type(mono, resolved_inner.expr_type)
                    let concrete_type = when actual_type in {
                        .ReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        .WeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        _ then actual_type,
                    }
                    collect_concrete_vtable_request(mono, concrete_type, trait_name)
                },
                _ then {},
            }
            yield box(TypedExprKind.CastExpr(new_target, resolved_inner))
        },
        .TraitObjectConversion(inner, trait_type, concrete_type) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            let mut new_trait_type = resolve_parameterized_type(mono, trait_type)
            when trait_type in {
                .TraitObject(original_trait_name) then { new_trait_type = Type.TraitObject(original_trait_name) },
                _ then {},
            }
            let new_concrete_type = resolve_parameterized_type(mono, concrete_type)
            when new_trait_type in {
                .TraitObject(trait_name) then collect_concrete_vtable_request(mono, new_concrete_type, trait_name),
                _ then {},
            }
            yield box(TypedExprKind.TraitObjectConversion(new_inner, new_trait_type, new_concrete_type))
        },
        .Unary(op, inner) then {
            yield box(TypedExprKind.Unary(op, resolve_types_in_expression(mono, inner)))
        },
        .RefExpr(inner) then box(TypedExprKind.RefExpr(resolve_types_in_expression(mono, inner))),
        .PtrExpr(inner) then box(TypedExprKind.PtrExpr(resolve_types_in_expression(mono, inner))),
        .DerefExpr(inner) then box(TypedExprKind.DerefExpr(resolve_types_in_expression(mono, inner))),
        .ArithmeticExpr(left, op, right) then {
            yield box(TypedExprKind.ArithmeticExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .ComparisonExpr(left, op, right) then {
            yield box(TypedExprKind.ComparisonExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .BitwiseExpr(left, op, right) then {
            yield box(TypedExprKind.BitwiseExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .AndExpr(left, right) then {
            yield box(TypedExprKind.AndExpr(resolve_types_in_expression(mono, left), resolve_types_in_expression(mono, right)))
        },
        .OrExpr(left, right) then {
            yield box(TypedExprKind.OrExpr(resolve_types_in_expression(mono, left), resolve_types_in_expression(mono, right)))
        },
        .IsExpr(subject, pattern) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            yield box(TypedExprKind.IsExpr(new_subject, pattern))
        },
        .IsNotExpr(subject, pattern) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            yield box(TypedExprKind.IsNotExpr(new_subject, pattern))
        },
        .RangeExpr(op, left, right) then {
            let new_left = when left in {
                .Some(inner) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, inner)),
                .None() then [TypedExpr ref]Option.None(),
            }
            let new_right = when right in {
                .Some(inner) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, inner)),
                .None() then [TypedExpr ref]Option.None(),
            }
            yield box(TypedExprKind.RangeExpr(op, new_left, new_right))
        },
        .CollectionLiteral(elements) then {
            let mut new_elements = [TypedExpr ref]List.new()
            for e in elements then {
                new_elements.push(resolve_types_in_expression(mono, e))
            }
            yield box(TypedExprKind.CollectionLiteral(new_elements))
        },
        .DictLiteral(entries) then {
            let mut new_entries = [TypedExprPair]List.new()
            for entry in entries then {
                new_entries.push(TypedExprPair(resolve_types_in_expression(mono, entry.first), resolve_types_in_expression(mono, entry.second)))
            }
            yield box(TypedExprKind.DictLiteral(new_entries))
        },
        .Call(callee, args) then {
            let new_callee = resolve_types_in_expression(mono, callee)
            let mut new_args = [TypedExpr ref]List.new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            yield box(TypedExprKind.Call(new_callee, new_args))
        },
        .MemberExpr(base, member) then {
            yield box(TypedExprKind.MemberExpr(resolve_types_in_expression(mono, base), member))
        },
        .MemberPath(base, path) then {
            yield box(TypedExprKind.MemberPath(resolve_types_in_expression(mono, base), path))
        },
        .Block(statements) then {
            let mut new_statements = [TypedStatement]List.new()
            for stmt in statements then {
                new_statements.push(resolve_types_in_statement(mono, stmt))
            }
            yield box(TypedExprKind.Block(new_statements))
        },
        .IfExpr(condition, then_branch, else_branch) then {
            let new_condition = resolve_types_in_expression(mono, condition)
            let new_then = resolve_types_in_expression(mono, then_branch)
            let new_else = when else_branch in {
                .Some(expr) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, expr)),
                .None() then [TypedExpr ref]Option.None(),
            }
            yield box(TypedExprKind.IfExpr(new_condition, new_then, new_else))
        },
        .WhileExpr(condition, body) then {
            yield box(TypedExprKind.WhileExpr(resolve_types_in_expression(mono, condition), resolve_types_in_expression(mono, body)))
        },
        .IfPatternExpr(subject, pattern, then_branch, else_branch) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            let mut pattern_bindings = [String, Type]Dict.new()
            mono_collect_pattern_binding_types(mono, pattern, new_subject.expr_type, pattern_bindings.ref)
            mono_register_pattern_binding_types_in_expr(mono, then_branch, pattern_bindings)
            let new_then = resolve_types_in_expression(mono, then_branch)
            let new_else = when else_branch in {
                .Some(expr) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, expr)),
                .None() then [TypedExpr ref]Option.None(),
            }
            yield box(TypedExprKind.IfPatternExpr(new_subject, pattern, new_then, new_else))
        },
        .WhilePatternExpr(subject, pattern, body) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            let mut pattern_bindings = [String, Type]Dict.new()
            mono_collect_pattern_binding_types(mono, pattern, new_subject.expr_type, pattern_bindings.ref)
            mono_register_pattern_binding_types_in_expr(mono, body, pattern_bindings)
            yield box(TypedExprKind.WhilePatternExpr(new_subject, pattern, resolve_types_in_expression(mono, body)))
        },
        .ForExpr(pattern, iterable, body) then {
            let new_iterable = resolve_types_in_expression(mono, iterable)
            let new_body = resolve_types_in_expression(mono, body)
            let iterable_type = resolve_parameterized_type(mono, new_iterable.expr_type)

            // Trigger on-demand instantiation of iterator() and next() extension methods.
            // This matches the Swift compiler's approach where for-loop desugaring happens
            // during type checking and calls lookupConcreteMethodSymbol to instantiate
            // the methods. In the bootstrap compiler, we trigger instantiation here during
            // monomorphization so that codegen can find the methods by name.
            if mono.storage.extension_body_resolution_depth == 0 and not has_generic_parameter(iterable_type) then {
                // Auto-deref for reference types
                let base_iterable_type = when iterable_type in {
                    .ReferenceType(inner) then inner.val,
                    _ then iterable_type,
                }

                // Try to instantiate iterator() method
                let dummy_iterator_sym = Symbol(DefId(0), "iterator", Type.Unknown(), SymbolKind.Function())
                let iterator_sym = try_bind_generic_method_call(mono, base_iterable_type, dummy_iterator_sym, [TypedExpr ref]List.new(), Type.Unknown())

                // Get the iterator type from the method's return type
                let iterator_type = when mono.storage.def_id_map.get_signature(iterator_sym.def_id) in {
                    .Some(sig) then sig.return_type,
                    .None() then iterator_sym.symbol_type,
                }

                // Try to instantiate next() method on the iterator type
                if not has_generic_parameter(iterator_type) then {
                    let dummy_next_sym = Symbol(DefId(0), "next", Type.Unknown(), SymbolKind.Function())
                    try_bind_generic_method_call(mono, iterator_type, dummy_next_sym, [TypedExpr ref]List.new(), Type.Unknown())
                }

                // Also try next() directly on the iterable (if it's already an iterator)
                let dummy_next_direct = Symbol(DefId(0), "next", Type.Unknown(), SymbolKind.Function())
                try_bind_generic_method_call(mono, base_iterable_type, dummy_next_direct, [TypedExpr ref]List.new(), Type.Unknown())
            }

            yield box(TypedExprKind.ForExpr(pattern, new_iterable, new_body))
        },
        .WhenExpr(subject, arms) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            let mut new_arms = [TypedWhenArm]List.new()
            for arm in arms then {
                let mut pattern_bindings = [String, Type]Dict.new()
                mono_collect_pattern_binding_types(mono, arm.pattern, new_subject.expr_type, pattern_bindings.ref)
                mono_register_pattern_binding_types_in_expr(mono, arm.body, pattern_bindings)
                let new_body = resolve_types_in_expression(mono, arm.body)
                let new_arm_type = resolve_parameterized_type(mono, arm.arm_type)
                new_arms.push(TypedWhenArm(arm.pattern, new_body, new_arm_type))
            }
            yield box(TypedExprKind.WhenExpr(new_subject, new_arms))
        },
        .LambdaExpr(params, return_type, body) then {
            let mut new_params = [TypedParam]List.new()
            for p in params then {
                let new_type = resolve_parameterized_type(mono, p.param_type)
                new_params.push(TypedParam(p.name, p.mutable, new_type, p.named))
            }
            let new_return = resolve_parameterized_type(mono, return_type)
            yield box(TypedExprKind.LambdaExpr(new_params, new_return, resolve_types_in_expression(mono, body)))
        },
        .ImplicitMemberExpr(member_name, args) then {
            let mut new_args = [TypedExpr ref]List.new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            collect_implicit_member_vtable_requests(mono, expr.expr_type, member_name, new_args)
            yield box(TypedExprKind.ImplicitMemberExpr(member_name, new_args))
        },
        .StaticMethodCall(receiver_type, method, args) then {
            yield resolve_static_method_call_to_call(mono, expr, receiver_type, method, args)
        },
        .GenericMethodCall(base, receiver_type, method, args, dispatch_callsite) then {
            let new_base = resolve_types_in_expression(mono, base)
            let declared_receiver_type = resolve_parameterized_type(mono, receiver_type)
            let inferred_receiver_type = resolve_parameterized_type(mono, new_base.expr_type)
            let new_receiver_type = when inferred_receiver_type in {
                .TraitObject(_) then inferred_receiver_type,
                _ then if layout_key(declared_receiver_type) <> layout_key(inferred_receiver_type)
                    and not has_generic_parameter(inferred_receiver_type)
                    then inferred_receiver_type
                    else declared_receiver_type,
            }
            let new_method = resolve_symbol_type(mono, method)
            let mut new_args = [TypedExpr ref]List.new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            // Like the Swift compiler's resolveTypesInExpression, try to instantiate
            // the extension method on-demand when the receiver is a concrete type
            // from a generic instantiation (e.g. List_String.iterator()).
            let bound_method = try_bind_generic_method_call(mono, new_receiver_type, new_method, new_args, resolve_parameterized_type(mono, expr.expr_type))
            let effective_dispatch_callsite = ensure_receiver_dispatch_callsite(mono, dispatch_callsite, new_receiver_type, bound_method)
            yield box(TypedExprKind.GenericMethodCall(new_base, new_receiver_type, box(bound_method), new_args, effective_dispatch_callsite))
        },
        .QualifiedMethodCall(base, trait_type, method, args, dispatch_callsite) then {
            let new_base = resolve_types_in_expression(mono, base)
            let mut new_trait_type = resolve_parameterized_type(mono, trait_type)
            when trait_type in {
                .TraitObject(original_trait_name) then { new_trait_type = Type.TraitObject(original_trait_name) },
                _ then {},
            }
            let resolved_method = resolve_symbol_type(mono, method)
            let new_method = Symbol(resolved_method.def_id, method.name, resolved_method.symbol_type, resolved_method.kind)
            let mut new_args = [TypedExpr ref]List.new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            when new_trait_type in {
                .TraitObject(trait_name) then collect_qualified_method_vtable_requests(mono, trait_name, method.name, new_base, new_args),
                _ then {},
            }
            let effective_dispatch_callsite = when new_trait_type in {
                .TraitObject(_) then [DefId]Option.None(),
                _ then ensure_receiver_dispatch_callsite(mono, dispatch_callsite, concrete_trait_receiver_type(mono, new_base), new_method),
            }
            yield box(TypedExprKind.QualifiedMethodCall(new_base, new_trait_type, box(new_method), new_args, effective_dispatch_callsite))
        },
        .GenericInstantiation(base_type, type_args) then {
            let new_base_type = resolve_parameterized_type(mono, base_type)
            let mut new_type_args = [Type]List.new()
            for type_arg in type_args then {
                new_type_args.push(resolve_parameterized_type(mono, type_arg))
            }
            yield box(TypedExprKind.GenericInstantiation(new_base_type, new_type_args))
        },
        _ then expr.expr_kind,
    }
}
// ── GenericMethodCall binding helper ──────────────────────────────────────────

private let infer_extension_method_type_args(
    mono Monomorphizer ref,
    ext GenericExtensionMethodTemplate,
    receiver_type Type,
    args [TypedExpr ref]List,
    expected_return_type Type,
) [[Type ref]List]Option = {
    let mut method_bindings = [String, Type]Dict.new()
    let concrete_receiver_type = resolve_parameterized_type(mono, receiver_type)
    let has_receiver_param = if not ext.method.params.is_empty() then ext.method.params.at((UInt)0).name == "self" else false
    let has_explicit_receiver_arg = if not args.is_empty() then {
        let first_arg_type = resolve_parameterized_type(mono, args.at((UInt)0).expr_type)
        yield layout_key(first_arg_type) == layout_key(concrete_receiver_type)
    } else false

    if has_receiver_param then {
        collect_generic_bindings_from_type(mono, ext.method.params.at((UInt)0).param_type, receiver_type, method_bindings.ref)
    }

    let mut arg_i UInt = if has_receiver_param and has_explicit_receiver_arg then (UInt)1 else (UInt)0
    let mut param_i UInt = if has_receiver_param then (UInt)1 else (UInt)0
    while arg_i < args.count() and param_i < ext.method.params.count() then {
        let actual_type = resolve_parameterized_type(mono, args.at(arg_i).expr_type)
        collect_generic_bindings_from_type(mono, ext.method.params.at(param_i).param_type, actual_type, method_bindings.ref)
        arg_i += 1
        param_i += 1
    }

    when ext.checked_return_type in {
        .Some(ret_type) then {
            let concrete_expected = resolve_parameterized_type(mono, expected_return_type)
            if not has_generic_parameter(concrete_expected) then {
                collect_generic_bindings_from_type(mono, ret_type, concrete_expected, method_bindings.ref)
            }
        },
        .None() then {},
    }

    let mut method_type_args = [Type ref]List.new()
    for method_tp in ext.method.type_params then {
        when method_bindings.get(method_tp.name) in {
            .Some(bound) then {
                let concrete_bound = resolve_parameterized_type(mono, bound)
                if has_generic_parameter(concrete_bound) then {
                    return [[Type ref]List]Option.None()
                }
                method_type_args.push(box(concrete_bound))
            },
            .None() then {
                let fallback_arg_index = if has_receiver_param and has_explicit_receiver_arg then (UInt)1 else (UInt)0
                if ext.method.type_params.count() == (UInt)1 and fallback_arg_index < args.count() then {
                    let first_arg_type = resolve_parameterized_type(mono, args.at(fallback_arg_index).expr_type)
                    if not has_generic_parameter(first_arg_type) then {
                        method_type_args.push(box(first_arg_type))
                        continue
                    }
                }
                return [[Type ref]List]Option.None()
            },
        }
    }

    return [[Type ref]List]Option.Some(method_type_args)
}

// Try to bind a GenericMethodCall's method symbol to a concrete extension method.
// This mirrors the Swift compiler's lookupConcreteMethodSymbol behavior during
// resolveTypesInExpression: when the receiver type is a concrete type from a
// generic instantiation, we trigger extension method instantiation on-demand.
public let try_bind_generic_method_call(
    mono Monomorphizer ref,
    receiver_type Type,
    method Symbol,
    args [TypedExpr ref]List,
    expected_return_type Type,
) Symbol = {
    let method_name = method.name
    // Skip if receiver still has generic parameters
    if has_generic_parameter(receiver_type) then { return method }

    // Determine the template name and type args for extension method lookup
    let mut template_name_opt = [String]Option.None()
    let mut type_args = [Type ref]List.new()
    let mut concrete_receiver_type = receiver_type
    let mut autoderef_fallback = [Type]Option.None()

    when receiver_type in {
        .GenericStruct(template_name, args) then {
            template_name_opt = [String]Option.Some(template_name)
            let mut resolved_args = [Type ref]List.new()
            for a in args then {
                let resolved_arg = resolve_parameterized_type(mono, a.val)
                resolved_args.push(box(resolved_arg))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            for canonical_arg in canonical_args then {
                type_args.push(box(canonical_arg.val))
            }
            when mono.storage.input.generic_templates.lookup_struct(template_name) in {
                .Some(struct_template) then {
                    concrete_receiver_type = mono.instantiate_struct_impl(struct_template, canonical_args)
                },
                .None() then {},
            }
        },
        .GenericEnum(template_name, args) then {
            template_name_opt = [String]Option.Some(template_name)
            let mut resolved_args = [Type ref]List.new()
            for a in args then {
                let resolved_arg = resolve_parameterized_type(mono, a.val)
                resolved_args.push(box(resolved_arg))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            for canonical_arg in canonical_args then {
                type_args.push(box(canonical_arg.val))
            }
            when mono.storage.input.generic_templates.lookup_enum(template_name) in {
                .Some(enum_template) then {
                    concrete_receiver_type = mono.instantiate_enum_impl(enum_template, canonical_args)
                },
                .None() then {},
            }
        },
        .StructureType(def_id) then {
            let name = when mono.storage.def_id_map.get_name(def_id) in {
                .Some(n) then n,
                .None() then "",
            }
            when mono.storage.layout_to_template_info.get(name) in {
                .Some(info) then {
                    template_name_opt = [String]Option.Some(info.base_name)
                    for a in info.args then { type_args.push(box(a.val)) }
                },
                .None() then {
                    // Prefer DefId generic-instantiation metadata when available.
                    when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then {
                            template_name_opt = [String]Option.Some(template_name)
                            when mono.storage.def_id_map.get_type_arguments(def_id) in {
                                .Some(actual_args) then {
                                    for a in actual_args then {
                                        type_args.push(box(a))
                                    }
                                },
                                .None() then {},
                            }
                        },
                        .None() then {
                            // Non-generic struct — use the name directly.
                            template_name_opt = [String]Option.Some(name)
                        },
                    }
                },
            }
        },
        .EnumType(def_id) then {
            let name = when mono.storage.def_id_map.get_name(def_id) in {
                .Some(n) then n,
                .None() then "",
            }
            when mono.storage.layout_to_template_info.get(name) in {
                .Some(info) then {
                    template_name_opt = [String]Option.Some(info.base_name)
                    for a in info.args then { type_args.push(box(a.val)) }
                },
                .None() then {
                    when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then {
                            template_name_opt = [String]Option.Some(template_name)
                            when mono.storage.def_id_map.get_type_arguments(def_id) in {
                                .Some(actual_args) then {
                                    for a in actual_args then {
                                        type_args.push(box(a))
                                    }
                                },
                                .None() then {},
                            }
                        },
                        .None() then {
                            template_name_opt = [String]Option.Some(name)
                        },
                    }
                },
            }
        },
        .ReferenceType(inner) then {
            template_name_opt = [String]Option.Some("T ref")
            type_args.push(box(inner.val))
            autoderef_fallback = [Type]Option.Some(inner.val)
        },
        .PointerType(inner) then {
            template_name_opt = [String]Option.Some("T ptr")
            type_args.push(box(inner.val))
        },
        .WeakReferenceType(inner) then {
            template_name_opt = [String]Option.Some("T weakref")
            type_args.push(box(inner.val))
        },
        .IntType() then { template_name_opt = [String]Option.Some("Int") },
        .Int8Type() then { template_name_opt = [String]Option.Some("Int8") },
        .Int16Type() then { template_name_opt = [String]Option.Some("Int16") },
        .Int32Type() then { template_name_opt = [String]Option.Some("Int32") },
        .Int64Type() then { template_name_opt = [String]Option.Some("Int64") },
        .UIntType() then { template_name_opt = [String]Option.Some("UInt") },
        .UInt8Type() then { template_name_opt = [String]Option.Some("UInt8") },
        .UInt16Type() then { template_name_opt = [String]Option.Some("UInt16") },
        .UInt32Type() then { template_name_opt = [String]Option.Some("UInt32") },
        .UInt64Type() then { template_name_opt = [String]Option.Some("UInt64") },
        .Float32Type() then { template_name_opt = [String]Option.Some("Float32") },
        .Float64Type() then { template_name_opt = [String]Option.Some("Float64") },
        .BoolType() then { template_name_opt = [String]Option.Some("Bool") },
        _ then {},
    }

    let template_name = when template_name_opt in {
        .Some(n) then n,
        .None() then {
            return when autoderef_fallback in {
                .Some(inner) then try_bind_generic_method_call(mono, inner, method, args, expected_return_type),
                .None() then method,
            }
        },
    }

    let type_key = when concrete_receiver_type in {
        .StructureType(def_id) then mono.storage.def_id_map.get_name(def_id) or else layout_key(concrete_receiver_type),
        .EnumType(def_id) then mono.storage.def_id_map.get_name(def_id) or else layout_key(concrete_receiver_type),
        _ then layout_key(concrete_receiver_type),
    }
    // First try to infer concrete method type arguments and instantiate the
    // extension method on-demand. Generic methods must bind through their
    // concrete method-arg key before falling back to any plain-name cache.
    when mono.storage.input.generic_templates.lookup_extension_methods(template_name) in {
        .Some(ext_templates) then {
            when select_extension_template(
                ext_templates,
                method_name,
                [UInt]Option.None(),
                [UInt]Option.None(),
            ) in {
                .Some(ext) then {
                    let effective_ext = when ext.checked_body in {
                        .Some(_) then ext,
                        .None() then when ext.conformance_trait_name in {
                            .Some(trait_name) then when mono.storage.input.generic_templates.lookup_extension_methods(trait_name) in {
                                .Some(tool_templates) then when select_extension_template(
                                    tool_templates,
                                    method_name,
                                    [UInt]Option.Some(ext.method.type_params.count()),
                                    [UInt]Option.Some(ext.conformance_trait_args.count()),
                                ) in {
                                    .Some(tool_template) then GenericExtensionMethodTemplate(
                                        ext.type_params,
                                        ext.method,
                                        ext.conformance_trait_name,
                                        ext.conformance_trait_args,
                                        tool_template.checked_body,
                                        ext.checked_parameters,
                                        ext.checked_return_type,
                                    ),
                                    .None() then ext,
                                },
                                .None() then ext,
                            },
                            .None() then ext,
                        },
                    }
                    when infer_extension_method_type_args(mono, effective_ext, receiver_type, args, expected_return_type) in {
                        .Some(method_type_args) then {
                            let concrete_lookup_key = make_extension_method_lookup_key(mono, type_key, method_name, method_type_args)
                            when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                .Some(def_id) then {
                                    let mut stale_cached_intrinsic = false
                                    let mut found_materialized_decl = false
                                    when effective_ext.checked_body in {
                                        .Some(_) then {
                                            let mut found_generated_node = false
                                            let mut node_index UInt = 0
                                            while node_index < mono.storage.generated_node_def_ids.count() then {
                                                when mono.storage.generated_node_def_ids.at(node_index) in {
                                                    .Some(node_def_id) then {
                                                        if node_def_id.id == def_id.id then {
                                                            found_generated_node = true
                                                            when mono.storage.generated_nodes.at(node_index) in {
                                                                .IntrinsicFunctionDecl(_, _, _, _, _) then {
                                                                    stale_cached_intrinsic = true
                                                                },
                                                                _ then {},
                                                            }
                                                            break
                                                        }
                                                    },
                                                    .None() then {},
                                                }
                                                node_index += 1
                                            }
                                            if not found_generated_node then {
                                                for node in mono.storage.generated_nodes then {
                                                    when node in {
                                                        .GivenDecl(target_type, members, _) then {
                                                            for member in members then {
                                                                if member.def_id.id == def_id.id then {
                                                                    let mut member_is_concrete = not has_generic_parameter(target_type) and not has_generic_parameter(member.return_type)
                                                                    for param in member.params then {
                                                                        if has_generic_parameter(param.param_type) then {
                                                                            member_is_concrete = false
                                                                            break
                                                                        }
                                                                    }
                                                                    if member_is_concrete then {
                                                                        found_materialized_decl = true
                                                                    } else {
                                                                        stale_cached_intrinsic = true
                                                                    }
                                                                    break
                                                                }
                                                            }
                                                        },
                                                        .GivenTraitDecl(target_type, _, _, members, _) then {
                                                            for member in members then {
                                                                if member.def_id.id == def_id.id then {
                                                                    let mut member_is_concrete = not has_generic_parameter(target_type) and not has_generic_parameter(member.return_type)
                                                                    for param in member.params then {
                                                                        if has_generic_parameter(param.param_type) then {
                                                                            member_is_concrete = false
                                                                            break
                                                                        }
                                                                    }
                                                                    if member_is_concrete then {
                                                                        found_materialized_decl = true
                                                                    } else {
                                                                        stale_cached_intrinsic = true
                                                                    }
                                                                    break
                                                                }
                                                            }
                                                        },
                                                        .IntrinsicGivenDecl(target_type, members, _) then {
                                                            for member in members then {
                                                                if member.def_id.id == def_id.id then {
                                                                    let mut member_is_concrete = not has_generic_parameter(target_type) and not has_generic_parameter(member.return_type)
                                                                    for param in member.params then {
                                                                        if has_generic_parameter(param.param_type) then {
                                                                            member_is_concrete = false
                                                                            break
                                                                        }
                                                                    }
                                                                    if member_is_concrete then {
                                                                        found_materialized_decl = true
                                                                    } else {
                                                                        stale_cached_intrinsic = true
                                                                    }
                                                                    break
                                                                }
                                                            }
                                                        },
                                                        _ then {},
                                                    }
                                                    if found_materialized_decl then { break }
                                                }
                                            }
                                            if not found_generated_node then {
                                                if not found_materialized_decl then {
                                                    stale_cached_intrinsic = true
                                                }
                                            }
                                        },
                                        .None() then {},
                                    }
                                    if not stale_cached_intrinsic then {
                                        let bound_return_type = when mono.storage.def_id_map.get_signature(def_id) in {
                                            .Some(sig) then sig.return_type,
                                            .None() then method.symbol_type,
                                        }
                                        return Symbol(def_id, method_name, bound_return_type, method.kind)
                                    }
                                },
                                .None() then {},
                            }
                            let should_defer_trait_placeholder = when effective_ext.checked_body in {
                                .Some(_) then false,
                                .None() then when effective_ext.conformance_trait_name in {
                                    .Some(_) then true,
                                    .None() then false,
                                },
                            }
                            if should_defer_trait_placeholder then {
                                when effective_ext.conformance_trait_name in {
                                    .Some(trait_name) then {
                                        when mono.storage.input.generic_templates.lookup_extension_methods(trait_name) in {
                                            .Some(tool_templates) then {
                                                when select_extension_template(
                                                    tool_templates,
                                                    method_name,
                                                    [UInt]Option.Some(method_type_args.count()),
                                                    [UInt]Option.Some(effective_ext.conformance_trait_args.count()),
                                                ) in {
                                                    .Some(tool_template) then {
                                                        let patched_template = GenericExtensionMethodTemplate(
                                                            effective_ext.type_params,
                                                            effective_ext.method,
                                                            effective_ext.conformance_trait_name,
                                                            effective_ext.conformance_trait_args,
                                                            tool_template.checked_body,
                                                            effective_ext.checked_parameters,
                                                            effective_ext.checked_return_type,
                                                        )
                                                        let sym = mono.instantiate_extension_method_impl(
                                                            concrete_receiver_type,
                                                            template_name,
                                                            patched_template,
                                                            type_args,
                                                            method_type_args,
                                                        )
                                                        let bound_return_type = when mono.storage.def_id_map.get_signature(sym.def_id) in {
                                                            .Some(sig) then sig.return_type,
                                                            .None() then sym.symbol_type,
                                                        }
                                                        return Symbol(sym.def_id, method_name, bound_return_type, method.kind)
                                                    },
                                                    .None() then {},
                                                }
                                            },
                                            .None() then {},
                                        }
                                    },
                                    .None() then {},
                                }
                                instantiate_trait_placeholder_method(mono, concrete_receiver_type, method_name, method_type_args)
                                when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                    .Some(def_id) then {
                                        let bound_return_type = when mono.storage.def_id_map.get_signature(def_id) in {
                                            .Some(sig) then sig.return_type,
                                            .None() then method.symbol_type,
                                        }
                                        return Symbol(def_id, method_name, bound_return_type, method.kind)
                                    },
                                    .None() then {},
                                }
                            }
                            let sym = mono.instantiate_extension_method_impl(
                                concrete_receiver_type,
                                template_name,
                                effective_ext,
                                type_args,
                                method_type_args,
                            )
                            // Return the instantiated symbol with updated info
                            let bound_return_type = when mono.storage.def_id_map.get_signature(sym.def_id) in {
                                .Some(sig) then sig.return_type,
                                .None() then sym.symbol_type,
                            }
                            return Symbol(sym.def_id, method_name, bound_return_type, method.kind)
                        },
                        .None() then {},
                    }
                },
                .None() then {},
            }
        },
        .None() then {},
    }

    let mut trait_method_type_args = [Type ref]List.new()
    if not args.is_empty() then {
        let first_arg_type = resolve_parameterized_type(mono, args.at((UInt)0).expr_type)
        if not has_generic_parameter(first_arg_type) then {
            trait_method_type_args.push(box(first_arg_type))
        }
    }
    instantiate_trait_placeholder_method(mono, concrete_receiver_type, method_name, trait_method_type_args)

    if not trait_method_type_args.is_empty() then {
        let typed_lookup_key = make_extension_method_lookup_key(mono, type_key, method_name, trait_method_type_args)
        when mono.storage.extension_method_def_ids.get(typed_lookup_key) in {
            .Some(def_id) then {
                let bound_return_type = when mono.storage.def_id_map.get_signature(def_id) in {
                    .Some(sig) then sig.return_type,
                    .None() then method.symbol_type,
                }
                return Symbol(def_id, method_name, bound_return_type, method.kind)
            },
            .None() then {},
        }
    }

    let plain_lookup_key = make_extension_method_lookup_key(mono, type_key, method_name, [Type ref]List.new())
    when mono.storage.extension_method_def_ids.get(plain_lookup_key) in {
        .Some(def_id) then {
            let bound_return_type = when mono.storage.def_id_map.get_signature(def_id) in {
                .Some(sig) then sig.return_type,
                .None() then method.symbol_type,
            }
            return Symbol(def_id, method_name, bound_return_type, method.kind)
        },
        .None() then {},
    }

    return when autoderef_fallback in {
        .Some(inner) then try_bind_generic_method_call(mono, inner, method, args, expected_return_type),
        .None() then method,
    }
}

private let collect_generic_bindings_from_type(
    mono Monomorphizer ref,
    pattern Type,
    actual Type,
    bindings [String, Type]Dict ref,
) Void = {
    when pattern in {
        .GenericParameter(name) then {
            bindings.insert(name, actual)
        },
        .ReferenceType(pattern_inner) then {
            when actual in {
                .ReferenceType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .WeakReferenceType(pattern_inner) then {
            when actual in {
                .WeakReferenceType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .PointerType(pattern_inner) then {
            when actual in {
                .PointerType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .FunctionType(pattern_params, pattern_return) then {
            when actual in {
                .FunctionType(actual_params, actual_return) then {
                    let mut i UInt = 0
                    let max_count = if pattern_params.count() < actual_params.count() then pattern_params.count() else actual_params.count()
                    while i < max_count then {
                        collect_generic_bindings_from_type(mono, pattern_params.at(i).val, actual_params.at(i).val, bindings)
                        i += 1
                    }
                    collect_generic_bindings_from_type(mono, pattern_return.val, actual_return.val, bindings)
                },
                _ then {},
            }
        },
        .GenericStruct(pattern_template, pattern_args) then {
            when actual in {
                .GenericStruct(actual_template, actual_args) then {
                    if pattern_template == actual_template then {
                        let mut i UInt = 0
                        let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                        while i < max_count then {
                            collect_generic_bindings_from_type(mono, pattern_args.at(i).val, actual_args.at(i).val, bindings)
                            i += 1
                        }
                    }
                },
                .StructureType(def_id) then {
                    let actual_template_opt = when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then [String]Option.Some(template_name),
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.def_id_map.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then [String]Option.Some(info.base_name),
                            .None() then [String]Option.None(),
                        },
                    }
                    let actual_args_opt = when mono.storage.def_id_map.get_type_arguments(def_id) in {
                        .Some(actual_type_args) then {
                            let mut arg_refs = [Type ref]List.new()
                            for actual_type_arg in actual_type_args then {
                                arg_refs.push(box(actual_type_arg))
                            }
                            yield [[Type ref]List]Option.Some(arg_refs)
                        },
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.def_id_map.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then {
                                let mut arg_refs = [Type ref]List.new()
                                for actual_type_arg in info.args then {
                                    arg_refs.push(box(actual_type_arg.val))
                                }
                                yield [[Type ref]List]Option.Some(arg_refs)
                            },
                            .None() then [[Type ref]List]Option.None(),
                        },
                    }
                    when actual_template_opt in {
                        .Some(actual_template) then when actual_args_opt in {
                            .Some(actual_args) then {
                                if pattern_template == actual_template then {
                                    let mut i UInt = 0
                                    let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                                    while i < max_count then {
                                        collect_generic_bindings_from_type(mono, pattern_args.at(i).val, actual_args.at(i).val, bindings)
                                        i += 1
                                    }
                                }
                            },
                            .None() then {},
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }
        },
        .GenericEnum(pattern_template, pattern_args) then {
            when actual in {
                .GenericEnum(actual_template, actual_args) then {
                    if pattern_template == actual_template then {
                        let mut i UInt = 0
                        let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                        while i < max_count then {
                            collect_generic_bindings_from_type(mono, pattern_args.at(i).val, actual_args.at(i).val, bindings)
                            i += 1
                        }
                    }
                },
                .EnumType(def_id) then {
                    let actual_template_opt = when mono.storage.def_id_map.get_template_name(def_id) in {
                        .Some(template_name) then [String]Option.Some(template_name),
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.def_id_map.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then [String]Option.Some(info.base_name),
                            .None() then [String]Option.None(),
                        },
                    }
                    let actual_args_opt = when mono.storage.def_id_map.get_type_arguments(def_id) in {
                        .Some(actual_type_args) then {
                            let mut arg_refs = [Type ref]List.new()
                            for actual_type_arg in actual_type_args then {
                                arg_refs.push(box(actual_type_arg))
                            }
                            yield [[Type ref]List]Option.Some(arg_refs)
                        },
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.def_id_map.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then {
                                let mut arg_refs = [Type ref]List.new()
                                for actual_type_arg in info.args then {
                                    arg_refs.push(box(actual_type_arg.val))
                                }
                                yield [[Type ref]List]Option.Some(arg_refs)
                            },
                            .None() then [[Type ref]List]Option.None(),
                        },
                    }
                    when actual_template_opt in {
                        .Some(actual_template) then when actual_args_opt in {
                            .Some(actual_args) then {
                                if pattern_template == actual_template then {
                                    let mut i UInt = 0
                                    let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                                    while i < max_count then {
                                        collect_generic_bindings_from_type(mono, pattern_args.at(i).val, actual_args.at(i).val, bindings)
                                        i += 1
                                    }
                                }
                            },
                            .None() then {},
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }
        },
        _ then {},
    }
}

// ── StaticMethodCall resolution helpers ───────────────────────────────────────

// Resolve a StaticMethodCall to a Call(Variable(...)) expression, matching the
// Swift compiler's behavior. This is the main entry point called from resolve_expr_kind.
private let resolve_static_method_call_to_call(
    mono Monomorphizer ref,
    expr TypedExpr ref,
    receiver_type Type,
    method Symbol ref,
    args [TypedExpr ref]List,
) TypedExprKind ref = {
    let new_receiver_type = resolve_parameterized_type(mono, receiver_type)
    let new_method = resolve_symbol_type(mono, method)
    let mut new_args = [TypedExpr ref]List.new()
    for arg in args then {
        new_args.push(resolve_types_in_expression(mono, arg))
    }

    // If the resolved base type still contains generic parameters, keep as StaticMethodCall.
    if has_generic_parameter(new_receiver_type) then {
        return box(TypedExprKind.StaticMethodCall(new_receiver_type, box(new_method), new_args))
    }

    // Determine template_name and emitted_type_scope_name from the resolved base type.
    let template_name = resolve_static_call_template_name(mono, new_receiver_type)
    // Keep the logical method name through monomorphization; concrete DefId
    // resolution happens separately via lookup_concrete_method_for_static_call.
    let method_name = new_method.name

    let mut resolved_return_type = resolve_parameterized_type(mono, expr.expr_type)

    // Prefer already-registered concrete methods first. This mirrors Swift's
    // direct extensionMethodDefIds lookup and prevents trait-tool free
    // functions like Std.Math.sqrt(T) from re-binding T.sqrt(...) back to the
    // currently-instantiating specialization itself.
    let direct_concrete_sym = lookup_concrete_method_for_static_call(mono, new_receiver_type, method_name)
    let concrete_sym = when direct_concrete_sym in {
        .Some(sym) then [Symbol]Option.Some(sym),
        .None() then enqueue_extension_method_for_static_call(mono, new_receiver_type, method_name, template_name, new_args, resolved_return_type),
    }

    // If the return type is still Unknown/Void, try to recover from the method signature.
    // This happens when the type checker couldn't resolve the return type at call sites
    // (e.g. recursive calls within a given block).
    when resolved_return_type in {
        .Unknown() then {
            // First try from concrete_sym's signature
            when concrete_sym in {
                .Some(sym) then {
                    when mono.storage.def_id_map.get_signature(sym.def_id) in {
                        .Some(sig) then {
                            resolved_return_type = resolve_parameterized_type(mono, sig.return_type)
                        },
                        .None() then {},
                    }
                },
                .None() then {},
            }
        },
        _ then {},
    }

    // Build the function type for the callee.
    let mut param_types = [Type ref]List.new()
    for a in new_args then {
        param_types.push(box(a.val.expr_type))
    }
    let func_type = Type.FunctionType(param_types, box(resolved_return_type))

    // If we did not resolve a concrete symbol, keep StaticMethodCall unchanged.
    let callee_symbol = when concrete_sym in {
        .Some(sym) then Symbol(sym.def_id, sym.name, func_type, SymbolKind.Function()),
        .None() then {
            return box(TypedExprKind.StaticMethodCall(new_receiver_type, box(new_method), new_args))
        },
    }
    let callee_expr = box(TypedExpr(box(TypedExprKind.Variable(box(callee_symbol))), func_type))
    return box(TypedExprKind.Call(callee_expr, new_args))
}

// Determine the template name for extension method lookup from a resolved type.
// For StructureType/EnumType, uses the template name if available (for generic
// instantiations), otherwise the concrete name. For built-in types, uses the
// type name directly (e.g. "String", "Int").
private let resolve_static_call_template_name(mono Monomorphizer ref, t Type) String = {
    return when t in {
        .StructureType(def_id) then {
            let name = when mono.storage.def_id_map.get_name(def_id) in {
                .Some(n) then n,
                .None() then type_to_string(t),
            }
            yield when mono.storage.layout_to_template_info.get(name) in {
                .Some(info) then info.base_name,
                .None() then when mono.storage.def_id_map.get_template_name(def_id) in {
                    .Some(tn) then tn,
                    .None() then name,
                },
            }
        },
        .EnumType(def_id) then {
            let name = when mono.storage.def_id_map.get_name(def_id) in {
                .Some(n) then n,
                .None() then type_to_string(t),
            }
            yield when mono.storage.layout_to_template_info.get(name) in {
                .Some(info) then info.base_name,
                .None() then when mono.storage.def_id_map.get_template_name(def_id) in {
                    .Some(tn) then tn,
                    .None() then name,
                },
            }
        },
        .GenericStruct(name, _) then name,
        .GenericEnum(name, _) then name,
        .OpaqueType(def_id) then {
            // Resolve opaque types to their underlying type's template name
            yield when mono.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped_type) then resolve_static_call_template_name(mono, mapped_type),
                .None() then when mono.storage.def_id_map.get_name(def_id) in {
                    .Some(n) then n,
                    .None() then type_to_string(t),
                },
            }
        },
        .IntType() then "Int",
        .Int8Type() then "Int8",
        .Int16Type() then "Int16",
        .Int32Type() then "Int32",
        .Int64Type() then "Int64",
        .UIntType() then "UInt",
        .UInt8Type() then "UInt8",
        .UInt16Type() then "UInt16",
        .UInt32Type() then "UInt32",
        .UInt64Type() then "UInt64",
        .Float32Type() then "Float32",
        .Float64Type() then "Float64",
        .BoolType() then "Bool",
        _ then type_to_string(t),
    }
}

// Look up a concrete method symbol for a static method call.
// Checks extension_methods cache.
// If found, returns the symbol. Otherwise returns None.
private let lookup_concrete_method_for_static_call(
    mono Monomorphizer ref,
    base_type Type,
    method_name String,
) [Symbol]Option = {
    let resolved_base_type = when base_type in {
        .OpaqueType(def_id) then when mono.storage.def_id_map.lookup_type(def_id) in {
            .Some(underlying) then resolve_parameterized_type(mono, underlying),
            .None() then resolve_parameterized_type(mono, base_type),
        },
        _ then resolve_parameterized_type(mono, base_type),
    }
    let mut lookup_type_names = [String]List.new()
    let base_layout_name = layout_key(base_type)
    if base_layout_name <> "" then {
        lookup_type_names.push(base_layout_name)
    }
    let resolved_layout_name = layout_key(resolved_base_type)
    if resolved_layout_name <> "" and not lookup_type_names.contains(resolved_layout_name) then {
        lookup_type_names.push(resolved_layout_name)
    }

    let base_display_name = mono.storage.def_id_map.type_display_name(base_type)
    if base_display_name <> "" and not lookup_type_names.contains(base_display_name) then {
        lookup_type_names.push(base_display_name)
    }
    let resolved_display_name = mono.storage.def_id_map.type_display_name(resolved_base_type)
    if resolved_display_name <> "" and not lookup_type_names.contains(resolved_display_name) then {
        lookup_type_names.push(resolved_display_name)
    }

    when base_type in {
        .OpaqueType(def_id) then {
            let opaque_name = mono.storage.def_id_map.get_name(def_id) or else ""
            if opaque_name <> "" and not lookup_type_names.contains(opaque_name) then {
                lookup_type_names.push(opaque_name)
            }
        },
        _ then {},
    }

    when resolved_base_type in {
        .StructureType(def_id) then {
            let concrete_name = mono.storage.def_id_map.get_name(def_id) or else ""
            if concrete_name <> "" and not lookup_type_names.contains(concrete_name) then {
                lookup_type_names.push(concrete_name)
            }
        },
        .EnumType(def_id) then {
            let concrete_name = mono.storage.def_id_map.get_name(def_id) or else ""
            if concrete_name <> "" and not lookup_type_names.contains(concrete_name) then {
                lookup_type_names.push(concrete_name)
            }
        },
        _ then {},
    }

    let declared_method_symbol = when find_declared_static_receiver_method(mono, base_type, method_name) in {
        .Some(symbol) then [Symbol]Option.Some(symbol),
        .None() then find_declared_static_receiver_method(mono, resolved_base_type, method_name),
    }
    when declared_method_symbol in {
        .Some(symbol) then { return declared_method_symbol },
        .None() then {},
    }

    // First prefer direct concrete method registrations, mirroring Swift's
    // extensionMethodDefIds lookup so non-generic given methods win over any
    // currently-instantiating trait-tool specializations.
    for type_name in lookup_type_names then {
        let key = "\(type_name).\(method_name)"
        when mono.storage.extension_method_def_ids.get(key) in {
            .Some(def_id) then {
                if not is_materialized_method_def_id(mono, def_id) then {
                    continue
                }
                let symbol_type = when mono.storage.def_id_map.get_signature(def_id) in {
                    .Some(sig) then {
                        let mut param_types = [Type ref]List.new()
                        for param_type in sig.param_types then {
                            param_types.push(box(param_type))
                        }
                        yield Type.FunctionType(param_types, box(sig.return_type))
                    },
                    .None() then Type.Unknown(),
                }
                let symbol_name = mono.storage.def_id_map.get_name(def_id) or else method_name
                return [Symbol]Option.Some(Symbol(def_id, symbol_name, symbol_type, SymbolKind.Function()))
            },
            .None() then {},
        }
    }

    // Check extension_methods map first.
    for type_name in lookup_type_names then {
        when mono.storage.extension_methods.get(type_name) in {
            .Some(method_map) then {
                when method_map.get(method_name) in {
                    .Some(entry) then {
                        return [Symbol]Option.Some(entry.symbol)
                    },
                    .None() then {},
                }
            },
            .None() then {},
        }
    }

    return [Symbol]Option.None()
}

private let find_declared_static_receiver_method(
    mono Monomorphizer ref,
    base_type Type,
    method_name String,
) [Symbol]Option = {
    let concrete_base_type = resolve_parameterized_type(mono, base_type)
    let base_key = layout_key(concrete_base_type)

    for node in mono.storage.generated_nodes then {
        when node in {
            .GivenDecl(target_type, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_key, method_name) in {
                    .Some(symbol) then { return [Symbol]Option.Some(symbol) },
                    .None() then {},
                }
            },
            .GivenTraitDecl(target_type, _, _, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_key, method_name) in {
                    .Some(symbol) then { return [Symbol]Option.Some(symbol) },
                    .None() then {},
                }
            },
            .IntrinsicGivenDecl(target_type, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_key, method_name) in {
                    .Some(symbol) then { return [Symbol]Option.Some(symbol) },
                    .None() then {},
                }
            },
            _ then {},
        }
    }

    return [Symbol]Option.None()
}

private let is_materialized_method_def_id(mono Monomorphizer ref, def_id DefId) Bool = {
    let mut node_index UInt = 0
    while node_index < mono.storage.generated_node_def_ids.count() then {
        when mono.storage.generated_node_def_ids.at(node_index) in {
            .Some(node_def_id) then {
                if node_def_id.id == def_id.id then {
                    return true
                }
            },
            .None() then {},
        }
        node_index += 1
    }

    for node in mono.storage.generated_nodes then {
        when node in {
            .GivenDecl(_, members, _) then {
                for member in members then {
                    if member.def_id.id == def_id.id then {
                        return true
                    }
                }
            },
            .GivenTraitDecl(_, _, _, members, _) then {
                for member in members then {
                    if member.def_id.id == def_id.id then {
                        return true
                    }
                }
            },
            .IntrinsicGivenDecl(_, members, _) then {
                for member in members then {
                    if member.def_id.id == def_id.id then {
                        return true
                    }
                }
            },
            _ then {},
        }
    }

    return false
}

private let match_declared_static_receiver_member(
    mono Monomorphizer ref,
    target_type Type,
    members [TypedGivenMember]List,
    base_key String,
    method_name String,
) [Symbol]Option = {
    let resolved_target_type = when target_type in {
        .OpaqueType(def_id) then when mono.storage.def_id_map.lookup_type(def_id) in {
            .Some(underlying) then underlying,
            .None() then target_type,
        },
        _ then target_type,
    }
    let target_key = layout_key(resolve_parameterized_type(mono, target_type))
    let resolved_target_key = layout_key(resolve_parameterized_type(mono, resolved_target_type))
    if target_key <> base_key and resolved_target_key <> base_key then {
        return [Symbol]Option.None()
    }
    for member in members then {
        if member.name <> method_name then {
            continue
        }
        let mut member_is_concrete = not has_generic_parameter(resolved_target_type) and not has_generic_parameter(member.return_type)
        for param in member.params then {
            if has_generic_parameter(param.param_type) then {
                member_is_concrete = false
                break
            }
        }
        if not member_is_concrete then {
            continue
        }
        let symbol_type = when mono.storage.def_id_map.get_signature(member.def_id) in {
            .Some(sig) then {
                let mut param_types = [Type ref]List.new()
                for param_type in sig.param_types then {
                    param_types.push(box(param_type))
                }
                yield Type.FunctionType(param_types, box(sig.return_type))
            },
            .None() then Type.Unknown(),
        }
        let symbol_name = mono.storage.def_id_map.get_name(member.def_id) or else member.name
        return [Symbol]Option.Some(Symbol(member.def_id, symbol_name, symbol_type, SymbolKind.Function()))
    }
    return [Symbol]Option.None()
}

// Enqueue an extension method instantiation request for a static method call
// if the extension method template exists in the registry.
private let enqueue_extension_method_for_static_call(
    mono Monomorphizer ref,
    base_type Type,
    method_name String,
    template_name String,
    args [TypedExpr ref]List,
    expected_return_type Type,
) [Symbol]Option = {
    let type_key = when base_type in {
        .StructureType(def_id) then mono.storage.def_id_map.get_name(def_id) or else layout_key(base_type),
        .EnumType(def_id) then mono.storage.def_id_map.get_name(def_id) or else layout_key(base_type),
        _ then layout_key(base_type),
    }

    // Look up extension method templates from the registry.
    when mono.storage.input.generic_templates.lookup_extension_methods(template_name) in {
        .Some(ext_templates) then {
            // Determine type_args from the base type.
            let mut type_args = [Type ref]List.new()
            when base_type in {
                .GenericStruct(_, args) then {
                    for a in args then { type_args.push(box(a.val)) }
                },
                .GenericEnum(_, args) then {
                    for a in args then { type_args.push(box(a.val)) }
                },
                .StructureType(def_id) then {
                    when mono.storage.layout_to_template_info.get(
                        when mono.storage.def_id_map.get_name(def_id) in {
                            .Some(n) then n,
                            .None() then "",
                        }
                    ) in {
                        .Some(info) then {
                            for a in info.args then { type_args.push(box(a.val)) }
                        },
                        .None() then {},
                    }
                },
                .EnumType(def_id) then {
                    when mono.storage.layout_to_template_info.get(
                        when mono.storage.def_id_map.get_name(def_id) in {
                            .Some(n) then n,
                            .None() then "",
                        }
                    ) in {
                        .Some(info) then {
                            for a in info.args then { type_args.push(box(a.val)) }
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }

            // Find a template whose method-level generic args can be fully inferred
            // from this static call site, preferring checked templates first.
            let mut pass = (UInt)0
            while pass < (UInt)2 then {
                for ext in ext_templates then {
                    if ext.method.name <> method_name then { continue }
                    if ext.type_params.count() <> type_args.count() then { continue }
                    if pass == (UInt)0 then {
                        when ext.checked_body in {
                            .Some(_) then {},
                            .None() then { continue },
                        }
                    }

                    let mut inferred_method_type_args_opt = infer_extension_method_type_args(mono, ext, base_type, args, expected_return_type)
                    when inferred_method_type_args_opt in {
                        .None() then {
                            // Keep strict inference: method type args must be derivable from
                            // the structured static-call argument list as-is.
                        },
                        .Some(_) then {},
                    }

                    when inferred_method_type_args_opt in {
                        .Some(method_type_args) then {
                            let concrete_lookup_key = make_extension_method_lookup_key(mono, type_key, method_name, method_type_args)
                            when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                .Some(def_id) then {
                                    let concrete_name = when mono.storage.def_id_map.get_name(def_id) in {
                                        .Some(name) then name,
                                        .None() then method_name,
                                    }
                                    let bound_return_type = when mono.storage.def_id_map.get_signature(def_id) in {
                                        .Some(sig) then sig.return_type,
                                        .None() then expected_return_type,
                                    }
                                    return [Symbol]Option.Some(Symbol(def_id, concrete_name, bound_return_type, SymbolKind.Function()))
                                },
                                .None() then {},
                            }

                            let should_defer_trait_placeholder = when ext.checked_body in {
                                .Some(_) then false,
                                .None() then when ext.conformance_trait_name in {
                                    .Some(_) then true,
                                    .None() then false,
                                },
                            }
                            if should_defer_trait_placeholder then {
                                instantiate_trait_placeholder_method(mono, base_type, method_name, method_type_args)
                                when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                    .Some(def_id) then {
                                        let concrete_name = when mono.storage.def_id_map.get_name(def_id) in {
                                            .Some(name) then name,
                                            .None() then method_name,
                                        }
                                        let bound_return_type = when mono.storage.def_id_map.get_signature(def_id) in {
                                            .Some(sig) then sig.return_type,
                                            .None() then expected_return_type,
                                        }
                                        return [Symbol]Option.Some(Symbol(def_id, concrete_name, bound_return_type, SymbolKind.Function()))
                                    },
                                    .None() then {},
                                }
                            }

                            let sym = mono.instantiate_extension_method_impl(
                                base_type,
                                template_name,
                                ext,
                                type_args,
                                method_type_args,
                            )
                            return [Symbol]Option.Some(sym)
                        },
                        .None() then {},
                    }
                }
                pass += (UInt)1
            }
        },
        .None() then {},
    }
    return [Symbol]Option.None()
}

// ── resolve_types_in_global_node ──────────────────────────────────────────────

// Resolve parameterized types in all global nodes.
// Processes: function params, return types, struct fields, enum case params,
// and given declaration methods.
//
public let resolve_types_in_global_node(mono Monomorphizer ref, node TypedDecl) TypedDecl = {
    return when node in {
        // FunctionDecl: resolve param types, return type, and body.
        // Must resolve body types so no GenericStruct/GenericEnum reach CodeGen.
        .FunctionDecl(access, name, params, return_type, body, span) then {
            let mut resolved_params = [TypedParam]List.new()
            for p in params then {
                let resolved_type = resolve_parameterized_type(mono, p.param_type)
                resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type)
            let resolved_body = resolve_types_in_expression(mono, body)
            yield TypedDecl.FunctionDecl(access, name, resolved_params, resolved_return, resolved_body, span)
        },

        // IntrinsicFunctionDecl: resolve param types and return type.
        .IntrinsicFunctionDecl(access, name, params, return_type, span) then {
            let mut resolved_params = [TypedParam]List.new()
            for p in params then {
                let resolved_type = resolve_parameterized_type(mono, p.param_type)
                resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type)
            yield TypedDecl.IntrinsicFunctionDecl(access, name, resolved_params, resolved_return, span)
        },

        // ForeignFunctionDecl: resolve param types and return type.
        .ForeignFunctionDecl(access, name, params, return_type, span) then {
            let mut resolved_params = [TypedParam]List.new()
            for p in params then {
                let resolved_type = resolve_parameterized_type(mono, p.param_type)
                resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type)
            yield TypedDecl.ForeignFunctionDecl(access, name, resolved_params, resolved_return, span)
        },

        // TypeStructDecl: resolve field types.
        .TypeStructDecl(access, name, fields, span) then {
            let mut resolved_fields = [TypedField]List.new()
            for f in fields then {
                let resolved_type = resolve_parameterized_type(mono, f.field_type)
                collect_vtable_request_if_needed(mono, resolved_type)
                resolved_fields.push(TypedField(f.access, f.name, f.mutable, resolved_type, f.named))
            }
            yield TypedDecl.TypeStructDecl(access, name, resolved_fields, span)
        },

        // TypeEnumDecl: resolve case param types.
        .TypeEnumDecl(access, name, cases, span) then {
            let mut resolved_cases = [TypedEnumCase]List.new()
            for c in cases then {
                let mut resolved_fields = [TypedEnumCaseField]List.new()
                for f in c.fields then {
                    let resolved_type = resolve_parameterized_type(mono, f.field_type)
                    resolved_fields.push(TypedEnumCaseField(f.name, resolved_type, f.named))
                }
                resolved_cases.push(TypedEnumCase(c.name, resolved_fields))
            }
            yield TypedDecl.TypeEnumDecl(access, name, resolved_cases, span)
        },

        // GivenDecl: resolve method param types, return types, and bodies.
        .GivenDecl(target_type, members, span) then {
            let resolved_target = resolve_parameterized_type(mono, target_type)
            let mut resolved_members = [TypedGivenMember]List.new()
            for m in members then {
                let mut resolved_params = [TypedParam]List.new()
                for p in m.params then {
                    let resolved_type = resolve_parameterized_type(mono, p.param_type)
                        resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
                }
                let resolved_return = resolve_parameterized_type(mono, m.return_type)
                let resolved_body = when m.body in {
                    .Some(body) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, body)),
                    .None() then [TypedExpr ref]Option.None(),
                }
                resolved_members.push(TypedGivenMember(m.def_id, m.name, resolved_params, resolved_return, resolved_body))
            }
            yield TypedDecl.GivenDecl(resolved_target, resolved_members, span)
        },

        // GivenTraitDecl: resolve method param types, return types, and bodies.
        .GivenTraitDecl(target_type, trait_name, trait_args, members, span) then {
            let resolved_target = resolve_parameterized_type(mono, target_type)
            let mut resolved_trait_args = [Type]List.new()
            for trait_arg in trait_args then {
                resolved_trait_args.push(resolve_parameterized_type(mono, trait_arg))
            }
            let mut resolved_members = [TypedGivenMember]List.new()
            for m in members then {
                let mut resolved_params = [TypedParam]List.new()
                for p in m.params then {
                    let resolved_type = resolve_parameterized_type(mono, p.param_type)
                        resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
                }
                let resolved_return = resolve_parameterized_type(mono, m.return_type)
                let resolved_body = when m.body in {
                    .Some(body) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, body)),
                    .None() then [TypedExpr ref]Option.None(),
                }
                resolved_members.push(TypedGivenMember(m.def_id, m.name, resolved_params, resolved_return, resolved_body))
            }
            yield TypedDecl.GivenTraitDecl(resolved_target, trait_name, resolved_trait_args, resolved_members, span)
        },

        // IntrinsicGivenDecl: resolve method param types, return types, and bodies.
        .IntrinsicGivenDecl(target_type, members, span) then {
            let resolved_target = resolve_parameterized_type(mono, target_type)
            let mut resolved_members = [TypedGivenMember]List.new()
            for m in members then {
                let mut resolved_params = [TypedParam]List.new()
                for p in m.params then {
                    let resolved_type = resolve_parameterized_type(mono, p.param_type)
                        resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
                }
                let resolved_return = resolve_parameterized_type(mono, m.return_type)
                let resolved_body = when m.body in {
                    .Some(body) then [TypedExpr ref]Option.Some(resolve_types_in_expression(mono, body)),
                    .None() then [TypedExpr ref]Option.None(),
                }
                resolved_members.push(TypedGivenMember(m.def_id, m.name, resolved_params, resolved_return, resolved_body))
            }
            yield TypedDecl.IntrinsicGivenDecl(resolved_target, resolved_members, span)
        },

        // LetDecl: resolve decl type and initializer expression.
        .LetDecl(access, name, mutable, decl_type, initializer, span) then {
            let resolved_type = resolve_parameterized_type(mono, decl_type)
            let resolved_initializer = resolve_types_in_expression(mono, initializer)
            yield TypedDecl.LetDecl(access, name, mutable, resolved_type, resolved_initializer, span)
        },

        // ForeignLetDecl: resolve decl type.
        .ForeignLetDecl(access, name, mutable, decl_type, span) then {
            let resolved_type = resolve_parameterized_type(mono, decl_type)
            yield TypedDecl.ForeignLetDecl(access, name, mutable, resolved_type, span)
        },

        // TypeAliasDecl: resolve target type.
        .TypeAliasDecl(access, name, target, span) then {
            let resolved_target = resolve_parameterized_type(mono, target)
            yield TypedDecl.TypeAliasDecl(access, name, resolved_target, span)
        },

        // All other declarations: return unchanged.
        _ then node,
    }
}
