// Type resolution and substitution for the monomorphization phase.
// Implements substitute_type, resolve_parameterized_type, resolve_type_node,
// and resolve_types_in_global_node.
//
using std::os { .. }

// ── substitute_type ───────────────────────────────────────────────────────────

// Recursively traverse a Type, replacing GenericParameter with concrete types
// from the substitution map.
//
// Handles all Type variants:
//   - GenericParameter: look up in substitution map, return concrete type or keep as-is
//   - FunctionType: substitute param types and return type
//   - ReferenceType: substitute inner type
//   - PointerType: substitute inner type
//   - WeakReferenceType: substitute inner type
//   - GenericStruct: substitute each type arg
//   - GenericEnum: substitute each type arg
//   - All primitive/concrete types: return unchanged
//
public let substitute_type(mono ref Monomorphizer, t Type, substitution Dict[String, Type]) Type = {
    return when t in {
        // GenericParameter: look up in substitution map.
        .GenericParameter(name) then {
            yield when substitution.get(name) in {
                .Some(concrete) then concrete,
                .None() then t,
            }
        },

        // FunctionType: substitute param types and return type.
        .FunctionType(fn_params, return_type) then {
            let param_types = param_entry_types(fn_params)
            let mut new_param_types = List[ref Type].new()
            for pt in param_types then {
                let substituted = substitute_type(mono, pt.val, substitution)
                new_param_types.push(box(substituted))
            }
            let new_return_type = substitute_type(mono, return_type.val, substitution)
            yield make_function_type(new_param_types, new_return_type)
        },

        // ReferenceType: substitute inner type.
        .ReferenceType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.ReferenceType(box(new_inner))
        },
        .MutableReferenceType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.MutableReferenceType(box(new_inner))
        },

        // PointerType: substitute inner type.
        .PointerType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.PointerType(box(new_inner))
        },
        .MutablePointerType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.MutablePointerType(box(new_inner))
        },

        // WeakReferenceType: substitute inner type.
        .WeakReferenceType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.WeakReferenceType(box(new_inner))
        },
        .MutableWeakReferenceType(inner) then {
            let new_inner = substitute_type(mono, inner.val, substitution)
            yield Type.MutableWeakReferenceType(box(new_inner))
        },

        // GenericStruct: substitute each type arg.
        // If this generic name is a trait placeholder bound via __trait__:<name>,
        // rewrite it to the concrete receiver type.
        .GenericStruct(template, args) then {
            let trait_key = "__trait__:\(template)"
            yield when substitution.get(trait_key) in {
                .Some(concrete) then concrete,
                .None() then {
                    let mut new_args = List[ref Type].new()
                    for a in args then {
                        let substituted = substitute_type(mono, a.val, substitution)
                        new_args.push(box(substituted))
                    }
                    yield Type.GenericStruct(template, new_args)
                },
            }
        },

        // GenericEnum: substitute each type arg.
        // Mirror GenericStruct trait-placeholder rewrite for completeness.
        .GenericEnum(template, args) then {
            let trait_key = "__trait__:\(template)"
            yield when substitution.get(trait_key) in {
                .Some(concrete) then concrete,
                .None() then {
                    let mut new_args = List[ref Type].new()
                    for a in args then {
                        let substituted = substitute_type(mono, a.val, substitution)
                        new_args.push(box(substituted))
                    }
                    yield Type.GenericEnum(template, new_args)
                },
            }
        },

        // All primitive and concrete types: return unchanged.
        .TraitObject(trait_name, _) then {
            let trait_key = "__trait__:\(trait_name)"
            yield when substitution.get(trait_key) in {
                .Some(concrete) then concrete,
                .None() then t,
            }
        },
        _ then t,
    }
}

// ── resolve_parameterized_type ────────────────────────────────────────────────

// Resolve a parameterized type (GenericStruct/GenericEnum) to a concrete type.
//
// - GenericStruct: look up struct template and instantiate, return concrete StructureType
// - GenericEnum: look up enum template and instantiate, return concrete EnumType
// - ReferenceType: recursively resolve inner type and wrap as reference
// - PointerType: recursively resolve inner type and wrap as pointer
// - WeakReferenceType: recursively resolve inner type and wrap as weak reference
// - FunctionType: recursively resolve param types and return type
// - If type args still contain generic params, preserve original type
// - All other types: return unchanged
//
private let normalize_trait_placeholder_type(mono ref Monomorphizer, t Type) Type = {
    return when t in {
        .GenericStruct(template_name, args) then {
            let mut normalized_args = List[ref Type].new()
            for arg_ref in args then {
                normalized_args.push(box(normalize_trait_placeholder_type(mono, arg_ref.val)))
            }
            let trait_name_opt = when mono.storage.generic_templates.traits.get(template_name) in {
                .Some(_) then Option[String].Some(template_name),
                .None() then {
                    let mut matched = Option[String].None()
                    for entry in mono.storage.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = Option[String].Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name, normalized_args),
                .None() then Type.GenericStruct(template_name, normalized_args),
            }
        },
        .GenericEnum(template_name, args) then {
            let mut normalized_args = List[ref Type].new()
            for arg_ref in args then {
                normalized_args.push(box(normalize_trait_placeholder_type(mono, arg_ref.val)))
            }
            let trait_name_opt = when mono.storage.generic_templates.traits.get(template_name) in {
                .Some(_) then Option[String].Some(template_name),
                .None() then {
                    let mut matched = Option[String].None()
                    for entry in mono.storage.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = Option[String].Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name, normalized_args),
                .None() then Type.GenericEnum(template_name, normalized_args),
            }
        },
        .ReferenceType(inner) then Type.ReferenceType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .MutableReferenceType(inner) then Type.MutableReferenceType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .PointerType(inner) then Type.PointerType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .MutablePointerType(inner) then Type.MutablePointerType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .WeakReferenceType(inner) then Type.WeakReferenceType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(normalize_trait_placeholder_type(mono, inner.val))),
        .FunctionType(fn_params, return_type) then {
            let param_types = param_entry_types(fn_params)
            let mut normalized_params = List[ref Type].new()
            for param_type in param_types then {
                normalized_params.push(box(normalize_trait_placeholder_type(mono, param_type.val)))
            }
            let normalized_return = normalize_trait_placeholder_type(mono, return_type.val)
            yield make_function_type(normalized_params, normalized_return)
        },
        _ then t,
    }
}

private let canonicalize_type_arguments(mono ref Monomorphizer, args List[ref Type]) List[ref Type] = {
    let mut canonical_args = List[ref Type].new()
    for arg_ref in args then {
        let canonical_arg = canonical_type_for_generic_binding(mono, arg_ref.val)
        canonical_args.push(box(canonical_arg))
    }
    return canonical_args
}

private let trait_object_type_from_registry(mono ref Monomorphizer, trait_name String) Type = {
    let mut trait_type_args = List[ref Type].new()
    when mono.storage.generic_templates.traits.get(trait_name) in {
        .Some(info) then {
            for type_param in info.type_params then {
                trait_type_args.push(box(Type.GenericParameter(type_param.name)))
            }
        },
        .None() then {},
    }
    return Type.TraitObject(trait_name, trait_type_args)
}

private let resolve_def_id_backed_type(
    mono ref Monomorphizer,
    def_id DefId,
    fallback Type,
    is_struct Bool,
) Type = {
    let reconstructed = when mono.storage.context.get_template_name(def_id) in {
        .Some(template_name) then {
            yield when mono.storage.context.get_type_arguments(def_id) in {
                .Some(type_args) then {
                    let mut resolved_args = List[ref Type].new()
                    for type_arg in type_args then {
                        resolved_args.push(box(resolve_parameterized_type(mono, type_arg)))
                    }
                    let canonical_args = canonicalize_type_arguments(mono, resolved_args)
                    yield if args_have_generic_parameter(canonical_args) then {
                        yield if is_struct then Type.GenericStruct(template_name, canonical_args) else Type.GenericEnum(template_name, canonical_args)
                    } else if is_struct then {
                        yield when mono.storage.generic_templates.lookup_struct(template_name) in {
                            .Some(struct_template) then mono.instantiate_struct_impl(struct_template, canonical_args),
                            .None() then when mono.storage.generic_templates.concrete_struct_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericStruct(template_name, canonical_args),
                            },
                        }
                    } else {
                        yield when mono.storage.generic_templates.lookup_enum(template_name) in {
                            .Some(enum_template) then mono.instantiate_enum_impl(enum_template, canonical_args),
                            .None() then when mono.storage.generic_templates.concrete_enum_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericEnum(template_name, canonical_args),
                            },
                        }
                    }
                },
                .None() then fallback,
            }
        },
        .None() then {
            yield when mono.storage.context.lookup_type(def_id) in {
                .Some(mapped) then {
                    let resolved_mapped = resolve_parameterized_type(mono, mapped)
                    yield if layout_key(resolved_mapped) == layout_key(fallback) then fallback else resolved_mapped
                },
                .None() then fallback,
            }
        },
    }
    if reconstructed == fallback then {
        when fallback in {
            .StructureType(local_def_id) then when mono.storage.context.get_struct_fields(local_def_id) in {
                .Some(fields) then {
                    let mut resolved_fields = List[StructField].with_capacity(fields.count())
                    let mut changed = false
                    for field in fields then {
                        let resolved_field_type = resolve_parameterized_type(mono, field.field_type)
                        if resolved_field_type <> field.field_type then {
                            changed = true
                        }
                        resolved_fields.push(StructField(field.name, resolved_field_type, field.mutable, field.access, field.named))
                    }
                    if changed then {
                        mono.storage.context.set_struct_fields(local_def_id, resolved_fields)
                    }
                },
                .None() then {},
            },
            .EnumType(local_def_id) then when mono.storage.context.get_enum_cases(local_def_id) in {
                .Some(cases) then {
                    let mut resolved_cases = List[EnumCaseInfo].with_capacity(cases.count())
                    let mut changed = false
                    for enum_case in cases then {
                        let mut resolved_params = List[EnumCaseParam].with_capacity(enum_case.params.count())
                        for param in enum_case.params then {
                            let resolved_param_type = resolve_parameterized_type(mono, param.param_type)
                            if resolved_param_type <> param.param_type then {
                                changed = true
                            }
                            resolved_params.push(EnumCaseParam(param.name, resolved_param_type, param.named))
                        }
                        resolved_cases.push(EnumCaseInfo(enum_case.name, resolved_params))
                    }
                    if changed then {
                        mono.storage.context.set_enum_cases(local_def_id, resolved_cases)
                    }
                },
                .None() then {},
            },
            _ then {},
        }
    }
    return reconstructed
}

public let resolve_parameterized_type(mono ref Monomorphizer, t Type) Type = {
    when t in {
        .IntType() then { return t },
        .Int8Type() then { return t },
        .Int16Type() then { return t },
        .Int32Type() then { return t },
        .Int64Type() then { return t },
        .UIntType() then { return t },
        .UInt8Type() then { return t },
        .UInt16Type() then { return t },
        .UInt32Type() then { return t },
        .UInt64Type() then { return t },
        .Float32Type() then { return t },
        .Float64Type() then { return t },
        .BoolType() then { return t },
        .VoidType() then { return t },
        .NeverType() then { return t },
        .ModuleType(_) then { return t },
        .TraitObject(_, _) then { return t },
        .TypeVar(_) then { return t },
        .Unknown() then { return t },
        _ then {},
    }

    when t in {
        .ReferenceType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            return if resolved_inner == inner.val then t else Type.ReferenceType(box(resolved_inner))
        },
        .MutableReferenceType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            return if resolved_inner == inner.val then t else Type.MutableReferenceType(box(resolved_inner))
        },
        .PointerType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            return if resolved_inner == inner.val then t else Type.PointerType(box(resolved_inner))
        },
        .MutablePointerType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            return if resolved_inner == inner.val then t else Type.MutablePointerType(box(resolved_inner))
        },
        .WeakReferenceType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            return if resolved_inner == inner.val then t else Type.WeakReferenceType(box(resolved_inner))
        },
        .MutableWeakReferenceType(inner) then {
            let resolved_inner = resolve_parameterized_type(mono, inner.val)
            return if resolved_inner == inner.val then t else Type.MutableWeakReferenceType(box(resolved_inner))
        },
        .FunctionType(fn_params, return_type) then {
            let param_types = param_entry_types(fn_params)
            let mut new_param_types = List[ref Type].with_capacity(param_types.count())
            let mut changed = false
            for pt in param_types then {
                let resolved = resolve_parameterized_type(mono, pt.val)
                if resolved <> pt.val then {
                    changed = true
                }
                new_param_types.push(box(resolved))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type.val)
            if not changed and resolved_return == return_type.val then {
                return t
            }
            return make_function_type(new_param_types, resolved_return)
        },
        .OpaqueType(def_id) then {
            if mono.storage.context.lookup_type(def_id) is .None() then {
                return t
            }
        },
        _ then {},
    }

    when mono.storage.resolved_parameterized_types.get(t) in {
        .Some(cached) then { return cached },
        .None() then {},
    }
    if mono.storage.resolving_parameterized_type_keys.contains(t) then {
        return t
    }
    mono.storage.resolving_parameterized_type_keys.insert(t)

    let resolved = when t in {
        // GenericStruct: look up struct template and instantiate.
        .GenericStruct(template_name, args) then {
            // Trait names can appear in GenericStruct form during sema output
            // (e.g. [T]Iterator). Treat them as trait objects in mono/type
            // resolution so codegen does not attempt to materialize fake
            // concrete layouts like Iterator_Int.
            let trait_name_opt = when mono.storage.generic_templates.traits.get(template_name) in {
                .Some(_) then Option[String].Some(template_name),
                .None() then {
                    let mut matched = Option[String].None()
                    for entry in mono.storage.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = Option[String].Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            let mut resolved_args = List[ref Type].new()
            for arg_ref in args then {
                let normalized_arg = normalize_trait_placeholder_type(mono, arg_ref.val)
                resolved_args.push(box(normalized_arg))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name, canonical_args),
                .None() then {
                    yield if args_have_generic_parameter(canonical_args)
                        then Type.GenericStruct(template_name, canonical_args)
                        else when mono.storage.generic_templates.lookup_struct(template_name) in {
                        .Some(struct_template) then {
                            yield mono.instantiate_struct_impl(struct_template, canonical_args)
                        },
                        .None() then {
                            // Check concrete struct types registry.
                            yield when mono.storage.generic_templates.concrete_struct_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericStruct(template_name, canonical_args),
                            }
                        },
                    }
                },
            }
        },

        // GenericEnum: look up enum template and instantiate.
        .GenericEnum(template_name, args) then {
            let trait_name_opt = when mono.storage.generic_templates.traits.get(template_name) in {
                .Some(_) then Option[String].Some(template_name),
                .None() then {
                    let mut matched = Option[String].None()
                    for entry in mono.storage.generic_templates.traits.iterator() then {
                        let key = entry.first
                        if key == template_name
                            or key.ends_with(".\(template_name)")
                            or template_name.ends_with(".\(key)") then {
                            matched = Option[String].Some(key)
                            break
                        }
                    }
                    yield matched
                },
            }
            let mut resolved_args = List[ref Type].new()
            for arg_ref in args then {
                let normalized_arg = normalize_trait_placeholder_type(mono, arg_ref.val)
                resolved_args.push(box(normalized_arg))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            yield when trait_name_opt in {
                .Some(trait_name) then Type.TraitObject(trait_name, canonical_args),
                .None() then {
                    yield if args_have_generic_parameter(canonical_args)
                        then Type.GenericEnum(template_name, canonical_args)
                        else when mono.storage.generic_templates.lookup_enum(template_name) in {
                        .Some(enum_template) then {
                            yield mono.instantiate_enum_impl(enum_template, canonical_args)
                        },
                        .None() then {
                            // Check concrete enum types registry.
                            yield when mono.storage.generic_templates.concrete_enum_types.get(template_name) in {
                                .Some(concrete) then concrete,
                                .None() then Type.GenericEnum(template_name, canonical_args),
                            }
                        },
                    }
                },
            }
        },

        .StructureType(def_id) then resolve_def_id_backed_type(mono, def_id, t, true),

        .EnumType(def_id) then resolve_def_id_backed_type(mono, def_id, t, false),

        .OpaqueType(def_id) then {
            yield when mono.storage.context.lookup_type(def_id) in {
                .Some(mapped) then {
                    let resolved_mapped = resolve_parameterized_type(mono, mapped)
                    yield if layout_key(resolved_mapped) == layout_key(t) then t else resolved_mapped
                },
                .None() then t,
            }
        },

        // All other types: return unchanged.
        _ then t,
    }

    mono.storage.resolving_parameterized_type_keys.remove(t)
    mono.storage.resolved_parameterized_types.insert(t, resolved)
    return resolved
}

// ── resolve_type_node ─────────────────────────────────────────────────────────

// Resolve a TypeNode to a concrete Type using the substitution map.
//
// Priority for TypeNode.Identifier:
//   1. Type substitution map (generic parameter replacement)
//   2. Built-in types (Int, Bool, String, etc.)
//   3. Concrete type registry (struct/enum types)
//
public let resolve_type_node(mono ref Monomorphizer, node TypeNode, substitution Dict[String, Type]) Type = {
    return when node in {
        // TypeNode.Identifier: priority: substitution map → built-in types → concrete registry
        //
        .Identifier(name) then {
            yield when substitution.get(name) in {
                .Some(concrete) then concrete,
                .None() then {
                    yield when resolve_builtin_type(name) in {
                        .Some(t) then t,
                        .None() then {
                            yield when mono.storage.generic_templates.concrete_struct_types.get(name) in {
                                .Some(t) then t,
                                .None() then {
                                    yield when mono.storage.generic_templates.concrete_enum_types.get(name) in {
                                        .Some(t) then t,
                                        .None() then {
                                            yield when mono.storage.instantiated_types.get(name) in {
                                                .Some(t) then t,
                                                .None() then {
                                                    // Keep trait identifiers resolvable during monomorphization
                                                    // so types like Error ref are preserved as trait-object refs.
                                                    yield when mono.storage.generic_templates.traits.get(name) in {
                                                        .Some(_) then trait_object_type_from_registry(mono, name),
                                                        .None() then Type.Unknown(),
                                                    }
                                                },
                                            }
                                        },
                                    }
                                },
                            }
                        },
                    }
                },
            }
        },

        // TypeNode.Generic: recursively resolve type args and instantiate.
        .Generic(base, args) then {
            let mut resolved_args = List[ref Type].new()
            for arg in args then {
                let resolved = resolve_type_node(mono, arg.val, substitution)
                resolved_args.push(box(resolved))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            if mono.storage.generic_templates.traits.get(base) is .Some(_) then {
                return Type.TraitObject(base, canonical_args)
            }
            yield when mono.storage.generic_templates.lookup_struct(base) in {
                .Some(struct_template) then mono.instantiate_struct_impl(struct_template, canonical_args),
                .None() then {
                    yield when mono.storage.generic_templates.lookup_enum(base) in {
                        .Some(enum_template) then mono.instantiate_enum_impl(enum_template, canonical_args),
                        .None() then Type.GenericStruct(base, canonical_args),
                    }
                },
            }
        },

        // TypeNode.Reference: recursively resolve inner type and wrap.
        .Reference(inner, mutable) then {
            let trait_ref_override = when inner.val in {
                .Identifier(name) then if mono.storage.generic_templates.traits.get(name) is .Some(_) then {
                    let trait_ref_inner = trait_object_type_from_registry(mono, name)
                    yield Option[Type].Some(if mutable
                        then Type.MutableReferenceType(box(trait_ref_inner))
                        else Type.ReferenceType(box(trait_ref_inner)))
                } else Option[Type].None(),
                .Generic(base, args) then {
                    yield if mono.storage.generic_templates.traits.get(base) is .Some(_) then {
                        let mut resolved_args = List[ref Type].new()
                        for arg in args then {
                            let resolved = resolve_type_node(mono, arg.val, substitution)
                            resolved_args.push(box(resolved))
                        }
                        let canonical_args = canonicalize_type_arguments(mono, resolved_args)
                        let trait_ref_inner = Type.TraitObject(base, canonical_args)
                        yield Option[Type].Some(if mutable
                            then Type.MutableReferenceType(box(trait_ref_inner))
                            else Type.ReferenceType(box(trait_ref_inner)))
                    } else Option[Type].None()
                },
                _ then Option[Type].None(),
            }
            when trait_ref_override in {
                .Some(resolved_trait_ref) then { yield resolved_trait_ref },
                .None() then {},
            }
            let resolved_inner = resolve_type_node(mono, inner.val, substitution)
            yield if mutable then Type.MutableReferenceType(box(resolved_inner)) else Type.ReferenceType(box(resolved_inner))
        },

        // TypeNode.Pointer: recursively resolve inner type and wrap.
        .Pointer(inner, mutable) then {
            let resolved_inner = resolve_type_node(mono, inner.val, substitution)
            yield if mutable then Type.MutablePointerType(box(resolved_inner)) else Type.PointerType(box(resolved_inner))
        },

        // TypeNode.WeakReference: recursively resolve inner type and wrap.
        .WeakReference(inner, mutable) then {
            let resolved_inner = resolve_type_node(mono, inner.val, substitution)
            yield if mutable then Type.MutableWeakReferenceType(box(resolved_inner)) else Type.WeakReferenceType(box(resolved_inner))
        },

        // TypeNode.FunctionType: recursively resolve param types and return type.
        .FunctionType(param_types, return_type) then {
            let mut resolved_params = List[ref Type].new()
            for pt in param_types then {
                let resolved = resolve_type_node(mono, pt.val, substitution)
                resolved_params.push(box(resolved))
            }
            let resolved_return = resolve_type_node(mono, return_type.val, substitution)
            yield make_function_type(resolved_params, resolved_return)
        },

        // TypeNode.InferredSelf: look up `Self` in substitution map.
        .InferredSelf() then {
            yield when substitution.get("Self") in {
                .Some(self_type) then self_type,
                .None() then Type.Unknown(),
            }
        },
    }
}

// ── resolve_builtin_type ──────────────────────────────────────────────────────

// Dict a type name string to a built-in Type variant.
// Returns None if the name is not a built-in type.
private let resolve_builtin_type(name String) Option[Type] = {
    return when name in {
        "Int"     then Option[Type].Some(Type.IntType()),
        "Int8"    then Option[Type].Some(Type.Int8Type()),
        "Int16"   then Option[Type].Some(Type.Int16Type()),
        "Int32"   then Option[Type].Some(Type.Int32Type()),
        "Int64"   then Option[Type].Some(Type.Int64Type()),
        "UInt"    then Option[Type].Some(Type.UIntType()),
        "UInt8"   then Option[Type].Some(Type.UInt8Type()),
        "UInt16"  then Option[Type].Some(Type.UInt16Type()),
        "UInt32"  then Option[Type].Some(Type.UInt32Type()),
        "UInt64"  then Option[Type].Some(Type.UInt64Type()),
        "Float32" then Option[Type].Some(Type.Float32Type()),
        "Float64" then Option[Type].Some(Type.Float64Type()),
        "Bool"    then Option[Type].Some(Type.BoolType()),
        "Void"    then Option[Type].Some(Type.VoidType()),
        "Never"   then Option[Type].Some(Type.NeverType()),
        _         then Option[Type].None(),
    }
}

// ── collect_vtable_request_if_needed ─────────────────────────────────────────

private let normalize_vtable_conformance_actual_type(mono ref Monomorphizer, actual Type) Type = {
    return when actual in {
        .StructureType(def_id) then {
            let layout_name = mono.storage.context.get_name(def_id) or else ""
            yield when mono.storage.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut args = List[ref Type].new()
                            for type_arg in type_args then {
                                args.push(box(type_arg))
                            }
                            yield Type.GenericStruct(template_name, args)
                        },
                        .None() then actual,
                    }
                },
                .None() then {
                    yield when mono.storage.layout_to_template_info.get(layout_name) in {
                        .Some(info) then {
                            let mut args = List[ref Type].new()
                            for type_arg in info.args then {
                                args.push(box(type_arg.val))
                            }
                            yield Type.GenericStruct(info.base_name, args)
                        },
                        .None() then actual,
                    }
                },
            }
        },
        .EnumType(def_id) then {
            let layout_name = mono.storage.context.get_name(def_id) or else ""
            yield when mono.storage.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut args = List[ref Type].new()
                            for type_arg in type_args then {
                                args.push(box(type_arg))
                            }
                            yield Type.GenericEnum(template_name, args)
                        },
                        .None() then actual,
                    }
                },
                .None() then {
                    yield when mono.storage.layout_to_template_info.get(layout_name) in {
                        .Some(info) then {
                            let mut args = List[ref Type].new()
                            for type_arg in info.args then {
                                args.push(box(type_arg.val))
                            }
                            yield Type.GenericEnum(info.base_name, args)
                        },
                        .None() then actual,
                    }
                },
            }
        },
        _ then actual,
    }
}

private let collect_vtable_conformance_bindings(pattern Type, actual Type, bindings mut ref Dict[String, Type]) Bool = {
    return when pattern in {
        .GenericParameter(name) then {
            yield when bindings.get(name) in {
                .Some(bound) then layout_key(bound) == layout_key(actual),
                .None() then {
                    bindings.insert(name, actual)
                    yield true
                },
            }
        },
        .ReferenceType(pattern_inner) then when actual in {
            .ReferenceType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .MutableReferenceType(pattern_inner) then when actual in {
            .MutableReferenceType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .WeakReferenceType(pattern_inner) then when actual in {
            .WeakReferenceType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .MutableWeakReferenceType(pattern_inner) then when actual in {
            .MutableWeakReferenceType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .PointerType(pattern_inner) then when actual in {
            .PointerType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .MutablePointerType(pattern_inner) then when actual in {
            .MutablePointerType(actual_inner) then collect_vtable_conformance_bindings(pattern_inner.val, actual_inner.val, bindings),
            _ then false,
        },
        .GenericStruct(pattern_template, pattern_args) then when actual in {
            .GenericStruct(actual_template, actual_args) then {
                let mut all_match = pattern_template == actual_template and pattern_args.count() == actual_args.count()
                if all_match then {
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not collect_vtable_conformance_bindings(pattern_args[i].val, actual_args[i].val, bindings) then {
                            all_match = false
                            break
                        }
                        i += 1
                    }
                }
                yield all_match
            },
            _ then false,
        },
        .GenericEnum(pattern_template, pattern_args) then when actual in {
            .GenericEnum(actual_template, actual_args) then {
                let mut all_match = pattern_template == actual_template and pattern_args.count() == actual_args.count()
                if all_match then {
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not collect_vtable_conformance_bindings(pattern_args[i].val, actual_args[i].val, bindings) then {
                            all_match = false
                            break
                        }
                        i += 1
                    }
                }
                yield all_match
            },
            _ then false,
        },
        _ then layout_key(pattern) == layout_key(actual),
    }
}

private let resolve_vtable_trait_args(mono ref Monomorphizer, concrete_type Type, trait_name String) List[ref Type] = {
    let mut out = List[ref Type].new()
    let normalized_concrete_type = normalize_vtable_conformance_actual_type(mono, resolve_parameterized_type(mono, concrete_type))
    for node_ref in mono.storage.source_given_decls then {
        when node_ref in {
            .GivenTraitDecl(target_type, node_trait_name, trait_args, _, _) then {
                if node_trait_name <> trait_name then {
                    continue
                }
                let mut bindings = Dict[String, Type].new()
                if not collect_vtable_conformance_bindings(target_type, normalized_concrete_type, bindings.ref) then {
                    continue
                }
                for trait_arg in trait_args then {
                    out.push(box(resolve_parameterized_type(mono, substitute_type(mono, trait_arg, bindings))))
                }
                return out
            },
            _ then {},
        }
    }
    return out
}

// If the given type is a TraitObject, record a VtableRequest for it.
// Called during type resolution whenever a field or parameter type resolves
// to a trait object type.
private let collect_vtable_request_if_needed(mono ref Monomorphizer, t Type) Void = {
    when t in {
        .TraitObject(trait_name, _) then {
            let req = VtableRequest(t, trait_name, List[ref Type].new())
            mono.storage.vtable_requests.push(req)
        },
        _ then {},
    }
}

let collect_concrete_vtable_request(mono ref Monomorphizer, concrete_type Type, trait_name String) Void = {
    if has_generic_parameter(concrete_type) then {
        return
    }
    when concrete_type in {
        .TraitObject(_, _) then {},
        .Unknown() then {},
        _ then {
            let trait_type_args = resolve_vtable_trait_args(mono, concrete_type, trait_name)
            mono.storage.vtable_requests.push(VtableRequest(concrete_type, trait_name, trait_type_args))
            mono.instantiate_trait_vtable_methods_impl(concrete_type, trait_name, trait_type_args)
        },
    }
}

private let concrete_trait_receiver_type(mono ref Monomorphizer, expr ref TypedExpr) Type = {
    return when expr.expr_kind in {
        .TraitObjectConversion(inner, _, concrete_type) then {
            let stored_type = resolve_parameterized_type(mono, concrete_type)
            let inner_type = resolve_parameterized_type(mono, inner.expr_type)
            yield prefer_more_concrete_type(mono, stored_type, inner_type)
        },
        _ then resolve_parameterized_type(mono, expr.expr_type),
    }
}

private let collect_qualified_method_vtable_requests(
    mono ref Monomorphizer,
    trait_name String,
    method_name String,
    base ref TypedExpr,
    args List[ref TypedExpr],
) Void = {
    let concrete_base_type = concrete_trait_receiver_type(mono, base)
    collect_concrete_vtable_request(mono, concrete_base_type, trait_name)

    when mono.storage.generic_templates.traits.get(trait_name) in {
        .Some(trait_info) then {
            for member in trait_info.members then {
                if member.name <> method_name then {
                    continue
                }
                let mut arg_index UInt = 0
                let mut param_index UInt = 1
                while arg_index < args.count() and param_index < member.params.count() then {
                    let expected_param_type = resolve_parameterized_type(mono, member.params[param_index].param_type)
                    when expected_param_type in {
                        .TraitObject(param_trait_name, _) then {
                            let arg_type = concrete_trait_receiver_type(mono, args[arg_index])
                            collect_concrete_vtable_request(mono, arg_type, param_trait_name)
                        },
                        _ then {},
                    }
                    arg_index += 1
                    param_index += 1
                }
                return
            }
        },
        .None() then {},
    }
}

private let ordered_trait_method_names_helper(
    mono ref Monomorphizer,
    trait_name String,
    visited mut ref Set[String],
    ordered mut ref List[String],
    seen mut ref Set[String],
) Void = {
    if visited.contains(trait_name) then {
        return
    }
    visited.insert(trait_name)
    when mono.storage.generic_templates.traits.get(trait_name) in {
        .Some(info) then {
            for parent in info.parent_traits then {
                ordered_trait_method_names_helper(mono, parent.name, visited, ordered, seen)
            }
            for member in info.raw_members then {
                if not seen.contains(member.name) then {
                    seen.insert(member.name)
                    ordered.push(member.name)
                }
            }
        },
        .None() then {},
    }
}

private let vtable_method_index(mono ref Monomorphizer, trait_name String, method_name String) Int = {
    let mut visited = Set[String].new()
    let mut ordered = List[String].new()
    let mut seen = Set[String].new()
    ordered_trait_method_names_helper(mono, trait_name, visited.ref, ordered.ref, seen.ref)
    let mut idx UInt = 0
    while idx < ordered.count() then {
        if ordered[idx] == method_name then {
            return idx(Int)
        }
        idx += 1
    }
    return -1
}

private let expr_is_type_symbol(expr ref TypedExpr) Bool = {
    return when expr.expr_kind in {
        .Variable(sym) then sym.kind is .TypeSymbol(),
        _ then false,
    }
}

private let static_dispatch_receiver_expr(expr ref TypedExpr) ref TypedExpr = {
    return when expr.expr_kind in {
        .TraitObjectConversion(inner, _, _) then inner,
        _ then expr,
    }
}

private let adapt_receiver_expr_for_method(
    mono ref Monomorphizer,
    receiver_expr ref TypedExpr,
    method Symbol,
) ref TypedExpr = {
    let current_expr = static_dispatch_receiver_expr(receiver_expr)
    let current_type = resolve_parameterized_type(mono, current_expr.expr_type)
    let expected_self_type_opt = when resolved_method_symbol_type(mono, method.def_id, method.symbol_type) in {
        .FunctionType(fn_params, _) then {
            let param_types = param_entry_types(fn_params)
            yield if param_types.count() == 0 then {
                yield Option[Type].None()
            } else {
                yield Option[Type].Some(resolve_parameterized_type(mono, param_types[0(UInt)].val))
            }
        },
        _ then Option[Type].None(),
    }

    return when expected_self_type_opt in {
        .Some(expected_self_type) then {
            yield if layout_key(expected_self_type) == layout_key(current_type) then {
                yield current_expr
            } else when expected_self_type in {
                .ReferenceType(inner) then {
                    let inner_type = resolve_parameterized_type(mono, inner.val)
                    yield if layout_key(inner_type) == layout_key(current_type) then {
                        yield box(TypedExpr(box(TypedExprKind.RefExpr(current_expr)), expected_self_type))
                    } else when current_type in {
                        .MutableReferenceType(actual_inner) then {
                            let actual_inner_type = resolve_parameterized_type(mono, actual_inner.val)
                            yield if layout_key(inner_type) == layout_key(actual_inner_type) then {
                                yield box(TypedExpr(current_expr.expr_kind, expected_self_type))
                            } else {
                                yield current_expr
                            }
                        },
                        _ then current_expr,
                    }
                },
                .MutableReferenceType(inner) then {
                    let inner_type = resolve_parameterized_type(mono, inner.val)
                    yield if layout_key(inner_type) == layout_key(current_type) then {
                        yield box(TypedExpr(box(TypedExprKind.RefExpr(current_expr)), expected_self_type))
                    } else when current_type in {
                        .ReferenceType(actual_inner) then {
                            let actual_inner_type = resolve_parameterized_type(mono, actual_inner.val)
                            yield if layout_key(inner_type) == layout_key(actual_inner_type) then {
                                yield box(TypedExpr(current_expr.expr_kind, expected_self_type))
                            } else {
                                yield current_expr
                            }
                        },
                        .MutableReferenceType(actual_inner) then {
                            let actual_inner_type = resolve_parameterized_type(mono, actual_inner.val)
                            yield if layout_key(inner_type) == layout_key(actual_inner_type) then {
                                yield box(TypedExpr(current_expr.expr_kind, expected_self_type))
                            } else {
                                yield current_expr
                            }
                        },
                        _ then current_expr,
                    }
                },
                _ then when current_type in {
                    .ReferenceType(inner) then {
                        let inner_type = resolve_parameterized_type(mono, inner.val)
                        yield if layout_key(inner_type) == layout_key(expected_self_type) then {
                            yield box(TypedExpr(box(TypedExprKind.DerefExpr(current_expr)), expected_self_type))
                        } else {
                            yield current_expr
                        }
                    },
                    .MutableReferenceType(inner) then {
                        let inner_type = resolve_parameterized_type(mono, inner.val)
                        yield if layout_key(inner_type) == layout_key(expected_self_type) then {
                            yield box(TypedExpr(box(TypedExprKind.DerefExpr(current_expr)), expected_self_type))
                        } else {
                            yield current_expr
                        }
                    },
                    _ then current_expr,
                },
            }
        },
        .None() then current_expr,
    }
}

private let receiver_param_matches_actual_receiver(
    mono ref Monomorphizer,
    receiver_param_type Type,
    actual_receiver_type Type,
) Bool = {
    let resolved_actual = resolve_parameterized_type(mono, actual_receiver_type)
    return when receiver_param_type in {
        .ReferenceType(inner_ref) then when resolved_actual in {
            .ReferenceType(actual_inner) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(resolve_parameterized_type(mono, actual_inner.val)),
            .MutableReferenceType(actual_inner) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(resolve_parameterized_type(mono, actual_inner.val)),
            _ then false,
        },
        .MutableReferenceType(inner_ref) then when resolved_actual in {
            .MutableReferenceType(actual_inner) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(resolve_parameterized_type(mono, actual_inner.val)),
            _ then false,
        },
        .WeakReferenceType(inner_ref) then when resolved_actual in {
            .WeakReferenceType(actual_inner) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(resolve_parameterized_type(mono, actual_inner.val)),
            .MutableWeakReferenceType(actual_inner) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(resolve_parameterized_type(mono, actual_inner.val)),
            _ then false,
        },
        .MutableWeakReferenceType(inner_ref) then when resolved_actual in {
            .MutableWeakReferenceType(actual_inner) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(resolve_parameterized_type(mono, actual_inner.val)),
            _ then false,
        },
        _ then layout_key(resolve_parameterized_type(mono, receiver_param_type)) == layout_key(resolved_actual),
    }
}

private let method_def_id_matches_receiver_exactly(
    mono ref Monomorphizer,
    method_def_id DefId,
    receiver_type Type,
) Bool = {
    if method_def_id.id == 0 then {
        return false
    }
    let concrete_receiver_type = resolve_parameterized_type(mono, receiver_type)
    return when mono.storage.context.get_function_type(method_def_id) in {
        .Some(function_type) then when function_type in {
            .FunctionType(fn_params, _) then {
                let param_types = param_entry_types(fn_params)
                if param_types.count() == 0 then { return false }
                yield layout_key(resolve_parameterized_type(mono, param_types[0(UInt)].val)) == layout_key(concrete_receiver_type)
            },
            _ then false,
        },
        .None() then false,
    }
}

private let collect_enum_constructor_vtable_requests(
    mono ref Monomorphizer,
    enum_type Type,
    case_name String,
    args List[ref TypedExpr],
) Void = {
    let resolved_enum_type = resolve_parameterized_type(mono, enum_type)
    let case_field_types = mono_get_enum_case_field_types(mono, resolved_enum_type, UInt.max_value(), case_name)
    let mut idx UInt = 0
    while idx < args.count() and idx < case_field_types.count() then {
        let expected_type = normalize_trait_object_expected_type(mono, case_field_types[idx])
        when expected_type in {
            .ReferenceType(expected_inner_ref) then {
                when expected_inner_ref.val in {
                    .TraitObject(trait_name, _) then {
                        let actual_type = resolve_parameterized_type(mono, args[idx].expr_type)
                        let concrete_type = when actual_type in {
                            .ReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .MutableReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .WeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .MutableWeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .PointerType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .MutablePointerType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            _ then actual_type,
                        }
                        collect_concrete_vtable_request(mono, concrete_type, trait_name)
                    },
                    _ then {},
                }
            },
            .MutableReferenceType(expected_inner_ref) then {
                when expected_inner_ref.val in {
                    .TraitObject(trait_name, _) then {
                        let actual_type = resolve_parameterized_type(mono, args[idx].expr_type)
                        let concrete_type = when actual_type in {
                            .ReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .MutableReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .WeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .MutableWeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .PointerType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            .MutablePointerType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                            _ then actual_type,
                        }
                        collect_concrete_vtable_request(mono, concrete_type, trait_name)
                    },
                    _ then {},
                }
            },
            .TraitObject(trait_name, _) then {
                let actual_type = resolve_parameterized_type(mono, args[idx].expr_type)
                collect_concrete_vtable_request(mono, actual_type, trait_name)
            },
            _ then {},
        }
        idx += 1
    }
}

private let normalize_trait_object_expected_type(
    mono ref Monomorphizer,
    t Type,
) Type = {
    return when resolve_parameterized_type(mono, t) in {
        .OpaqueType(def_id) then when mono.storage.context.lookup_type(def_id) in {
            .Some(mapped) then normalize_trait_object_expected_type(mono, mapped),
            .None() then resolve_parameterized_type(mono, t),
        },
        .ReferenceType(inner) then Type.ReferenceType(box(normalize_trait_object_expected_type(mono, inner.val))),
        .MutableReferenceType(inner) then Type.MutableReferenceType(box(normalize_trait_object_expected_type(mono, inner.val))),
        .WeakReferenceType(inner) then Type.WeakReferenceType(box(normalize_trait_object_expected_type(mono, inner.val))),
        .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(normalize_trait_object_expected_type(mono, inner.val))),
        other then other,
    }
}

private let resolve_concrete_qualified_trait_member(
    mono ref Monomorphizer,
    concrete_type Type,
    trait_name String,
    method_name String,
) Option[TypedTraitMember] = {
    let resolved_concrete_type = resolve_parameterized_type(mono, concrete_type)
    let trait_type_args = resolve_vtable_trait_args(mono, resolved_concrete_type, trait_name)

    return when mono.storage.generic_templates.traits.get(trait_name) in {
        .Some(trait_info) then {
            let mut bindings = Dict[String, Type].new()
            bindings.insert("Self", resolved_concrete_type)

            let mut trait_arg_index UInt = 0
            while trait_arg_index < trait_info.type_params.count() and trait_arg_index < trait_type_args.count() then {
                bindings.insert(trait_info.type_params[trait_arg_index].name, trait_type_args[trait_arg_index].val)
                trait_arg_index += 1
            }

            for member in trait_info.members then {
                if member.name <> method_name then {
                    continue
                }

                let mut resolved_params = List[TypedParam].new()
                for param in member.params then {
                    let resolved_param_type = resolve_parameterized_type(mono, substitute_type(mono, param.param_type, bindings))
                    resolved_params.push(TypedParam(param.name, param.mutable, resolved_param_type, param.named))
                }

                let resolved_return_type = resolve_parameterized_type(mono, substitute_type(mono, member.return_type, bindings))
                yield Option[TypedTraitMember].Some(TypedTraitMember(member.name, resolved_params, resolved_return_type))
            }

            yield Option[TypedTraitMember].None()
        },
        .None() then Option[TypedTraitMember].None(),
    }
}

private let mono_resolve_qualified_method_return_type(
    mono ref Monomorphizer,
    concrete_type Type,
    trait_name String,
    method_name String,
    fallback Type,
) Type = {
    let fallback_type = resolve_parameterized_type(mono, fallback)
    return when resolve_concrete_qualified_trait_member(mono, concrete_type, trait_name, method_name) in {
        .Some(member) then prefer_more_concrete_type(mono, member.return_type, fallback_type),
        .None() then fallback_type,
    }
}

private let method_signature_matches_receiver_type(
    mono ref Monomorphizer,
    method Symbol,
    receiver_type Type,
) Bool = {
    if method.def_id.id == 0 then {
        return false
    }

    let concrete_receiver_type = resolve_parameterized_type(mono, receiver_type)
    return when mono.storage.context.get_function_type(method.def_id) in {
        .Some(function_type) then when function_type in {
            .FunctionType(fn_params, _) then {
                let param_types = param_entry_types(fn_params)
                yield if param_types.count() == 0 then {
                    yield false
                } else {
                    let declared_receiver_type = resolve_parameterized_type(mono, param_types[0(UInt)].val)
                    yield layout_key(declared_receiver_type) == layout_key(concrete_receiver_type)
                }
            },
            _ then false,
        },
        .None() then when resolve_parameterized_type(mono, method.symbol_type) in {
            .FunctionType(fn_params, _) then {
                let param_types = param_entry_types(fn_params)
                yield if param_types.count() == 0 then {
                    yield false
                } else {
                    let declared_receiver_type = resolve_parameterized_type(mono, param_types[0(UInt)].val)
                    yield layout_key(declared_receiver_type) == layout_key(concrete_receiver_type)
                }
            },
            _ then false,
        },
    }
}

private let ensure_receiver_dispatch_callsite(
    mono ref Monomorphizer,
    dispatch_callsite Option[DefId],
    receiver_type Type,
    method Symbol,
    logical_method_name Option[String],
) Option[DefId] = {
    if method.def_id.id == 0 then {
        return dispatch_callsite
    }

    let resolved_receiver_type = resolve_parameterized_type(mono, receiver_type)
    if resolved_receiver_type is .TraitObject(_, _) then {
        return dispatch_callsite
    }
    if not method_signature_matches_receiver_type(mono, method, resolved_receiver_type) then {
        return dispatch_callsite
    }

    let callsite_def_id = when dispatch_callsite in {
        .Some(existing) then existing,
        .None() then {
            let callsite_name = "__receiver_dispatch_\(mono.storage.context.symbol_name(method))_\(mono.storage.context.next_def_id())"
            yield mono.storage.context.allocate(callsite_name, DefKind.Function())
        },
    }

    let effective_logical_method_name = logical_method_name or else mono.storage.context.symbol_name(method)
    mono.set_receiver_method_dispatch_if_absent(
        callsite_def_id,
        ReceiverMethodDispatchInfo(method.def_id, effective_logical_method_name, Option[ReceiverMethodOwner].None(), Option[String].None())
    )
    return Option[DefId].Some(callsite_def_id)
}

private let resolve_symbol_type(mono ref Monomorphizer, symbol ref Symbol) Symbol = {
    let resolved = resolve_parameterized_type(mono, symbol.symbol_type)
    let registered = when mono.storage.context.get_symbol_type(symbol.def_id) in {
        .Some(t) then resolve_parameterized_type(mono, t),
        .None() then resolved,
    }
    let chosen = when resolved in {
        .VoidType() then registered,
        .Unknown() then registered,
        _ then when registered in {
            .VoidType() then resolved,
            .Unknown() then resolved,
            _ then prefer_more_concrete_type(mono, resolved, registered),
        },
    }
    return Symbol(symbol.def_id, chosen, symbol.kind)
}

private let recover_type_construction_type(
    mono ref Monomorphizer,
    identifier_type Type,
    identifier_def_id DefId,
    type_args List[Type],
    args List[ref TypedExpr],
) Type = {
    let resolved_identifier_type = resolve_parameterized_type(mono, identifier_type)
    when resolved_identifier_type in {
        .StructureType(_) then { return resolved_identifier_type },
        .EnumType(_) then { return resolved_identifier_type },
        .GenericStruct(_, _) then { return resolved_identifier_type },
        .GenericEnum(_, _) then { return resolved_identifier_type },
        _ then {},
    }

    if not type_args.is_empty() then {
        let mut boxed_args = List[ref Type].new()
        for type_arg in type_args then {
            boxed_args.push(box(resolve_parameterized_type(mono, type_arg)))
        }

        let template_name = when mono.storage.context.get_template_name(identifier_def_id) in {
            .Some(name) then name,
            .None() then mono.storage.context.get_name(identifier_def_id) or else "",
        }

        if not template_name.is_empty() then {
            when mono.storage.generic_templates.lookup_struct(template_name) in {
                .Some(template) then {
                    return resolve_parameterized_type(mono, mono.instantiate_struct_impl(template, boxed_args))
                },
                .None() then {},
            }
            when mono.storage.generic_templates.lookup_enum(template_name) in {
                .Some(template) then {
                    return resolve_parameterized_type(mono, mono.instantiate_enum_impl(template, boxed_args))
                },
                .None() then {},
            }
        }
    }

    when infer_type_construction_type_from_args(mono, identifier_def_id, args) in {
        .Some(inferred) then { return inferred },
        .None() then {},
    }

    return resolved_identifier_type
}

private let resolve_type_construction_symbol(
    mono ref Monomorphizer,
    identifier ref Symbol,
    type_args List[Type],
    args List[ref TypedExpr],
) Symbol = {
    let resolved_type = recover_type_construction_type(mono, identifier.symbol_type, identifier.def_id, type_args, args)
    return when resolved_type in {
        .StructureType(def_id) then Symbol(def_id, resolved_type, identifier.kind),
        .EnumType(def_id) then Symbol(def_id, resolved_type, identifier.kind),
        _ then Symbol(identifier.def_id, resolved_type, identifier.kind),
    }
}

private let infer_type_construction_type_from_args(
    mono ref Monomorphizer,
    identifier_def_id DefId,
    args List[ref TypedExpr],
) Option[Type] = {
    let template_name = when mono.storage.context.get_template_name(identifier_def_id) in {
        .Some(name) then name,
        .None() then mono.storage.context.get_name(identifier_def_id) or else "",
    }
    if template_name.is_empty() then {
        return Option[Type].None()
    }

    if args.count() == 2(UInt) and (template_name == "Pair" or template_name.ends_with(".Pair")) then {
        let mut pair_args = List[ref Type].new()
        pair_args.push(box(resolve_parameterized_type(mono, args[0(UInt)].expr_type)))
        pair_args.push(box(resolve_parameterized_type(mono, args[1(UInt)].expr_type)))
        return Option[Type].Some(resolve_parameterized_type(mono, Type.GenericStruct("Pair", pair_args)))
    }

    let template_opt = when mono.storage.generic_templates.lookup_struct(template_name) in {
        .Some(template) then Option[GenericStructTemplate].Some(template),
        .None() then {
            let mut matched = Option[GenericStructTemplate].None()
            for entry in mono.storage.generic_templates.struct_templates.iterator() then {
                let key = entry.first
                if key == template_name
                    or key.ends_with(".\(template_name)")
                    or template_name.ends_with(".\(key)") then {
                    matched = Option[GenericStructTemplate].Some(entry.second)
                    break
                }
            }
            yield matched
        },
    }

    return when template_opt in {
        .Some(template) then {
            if template.fields.count() <> args.count() then {
                return Option[Type].None()
            }
            let mut bindings = Dict[String, Type].new()
            let empty_subst = Dict[String, Type].new()
            let mut i UInt = 0
            while i < args.count() then {
                let field_pattern = mono.resolve_type_node_impl(template.fields[i].field_type, empty_subst)
                infer_type_bindings_from_constructor_pattern(mono, field_pattern, resolve_parameterized_type(mono, args[i].expr_type), bindings.ref)
                i += 1
            }

            let mut inferred_args = List[ref Type].new()
            for type_param in template.type_parameters then {
                inferred_args.push(box(bindings.get(type_param.name) or else Type.GenericParameter(type_param.name)))
            }
            yield Option[Type].Some(resolve_parameterized_type(mono, Type.GenericStruct(template.name, inferred_args)))
        },
        .None() then Option[Type].None(),
    }
}

private let infer_type_bindings_from_constructor_pattern(
    mono ref Monomorphizer,
    pattern Type,
    concrete Type,
    bindings mut ref Dict[String, Type],
) Void = {
    let normalized_pattern = resolve_parameterized_type(mono, pattern)
    let normalized_concrete = resolve_parameterized_type(mono, concrete)
    when normalized_pattern in {
        .GenericParameter(name) then {
            if bindings.get(name) is .None() then {
                bindings.insert(name, normalized_concrete)
            }
        },
        .ReferenceType(inner) then when normalized_concrete in {
            .ReferenceType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            .MutableReferenceType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            _ then {},
        },
        .MutableReferenceType(inner) then when normalized_concrete in {
            .MutableReferenceType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            _ then {},
        },
        .PointerType(inner) then when normalized_concrete in {
            .PointerType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            .MutablePointerType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            _ then {},
        },
        .MutablePointerType(inner) then when normalized_concrete in {
            .MutablePointerType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            _ then {},
        },
        .WeakReferenceType(inner) then when normalized_concrete in {
            .WeakReferenceType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            .MutableWeakReferenceType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            _ then {},
        },
        .MutableWeakReferenceType(inner) then when normalized_concrete in {
            .MutableWeakReferenceType(concrete_inner) then infer_type_bindings_from_constructor_pattern(mono, inner.val, concrete_inner.val, bindings),
            _ then {},
        },
        .FunctionType(pattern_params, pattern_return) then when normalized_concrete in {
            .FunctionType(concrete_params, concrete_return) then {
                if pattern_params.count() == concrete_params.count() then {
                    let mut i UInt = 0
                    while i < pattern_params.count() then {
                        infer_type_bindings_from_constructor_pattern(mono, pattern_params[i].val.param_type, concrete_params[i].val.param_type, bindings)
                        i += 1
                    }
                    infer_type_bindings_from_constructor_pattern(mono, pattern_return.val, concrete_return.val, bindings)
                }
            },
            _ then {},
        },
        .GenericStruct(pattern_name, pattern_args) then when normalized_concrete in {
            .GenericStruct(concrete_name, concrete_args) then {
                if pattern_name == concrete_name and pattern_args.count() == concrete_args.count() then {
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        infer_type_bindings_from_constructor_pattern(mono, pattern_args[i].val, concrete_args[i].val, bindings)
                        i += 1
                    }
                }
            },
            _ then {},
        },
        .GenericEnum(pattern_name, pattern_args) then when normalized_concrete in {
            .GenericEnum(concrete_name, concrete_args) then {
                if pattern_name == concrete_name and pattern_args.count() == concrete_args.count() then {
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        infer_type_bindings_from_constructor_pattern(mono, pattern_args[i].val, concrete_args[i].val, bindings)
                        i += 1
                    }
                }
            },
            _ then {},
        },
        _ then {},
    }
}

private let mono_is_unresolved_expr_type(mono ref Monomorphizer, t Type) Bool = {
    return when t in {
        .VoidType() then true,
        .GenericStruct(_, args) then {
            for arg_ref in args then {
                if mono_is_unresolved_expr_type(mono, arg_ref.val) then {
                    return true
                }
            }
            yield is_placeholder_inferred_type(t)
        },
        .GenericEnum(_, args) then {
            for arg_ref in args then {
                if mono_is_unresolved_expr_type(mono, arg_ref.val) then {
                    return true
                }
            }
            yield is_placeholder_inferred_type(t)
        },
        .StructureType(def_id) then {
            let display_name = mono.storage.context.type_display_name(t)
            let type_name = mono.storage.context.get_name(def_id) or else display_name
            if type_name.contains("__") or display_name.contains("__") then {
                return true
            }
            yield when mono.storage.context.get_type_arguments(def_id) in {
                .Some(type_args) then {
                    for type_arg in type_args then {
                        if mono_is_unresolved_expr_type(mono, type_arg) then {
                            return true
                        }
                    }
                    yield is_placeholder_inferred_type(t)
                },
                .None() then is_placeholder_inferred_type(t),
            }
        },
        .EnumType(def_id) then {
            let display_name = mono.storage.context.type_display_name(t)
            let type_name = mono.storage.context.get_name(def_id) or else display_name
            if type_name.contains("__") or display_name.contains("__") then {
                return true
            }
            yield when mono.storage.context.get_type_arguments(def_id) in {
                .Some(type_args) then {
                    for type_arg in type_args then {
                        if mono_is_unresolved_expr_type(mono, type_arg) then {
                            return true
                        }
                    }
                    yield is_placeholder_inferred_type(t)
                },
                .None() then is_placeholder_inferred_type(t),
            }
        },
        _ then is_placeholder_inferred_type(t),
    }
}

private let is_concrete_integer_type(t Type) Bool = {
    return when t in {
        .IntType() then true,
        .Int8Type() then true,
        .Int16Type() then true,
        .Int32Type() then true,
        .Int64Type() then true,
        .UIntType() then true,
        .UInt8Type() then true,
        .UInt16Type() then true,
        .UInt32Type() then true,
        .UInt64Type() then true,
        _ then false,
    }
}

private let is_concrete_float_type(t Type) Bool = {
    return when t in {
        .Float32Type() then true,
        .Float64Type() then true,
        _ then false,
    }
}

private let is_concrete_numeric_type(t Type) Bool = {
    return is_concrete_integer_type(t) or is_concrete_float_type(t)
}

private let is_matching_unsigned_shift_amount_type(value_type Type, shift_type Type) Bool = {
    if not is_concrete_integer_type(value_type) then {
        return false
    }
    return when shift_type in {
        .UIntType() then true,
        .UInt8Type() then true,
        .UInt16Type() then true,
        .UInt32Type() then true,
        .UInt64Type() then true,
        _ then false,
    }
}

private let method_semantic_name_from_dispatch(mono ref Monomorphizer, method Symbol) Option[String] = {
    return Option[String].Some(get_semantic_method_name(mono, method))
}

private let method_semantic_name_from_callsite(
    mono ref Monomorphizer,
    dispatch_callsite Option[DefId],
) Option[String] = {
    return when dispatch_callsite in {
        .Some(def_id) then {
            yield when mono.receiver_method_dispatch_info(def_id) in {
                .Some(info) then Option[String].Some(info.method_name),
                .None() then Option[String].None(),
            }
        },
        .None() then Option[String].None(),
    }
}

private let make_zero_integer_literal_expr(t Type) ref TypedExpr = {
    return box(TypedExpr(box(TypedExprKind.IntegerLiteral("0")), t))
}

private let is_wrapping_method_name(name String) Bool = {
    return name == "wrapping_add"
        or name == "wrapping_sub"
        or name == "wrapping_mul"
        or name == "wrapping_div"
        or name == "wrapping_rem"
        or name == "wrapping_neg"
        or name == "wrapping_shl"
        or name == "wrapping_shr"
}

private let try_lower_wrapping_generic_method_call(
    mono ref Monomorphizer,
    base ref TypedExpr,
    method Symbol,
    args List[ref TypedExpr],
    result_type Type,
    dispatch_callsite Option[DefId],
) Option[ref TypedExpr] = {
    let base_type = resolve_parameterized_type(mono, base.expr_type)
    if not is_concrete_integer_type(base_type) then {
        return Option[ref TypedExpr].None()
    }

    let callsite_name = method_semantic_name_from_callsite(mono, dispatch_callsite) or else ""
    let method_name = if is_wrapping_method_name(callsite_name)
            then callsite_name
        else get_semantic_method_name(mono, method)
    if not is_wrapping_method_name(method_name) then {
        return Option[ref TypedExpr].None()
    }

    return try_lower_wrapping_method_name_call(mono, base, method_name, args, result_type)
}

private let try_lower_wrapping_method_name_call(
    mono ref Monomorphizer,
    base ref TypedExpr,
    method_name String,
    args List[ref TypedExpr],
    result_type Type,
) Option[ref TypedExpr] = {
    let base_type = resolve_parameterized_type(mono, base.expr_type)
    if not is_concrete_integer_type(base_type) then {
        return Option[ref TypedExpr].None()
    }
    if not is_wrapping_method_name(method_name) then {
        return Option[ref TypedExpr].None()
    }

    if args.count() == 1(UInt) then {
        let rhs = args[0(UInt)]
        let rhs_type = resolve_parameterized_type(mono, rhs.expr_type)
        let compatible_rhs = layout_key(base_type) == layout_key(rhs_type)
            or is_concrete_integer_type(rhs_type)
        if method_name == "wrapping_add" and compatible_rhs then {
            return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingArithmeticExpr(base, ArithmeticOperator.Add(), rhs)), result_type)))
        }
        if method_name == "wrapping_sub" and compatible_rhs then {
            return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingArithmeticExpr(base, ArithmeticOperator.Subtract(), rhs)), result_type)))
        }
        if method_name == "wrapping_mul" and compatible_rhs then {
            return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingArithmeticExpr(base, ArithmeticOperator.Multiply(), rhs)), result_type)))
        }
        if method_name == "wrapping_div" and compatible_rhs then {
            return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingArithmeticExpr(base, ArithmeticOperator.Divide(), rhs)), result_type)))
        }
        if method_name == "wrapping_rem" and compatible_rhs then {
            return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingArithmeticExpr(base, ArithmeticOperator.Remainder(), rhs)), result_type)))
        }
        if method_name == "wrapping_shl" and is_matching_unsigned_shift_amount_type(base_type, rhs_type) then {
            return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingShiftExpr(base, BitwiseOperator.LeftShift(), rhs)), result_type)))
        }
        if method_name == "wrapping_shr" and is_matching_unsigned_shift_amount_type(base_type, rhs_type) then {
            return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingShiftExpr(base, BitwiseOperator.RightShift(), rhs)), result_type)))
        }
    }

    if method_name == "wrapping_neg" and args.count() == 0 then {
        let zero = make_zero_integer_literal_expr(base_type)
        return Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.WrappingArithmeticExpr(zero, ArithmeticOperator.Subtract(), base)), result_type)))
    }

    return Option[ref TypedExpr].None()
}

// Lower to_ref intrinsic method on weakref types to UpgradeRef nodes.
// When the monomorphizer encounters a method call where:
//   - The method name is "to_ref"
//   - The receiver (base) type is a weakref type
//   - There are no arguments (besides self)
// It lowers the call to TypedIntrinsic.UpgradeRef with the appropriate Option result type.
private let try_lower_to_ref_method_call(
    mono ref Monomorphizer,
    base ref TypedExpr,
    method Symbol,
    args List[ref TypedExpr],
    result_type Type,
    dispatch_callsite Option[DefId],
) Option[ref TypedExpr] = {
    if args.count() > 0 then {
        return Option[ref TypedExpr].None()
    }

    // Use structured lookup instead of brute-force string matching.
    // Priority: callsite dispatch info > semantic method name from defId.
    let method_name = when dispatch_callsite in {
        .Some(def_id) then when mono.receiver_method_dispatch_info(def_id) in {
            .Some(info) then info.method_name,
            .None() then get_semantic_method_name(mono, method),
        },
        .None() then get_semantic_method_name(mono, method),
    }
    if method_name <> "to_ref" then {
        return Option[ref TypedExpr].None()
    }

    let base_type = resolve_parameterized_type(mono, base.expr_type)
    return when base_type in {
        .WeakReferenceType(inner) then {
            let ref_type = Type.ReferenceType(inner)
            let mut option_args = List[ref Type].new()
            option_args.push(box(ref_type))
            let option_type = Type.GenericEnum("Option", option_args)
            yield Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.IntrinsicCall(TypedIntrinsic.UpgradeRef(base, option_type))), option_type)))
        },
        .MutableWeakReferenceType(inner) then {
            let ref_type = Type.MutableReferenceType(inner)
            let mut option_args = List[ref Type].new()
            option_args.push(box(ref_type))
            let option_type = Type.GenericEnum("Option", option_args)
            yield Option[ref TypedExpr].Some(box(TypedExpr(box(TypedExprKind.IntrinsicCall(TypedIntrinsic.UpgradeMutRef(base, option_type))), option_type)))
        },
        _ then Option[ref TypedExpr].None(),
    }
}

private let prefer_more_concrete_type(mono ref Monomorphizer, primary Type, fallback Type) Type = {
    let primary_has_generics = has_generic_parameter(primary)
    let fallback_has_generics = has_generic_parameter(fallback)
    let primary_is_unresolved = mono_is_unresolved_expr_type(mono, primary)
    let fallback_is_unresolved = mono_is_unresolved_expr_type(mono, fallback)
    let primary_is_placeholder = when primary in {
        .StructureType(def_id) then {
            let display_name = mono.storage.context.type_display_name(primary)
            let type_name = mono.storage.context.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        .EnumType(def_id) then {
            let display_name = mono.storage.context.type_display_name(primary)
            let type_name = mono.storage.context.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        _ then false,
    }
    let fallback_is_placeholder = when fallback in {
        .StructureType(def_id) then {
            let display_name = mono.storage.context.type_display_name(fallback)
            let type_name = mono.storage.context.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        .EnumType(def_id) then {
            let display_name = mono.storage.context.type_display_name(fallback)
            let type_name = mono.storage.context.get_name(def_id) or else display_name
            yield type_name.ends_with("_T") or display_name.ends_with("_T")
        },
        _ then false,
    }
    let primary_is_parameterized = when primary in {
        .GenericStruct(_, _) then true,
        .GenericEnum(_, _) then true,
        .TraitObject(_, _) then true,
        _ then false,
    }
    let fallback_is_nominal = when fallback in {
        .StructureType(_) then true,
        .EnumType(_) then true,
        _ then false,
    }
    if primary_is_parameterized and fallback_is_nominal then {
        return fallback
    }
    if primary_is_unresolved and not fallback_is_unresolved then {
        return fallback
    }
    if fallback_is_unresolved and not primary_is_unresolved then {
        return primary
    }
    if primary_has_generics and not fallback_has_generics then {
        return fallback
    }
    if primary_is_placeholder and not fallback_is_placeholder then {
        return fallback
    }
    when primary in {
        .Unknown() then {
            return fallback
        },
        _ then {},
    }
    return primary
}

private let resolved_method_return_type(mono ref Monomorphizer, method Symbol, fallback Type) Type = {
    let method_return_type = when resolve_parameterized_type(mono, method.symbol_type) in {
        .FunctionType(_, return_type) then resolve_parameterized_type(mono, return_type.val),
        _ then resolve_parameterized_type(mono, method.symbol_type),
    }
    let fallback_type = resolve_parameterized_type(mono, fallback)
    return prefer_more_concrete_type(mono, method_return_type, fallback_type)
}

private let resolved_callsite_result_type(mono ref Monomorphizer, declared_type Type, method Symbol) Type = {
    let concrete_declared_type = resolve_parameterized_type(mono, declared_type)
    let method_return_type = resolved_method_return_type(mono, method, concrete_declared_type)
    return prefer_more_concrete_type(mono, concrete_declared_type, method_return_type)
}

private let resolved_method_symbol_type(
    mono ref Monomorphizer,
    def_id DefId,
    fallback Type,
) Type = {
    return when mono.storage.context.get_function_type(def_id) in {
        .Some(function_type) then resolve_parameterized_type(mono, function_type),
        .None() then resolve_parameterized_type(mono, fallback),
    }
}

private let resolved_method_symbol(
    mono ref Monomorphizer,
    def_id DefId,
    fallback_name String,
    fallback_type Type,
) Symbol = {
    let concrete_name = when mono.storage.context.get_name(def_id) in {
        .Some(name) then name,
        .None() then fallback_name,
    }
    let concrete_type = resolved_method_symbol_type(mono, def_id, fallback_type)
    let result = Symbol(def_id, concrete_type, SymbolKind.Function())
    return result
}

private let method_has_compatible_ref_like_receiver(
    mono ref Monomorphizer,
    method_type Type,
    base_type Type,
) Bool = {
    let resolved_method_type = resolve_parameterized_type(mono, method_type)
    let resolved_base_type = resolve_parameterized_type(mono, base_type)
    return when resolved_method_type in {
        .FunctionType(fn_params, _) then {
            let param_types = param_entry_types(fn_params)
            if param_types.is_empty() then {
                return false
            }
            let first_param_type = resolve_parameterized_type(mono, param_types[0(UInt)].val)
            yield when first_param_type in {
                .ReferenceType(lhs) then when resolved_base_type in {
                    .ReferenceType(rhs) then layout_key(resolve_parameterized_type(mono, lhs.val)) == layout_key(resolve_parameterized_type(mono, rhs.val)),
                    .MutableReferenceType(rhs) then layout_key(resolve_parameterized_type(mono, lhs.val)) == layout_key(resolve_parameterized_type(mono, rhs.val)),
                    _ then false,
                },
                .MutableReferenceType(lhs) then when resolved_base_type in {
                    .MutableReferenceType(rhs) then layout_key(resolve_parameterized_type(mono, lhs.val)) == layout_key(resolve_parameterized_type(mono, rhs.val)),
                    _ then false,
                },
                .WeakReferenceType(lhs) then when resolved_base_type in {
                    .WeakReferenceType(rhs) then layout_key(resolve_parameterized_type(mono, lhs.val)) == layout_key(resolve_parameterized_type(mono, rhs.val)),
                    .MutableWeakReferenceType(rhs) then layout_key(resolve_parameterized_type(mono, lhs.val)) == layout_key(resolve_parameterized_type(mono, rhs.val)),
                    _ then false,
                },
                .MutableWeakReferenceType(lhs) then when resolved_base_type in {
                    .MutableWeakReferenceType(rhs) then layout_key(resolve_parameterized_type(mono, lhs.val)) == layout_key(resolve_parameterized_type(mono, rhs.val)),
                    _ then false,
                },
                _ then false,
            }
        },
        _ then false,
    }
}

private let should_preserve_resolved_method_reference(
    mono ref Monomorphizer,
    method ref Symbol,
    base_type Type,
) Bool = {
    if method.def_id.id == 0 then {
        return false
    }
    let resolved_method_type = resolve_parameterized_type(mono, method.symbol_type)
    if not method_has_compatible_ref_like_receiver(mono, resolved_method_type, base_type) then {
        return false
    }
    if has_generic_parameter(resolved_method_type) then {
        return false
    }
    return when mono.receiver_method_dispatch_info(method.def_id) in {
        .Some(info) then when info.owner in {
            .Some(owner) then when owner in {
                .ExtensionTemplate(owner_name) then
                    owner_name == "Ref" or owner_name == "MutRef" or owner_name == "WeakRef" or owner_name == "MutWeakRef",
                .ConcreteType(type_name) then
                    type_name == "Ref" or type_name == "MutRef" or type_name == "WeakRef" or type_name == "MutWeakRef",
            },
            .None() then false,
        },
        .None() then false,
    }
}

private let resolve_types_in_statement(mono ref Monomorphizer, stmt ref TypedStatement) TypedStatement = {
    return when stmt in {
        .LetStmt(symbol, value, span) then {
            let new_symbol = resolve_symbol_type(mono, symbol)
            let resolved_value = resolve_types_in_expression(mono, value)
            let concrete_symbol_type = resolve_parameterized_type(mono, new_symbol.symbol_type)
            let mut effective_symbol_type = prefer_more_concrete_type(mono, concrete_symbol_type, resolved_value.expr_type)
            if mono_is_unresolved_expr_type(mono, concrete_symbol_type) and not mono_is_unresolved_expr_type(mono, resolved_value.expr_type) then {
                effective_symbol_type = resolved_value.expr_type
            }
            if new_symbol.def_id.id > 0 then {
                let symbol_kind = when mono.storage.context.get_symbol_kind(new_symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then new_symbol.kind,
                }
                let symbol_method_kind = when mono.storage.context.get_symbol_method_kind(new_symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then MethodKind.Normal(),
                }
                let symbol_mutable = when mono.storage.context.get_symbol_mutable(new_symbol.def_id) in {
                    .Some(mutable) then mutable,
                    .None() then false,
                }
                mono.storage.context.set_symbol_info(new_symbol.def_id, SymbolInfo(effective_symbol_type, symbol_kind, symbol_method_kind, symbol_mutable))
            }
            yield TypedStatement.LetStmt(box(Symbol(new_symbol.def_id, effective_symbol_type, new_symbol.kind)), resolved_value, span)
        },
        .PairLetStmt(first_symbol, second_symbol, value, span) then {
            let resolved_value = resolve_types_in_expression(mono, value)
            let new_first_symbol = when first_symbol in {
                .Some(symbol) then {
                    let resolved_symbol = resolve_symbol_type(mono, symbol)
                    yield Option[ref Symbol].Some(box(Symbol(resolved_symbol.def_id, resolved_symbol.symbol_type, resolved_symbol.kind)))
                },
                .None() then Option[ref Symbol].None(),
            }
            let new_second_symbol = when second_symbol in {
                .Some(symbol) then {
                    let resolved_symbol = resolve_symbol_type(mono, symbol)
                    yield Option[ref Symbol].Some(box(Symbol(resolved_symbol.def_id, resolved_symbol.symbol_type, resolved_symbol.kind)))
                },
                .None() then Option[ref Symbol].None(),
            }
            yield TypedStatement.PairLetStmt(new_first_symbol, new_second_symbol, resolved_value, span)
        },
        .AssignmentStmt(target, value, span) then {
            yield TypedStatement.AssignmentStmt(resolve_types_in_expression(mono, target), resolve_types_in_expression(mono, value), span)
        },
        .ExprStmt(expr, span) then {
            yield TypedStatement.ExprStmt(resolve_types_in_expression(mono, expr), span)
        },
        .IfStmt(condition, then_branch, else_branch, span) then {
            let new_else = when else_branch in {
                .Some(expr) then Option[ref TypedExpr].Some(resolve_types_in_expression(mono, expr)),
                .None() then Option[ref TypedExpr].None(),
            }
            yield TypedStatement.IfStmt(
                resolve_types_in_expression(mono, condition),
                resolve_types_in_expression(mono, then_branch),
                new_else,
                span
            )
        },
        .WhileStmt(condition, body, span) then {
            yield TypedStatement.WhileStmt(
                resolve_types_in_expression(mono, condition),
                resolve_types_in_expression(mono, body),
                span
            )
        },
        .WhenStmt(subject, arms, span) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            let mut new_arms = List[ref TypedWhenArm].new()
            for arm_ref in arms then {
                let new_body = resolve_types_in_expression(mono, arm_ref.body)
                new_arms.push(box(TypedWhenArm(arm_ref.pattern, new_body, resolve_parameterized_type(mono, arm_ref.arm_type))))
            }
            yield TypedStatement.WhenStmt(new_subject, new_arms, span)
        },
        .ReturnStmt(value, span) then {
            let new_value = when value in {
                .Some(expr) then Option[ref TypedExpr].Some(resolve_types_in_expression(mono, expr)),
                .None() then Option[ref TypedExpr].None(),
            }
            yield TypedStatement.ReturnStmt(new_value, span)
        },
        .FinallyStmt(expr, span) then {
            yield TypedStatement.FinallyStmt(resolve_types_in_expression(mono, expr), span)
        },
        .YieldStmt(expr, span) then {
            yield TypedStatement.YieldStmt(resolve_types_in_expression(mono, expr), span)
        },
        _ then stmt,
    }
}

public let resolve_types_in_expression(mono ref Monomorphizer, expr ref TypedExpr) ref TypedExpr = {
    when expr.expr_kind in {
        .Variable(symbol) then {
            let new_symbol = resolve_symbol_type(mono, symbol)
            return box(TypedExpr(box(TypedExprKind.Variable(box(new_symbol))), new_symbol.symbol_type))
        },
        .RefExpr(inner) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            let resolved_inner = resolve_parameterized_type(mono, new_inner.expr_type)
            let resolved_type = when expr.expr_type in {
                .MutableReferenceType(_) then Type.MutableReferenceType(box(resolved_inner)),
                .ReferenceType(_) then Type.ReferenceType(box(resolved_inner)),
                .MutableWeakReferenceType(_) then Type.MutableWeakReferenceType(box(resolved_inner)),
                .WeakReferenceType(_) then Type.WeakReferenceType(box(resolved_inner)),
                _ then Type.ReferenceType(box(resolved_inner)),
            }
            return box(TypedExpr(box(TypedExprKind.RefExpr(new_inner)), resolved_type))
        },
        .PtrExpr(inner) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            let resolved_inner = resolve_parameterized_type(mono, new_inner.expr_type)
            let resolved_type = when expr.expr_type in {
                .MutablePointerType(_) then Type.MutablePointerType(box(resolved_inner)),
                .PointerType(_) then Type.PointerType(box(resolved_inner)),
                _ then Type.PointerType(box(resolved_inner)),
            }
            return box(TypedExpr(box(TypedExprKind.PtrExpr(new_inner)), resolved_type))
        },
        .DerefExpr(inner) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            let resolved_type = when new_inner.expr_type in {
                .ReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                .MutableReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                .WeakReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                .MutableWeakReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                .PointerType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                .MutablePointerType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val),
                _ then resolve_parameterized_type(mono, expr.expr_type),
            }
            return box(TypedExpr(box(TypedExprKind.DerefExpr(new_inner)), resolved_type))
        },
        .Call(callee, args) then {
            let mut new_args = List[ref TypedExpr].new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            let resolved_callee = resolve_types_in_expression(mono, callee)
            let new_callee = when callee.expr_kind in {
                .Variable(original_symbol) then when original_symbol.kind in {
                    .Function() then when resolved_callee.expr_kind in {
                        .Variable(resolved_symbol) then when resolved_symbol.kind in {
                            .Function() then resolved_callee,
                            _ then {
                                let stable_symbol = resolve_symbol_type(mono, original_symbol)
                                yield box(TypedExpr(box(TypedExprKind.Variable(box(stable_symbol))), stable_symbol.symbol_type))
                            },
                        },
                        _ then resolved_callee,
                    },
                    _ then resolved_callee,
                },
                _ then resolved_callee,
            }
            when new_callee.expr_kind in {
                .TraitMethodPlaceholder(base_expr, trait_type, method, method_type_args, dispatch_callsite) then {
                    let mut trait_object_type_opt Option[Type] = Option[Type].None()
                    let base_type = resolve_parameterized_type(mono, base_expr.expr_type)
                    when base_type in {
                        .TraitObject(trait_name, trait_type_args) then {
                            trait_object_type_opt = Option[Type].Some(Type.TraitObject(trait_name, trait_type_args))
                        },
                        .ReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                            .TraitObject(trait_name, trait_type_args) then {
                                trait_object_type_opt = Option[Type].Some(Type.TraitObject(trait_name, trait_type_args))
                            },
                            _ then {},
                        },
                        .MutableReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                            .TraitObject(trait_name, trait_type_args) then {
                                trait_object_type_opt = Option[Type].Some(Type.TraitObject(trait_name, trait_type_args))
                            },
                            _ then {},
                        },
                        _ then {},
                    }
                    when trait_object_type_opt in {
                        .Some(trait_object_type) then when trait_object_type in {
                            .TraitObject(trait_name, _) then {
                                let logical_method_name = get_semantic_method_name(mono, method)
                                let method_index = vtable_method_index(mono, trait_name, logical_method_name)
                                if method_index >= 0 then {
                                    let trait_receiver = when base_expr.expr_kind in {
                                        .DerefExpr(inner) then when resolve_parameterized_type(mono, inner.expr_type) in {
                                            .ReferenceType(ref_inner) then when resolve_parameterized_type(mono, ref_inner.val) in {
                                                .TraitObject(_, _) then inner,
                                                _ then base_expr,
                                            },
                                            .MutableReferenceType(ref_inner) then when resolve_parameterized_type(mono, ref_inner.val) in {
                                                .TraitObject(_, _) then inner,
                                                _ then base_expr,
                                            },
                                            _ then base_expr,
                                        },
                                        _ then base_expr,
                                    }
                                    return box(TypedExpr(
                                        box(TypedExprKind.TraitMethodCall(trait_receiver, trait_object_type, logical_method_name, method_index, new_args)),
                                        resolve_parameterized_type(mono, expr.expr_type)
                                    ))
                                }
                            },
                            _ then {},
                        },
                        .None() then {},
                    }
                },
                .MethodReference(base_expr, receiver_type, method, type_args, method_type_args, dispatch_callsite) then {
                    let resolved_base = base_expr
                    let declared_receiver_type = resolve_parameterized_type(mono, receiver_type)
                    let inferred_receiver_type = resolve_parameterized_type(mono, resolved_base.expr_type)
                    let effective_receiver_type = when inferred_receiver_type in {
                        .TraitObject(_, _) then inferred_receiver_type,
                        _ then if layout_key(declared_receiver_type) <> layout_key(inferred_receiver_type)
                            and not has_generic_parameter(inferred_receiver_type)
                            then inferred_receiver_type
                            else declared_receiver_type,
                    }
                    let resolved_call_type = resolve_parameterized_type(mono, expr.expr_type)
                    when try_lower_wrapping_generic_method_call(mono, resolved_base, method, new_args, resolved_call_type, dispatch_callsite) in {
                        .Some(lowered_expr) then { return lowered_expr },
                        .None() then {},
                    }
                    when try_lower_to_ref_method_call(mono, resolved_base, method, new_args, resolved_call_type, dispatch_callsite) in {
                        .Some(lowered_expr) then { return lowered_expr },
                        .None() then {},
                    }
                    let mut resolved_method_type_args = List[Type].new()
                    for method_type_arg in method_type_args then {
                        resolved_method_type_args.push(resolve_parameterized_type(mono, method_type_arg))
                    }
                    let method_name_for_lookup = get_semantic_method_name(mono, method)
                    let template_name_for_lookup = resolve_static_call_template_name(mono, effective_receiver_type)
                    let instantiated_method_lookup = enqueue_extension_method_for_static_call(
                        mono,
                        effective_receiver_type,
                        method_name_for_lookup,
                        template_name_for_lookup,
                        resolved_method_type_args,
                        new_args,
                        resolved_call_type,
                    )
                    let concrete_method_lookup = lookup_concrete_method_for_static_call(
                        mono,
                        effective_receiver_type,
                        method_name_for_lookup,
                        resolved_method_type_args,
                        new_args,
                        resolved_call_type,
                    )
                    let generic_rebound_method = try_bind_generic_method_call(
                        mono,
                        effective_receiver_type,
                        method,
                        new_args,
                        resolved_call_type,
                    ).val
                    let expected_method_type = resolve_parameterized_type(mono, new_callee.expr_type)
                    let mut expected_call_param_types = List[ref Type].new()
                    expected_call_param_types.push(box(resolve_parameterized_type(mono, effective_receiver_type)))
                    for arg in new_args then {
                        expected_call_param_types.push(box(resolve_parameterized_type(mono, arg.expr_type)))
                    }
                    let expected_call_type_with_receiver = Type.FunctionType(
                        types_to_param_entries(expected_call_param_types),
                        box(resolved_call_type)
                    )
                    let mut expected_call_arg_types = List[ref Type].new()
                    for arg in new_args then {
                        expected_call_arg_types.push(box(resolve_parameterized_type(mono, arg.expr_type)))
                    }
                    let expected_call_type_without_receiver = Type.FunctionType(
                        types_to_param_entries(expected_call_arg_types),
                        box(resolved_call_type)
                    )
                    let rebound_method_with_receiver = bind_receiver_method_symbol(
                        mono,
                        effective_receiver_type,
                        method,
                        Option[Type].Some(expected_call_type_with_receiver),
                    )
                    let rebound_method_with_declared = if rebound_method_with_receiver.def_id.id == method.def_id.id then {
                        yield bind_receiver_method_symbol(
                            mono,
                            effective_receiver_type,
                            method,
                            Option[Type].Some(expected_method_type),
                        )
                    } else rebound_method_with_receiver
                    let rebound_method = if rebound_method_with_declared.def_id.id == method.def_id.id then {
                        yield bind_receiver_method_symbol(
                            mono,
                            effective_receiver_type,
                            method,
                            Option[Type].Some(expected_call_type_without_receiver),
                        )
                    } else rebound_method_with_declared
                    let bound_method = when concrete_method_lookup in {
                        .Some(concrete_method) then when instantiated_method_lookup in {
                            .Some(instantiated_method) then instantiated_method,
                            .None() then concrete_method,
                        },
                        .None() then when instantiated_method_lookup in {
                            .Some(instantiated_method) then instantiated_method,
                            .None() then if generic_rebound_method.def_id.id <> method.def_id.id then {
                                yield generic_rebound_method
                            } else if rebound_method.def_id.id == method.def_id.id then {
                                yield try_bind_generic_method_call(
                                    mono,
                                    effective_receiver_type,
                                    method,
                                    new_args,
                                    resolved_call_type,
                                ).val
                            } else rebound_method,
                        },
                    }
                    let adapted_base = adapt_receiver_expr_for_method(mono, resolved_base, bound_method)
                    let resolved_type = resolved_callsite_result_type(mono, expr.expr_type, bound_method)
                    let effective_dispatch_callsite = ensure_receiver_dispatch_callsite(
                        mono,
                        dispatch_callsite,
                        effective_receiver_type,
                        bound_method,
                        Option[String].Some(mono.storage.context.symbol_name(method)),
                    )
                    when try_lower_wrapping_generic_method_call(mono, adapted_base, bound_method, new_args, resolved_type, effective_dispatch_callsite) in {
                        .Some(lowered_expr) then { return lowered_expr },
                        .None() then {},
                    }
                    when try_lower_to_ref_method_call(mono, adapted_base, bound_method, new_args, resolved_type, effective_dispatch_callsite) in {
                        .Some(lowered_expr) then { return lowered_expr },
                        .None() then {},
                    }
                    let receiver_trait_name_opt = when effective_receiver_type in {
                        .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                        .ReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                            .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                            _ then Option[String].None(),
                        },
                        .MutableReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                            .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                            _ then Option[String].None(),
                        },
                        .WeakReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                            .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                            _ then Option[String].None(),
                        },
                        .MutableWeakReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                            .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                            _ then Option[String].None(),
                        },
                        _ then Option[String].None(),
                    }
                    when receiver_trait_name_opt in {
                        .Some(trait_name) then {
                            let logical_method_name = when effective_dispatch_callsite in {
                                .Some(def_id) then when mono.receiver_method_dispatch_info(def_id) in {
                                    .Some(info) then info.method_name,
                                    .None() then get_semantic_method_name(mono, bound_method),
                                },
                                .None() then get_semantic_method_name(mono, bound_method),
                            }
                            if vtable_method_index(mono, trait_name, logical_method_name) < 0 then {
                                let callee_expr = box(TypedExpr(
                                    box(TypedExprKind.Variable(box(bound_method))),
                                    bound_method.symbol_type,
                                ))
                                let mut direct_args = List[ref TypedExpr].new()
                                direct_args.push(adapted_base)
                                for arg in new_args then {
                                    direct_args.push(arg)
                                }
                                return box(TypedExpr(box(TypedExprKind.Call(callee_expr, direct_args)), resolved_type))
                            }
                        },
                        .None() then {},
                    }
                    let rebound_callee = box(TypedExpr(
                        box(TypedExprKind.MethodReference(adapted_base, adapted_base.expr_type, box(bound_method), type_args, method_type_args, effective_dispatch_callsite)),
                        bound_method.symbol_type,
                    ))
                    return box(TypedExpr(box(TypedExprKind.Call(rebound_callee, new_args)), resolved_type))
                },
                .MemberPath(base_expr, path) then {
                    if not path.is_empty() and new_callee.expr_type is not .FunctionType(_, _) then {
                        let member_name = path[path.count() - 1]
                        let resolved_base = base_expr
                        let receiver_expr = if path.count() == 1 then resolved_base else {
                            let mut receiver_path = List[String].new()
                            let mut idx UInt = 0
                            while idx + 1 < path.count() then {
                                receiver_path.push(path[idx])
                                idx += 1
                            }
                            let receiver_type = resolve_member_path_type(mono, resolved_base.expr_type, receiver_path, expr.expr_type)
                            yield box(TypedExpr(box(TypedExprKind.MemberPath(resolved_base, receiver_path)), receiver_type))
                        }
                        let receiver_type = resolve_parameterized_type(mono, receiver_expr.expr_type)
                        let binding_receiver_type = when receiver_type in {
                            .ReferenceType(inner) then inner.val,
                            .MutableReferenceType(inner) then inner.val,
                            .WeakReferenceType(inner) then inner.val,
                            .MutableWeakReferenceType(inner) then inner.val,
                            _ then receiver_type,
                        }
                        when try_lower_wrapping_method_name_call(mono, receiver_expr, member_name, new_args, resolve_parameterized_type(mono, expr.expr_type)) in {
                            .Some(lowered_expr) then { return lowered_expr },
                            .None() then {},
                        }
                        // Lower to_ref intrinsic method on weakref types
                        if member_name == "to_ref" and new_args.count() == 0 then {
                            let base_type = resolve_parameterized_type(mono, receiver_expr.expr_type)
                            when base_type in {
                                .WeakReferenceType(inner) then {
                                    let ref_type = Type.ReferenceType(inner)
                                    let mut option_args = List[ref Type].new()
                                    option_args.push(box(ref_type))
                                    let option_type = Type.GenericEnum("Option", option_args)
                                    return box(TypedExpr(box(TypedExprKind.IntrinsicCall(TypedIntrinsic.UpgradeRef(receiver_expr, option_type))), option_type))
                                },
                                .MutableWeakReferenceType(inner) then {
                                    let ref_type = Type.MutableReferenceType(inner)
                                    let mut option_args = List[ref Type].new()
                                    option_args.push(box(ref_type))
                                    let option_type = Type.GenericEnum("Option", option_args)
                                    return box(TypedExpr(box(TypedExprKind.IntrinsicCall(TypedIntrinsic.UpgradeMutRef(receiver_expr, option_type))), option_type))
                                },
                                _ then {},
                            }
                        }
                        let dummy_method_def_id = mono.storage.context.allocate_unindexed(member_name, DefKind.Function())
                        let dummy_method = Symbol(dummy_method_def_id, Type.Unknown(), SymbolKind.Function())
                        let bound_method = try_bind_generic_method_call(
                            mono,
                            binding_receiver_type,
                            dummy_method,
                            new_args,
                            resolve_parameterized_type(mono, expr.expr_type),
                        ).val
                        if bound_method.def_id.id > 0 then {
                            let adapted_receiver = adapt_receiver_expr_for_method(mono, receiver_expr, bound_method)
                            let resolved_type = resolved_callsite_result_type(mono, expr.expr_type, bound_method)
                            let dispatch_callsite = ensure_receiver_dispatch_callsite(
                                mono,
                                .None(),
                                binding_receiver_type,
                                bound_method,
                                Option[String].Some(member_name),
                            )
                            when try_lower_wrapping_generic_method_call(mono, adapted_receiver, bound_method, new_args, resolved_type, dispatch_callsite) in {
                                .Some(lowered_expr) then { return lowered_expr },
                                .None() then {},
                            }
                            when try_lower_to_ref_method_call(mono, adapted_receiver, bound_method, new_args, resolved_type, dispatch_callsite) in {
                                .Some(lowered_expr) then { return lowered_expr },
                                .None() then {},
                            }
                            let rebound_callee = box(TypedExpr(
                                box(TypedExprKind.MethodReference(adapted_receiver, adapted_receiver.expr_type, box(bound_method), List[Type].new(), List[Type].new(), dispatch_callsite)),
                                bound_method.symbol_type,
                            ))
                            return box(TypedExpr(box(TypedExprKind.Call(rebound_callee, new_args)), resolved_type))
                        }
                    }
                },
                _ then {},
            }
            let mut bound_callee = bind_generic_function_call_callee(mono, new_callee, new_args, resolve_parameterized_type(mono, expr.expr_type))
            // Also try try_bind_generic_method_call for MethodReference callees
            // that were not resolved by bind_generic_function_call_callee.
            // This handles extension methods from given blocks (e.g. Path.join[T]).
            when new_callee.expr_kind in {
                .MethodReference(_, _, method_ref, _, _, _) then {
                    if new_args.count() > 0(UInt) then {
                        let receiver_type = resolve_parameterized_type(mono, new_args[0(UInt)].expr_type)
                        let binding_receiver_type = when receiver_type in {
                            .ReferenceType(inner) then inner.val,
                            .MutableReferenceType(inner) then inner.val,
                            .WeakReferenceType(inner) then inner.val,
                            .MutableWeakReferenceType(inner) then inner.val,
                            _ then receiver_type,
                        }
                        if not has_generic_parameter(binding_receiver_type) then {
                            let method_name = mono.storage.context.symbol_name(method_ref)
                            if not method_name.is_empty() then {
                                // Create a dummy method with the correct method name
                                // so try_bind_generic_method_call can find the extension method.
                                let dummy_def_id = mono.storage.context.allocate_unindexed(method_name, DefKind.Function())
                                let dummy_method = Symbol(dummy_def_id, Type.Unknown(), SymbolKind.Function())
                                let rebound = try_bind_generic_method_call(
                                    mono,
                                    binding_receiver_type,
                                    dummy_method,
                                    new_args,
                                    resolve_parameterized_type(mono, expr.expr_type),
                                ).val
                                if rebound.def_id.id > 0 then {
                                    let resolved_type = resolved_callsite_result_type(mono, expr.expr_type, rebound)
                                    let adapted_receiver = adapt_receiver_expr_for_method(mono, new_args[0(UInt)], rebound)
                                    let dispatch_callsite = ensure_receiver_dispatch_callsite(
                                        mono,
                                        .None(),
                                        binding_receiver_type,
                                        rebound,
                                        Option[String].Some(method_name),
                                    )
                                    let rebound_callee = box(TypedExpr(
                                        box(TypedExprKind.MethodReference(adapted_receiver, adapted_receiver.expr_type, box(rebound), List[Type].new(), List[Type].new(), dispatch_callsite)),
                                        rebound.symbol_type,
                                    ))
                                    return box(TypedExpr(box(TypedExprKind.Call(rebound_callee, new_args)), resolved_type))
                                }
                            }
                        }
                    }
                },
                _ then {},
            }
            when bound_callee.expr_kind in {
                .Variable(symbol) then {
                    if symbol.def_id.id == 0 and new_args.count() > 0(UInt) then {
                        // Get method name from new_callee, not from the dummy symbol
                        let normalized_name = when new_callee.expr_kind in {
                            .MethodReference(_, _, method_ref, _, _, _) then mono.storage.context.symbol_name(method_ref),
                            .Variable(orig_symbol) then get_semantic_method_name(mono, orig_symbol),
                            _ then get_semantic_method_name(mono, symbol),
                        }
                        let receiver_type = resolve_parameterized_type(mono, new_args[0(UInt)].expr_type)
                        let binding_receiver_type = when receiver_type in {
                            .ReferenceType(inner) then inner.val,
                            .MutableReferenceType(inner) then inner.val,
                            .WeakReferenceType(inner) then inner.val,
                            .MutableWeakReferenceType(inner) then inner.val,
                            _ then receiver_type,
                        }
                        if not has_generic_parameter(binding_receiver_type) then {
                            let mut method_args = List[ref TypedExpr].new()
                            let mut method_arg_index UInt = 1(UInt)
                            while method_arg_index < new_args.count() then {
                                method_args.push(new_args[method_arg_index])
                                method_arg_index += 1(UInt)
                            }

                            let rebound_method = try_bind_generic_method_call(
                                mono,
                                binding_receiver_type,
                                Symbol(mono.storage.context.allocate_unindexed(normalized_name, DefKind.Function()), symbol.symbol_type, SymbolKind.Function()),
                                method_args,
                                resolve_parameterized_type(mono, expr.expr_type),
                            ).val
                            if rebound_method.def_id.id > 0 then {
                                let resolved_type = resolved_callsite_result_type(mono, expr.expr_type, rebound_method)
                                let receiver_trait_name_opt = when binding_receiver_type in {
                                    .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                    .ReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                        .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                        _ then Option[String].None(),
                                    },
                                    .MutableReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                        .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                        _ then Option[String].None(),
                                    },
                                    .WeakReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                        .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                        _ then Option[String].None(),
                                    },
                                    .MutableWeakReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                        .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                        _ then Option[String].None(),
                                    },
                                    _ then Option[String].None(),
                                }
                                when receiver_trait_name_opt in {
                                    .Some(trait_name) then {
                                        if vtable_method_index(mono, trait_name, normalized_name) < 0 then {
                                            let callee_expr = box(TypedExpr(
                                                box(TypedExprKind.Variable(box(rebound_method))),
                                                rebound_method.symbol_type,
                                            ))
                                            return box(TypedExpr(box(TypedExprKind.Call(callee_expr, new_args)), resolved_type))
                                        }
                                    },
                                    .None() then {},
                                }
                                let dispatch_callsite = ensure_receiver_dispatch_callsite(
                                    mono,
                                    .None(),
                                    binding_receiver_type,
                                    rebound_method,
                                    Option[String].Some(normalized_name),
                                )
                                when try_lower_wrapping_generic_method_call(mono, new_args[0(UInt)], rebound_method, method_args, resolved_type, dispatch_callsite) in {
                                    .Some(lowered_expr) then { return lowered_expr },
                                    .None() then {},
                                }
                                when try_lower_to_ref_method_call(mono, new_args[0(UInt)], rebound_method, method_args, resolved_type, dispatch_callsite) in {
                                    .Some(lowered_expr) then { return lowered_expr },
                                    .None() then {},
                                }
                                let adapted_receiver = adapt_receiver_expr_for_method(mono, new_args[0(UInt)], rebound_method)
                                let rebound_callee = box(TypedExpr(
                                    box(TypedExprKind.MethodReference(adapted_receiver, adapted_receiver.expr_type, box(rebound_method), List[Type].new(), List[Type].new(), dispatch_callsite)),
                                    rebound_method.symbol_type,
                                ))
                                return box(TypedExpr(box(TypedExprKind.Call(rebound_callee, method_args)), resolved_type))
                            }

                            let type_key = when binding_receiver_type in {
                                .StructureType(def_id) then {
                                    let key = layout_key(binding_receiver_type)
                                    yield if key.is_empty() then mono.storage.context.get_name(def_id) or else key else key
                                },
                                .EnumType(def_id) then {
                                    let key = layout_key(binding_receiver_type)
                                    yield if key.is_empty() then mono.storage.context.get_name(def_id) or else key else key
                                },
                                _ then layout_key(binding_receiver_type),
                            }

                            instantiate_trait_placeholder_method(mono, binding_receiver_type, normalized_name, List[ref Type].new())
                            let lookup_key = make_extension_method_lookup_key(mono, type_key, normalized_name, List[ref Type].new())
                            when mono.storage.extension_method_def_ids.get(lookup_key) in {
                                .Some(def_id) then {
                                    let rebound_symbol = resolved_method_symbol(mono, def_id, normalized_name, symbol.symbol_type)
                                    bound_callee = box(TypedExpr(box(TypedExprKind.Variable(box(rebound_symbol))), rebound_symbol.symbol_type))
                                },
                                .None() then {},
                            }
                        }
                    }
                },
                _ then {},
            }
            let declared_resolved_type = resolve_parameterized_type(mono, expr.expr_type)
            let resolved_type = if not has_generic_parameter(declared_resolved_type)
                then declared_resolved_type
                else when bound_callee.expr_type in {
                    .FunctionType(_, return_type_ref) then resolve_parameterized_type(mono, return_type_ref.val),
                    _ then declared_resolved_type,
                }
            if bound_callee.expr_kind is .AndExpr(_, _) or bound_callee.expr_kind is .OrExpr(_, _) then {
                panic("mono produced invalid call callee: original=\(mono_debug_expr_kind(callee)) resolved=\(mono_debug_expr_kind(new_callee)) bound=\(mono_debug_expr_kind(bound_callee)) result=\(layout_key(resolved_type)) args=\(new_args.count().to_string())")
            }
            when callee.expr_kind in {
                .Variable(original_symbol) then when original_symbol.kind in {
                    .Function() then {
                        let bound_is_callable = when bound_callee.expr_kind in {
                            .Variable(bound_symbol) then when bound_symbol.kind in {
                                .Function() then true,
                                _ then false,
                            },
                            .MethodReference(_, _, _, _, _, _) then true,
                            .TraitMethodPlaceholder(_, _, _, _, _) then true,
                            .Call(_, _) then true,
                            _ then false,
                        }
                        if not bound_is_callable then {
                            panic("mono invalid function callee: original=\(mono_debug_expr_kind(callee)) resolved=\(mono_debug_expr_kind(new_callee)) bound=\(mono_debug_expr_kind(bound_callee)) result=\(layout_key(resolved_type)) args=\(new_args.count().to_string())")
                        }
                    },
                    _ then {},
                },
                _ then {},
            }
            let final_callee = when callee.expr_kind in {
                .Variable(original_symbol) then when original_symbol.kind in {
                    .Function() then when bound_callee.expr_kind in {
                        .Variable(bound_symbol) then {
                            let stable_symbol = when bound_symbol.kind in {
                                .Function() then bound_symbol,
                                _ then resolve_symbol_type(mono, original_symbol),
                            }
                            yield box(TypedExpr(box(TypedExprKind.Variable(box(stable_symbol))), stable_symbol.symbol_type))
                        },
                        _ then bound_callee,
                    },
                    _ then bound_callee,
                },
                _ then bound_callee,
            }
            return box(TypedExpr(box(TypedExprKind.Call(final_callee, new_args)), resolved_type))
        },
        _ then {},
    }
    let resolved_kind = resolve_expr_kind(mono, expr)
    let resolved_type = when resolved_kind in {
        .Variable(symbol) then symbol.symbol_type,
        .ArithmeticExpr(left, _, right) then {
            let left_t = left.expr_type
            let right_t = right.expr_type
            let declared_type = resolve_parameterized_type(mono, expr.expr_type)
            let mut result_type = declared_type
            if layout_key(left_t) == layout_key(right_t) then {
                result_type = left_t
            } else if mono_is_unresolved_expr_type(mono, declared_type) then {
                if is_concrete_numeric_type(left_t) then {
                    result_type = left_t
                } else if is_concrete_numeric_type(right_t) then {
                    result_type = right_t
                }
            }
            yield result_type
        },
        .BitwiseExpr(left, _, right) then {
            let left_t = left.expr_type
            let right_t = right.expr_type
            let declared_type = resolve_parameterized_type(mono, expr.expr_type)
            let mut result_type = declared_type
            if layout_key(left_t) == layout_key(right_t) then {
                result_type = left_t
            } else if mono_is_unresolved_expr_type(mono, declared_type) then {
                if is_concrete_integer_type(left_t) then {
                    result_type = left_t
                } else if is_concrete_integer_type(right_t) then {
                    result_type = right_t
                }
            }
            yield result_type
        },
        .WrappingArithmeticExpr(_, _, _) then resolve_parameterized_type(mono, expr.expr_type),
        .WrappingShiftExpr(_, _, _) then resolve_parameterized_type(mono, expr.expr_type),
        .MemberPath(base, path) then resolve_member_path_type(mono, base.expr_type, path, expr.expr_type),
        .TypeConstruction(identifier, type_args, args) then recover_type_construction_type(mono, identifier.symbol_type, identifier.def_id, type_args, args),
        _ then resolve_parameterized_type(mono, expr.expr_type),
    }

    return box(TypedExpr(resolved_kind, resolved_type))
}

private let mono_debug_expr_kind(expr ref TypedExpr) String = {
    return when expr.expr_kind in {
        .Variable(symbol) then "variable:\(symbol.def_id.id):\(layout_key(symbol.symbol_type))",
        .MethodReference(base, _, method, _, _, _) then "method-ref:\(method.def_id.id):base=\(layout_key(base.expr_type))",
        .Call(callee, args) then "call(callee=\(mono_debug_expr_kind(callee)),args=\(args.count().to_string()))",
        .StaticMethodCall(receiver_type, method_name, method, _, _, args) then "static:\(method_name)#\(method.def_id.id):receiver=\(layout_key(receiver_type)):args=\(args.count().to_string())",
        .MemberPath(base, path) then "member:\(path.join_to_string(".")):base=\(layout_key(base.expr_type))",
        .AndExpr(_, _) then "and",
        .OrExpr(_, _) then "or",
        .ComparisonExpr(_, _, _) then "comparison",
        .ArithmeticExpr(_, _, _) then "arithmetic",
        .WrappingArithmeticExpr(_, _, _) then "wrapping-arithmetic",
        .WrappingShiftExpr(_, _, _) then "wrapping-shift",
        .BitwiseExpr(_, _, _) then "bitwise",
        .Unary(_, _) then "unary",
        .CastExpr(target_type, inner) then "cast:\(layout_key(inner.expr_type))->\(layout_key(target_type))",
        .RefExpr(inner) then "ref:\(layout_key(inner.expr_type))",
        .PtrExpr(inner) then "ptr:\(layout_key(inner.expr_type))",
        .DerefExpr(inner) then "deref:\(layout_key(inner.expr_type))",
        .Block(_) then "block",
        .IfExpr(_, _, _) then "if",
        .WhenExpr(_, _) then "when",
        .LambdaExpr(_, _, _) then "lambda",
        .TypeConstruction(identifier, _, args) then "type:\(identifier.def_id.id):args=\(args.count().to_string())",
        .EnumConstruction(_, case_name, args) then "enum:\(case_name):args=\(args.count().to_string())",
        .TraitMethodPlaceholder(_, _, method, _, _) then "trait-placeholder:\(method.def_id.id)",
        .TraitObjectConversion(_, trait_type, _) then "trait-object:\(layout_key(trait_type))",
        .TraitMethodCall(_, trait_type, method_name, _, args) then "trait-call:\(method_name):trait=\(layout_key(trait_type)):args=\(args.count().to_string())",
        .GenericCall(function_symbol, _, args) then "generic:\(function_symbol.def_id.id):args=\(args.count().to_string())",
        .IntrinsicCall(_) then "intrinsic",
        .GenericInstantiation(base_type, _) then "generic-inst:\(layout_key(base_type))",
        .IsExpr(_, _, _) then "is",
        .IntegerLiteral(_) then "int",
        .FloatLiteral(_) then "float",
        .StringLiteral(_) then "string",
        .BoolLiteral(_) then "bool",
    }
}

private let resolve_member_field_type(
    mono ref Monomorphizer,
    base_type Type,
    member_name String,
    fallback Type,
) Type = {
    let resolved_base = resolve_parameterized_type(mono, base_type)
    when resolved_base in {
        .ReferenceType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .MutableReferenceType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .WeakReferenceType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .MutableWeakReferenceType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .PointerType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .MutablePointerType(inner) then {
            return resolve_member_field_type(mono, inner.val, member_name, fallback)
        },
        .GenericStruct(template_name, args) then {
            if template_name == "Pair" and args.count() == 2(UInt) then {
                when member_name in {
                    "first" then {
                        return resolve_parameterized_type(mono, args[0(UInt)].val)
                    },
                    "second" then {
                        return resolve_parameterized_type(mono, args[1(UInt)].val)
                    },
                    _ then {},
                }
            }
            when mono.storage.generic_templates.lookup_struct(template_name) in {
                .Some(template) then {
                    let mut subst = Dict[String, Type].new()
                    let mut i UInt = 0
                    while i < template.type_parameters.count() and i < args.count() then {
                        subst.insert(template.type_parameters[i].name, args[i].val)
                        i += 1
                    }
                    for field in template.fields then {
                        if field.name == member_name then {
                            return resolve_parameterized_type(mono, mono.resolve_type_node_impl(field.field_type, subst))
                        }
                    }
                },
                .None() then {},
            }
        },
        .StructureType(def_id) then {
            when mono.storage.context.get_struct_fields(def_id) in {
                .Some(fields) then {
                    for field in fields then {
                        if field.name == member_name then {
                            return resolve_parameterized_type(mono, field.field_type)
                        }
                    }
                },
                .None() then {},
            }
        },
        _ then {},
    }
    return resolve_parameterized_type(mono, fallback)
}

private let resolve_member_path_type(
    mono ref Monomorphizer,
    base_type Type,
    path List[String],
    fallback Type,
) Type = {
    let mut current = resolve_parameterized_type(mono, base_type)
    for member_name in path then {
        current = resolve_member_field_type(mono, current, member_name, fallback)
    }
    return current
}

private let mono_enum_case_name_matches(pattern_case_name String, enum_case_name String) Bool = {
    if enum_case_name == pattern_case_name then { return true }
    if enum_case_name.ends_with("_" + pattern_case_name) then { return true }

    let pattern_tail = when pattern_case_name.split_last_once(".") in {
        .Some(parts) then parts.second,
        .None() then pattern_case_name,
    }
    if enum_case_name == pattern_tail then { return true }
    if enum_case_name.ends_with("_" + pattern_tail) then { return true }

    let enum_tail = when enum_case_name.split_last_once("_") in {
        .Some(parts) then parts.second,
        .None() then enum_case_name,
    }
    return enum_tail == pattern_tail
}

private let mono_get_enum_case_field_types(
    mono ref Monomorphizer,
    subject_type Type,
    tag_index UInt,
    case_name String,
) List[Type] = {
    let inner_type = when subject_type in {
        .ReferenceType(inner) then inner.val,
        .MutableReferenceType(inner) then inner.val,
        .WeakReferenceType(inner) then inner.val,
        .MutableWeakReferenceType(inner) then inner.val,
        _ then subject_type,
    }
    return when inner_type in {
        .EnumType(def_id) then when mono.storage.context.get_enum_cases(def_id) in {
            .Some(cases) then {
                let mut result = List[Type].new()
                let mut matched = false
                let mut i UInt = 0
                for case_info in cases then {
                    let index_match = i == tag_index
                    let name_match = mono_enum_case_name_matches(case_name, case_info.name)
                    if not matched and (index_match or name_match) then {
                        for param in case_info.params then {
                            result.push(resolve_parameterized_type(mono, param.param_type))
                        }
                        matched = true
                    }
                    i += 1
                }
                yield result
            },
            .None() then List[Type].new(),
        },
        .GenericEnum(template_name, args) then {
            yield when mono.storage.generic_templates.lookup_enum(template_name) in {
                .Some(enum_template) then when mono.storage.context.get_enum_cases(enum_template.def_id) in {
                    .Some(cases) then {
                        let mut bindings = Dict[String, Type].new()
                        let mut i UInt = 0
                        let param_count = enum_template.type_parameters.count()
                        let arg_count = args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = enum_template.type_parameters[i]
                            bindings.insert(tp.name, args[i].val)
                            i += 1
                        }
                        let mut result = List[Type].new()
                        let mut matched = false
                        let mut case_index UInt = 0
                        for case_info in cases then {
                            let index_match = case_index == tag_index
                            let name_match = mono_enum_case_name_matches(case_name, case_info.name)
                            if not matched and (index_match or name_match) then {
                                for param in case_info.params then {
                                    let concrete_param_type = resolve_parameterized_type(mono, substitute_type(mono, param.param_type, bindings))
                                    result.push(concrete_param_type)
                                }
                                matched = true
                            }
                            case_index += 1
                        }
                        yield result
                    },
                    .None() then List[Type].new(),
                },
                .None() then List[Type].new(),
            }
        },
        _ then List[Type].new(),
    }
}

private let mono_get_struct_pattern_field_types(
    mono ref Monomorphizer,
    subject_type Type,
    type_name String,
) List[Type] = {
    let inner_type = when subject_type in {
        .ReferenceType(inner) then inner.val,
        .MutableReferenceType(inner) then inner.val,
        .WeakReferenceType(inner) then inner.val,
        .MutableWeakReferenceType(inner) then inner.val,
        _ then subject_type,
    }
    return when inner_type in {
        .StructureType(def_id) then {
            let actual_name = mono.storage.context.get_name(def_id) or else mono.storage.context.type_display_name(inner_type)
            let mut result = List[Type].new()
            if actual_name == type_name then {
                when mono.storage.context.get_struct_fields(def_id) in {
                    .Some(fields) then {
                        for field in fields then {
                            result.push(resolve_parameterized_type(mono, field.field_type))
                        }
                    },
                    .None() then {},
                }
            }
            yield result
        },
        .GenericStruct(template_name, args) then {
            let mut result = List[Type].new()
            if template_name == type_name then {
                when mono.storage.generic_templates.lookup_struct(template_name) in {
                    .Some(struct_template) then when mono.storage.context.get_struct_fields(struct_template.def_id) in {
                        .Some(fields) then {
                            let mut bindings = Dict[String, Type].new()
                            let mut i UInt = 0
                            let param_count = struct_template.type_parameters.count()
                            let arg_count = args.count()
                            let n = if param_count < arg_count then param_count else arg_count
                            while i < n then {
                                let tp = struct_template.type_parameters[i]
                                bindings.insert(tp.name, args[i].val)
                                i += 1
                            }
                            for field in fields then {
                                result.push(resolve_parameterized_type(mono, substitute_type(mono, field.field_type, bindings)))
                            }
                        },
                        .None() then {},
                    },
                    .None() then {},
                }
            }
            yield result
        },
        _ then List[Type].new(),
    }
}

private let mono_collect_pattern_binding_types(
    mono ref Monomorphizer,
    pattern ref TypedPattern,
    subject_type Type,
    bindings mut ref Dict[UInt, Type],
) Void = {
    let concrete_subject_type = resolve_parameterized_type(mono, subject_type)
    when pattern in {
        .Variable(symbol) then {
            if mono.storage.context.symbol_name(symbol) <> "_" and symbol.def_id.id <> 0 then {
                bindings.insert(symbol.def_id.id, concrete_subject_type)
            }
        },
        .EnumCase(case_name, tag_index, elements) then {
            let field_types = mono_get_enum_case_field_types(mono, concrete_subject_type, tag_index, case_name)
            let mut i UInt = 0
            for element in elements then {
                let field_type = when field_types.get(i) in {
                    .Some(t) then t,
                    .None() then Type.Unknown(),
                }
                mono_collect_pattern_binding_types(mono, element.pattern, field_type, bindings)
                i += 1
            }
        },
        .StructPattern(type_name, elements) then {
            let field_types = mono_get_struct_pattern_field_types(mono, concrete_subject_type, type_name)
            let mut i UInt = 0
            for element in elements then {
                let field_type = when field_types.get(i) in {
                    .Some(t) then t,
                    .None() then Type.Unknown(),
                }
                mono_collect_pattern_binding_types(mono, element.pattern, field_type, bindings)
                i += 1
            }
        },
        .AndPattern(left, right) then {
            mono_collect_pattern_binding_types(mono, left, concrete_subject_type, bindings)
            mono_collect_pattern_binding_types(mono, right, concrete_subject_type, bindings)
        },
        .OrPattern(left, right) then {
            mono_collect_pattern_binding_types(mono, left, concrete_subject_type, bindings)
            mono_collect_pattern_binding_types(mono, right, concrete_subject_type, bindings)
        },
        .NotPattern(inner) then {
            mono_collect_pattern_binding_types(mono, inner, concrete_subject_type, bindings)
        },
        _ then {},
    }
}

private let mono_register_pattern_binding_symbol_type(
    mono ref Monomorphizer,
    symbol ref Symbol,
    bindings Dict[UInt, Type],
) Void = {
    if symbol.def_id.id == 0 then { return }
    when bindings.get(symbol.def_id.id) in {
        .Some(bound_type) then {
            let current_type = resolve_symbol_type(mono, symbol).symbol_type
            if (mono_is_unresolved_expr_type(mono, current_type) or has_generic_parameter(current_type))
                and not mono_is_unresolved_expr_type(mono, bound_type)
                and not has_generic_parameter(bound_type)
            then {
                let symbol_kind = when mono.storage.context.get_symbol_kind(symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then symbol.kind,
                }
                let symbol_method_kind = when mono.storage.context.get_symbol_method_kind(symbol.def_id) in {
                    .Some(kind) then kind,
                    .None() then MethodKind.Normal(),
                }
                let symbol_mutable = when mono.storage.context.get_symbol_mutable(symbol.def_id) in {
                    .Some(mutable) then mutable,
                    .None() then false,
                }
                mono.storage.context.set_symbol_info(symbol.def_id, SymbolInfo(bound_type, symbol_kind, symbol_method_kind, symbol_mutable))
            }
        },
        .None() then {},
    }
}

private let mono_register_pattern_binding_types_in_statement(
    mono ref Monomorphizer,
    stmt ref TypedStatement,
    bindings Dict[UInt, Type],
) Void = {
    when stmt in {
        .LetStmt(_, value, _) then mono_register_pattern_binding_types_in_expr(mono, value, bindings),
        .PairLetStmt(_, _, value, _) then mono_register_pattern_binding_types_in_expr(mono, value, bindings),
        .AssignmentStmt(target, value, _) then {
            mono_register_pattern_binding_types_in_expr(mono, target, bindings)
            mono_register_pattern_binding_types_in_expr(mono, value, bindings)
        },
        .ExprStmt(expr, _) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
        .IfStmt(condition, then_branch, else_branch, _) then {
            mono_register_pattern_binding_types_in_expr(mono, condition, bindings)
            mono_register_pattern_binding_types_in_expr(mono, then_branch, bindings)
            when else_branch in {
                .Some(expr) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
                .None() then {},
            }
        },
        .WhileStmt(condition, body, _) then {
            mono_register_pattern_binding_types_in_expr(mono, condition, bindings)
            mono_register_pattern_binding_types_in_expr(mono, body, bindings)
        },
        .WhenStmt(subject, arms, _) then {
            mono_register_pattern_binding_types_in_expr(mono, subject, bindings)
            for arm_ref in arms then {
                mono_register_pattern_binding_types_in_expr(mono, arm_ref.body, bindings)
            }
        },
        .ReturnStmt(value, _) then when value in {
            .Some(expr) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
            .None() then {},
        },
        .FinallyStmt(expr, _) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
        .YieldStmt(expr, _) then mono_register_pattern_binding_types_in_expr(mono, expr, bindings),
        _ then {},
    }
}

private let mono_register_pattern_binding_types_in_expr(
    mono ref Monomorphizer,
    expr ref TypedExpr,
    bindings Dict[UInt, Type],
) Void = {
    when expr.expr_kind in {
        .Variable(symbol) then mono_register_pattern_binding_symbol_type(mono, symbol, bindings),
        .CastExpr(_, inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .TraitObjectConversion(inner, _, _) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .Unary(_, inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .RefExpr(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .PtrExpr(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .DerefExpr(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings),
        .ArithmeticExpr(left, _, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .ComparisonExpr(left, _, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .BitwiseExpr(left, _, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .AndExpr(left, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .OrExpr(left, right) then {
            mono_register_pattern_binding_types_in_expr(mono, left, bindings)
            mono_register_pattern_binding_types_in_expr(mono, right, bindings)
        },
        .IsExpr(subject, _, _) then mono_register_pattern_binding_types_in_expr(mono, subject, bindings),
        .Call(callee, args) then {
            mono_register_pattern_binding_types_in_expr(mono, callee, bindings)
            for arg in args then { mono_register_pattern_binding_types_in_expr(mono, arg, bindings) }
        },
        .MemberPath(base, _) then mono_register_pattern_binding_types_in_expr(mono, base, bindings),
        .Block(statements) then for stmt_ref in statements then { mono_register_pattern_binding_types_in_statement(mono, stmt_ref, bindings) },
        .IfExpr(condition, then_branch, else_branch) then {
            mono_register_pattern_binding_types_in_expr(mono, condition, bindings)
            mono_register_pattern_binding_types_in_expr(mono, then_branch, bindings)
            when else_branch in { .Some(inner) then mono_register_pattern_binding_types_in_expr(mono, inner, bindings), .None() then {} }
        },
        .WhenExpr(subject, arms) then {
            mono_register_pattern_binding_types_in_expr(mono, subject, bindings)
            for arm_ref in arms then { mono_register_pattern_binding_types_in_expr(mono, arm_ref.body, bindings) }
        },
        .LambdaExpr(_, _, body) then mono_register_pattern_binding_types_in_expr(mono, body, bindings),
        .StaticMethodCall(_, _, _, _, _, args) then for arg in args then { mono_register_pattern_binding_types_in_expr(mono, arg, bindings) },
        .IntrinsicCall(node) then {
            when node in {
                .IsUniqueMutable(ref_expr) then mono_register_pattern_binding_types_in_expr(mono, ref_expr, bindings),
                .RefCount(ref_expr) then mono_register_pattern_binding_types_in_expr(mono, ref_expr, bindings),
                .MakeRef(pointer_expr, owner_expr, _) then {
                    mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, owner_expr, bindings)
                },
                .MakeMutRef(pointer_expr, owner_expr, _) then {
                    mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, owner_expr, bindings)
                },
                .DowngradeRef(ref_expr, _) then mono_register_pattern_binding_types_in_expr(mono, ref_expr, bindings),
                .DowngradeMutRef(ref_expr, _) then mono_register_pattern_binding_types_in_expr(mono, ref_expr, bindings),
                .UpgradeRef(weak_expr, _) then mono_register_pattern_binding_types_in_expr(mono, weak_expr, bindings),
                .UpgradeMutRef(weak_expr, _) then mono_register_pattern_binding_types_in_expr(mono, weak_expr, bindings),
                .SpawnThread(out_handle, out_tid, closure, stack_size) then {
                    mono_register_pattern_binding_types_in_expr(mono, out_handle, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, out_tid, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, closure, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, stack_size, bindings)
                },
                .AllocMemory(count, _) then mono_register_pattern_binding_types_in_expr(mono, count, bindings),
                .DeallocMemory(pointer_expr) then mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings),
                .CopyMemory(dest, source, count) then {
                    mono_register_pattern_binding_types_in_expr(mono, dest, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, source, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, count, bindings)
                },
                .MoveMemory(dest, source, count) then {
                    mono_register_pattern_binding_types_in_expr(mono, dest, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, source, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, count, bindings)
                },
                .InitMemory(pointer_expr, value_expr) then {
                    mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings)
                    mono_register_pattern_binding_types_in_expr(mono, value_expr, bindings)
                },
                .DeinitMemory(pointer_expr) then mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings),
                .TakeMemory(pointer_expr, _) then mono_register_pattern_binding_types_in_expr(mono, pointer_expr, bindings),
                .NullPtr(_) then {},
            }
        },
        _ then {},
    }
}

// Try to bind a generic top-level function call callee to a concrete instantiated
// function symbol using call-site argument types.
private let bind_generic_function_call_callee(
    mono ref Monomorphizer,
    callee ref TypedExpr,
    args List[ref TypedExpr],
    expected_return_type Type,
) ref TypedExpr = {
    when callee.expr_kind in {
        .Variable(symbol) then {
            let has_ambiguous_remap = when mono.storage.remapped_function_def_ids.get(symbol.def_id.id) in {
                .Some(remapped_list) then remapped_list.count() > 1,
                .None() then false,
            }
            // Swift-aligned fast path: only reuse an existing concrete callee when
            // the full call shape is already concrete and matches exactly.
            if symbol.def_id.id > 0 then {
                when mono.storage.remapped_function_def_ids.get(symbol.def_id.id) in {
                    .Some(remapped_list) then {
                        let mut call_param_types = List[ref Type].new()
                        let mut can_disambiguate = not is_placeholder_inferred_type(expected_return_type)
                        for arg in args then {
                            let arg_type = resolve_parameterized_type(mono, arg.expr_type)
                            if is_placeholder_inferred_type(arg_type) then {
                                can_disambiguate = false
                            }
                            call_param_types.push(box(arg_type))
                        }

                        if can_disambiguate then {
                            let expected_call_type = Type.FunctionType(types_to_param_entries(call_param_types), box(resolve_parameterized_type(mono, expected_return_type)))
                            for remapped in remapped_list then {
                                let candidate_def_id = remapped.first
                                let candidate_type = resolve_parameterized_type(mono, remapped.second)
                                if layout_key(candidate_type) == layout_key(expected_call_type) then {
                                    let concrete_name = when mono.storage.context.get_name(candidate_def_id) in {
                                        .Some(name) then name,
                                        .None() then mono.storage.context.symbol_name(symbol),
                                    }
                                    let concrete_symbol = Symbol(candidate_def_id, candidate_type, SymbolKind.Function())
                                    return box(TypedExpr(box(TypedExprKind.Variable(box(concrete_symbol))), candidate_type))
                                }
                            }
                        }
                    },
                    .None() then {},
                }
            }

            // Find generic function template by DefId first to avoid collisions
            // between helpers that share the same textual name across modules.
            let template_opt = if symbol.def_id.id > 0 then mono.storage.generic_templates.lookup_function_by_def_id(symbol.def_id)
                else Option[ref GenericFunctionTemplate].None()
            // If this is a method call (has arguments) and the template has a
            // receiver parameter, it might be an extension method from a given block
            // (e.g. Path.join[T]). Route through try_bind_generic_method_call so
            // the monomorphizer can properly instantiate it.
            when template_opt in {
                .Some(t) then {
                    if not args.is_empty() and not t.parameters.is_empty() and t.parameters[0(UInt)].name == "self" then {
                        let dummy_type = resolve_parameterized_type(mono, symbol.symbol_type)
                        return box(TypedExpr(box(TypedExprKind.Variable(box(Symbol(DefId(0), dummy_type, SymbolKind.Function())))), dummy_type))
                    }
                },
                .None() then {},
            }
            let template = when template_opt in {
                .Some(t) then t,
                .None() then {
                    if symbol.def_id.id > 0 and not has_generic_parameter(resolve_parameterized_type(mono, symbol.symbol_type)) and not has_ambiguous_remap then {
                        // If the call has arguments (method call), this might be an extension
                        // method from a given block (e.g. Path.join[T]).
                        // Route through try_bind_generic_method_call.
                        if not args.is_empty() then {
                            let dummy_type = resolve_parameterized_type(mono, symbol.symbol_type)
                            return box(TypedExpr(box(TypedExprKind.Variable(box(Symbol(DefId(0), dummy_type, SymbolKind.Function())))), dummy_type))
                        }
                        return callee
                    }
                    let symbol_name = mono.storage.context.symbol_name(symbol)
                    yield when mono.storage.generic_templates.lookup_function(symbol_name) in {
                        .Some(by_name) then by_name,
                        .None() then {
                            yield when mono.storage.context.get_name(symbol.def_id) in {
                                .Some(def_name) then when mono.storage.generic_templates.lookup_function(def_name) in {
                                    .Some(named) then named,
                                    .None() then { return callee },
                                },
                                .None() then { return callee },
                            }
                        },
                    }
                },
            }

            // Symbols may lose template DefId during substitution passes.
            // Keep name-based binding so generic helper calls can still be
            // instantiated in monomorphization, matching Swift's call flow.
            if template.type_parameters.is_empty() then { return callee }

            let mut inferred = Dict[String, Type].new()
            let mut type_param_names = List[String].new()
            for tp in template.type_parameters then {
                type_param_names.push(tp.name)
            }

            // Infer generic type arguments from template parameter TypeNodes and call args.
            let mut i UInt = 0
            while i < template.parameters.count() and i < args.count() then {
                let expected_node = template.parameters[i].param_type
                let actual = infer_generic_function_call_argument_type(mono, args[i].val)
                collect_generic_bindings_from_type_node(mono, expected_node, actual, template.type_parameters, inferred.ref)
                i += 1
            }

            let concrete_expected_return = resolve_parameterized_type(mono, expected_return_type)
            if not has_generic_parameter(concrete_expected_return) then {
                let mut pattern_param_types = List[ref Type].new()
                when template.checked_parameters in {
                    .Some(checked_params) then {
                        for param in checked_params then {
                            pattern_param_types.push(box(param.symbol_type))
                        }
                    },
                    .None() then {
                        for param in template.parameters then {
                            pattern_param_types.push(box(resolve_type_node(mono, param.param_type, Dict[String, Type].new())))
                        }
                    },
                }

                let pattern_return_type = when template.checked_return_type in {
                    .Some(checked_ret) then checked_ret,
                    .None() then resolve_type_node(mono, template.return_type, Dict[String, Type].new()),
                }

                let mut actual_param_types = List[ref Type].new()
                for arg in args then {
                    actual_param_types.push(box(infer_generic_function_call_argument_type(mono, arg)))
                }

                let pattern_call_type = make_function_type(pattern_param_types, pattern_return_type)
                let actual_call_type = make_function_type(actual_param_types, concrete_expected_return)
                let _matched = unify_generic_type_pattern(mono, pattern_call_type, actual_call_type, type_param_names, inferred.ref)
            }

            // Generic intrinsic functions are runtime-provided, but their symbol
            // type still needs concrete substitutions so downstream codegen uses
            // the right ref/weakref/option layouts.
            let is_intrinsic_template = template.checked_body is .None()
            if is_intrinsic_template then {
                let intrinsic_type = when template.checked_return_type in {
                    .Some(ret_ty) then {
                        let mut ps = List[ref Type].new()
                        when template.checked_parameters in {
                            .Some(params) then {
                                for p in params then {
                                    let param_type = resolve_parameterized_type(mono, substitute_type(mono, p.symbol_type, inferred))
                                    ps.push(box(param_type))
                                }
                            },
                            .None() then {
                            },
                        }
                        let resolved_return = resolve_parameterized_type(mono, substitute_type(mono, ret_ty, inferred))
                        yield make_function_type(ps, resolved_return)
                    },
                    .None() then resolve_parameterized_type(mono, substitute_type(mono, symbol.symbol_type, inferred)),
                }
                let intrinsic_symbol = Symbol(template.def_id, intrinsic_type, SymbolKind.Function())
                return box(TypedExpr(box(TypedExprKind.Variable(box(intrinsic_symbol))), intrinsic_type))
            }

            let mut type_args = List[ref Type].new()
            for tp in template.type_parameters then {
                let inferred_arg = when inferred.get(tp.name) in {
                    .Some(t) then resolve_parameterized_type(mono, t),
                    .None() then {
                        // Fallback to expected call return type when template return is this type parameter.
                        let from_expected_return = when template.return_type in {
                            .Identifier(ret_name) then ret_name == tp.name,
                            _ then false,
                        }
                        let constrained_by_params = template_type_parameter_constrained_by_parameters(template, tp.name)
                        yield if from_expected_return and not constrained_by_params and not has_generic_parameter(concrete_expected_return)
                            then concrete_expected_return
                            else Type.GenericParameter(tp.name)
                    },
                }
                let canonical_arg = canonical_type_for_generic_binding(mono, inferred_arg)
                if has_generic_parameter(canonical_arg) then {
                    return callee
                }
                type_args.push(box(canonical_arg))
            }

            if args_have_generic_parameter(type_args) then {
                return callee
            }

            let instantiated = mono.instantiate_function_impl(template, type_args)
            if instantiated.mangled_name.is_empty() then { return callee }

            let bound_symbol = when mono.storage.instantiated_function_symbols.get(instantiated.mangled_name) in {
                .Some(sym) then sym,
                .None() then { return callee },
            }
            let concrete_type = when mono.storage.context.get_function_type(bound_symbol.def_id) in {
                .Some(function_type) then function_type,
                .None() then bound_symbol.symbol_type,
            }
            let concrete_symbol = Symbol(bound_symbol.def_id, concrete_type, SymbolKind.Function())
            return box(TypedExpr(box(TypedExprKind.Variable(box(concrete_symbol))), concrete_type))
        },
        _ then {},
    }
    return callee
}

private let infer_generic_function_call_argument_type(
    mono ref Monomorphizer,
    arg ref TypedExpr,
) Type = {
    let resolved = resolve_parameterized_type(mono, arg.expr_type)
    if not has_generic_parameter(resolved) then {
        return resolved
    }
    return when arg.expr_kind in {
        .IntegerLiteral(_) then Type.IntType(),
        .FloatLiteral(_) then Type.Float64Type(),
        _ then resolved,
    }
}

// Collect GenericParameter -> concrete Type bindings by structurally matching a
// template parameter TypeNode against an actual call-site type.
private let collect_generic_bindings_from_type_node(
    mono ref Monomorphizer,
    expected_node TypeNode,
    actual Type,
    type_params List[TypeParameterDecl],
    bindings mut ref Dict[String, Type],
) Void = {
    when expected_node in {
        .Identifier(name) then {
            if is_type_parameter_name(name, type_params) then {
                when actual in {
                    .GenericParameter(actual_name) then {
                        if is_type_parameter_name(actual_name, type_params) then {
                            return
                        }
                    },
                    _ then {},
                }
                when bindings.get(name) in {
                    .Some(existing) then {
                        if is_placeholder_inferred_type(existing) and not is_placeholder_inferred_type(actual) then {
                            bindings.insert(name, actual)
                        }
                    },
                    .None() then {
                        bindings.insert(name, actual)
                    },
                }
            }
        },
        .Reference(inner, _) then {
            when actual in {
                .ReferenceType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                .MutableReferenceType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                _ then {},
            }
        },
        .Pointer(inner, _) then {
            when actual in {
                .PointerType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                .MutablePointerType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                _ then {},
            }
        },
        .WeakReference(inner, _) then {
            when actual in {
                .WeakReferenceType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                .MutableWeakReferenceType(act_inner) then collect_generic_bindings_from_type_node(mono, inner.val, act_inner.val, type_params, bindings),
                _ then {},
            }
        },
        .Generic(base, args) then {
            when actual in {
                .GenericStruct(act_base, act_args) then {
                    if base == act_base then {
                        let mut i UInt = 0
                        while i < args.count() and i < act_args.count() then {
                            collect_generic_bindings_from_type_node(mono, args[i].val, act_args[i].val, type_params, bindings)
                            i += 1
                        }
                    }
                },
                .StructureType(def_id) then {
                    when mono.storage.context.get_template_name(def_id) in {
                        .Some(template_name) then {
                            if template_name == base then {
                                when mono.storage.context.get_type_arguments(def_id) in {
                                    .Some(act_args) then {
                                        let mut i UInt = 0
                                        while i < args.count() and i < act_args.count() then {
                                            collect_generic_bindings_from_type_node(mono, args[i].val, act_args[i], type_params, bindings)
                                            i += 1
                                        }
                                    },
                                    .None() then {},
                                }
                            }
                        },
                        .None() then {},
                    }
                },
                .GenericEnum(act_base, act_args) then {
                    if base == act_base then {
                        let mut i UInt = 0
                        while i < args.count() and i < act_args.count() then {
                            collect_generic_bindings_from_type_node(mono, args[i].val, act_args[i].val, type_params, bindings)
                            i += 1
                        }
                    }
                },
                .EnumType(def_id) then {
                    when mono.storage.context.get_template_name(def_id) in {
                        .Some(template_name) then {
                            if template_name == base then {
                                when mono.storage.context.get_type_arguments(def_id) in {
                                    .Some(act_args) then {
                                        let mut i UInt = 0
                                        while i < args.count() and i < act_args.count() then {
                                            collect_generic_bindings_from_type_node(mono, args[i].val, act_args[i], type_params, bindings)
                                            i += 1
                                        }
                                    },
                                    .None() then {},
                                }
                            }
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }
        },
        .FunctionType(param_nodes, ret_node) then {
            when actual in {
                .FunctionType(fn_params, ret_type) then {
                    let param_types = param_entry_types(fn_params)
                    let mut i UInt = 0
                    while i < param_nodes.count() and i < param_types.count() then {
                        collect_generic_bindings_from_type_node(mono, param_nodes[i].val, param_types[i].val, type_params, bindings)
                        i += 1
                    }
                    collect_generic_bindings_from_type_node(mono, ret_node.val, ret_type.val, type_params, bindings)
                },
                _ then {},
            }
        },
        .InferredSelf() then {},
    }
}

private let is_type_parameter_name(name String, type_params List[TypeParameterDecl]) Bool = {
    for tp in type_params then {
        if tp.name == name then { return true }
    }
    return false
}

private let type_node_mentions_type_parameter(node TypeNode, type_param_name String) Bool = {
    return when node in {
        .Identifier(name) then name == type_param_name,
        .Reference(inner, _) then type_node_mentions_type_parameter(inner.val, type_param_name),
        .Pointer(inner, _) then type_node_mentions_type_parameter(inner.val, type_param_name),
        .WeakReference(inner, _) then type_node_mentions_type_parameter(inner.val, type_param_name),
        .Generic(_, args) then {
            for arg in args then {
                if type_node_mentions_type_parameter(arg.val, type_param_name) then { return true }
            }
            yield false
        },
        .FunctionType(param_nodes, ret_node) then {
            for p in param_nodes then {
                if type_node_mentions_type_parameter(p.val, type_param_name) then { return true }
            }
            yield type_node_mentions_type_parameter(ret_node.val, type_param_name)
        },
        .InferredSelf() then false,
    }
}

private let template_type_parameter_constrained_by_parameters(template ref GenericFunctionTemplate, type_param_name String) Bool = {
    for param in template.parameters then {
        if type_node_mentions_type_parameter(param.param_type, type_param_name) then {
            return true
        }
    }
    return false
}

let is_placeholder_inferred_type(t Type) Bool = {
    return when t in {
        .Unknown() then true,
        .TypeVar(_) then true,
        .GenericParameter(_) then true,
        _ then false,
    }
}

private let canonical_type_for_generic_binding(mono ref Monomorphizer, t Type) Type = {
    return when t in {
        .StructureType(def_id) then {
            let reconstructed = when mono.storage.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut canonical_args = List[ref Type].new()
                            for type_arg in type_args then {
                                canonical_args.push(box(canonical_type_for_generic_binding(mono, type_arg)))
                            }
                            yield Option[Type].Some(Type.GenericStruct(template_name, canonical_args))
                        },
                        .None() then Option[Type].None(),
                    }
                },
                .None() then Option[Type].None(),
            }
            yield when reconstructed in {
                .Some(reconstructed_type) then reconstructed_type,
                .None() then when mono.storage.context.lookup_type(def_id) in {
                    .Some(mapped) then canonical_type_for_generic_binding(mono, mapped),
                    .None() then t,
                },
            }
        },
        .EnumType(def_id) then {
            let reconstructed = when mono.storage.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    yield when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(type_args) then {
                            let mut canonical_args = List[ref Type].new()
                            for type_arg in type_args then {
                                canonical_args.push(box(canonical_type_for_generic_binding(mono, type_arg)))
                            }
                            yield Option[Type].Some(Type.GenericEnum(template_name, canonical_args))
                        },
                        .None() then Option[Type].None(),
                    }
                },
                .None() then Option[Type].None(),
            }
            yield when reconstructed in {
                .Some(reconstructed_type) then reconstructed_type,
                .None() then when mono.storage.context.lookup_type(def_id) in {
                    .Some(mapped) then canonical_type_for_generic_binding(mono, mapped),
                    .None() then t,
                },
            }
        },
        .OpaqueType(def_id) then {
            yield when mono.storage.context.lookup_type(def_id) in {
                .Some(mapped) then canonical_type_for_generic_binding(mono, mapped),
                .None() then t,
            }
        },
        .ReferenceType(inner_ref) then Type.ReferenceType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .MutableReferenceType(inner_ref) then Type.MutableReferenceType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .WeakReferenceType(inner_ref) then Type.WeakReferenceType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .MutableWeakReferenceType(inner_ref) then Type.MutableWeakReferenceType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .PointerType(inner_ref) then Type.PointerType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .MutablePointerType(inner_ref) then Type.MutablePointerType(box(canonical_type_for_generic_binding(mono, inner_ref.val))),
        .FunctionType(fn_params, return_type_ref) then {
            let param_types = param_entry_types(fn_params)
            let mut new_params = List[ref Type].new()
            for param_type in param_types then {
                new_params.push(box(canonical_type_for_generic_binding(mono, param_type.val)))
            }
            yield Type.FunctionType(types_to_param_entries(new_params), box(canonical_type_for_generic_binding(mono, return_type_ref.val)))
        },
        .GenericStruct(name, args) then {
            let mut new_args = List[ref Type].new()
            for arg in args then {
                new_args.push(box(canonical_type_for_generic_binding(mono, arg.val)))
            }
            yield Type.GenericStruct(name, new_args)
        },
        .GenericEnum(name, args) then {
            let mut new_args = List[ref Type].new()
            for arg in args then {
                new_args.push(box(canonical_type_for_generic_binding(mono, arg.val)))
            }
            yield Type.GenericEnum(name, new_args)
        },
        _ then t,
    }
}

private let is_generic_type_param_name(name String, type_param_names List[String]) Bool = {
    for param_name in type_param_names then {
        if param_name == name then { return true }
    }
    return false
}

private let unify_generic_type_pattern(
    mono ref Monomorphizer,
    pattern Type,
    actual Type,
    type_param_names List[String],
    inferred mut ref Dict[String, Type],
) Bool = {
    let normalized_actual = canonical_type_for_generic_binding(mono, actual)
    return when pattern in {
        .GenericParameter(name) then {
            yield if not is_generic_type_param_name(name, type_param_names) then layout_key(pattern) == layout_key(normalized_actual) else when normalized_actual in {
                .GenericParameter(actual_name) then {
                    yield if is_generic_type_param_name(actual_name, type_param_names) then true else when inferred.get(name) in {
                        .Some(existing) then layout_key(existing) == layout_key(normalized_actual),
                        .None() then {
                            inferred.insert(name, normalized_actual)
                            yield true
                        },
                    }
                },
                _ then when inferred.get(name) in {
                    .Some(existing) then layout_key(existing) == layout_key(normalized_actual),
                    .None() then {
                        inferred.insert(name, normalized_actual)
                        yield true
                    },
                },
            }
        },
        .ReferenceType(pattern_inner) then {
            yield when normalized_actual in {
                .ReferenceType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .MutableReferenceType(pattern_inner) then {
            yield when normalized_actual in {
                .MutableReferenceType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .WeakReferenceType(pattern_inner) then {
            yield when normalized_actual in {
                .WeakReferenceType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .MutableWeakReferenceType(pattern_inner) then {
            yield when normalized_actual in {
                .MutableWeakReferenceType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .PointerType(pattern_inner) then {
            yield when normalized_actual in {
                .PointerType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .MutablePointerType(pattern_inner) then {
            yield when normalized_actual in {
                .MutablePointerType(actual_inner) then unify_generic_type_pattern(mono, pattern_inner.val, actual_inner.val, type_param_names, inferred),
                _ then false,
            }
        },
        .GenericStruct(pattern_name, pattern_args) then {
            let actual_args_opt = when normalized_actual in {
                .GenericStruct(actual_name, actual_args) then {
                    yield if actual_name == pattern_name then Option[List[ref Type]].Some(actual_args) else Option[List[ref Type]].None()
                },
                .StructureType(def_id) then {
                    let layout_args_opt = when mono.storage.context.get_name(def_id) in {
                        .Some(type_name) then when mono.storage.layout_to_template_info.get(type_name) in {
                            .Some(info) then {
                                yield if info.base_name == pattern_name then {
                                    let mut args = List[ref Type].new()
                                    for type_arg in info.args then { args.push(box(type_arg.val)) }
                                    yield Option[List[ref Type]].Some(args)
                                } else Option[List[ref Type]].None()
                            },
                            .None() then Option[List[ref Type]].None(),
                        },
                        .None() then Option[List[ref Type]].None(),
                    }
                    yield when layout_args_opt in {
                        .Some(args) then Option[List[ref Type]].Some(args),
                        .None() then when mono.storage.context.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .GenericStruct(actual_name, actual_args) then {
                                yield if actual_name == pattern_name then Option[List[ref Type]].Some(actual_args) else Option[List[ref Type]].None()
                            },
                            _ then when mono.storage.context.get_template_name(def_id) in {
                                .Some(template_name) then {
                                    yield if template_name == pattern_name then when mono.storage.context.get_type_arguments(def_id) in {
                                        .Some(type_args) then {
                                            let mut args = List[ref Type].new()
                                            for type_arg in type_args then { args.push(box(type_arg)) }
                                            yield Option[List[ref Type]].Some(args)
                                        },
                                        .None() then Option[List[ref Type]].None(),
                                    } else Option[List[ref Type]].None()
                                },
                                .None() then Option[List[ref Type]].None(),
                            },
                        },
                        .None() then when mono.storage.context.get_template_name(def_id) in {
                            .Some(template_name) then {
                                yield if template_name == pattern_name then when mono.storage.context.get_type_arguments(def_id) in {
                                    .Some(type_args) then {
                                        let mut args = List[ref Type].new()
                                        for type_arg in type_args then { args.push(box(type_arg)) }
                                        yield Option[List[ref Type]].Some(args)
                                    },
                                    .None() then Option[List[ref Type]].None(),
                                } else Option[List[ref Type]].None()
                            },
                            .None() then Option[List[ref Type]].None(),
                        },
                    },
                    }
                },
                _ then Option[List[ref Type]].None(),
            }
            yield when actual_args_opt in {
                .Some(actual_args) then {
                    if pattern_args.count() <> actual_args.count() then { return false }
                    let mut matches = true
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not unify_generic_type_pattern(mono, pattern_args[i].val, actual_args[i].val, type_param_names, inferred) then {
                            matches = false
                        }
                        i += 1
                    }
                    yield matches
                },
                .None() then false,
            }
        },
        .GenericEnum(pattern_name, pattern_args) then {
            let actual_args_opt = when normalized_actual in {
                .GenericEnum(actual_name, actual_args) then {
                    yield if actual_name == pattern_name then Option[List[ref Type]].Some(actual_args) else Option[List[ref Type]].None()
                },
                .EnumType(def_id) then {
                    let layout_args_opt = when mono.storage.context.get_name(def_id) in {
                        .Some(type_name) then when mono.storage.layout_to_template_info.get(type_name) in {
                            .Some(info) then {
                                yield if info.base_name == pattern_name then {
                                    let mut args = List[ref Type].new()
                                    for type_arg in info.args then { args.push(box(type_arg.val)) }
                                    yield Option[List[ref Type]].Some(args)
                                } else Option[List[ref Type]].None()
                            },
                            .None() then Option[List[ref Type]].None(),
                        },
                        .None() then Option[List[ref Type]].None(),
                    }
                    yield when layout_args_opt in {
                        .Some(args) then Option[List[ref Type]].Some(args),
                        .None() then when mono.storage.context.lookup_type(def_id) in {
                        .Some(mapped_type) then when mapped_type in {
                            .GenericEnum(actual_name, actual_args) then {
                                yield if actual_name == pattern_name then Option[List[ref Type]].Some(actual_args) else Option[List[ref Type]].None()
                            },
                            _ then when mono.storage.context.get_template_name(def_id) in {
                                .Some(template_name) then {
                                    yield if template_name == pattern_name then when mono.storage.context.get_type_arguments(def_id) in {
                                        .Some(type_args) then {
                                            let mut args = List[ref Type].new()
                                            for type_arg in type_args then { args.push(box(type_arg)) }
                                            yield Option[List[ref Type]].Some(args)
                                        },
                                        .None() then Option[List[ref Type]].None(),
                                    } else Option[List[ref Type]].None()
                                },
                                .None() then Option[List[ref Type]].None(),
                            },
                        },
                        .None() then when mono.storage.context.get_template_name(def_id) in {
                            .Some(template_name) then {
                                yield if template_name == pattern_name then when mono.storage.context.get_type_arguments(def_id) in {
                                    .Some(type_args) then {
                                        let mut args = List[ref Type].new()
                                        for type_arg in type_args then { args.push(box(type_arg)) }
                                        yield Option[List[ref Type]].Some(args)
                                    },
                                    .None() then Option[List[ref Type]].None(),
                                } else Option[List[ref Type]].None()
                            },
                            .None() then Option[List[ref Type]].None(),
                        },
                    },
                    }
                },
                _ then Option[List[ref Type]].None(),
            }
            yield when actual_args_opt in {
                .Some(actual_args) then {
                    if pattern_args.count() <> actual_args.count() then { return false }
                    let mut matches = true
                    let mut i UInt = 0
                    while i < pattern_args.count() then {
                        if not unify_generic_type_pattern(mono, pattern_args[i].val, actual_args[i].val, type_param_names, inferred) then {
                            matches = false
                        }
                        i += 1
                    }
                    yield matches
                },
                .None() then false,
            }
        },
        .FunctionType(pattern_params, pattern_return) then {
            yield when normalized_actual in {
                .FunctionType(actual_params, actual_return) then {
                    if pattern_params.count() <> actual_params.count() then { return false }
                    let mut matches = true
                    let mut i UInt = 0
                    while i < pattern_params.count() then {
                        if not unify_generic_type_pattern(mono, pattern_params[i].val.param_type, actual_params[i].val.param_type, type_param_names, inferred) then {
                            matches = false
                        }
                        i += 1
                    }
                    yield matches and unify_generic_type_pattern(mono, pattern_return.val, actual_return.val, type_param_names, inferred)
                },
                _ then false,
            }
        },
        _ then layout_key(pattern) == layout_key(normalized_actual),
    }
}

// Collect GenericParameter -> concrete Type bindings by structurally matching an
// expected template type against an actual call-site type.
private let collect_generic_type_bindings(expected Type, actual Type, bindings mut ref Dict[String, Type]) Void = {
    when expected in {
        .GenericParameter(name) then {
            when bindings.get(name) in {
                .Some(existing) then {
                    if is_placeholder_inferred_type(existing) and not is_placeholder_inferred_type(actual) then {
                        bindings.insert(name, actual)
                    }
                },
                .None() then {
                    bindings.insert(name, actual)
                },
            }
        },
        .ReferenceType(exp_inner) then {
            when actual in {
                .ReferenceType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .MutableReferenceType(exp_inner) then {
            when actual in {
                .MutableReferenceType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .WeakReferenceType(exp_inner) then {
            when actual in {
                .WeakReferenceType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .MutableWeakReferenceType(exp_inner) then {
            when actual in {
                .MutableWeakReferenceType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .PointerType(exp_inner) then {
            when actual in {
                .PointerType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .MutablePointerType(exp_inner) then {
            when actual in {
                .MutablePointerType(act_inner) then collect_generic_type_bindings(exp_inner.val, act_inner.val, bindings),
                _ then {},
            }
        },
        .FunctionType(exp_params, exp_ret) then {
            when actual in {
                .FunctionType(act_params, act_ret) then {
                    let mut i UInt = 0
                    while i < exp_params.count() and i < act_params.count() then {
                        collect_generic_type_bindings(exp_params[i].val.param_type, act_params[i].val.param_type, bindings)
                        i += 1
                    }
                    collect_generic_type_bindings(exp_ret.val, act_ret.val, bindings)
                },
                _ then {},
            }
        },
        .GenericStruct(exp_name, exp_args) then {
            when actual in {
                .GenericStruct(act_name, act_args) then {
                    if exp_name == act_name then {
                        let mut i UInt = 0
                        while i < exp_args.count() and i < act_args.count() then {
                            collect_generic_type_bindings(exp_args[i].val, act_args[i].val, bindings)
                            i += 1
                        }
                    }
                },
                _ then {},
            }
        },
        .GenericEnum(exp_name, exp_args) then {
            when actual in {
                .GenericEnum(act_name, act_args) then {
                    if exp_name == act_name then {
                        let mut i UInt = 0
                        while i < exp_args.count() and i < act_args.count() then {
                            collect_generic_type_bindings(exp_args[i].val, act_args[i].val, bindings)
                            i += 1
                        }
                    }
                },
                _ then {},
            }
        },
        _ then {},
    }
}

private let resolve_expr_kind(mono ref Monomorphizer, expr ref TypedExpr) ref TypedExprKind = {
    return when expr.expr_kind in {
        .Variable(symbol) then box(TypedExprKind.Variable(box(resolve_symbol_type(mono, symbol)))),
        .IntegerLiteral(value) then box(TypedExprKind.IntegerLiteral(value)),
        .FloatLiteral(value) then box(TypedExprKind.FloatLiteral(value)),
        .StringLiteral(value) then box(TypedExprKind.StringLiteral(value)),
        .BoolLiteral(value) then box(TypedExprKind.BoolLiteral(value)),
        .CastExpr(target_type, inner) then {
            let new_target = resolve_parameterized_type(mono, target_type)
            let resolved_inner = resolve_types_in_expression(mono, inner)
            when new_target in {
                .TraitObject(trait_name, _) then {
                    let actual_type = resolve_parameterized_type(mono, resolved_inner.expr_type)
                    let concrete_type = when actual_type in {
                        .ReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        .MutableReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        .WeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        .MutableWeakReferenceType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        .PointerType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        .MutablePointerType(actual_inner_ref) then resolve_parameterized_type(mono, actual_inner_ref.val),
                        _ then actual_type,
                    }
                    collect_concrete_vtable_request(mono, concrete_type, trait_name)
                },
                _ then {},
            }
            yield box(TypedExprKind.CastExpr(new_target, resolved_inner))
        },
        .TraitObjectConversion(inner, trait_type, concrete_type) then {
            let new_inner = resolve_types_in_expression(mono, inner)
            let mut new_trait_type = resolve_parameterized_type(mono, trait_type)
            when trait_type in {
                .TraitObject(original_trait_name, original_type_args) then {
                    let mut resolved_trait_args = List[ref Type].new()
                    for original_type_arg in original_type_args then {
                        resolved_trait_args.push(box(resolve_parameterized_type(mono, original_type_arg.val)))
                    }
                    new_trait_type = Type.TraitObject(original_trait_name, resolved_trait_args)
                },
                _ then {},
            }
            let new_concrete_type = resolve_parameterized_type(mono, concrete_type)
            when new_trait_type in {
                .TraitObject(trait_name, _) then collect_concrete_vtable_request(mono, new_concrete_type, trait_name),
                _ then {},
            }
            yield box(TypedExprKind.TraitObjectConversion(new_inner, new_trait_type, new_concrete_type))
        },
        .Unary(op, inner) then {
            yield box(TypedExprKind.Unary(op, resolve_types_in_expression(mono, inner)))
        },
        .RefExpr(inner) then box(TypedExprKind.RefExpr(resolve_types_in_expression(mono, inner))),
        .PtrExpr(inner) then box(TypedExprKind.PtrExpr(resolve_types_in_expression(mono, inner))),
        .DerefExpr(inner) then box(TypedExprKind.DerefExpr(resolve_types_in_expression(mono, inner))),
        .ArithmeticExpr(left, op, right) then {
            yield box(TypedExprKind.ArithmeticExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .WrappingArithmeticExpr(left, op, right) then {
            yield box(TypedExprKind.WrappingArithmeticExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .WrappingShiftExpr(left, op, right) then {
            yield box(TypedExprKind.WrappingShiftExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .ComparisonExpr(left, op, right) then {
            yield box(TypedExprKind.ComparisonExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .BitwiseExpr(left, op, right) then {
            yield box(TypedExprKind.BitwiseExpr(resolve_types_in_expression(mono, left), op, resolve_types_in_expression(mono, right)))
        },
        .AndExpr(left, right) then {
            yield box(TypedExprKind.AndExpr(resolve_types_in_expression(mono, left), resolve_types_in_expression(mono, right)))
        },
        .OrExpr(left, right) then {
            yield box(TypedExprKind.OrExpr(resolve_types_in_expression(mono, left), resolve_types_in_expression(mono, right)))
        },
        .IsExpr(subject, pattern, negated) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            yield box(TypedExprKind.IsExpr(new_subject, pattern, negated))
        },
        .Call(callee, args) then {
            let new_callee = resolve_types_in_expression(mono, callee)
            let mut new_args = List[ref TypedExpr].new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            yield box(TypedExprKind.Call(new_callee, new_args))
        },
        .GenericCall(function_symbol, type_args, args) then {
            let new_function_symbol = resolve_symbol_type(mono, function_symbol)
            let mut new_type_args = List[Type].new()
            for type_arg in type_args then {
                new_type_args.push(resolve_parameterized_type(mono, type_arg))
            }
            let mut new_args = List[ref TypedExpr].new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            yield box(TypedExprKind.GenericCall(box(new_function_symbol), new_type_args, new_args))
        },
        .IntrinsicCall(node) then {
            let new_node = when node in {
                .IsUniqueMutable(ref_expr) then TypedIntrinsic.IsUniqueMutable(resolve_types_in_expression(mono, ref_expr)),
                .RefCount(ref_expr) then TypedIntrinsic.RefCount(resolve_types_in_expression(mono, ref_expr)),
                .MakeRef(pointer_expr, owner_expr, result_type) then TypedIntrinsic.MakeRef(resolve_types_in_expression(mono, pointer_expr), resolve_types_in_expression(mono, owner_expr), resolve_parameterized_type(mono, result_type)),
                .MakeMutRef(pointer_expr, owner_expr, result_type) then TypedIntrinsic.MakeMutRef(resolve_types_in_expression(mono, pointer_expr), resolve_types_in_expression(mono, owner_expr), resolve_parameterized_type(mono, result_type)),
                .DowngradeRef(ref_expr, result_type) then TypedIntrinsic.DowngradeRef(resolve_types_in_expression(mono, ref_expr), resolve_parameterized_type(mono, result_type)),
                .DowngradeMutRef(ref_expr, result_type) then TypedIntrinsic.DowngradeMutRef(resolve_types_in_expression(mono, ref_expr), resolve_parameterized_type(mono, result_type)),
                .UpgradeRef(weak_expr, result_type) then TypedIntrinsic.UpgradeRef(resolve_types_in_expression(mono, weak_expr), resolve_parameterized_type(mono, result_type)),
                .UpgradeMutRef(weak_expr, result_type) then TypedIntrinsic.UpgradeMutRef(resolve_types_in_expression(mono, weak_expr), resolve_parameterized_type(mono, result_type)),
                .SpawnThread(out_handle, out_tid, closure, stack_size) then TypedIntrinsic.SpawnThread(resolve_types_in_expression(mono, out_handle), resolve_types_in_expression(mono, out_tid), resolve_types_in_expression(mono, closure), resolve_types_in_expression(mono, stack_size)),
                .AllocMemory(count, result_type) then TypedIntrinsic.AllocMemory(resolve_types_in_expression(mono, count), resolve_parameterized_type(mono, result_type)),
                .DeallocMemory(pointer_expr) then TypedIntrinsic.DeallocMemory(resolve_types_in_expression(mono, pointer_expr)),
                .CopyMemory(dest, source, count) then TypedIntrinsic.CopyMemory(resolve_types_in_expression(mono, dest), resolve_types_in_expression(mono, source), resolve_types_in_expression(mono, count)),
                .MoveMemory(dest, source, count) then TypedIntrinsic.MoveMemory(resolve_types_in_expression(mono, dest), resolve_types_in_expression(mono, source), resolve_types_in_expression(mono, count)),
                .InitMemory(pointer_expr, value_expr) then TypedIntrinsic.InitMemory(resolve_types_in_expression(mono, pointer_expr), resolve_types_in_expression(mono, value_expr)),
                .DeinitMemory(pointer_expr) then TypedIntrinsic.DeinitMemory(resolve_types_in_expression(mono, pointer_expr)),
                .TakeMemory(pointer_expr, result_type) then TypedIntrinsic.TakeMemory(resolve_types_in_expression(mono, pointer_expr), resolve_parameterized_type(mono, result_type)),
                .NullPtr(result_type) then TypedIntrinsic.NullPtr(resolve_parameterized_type(mono, result_type)),
            }
            yield box(TypedExprKind.IntrinsicCall(new_node))
        },
        .MemberPath(base, path) then {
            yield box(TypedExprKind.MemberPath(resolve_types_in_expression(mono, base), path))
        },
        .MethodReference(base, receiver_type, method, type_args, method_type_args, dispatch_callsite) then {
            let mut new_base = resolve_types_in_expression(mono, base)
            let mut new_receiver_type = resolve_parameterized_type(mono, receiver_type)
            let mut new_method = resolve_symbol_type(mono, method)
            let mut new_type_args = List[Type].new()
            for type_arg in type_args then {
                new_type_args.push(resolve_parameterized_type(mono, type_arg))
            }
            let mut new_method_type_args = List[Type].new()
            for method_type_arg in method_type_args then {
                new_method_type_args.push(resolve_parameterized_type(mono, method_type_arg))
            }
            let binding_receiver_type = resolve_parameterized_type(mono, new_base.expr_type)
            let resolved_method_symbol_type = resolve_parameterized_type(mono, new_method.symbol_type)
            let should_delay_method_binding = new_method_type_args.is_empty() and has_generic_parameter(resolved_method_symbol_type)
            if not has_generic_parameter(binding_receiver_type) and not should_delay_method_binding then {
                if should_preserve_resolved_method_reference(mono, box(new_method), binding_receiver_type) then {
                    new_method = resolve_symbol_type(mono, new_method)
                } else {
                    let rebound_method = bind_receiver_method_symbol(mono, binding_receiver_type, new_method, Option[Type].Some(resolve_parameterized_type(mono, expr.expr_type)))
                    new_method = resolve_symbol_type(mono, rebound_method)
                    new_base = align_method_reference_base_for_bound_method(mono, new_base, new_method)
                    new_receiver_type = resolve_parameterized_type(mono, new_base.expr_type)
                }
            }
            yield box(TypedExprKind.MethodReference(new_base, new_receiver_type, box(new_method), new_type_args, new_method_type_args, dispatch_callsite))
        },
        .Block(statements) then {
            let mut new_statements = List[ref TypedStatement].new()
            for stmt_ref in statements then {
                new_statements.push(box(resolve_types_in_statement(mono, stmt_ref)))
            }
            yield box(TypedExprKind.Block(new_statements))
        },
        .IfExpr(condition, then_branch, else_branch) then {
            let new_condition = resolve_types_in_expression(mono, condition)
            let new_then = resolve_types_in_expression(mono, then_branch)
            let new_else = when else_branch in {
                .Some(expr) then Option[ref TypedExpr].Some(resolve_types_in_expression(mono, expr)),
                .None() then Option[ref TypedExpr].None(),
            }
            yield box(TypedExprKind.IfExpr(new_condition, new_then, new_else))
        },
        .WhenExpr(subject, arms) then {
            let new_subject = resolve_types_in_expression(mono, subject)
            let mut new_arms = List[ref TypedWhenArm].new()
            for arm_ref in arms then {
                let mut pattern_bindings = Dict[UInt, Type].new()
                mono_collect_pattern_binding_types(mono, arm_ref.pattern, new_subject.expr_type, pattern_bindings.ref)
                mono_register_pattern_binding_types_in_expr(mono, arm_ref.body, pattern_bindings)
                let new_body = resolve_types_in_expression(mono, arm_ref.body)
                let new_arm_type = resolve_parameterized_type(mono, arm_ref.arm_type)
                new_arms.push(box(TypedWhenArm(arm_ref.pattern, new_body, new_arm_type)))
            }
            yield box(TypedExprKind.WhenExpr(new_subject, new_arms))
        },
        .LambdaExpr(params, return_type, body) then {
            let mut new_params = List[TypedParam].new()
            for p in params then {
                let new_type = resolve_parameterized_type(mono, p.param_type)
                new_params.push(TypedParam(p.name, p.mutable, new_type, p.named))
            }
            let new_return = resolve_parameterized_type(mono, return_type)
            yield box(TypedExprKind.LambdaExpr(new_params, new_return, resolve_types_in_expression(mono, body)))
        },
        .StaticMethodCall(receiver_type, method_name, method, type_args, method_type_args, args) then {
            yield box(resolve_static_method_call_to_call(mono, expr, receiver_type, method_name, method, type_args, method_type_args, args))
        },
        .TypeConstruction(identifier, type_args, args) then {
            let resolved_identifier = resolve_type_construction_symbol(mono, identifier, type_args, args)
            let mut new_type_args = List[Type].new()
            for type_arg in type_args then {
                new_type_args.push(resolve_parameterized_type(mono, type_arg))
            }
            let mut new_args = List[ref TypedExpr].new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            yield box(TypedExprKind.TypeConstruction(box(resolved_identifier), new_type_args, new_args))
        },
        .EnumConstruction(enum_type, case_name, args) then {
            let mut new_args = List[ref TypedExpr].new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            let resolved_enum_type = resolve_parameterized_type(mono, enum_type)
            collect_enum_constructor_vtable_requests(mono, resolved_enum_type, case_name, new_args)
            yield box(TypedExprKind.EnumConstruction(resolved_enum_type, case_name, new_args))
        },
        .TraitMethodPlaceholder(base, trait_type, method, _, dispatch_callsite) then {
            let new_base = resolve_types_in_expression(mono, base)
            let new_trait_type = resolve_parameterized_type(mono, trait_type)
            let resolved_method = resolve_symbol_type(mono, method)
            let new_method = Symbol(resolved_method.def_id, resolved_method.symbol_type, resolved_method.kind)
            yield box(TypedExprKind.TraitMethodPlaceholder(new_base, new_trait_type, box(new_method), List[Type].new(), dispatch_callsite))
        },
        .TraitMethodCall(receiver, trait_type, method_name, method_index, args) then {
            let new_receiver = resolve_types_in_expression(mono, receiver)
            let mut new_trait_type = resolve_parameterized_type(mono, trait_type)
            when trait_type in {
                .TraitObject(original_trait_name, original_type_args) then {
                    let mut resolved_trait_args = List[ref Type].new()
                    for original_type_arg in original_type_args then {
                        resolved_trait_args.push(box(resolve_parameterized_type(mono, original_type_arg.val)))
                    }
                    new_trait_type = Type.TraitObject(original_trait_name, resolved_trait_args)
                },
                _ then {},
            }
            let mut new_args = List[ref TypedExpr].new()
            for arg in args then {
                new_args.push(resolve_types_in_expression(mono, arg))
            }
            let concrete_receiver_type = concrete_trait_receiver_type(mono, new_receiver)
            let receiver_requires_dynamic_trait_dispatch = when concrete_receiver_type in {
                .TraitObject(_, _) then true,
                .ReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val) is .TraitObject(_, _),
                .MutableReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val) is .TraitObject(_, _),
                .WeakReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val) is .TraitObject(_, _),
                .MutableWeakReferenceType(inner_ref) then resolve_parameterized_type(mono, inner_ref.val) is .TraitObject(_, _),
                _ then false,
            }
            let can_use_static_dispatch = when concrete_receiver_type in {
                _ then not receiver_requires_dynamic_trait_dispatch and not has_generic_parameter(concrete_receiver_type) and not expr_is_type_symbol(new_receiver),
            }
            let mut rebound_static_kind Option[ref TypedExprKind] = Option[ref TypedExprKind].None()
            if can_use_static_dispatch then {
                let resolved_result_type = resolve_parameterized_type(mono, expr.expr_type)
                let method_symbol = make_trait_method_symbol(mono, method_name, resolved_result_type)
                let rebound_method = try_bind_generic_method_call(mono, concrete_receiver_type, method_symbol, new_args, resolved_result_type).val
                let static_receiver_base = when new_receiver.expr_kind in {
                    .TraitObjectConversion(inner, _, concrete_type) then {
                        let resolved_inner = resolve_types_in_expression(mono, inner)
                        let resolved_concrete_type = resolve_parameterized_type(mono, concrete_type)
                        yield box(TypedExpr(resolved_inner.expr_kind, resolved_concrete_type))
                    },
                    _ then new_receiver,
                }
                let static_receiver = adapt_receiver_expr_for_method(mono, static_receiver_base, rebound_method)
                let effective_dispatch_callsite = ensure_receiver_dispatch_callsite(
                    mono,
                    Option[DefId].None(),
                    concrete_receiver_type,
                    rebound_method,
                    Option[String].Some(method_name),
                )
                rebound_static_kind = Option[ref TypedExprKind].Some(
                    when try_lower_wrapping_generic_method_call(
                        mono,
                        static_receiver,
                        rebound_method,
                        new_args,
                        resolved_result_type,
                        effective_dispatch_callsite,
                    ) in {
                        .Some(lowered_expr) then lowered_expr.expr_kind,
                        .None() then {
                                    yield when try_lower_to_ref_method_call(
                                mono,
                                static_receiver,
                                rebound_method,
                                new_args,
                                resolved_result_type,
                                effective_dispatch_callsite,
                            ) in {
                                .Some(lowered_expr) then lowered_expr.expr_kind,
                                .None() then {
                                    let rebound_callee = box(TypedExpr(
                                        box(TypedExprKind.MethodReference(static_receiver, static_receiver.expr_type, box(rebound_method), List[Type].new(), List[Type].new(), effective_dispatch_callsite)),
                                        rebound_method.symbol_type,
                                    ))
                                    yield box(TypedExprKind.Call(rebound_callee, new_args))
                                },
                            }
                        },
                    }
                )
            }
            yield when rebound_static_kind in {
                .Some(kind) then kind,
                .None() then {
                    let mut trait_method_index Int = -1
                    let mut logical_method_name = method_name
                    when new_trait_type in {
                        .TraitObject(trait_name, _) then {
                            logical_method_name = method_name
                            trait_method_index = if method_index >= 0 then method_index else vtable_method_index(mono, trait_name, logical_method_name)
                            if trait_method_index >= 0 then {
                                collect_qualified_method_vtable_requests(mono, trait_name, logical_method_name, new_receiver, new_args)
                            }
                        },
                        _ then {},
                    }
                    let lowered_kind = if trait_method_index >= 0 then {
                        yield box(TypedExprKind.TraitMethodCall(new_receiver, new_trait_type, logical_method_name, trait_method_index, new_args))
                    } else {
                        let method_symbol = make_trait_method_symbol(mono, method_name, resolve_parameterized_type(mono, expr.expr_type))
                        let direct_callee = box(TypedExpr(
                            box(TypedExprKind.MethodReference(new_receiver, new_receiver.expr_type, box(method_symbol), List[Type].new(), List[Type].new(), Option[DefId].None())),
                            method_symbol.symbol_type,
                        ))
                        yield box(TypedExprKind.Call(direct_callee, new_args))
                    }
                    yield lowered_kind
                },
            }
        },
        .GenericInstantiation(base_type, type_args) then {
            let new_base_type = resolve_parameterized_type(mono, base_type)
            let mut new_type_args = List[Type].new()
            for type_arg in type_args then {
                new_type_args.push(resolve_parameterized_type(mono, type_arg))
            }
            yield box(TypedExprKind.GenericInstantiation(new_base_type, new_type_args))
        },
    }
}
// ── GenericMethodCall binding helper ──────────────────────────────────────────

// inferred_extension_method_actual_arg_type has been deleted.
// resolve_parameterized_type(mono, arg.expr_type) is now used directly.

private let extension_method_has_receiver_param(
    ext ref GenericExtensionMethodTemplate,
) Bool = {
    let _ = ext.checked_parameters
    return if ext.method.params.is_empty() then false else ext.method.params[0(UInt)].name == "self"
}

private let type_mentions_method_type_params(pattern Type, type_param_names List[String]) Bool = {
    return when pattern in {
        .GenericParameter(name) then {
            for type_param_name in type_param_names then {
                if type_param_name == name then { return true }
            }
            yield false
        },
        .ReferenceType(inner) then type_mentions_method_type_params(inner.val, type_param_names),
        .MutableReferenceType(inner) then type_mentions_method_type_params(inner.val, type_param_names),
        .PointerType(inner) then type_mentions_method_type_params(inner.val, type_param_names),
        .MutablePointerType(inner) then type_mentions_method_type_params(inner.val, type_param_names),
        .WeakReferenceType(inner) then type_mentions_method_type_params(inner.val, type_param_names),
        .MutableWeakReferenceType(inner) then type_mentions_method_type_params(inner.val, type_param_names),
        .FunctionType(fn_params, return_type) then {
            let param_types = param_entry_types(fn_params)
            for param_type in param_types then {
                if type_mentions_method_type_params(param_type.val, type_param_names) then {
                    return true
                }
            }
            yield type_mentions_method_type_params(return_type.val, type_param_names)
        },
        .GenericStruct(_, args) then {
            for arg in args then {
                if type_mentions_method_type_params(arg.val, type_param_names) then {
                    return true
                }
            }
            yield false
        },
        .GenericEnum(_, args) then {
            for arg in args then {
                if type_mentions_method_type_params(arg.val, type_param_names) then {
                    return true
                }
            }
            yield false
        },
        _ then false,
    }
}

private let infer_extension_method_type_args(
    mono ref Monomorphizer,
    ext ref GenericExtensionMethodTemplate,
    base_type Type,
    extension_type_args List[ref Type],
    provided_method_type_args List[ref Type],
    args List[ref TypedExpr],
    expected_return_type Type,
) Option[List[ref Type]] = {
    if not provided_method_type_args.is_empty() or ext.method.type_params.is_empty() then {
        return Option[List[ref Type]].Some(provided_method_type_args)
    }

    let resolved_base_type = resolve_parameterized_type(mono, base_type)
    let mut substitution = Dict[String, Type].new()
    substitution.insert("Self", resolved_base_type)

    let mut ext_i UInt = 0
    while ext_i < ext.type_params.count() and ext_i < extension_type_args.count() then {
        substitution.insert(ext.type_params[ext_i].name, resolve_parameterized_type(mono, extension_type_args[ext_i].val))
        ext_i += 1
    }

    let mut pattern_param_types = List[ref Type].new()
    let pattern_return_type = when ext.checked_return_type in {
        .Some(ret_type) then resolve_parameterized_type(mono, substitute_type(mono, ret_type, substitution)),
        .None() then resolve_parameterized_type(mono, mono.resolve_type_node_impl(ext.method.return_type, substitution)),
    }

    when ext.checked_parameters in {
        .Some(checked_params) then {
            for checked_param in checked_params then {
                pattern_param_types.push(box(resolve_parameterized_type(mono, substitute_type(mono, checked_param.symbol_type, substitution))))
            }
        },
        .None() then {
            for method_param in ext.method.params then {
                pattern_param_types.push(box(resolve_parameterized_type(mono, mono.resolve_type_node_impl(method_param.param_type, substitution))))
            }
        },
    }

    let mut actual_param_types = List[ref Type].new()
    if extension_method_has_receiver_param(ext) then {
        actual_param_types.push(box(base_type))
    }
    for arg in args then {
        actual_param_types.push(box(resolve_parameterized_type(mono, arg.expr_type)))
    }

    if pattern_param_types.count() <> actual_param_types.count() then {
        return Option[List[ref Type]].None()
    }

    let mut type_param_names = List[String].new()
    for method_tp in ext.method.type_params then {
        type_param_names.push(method_tp.name)
    }

    let mut method_bindings = Dict[String, Type].new()
    let mut i UInt = 0
    while i < pattern_param_types.count() then {
        if not unify_generic_type_pattern(
            mono,
            pattern_param_types[i].val,
            actual_param_types[i].val,
            type_param_names,
            method_bindings.ref,
        ) then {
            if type_mentions_method_type_params(pattern_param_types[i].val, type_param_names) then {
                return Option[List[ref Type]].None()
            }
        }
        i += 1
    }

    let concrete_expected = resolve_parameterized_type(mono, expected_return_type)
    if not has_generic_parameter(concrete_expected) and not is_placeholder_inferred_type(concrete_expected) then {
        if not unify_generic_type_pattern(
            mono,
            pattern_return_type,
            concrete_expected,
            type_param_names,
            method_bindings.ref,
        ) then {
            if type_mentions_method_type_params(pattern_return_type, type_param_names) then {
                return Option[List[ref Type]].None()
            }
        }
    }

    let mut method_type_args = List[ref Type].new()
    for method_tp in ext.method.type_params then {
        when method_bindings.get(method_tp.name) in {
            .Some(bound) then {
                let concrete_bound = resolve_parameterized_type(mono, bound)
                if has_generic_parameter(concrete_bound) or is_placeholder_inferred_type(concrete_bound) then {
                    return Option[List[ref Type]].None()
                }
                method_type_args.push(box(concrete_bound))
            },
            .None() then {
                return Option[List[ref Type]].None()
            },
        }
    }

    return Option[List[ref Type]].Some(method_type_args)
}

private let patched_extension_template_for_type_resolution(
    template ref GenericExtensionMethodTemplate,
    checked_body Option[ref TypedExpr],
) ref GenericExtensionMethodTemplate = {
    return box(GenericExtensionMethodTemplate(
        template.type_params,
        template.method,
        template.conformance_trait_name,
        template.source_file,
        template.module_path,
        template.package_id,
        checked_body,
        template.checked_parameters,
        template.checked_return_type,
    ))
}

private let make_trait_method_symbol(
    mono ref Monomorphizer,
    method_name String,
    return_type Type,
) Symbol = {
    let def_id = mono.storage.context.allocate_unindexed(method_name, DefKind.Function())
    return Symbol(def_id, Type.FunctionType(List[ref FunctionParamEntry].new(), box(return_type)), SymbolKind.Function())
}

// Get the semantic method name for a symbol, using structured defId lookup
// instead of brute-force registry search.
// Mirrors Swift's receiverMethodDispatch[method.defId]?.methodName.
private let get_semantic_method_name(
    mono ref Monomorphizer,
    method Symbol,
) String = {
    // 1. Try receiver_method_dispatch (from sema)
    if method.def_id.id > 0 then {
        when mono.receiver_method_dispatch_info(method.def_id) in {
            .Some(info) then { return info.method_name },
            .None() then {},
        }
        // 2. Try concrete_callable metadata (from mono)
        when mono.concrete_callable_info(method.def_id) in {
            .Some(info) then { return info.logical_name },
            .None() then {},
        }
        // 3. Try context name registry
        when mono.storage.context.get_name(method.def_id) in {
            .Some(name) then { return name },
            .None() then {},
        }
    }
    return mono.storage.context.symbol_name(method)
}

// normalize_method_name_from_registry has been deleted.
// All call sites now use get_semantic_method_name() which does O(1) defId lookup
// instead of O(n) brute-force suffix matching across all extension method templates.

// Try to bind a GenericMethodCall's method symbol to a concrete extension method.
// This mirrors the Swift compiler's lookupConcreteMethodSymbol behavior during
// resolveTypesInExpression: when the receiver type is a concrete type from a
// generic instantiation, we trigger extension method instantiation on-demand.
public let try_bind_generic_method_call(
    mono ref Monomorphizer,
    receiver_type Type,
    method Symbol,
    args List[ref TypedExpr],
    expected_return_type Type,
) ref Symbol = {
    let method_name = mono.storage.context.symbol_name(method)
    let effective_method_name = get_semantic_method_name(mono, method)
    // Skip if receiver still has generic parameters
    if has_generic_parameter(receiver_type) then { return box(method) }

    // Determine the template name and type args for extension method lookup
    let mut template_name_opt = Option[String].None()
    let mut type_args = List[ref Type].new()
    let mut concrete_receiver_type = receiver_type
    let mut autoderef_fallback = Option[Type].None()

    when receiver_type in {
        .GenericStruct(template_name, args) then {
            template_name_opt = Option[String].Some(template_name)
            let mut resolved_args = List[ref Type].new()
            for a in args then {
                let resolved_arg = resolve_parameterized_type(mono, a.val)
                resolved_args.push(box(resolved_arg))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            for canonical_arg in canonical_args then {
                type_args.push(box(canonical_arg.val))
            }
            when mono.storage.generic_templates.lookup_struct(template_name) in {
                .Some(struct_template) then {
                    concrete_receiver_type = mono.instantiate_struct_impl(struct_template, canonical_args)
                },
                .None() then {},
            }
        },
        .GenericEnum(template_name, args) then {
            template_name_opt = Option[String].Some(template_name)
            let mut resolved_args = List[ref Type].new()
            for a in args then {
                let resolved_arg = resolve_parameterized_type(mono, a.val)
                resolved_args.push(box(resolved_arg))
            }
            let canonical_args = canonicalize_type_arguments(mono, resolved_args)
            for canonical_arg in canonical_args then {
                type_args.push(box(canonical_arg.val))
            }
            when mono.storage.generic_templates.lookup_enum(template_name) in {
                .Some(enum_template) then {
                    concrete_receiver_type = mono.instantiate_enum_impl(enum_template, canonical_args)
                },
                .None() then {},
            }
        },
        .StructureType(def_id) then {
            let name = when mono.storage.context.get_name(def_id) in {
                .Some(n) then n,
                .None() then "",
            }
            when mono.storage.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    template_name_opt = Option[String].Some(template_name)
                    when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(actual_args) then {
                            for a in actual_args then {
                                type_args.push(box(a))
                            }
                        },
                        .None() then {
                            when mono.storage.context.lookup_type(def_id) in {
                                .Some(mapped_type) then {
                                    when mapped_type in {
                                        .GenericStruct(_, mapped_args) then {
                                            for a in mapped_args then {
                                                type_args.push(box(a.val))
                                            }
                                        },
                                        _ then {},
                                    }
                                },
                                .None() then {
                                    when mono.storage.layout_to_template_info.get(name) in {
                                        .Some(info) then {
                                            for a in info.args then { type_args.push(box(a.val)) }
                                        },
                                        .None() then {},
                                    }
                                },
                            }
                        },
                    }
                },
                .None() then {
                    when mono.storage.context.lookup_type(def_id) in {
                        .Some(mapped_type) then {
                            when mapped_type in {
                                .GenericStruct(template_name, mapped_args) then {
                                    template_name_opt = Option[String].Some(template_name)
                                    for a in mapped_args then {
                                        type_args.push(box(a.val))
                                    }
                                },
                                _ then {
                                    when mono.storage.layout_to_template_info.get(name) in {
                                        .Some(info) then {
                                            template_name_opt = Option[String].Some(info.base_name)
                                            for a in info.args then { type_args.push(box(a.val)) }
                                        },
                                        .None() then {
                                            template_name_opt = Option[String].Some(name)
                                        },
                                    }
                                },
                            }
                        },
                        .None() then {
                            when mono.storage.layout_to_template_info.get(name) in {
                                .Some(info) then {
                                    template_name_opt = Option[String].Some(info.base_name)
                                    for a in info.args then { type_args.push(box(a.val)) }
                                },
                                .None() then {
                                    template_name_opt = Option[String].Some(name)
                                },
                            }
                        },
                    }
                },
            }
        },
        .EnumType(def_id) then {
            let name = when mono.storage.context.get_name(def_id) in {
                .Some(n) then n,
                .None() then "",
            }
            when mono.storage.context.get_template_name(def_id) in {
                .Some(template_name) then {
                    template_name_opt = Option[String].Some(template_name)
                    when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(actual_args) then {
                            for a in actual_args then {
                                type_args.push(box(a))
                            }
                        },
                        .None() then {
                            when mono.storage.context.lookup_type(def_id) in {
                                .Some(mapped_type) then {
                                    when mapped_type in {
                                        .GenericEnum(_, mapped_args) then {
                                            for a in mapped_args then {
                                                type_args.push(box(a.val))
                                            }
                                        },
                                        _ then {},
                                    }
                                },
                                .None() then {
                                    when mono.storage.layout_to_template_info.get(name) in {
                                        .Some(info) then {
                                            for a in info.args then { type_args.push(box(a.val)) }
                                        },
                                        .None() then {},
                                    }
                                },
                            }
                        },
                    }
                },
                .None() then {
                    when mono.storage.context.lookup_type(def_id) in {
                        .Some(mapped_type) then {
                            when mapped_type in {
                                .GenericEnum(template_name, mapped_args) then {
                                    template_name_opt = Option[String].Some(template_name)
                                    for a in mapped_args then {
                                        type_args.push(box(a.val))
                                    }
                                },
                                _ then {
                                    when mono.storage.layout_to_template_info.get(name) in {
                                        .Some(info) then {
                                            template_name_opt = Option[String].Some(info.base_name)
                                            for a in info.args then { type_args.push(box(a.val)) }
                                        },
                                        .None() then {
                                            template_name_opt = Option[String].Some(name)
                                        },
                                    }
                                },
                            }
                        },
                        .None() then {
                            when mono.storage.layout_to_template_info.get(name) in {
                                .Some(info) then {
                                    template_name_opt = Option[String].Some(info.base_name)
                                    for a in info.args then { type_args.push(box(a.val)) }
                                },
                                .None() then {
                                    template_name_opt = Option[String].Some(name)
                                },
                            }
                        },
                    }
                },
            }
        },
        .ReferenceType(inner) then {
            template_name_opt = Option[String].Some("Ref")
            type_args.push(box(inner.val))
            autoderef_fallback = Option[Type].Some(inner.val)
        },
        .MutableReferenceType(inner) then {
            template_name_opt = Option[String].Some("MutRef")
            type_args.push(box(inner.val))
            autoderef_fallback = Option[Type].Some(inner.val)
        },
        .PointerType(inner) then {
            template_name_opt = Option[String].Some("Ptr")
            type_args.push(box(inner.val))
        },
        .MutablePointerType(inner) then {
            template_name_opt = Option[String].Some("MutPtr")
            type_args.push(box(inner.val))
        },
        .WeakReferenceType(inner) then {
            template_name_opt = Option[String].Some("WeakRef")
            type_args.push(box(inner.val))
        },
        .MutableWeakReferenceType(inner) then {
            template_name_opt = Option[String].Some("MutWeakRef")
            type_args.push(box(inner.val))
        },
        .IntType() then { template_name_opt = Option[String].Some("Int") },
        .Int8Type() then { template_name_opt = Option[String].Some("Int8") },
        .Int16Type() then { template_name_opt = Option[String].Some("Int16") },
        .Int32Type() then { template_name_opt = Option[String].Some("Int32") },
        .Int64Type() then { template_name_opt = Option[String].Some("Int64") },
        .UIntType() then { template_name_opt = Option[String].Some("UInt") },
        .UInt8Type() then { template_name_opt = Option[String].Some("UInt8") },
        .UInt16Type() then { template_name_opt = Option[String].Some("UInt16") },
        .UInt32Type() then { template_name_opt = Option[String].Some("UInt32") },
        .UInt64Type() then { template_name_opt = Option[String].Some("UInt64") },
        .Float32Type() then { template_name_opt = Option[String].Some("Float32") },
        .Float64Type() then { template_name_opt = Option[String].Some("Float64") },
        .BoolType() then { template_name_opt = Option[String].Some("Bool") },
        _ then {},
    }

    let template_name = when template_name_opt in {
        .Some(n) then n,
        .None() then {
            when autoderef_fallback in {
                .Some(inner) then { return try_bind_generic_method_call(mono, inner, method, args, expected_return_type) },
                .None() then {},
            }
            return box(method)
        },
    }

    let type_key = when concrete_receiver_type in {
        .StructureType(def_id) then {
            let key = layout_key(concrete_receiver_type)
            yield if key.is_empty() then mono.storage.context.get_name(def_id) or else key else key
        },
        .EnumType(def_id) then {
            let key = layout_key(concrete_receiver_type)
            yield if key.is_empty() then mono.storage.context.get_name(def_id) or else key else key
        },
        _ then layout_key(concrete_receiver_type),
    }
    let mut has_generic_method_template = false
    // First try to infer concrete method type arguments and instantiate the
    // extension method on-demand. Generic methods must bind through their
    // concrete method-arg key before falling back to any plain-name cache.
    when mono.storage.generic_templates.lookup_extension_methods(template_name) in {
        .Some(ext_templates) then {
            when select_extension_template(
                ext_templates,
                effective_method_name,
                Option[UInt].None(),
                Option[UInt].None(),
            ) in {
                .Some(ext_ref) then {
                    let effective_ext_ref = if ext_ref.checked_body is .Some(_) then ext_ref else when ext_ref.conformance_trait_name in {
                            .Some(trait_name) then when mono.storage.generic_templates.lookup_extension_methods(trait_name) in {
                                .Some(tool_templates) then when select_extension_template(
                                    tool_templates,
                                    effective_method_name,
                                    Option[UInt].Some(ext_ref.method.type_params.count()),
                                    Option[UInt].Some(resolve_extension_template_conformance_trait_args(mono, concrete_receiver_type, ext_ref).count()),
                                ) in {
                                    .Some(tool_template_ref) then patched_extension_template_for_type_resolution(
                                        ext_ref,
                                        tool_template_ref.checked_body,
                                    ),
                                    .None() then ext_ref,
                                },
                                .None() then ext_ref,
                            },
                            .None() then ext_ref,
                        }
                    let owned_effective_ext_ref = effective_ext_ref
                    if owned_effective_ext_ref.method.type_params.count() > 0 then {
                        has_generic_method_template = true
                    }
                    when infer_extension_method_type_args(
                        mono,
                        owned_effective_ext_ref,
                        concrete_receiver_type,
                        type_args,
                        List[ref Type].new(),
                        args,
                        expected_return_type,
                    ) in {
                        .Some(method_type_args) then {
                            let concrete_lookup_key = make_extension_method_lookup_key(mono, type_key, effective_method_name, method_type_args)
                            when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                .Some(def_id) then {
                                    // Trust the cache directly (matching Swift's approach).
                                    return box(resolved_method_symbol(mono, def_id, effective_method_name, method.symbol_type))
                                },
                                .None() then {},
                            }
                            let should_defer_trait_placeholder = if owned_effective_ext_ref.checked_body is .Some(_) then false else when owned_effective_ext_ref.conformance_trait_name in {
                                    .Some(_) then true,
                                    .None() then false,
                            }
                            if should_defer_trait_placeholder then {
                                when owned_effective_ext_ref.conformance_trait_name in {
                                    .Some(trait_name) then {
                                        when mono.storage.generic_templates.lookup_extension_methods(trait_name) in {
                                            .Some(tool_templates) then {
                                                let effective_trait_args = resolve_extension_template_conformance_trait_args(
                                                    mono,
                                                    concrete_receiver_type,
                                                    owned_effective_ext_ref,
                                                )
                                                when select_extension_template(
                                                    tool_templates,
                                                    effective_method_name,
                                                    Option[UInt].Some(method_type_args.count()),
                                                    Option[UInt].Some(effective_trait_args.count()),
                                                ) in {
                                                    .Some(tool_template_ref) then {
                                                        let patched_template = patched_extension_template_for_type_resolution(
                                                            owned_effective_ext_ref,
                                                            tool_template_ref.checked_body,
                                                        )
                                                        let sym = mono.instantiate_extension_method_impl(
                                                            concrete_receiver_type,
                                                            template_name,
                                                            patched_template,
                                                            type_args,
                                                            method_type_args,
                                                        )
                                                        return box(resolved_method_symbol(mono, sym.def_id, effective_method_name, sym.symbol_type))
                                                    },
                                                    .None() then {},
                                                }
                                            },
                                            .None() then {},
                                        }
                                    },
                                    .None() then {},
                                }
                                instantiate_trait_placeholder_method(mono, concrete_receiver_type, effective_method_name, method_type_args)
                                when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                    .Some(def_id) then {
                                        return box(resolved_method_symbol(mono, def_id, effective_method_name, method.symbol_type))
                                    },
                                    .None() then {},
                                }
                            }
                            let _ = mono.instantiate_extension_method_def_id_impl(
                                concrete_receiver_type,
                                template_name,
                                owned_effective_ext_ref,
                                type_args,
                                method_type_args,
                            )
                            when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                .Some(def_id) then {
                                    let resolved_symbol = resolved_method_symbol(mono, def_id, effective_method_name, method.symbol_type)
                                    return box(resolved_symbol)
                                },
                                .None() then {
                                    return box(method)
                                },
                            }
                        },
                        .None() then {},
                    }
                },
                .None() then {},
            }
        },
        .None() then {},
    }

    let mut trait_method_type_args = List[ref Type].new()
    if not args.is_empty() then {
        let first_arg_type = resolve_parameterized_type(mono, args[0(UInt)].expr_type)
        let inferred_trait_method_arg = when first_arg_type in {
            .FunctionType(_, return_type_ref) then resolve_parameterized_type(mono, return_type_ref.val),
            _ then first_arg_type,
        }
        if not has_generic_parameter(inferred_trait_method_arg) then {
            trait_method_type_args.push(box(inferred_trait_method_arg))
        }
    }
    instantiate_trait_placeholder_method(mono, concrete_receiver_type, effective_method_name, trait_method_type_args)

    if not trait_method_type_args.is_empty() then {
        let typed_lookup_key = make_extension_method_lookup_key(mono, type_key, effective_method_name, trait_method_type_args)
        when mono.storage.extension_method_def_ids.get(typed_lookup_key) in {
            .Some(def_id) then {
                return box(resolved_method_symbol(mono, def_id, effective_method_name, method.symbol_type))
            },
            .None() then {},
        }
    }

    if not has_generic_method_template then {
        let plain_lookup_key = make_extension_method_lookup_key(mono, type_key, effective_method_name, List[ref Type].new())
        when mono.storage.extension_method_def_ids.get(plain_lookup_key) in {
            .Some(def_id) then {
                return box(resolved_method_symbol(mono, def_id, effective_method_name, method.symbol_type))
            },
            .None() then {},
        }
    }

    when autoderef_fallback in {
        .Some(inner) then { return try_bind_generic_method_call(mono, inner, method, args, expected_return_type) },
        .None() then {},
    }
    return box(method)
}

private let collect_generic_bindings_from_type(
    mono ref Monomorphizer,
    pattern Type,
    actual Type,
    bindings mut ref Dict[String, Type],
) Void = {
    when pattern in {
        .GenericParameter(name) then {
            bindings.insert(name, actual)
        },
        .ReferenceType(pattern_inner) then {
            when actual in {
                .ReferenceType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .MutableReferenceType(pattern_inner) then {
            when actual in {
                .MutableReferenceType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .WeakReferenceType(pattern_inner) then {
            when actual in {
                .WeakReferenceType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .MutableWeakReferenceType(pattern_inner) then {
            when actual in {
                .MutableWeakReferenceType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .PointerType(pattern_inner) then {
            when actual in {
                .PointerType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .MutablePointerType(pattern_inner) then {
            when actual in {
                .MutablePointerType(actual_inner) then collect_generic_bindings_from_type(mono, pattern_inner.val, actual_inner.val, bindings),
                _ then {},
            }
        },
        .FunctionType(pattern_params, pattern_return) then {
            when actual in {
                .FunctionType(actual_params, actual_return) then {
                    let mut i UInt = 0
                    let max_count = if pattern_params.count() < actual_params.count() then pattern_params.count() else actual_params.count()
                    while i < max_count then {
                        collect_generic_bindings_from_type(mono, pattern_params[i].val.param_type, actual_params[i].val.param_type, bindings)
                        i += 1
                    }
                    collect_generic_bindings_from_type(mono, pattern_return.val, actual_return.val, bindings)
                },
                _ then {},
            }
        },
        .GenericStruct(pattern_template, pattern_args) then {
            when actual in {
                .GenericStruct(actual_template, actual_args) then {
                    if pattern_template == actual_template then {
                        let mut i UInt = 0
                        let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                        while i < max_count then {
                            collect_generic_bindings_from_type(mono, pattern_args[i].val, actual_args[i].val, bindings)
                            i += 1
                        }
                    }
                },
                .StructureType(def_id) then {
                    let actual_template_opt = when mono.storage.context.get_template_name(def_id) in {
                        .Some(template_name) then Option[String].Some(template_name),
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.context.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then Option[String].Some(info.base_name),
                            .None() then Option[String].None(),
                        },
                    }
                    let actual_args_opt = when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(actual_type_args) then {
                            let mut arg_refs = List[ref Type].new()
                            for actual_type_arg in actual_type_args then {
                                arg_refs.push(box(actual_type_arg))
                            }
                            yield Option[List[ref Type]].Some(arg_refs)
                        },
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.context.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then {
                                let mut arg_refs = List[ref Type].new()
                                for actual_type_arg in info.args then {
                                    arg_refs.push(box(actual_type_arg.val))
                                }
                                yield Option[List[ref Type]].Some(arg_refs)
                            },
                            .None() then Option[List[ref Type]].None(),
                        },
                    }
                    when actual_template_opt in {
                        .Some(actual_template) then when actual_args_opt in {
                            .Some(actual_args) then {
                                if pattern_template == actual_template then {
                                    let mut i UInt = 0
                                    let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                                    while i < max_count then {
                                        collect_generic_bindings_from_type(mono, pattern_args[i].val, actual_args[i].val, bindings)
                                        i += 1
                                    }
                                }
                            },
                            .None() then {},
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }
        },
        .GenericEnum(pattern_template, pattern_args) then {
            when actual in {
                .GenericEnum(actual_template, actual_args) then {
                    if pattern_template == actual_template then {
                        let mut i UInt = 0
                        let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                        while i < max_count then {
                            collect_generic_bindings_from_type(mono, pattern_args[i].val, actual_args[i].val, bindings)
                            i += 1
                        }
                    }
                },
                .EnumType(def_id) then {
                    let actual_template_opt = when mono.storage.context.get_template_name(def_id) in {
                        .Some(template_name) then Option[String].Some(template_name),
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.context.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then Option[String].Some(info.base_name),
                            .None() then Option[String].None(),
                        },
                    }
                    let actual_args_opt = when mono.storage.context.get_type_arguments(def_id) in {
                        .Some(actual_type_args) then {
                            let mut arg_refs = List[ref Type].new()
                            for actual_type_arg in actual_type_args then {
                                arg_refs.push(box(actual_type_arg))
                            }
                            yield Option[List[ref Type]].Some(arg_refs)
                        },
                        .None() then when mono.storage.layout_to_template_info.get(
                            when mono.storage.context.get_name(def_id) in {
                                .Some(n) then n,
                                .None() then "",
                            }
                        ) in {
                            .Some(info) then {
                                let mut arg_refs = List[ref Type].new()
                                for actual_type_arg in info.args then {
                                    arg_refs.push(box(actual_type_arg.val))
                                }
                                yield Option[List[ref Type]].Some(arg_refs)
                            },
                            .None() then Option[List[ref Type]].None(),
                        },
                    }
                    when actual_template_opt in {
                        .Some(actual_template) then when actual_args_opt in {
                            .Some(actual_args) then {
                                if pattern_template == actual_template then {
                                    let mut i UInt = 0
                                    let max_count = if pattern_args.count() < actual_args.count() then pattern_args.count() else actual_args.count()
                                    while i < max_count then {
                                        collect_generic_bindings_from_type(mono, pattern_args[i].val, actual_args[i].val, bindings)
                                        i += 1
                                    }
                                }
                            },
                            .None() then {},
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }
        },
        _ then {},
    }
}

// ── StaticMethodCall resolution helpers ───────────────────────────────────────

private let static_method_receiver_key_for_type_resolution(t Type) String = {
    return when t in {
        .ReferenceType(inner) then static_method_receiver_key_for_type_resolution(inner.val),
        .MutableReferenceType(inner) then static_method_receiver_key_for_type_resolution(inner.val),
        .WeakReferenceType(inner) then static_method_receiver_key_for_type_resolution(inner.val),
        .MutableWeakReferenceType(inner) then static_method_receiver_key_for_type_resolution(inner.val),
        .PointerType(inner) then static_method_receiver_key_for_type_resolution(inner.val),
        .MutablePointerType(inner) then static_method_receiver_key_for_type_resolution(inner.val),
        _ then layout_key(t),
    }
}

private let push_static_method_receiver_alias_for_type_resolution(alias_list List[String], alias String) List[String] = {
    if alias.is_empty() then { return alias_list }
    for existing in alias_list then {
        if existing == alias then { return alias_list }
    }
    let mut updated = alias_list
    updated.push(alias)
    return updated
}

private let static_method_receiver_aliases_for_type_resolution(mono ref Monomorphizer, t Type) List[String] = {
    let mut aliases = List[String].new()
    aliases = push_static_method_receiver_alias_for_type_resolution(aliases, static_method_receiver_key_for_type_resolution(t))

    when t in {
        .ReferenceType(inner) then {
            for alias in static_method_receiver_aliases_for_type_resolution(mono, inner.val) then {
                aliases = push_static_method_receiver_alias_for_type_resolution(aliases, alias)
            }
        },
        .MutableReferenceType(inner) then {
            for alias in static_method_receiver_aliases_for_type_resolution(mono, inner.val) then {
                aliases = push_static_method_receiver_alias_for_type_resolution(aliases, alias)
            }
        },
        .WeakReferenceType(inner) then {
            for alias in static_method_receiver_aliases_for_type_resolution(mono, inner.val) then {
                aliases = push_static_method_receiver_alias_for_type_resolution(aliases, alias)
            }
        },
        .MutableWeakReferenceType(inner) then {
            for alias in static_method_receiver_aliases_for_type_resolution(mono, inner.val) then {
                aliases = push_static_method_receiver_alias_for_type_resolution(aliases, alias)
            }
        },
        .PointerType(inner) then {
            for alias in static_method_receiver_aliases_for_type_resolution(mono, inner.val) then {
                aliases = push_static_method_receiver_alias_for_type_resolution(aliases, alias)
            }
        },
        .MutablePointerType(inner) then {
            for alias in static_method_receiver_aliases_for_type_resolution(mono, inner.val) then {
                aliases = push_static_method_receiver_alias_for_type_resolution(aliases, alias)
            }
        },
        .GenericStruct(template, _) then {
            aliases = push_static_method_receiver_alias_for_type_resolution(aliases, template)
        },
        .GenericEnum(template, _) then {
            aliases = push_static_method_receiver_alias_for_type_resolution(aliases, template)
        },
        .StructureType(def_id) then {
            when mono.storage.context.get_name(def_id) in {
                .Some(name) then {
                    aliases = push_static_method_receiver_alias_for_type_resolution(aliases, name)
                    when mono.storage.layout_to_template_info.get(name) in {
                        .Some(info) then {
                            aliases = push_static_method_receiver_alias_for_type_resolution(aliases, info.base_name)
                        },
                        .None() then {},
                    }
                },
                .None() then {},
            }
        },
        .EnumType(def_id) then {
            when mono.storage.context.get_name(def_id) in {
                .Some(name) then {
                    aliases = push_static_method_receiver_alias_for_type_resolution(aliases, name)
                    when mono.storage.layout_to_template_info.get(name) in {
                        .Some(info) then {
                            aliases = push_static_method_receiver_alias_for_type_resolution(aliases, info.base_name)
                        },
                        .None() then {},
                    }
                },
                .None() then {},
            }
        },
        _ then {},
    }

    return aliases
}

private let bind_static_method_symbol_for_type_resolution(
    mono ref Monomorphizer,
    receiver_type Type,
    method Symbol,
) Symbol = {
    let receiver_aliases = static_method_receiver_aliases_for_type_resolution(mono, receiver_type)
    for receiver_key in receiver_aliases then {
        let lookup_key = "\(receiver_key).\(get_semantic_method_name(mono, method))"
        when mono.storage.extension_method_def_ids.get(lookup_key) in {
            .Some(def_id) then {
                let bound_symbol_type = when mono.storage.context.get_function_type(def_id) in {
                    .Some(function_type) then function_type,
                    .None() then method.symbol_type,
                }
                return Symbol(def_id, bound_symbol_type, method.kind)
            },
            .None() then {},
        }
    }
    return method
}

// Resolve a StaticMethodCall to a Call(Variable(...)) expression, matching the
// Swift compiler's behavior. This is the main entry point called from resolve_expr_kind.
private let resolve_static_method_call_to_call(
    mono ref Monomorphizer,
    expr ref TypedExpr,
    receiver_type Type,
    static_method_name String,
    method ref Symbol,
    type_args List[Type],
    method_type_args List[Type],
    args List[ref TypedExpr],
) TypedExprKind = {
    let new_receiver_type = resolve_parameterized_type(mono, receiver_type)
    let new_method = resolve_symbol_type(mono, method)
    let lookup_method = if method_def_id_matches_receiver_exactly(mono, new_method.def_id, new_receiver_type)
        then new_method
        else Symbol(DefId(0(UInt)), new_method.symbol_type, new_method.kind)
    let mut new_type_args = List[Type].new()
    for type_arg in type_args then {
        new_type_args.push(resolve_parameterized_type(mono, type_arg))
    }
    let mut new_method_type_args = List[Type].new()
    for method_type_arg in method_type_args then {
        new_method_type_args.push(resolve_parameterized_type(mono, method_type_arg))
    }
    let mut new_args = List[ref TypedExpr].new()
    for arg in args then {
        new_args.push(resolve_types_in_expression(mono, arg))
    }

    // If the resolved base type still contains generic parameters, keep as StaticMethodCall.
    if has_generic_parameter(new_receiver_type) then {
        return TypedExprKind.StaticMethodCall(new_receiver_type, static_method_name, box(new_method), new_type_args, new_method_type_args, new_args)
    }

    let rebound_static_method = bind_static_method_symbol_for_type_resolution(mono, new_receiver_type, new_method)

    // Determine template_name and emitted_type_scope_name from the resolved base type.
    let template_name = resolve_static_call_template_name(mono, new_receiver_type)
    // Keep the logical method name through monomorphization; concrete DefId
    // resolution happens separately via lookup_concrete_method_for_static_call.
    let method_name = if not static_method_name.is_empty()
        then static_method_name
        else get_semantic_method_name(mono, lookup_method)

    let mut resolved_return_type = resolve_parameterized_type(mono, expr.expr_type)
    collect_enum_constructor_vtable_requests(mono, new_receiver_type, method_name, new_args)

    let mut remapped_method_match = Option[Symbol].None()
    if lookup_method.def_id.id > 0 and not is_placeholder_inferred_type(resolved_return_type) then {
        when mono.storage.remapped_function_def_ids.get(lookup_method.def_id.id) in {
            .Some(remapped_list) then {
                let mut call_param_types = List[ref Type].new()
                for a in new_args then {
                    call_param_types.push(box(resolve_parameterized_type(mono, a.expr_type)))
                }
                let expected_call_type = Type.FunctionType(types_to_param_entries(call_param_types), box(resolve_parameterized_type(mono, resolved_return_type)))
                for remapped in remapped_list then {
                    let candidate_def_id = remapped.first
                    let candidate_type = resolve_parameterized_type(mono, remapped.second)
                    let owner_matches_receiver = when mono.concrete_callable_info(candidate_def_id) in {
                        .Some(info) then when info.owner_type in {
                            .Some(owner_type) then layout_key(resolve_parameterized_type(mono, owner_type)) == layout_key(new_receiver_type),
                            .None() then true,
                        },
                        .None() then true,
                    }
                    if owner_matches_receiver and layout_key(candidate_type) == layout_key(expected_call_type) then {
                        remapped_method_match = Option[Symbol].Some(Symbol(candidate_def_id, candidate_type, SymbolKind.Function()))
                        break
                    }
                }
            },
            .None() then {},
        }
    }

    // Prefer already-registered concrete methods first. This mirrors Swift's
    // direct extensionMethodDefIds lookup and prevents trait-tool free
    // functions like Std.Math.sqrt(T) from re-binding T.sqrt(...) back to the
    // currently-instantiating specialization itself.
    let rebound_static_sym = if rebound_static_method.def_id.id > 0
            and not has_generic_parameter(resolve_parameterized_type(mono, rebound_static_method.symbol_type))
            and (
                rebound_static_method.def_id.id <> new_method.def_id.id
                or method_def_id_matches_receiver_exactly(mono, rebound_static_method.def_id, new_receiver_type)
            )
        then Option[Symbol].Some(rebound_static_method)
        else Option[Symbol].None()
    let direct_concrete_sym = when remapped_method_match in {
        .Some(sym) then Option[Symbol].Some(sym),
        .None() then when rebound_static_sym in {
            .Some(sym) then Option[Symbol].Some(sym),
            .None() then lookup_concrete_method_for_static_call(mono, new_receiver_type, method_name, new_method_type_args, new_args, resolved_return_type),
        },
    }
    let mut concrete_sym = when direct_concrete_sym in {
        .Some(sym) then Option[Symbol].Some(sym),
        .None() then enqueue_extension_method_for_static_call(mono, new_receiver_type, method_name, template_name, new_method_type_args, new_args, resolved_return_type),
    }
    if concrete_sym is .None() then {
        let dispatch_trait_name_opt = if new_method.def_id.id > 0 then when mono.receiver_method_dispatch_info(new_method.def_id) in {
                .Some(info) then info.conformance_trait_name,
                .None() then Option[String].None(),
            } else Option[String].None()
        concrete_sym = instantiate_trait_target_static_method(
            mono,
            new_receiver_type,
            method_name,
            dispatch_trait_name_opt,
            new_method_type_args,
            new_args,
            resolved_return_type,
        )
    }
    when concrete_sym in {
        .Some(_) then {},
        .None() then {
            let mut type_key = layout_key(new_receiver_type)
            when new_receiver_type in {
                .StructureType(def_id) then {
                    type_key = mono.storage.context.get_name(def_id) or else type_key
                },
                .EnumType(def_id) then {
                    type_key = mono.storage.context.get_name(def_id) or else type_key
                },
                _ then {},
            }

            let mut trait_method_type_args = List[ref Type].new()
            if not new_method_type_args.is_empty() then {
                for method_type_arg in new_method_type_args then {
                    trait_method_type_args.push(box(method_type_arg))
                }
            } else if not new_args.is_empty() then {
                let first_arg_type = resolve_parameterized_type(mono, new_args[0(UInt)].expr_type)
                let inferred_trait_method_arg = when first_arg_type in {
                    .FunctionType(_, return_type_ref) then resolve_parameterized_type(mono, return_type_ref.val),
                    _ then first_arg_type,
                }
                if not has_generic_parameter(inferred_trait_method_arg) then {
                    trait_method_type_args.push(box(inferred_trait_method_arg))
                }
            }

            instantiate_trait_placeholder_method(mono, new_receiver_type, method_name, trait_method_type_args)

            when lookup_concrete_method_for_static_call(
                mono,
                new_receiver_type,
                method_name,
                new_method_type_args,
                new_args,
                resolved_return_type,
            ) in {
                .Some(sym) then {
                    concrete_sym = Option[Symbol].Some(sym)
                },
                .None() then {},
            }

            if not trait_method_type_args.is_empty() then {
                let typed_lookup_key = make_extension_method_lookup_key(mono, type_key, method_name, trait_method_type_args)
                when mono.storage.extension_method_def_ids.get(typed_lookup_key) in {
                    .Some(def_id) then {
                        concrete_sym = Option[Symbol].Some(resolved_method_symbol(mono, def_id, method_name, method.symbol_type))
                    },
                    .None() then {},
                }
            }

            when concrete_sym in {
                .Some(_) then {},
                .None() then {
                    let plain_lookup_key = make_extension_method_lookup_key(mono, type_key, method_name, List[ref Type].new())
                    when mono.storage.extension_method_def_ids.get(plain_lookup_key) in {
                        .Some(def_id) then {
                            concrete_sym = Option[Symbol].Some(resolved_method_symbol(mono, def_id, method_name, method.symbol_type))
                        },
                        .None() then {},
                    }
                },
            }
        },
    }

    // If the return type is still Unknown/Void, try to recover from the method signature.
    // This happens when the type checker couldn't resolve the return type at call sites
    // (e.g. recursive calls within a given block).
    when resolved_return_type in {
        .Unknown() then {
            // First try from concrete_sym's signature
            when concrete_sym in {
                .Some(sym) then {
                    when mono.storage.context.get_function_return_type(sym.def_id) in {
                        .Some(return_type) then {
                            resolved_return_type = resolve_parameterized_type(mono, return_type)
                        },
                        .None() then {},
                    }
                },
                .None() then {},
            }
        },
        _ then {},
    }

    // Build the function type for the callee.
    when concrete_sym in {
        .Some(sym) then when sym.symbol_type in {
            .FunctionType(fn_params, _) then {
                if not new_args.is_empty() and fn_params.count() == new_args.count() then {
                    let receiver_param_type = resolve_parameterized_type(mono, fn_params[0(UInt)].val.param_type)
                    let actual_receiver_expr = static_dispatch_receiver_expr(new_args[0(UInt)])
                    let actual_receiver_type = resolve_parameterized_type(mono, actual_receiver_expr.expr_type)
                    let owner_matches = when mono.concrete_callable_info(sym.def_id) in {
                        .Some(info) then when info.owner_type in {
                            .Some(owner_type) then {
                                let normalized_owner_type = resolve_parameterized_type(mono, owner_type)
                                let owner_is_self_param = when receiver_param_type in {
                                    .ReferenceType(inner_ref) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(normalized_owner_type),
                                    .MutableReferenceType(inner_ref) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(normalized_owner_type),
                                    .WeakReferenceType(inner_ref) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(normalized_owner_type),
                                    .MutableWeakReferenceType(inner_ref) then layout_key(resolve_parameterized_type(mono, inner_ref.val)) == layout_key(normalized_owner_type),
                                    _ then layout_key(receiver_param_type) == layout_key(normalized_owner_type),
                                }
                                yield owner_is_self_param and layout_key(normalized_owner_type) == layout_key(resolve_parameterized_type(mono, new_receiver_type))
                            },
                            .None() then false,
                        },
                        .None() then false,
                    }
                    let receiver_matches = when receiver_param_type in {
                        _ then receiver_param_matches_actual_receiver(mono, receiver_param_type, actual_receiver_type),
                    }
                    if owner_matches and receiver_matches then {
                        let receiver_trait_name_opt = when new_receiver_type in {
                            .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                            .ReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                _ then Option[String].None(),
                            },
                            .MutableReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                _ then Option[String].None(),
                            },
                            .WeakReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                _ then Option[String].None(),
                            },
                            .MutableWeakReferenceType(inner_ref) then when resolve_parameterized_type(mono, inner_ref.val) in {
                                .TraitObject(trait_name, _) then Option[String].Some(trait_name),
                                _ then Option[String].None(),
                            },
                            _ then Option[String].None(),
                        }
                        when receiver_trait_name_opt in {
                            .Some(trait_name) then {
                                if vtable_method_index(mono, trait_name, method_name) < 0 then {
                                    let callee_expr = box(TypedExpr(
                                        box(TypedExprKind.Variable(box(sym))),
                                        sym.symbol_type,
                                    ))
                                    return TypedExprKind.Call(callee_expr, new_args)
                                }
                            },
                            .None() then {},
                        }
                        let receiver_arg = adapt_receiver_expr_for_method(mono, actual_receiver_expr, sym)
                        let mut method_args = List[ref TypedExpr].new()
                        let mut arg_index UInt = 1(UInt)
                        while arg_index < new_args.count() then {
                            method_args.push(new_args[arg_index])
                            arg_index += 1(UInt)
                        }
                        let dispatch_callsite = ensure_receiver_dispatch_callsite(
                            mono,
                            Option[DefId].None(),
                            new_receiver_type,
                            sym,
                            Option[String].Some(method_name),
                        )
                        let callee_expr = box(TypedExpr(
                            box(TypedExprKind.MethodReference(receiver_arg, receiver_arg.expr_type, box(sym), List[Type].new(), List[Type].new(), dispatch_callsite)),
                            sym.symbol_type,
                        ))
                        return TypedExprKind.Call(callee_expr, method_args)
                    }
                }
            },
            _ then {},
        },
        .None() then {},
    }

    let mut param_types = List[ref Type].new()
    for a in new_args then {
        param_types.push(box(a.expr_type))
    }
    let mut func_type = make_function_type(param_types, resolved_return_type)
    let callee_symbol = when concrete_sym in {
        .Some(sym) then {
            let resolved_symbol_type = resolve_parameterized_type(mono, sym.symbol_type)
            when resolved_symbol_type in {
                .FunctionType(_, _) then {
                    func_type = resolved_symbol_type
                },
                _ then {},
            }
            yield Symbol(sym.def_id, func_type, SymbolKind.Function())
        },
        .None() then {
            let receiver_aliases = static_method_receiver_aliases_for_type_resolution(mono, new_receiver_type)
            let alias_text = join_strings(receiver_aliases, ",")
            panic("Unresolved static method call before MIR: \(method_name) on \(type_to_string(new_receiver_type)) aliases=\(alias_text)")
        },
    }
    let callee_expr = box(TypedExpr(
        box(TypedExprKind.Variable(box(callee_symbol))),
        callee_symbol.symbol_type,
    ))
    return TypedExprKind.Call(callee_expr, new_args)
}

// Determine the template name for extension method lookup from a resolved type.
// For StructureType/EnumType, uses the template name if available (for generic
// instantiations), otherwise the concrete name. For built-in types, uses the
// type name directly (e.g. "String", "Int").
private let resolve_static_call_template_name(mono ref Monomorphizer, t Type) String = {
    return when t in {
        .StructureType(def_id) then {
            let name = when mono.storage.context.get_name(def_id) in {
                .Some(n) then n,
                .None() then type_to_string(t),
            }
            yield when mono.storage.layout_to_template_info.get(name) in {
                .Some(info) then info.base_name,
                .None() then when mono.storage.context.get_template_name(def_id) in {
                    .Some(tn) then tn,
                    .None() then name,
                },
            }
        },
        .EnumType(def_id) then {
            let name = when mono.storage.context.get_name(def_id) in {
                .Some(n) then n,
                .None() then type_to_string(t),
            }
            yield when mono.storage.layout_to_template_info.get(name) in {
                .Some(info) then info.base_name,
                .None() then when mono.storage.context.get_template_name(def_id) in {
                    .Some(tn) then tn,
                    .None() then name,
                },
            }
        },
        .GenericStruct(name, _) then name,
        .GenericEnum(name, _) then name,
        .OpaqueType(def_id) then {
            // Resolve opaque types to their underlying type's template name
            yield when mono.storage.context.lookup_type(def_id) in {
                .Some(mapped_type) then resolve_static_call_template_name(mono, mapped_type),
                .None() then when mono.storage.context.get_name(def_id) in {
                    .Some(n) then n,
                    .None() then type_to_string(t),
                },
            }
        },
        .IntType() then "Int",
        .Int8Type() then "Int8",
        .Int16Type() then "Int16",
        .Int32Type() then "Int32",
        .Int64Type() then "Int64",
        .UIntType() then "UInt",
        .UInt8Type() then "UInt8",
        .UInt16Type() then "UInt16",
        .UInt32Type() then "UInt32",
        .UInt64Type() then "UInt64",
        .Float32Type() then "Float32",
        .Float64Type() then "Float64",
        .BoolType() then "Bool",
        _ then type_to_string(t),
    }
}

private let resolve_static_call_emitted_scope_name(
    mono ref Monomorphizer,
    t Type,
) String = {
    let resolved = resolve_parameterized_type(mono, t)
    return when resolved in {
        .StructureType(def_id) then when mono.storage.context.get_qualified_name(def_id) in {
            .Some(name) then name,
            .None() then mono.storage.context.get_name(def_id) or else resolve_static_call_template_name(mono, resolved),
        },
        .EnumType(def_id) then when mono.storage.context.get_qualified_name(def_id) in {
            .Some(name) then name,
            .None() then mono.storage.context.get_name(def_id) or else resolve_static_call_template_name(mono, resolved),
        },
        .OpaqueType(def_id) then when mono.storage.context.lookup_type(def_id) in {
            .Some(mapped_type) then resolve_static_call_emitted_scope_name(mono, mapped_type),
            .None() then resolve_static_call_template_name(mono, resolved),
        },
        .GenericStruct(_, _) then layout_key(resolved),
        .GenericEnum(_, _) then layout_key(resolved),
        _ then resolve_static_call_template_name(mono, resolved),
    }
}

private let specialized_static_method_symbol_name(
    mono ref Monomorphizer,
    receiver_type Type,
    method_name String,
    method_type_args List[Type],
) String = {
    let emitted_scope_name = resolve_static_call_emitted_scope_name(mono, receiver_type)
    if method_type_args.is_empty() then {
        return "\(emitted_scope_name)_\(method_name)"
    }

    let mut method_arg_keys = List[String].new()
    for method_type_arg in method_type_args then {
        method_arg_keys.push(layout_key(resolve_parameterized_type(mono, method_type_arg)))
    }
    return "\(emitted_scope_name)_\(method_name)_\(join_strings(method_arg_keys, "_"))"
}

private let join_strings(values List[String], separator String) String = {
    let mut out = String.new()
    let mut first = true
    for value in values then {
        if not first then { out.push_string(separator) }
        out.push_string(value)
        first = false
    }
    return out
}

private let instantiate_trait_target_static_method(
    mono ref Monomorphizer,
    base_type Type,
    method_name String,
    dispatch_trait_name_opt Option[String],
    provided_method_type_args List[Type],
    args List[ref TypedExpr],
    expected_return_type Type,
) Option[Symbol] = {
    let resolved_base_type = resolve_parameterized_type(mono, base_type)
    let structure_name = resolve_static_call_template_name(mono, resolved_base_type)

    let mut provided_method_type_arg_refs = List[ref Type].new()
    for method_type_arg in provided_method_type_args then {
        provided_method_type_arg_refs.push(box(method_type_arg))
    }
    let method_type_arg_count = if provided_method_type_args.is_empty()
        then Option[UInt].None()
        else Option[UInt].Some(provided_method_type_args.count())

    for node_ref in mono.storage.source_given_decls then {
        when node_ref in {
            .GivenTraitDecl(target_type, trait_name, trait_args, _, _) then {
                let normalized_base_type = normalize_vtable_conformance_actual_type(mono, resolved_base_type)
                let mut bindings = Dict[String, Type].new()
                if not collect_vtable_conformance_bindings(target_type, normalized_base_type, bindings.ref) then {
                    continue
                }

                let mut effective_trait_args = List[ref Type].new()
                for trait_arg in trait_args then {
                    effective_trait_args.push(box(resolve_parameterized_type(mono, substitute_type(mono, trait_arg, bindings))))
                }

                let template_lookup_trait_name = when dispatch_trait_name_opt in {
                    .Some(dispatch_trait_name) then dispatch_trait_name,
                    .None() then trait_name,
                }
                let trait_templates_opt = when mono.storage.generic_templates.lookup_extension_methods(template_lookup_trait_name) in {
                    .Some(tool_templates) then Option[List[ref GenericExtensionMethodTemplate]].Some(tool_templates),
                    .None() then when mono.storage.generic_templates.lookup_extension_methods(trait_name) in {
                        .Some(tool_templates) then Option[List[ref GenericExtensionMethodTemplate]].Some(tool_templates),
                        .None() then mono.storage.generic_templates.lookup_extension_methods(structure_name),
                    },
                }

                when trait_templates_opt in {
                    .Some(tool_templates) then {
                        when select_extension_template(
                            tool_templates,
                            method_name,
                            method_type_arg_count,
                            Option[UInt].Some(effective_trait_args.count()),
                        ) in {
                            .Some(tool_template_ref) then {
                                when infer_extension_method_type_args(
                                    mono,
                                    tool_template_ref,
                                    resolved_base_type,
                                    effective_trait_args,
                                    provided_method_type_arg_refs,
                                    args,
                                    expected_return_type,
                                ) in {
                                    .Some(resolved_method_type_args) then {
                                        let sym = mono.instantiate_extension_method_impl(
                                            resolved_base_type,
                                            structure_name,
                                            tool_template_ref,
                                            effective_trait_args,
                                            resolved_method_type_args,
                                        )
                                        return Option[Symbol].Some(sym)
                                    },
                                    .None() then {},
                                }
                            },
                            .None() then {},
                        }
                    },
                    .None() then {},
                }
            },
            _ then {},
        }
    }

    return Option[Symbol].None()
}

// Look up a concrete method symbol for a static method call.
// Checks extension_methods cache.
// If found, returns the symbol. Otherwise returns None.
private let lookup_concrete_method_for_static_call(
    mono ref Monomorphizer,
    base_type Type,
    method_name String,
    provided_method_type_args List[Type],
    args List[ref TypedExpr],
    expected_return_type Type,
) Option[Symbol] = {
    let resolved_base_type = when base_type in {
        .OpaqueType(def_id) then when mono.storage.context.lookup_type(def_id) in {
            .Some(underlying) then resolve_parameterized_type(mono, underlying),
            .None() then resolve_parameterized_type(mono, base_type),
        },
        _ then resolve_parameterized_type(mono, base_type),
    }
    let mut lookup_type_names = List[String].new()
    let base_layout_name = layout_key(base_type)
    if base_layout_name <> "" then {
        lookup_type_names.push(base_layout_name)
    }
    let resolved_layout_name = layout_key(resolved_base_type)
    if resolved_layout_name <> "" and not lookup_type_names.contains(resolved_layout_name) then {
        lookup_type_names.push(resolved_layout_name)
    }

    let base_display_name = mono.storage.context.type_display_name(base_type)
    if base_display_name <> "" and not lookup_type_names.contains(base_display_name) then {
        lookup_type_names.push(base_display_name)
    }
    let resolved_display_name = mono.storage.context.type_display_name(resolved_base_type)
    if resolved_display_name <> "" and not lookup_type_names.contains(resolved_display_name) then {
        lookup_type_names.push(resolved_display_name)
    }

    when base_type in {
        .OpaqueType(def_id) then {
            let opaque_name = mono.storage.context.get_name(def_id) or else ""
            if opaque_name <> "" and not lookup_type_names.contains(opaque_name) then {
                lookup_type_names.push(opaque_name)
            }
        },
        _ then {},
    }

    when resolved_base_type in {
        .StructureType(def_id) then {
            let concrete_name = mono.storage.context.get_name(def_id) or else ""
            if concrete_name <> "" and not lookup_type_names.contains(concrete_name) then {
                lookup_type_names.push(concrete_name)
            }
        },
        .EnumType(def_id) then {
            let concrete_name = mono.storage.context.get_name(def_id) or else ""
            if concrete_name <> "" and not lookup_type_names.contains(concrete_name) then {
                lookup_type_names.push(concrete_name)
            }
        },
        _ then {},
    }

    let resolved_base_key = layout_key(resolved_base_type)
    for entry in mono.storage.concrete_callables_by_def_id.iterator() then {
        let def_id = entry.first
        let concrete = entry.second
        if concrete.logical_name <> method_name then {
            continue
        }
        let owner_type = concrete.owner_type or else { continue }
        if layout_key(resolve_parameterized_type(mono, owner_type)) <> resolved_base_key then {
            continue
        }
        let symbol_type = when mono.storage.context.get_function_type(def_id) in {
            .Some(function_type) then function_type,
            .None() then Type.Unknown(),
        }
        let mut signature_matches = true
        when symbol_type in {
            .FunctionType(fn_params, return_type_ref) then {
                let param_types = param_entry_types(fn_params)
                if param_types.count() <> args.count() then {
                    signature_matches = false
                } else {
                    let mut arg_i UInt = 0
                    while arg_i < args.count() then {
                        let actual_arg_expr = if arg_i == 0(UInt) then {
                            yield static_dispatch_receiver_expr(args[arg_i])
                        } else {
                            yield args[arg_i]
                        }
                        let actual_arg_type = resolve_parameterized_type(mono, actual_arg_expr.expr_type)
                        let expected_param_type = resolve_parameterized_type(mono, param_types[arg_i].val)
                        if layout_key(actual_arg_type) <> layout_key(expected_param_type) then {
                            signature_matches = false
                            break
                        }
                        arg_i += 1
                    }
                }
                if signature_matches then {
                    let concrete_expected_return = resolve_parameterized_type(mono, expected_return_type)
                    if not has_generic_parameter(concrete_expected_return) and not is_placeholder_inferred_type(concrete_expected_return) then {
                        let concrete_return_type = resolve_parameterized_type(mono, return_type_ref.val)
                        if layout_key(concrete_return_type) <> layout_key(concrete_expected_return) then {
                            signature_matches = false
                        }
                    }
                }
            },
            _ then {
                signature_matches = false
            },
        }
        if not signature_matches then {
            continue
        }
        return Option[Symbol].Some(Symbol(def_id, symbol_type, SymbolKind.Function()))
    }

    let declared_method_symbol = when find_declared_static_receiver_method(mono, base_type, method_name, args, expected_return_type) in {
        .Some(symbol) then Option[Symbol].Some(symbol),
        .None() then find_declared_static_receiver_method(mono, resolved_base_type, method_name, args, expected_return_type),
    }
    when declared_method_symbol in {
        .Some(symbol) then { return declared_method_symbol },
        .None() then {},
    }

    let mut provided_method_type_arg_refs = List[ref Type].new()
    for method_type_arg in provided_method_type_args then {
        provided_method_type_arg_refs.push(box(method_type_arg))
    }

    let mut exact_lookup_keys = List[String].new()
    let base_lookup_key = make_extension_method_lookup_key(mono, layout_key(base_type), method_name, provided_method_type_arg_refs)
    if base_lookup_key.count() > 0 and not exact_lookup_keys.contains(base_lookup_key) then {
        exact_lookup_keys.push(base_lookup_key)
    }
    let resolved_lookup_key = make_extension_method_lookup_key(mono, resolved_base_key, method_name, provided_method_type_arg_refs)
    if resolved_lookup_key.count() > 0 and not exact_lookup_keys.contains(resolved_lookup_key) then {
        exact_lookup_keys.push(resolved_lookup_key)
    }
    for key in exact_lookup_keys then {
        when mono.storage.extension_method_def_ids.get(key) in {
            .Some(def_id) then {
                let symbol_type = when mono.storage.context.get_function_type(def_id) in {
                    .Some(function_type) then function_type,
                    .None() then Type.Unknown(),
                }
                let symbol_name = mono.storage.context.get_name(def_id) or else method_name
                return Option[Symbol].Some(Symbol(def_id, symbol_type, SymbolKind.Function()))
            },
            .None() then {},
        }
    }

    // First prefer direct concrete method registrations, mirroring Swift's
    // extensionMethodDefIds lookup so non-generic given methods win over any
    // currently-instantiating trait-tool specializations.
    for type_name in lookup_type_names then {
        let key = "\(type_name).\(method_name)"
        when mono.storage.extension_method_def_ids.get(key) in {
            .Some(def_id) then {
                let owner_matches_receiver = when mono.concrete_callable_info(def_id) in {
                    .Some(info) then when info.owner_type in {
                        .Some(owner_type) then layout_key(resolve_parameterized_type(mono, owner_type)) == resolved_base_key,
                        .None() then true,
                    },
                    .None() then true,
                }
                if not owner_matches_receiver then {
                    continue
                }
                let symbol_type = when mono.storage.context.get_function_type(def_id) in {
                    .Some(function_type) then function_type,
                    .None() then Type.Unknown(),
                }
                let symbol_name = mono.storage.context.get_name(def_id) or else method_name
                return Option[Symbol].Some(Symbol(def_id, symbol_type, SymbolKind.Function()))
            },
            .None() then {},
        }
    }

    // Check extension_methods map first.
    for type_name in lookup_type_names then {
        when mono.storage.extension_methods.get(type_name) in {
            .Some(method_map) then {
                when method_map.get(method_name) in {
                    .Some(entry) then {
                        let owner_matches_receiver = when mono.concrete_callable_info(entry.symbol.def_id) in {
                            .Some(info) then when info.owner_type in {
                                .Some(owner_type) then layout_key(resolve_parameterized_type(mono, owner_type)) == resolved_base_key,
                                .None() then true,
                            },
                            .None() then true,
                        }
                        if not owner_matches_receiver then {
                            continue
                        }
                        return Option[Symbol].Some(entry.symbol)
                    },
                    .None() then {},
                }
            },
            .None() then {},
        }
    }

    return Option[Symbol].None()
}

private let find_declared_static_receiver_method(
    mono ref Monomorphizer,
    base_type Type,
    method_name String,
    args List[ref TypedExpr],
    expected_return_type Type,
) Option[Symbol] = {
    let concrete_base_type = resolve_parameterized_type(mono, base_type)
    let base_aliases = static_method_receiver_aliases_for_type_resolution(mono, concrete_base_type)

    for node_ref in mono.storage.generated_nodes then {
        when node_ref in {
            .GivenDecl(target_type, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_aliases, method_name, args, expected_return_type) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
            .GivenTraitDecl(target_type, _, _, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_aliases, method_name, args, expected_return_type) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
            .IntrinsicGivenDecl(target_type, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_aliases, method_name, args, expected_return_type) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
            _ then {},
        }
    }

    for node_ref in mono.storage.source_given_decls then {
        when node_ref in {
            .GivenDecl(target_type, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_aliases, method_name, args, expected_return_type) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
            .GivenTraitDecl(target_type, _, _, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_aliases, method_name, args, expected_return_type) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
            .IntrinsicGivenDecl(target_type, members, _) then {
                when match_declared_static_receiver_member(mono, target_type, members, base_aliases, method_name, args, expected_return_type) in {
                    .Some(symbol) then { return Option[Symbol].Some(symbol) },
                    .None() then {},
                }
            },
            _ then {},
        }
    }

    return Option[Symbol].None()
}

private let match_declared_static_receiver_member(
    mono ref Monomorphizer,
    target_type Type,
    members List[ref TypedGivenMember],
    base_aliases List[String],
    method_name String,
    args List[ref TypedExpr],
    expected_return_type Type,
) Option[Symbol] = {
    let resolved_target_type = when target_type in {
        .OpaqueType(def_id) then when mono.storage.context.lookup_type(def_id) in {
            .Some(underlying) then underlying,
            .None() then target_type,
        },
        _ then target_type,
    }
    let target_aliases = static_method_receiver_aliases_for_type_resolution(mono, resolve_parameterized_type(mono, resolved_target_type))
    let mut receiver_matches = false
    for target_alias in target_aliases then {
        if base_aliases.contains(target_alias) then {
            receiver_matches = true
            break
        }
    }
    if not receiver_matches then {
        return Option[Symbol].None()
    }
    for member_ref in members then {
        if member_ref.name <> method_name then {
            continue
        }
        let mut member_is_concrete = not has_generic_parameter(resolved_target_type) and not has_generic_parameter(member_ref.return_type)
        for param in member_ref.params then {
            if has_generic_parameter(param.param_type) then {
                member_is_concrete = false
                break
            }
        }
        if not member_is_concrete then {
            continue
        }
        let symbol_type = when mono.storage.context.get_function_type(member_ref.def_id) in {
            .Some(function_type) then function_type,
            .None() then Type.Unknown(),
        }

        let mut signature_matches = true
        when symbol_type in {
            .FunctionType(fn_params, return_type_ref) then {
                let param_types = param_entry_types(fn_params)
                if param_types.count() <> args.count() then {
                    signature_matches = false
                } else {
                    let mut arg_i UInt = 0
                    while arg_i < args.count() then {
                        let actual_arg_expr = if arg_i == 0(UInt) then {
                            yield static_dispatch_receiver_expr(args[arg_i])
                        } else {
                            yield args[arg_i]
                        }
                        let actual_arg_type = resolve_parameterized_type(mono, actual_arg_expr.expr_type)
                        let expected_param_type = resolve_parameterized_type(mono, param_types[arg_i].val)
                        if layout_key(actual_arg_type) <> layout_key(expected_param_type) then {
                            signature_matches = false
                            break
                        }
                        arg_i += 1
                    }
                }

                if signature_matches then {
                    let concrete_expected_return = resolve_parameterized_type(mono, expected_return_type)
                    if not has_generic_parameter(concrete_expected_return) then {
                        let concrete_member_return = resolve_parameterized_type(mono, return_type_ref.val)
                        if layout_key(concrete_member_return) <> layout_key(concrete_expected_return) then {
                            signature_matches = false
                        }
                    }
                }
            },
            _ then {
                signature_matches = false
            },
        }

        if not signature_matches then {
            continue
        }

        let symbol_name = mono.storage.context.get_name(member_ref.def_id) or else member_ref.name
        return Option[Symbol].Some(Symbol(member_ref.def_id, symbol_type, SymbolKind.Function()))
    }
    return Option[Symbol].None()
}

// Enqueue an extension method instantiation request for a static method call
// if the extension method template exists in the registry.
private let enqueue_extension_method_for_static_call(
    mono ref Monomorphizer,
    base_type Type,
    method_name String,
    template_name String,
    provided_method_type_args List[Type],
    args List[ref TypedExpr],
    expected_return_type Type,
) Option[Symbol] = {
    let type_key = when base_type in {
        .StructureType(def_id) then {
            let key = layout_key(base_type)
            yield if key.is_empty() then mono.storage.context.get_name(def_id) or else key else key
        },
        .EnumType(def_id) then {
            let key = layout_key(base_type)
            yield if key.is_empty() then mono.storage.context.get_name(def_id) or else key else key
        },
        _ then layout_key(base_type),
    }

    let mut provided_method_type_arg_refs = List[ref Type].new()
    for method_type_arg in provided_method_type_args then {
        provided_method_type_arg_refs.push(box(method_type_arg))
    }

    // Look up extension method templates from the registry.
    when mono.storage.generic_templates.lookup_extension_methods(template_name) in {
        .Some(ext_templates) then {
            // Determine type_args from the base type.
            let mut type_args = List[ref Type].new()
            when base_type in {
                .GenericStruct(_, args) then {
                    for a in args then { type_args.push(box(a.val)) }
                },
                .GenericEnum(_, args) then {
                    for a in args then { type_args.push(box(a.val)) }
                },
                .StructureType(def_id) then {
                    when mono.storage.layout_to_template_info.get(
                        when mono.storage.context.get_name(def_id) in {
                            .Some(n) then n,
                            .None() then "",
                        }
                    ) in {
                        .Some(info) then {
                            for a in info.args then { type_args.push(box(a.val)) }
                        },
                        .None() then {},
                    }
                },
                .EnumType(def_id) then {
                    when mono.storage.layout_to_template_info.get(
                        when mono.storage.context.get_name(def_id) in {
                            .Some(n) then n,
                            .None() then "",
                        }
                    ) in {
                        .Some(info) then {
                            for a in info.args then { type_args.push(box(a.val)) }
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }

            // Find a template whose method-level generic args can be fully inferred
            // from this static call site, preferring checked templates first.
            let mut pass = 0(UInt)
            while pass < 2(UInt) then {
                for ext in ext_templates then {
                    if ext.method.name <> method_name then { continue }
                    if ext.type_params.count() <> type_args.count() then { continue }
                    if pass == 0(UInt) then {
                        if ext.checked_body is .None() then { continue }
                    }

                    let mut inferred_method_type_args_opt = infer_extension_method_type_args(
                        mono,
                        ext,
                        base_type,
                        type_args,
                        provided_method_type_arg_refs,
                        args,
                        expected_return_type,
                    )
                    when inferred_method_type_args_opt in {
                        .None() then {
                            // Keep strict inference: method type args must be derivable from
                            // the structured static-call argument list as-is.
                        },
                        .Some(_) then {},
                    }

                    when inferred_method_type_args_opt in {
                        .Some(method_type_args) then {
                            let concrete_lookup_key = make_extension_method_lookup_key(mono, type_key, method_name, method_type_args)
                            when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                .Some(def_id) then {
                                    let concrete_name = when mono.storage.context.get_name(def_id) in {
                                        .Some(name) then name,
                                        .None() then method_name,
                                    }
                                    let bound_method_type = resolved_method_symbol_type(mono, def_id, expected_return_type)
                                    return Option[Symbol].Some(Symbol(def_id, bound_method_type, SymbolKind.Function()))
                                },
                                .None() then {},
                            }

                            let should_defer_trait_placeholder = if ext.checked_body is .Some(_) then false else when ext.conformance_trait_name in {
                                    .Some(_) then true,
                                    .None() then false,
                            }
                            if should_defer_trait_placeholder then {
                                instantiate_trait_placeholder_method(mono, base_type, method_name, method_type_args)
                                when mono.storage.extension_method_def_ids.get(concrete_lookup_key) in {
                                    .Some(def_id) then {
                                        let concrete_name = when mono.storage.context.get_name(def_id) in {
                                            .Some(name) then name,
                                            .None() then method_name,
                                        }
                                        let bound_method_type = resolved_method_symbol_type(mono, def_id, expected_return_type)
                                        return Option[Symbol].Some(Symbol(def_id, bound_method_type, SymbolKind.Function()))
                                    },
                                    .None() then {},
                                }
                            }

                            let sym = mono.instantiate_extension_method_impl(
                                base_type,
                                template_name,
                                ext,
                                type_args,
                                method_type_args,
                            )
                            return Option[Symbol].Some(sym)
                        },
                        .None() then {},
                    }
                }
                pass += 1(UInt)
            }
        },
        .None() then {},
    }
    return Option[Symbol].None()
}

// ── resolve_types_in_global_node ──────────────────────────────────────────────

// Resolve parameterized types in all global nodes.
// Processes: function params, return types, struct fields, enum case params,
// and given declaration methods.
//
public let resolve_types_in_global_node(mono ref Monomorphizer, node ref TypedDecl) TypedDecl = {
    return when node in {
        // FunctionDecl: resolve param types, return type, and body.
        // Must resolve body types so no GenericStruct/GenericEnum reach CodeGen.
        .FunctionDecl(access, name, params, return_type, body, span, id) then {
            let mut resolved_params = List[TypedParam].new()
            for p in params then {
                let resolved_type = resolve_parameterized_type(mono, p.param_type)
                resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type)
            let resolved_body = resolve_types_in_expression(mono, body)
            yield TypedDecl.FunctionDecl(access, name, resolved_params, resolved_return, resolved_body, span, id)
        },

        // IntrinsicFunctionDecl: resolve param types and return type.
        .IntrinsicFunctionDecl(access, name, params, return_type, span, id) then {
            let mut resolved_params = List[TypedParam].new()
            for p in params then {
                let resolved_type = resolve_parameterized_type(mono, p.param_type)
                resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type)
            yield TypedDecl.IntrinsicFunctionDecl(access, name, resolved_params, resolved_return, span, id)
        },

        // ForeignFunctionDecl: resolve param types and return type.
        .ForeignFunctionDecl(access, name, params, return_type, span, id) then {
            let mut resolved_params = List[TypedParam].new()
            for p in params then {
                let resolved_type = resolve_parameterized_type(mono, p.param_type)
                resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
            }
            let resolved_return = resolve_parameterized_type(mono, return_type)
            yield TypedDecl.ForeignFunctionDecl(access, name, resolved_params, resolved_return, span, id)
        },

        // TypeStructDecl: resolve field types.
        .TypeStructDecl(access, name, fields, span, id) then {
            let mut resolved_fields = List[TypedField].new()
            for f in fields then {
                let resolved_type = resolve_parameterized_type(mono, f.field_type)
                collect_vtable_request_if_needed(mono, resolved_type)
                resolved_fields.push(TypedField(f.access, f.name, f.mutable, resolved_type, f.named))
            }
            yield TypedDecl.TypeStructDecl(access, name, resolved_fields, span, id)
        },

        // TypeEnumDecl: resolve case param types.
        .TypeEnumDecl(access, name, cases, span, id) then {
            let mut resolved_cases = List[TypedEnumCase].new()
            for c in cases then {
                let mut resolved_fields = List[TypedEnumCaseField].new()
                for f in c.fields then {
                    let resolved_type = resolve_parameterized_type(mono, f.field_type)
                    resolved_fields.push(TypedEnumCaseField(f.name, resolved_type, f.named))
                }
                resolved_cases.push(TypedEnumCase(c.name, resolved_fields))
            }
            yield TypedDecl.TypeEnumDecl(access, name, resolved_cases, span, id)
        },

        // GivenDecl: resolve method param types, return types, and bodies.
        .GivenDecl(target_type, members, span) then {
            let resolved_target = resolve_parameterized_type(mono, target_type)
            let mut resolved_members = List[ref TypedGivenMember].new()
            for m_ref in members then {
                let mut resolved_params = List[TypedParam].new()
                for p in m_ref.params then {
                    let resolved_type = resolve_parameterized_type(mono, p.param_type)
                        resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
                }
                let resolved_return = resolve_parameterized_type(mono, m_ref.return_type)
                let resolved_body = when m_ref.body in {
                    .Some(body) then {
                        let body_result = resolve_types_in_expression(mono, body)
                        yield Option[ref TypedExpr].Some(body_result)
                    },
                    .None() then Option[ref TypedExpr].None(),
                }
                resolved_members.push(box(TypedGivenMember(m_ref.def_id, m_ref.name, resolved_params, resolved_return, resolved_body)))
            }
            yield TypedDecl.GivenDecl(resolved_target, resolved_members, span)
        },

        // GivenTraitDecl: resolve method param types, return types, and bodies.
        .GivenTraitDecl(target_type, trait_name, trait_args, members, span) then {
            let resolved_target = resolve_parameterized_type(mono, target_type)
            let mut resolved_trait_args = List[Type].new()
            for trait_arg in trait_args then {
                resolved_trait_args.push(resolve_parameterized_type(mono, trait_arg))
            }
            let mut resolved_members = List[ref TypedGivenMember].new()
            for m_ref in members then {
                let mut resolved_params = List[TypedParam].new()
                for p in m_ref.params then {
                    let resolved_type = resolve_parameterized_type(mono, p.param_type)
                        resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
                }
                let resolved_return = resolve_parameterized_type(mono, m_ref.return_type)
                let resolved_body = when m_ref.body in {
                    .Some(body) then {
                        let body_result = resolve_types_in_expression(mono, body)
                        yield Option[ref TypedExpr].Some(body_result)
                    },
                    .None() then Option[ref TypedExpr].None(),
                }
                resolved_members.push(box(TypedGivenMember(m_ref.def_id, m_ref.name, resolved_params, resolved_return, resolved_body)))
            }
            yield TypedDecl.GivenTraitDecl(resolved_target, trait_name, resolved_trait_args, resolved_members, span)
        },

        // IntrinsicGivenDecl: resolve method param types, return types, and bodies.
        .IntrinsicGivenDecl(target_type, members, span) then {
            let resolved_target = resolve_parameterized_type(mono, target_type)
            let mut resolved_members = List[ref TypedGivenMember].new()
            for m_ref in members then {
                let mut resolved_params = List[TypedParam].new()
                for p in m_ref.params then {
                    let resolved_type = resolve_parameterized_type(mono, p.param_type)
                        resolved_params.push(TypedParam(p.name, p.mutable, resolved_type, p.named))
                }
                let resolved_return = resolve_parameterized_type(mono, m_ref.return_type)
                let resolved_body = when m_ref.body in {
                    .Some(body) then Option[ref TypedExpr].Some(resolve_types_in_expression(mono, body)),
                    .None() then Option[ref TypedExpr].None(),
                }
                resolved_members.push(box(TypedGivenMember(m_ref.def_id, m_ref.name, resolved_params, resolved_return, resolved_body)))
            }
            yield TypedDecl.IntrinsicGivenDecl(resolved_target, resolved_members, span)
        },

        // LetDecl: resolve decl type and initializer expression.
        .LetDecl(access, name, mutable, decl_type, initializer, span, id) then {
            let resolved_type = resolve_parameterized_type(mono, decl_type)
            let resolved_initializer = resolve_types_in_expression(mono, initializer)
            yield TypedDecl.LetDecl(access, name, mutable, resolved_type, resolved_initializer, span, id)
        },

        // ForeignLetDecl: resolve decl type.
        .ForeignLetDecl(access, name, mutable, decl_type, span, id) then {
            let resolved_type = resolve_parameterized_type(mono, decl_type)
            yield TypedDecl.ForeignLetDecl(access, name, mutable, resolved_type, span, id)
        },

        // TypeAliasDecl: resolve target type.
        .TypeAliasDecl(access, name, target, span) then {
            let resolved_target = resolve_parameterized_type(mono, target)
            yield TypedDecl.TypeAliasDecl(access, name, resolved_target, span)
        },

        // All other declarations: return unchanged.
        _ then node,
    }
}
