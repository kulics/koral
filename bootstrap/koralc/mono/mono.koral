// Monomorphization output types and MonomorphizedProgram definition.
// This file defines the auxiliary types and the output structure produced
// by the Monomorphizer after processing all instantiation requests.

using Std.Os.*
using "instantiation_request"
using "generic_template_registry"
using "codegen_view"
using "mono_types"
using "mono_functions"
using "mono_type_resolution"
using "mono_expr_substitution"

private let mono_debug_enabled() Bool = {
    return when env("KORAL_DEBUG_PHASE") in {
        .Some(value) then value == "1" or value == "true" or value == "TRUE",
        .None() then false,
    }
}

private let mono_debug(message String) Void = {
    if mono_debug_enabled() then {
        eprintln("[mono] \(message)")
    }
}

// ── InstantiatedFunction ──────────────────────────────────────────────────────

// Represents a successfully instantiated generic function.
// mangled_name is the unique C-level symbol name (e.g. "identity_Int").
// function_type is the concrete function type after type substitution.
public type InstantiatedFunction(
    mangled_name String,
    function_type Type,
)

// ── ConcreteMethodEntry ───────────────────────────────────────────────────────

// An entry in the concrete extension-method table for a given type.
// trait_conformance is Some(trait_name) when this method satisfies a trait.
public type ConcreteMethodEntry(
    symbol Symbol,
    trait_conformance [String]Option,
)

public type LoweredMethodInfo(
    receiver_type Type,
    method_name String,
    trait_conformance [String]Option,
)

public type ConcreteCallableInfo(
    def_id DefId,
    logical_name String,
    owner_type [Type]Option,
    trait_conformance [String]Option,
)

public type ReceiverCallResolution(
    callsite_def_id DefId,
    method_def_id DefId,
    logical_method_name String,
    owner [ReceiverMethodOwner]Option,
)

private let mono_receiver_lookup_type(def_id_map DefIdMap ref, t Type) Type = {
    return when t in {
        .OpaqueType(def_id) then {
            yield when def_id_map.lookup_type(def_id) in {
                .Some(mapped) then mono_receiver_lookup_type(def_id_map, mapped),
                .None() then t,
            }
        },
        .ReferenceType(inner_ref) then Type.ReferenceType(box(mono_receiver_lookup_type(def_id_map, inner_ref.val))),
        .PointerType(inner_ref) then Type.PointerType(box(mono_receiver_lookup_type(def_id_map, inner_ref.val))),
        _ then t,
    }
}

private let mono_concrete_layout_key_for_def_id(def_id_map DefIdMap ref, def_id DefId) [String]Option = {
    let name = def_id_map.get_name(def_id) or else { return [String]Option.None() }
    let module_path = def_id_map.get_module_path(def_id) or else [String]List.new()
    let is_private = when def_id_map.get_access(def_id) in {
        .Some(access) then access is .Private(),
        .None() then false,
    }
    let source_file = def_id_map.get_source_file(def_id) or else ""

    let mut parts = [String]List.new()
    if not module_path.is_empty() then {
        let mut path_str = String.new()
        let mut first = true
        for seg in module_path then {
            if not first then { path_str.push_byte('_') }
            path_str.push_string(seg)
            first = false
        }
        parts.push(path_str)
    }
    if is_private and not source_file.is_empty() then {
        let mut hash UInt32 = 0
        for byte in source_file.bytes() then {
            hash = hash.wrapping_mul(31).wrapping_add((UInt32)byte)
        }
        parts.push("f\((UInt)(hash % 10000))")
    }
    parts.push(name)

    let mut out = String.new()
    let mut first = true
    for part in parts then {
        if not first then { out.push_byte('_') }
        out.push_string(part)
        first = false
    }
    return [String]Option.Some(out)
}

private let mono_concrete_layout_key_for_type(def_id_map DefIdMap ref, t Type) String = {
    return when t in {
        .ReferenceType(inner) then "ref_\(mono_concrete_layout_key_for_type(def_id_map, inner.val))",
        .PointerType(inner) then "ptr_\(mono_concrete_layout_key_for_type(def_id_map, inner.val))",
        .WeakReferenceType(inner) then "weakref_\(mono_concrete_layout_key_for_type(def_id_map, inner.val))",
        .FunctionType(param_types, return_type) then {
            let mut out = "fn"
            for pt in param_types then {
                out.push_string("_")
                out.push_string(mono_concrete_layout_key_for_type(def_id_map, pt.val))
            }
            out.push_string("_")
            out.push_string(mono_concrete_layout_key_for_type(def_id_map, return_type.val))
            yield out
        },
        .GenericStruct(template, args) then {
            let mut out = template
            for arg in args then {
                out.push_string("_")
                out.push_string(mono_concrete_layout_key_for_type(def_id_map, arg.val))
            }
            yield out
        },
        .GenericEnum(template, args) then {
            let mut out = template
            for arg in args then {
                out.push_string("_")
                out.push_string(mono_concrete_layout_key_for_type(def_id_map, arg.val))
            }
            yield out
        },
        .StructureType(def_id) then mono_concrete_layout_key_for_def_id(def_id_map, def_id) or else layout_key(t),
        .EnumType(def_id) then mono_concrete_layout_key_for_def_id(def_id_map, def_id) or else layout_key(t),
        .OpaqueType(def_id) then mono_concrete_layout_key_for_def_id(def_id_map, def_id) or else layout_key(t),
        _ then layout_key(t),
    }
}

private let concrete_receiver_method_lookup_key(def_id_map DefIdMap ref, receiver_type Type, method_name String) String = {
    let normalized = mono_receiver_lookup_type(def_id_map, receiver_type)
    let receiver_key = mono_concrete_layout_key_for_type(def_id_map, normalized)
    return "\(receiver_key).\(method_name)"
}

private let concrete_trait_method_lookup_key(def_id_map DefIdMap ref, receiver_type Type, trait_name String, method_name String) String = {
    let normalized = mono_receiver_lookup_type(def_id_map, receiver_type)
    let receiver_key = mono_concrete_layout_key_for_type(def_id_map, normalized)
    return "\(receiver_key)|\(trait_name)|\(method_name)"
}

// ── TemplateInfo ──────────────────────────────────────────────────────────────

// Records the generic template origin of an instantiated layout.
// Used to map a layout name back to its template for error messages and
// for the final trait-placeholder resolution pass.
public type TemplateInfo(
    base_name String,
    args [Type ref]List,
)

// ── VtableRequest ─────────────────────────────────────────────────────────────

// A request to generate a vtable for a (concrete_type, trait) combination.
// Collected during type resolution whenever a trait-object type is encountered.
public type VtableRequest(
    concrete_type Type,
    trait_name String,
    trait_type_args [Type ref]List,
)

// ── MonomorphizedProgram ──────────────────────────────────────────────────────

// The output of the monomorphization phase.
// global_nodes contains only concrete declarations (no generic templates).
// static_method_lookup maps concrete receiver names to concrete method DefIds.
// concrete_callables_by_def_id carries backend-facing method ownership metadata.
// traits carries all trait declarations forward to CodeGen for vtable generation.
// vtable_requests lists all (concrete type, trait) pairs needing a vtable.
// receiver_method_dispatch and receiver_call_resolution_by_callsite map
// call-site DefId -> concrete dispatch metadata.
public type MonomorphizedProgram(
    global_nodes [TypedDecl]List,
    global_node_def_ids [[DefId]Option]List,
    static_method_lookup [String, DefId]Dict,
    receiver_method_lookup [String, DefId]Dict,
    trait_method_lookup [String, DefId]Dict,
    concrete_callables_by_def_id [UInt, ConcreteCallableInfo]Dict,
    traits [String, TraitDeclInfo]Dict,
    vtable_requests [VtableRequest]List,
    receiver_method_dispatch [UInt, ReceiverMethodDispatchInfo]Dict,
    receiver_call_resolution_by_callsite [UInt, ReceiverCallResolution]Dict,
    lowered_method_info_by_def_id [UInt, LoweredMethodInfo]Dict,
    codegen_view CodegenView,
)

given MonomorphizedProgram {
    // Look up the DefId for a static method by type name and method name.
    // The key is built as "TypeName.methodName".
    public lookup_static_method(self, type_name String, method_name String) [DefId]Option = {
        let key = "\(type_name).\(method_name)"
        return when self.codegen_view.lookup_static_method(key) in {
            .Some(def_id) then [DefId]Option.Some(def_id),
            .None() then self.static_method_lookup.get(key),
        }
    }

    public lookup_receiver_method(self, receiver_key String, method_name String) [DefId]Option = {
        let key = "\(receiver_key).\(method_name)"
        return when self.codegen_view.lookup_receiver_method(key) in {
            .Some(def_id) then [DefId]Option.Some(def_id),
            .None() then self.receiver_method_lookup.get(key),
        }
    }

    public lookup_trait_method(self, receiver_key String, trait_name String, method_name String) [DefId]Option = {
        let key = "\(receiver_key)|\(trait_name)|\(method_name)"
        return when self.codegen_view.lookup_trait_method(key) in {
            .Some(def_id) then [DefId]Option.Some(def_id),
            .None() then self.trait_method_lookup.get(key),
        }
    }

    public lookup_concrete_callable(self, def_id DefId) [ConcreteCallableInfo]Option = {
        return when self.codegen_view.callable(def_id) in {
            .Some(info) then {
                yield [ConcreteCallableInfo]Option.Some(
                    ConcreteCallableInfo(
                        info.def_id,
                        info.emitted_c_name,
                        info.owner_type,
                        info.trait_conformance,
                    ),
                )
            },
            .None() then self.concrete_callables_by_def_id.get(def_id.id),
        }
    }

    public lookup_receiver_call_resolution(self, callsite_def_id DefId) [ReceiverCallResolution]Option = {
        return self.receiver_call_resolution_by_callsite.get(callsite_def_id.id)
    }

    public lookup_global_def_id_by_node_index(self, node_index UInt) [DefId]Option = {
        if node_index >= self.global_node_def_ids.count() then {
            return [DefId]Option.None()
        }
        return self.global_node_def_ids.at(node_index)
    }

    public lookup_global_function_by_node_index(self, node_index UInt) [DefId]Option = {
        let def_id_opt = self.lookup_global_def_id_by_node_index(node_index)
        return when def_id_opt in {
            .Some(def_id) then {
                yield when self.global_nodes.at(node_index) in {
                    .FunctionDecl(_, _, _, _, _, _) then [DefId]Option.Some(def_id),
                    .IntrinsicFunctionDecl(_, _, _, _, _) then [DefId]Option.Some(def_id),
                    .ForeignFunctionDecl(_, _, _, _, _) then [DefId]Option.Some(def_id),
                    _ then [DefId]Option.None(),
                }
            },
            .None() then [DefId]Option.None(),
        }
    }

    public lookup_global_variable_by_node_index(self, node_index UInt) [DefId]Option = {
        let def_id_opt = self.lookup_global_def_id_by_node_index(node_index)
        return when def_id_opt in {
            .Some(def_id) then {
                yield when self.global_nodes.at(node_index) in {
                    .LetDecl(_, _, _, _, _, _) then [DefId]Option.Some(def_id),
                    .ForeignLetDecl(_, _, _, _, _) then [DefId]Option.Some(def_id),
                    _ then [DefId]Option.None(),
                }
            },
            .None() then [DefId]Option.None(),
        }
    }

    public lookup_global_type_by_node_index(self, node_index UInt) [DefId]Option = {
        let def_id_opt = self.lookup_global_def_id_by_node_index(node_index)
        return when def_id_opt in {
            .Some(def_id) then {
                yield when self.global_nodes.at(node_index) in {
                    .TypeStructDecl(_, _, _, _) then [DefId]Option.Some(def_id),
                    .TypeEnumDecl(_, _, _, _) then [DefId]Option.Some(def_id),
                    .GenericTypeStructDecl(_, _, _, _) then [DefId]Option.Some(def_id),
                    .GenericTypeEnumDecl(_, _, _, _) then [DefId]Option.Some(def_id),
                    .ForeignTypeDecl(_, _, _, _) then [DefId]Option.Some(def_id),
                    _ then [DefId]Option.None(),
                }
            },
            .None() then [DefId]Option.None(),
        }
    }
}

// ── TypeCheckerOutput ─────────────────────────────────────────────────────────

// The output of the type-checking phase, which serves as the sole input to
// the monomorphization phase.
//
// program              – the fully type-annotated AST
// instantiation_requests – all generic-use sites collected during type-checking
// generic_templates    – registry of every generic template (struct/enum/fn/ext)
// def_id_map           – central store for DefId metadata (names, kinds, spans…)
public type TypeCheckerOutput(
    program TypedProgram,
    instantiation_requests [InstantiationRequest]List,
    generic_templates GenericTemplateRegistry,
    def_id_map DefIdMap ref,
)

// ── MonomorphizerStorage ──────────────────────────────────────────────────────

// All mutable Monomorphizer state lives here so Monomorphizer can be passed by
// ref without copying large data onto the stack (mirrors TypeCheckerStorage).
protected type MonomorphizerStorage(
    // ── Input ────────────────────────────────────────────────────────────────
    input TypeCheckerOutput ref,

    // ── Caches ───────────────────────────────────────────────────────────────
    mut instantiated_types [String, Type]Dict,
    mut instantiated_functions [String, InstantiatedFunction]Dict,
    mut instantiated_function_symbols [String, Symbol]Dict,
    mut generated_layouts [String]Set,

    // ── Output ───────────────────────────────────────────────────────────────
    mut generated_nodes [TypedDecl]List,
    mut generated_node_def_ids [[DefId]Option]List,

    // ── State ────────────────────────────────────────────────────────────────
    mut layout_to_template_info [String, TemplateInfo]Dict,
    mut extension_methods [String, [String, ConcreteMethodEntry]Dict]Dict,
    mut extension_method_def_ids [String, DefId]Dict,
    mut lowered_method_info_by_def_id [UInt, LoweredMethodInfo]Dict,
    mut remapped_function_def_ids [UInt, [[DefId, Type]Pair]List]Dict,
    mut receiver_method_dispatch [UInt, ReceiverMethodDispatchInfo]Dict,
    mut vtable_requests [VtableRequest]List,

    // ── Work queue ───────────────────────────────────────────────────────────
    mut pending_requests [InstantiationRequest]List,
    mut processed_request_keys [String]Set,

    // ── Recursion detection ──────────────────────────────────────────────────
    mut instantiating_types [String]Set,
    mut instantiating_functions [String]Set,
    mut current_recursion_depth Int,
    mut extension_body_resolution_depth Int,

    // ── DefId allocation ─────────────────────────────────────────────────────
    def_id_map DefIdMap ref,
)

// ── Monomorphizer ─────────────────────────────────────────────────────────────

// Core monomorphization engine.  All mutable state lives in storage (heap-allocated)
// so passing Monomorphizer by ref never copies large data onto the stack.
public type Monomorphizer(protected mut storage MonomorphizerStorage ref)

// ── Monomorphizer initialisation ──────────────────────────────────────────────

// Sort a list of InstantiationRequests in-place using insertion sort with
// the deterministic compare_requests ordering.
// This ensures the work queue is processed in a reproducible order
//.
private let sort_instantiation_requests(mut list [InstantiationRequest]List) Void = {
    let n = list.count()
    let mut i = (UInt)1
    while i < n then {
        let key_req = list.at(i)
        let mut j = i
        while j > (UInt)0 then {
            let prev = list.at(j - (UInt)1)
            if compare_requests(prev, key_req) > 0 then {
                list.set_at(j, prev)
                j -= (UInt)1
            } else {
                break
            }
        }
        list.set_at(j, key_req)
        i += (UInt)1
    }
}

// Returns true when a TypedDecl is a non-generic global node that should be
// preserved verbatim in the monomorphized output.
private let is_non_generic_decl(decl TypedDecl) Bool = {
    return when decl in {
        .ForeignUsingDecl(_, _, _)       then true,
        .ForeignFunctionDecl(_, _, _, _, _) then true,
        .ForeignTypeDecl(_, _, _, _)     then true,
        .ForeignLetDecl(_, _, _, _, _)   then true,
        .LetDecl(_, _, _, _, _, _)       then true,
        .FunctionDecl(_, _, _, _, _, _)  then true,
        .TypeStructDecl(_, _, _, _)      then true,
        .TypeEnumDecl(_, _, _, _)       then true,
        .GivenDecl(target_type, members, _) then {
            yield not has_generic_parameter(target_type) and not given_members_have_generic_parameter(members)
        },
        .GivenTraitDecl(target_type, _, _, members, _) then {
            yield not has_generic_parameter(target_type) and not given_members_have_generic_parameter(members)
        },
        .IntrinsicGivenDecl(target_type, members, _) then {
            yield not has_generic_parameter(target_type) and not given_members_have_generic_parameter(members)
        },
        // 泛型类型声明也需要保留，用于生成结构体定义
        .GenericTypeStructDecl(_, _, _, _) then true,
        .GenericTypeEnumDecl(_, _, _, _)  then true,
        _ then false,
    }
}

private let given_members_have_generic_parameter(members [TypedGivenMember]List) Bool = {
    for member in members then {
        for param in member.params then {
            if has_generic_parameter(param.param_type) then { return true }
        }
        if has_generic_parameter(member.return_type) then { return true }
    }
    return false
}

given Monomorphizer {
    // Construct a Monomorphizer from a TypeCheckerOutput.
    //
    // • Non-generic global nodes are copied directly into generated_nodes.
    // • All InstantiationRequests from the input are enqueued in pending_requests.
    // • Every cache / map / set is initialised empty.
    public new(input TypeCheckerOutput ref) Monomorphizer = {
        // Collect non-generic declarations from the typed program.
        let mut initial_nodes = [TypedDecl]List.new()
        let mut initial_node_def_ids = [[DefId]Option]List.new()
        let mut decl_index UInt = 0
        for decl in input.program.declarations then {
            let top_level_def_id = if decl_index < input.program.top_level_decl_def_ids.count() then {
                yield input.program.top_level_decl_def_ids.at(decl_index)
            } else {
                yield [DefId]Option.None()
            }
            if is_non_generic_decl(decl) then {
                initial_nodes.push(decl)
                initial_node_def_ids.push(top_level_def_id)
            }
            decl_index += 1
        }

        // Copy and deduplicate instantiation requests up front to avoid
        // pathological queue growth from repeated identical requests.
        let mut requests = [InstantiationRequest]List.new()
        let mut queued_keys = [String]Set.new()
        for req in input.instantiation_requests then {
            let key = req.deduplication_key()
            if not queued_keys.contains(key) then {
                queued_keys.insert(key)
                requests.push(req)
            }
        }

        let s = box(MonomorphizerStorage(
            input,
            // caches
            [String, Type]Dict.new(),
            [String, InstantiatedFunction]Dict.new(),
            [String, Symbol]Dict.new(),
            [String]Set.new(),
            // output
            initial_nodes,
            initial_node_def_ids,
            // state
            [String, TemplateInfo]Dict.new(),
            [String, [String, ConcreteMethodEntry]Dict]Dict.new(),
            [String, DefId]Dict.new(),
            [UInt, LoweredMethodInfo]Dict.new(),
            [UInt, [[DefId, Type]Pair]List]Dict.new(),
            [UInt, ReceiverMethodDispatchInfo]Dict.new(),
            [VtableRequest]List.new(),
            // work queue
            requests,
            [String]Set.new(),
            // recursion detection
            [String]Set.new(),
            [String]Set.new(),
            0,
            0,
            // DefId allocation
            input.def_id_map,
        ))
        return Monomorphizer(s)
    }

    // ── Seed GivenDecl method DefIds ──────────────────────────────────────────

    // Register method DefIds from GivenDecl/GivenTraitDecl/IntrinsicGivenDecl
    // into extension_method_def_ids so that resolve_static_method_call_to_call
    // can find them. Resolves OpaqueType to underlying type for correct key matching.
    private seed_given_method_def_ids(self ref, node TypedDecl) Void = {
        when node in {
            .GivenDecl(target_type, members, _) then {
                self.register_given_members_def_ids(target_type, [String]Option.None(), members)
            },
            .GivenTraitDecl(target_type, trait_name, _, members, _) then {
                self.register_given_members_def_ids(target_type, [String]Option.Some(trait_name), members)
            },
            .IntrinsicGivenDecl(target_type, members, _) then {
                self.register_given_members_def_ids(target_type, [String]Option.None(), members)
            },
            _ then {},
        }
    }

    private register_given_members_def_ids(self ref, target_type Type, trait_conformance [String]Option, members [TypedGivenMember]List) Void = {
        // Resolve OpaqueType to underlying type for correct layout_key
        let resolved_type = when target_type in {
            .OpaqueType(def_id) then {
                yield when self.storage.def_id_map.lookup_type(def_id) in {
                    .Some(underlying) then underlying,
                    .None() then target_type,
                }
            },
            _ then target_type,
        }
        let type_key = layout_key(resolved_type)
        // Also compute the display name as an alternative key
        let display_name = self.storage.def_id_map.type_display_name(target_type)

        for m in members then {
            when m.body in {
                .Some(_) then {
                    if not self.storage.lowered_method_info_by_def_id.contains_key(m.def_id.id) then {
                        self.storage.lowered_method_info_by_def_id.insert(
                            m.def_id.id,
                            LoweredMethodInfo(target_type, m.name, trait_conformance),
                        )
                    }
                    let key1 = "\(type_key).\(m.name)"
                    if not self.storage.extension_method_def_ids.contains_key(key1) then {
                        self.storage.extension_method_def_ids.insert(key1, m.def_id)
                    }
                    // Also register under display name if different
                    if not display_name.is_empty() and display_name <> type_key then {
                        let key2 = "\(display_name).\(m.name)"
                        if not self.storage.extension_method_def_ids.contains_key(key2) then {
                            self.storage.extension_method_def_ids.insert(key2, m.def_id)
                        }
                    }
                    // Also register under the original opaque layout_key
                    let opaque_key = layout_key(target_type)
                    if opaque_key <> type_key and opaque_key <> display_name then {
                        let key3 = "\(opaque_key).\(m.name)"
                        if not self.storage.extension_method_def_ids.contains_key(key3) then {
                            self.storage.extension_method_def_ids.insert(key3, m.def_id)
                        }
                    }
                },
                .None() then {},
            }
        }
    }

    // ── Main monomorphization loop ────────────────────────────────────────────

    // Execute the full monomorphization pass and return a MonomorphizedProgram.
    //
    // Processing flow:
    //   1. Work-queue loop: sort → take → dedup → dispatch
    //   2. Resolve parameterized types in all generated nodes
    //   3. Final trait-placeholder resolution loop
    //   4. Build staticMethodLookup
    //   5. Assemble and return MonomorphizedProgram
    //
    public monomorphize(self ref) MonomorphizedProgram = {
        // ── Seed extension_method_def_ids from GivenDecl nodes ────────────────
        // Register method DefIds from non-generic GivenDecl/GivenTraitDecl/IntrinsicGivenDecl
        // so that resolve_static_method_call_to_call can find them.
        for node in self.storage.generated_nodes then {
            self.seed_given_method_def_ids(node)
        }

        let mut processed_iterations = 0

        // ── Work-queue loop ───────────────────────────────────────────────────
        while not self.storage.pending_requests.is_empty() then {
            if self.storage.pending_requests.count() > 50000 then {
                panic("Monomorphization pending queue exceeded 50000 entries — possible infinite instantiation loop")
            }

            processed_iterations += 1
            if processed_iterations > 200000 then {
                panic("Monomorphization request limit exceeded (200000) — possible infinite instantiation loop")
            }

            // Recursion depth guard
            if self.storage.current_recursion_depth > 100 then {
                panic("Monomorphization recursion depth exceeded 100 — possible infinite generic instantiation")
            }

            // Sort pending requests for deterministic ordering
            sort_instantiation_requests(self.storage.pending_requests)

            // Take the first request from the sorted queue
            let req = self.storage.pending_requests.remove_at(0)
            let key = req.deduplication_key()
            let verbose_log = mono_debug_enabled() and processed_iterations <= 100
            if verbose_log or (mono_debug_enabled() and processed_iterations % 250 == 0) then {
                mono_debug("loop1 start iter=\(processed_iterations) pending=\(self.storage.pending_requests.count()) key=\(key)")
            }

            // Deduplication check
            if self.storage.processed_request_keys.contains(key) then {
                continue
            }
            self.storage.processed_request_keys.insert(key)

            // Increment recursion depth before dispatching
            self.storage.current_recursion_depth += 1

            // Dispatch by kind
            when req.kind in {
                .StructType(template, args) then {
                    self.instantiate_struct_impl(template, args)
                },
                .EnumType(template, args) then {
                    self.instantiate_enum_impl(template, args)
                },
                .Function(template, args) then {
                    self.instantiate_function_impl(template, args)
                },
                .ExtensionMethod(template_name, base_type, template, type_args, method_type_args) then {
                    self.instantiate_extension_method_impl(base_type, template_name, template, type_args, method_type_args)
                },
                .TraitMethod(base_type, method_name, method_type_args) then {
                    self.instantiate_trait_placeholder_method_impl(base_type, method_name, method_type_args)
                },
            }
            if verbose_log then {
                mono_debug("loop1 done iter=\(processed_iterations) key=\(key)")
            }

            // Decrement recursion depth after dispatching
            self.storage.current_recursion_depth -= 1
        }

        // ── Post-loop: resolve parameterized types in all generated nodes ─────
        //
        // Re-seed extension_method_def_ids from any newly-generated GivenDecl nodes
        // (the work-queue loop may have instantiated new extension methods).
        for node in self.storage.generated_nodes then {
            self.seed_given_method_def_ids(node)
        }

        // Process by index — resolve_parameterized_type may push new nodes into
        // generated_nodes; keep resolving until all appended nodes are processed.
        mono_debug("resolve generated nodes count=\(self.storage.generated_nodes.count())")
        let mut resolved_nodes = [TypedDecl]List.new()
        let mut resolved_node_def_ids = [[DefId]Option]List.new()
        let mut ri = (UInt)0
        while ri < self.storage.generated_nodes.count() then {
            let node = self.storage.generated_nodes.at(ri)
            resolved_nodes.push(resolve_types_in_global_node(self, node))
            resolved_node_def_ids.push(self.storage.generated_node_def_ids.at(ri))
            ri += (UInt)1
        }
        self.storage.generated_nodes = resolved_nodes
        self.storage.generated_node_def_ids = resolved_node_def_ids

        // ── Final trait-placeholder resolution loop ───────────────────────────
        while not self.storage.pending_requests.is_empty() then {
            if self.storage.pending_requests.count() > 50000 then {
                panic("Monomorphization pending queue exceeded 50000 entries — possible infinite instantiation loop")
            }

            processed_iterations += 1
            if processed_iterations > 200000 then {
                panic("Monomorphization request limit exceeded (200000) — possible infinite instantiation loop")
            }

            sort_instantiation_requests(self.storage.pending_requests)
            let req = self.storage.pending_requests.remove_at(0)
            let key = req.deduplication_key()
            let verbose_log = mono_debug_enabled() and processed_iterations <= 100
            if verbose_log or (mono_debug_enabled() and processed_iterations % 250 == 0) then {
                mono_debug("loop2 start iter=\(processed_iterations) pending=\(self.storage.pending_requests.count()) key=\(key)")
            }
            if self.storage.processed_request_keys.contains(key) then {
                continue
            }
            self.storage.processed_request_keys.insert(key)

            when req.kind in {
                .StructType(template, args) then {
                    self.instantiate_struct_impl(template, args)
                },
                .EnumType(template, args) then {
                    self.instantiate_enum_impl(template, args)
                },
                .Function(template, args) then {
                    self.instantiate_function_impl(template, args)
                },
                .ExtensionMethod(template_name, base_type, template, type_args, method_type_args) then {
                    self.instantiate_extension_method_impl(base_type, template_name, template, type_args, method_type_args)
                },
                .TraitMethod(base_type, method_name, method_type_args) then {
                    self.instantiate_trait_placeholder_method_impl(base_type, method_name, method_type_args)
                },
            }
            if verbose_log then {
                mono_debug("loop2 done iter=\(processed_iterations) key=\(key)")
            }
        }

        // ── Build static method lookup ────────────────────────────────────────
        //
        let static_lookup = self.build_static_method_lookup(self.storage.generated_nodes)
        let receiver_method_lookup = self.build_receiver_method_lookup()
        let trait_method_lookup = self.build_trait_method_lookup()
        let concrete_callables = self.build_concrete_callable_index()
        let receiver_call_resolutions = self.build_receiver_call_resolution_index()
        let codegen_view = self.build_codegen_view(
            static_lookup,
            receiver_method_lookup,
            trait_method_lookup,
            concrete_callables,
            receiver_call_resolutions,
        )

        // ── Assemble and return MonomorphizedProgram ──────────────────────────
        return MonomorphizedProgram(
            self.storage.generated_nodes,
            self.storage.generated_node_def_ids,
            static_lookup,
            receiver_method_lookup,
            trait_method_lookup,
            concrete_callables,
            self.storage.input.generic_templates.traits,
            self.storage.vtable_requests,
            self.storage.receiver_method_dispatch,
            receiver_call_resolutions,
            self.storage.lowered_method_info_by_def_id,
            codegen_view,
        )
    }

    // ── Stub methods (implemented in later tasks) ─────────────────────────────

    // Instantiate a generic struct template with concrete type arguments.
    // Implemented in mono_types.koral (task 5.3).
    instantiate_struct_impl(self ref, template GenericStructTemplate, args [Type ref]List) Type = {
        return instantiate_struct(self, template, args)
    }

    // Instantiate a generic enum template with concrete type arguments.
    // Implemented in mono_types.koral (task 5.4).
    instantiate_enum_impl(self ref, template GenericEnumTemplate, args [Type ref]List) Type = {
        return instantiate_enum(self, template, args)
    }

    // Instantiate a generic function template with concrete type arguments.
    // Implemented in mono_functions.koral (task 6.1).
    instantiate_function_impl(self ref, template GenericFunctionTemplate, args [Type ref]List) InstantiatedFunction = {
        return instantiate_function(self, template, args)
    }

    // Instantiate a generic extension method with concrete type arguments.
    // Implemented in mono_functions.koral (task 6.2).
    instantiate_extension_method_impl(self ref, base_type Type, template_name String, template GenericExtensionMethodTemplate, type_args [Type ref]List, method_type_args [Type ref]List) Symbol = {
        let sym = instantiate_extension_method(self, base_type, template_name, template, type_args, method_type_args)
        return sym
    }

    // Resolve a trait placeholder method call to a concrete implementation.
    // Implemented in mono_functions.koral (task 6.6).
    instantiate_trait_placeholder_method_impl(self ref, base_type Type, method_name String, method_type_args [Type ref]List) Void = {
        instantiate_trait_placeholder_method(self, base_type, method_name, method_type_args)
    }

    instantiate_trait_vtable_methods_impl(self ref, concrete_type Type, trait_name String) Void = {
        instantiate_trait_vtable_methods(self, concrete_type, trait_name)
    }

    // Substitute generic type parameters in a Type.
    // Implemented in mono_type_resolution.koral (task 8.1).
    substitute_type_impl(self ref, t Type, substitution [String, Type]Dict) Type = {
        return substitute_type(self, t, substitution)
    }

    // Substitute generic type parameters in a TypeNode, resolving to a concrete Type.
    // Implemented in mono_type_resolution.koral (task 8.3).
    resolve_type_node_impl(self ref, node TypeNode, substitution [String, Type]Dict) Type = {
        return resolve_type_node(self, node, substitution)
    }

    // Substitute generic type parameters throughout a TypedExpr tree.
    // Implemented in mono_expr_substitution.koral (task 9.1).
    substitute_types_in_expression_impl(self ref, expr TypedExpr ref, substitution [String, Type]Dict) TypedExpr ref = {
        return substitute_types_in_expression(self, expr, substitution)
    }

    // Build the static method lookup table from all generated nodes.
    // Traverses all global nodes collecting method DefIds, merges extension_method_def_ids.
    // Inherent methods (from GivenDecl) take priority over trait methods (from GivenTraitDecl).
    // Key format: "TypeName.methodName"
    build_static_method_lookup(self, nodes [TypedDecl]List) [String, DefId]Dict = {
        let mut lookup = [String, DefId]Dict.new()

        // First pass: collect trait methods (lower priority).
        for node in nodes then {
            when node in {
                .GivenTraitDecl(target_type, _, _, members, _) then {
                    let type_name = self.storage.def_id_map.type_display_name(target_type)
                    let lk_name = layout_key(target_type)
                    for m in members then {
                        let key = "\(type_name).\(m.name)"
                        let lk_key = "\(lk_name).\(m.name)"
                        when lookup.get(key) in {
                            .None() then {
                                when m.body in {
                                    .Some(_) then {
                                        // Try both type_display_name and layout_key formats
                                        let found_def_id = when self.storage.extension_method_def_ids.get(key) in {
                                            .Some(def_id) then [DefId]Option.Some(def_id),
                                            .None() then when self.storage.extension_method_def_ids.get(lk_key) in {
                                                .Some(def_id) then [DefId]Option.Some(def_id),
                                                .None() then [DefId]Option.None(),
                                            },
                                        }
                                        when found_def_id in {
                                            .Some(def_id) then {
                                                lookup.insert(key, def_id)
                                                if lk_key <> key then {
                                                    lookup.insert(lk_key, def_id)
                                                }
                                            },
                                            .None() then {},
                                        }
                                    },
                                    .None() then {},
                                }
                            },
                            .Some(_) then {},
                        }
                    }
                },
                _ then {},
            }
        }

        // Second pass: collect inherent methods (higher priority — overwrite trait methods).
        for node in nodes then {
            when node in {
                .GivenDecl(target_type, members, _) then {
                    let type_name = self.storage.def_id_map.type_display_name(target_type)
                    let lk_name = layout_key(target_type)
                    for m in members then {
                        let key = "\(type_name).\(m.name)"
                        let lk_key = "\(lk_name).\(m.name)"
                        when m.body in {
                            .Some(_) then {
                                // Try both type_display_name and layout_key formats
                                let found_def_id = when self.storage.extension_method_def_ids.get(key) in {
                                    .Some(def_id) then [DefId]Option.Some(def_id),
                                    .None() then when self.storage.extension_method_def_ids.get(lk_key) in {
                                        .Some(def_id) then [DefId]Option.Some(def_id),
                                        .None() then [DefId]Option.None(),
                                    },
                                }
                                when found_def_id in {
                                    .Some(def_id) then {
                                        lookup.insert(key, def_id)
                                        if lk_key <> key then {
                                            lookup.insert(lk_key, def_id)
                                        }
                                    },
                                    .None() then {},
                                }
                            },
                            .None() then {},
                        }
                    }
                },
                _ then {},
            }
        }

        // Third pass: merge all extension_method_def_ids.
        for entry in self.storage.extension_method_def_ids.iterator() then {
            let key = entry.first
            let def_id = entry.second
            when lookup.get(key) in {
                .None() then {
                    lookup.insert(key, def_id)
                },
                .Some(_) then {},
            }
        }

        return lookup
    }

    build_concrete_callable_index(self) [UInt, ConcreteCallableInfo]Dict = {
        let mut concrete_callables = [UInt, ConcreteCallableInfo]Dict.new()
        for entry in self.storage.lowered_method_info_by_def_id.iterator() then {
            let def_id = DefId(entry.first)
            let info = entry.second
            if not concrete_callables.contains_key(def_id.id) then {
                concrete_callables.insert(
                    def_id.id,
                    ConcreteCallableInfo(
                        def_id,
                        info.method_name,
                        [Type]Option.Some(info.receiver_type),
                        info.trait_conformance,
                    ),
                )
            }
        }
        return concrete_callables
    }

    build_receiver_method_lookup(self) [String, DefId]Dict = {
        let mut lookup = [String, DefId]Dict.new()
        for entry in self.storage.lowered_method_info_by_def_id.iterator() then {
            let def_id = DefId(entry.first)
            let info = entry.second
            let key = concrete_receiver_method_lookup_key(self.storage.def_id_map, info.receiver_type, info.method_name)
            if not lookup.contains_key(key) then {
                lookup.insert(key, def_id)
            }
        }
        return lookup
    }

    build_trait_method_lookup(self) [String, DefId]Dict = {
        let mut lookup = [String, DefId]Dict.new()
        for entry in self.storage.lowered_method_info_by_def_id.iterator() then {
            let def_id = DefId(entry.first)
            let info = entry.second
            when info.trait_conformance in {
                .Some(trait_name) then {
                    let key = concrete_trait_method_lookup_key(self.storage.def_id_map, info.receiver_type, trait_name, info.method_name)
                    if not lookup.contains_key(key) then {
                        lookup.insert(key, def_id)
                    }
                },
                .None() then {},
            }
        }
        return lookup
    }

    build_receiver_call_resolution_index(self) [UInt, ReceiverCallResolution]Dict = {
        let mut resolutions = [UInt, ReceiverCallResolution]Dict.new()
        for entry in self.storage.receiver_method_dispatch.iterator() then {
            let callsite_id = entry.first
            let info = entry.second
            resolutions.insert(
                callsite_id,
                ReceiverCallResolution(
                    DefId(callsite_id),
                    info.method_def_id,
                    info.method_name,
                    info.owner,
                ),
            )
        }
        return resolutions
    }

    private append_codegen_def_id_name_index(self, mut index [String, [DefId]List]Dict, name String, def_id DefId) [String, [DefId]List]Dict = {
        if name.is_empty() then {
            return index
        }

        let mut def_ids = when index.get(name) in {
            .Some(existing) then existing,
            .None() then [DefId]List.new(),
        }

        if not def_ids.iterator().any((existing) -> existing.id == def_id.id) then {
            def_ids.push(def_id)
            index.insert(name, def_ids)
        }

        return index
    }

    private build_codegen_def_id_name_index(self) [String, [DefId]List]Dict = {
        let mut index = [String, [DefId]List]Dict.new()
        let mut id UInt = 1
        while id < self.storage.def_id_map.next_id then {
            let def_id = DefId(id)
            if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                index = self.append_codegen_def_id_name_index(index, name, def_id)
            }
            id += 1
        }
        return index
    }

    private build_codegen_type_def_id_name_index(self) [String, [DefId]List]Dict = {
        let mut index = [String, [DefId]List]Dict.new()
        let mut id UInt = 1
        while id < self.storage.def_id_map.next_id then {
            let def_id = DefId(id)
            let is_type = if self.storage.def_id_map.get_kind(def_id) is .Some(kind)
                then kind is .TypeDef(_) or kind is .GenericTemplate(_)
                else false

            if is_type and self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                index = self.append_codegen_def_id_name_index(index, name, def_id)
                if self.storage.def_id_map.lookup_type(def_id) is .Some(mapped_type) then {
                    let display_name = self.storage.def_id_map.type_display_name(mapped_type)
                    index = self.append_codegen_def_id_name_index(index, display_name, def_id)
                    index = self.append_codegen_def_id_name_index(index, mono_concrete_layout_key_for_type(self.storage.def_id_map, mapped_type), def_id)
                }
            }
            id += 1
        }
        return index
    }

    private find_codegen_type_def_id(self, type_def_ids_by_name [String, [DefId]List]Dict, name String) [DefId]Option = {
        return when type_def_ids_by_name.get(name) in {
            .Some(def_ids) then when def_ids.get((UInt)0) in {
                .Some(def_id) then [DefId]Option.Some(def_id),
                .None() then [DefId]Option.None(),
            },
            .None() then [DefId]Option.None(),
        }
    }

    private codegen_emitted_identifier_for_def(self, def_id DefId, name String, foreign_def_ids [UInt]Set) String = {
        if foreign_def_ids.contains(def_id.id) then {
            return name
        }

        if name.starts_with("_k__") then {
            return name
        }

        return self.storage.def_id_map.get_c_identifier(def_id) or else name
    }

    private codegen_compose_method_c_name(self, type_c_name String, method_name String) String = {
        let prefix = "\(type_c_name)_"
        let raw_name = if method_name.starts_with(prefix)
            then method_name
            else "\(type_c_name)_\(method_name)"
        return if raw_name.starts_with("_k__k__") then raw_name.substring(3..) else raw_name
    }

    private codegen_emitted_type_name(self, c_identifier_by_def_id [UInt, String]Dict, type_def_ids_by_name [String, [DefId]List]Dict, t Type) String = {
        return when t in {
            .StructureType(def_id) then {
                yield when c_identifier_by_def_id.get(def_id.id) in {
                    .Some(name) then name,
                    .None() then when self.storage.def_id_map.get_name(def_id) in {
                        .Some(name) then self.codegen_emitted_identifier_for_def(def_id, name, [UInt]Set.new()),
                        .None() then "T_\(def_id.id)",
                    },
                }
            },
            .EnumType(def_id) then {
                yield when c_identifier_by_def_id.get(def_id.id) in {
                    .Some(name) then name,
                    .None() then when self.storage.def_id_map.get_name(def_id) in {
                        .Some(name) then self.codegen_emitted_identifier_for_def(def_id, name, [UInt]Set.new()),
                        .None() then "U_\(def_id.id)",
                    },
                }
            },
            .GenericStruct(template, _) then {
                let layout_name = mono_concrete_layout_key_for_type(self.storage.def_id_map, t)
                yield when self.find_codegen_type_def_id(type_def_ids_by_name, layout_name) in {
                    .Some(def_id) then when c_identifier_by_def_id.get(def_id.id) in {
                        .Some(name) then name,
                        .None() then layout_name,
                    },
                    .None() then layout_name,
                }
            },
            .GenericEnum(template, _) then {
                let layout_name = mono_concrete_layout_key_for_type(self.storage.def_id_map, t)
                yield when self.find_codegen_type_def_id(type_def_ids_by_name, layout_name) in {
                    .Some(def_id) then when c_identifier_by_def_id.get(def_id.id) in {
                        .Some(name) then name,
                        .None() then layout_name,
                    },
                    .None() then layout_name,
                }
            },
            .OpaqueType(def_id) then {
                yield when self.storage.def_id_map.lookup_type(def_id) in {
                    .Some(mapped_type) then self.codegen_emitted_type_name(c_identifier_by_def_id, type_def_ids_by_name, mapped_type),
                    .None() then when c_identifier_by_def_id.get(def_id.id) in {
                        .Some(name) then name,
                        .None() then when self.storage.def_id_map.get_cname(def_id) in {
                            .Some(name) then name,
                            .None() then self.storage.def_id_map.get_name(def_id) or else "opaque_\(def_id.id)",
                        },
                    },
                }
            },
            .ReferenceType(_) then mono_concrete_layout_key_for_type(self.storage.def_id_map, t),
            .IntType() then "Int",
            .Int8Type() then "Int8",
            .Int16Type() then "Int16",
            .Int32Type() then "Int32",
            .Int64Type() then "Int64",
            .UIntType() then "UInt",
            .UInt8Type() then "UInt8",
            .UInt16Type() then "UInt16",
            .UInt32Type() then "UInt32",
            .UInt64Type() then "UInt64",
            .Float32Type() then "Float32",
            .Float64Type() then "Float64",
            .BoolType() then "Bool",
            _ then mono_concrete_layout_key_for_type(self.storage.def_id_map, t),
        }
    }

    private codegen_receiver_lookup_name(self, t Type) String = {
        return when t in {
            .ReferenceType(inner_ref) then self.codegen_receiver_lookup_name(inner_ref.val),
            .StructureType(def_id) then self.storage.def_id_map.get_name(def_id) or else "T_\(def_id.id)",
            .EnumType(def_id) then self.storage.def_id_map.get_name(def_id) or else "U_\(def_id.id)",
            .GenericStruct(template, _) then template,
            .GenericEnum(template, _) then template,
            .OpaqueType(def_id) then {
                yield when self.storage.def_id_map.lookup_type(def_id) in {
                    .Some(mapped_type) then self.codegen_receiver_lookup_name(mapped_type),
                    .None() then self.storage.def_id_map.get_name(def_id) or else self.storage.def_id_map.type_display_name(t),
                }
            },
            .IntType() then "Int",
            .Int8Type() then "Int8",
            .Int16Type() then "Int16",
            .Int32Type() then "Int32",
            .Int64Type() then "Int64",
            .UIntType() then "UInt",
            .UInt8Type() then "UInt8",
            .UInt16Type() then "UInt16",
            .UInt32Type() then "UInt32",
            .UInt64Type() then "UInt64",
            .Float32Type() then "Float32",
            .Float64Type() then "Float64",
            .BoolType() then "Bool",
            _ then self.storage.def_id_map.type_display_name(t),
        }
    }

    private build_codegen_view(self, static_lookup [String, DefId]Dict, receiver_method_lookup [String, DefId]Dict, trait_method_lookup [String, DefId]Dict, concrete_callables [UInt, ConcreteCallableInfo]Dict, receiver_call_resolutions [UInt, ReceiverCallResolution]Dict) CodegenView = {
        let def_ids_by_name = self.build_codegen_def_id_name_index()
        let type_def_ids_by_name = self.build_codegen_type_def_id_name_index()

        let mut c_identifier_by_def_id = [UInt, String]Dict.new()
        let mut foreign_function_def_ids = [UInt]Set.new()
        let mut foreign_global_var_def_ids = [UInt]Set.new()
        let mut foreign_type_def_ids = [UInt]Set.new()
        let mut foreign_def_ids = [UInt]Set.new()

        let mut node_index UInt = 0
        while node_index < self.storage.generated_nodes.count() then {
            let node = self.storage.generated_nodes.at(node_index)
            let def_id_opt = if node_index < self.storage.generated_node_def_ids.count()
                then self.storage.generated_node_def_ids.at(node_index)
                else [DefId]Option.None()

            when node in {
                .ForeignFunctionDecl(_, _, _, _, _) then when def_id_opt in {
                    .Some(def_id) then {
                        foreign_function_def_ids.insert(def_id.id)
                        foreign_def_ids.insert(def_id.id)
                    },
                    .None() then {},
                },
                .ForeignLetDecl(_, _, _, _, _) then when def_id_opt in {
                    .Some(def_id) then {
                        foreign_global_var_def_ids.insert(def_id.id)
                        foreign_def_ids.insert(def_id.id)
                    },
                    .None() then {},
                },
                .ForeignTypeDecl(_, _, _, _) then when def_id_opt in {
                    .Some(def_id) then {
                        foreign_type_def_ids.insert(def_id.id)
                        foreign_def_ids.insert(def_id.id)
                    },
                    .None() then {},
                },
                _ then {},
            }

            node_index += 1
        }

        node_index = 0
        while node_index < self.storage.generated_nodes.count() then {
            let node = self.storage.generated_nodes.at(node_index)
            let def_id_opt = if node_index < self.storage.generated_node_def_ids.count()
                then self.storage.generated_node_def_ids.at(node_index)
                else [DefId]Option.None()

            when node in {
                .GivenDecl(_, _, _) then {},
                .GivenTraitDecl(_, _, _, _, _) then {},
                .FunctionDecl(_, name, _, _, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, self.codegen_emitted_identifier_for_def(def_id, name, foreign_def_ids))
                        },
                        .None() then {},
                    }
                },
                .ForeignFunctionDecl(_, name, _, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, name)
                        },
                        .None() then {},
                    }
                },
                .ForeignLetDecl(_, name, _, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, name)
                        },
                        .None() then {},
                    }
                },
                .ForeignTypeDecl(_, name, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, name)
                        },
                        .None() then {},
                    }
                },
                .TypeStructDecl(_, name, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, self.codegen_emitted_identifier_for_def(def_id, name, foreign_def_ids))
                        },
                        .None() then {},
                    }
                },
                .TypeEnumDecl(_, name, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, self.codegen_emitted_identifier_for_def(def_id, name, foreign_def_ids))
                        },
                        .None() then {},
                    }
                },
                .GenericTypeStructDecl(_, name, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, self.codegen_emitted_identifier_for_def(def_id, name, foreign_def_ids))
                        },
                        .None() then {},
                    }
                },
                .GenericTypeEnumDecl(_, name, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, self.codegen_emitted_identifier_for_def(def_id, name, foreign_def_ids))
                        },
                        .None() then {},
                    }
                },
                .LetDecl(_, name, _, _, _, _) then {
                    when def_id_opt in {
                        .Some(def_id) then {
                            c_identifier_by_def_id.insert(def_id.id, self.codegen_emitted_identifier_for_def(def_id, name, foreign_def_ids))
                        },
                        .None() then {},
                    }
                },
                _ then {},
            }

            node_index += 1
        }

        node_index = 0
        while node_index < self.storage.generated_nodes.count() then {
            let node = self.storage.generated_nodes.at(node_index)
            when node in {
                .GivenDecl(target_type, members, _) then {
                    let type_c_name = self.codegen_emitted_type_name(c_identifier_by_def_id, type_def_ids_by_name, target_type)
                    for m in members then {
                        if m.body is .Some(_) then {
                            c_identifier_by_def_id.insert(m.def_id.id, self.codegen_compose_method_c_name(type_c_name, m.name))
                        }
                    }
                },
                .GivenTraitDecl(target_type, _, _, members, _) then {
                    let type_c_name = self.codegen_emitted_type_name(c_identifier_by_def_id, type_def_ids_by_name, target_type)
                    for m in members then {
                        if m.body is .Some(_) then {
                            c_identifier_by_def_id.insert(m.def_id.id, self.codegen_compose_method_c_name(type_c_name, m.name))
                        }
                    }
                },
                _ then {},
            }
            node_index += 1
        }

        let mut type_by_c_type_name = [String, Type]Dict.new()
        let mut id UInt = 1
        while id < self.storage.def_id_map.next_id then {
            let def_id = DefId(id)
            if c_identifier_by_def_id.get(def_id.id) is .Some(raw_c_name) then {
                when self.storage.def_id_map.get_kind(def_id) in {
                    .Some(kind) then when kind in {
                        .TypeDef(type_kind) then when type_kind in {
                            .Structure() then {
                                type_by_c_type_name.insert("struct \(raw_c_name)", Type.StructureType(def_id))
                            },
                            .Enum() then {
                                type_by_c_type_name.insert("struct \(raw_c_name)", Type.EnumType(def_id))
                            },
                            .Opaque() then {
                                type_by_c_type_name.insert(raw_c_name, Type.OpaqueType(def_id))
                            },
                            _ then {},
                        },
                        .GenericTemplate(template_kind) then when template_kind in {
                            .Structure() then {
                                type_by_c_type_name.insert("struct \(raw_c_name)", Type.StructureType(def_id))
                            },
                            .Enum() then {
                                type_by_c_type_name.insert("struct \(raw_c_name)", Type.EnumType(def_id))
                            },
                            _ then {},
                        },
                        _ then {},
                    },
                    .None() then {},
                }
            }
            id += 1
        }

        let mut callable_by_c_name = [String, CallableCodegenInfo]Dict.new()
        let mut callable_by_def_id = [UInt, CallableCodegenInfo]Dict.new()
        for entry in concrete_callables.iterator() then {
            let def_id = DefId(entry.first)
            let concrete = entry.second
            let emitted_c_name = when c_identifier_by_def_id.get(def_id.id) in {
                .Some(name) then name,
                .None() then concrete.logical_name,
            }
            let final_signature = when self.storage.def_id_map.get_signature(def_id) in {
                .Some(signature) then signature,
                .None() then FunctionSignature([Type]List.new(), Type.Unknown(), [FunctionParamSpec]List.new()),
            }
            let normalized_receiver_type = when concrete.owner_type in {
                .Some(owner_type) then [Type]Option.Some(mono_receiver_lookup_type(self.storage.def_id_map, owner_type)),
                .None() then [Type]Option.None(),
            }
            let callable = CallableCodegenInfo(
                def_id,
                emitted_c_name,
                final_signature,
                concrete.owner_type,
                concrete.trait_conformance,
                normalized_receiver_type,
                foreign_function_def_ids.contains(def_id.id),
            )
            callable_by_def_id.insert(def_id.id, callable)
            callable_by_c_name.insert(emitted_c_name, callable)
        }

        let mut receiver_dispatch_by_callsite = [UInt, CallableCodegenInfo]Dict.new()
        for entry in receiver_call_resolutions.iterator() then {
            let callsite_def_id = DefId(entry.first)
            let resolution = entry.second
            if callable_by_def_id.get(resolution.method_def_id.id) is .Some(callable) then {
                receiver_dispatch_by_callsite.insert(callsite_def_id.id, callable)
            }
        }

        let mut type_layout_by_key = [String, TypeLayoutInfo]Dict.new()
        id = 1
        while id < self.storage.def_id_map.next_id then {
            let def_id = DefId(id)
            let layout_type_opt = when self.storage.def_id_map.get_kind(def_id) in {
                .Some(kind) then when kind in {
                    .TypeDef(type_kind) then when type_kind in {
                        .Structure() then [Type]Option.Some(self.storage.def_id_map.lookup_type(def_id) or else Type.StructureType(def_id)),
                        .Enum() then [Type]Option.Some(self.storage.def_id_map.lookup_type(def_id) or else Type.EnumType(def_id)),
                        .Opaque() then [Type]Option.Some(Type.OpaqueType(def_id)),
                        _ then [Type]Option.None(),
                    },
                    .GenericTemplate(template_kind) then when template_kind in {
                        .Structure() then [Type]Option.Some(self.storage.def_id_map.lookup_type(def_id) or else Type.StructureType(def_id)),
                        .Enum() then [Type]Option.Some(self.storage.def_id_map.lookup_type(def_id) or else Type.EnumType(def_id)),
                        _ then [Type]Option.None(),
                    },
                    _ then [Type]Option.None(),
                },
                .None() then [Type]Option.None(),
            }

            when layout_type_opt in {
                .Some(layout_type) then {
                    let canonical_type = mono_receiver_lookup_type(self.storage.def_id_map, layout_type)
                    let canonical_type_key = mono_concrete_layout_key_for_type(self.storage.def_id_map, canonical_type)
                    if not type_layout_by_key.contains_key(canonical_type_key) then {
                        let emitted_type_name = self.codegen_emitted_type_name(c_identifier_by_def_id, type_def_ids_by_name, canonical_type)
                        let c_type_name = when canonical_type in {
                            .StructureType(_) then "struct \(emitted_type_name)",
                            .EnumType(_) then "struct \(emitted_type_name)",
                            .GenericStruct(_, _) then "struct \(emitted_type_name)",
                            .GenericEnum(_, _) then "struct \(emitted_type_name)",
                            .OpaqueType(_) then emitted_type_name,
                            .ReferenceType(inner_ref) then when inner_ref.val in {
                                .TraitObject(_) then "struct __koral_TraitRef",
                                _ then "struct __koral_Ref",
                            },
                            .WeakReferenceType(inner_ref) then when inner_ref.val in {
                                .TraitObject(_) then "struct __koral_TraitWeakRef",
                                _ then "struct __koral_WeakRef",
                            },
                            .FunctionType(_, _) then "struct __koral_Closure",
                            .TraitObject(_) then "struct __koral_TraitRef",
                            .IntType() then "intptr_t",
                            .Int8Type() then "int8_t",
                            .Int16Type() then "int16_t",
                            .Int32Type() then "int32_t",
                            .Int64Type() then "int64_t",
                            .UIntType() then "uintptr_t",
                            .UInt8Type() then "uint8_t",
                            .UInt16Type() then "uint16_t",
                            .UInt32Type() then "uint32_t",
                            .UInt64Type() then "uint64_t",
                            .Float32Type() then "float",
                            .Float64Type() then "double",
                            .BoolType() then "int",
                            .VoidType() then "void",
                            _ then emitted_type_name,
                        }
                        let drop_c_name = when canonical_type in {
                            .StructureType(_) then [String]Option.Some("__koral_\(emitted_type_name)_drop"),
                            .EnumType(_) then [String]Option.Some("__koral_\(emitted_type_name)_drop"),
                            _ then [String]Option.None(),
                        }
                        let vtable_type_name = when canonical_type in {
                            .StructureType(_) then [String]Option.Some(emitted_type_name),
                            .EnumType(_) then [String]Option.Some(emitted_type_name),
                            _ then [String]Option.None(),
                        }
                        let underlying_type = when layout_type in {
                            .OpaqueType(opaque_def_id) then self.storage.def_id_map.lookup_type(opaque_def_id),
                            _ then [Type]Option.None(),
                        }
                        type_layout_by_key.insert(
                            canonical_type_key,
                            TypeLayoutInfo(
                                canonical_type,
                                canonical_type_key,
                                emitted_type_name,
                                c_type_name,
                                self.codegen_receiver_lookup_name(canonical_type),
                                self.storage.def_id_map.type_display_name(canonical_type),
                                drop_c_name,
                                vtable_type_name,
                                underlying_type,
                                foreign_type_def_ids.contains(def_id.id),
                            ),
                        )
                    }
                },
                .None() then {},
            }

            id += 1
        }

        return CodegenView(
            c_identifier_by_def_id,
            def_ids_by_name,
            type_def_ids_by_name,
            type_by_c_type_name,
            callable_by_c_name,
            callable_by_def_id,
            static_lookup,
            receiver_method_lookup,
            trait_method_lookup,
            receiver_dispatch_by_callsite,
            type_layout_by_key,
            foreign_function_def_ids,
            foreign_global_var_def_ids,
            foreign_type_def_ids,
        )
    }
}

// ── MonomorphizedProgram printing ─────────────────────────────────────────────

private let mono_type_name(t Type, def_id_map DefIdMap) String = {
    return when t in {
        .StructureType(def_id) then {
            yield when def_id_map.get_name(def_id) in {
                .Some(name) then name,
                .None() then "struct#\(def_id.id)",
            }
        },
        .EnumType(def_id) then {
            yield when def_id_map.get_name(def_id) in {
                .Some(name) then name,
                .None() then "enum#\(def_id.id)",
            }
        },
        _ then type_to_string(t),
    }
}

private let print_mono_node(node TypedDecl, def_id_map DefIdMap) Void = {
    when node in {
        .FunctionDecl(access, name, params, return_type, body, span) then {
            println("  fn \(name)(...): \(mono_type_name(return_type, def_id_map))")
        },
        .IntrinsicFunctionDecl(access, name, params, return_type, span) then {
            println("  intrinsic fn \(name)(...): \(mono_type_name(return_type, def_id_map))")
        },
        .ForeignFunctionDecl(access, name, params, return_type, span) then {
            println("  foreign fn \(name)(...): \(mono_type_name(return_type, def_id_map))")
        },
        .TypeStructDecl(access, name, fields, span) then {
            println("  struct \(name) { \(fields.count()) fields }")
        },
        .TypeEnumDecl(access, name, cases, span) then {
            println("  enum \(name) { \(cases.count()) cases }")
        },
        .TraitDecl(access, name, members, span) then {
            println("  trait \(name)")
        },
        .GivenDecl(target_type, members, span) then {
            println("  given \(mono_type_name(target_type, def_id_map)) { \(members.count()) methods }")
        },
        .GivenTraitDecl(target_type, trait_name, _, members, span) then {
            println("  given \(mono_type_name(target_type, def_id_map)) \(trait_name) { \(members.count()) methods }")
        },
        _ then {},
    }
}

public let print_monomorphized_program(program MonomorphizedProgram, def_id_map DefIdMap) Void = {
    let node_count = program.global_nodes.count()
    let vtable_count = program.vtable_requests.count()
    println("MonomorphizedProgram {")
    println("  global_nodes: \(node_count)")
    for node in program.global_nodes then {
        print_mono_node(node, def_id_map)
    }
    println("  vtable_requests: \(vtable_count)")
    println("}")
}
