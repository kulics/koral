given TypeChecker {
    private contains_generic_parameter(self, t Type) Bool = {
        let mut context = self.context()
        return context.contains_generic_parameter(t)
    }

    private mentions_unresolved_generic_placeholder(self, t Type) Bool = {
        return type_mentions_unresolved_generic_placeholder(t)
    }

    private contains_generic_parameter_in_list(self, types [Type]List) Bool = {
        for t in types then {
            if self.contains_generic_parameter(t) then { return true }
        }
        return false
    }

    private same_extension_template_slot(self, current GenericExtensionMethodTemplate mut ref, candidate GenericExtensionMethodTemplate mut ref) Bool = {
        return current.method.name == candidate.method.name
            and current.type_params.count() == candidate.type_params.count()
            and current.method.type_params.count() == candidate.method.type_params.count()
            and current.conformance_trait_name == candidate.conformance_trait_name
    }

    private upsert_extension_template(self mut ref, key String, template GenericExtensionMethodTemplate mut ref) Void = {
        when self.storage.generic_templates.extension_methods.get(key) in {
            .Some(existing) then {
                let mut index = (UInt)0
                let mut replaced = false
                while index < existing.val.count() then {
                    let current = existing.val[index]
                    if self.same_extension_template_slot(current, template) then {
                        let should_replace = if template.checked_body is .Some(_) then true else current.checked_body is .None()
                        if should_replace then {
                            existing[index] = template
                        }
                        replaced = true
                        break
                    }
                    index += (UInt)1
                }
                if not replaced then {
                    existing.push(template)
                }
            },
            .None() then {
                let mut list = [GenericExtensionMethodTemplate mut ref]List.with_capacity((UInt)64)
                list.push(template)
                self.storage.generic_templates.extension_methods.insert(key, box(list))
            },
        }
    }

    // Returns the canonical extension template registry key for a type.
    // For modifier types (ref/ptr/weakref), returns fixed short names matching Swift:
    //   "Ref", "MutRef", "Ptr", "MutPtr", "WeakRef", "MutWeakRef"
    // For generic types, returns the template name (e.g. "List", "Option").
    // For concrete types, returns the type name.
    private extension_template_key(self, target_type Type) String = {
        return when target_type in {
            .ReferenceType(_) then "Ref",
            .MutableReferenceType(_) then "MutRef",
            .PointerType(_) then "Ptr",
            .MutablePointerType(_) then "MutPtr",
            .WeakReferenceType(_) then "WeakRef",
            .MutableWeakReferenceType(_) then "MutWeakRef",
            .GenericStruct(template, _) then template,
            .GenericEnum(template, _) then template,
            .StructureType(def_id) then self.context().get_name(def_id)
                or else self.context().type_display_name(target_type),
            .EnumType(def_id) then self.context().get_name(def_id)
                or else self.context().type_display_name(target_type),
            _ then self.context().type_display_name(target_type),
        }
    }

    private register_extension_method_template(
        self mut ref,
        target_type Type,
        owner_type_params [TypeParameter]List,
        method_name String,
        method_access AccessModifier,
        method_type_params [TypeParameterDecl]List,
        method_params [TypedParam]List ref,
        method_return_type TypeNode,
        conformance_trait_name [String]Option,
        checked_body [TypedExpr ref]Option ref,
        checked_return_type [Type]Option,
    ) Void = {
        let type_key = self.extension_template_key(target_type)
        let owner_template_params = self.to_template_type_params(owner_type_params)
        let method_decl = MethodDeclaration(
            method_name,
            method_access,
            method_type_params,
            method_params.val,
            method_return_type,
            unknown_span(),
        )
        let template_checked_return_type = when checked_return_type in {
            .Some(t) then [Type]Option.Some(t),
            .None() then [Type]Option.None(),
        }
        let primary_template = box(GenericExtensionMethodTemplate(
            owner_template_params,
            method_decl,
            conformance_trait_name,
            checked_body.val,
            [[Symbol]List]Option.None(),
            template_checked_return_type,
        ))
        self.upsert_extension_template(type_key, primary_template)
        when target_type in {
            .GenericStruct(_, _) then {},
            .GenericEnum(_, _) then {},
            _ then {},
        }
    }

    private update_extension_method_checked_template(
        self mut ref,
        target_type Type,
        owner_type_param_count UInt,
        method_name String,
        method_type_param_count UInt,
        conformance_trait_name [String]Option,
        checked_body [TypedExpr ref]Option ref,
        checked_return_type Type,
    ) Void = {
        let type_key = self.extension_template_key(target_type)
        when self.storage.generic_templates.extension_methods.get(type_key) in {
            .Some(existing) then {
                let mut index = (UInt)0
                while index < existing.val.count() then {
                    let current = existing.val[index]
                    if current.method.name == method_name
                        and current.type_params.count() == owner_type_param_count
                        and current.method.type_params.count() == method_type_param_count
                        and current.conformance_trait_name == conformance_trait_name then {
                        if checked_body.val is .Some(_) then {
                            current.checked_body = checked_body.val
                        }
                        current.checked_return_type = [Type]Option.Some(checked_return_type)
                        return
                    }
                    index += (UInt)1
                }
                return
            },
            .None() then {
                return
            },
        }
    }

    private register_trait_tool_templates_for_concrete_type(self mut ref, target_type Type, owner_type_params [TypeParameter]List, trait_name String, existing_members [TypedGivenMember]List ref) Void = {
        // Swift does not maintain a second concrete-signature side cache for
        // trait conformance members here; direct calls are resolved through the
        // conformance lookup path. Keeping an extra copy in `method_table`
        // causes drift and stale-value bugs in bootstrap.
        when self.storage.generic_templates.extension_methods.get(trait_name) in {
            .Some(tool_templates_ref) then {
                let type_key = self.extension_template_key(target_type)
                let concrete_type_params = self.to_template_type_params(owner_type_params)
                for template in tool_templates_ref.val then {
                    if template.checked_body is .None() then {
                        continue
                    }
                    let mut already_present = false
                    for member in existing_members.val then {
                        if member.name == template.method.name then {
                            already_present = true
                        }
                    }
                    if already_present then {
                        continue
                    }
                    self.upsert_extension_template(
                        type_key,
                        box(GenericExtensionMethodTemplate(
                            concrete_type_params,
                            template.method,
                            [String]Option.Some(trait_name),
                            template.checked_body,
                            template.checked_parameters,
                            template.checked_return_type,
                        ))
                    )
                    when target_type in {
                        .GenericStruct(_, _) then {},
                        .GenericEnum(_, _) then {},
                        .StructureType(def_id) then {
                            if self.context().get_name(def_id) is .Some(name) then {
                                if name <> type_key then {
                                    self.upsert_extension_template(
                                        name,
                                        box(GenericExtensionMethodTemplate(
                                            concrete_type_params,
                                            template.method,
                                            [String]Option.Some(trait_name),
                                            template.checked_body,
                                            template.checked_parameters,
                                            template.checked_return_type,
                                        ))
                                    )
                                }
                            }
                        },
                        .EnumType(def_id) then {
                            if self.context().get_name(def_id) is .Some(name) then {
                                if name <> type_key then {
                                    self.upsert_extension_template(
                                        name,
                                        box(GenericExtensionMethodTemplate(
                                            concrete_type_params,
                                            template.method,
                                            [String]Option.Some(trait_name),
                                            template.checked_body,
                                            template.checked_parameters,
                                            template.checked_return_type,
                                        ))
                                    )
                                }
                            }
                        },
                        _ then {},
                    }
                }
            },
            .None() then {
            },
        }
    }

    private register_conformance_method_signatures_for_concrete_type(self, target_type Type, members [TypedGivenMember]List ref) Void = {
        let type_key = self.extension_template_key(target_type)
        for member in members.val then {
            if self.lookup_method_signature(type_key, member.name) is .Some(_) then {
                continue
            }

            let method_symbol = self.make_method_callable_symbol(member.name, member.params, member.return_type)
            self.storage.method_table.register(type_key, member.name, method_symbol)
            when target_type in {
                .GenericStruct(template_name, _) then self.storage.method_table.register(template_name, member.name, method_symbol),
                .GenericEnum(template_name, _) then self.storage.method_table.register(template_name, member.name, method_symbol),
                .StructureType(def_id) then {
                    if self.context().get_name(def_id) is .Some(name) then {
                        if name <> type_key then {
                            self.storage.method_table.register(name, member.name, method_symbol)
                        }
                    }
                },
                .EnumType(def_id) then {
                    if self.context().get_name(def_id) is .Some(name) then {
                        if name <> type_key then {
                            self.storage.method_table.register(name, member.name, method_symbol)
                        }
                    }
                },
                _ then {},
            }
        }
    }

    private backfill_trait_tool_method_to_existing_conformances(
        self mut ref,
        trait_name String,
        method_name String,
        method_access AccessModifier,
        method_type_params [TypeParameterDecl]List,
        method_params [TypedParam]List,
        method_return_type TypeNode,
        return_type Type,
    ) Void = {
        let method_decl = MethodDeclaration(
            method_name,
            method_access,
            method_type_params,
            method_params,
            method_return_type,
            unknown_span(),
        )
        for conformance in self.storage.generic_trait_conformance_templates then {
            if conformance.trait_name <> trait_name then {
                continue
            }

            let type_key = self.extension_template_key(conformance.target_type)
            self.upsert_extension_template(
                type_key,
                box(GenericExtensionMethodTemplate(
                    conformance.owner_type_params,
                    method_decl,
                    [String]Option.Some(trait_name),
                    [TypedExpr ref]Option.None(),
                    [[Symbol]List]Option.None(),
                    [Type]Option.Some(return_type),
                ))
            )
            when conformance.target_type in {
                .GenericStruct(_, _) then {},
                .GenericEnum(_, _) then {},
                .StructureType(def_id) then {
                    if self.context().get_name(def_id) is .Some(name) then {
                        if name <> type_key then {
                            self.upsert_extension_template(
                                name,
                                box(GenericExtensionMethodTemplate(
                                    conformance.owner_type_params,
                                    method_decl,
                                    [String]Option.Some(trait_name),
                                    [TypedExpr ref]Option.None(),
                                    [[Symbol]List]Option.None(),
                                    [Type]Option.Some(return_type),
                                ))
                            )
                        }
                    }
                },
                .EnumType(def_id) then {
                    if self.context().get_name(def_id) is .Some(name) then {
                        if name <> type_key then {
                            self.upsert_extension_template(
                                name,
                                box(GenericExtensionMethodTemplate(
                                    conformance.owner_type_params,
                                    method_decl,
                                    [String]Option.Some(trait_name),
                                    [TypedExpr ref]Option.None(),
                                    [[Symbol]List]Option.None(),
                                    [Type]Option.Some(return_type),
                                ))
                            )
                        }
                    }
                },
                _ then {},
            }
        }
    }

    private backfill_checked_trait_tool_method_to_existing_conformances(
        self mut ref,
        trait_name String,
        method_name String,
        method_access AccessModifier,
        method_type_params [TypeParameterDecl]List,
        method_params [TypedParam]List ref,
        method_return_type TypeNode,
        checked_body [TypedExpr ref]Option,
        checked_return_type Type,
    ) Void = {
        let method_decl = MethodDeclaration(
            method_name,
            method_access,
            method_type_params,
            method_params.val,
            method_return_type,
            unknown_span(),
        )
        for conformance in self.storage.generic_trait_conformance_templates then {
            if conformance.trait_name <> trait_name then {
                continue
            }
            let type_key = self.extension_template_key(conformance.target_type)
            self.upsert_extension_template(
                type_key,
                box(GenericExtensionMethodTemplate(
                    conformance.owner_type_params,
                    method_decl,
                    [String]Option.Some(trait_name),
                    checked_body,
                    [[Symbol]List]Option.None(),
                    [Type]Option.Some(checked_return_type),
                ))
            )
            when conformance.target_type in {
                .GenericStruct(_, _) then {},
                .GenericEnum(_, _) then {},
                .StructureType(def_id) then {
                    if self.context().get_name(def_id) is .Some(name) then {
                        if name <> type_key then {
                            self.upsert_extension_template(
                                name,
                                box(GenericExtensionMethodTemplate(
                                    conformance.owner_type_params,
                                    method_decl,
                                    [String]Option.Some(trait_name),
                                    checked_body,
                                    [[Symbol]List]Option.None(),
                                    [Type]Option.Some(checked_return_type),
                                ))
                            )
                        }
                    }
                },
                .EnumType(def_id) then {
                    if self.context().get_name(def_id) is .Some(name) then {
                        if name <> type_key then {
                            self.upsert_extension_template(
                                name,
                                box(GenericExtensionMethodTemplate(
                                    conformance.owner_type_params,
                                    method_decl,
                                    [String]Option.Some(trait_name),
                                    checked_body,
                                    [[Symbol]List]Option.None(),
                                    [Type]Option.Some(checked_return_type),
                                ))
                            )
                        }
                    }
                },
                _ then {},
            }
        }
    }

    private register_generic_function_template(
        self,
        name String,
        type_params [TypeParameter]List,
        params [Param]List,
        return_type TypeNode,
        checked_body [TypedExpr ref]Option,
        checked_return_type [Type]Option,
    ) Void = {
        if self.storage.global_scope.lookup(name) is .Some(sym) then {
            let template = GenericFunctionTemplate(
                sym.def_id,
                name,
                self.to_template_type_params(type_params),
                self.to_template_params(params),
                return_type,
                checked_body,
                [[Symbol]List]Option.None(),
                checked_return_type,
            )
            self.storage.generic_templates.function_templates.insert(name, template)
        }
    }

    // Resolve extension template signature for modifier types (ref/ptr) and weakref types.
    // When the base type is a modifier type, look up extension methods
    // registered under "Ref" / "MutRef" / "Ptr" / "MutPtr" / "WeakRef" / "MutWeakRef" keys.
    // For mutable variants, checks the mutable key first, then falls back to the immutable key.
    protected resolve_modifier_extension_template_signature(self, base_type Type, method_name String) [Symbol]Option = {
        let mut keys = [String]List.new()
        let mut inner_type_opt = [Type]Option.None()
        when base_type in {
            .ReferenceType(inner) then {
                keys.push("Ref")
                inner_type_opt = [Type]Option.Some(inner.val)
            },
            .MutableReferenceType(inner) then {
                keys.push("MutRef")
                keys.push("Ref")
                inner_type_opt = [Type]Option.Some(inner.val)
            },
            .PointerType(inner) then {
                keys.push("Ptr")
                inner_type_opt = [Type]Option.Some(inner.val)
            },
            .MutablePointerType(inner) then {
                keys.push("MutPtr")
                keys.push("Ptr")
                inner_type_opt = [Type]Option.Some(inner.val)
            },
            _ then { return [Symbol]Option.None() },
        }

        let inner_type = when inner_type_opt in {
            .Some(t) then t,
            .None() then { return [Symbol]Option.None() },
        }

        for key in keys then {
            when self.storage.generic_templates.lookup_extension_method_ref(
                key,
                method_name,
                [UInt]Option.None(),
                [UInt]Option.Some((UInt)1),
            ) in {
                .Some(template_ref) then {
                    let template = template_ref.val
                    let mut bindings = [String, Type]Dict.new()
                    if template.type_params.count() > (UInt)0 then {
                        bindings.insert(template.type_params[(UInt)0].name, inner_type)
                    }
                    bindings.insert("Self", base_type)
                    let mut typed_params = [TypedParam]List.new()
                    for param in template.method.params then {
                        typed_params.push(
                            TypedParam(
                                param.name,
                                param.mutable,
                                self.apply_type_bindings(param.param_type, bindings),
                                param.named,
                            )
                        )
                    }
                    let return_type = when template.checked_return_type in {
                        .Some(ret) then self.apply_type_bindings(ret, bindings),
                        .None() then Type.Unknown(),
                    }
                    return [Symbol]Option.Some(self.make_method_callable_symbol(method_name, typed_params, return_type))
                },
                .None() then {},
            }
        }
        return [Symbol]Option.None()
    }

    protected resolve_weakref_extension_template_signature(self, base_type Type, method_name String) [Symbol]Option = {
        let mut keys = [String]List.new()
        let mut inner_type_opt = [Type]Option.None()
        when base_type in {
            .WeakReferenceType(inner) then {
                keys.push("WeakRef")
                inner_type_opt = [Type]Option.Some(inner.val)
            },
            .MutableWeakReferenceType(inner) then {
                keys.push("MutWeakRef")
                keys.push("WeakRef")
                inner_type_opt = [Type]Option.Some(inner.val)
            },
            _ then { return [Symbol]Option.None() },
        }
        let inner_type = when inner_type_opt in {
            .Some(t) then t,
            .None() then { return [Symbol]Option.None() },
        }
        for key in keys then {
            when self.storage.generic_templates.lookup_extension_method_ref(
                key,
                method_name,
                [UInt]Option.None(),
                [UInt]Option.Some((UInt)1),
            ) in {
                .Some(template_ref) then {
                    let template = template_ref.val
                    let mut bindings = [String, Type]Dict.new()
                    // Bind the type parameter (e.g., T) to the inner type
                    if template.type_params.count() > (UInt)0 then {
                        bindings.insert(template.type_params[(UInt)0].name, inner_type)
                    }
                    bindings.insert("Self", base_type)
                    let mut typed_params = [TypedParam]List.new()
                    for param in template.method.params then {
                        typed_params.push(
                            TypedParam(
                                param.name,
                                param.mutable,
                                self.apply_type_bindings(param.param_type, bindings),
                                param.named,
                            )
                        )
                    }
                    let return_type = when template.checked_return_type in {
                        .Some(ret) then self.apply_type_bindings(ret, bindings),
                        .None() then Type.Unknown(),
                    }
                    return [Symbol]Option.Some(self.make_method_callable_symbol(method_name, typed_params, return_type))
                },
                .None() then {},
            }
        }
        return [Symbol]Option.None()
    }

    private maybe_record_extension_method_instantiation(self, base_type Type, method_name String, method_type_args [Type]List) Void = {
        let normalized_base = base_type
        if self.contains_generic_parameter(normalized_base) then { return }
        if self.contains_generic_parameter_in_list(method_type_args) then { return }

        let mut template_name_opt = [String]Option.None()
        let mut extension_type_args = [Type ref]List.new()
        when normalized_base in {
            .GenericStruct(template_name, args) then {
                template_name_opt = [String]Option.Some(template_name)
                for arg in args then {
                    extension_type_args.push(box(arg.val))
                }
            },
            .GenericEnum(template_name, args) then {
                template_name_opt = [String]Option.Some(template_name)
                for arg in args then {
                    extension_type_args.push(box(arg.val))
                }
            },
            .StructureType(def_id) then {
                if self.context().get_name(def_id) is .Some(name) then {
                    template_name_opt = [String]Option.Some(name)
                }
            },
            .EnumType(def_id) then {
                if self.context().get_name(def_id) is .Some(name) then {
                    template_name_opt = [String]Option.Some(name)
                }
            },
            .ReferenceType(inner) then {
                template_name_opt = [String]Option.Some("Ref")
                extension_type_args.push(box(inner.val))
            },
            .MutableReferenceType(inner) then {
                template_name_opt = [String]Option.Some("MutRef")
                extension_type_args.push(box(inner.val))
            },
            .PointerType(inner) then {
                template_name_opt = [String]Option.Some("Ptr")
                extension_type_args.push(box(inner.val))
            },
            .WeakReferenceType(inner) then {
                template_name_opt = [String]Option.Some("WeakRef")
                extension_type_args.push(box(inner.val))
            },
            .MutableWeakReferenceType(inner) then {
                template_name_opt = [String]Option.Some("MutWeakRef")
                extension_type_args.push(box(inner.val))
            },
            _ then {},
        }

        let template_name = when template_name_opt in {
            .Some(name) then name,
            .None() then { return },
        }
        let method_type_args_ref = self.to_type_ref_list(method_type_args)
        let receiver_is_generic_instance = when normalized_base in {
            .GenericStruct(_, _) then true,
            .GenericEnum(_, _) then true,
            _ then false,
        }
        if self.storage.generic_templates.lookup_extension_methods(template_name) is .Some(ext_templates) then {
            if select_extension_template(
                ext_templates,
                method_name,
                [UInt]Option.Some(method_type_args_ref.count()),
                [UInt]Option.Some(extension_type_args.count()),
            ) is .Some(template) then {
                let request_template = GenericExtensionMethodTemplate(
                    template.type_params,
                    template.method,
                    template.conformance_trait_name,
                    [TypedExpr ref]Option.None(),
                    [[Symbol]List]Option.None(),
                    [Type]Option.None(),
                )
                self.record_instantiation_request(InstantiationRequest(
                    InstantiationKind.ExtensionMethod(
                        template_name,
                        normalized_base,
                        request_template,
                        extension_type_args,
                        method_type_args_ref,
                    ),
                    0,
                    self.storage.file_path,
                ))
            }
        }
    }

    private maybe_record_trait_method_instantiation(self, base_type Type, method_name String, method_type_args [Type]List) Void = {
        let normalized_base = when base_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then base_type,
        }
        if self.contains_generic_parameter(normalized_base) then { return }
        if self.contains_generic_parameter_in_list(method_type_args) then { return }
        self.record_instantiation_request(InstantiationRequest(
            InstantiationKind.TraitMethod(normalized_base, method_name, self.to_type_ref_list(method_type_args)),
            0,
            self.storage.file_path,
        ))
    }

}
