// Diagnostic severity level.
public type DiagnosticLevel {
    Error(),
    Warning(),
    Note(),
}

given DiagnosticLevel {
    public to_string(self) String = {
        return when self in {
            .Error() then "error",
            .Warning() then "warning",
            .Note() then "note",
        }
    }
}

// A single diagnostic message with source location.
public type Diagnostic(
    level DiagnosticLevel,
    message String,
    span SourceSpan,
    file_name String,
    is_primary Bool,
)

// Collects diagnostics (errors, warnings, notes) during compilation.
public type DiagnosticCollector(
    mut diagnostics [Diagnostic]List,
)

given DiagnosticCollector {
    public new() DiagnosticCollector = {
        return DiagnosticCollector([Diagnostic]List.new())
    }

    public error(self ref, message String, span SourceSpan, file_name String) Void = {
        self.diagnostics.push(Diagnostic(DiagnosticLevel.Error(), message, span, file_name, true))
    }

    public warning(self ref, message String, span SourceSpan, file_name String) Void = {
        self.diagnostics.push(Diagnostic(DiagnosticLevel.Warning(), message, span, file_name, false))
    }

    public note(self ref, message String, span SourceSpan, file_name String) Void = {
        self.diagnostics.push(Diagnostic(DiagnosticLevel.Note(), message, span, file_name, false))
    }

    public has_errors(self) Bool = {
        for d in self.diagnostics then {
            if when d.level in { .Error() then true, _ then false } then {
                return true
            }
        }
        return false
    }

    public get_diagnostics(self) [Diagnostic]List = {
        return self.diagnostics
    }

    public clear(self ref) Void = {
        self.diagnostics = [Diagnostic]List.new()
    }

    // Renders all diagnostics as a formatted string.
    // Format: {file_name}:{line}:{col}: {level}: {message}
    public render(self) String = {
        let mut out = ""
        for d in self.diagnostics then {
            let line = d.span.start.line
            let col = d.span.start.column
            let level = d.level.to_string()
            out.push_string("\(d.file_name):\(line):\(col): \(level): \(d.message)\n")
        }
        return out
    }
}
