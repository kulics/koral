// compiler_context.koral - 统一编译上下文
//
// 对应 compiler/Sources/KoralCompiler/Sema/CompilerContext.swift
//
// 提供统一的查询/更新接口，封装 DefIdMap 的访问，
// 避免直接依赖全局可变状态。
//
// MethodKind, SymbolInfo, StructTypeInfo, EnumTypeInfo 定义在
// bootstrap/koralc/typed/types.koral 中，通过模块系统可见。

// ── CompilerContext ───────────────────────────────────────────────────────────

/// 统一编译上下文
///
/// 封装 DefIdMap ref，提供不可变查询 API 和显式更新 API。
/// 使用 ref 持有 DefIdMap，与 Swift 版本的 class 语义一致，
/// 避免 ~500 字节的 DefIdMap 在栈上复制。
public type CompilerContext(
    mut def_id_map mut ref DefIdMap,
)

given CompilerContext {
    public new() CompilerContext = {
        return CompilerContext(box(DefIdMap.new()))
    }

    public from_def_id_map(map mut ref DefIdMap) CompilerContext = {
        return CompilerContext(map)
    }

    // ── DefIdMap 查询 ─────────────────────────────────────────────────────

    public get_name(self ref, def_id DefId) Option[String] = {
        return self.def_id_map.get_name(def_id)
    }

    public get_module_path(self ref, def_id DefId) Option[List[String]] = {
        return self.def_id_map.get_module_path(def_id)
    }

    public get_source_file(self ref, def_id DefId) Option[String] = {
        return self.def_id_map.get_source_file(def_id)
    }

    public get_package_id(self ref, def_id DefId) Option[String] = {
        return self.def_id_map.get_package_id(def_id)
    }

    public get_kind(self ref, def_id DefId) Option[DefKind] = {
        return self.def_id_map.get_kind(def_id)
    }

    public get_access(self ref, def_id DefId) Option[AccessModifier] = {
        return self.def_id_map.get_access(def_id)
    }

    public get_span(self ref, def_id DefId) Option[SourceSpan] = {
        return self.def_id_map.get_span(def_id)
    }

    public get_qualified_name(self ref, def_id DefId) Option[String] = {
        return self.def_id_map.get_qualified_name(def_id)
    }

    public get_c_identifier(self ref, def_id DefId) Option[String] = {
        return self.def_id_map.get_c_identifier(def_id)
    }

    public get_symbol_type(self ref, def_id DefId) Option[Type] = {
        return self.def_id_map.get_symbol_type(def_id)
    }

    public get_symbol_kind(self ref, def_id DefId) Option[SymbolKind] = {
        return self.def_id_map.get_symbol_kind(def_id)
    }

    public get_symbol_method_kind(self ref, def_id DefId) Option[MethodKind] = {
        return self.def_id_map.get_symbol_method_kind(def_id)
    }

    public get_symbol_mutable(self ref, def_id DefId) Option[Bool] = {
        return self.def_id_map.get_symbol_mutable(def_id)
    }

    public get_symbol(self ref, def_id DefId) Option[Symbol] = {
        return when self.get_symbol_type(def_id) in {
            .Some(symbol_type) then when self.get_symbol_kind(def_id) in {
                .Some(kind) then Option[Symbol].Some(Symbol(def_id, symbol_type, kind)),
                .None() then Option[Symbol].None(),
            },
            .None() then Option[Symbol].None(),
        }
    }

    public symbol_name(self ref, symbol Symbol) String = {
        return self.get_name(symbol.def_id) or else ""
    }

    public symbol_name_or(self ref, symbol Symbol, fallback String) String = {
        return self.get_name(symbol.def_id) or else fallback
    }

    public is_symbol_mutable(self ref, def_id DefId) Bool = {
        return when self.def_id_map.get_symbol_mutable(def_id) in {
            .Some(v) then v,
            .None() then false,
        }
    }

    // ── DefId 查找 ────────────────────────────────────────────────────────

    public lookup_def_id(self ref, module_path List[String], name String, source_file Option[String]) Option[DefId] = {
        return self.def_id_map.lookup(module_path, name, source_file)
    }

    // ── DefId 分配 ────────────────────────────────────────────────────────

    public allocate_def_id(
        self mut ref,
        module_path List[String],
        name String,
        kind DefKind,
        source_file String,
        access AccessModifier,
        span SourceSpan,
    ) DefId = {
        return self.def_id_map.allocate_full(name, kind, module_path, source_file, "", access, span)
    }

    public allocate(self ref, name String, kind DefKind) DefId = {
        return self.def_id_map.allocate(name, kind)
    }

    public allocate_unindexed(self ref, name String, kind DefKind) DefId = {
        return self.def_id_map.allocate_unindexed(name, kind)
    }

    public allocate_full(
        self ref,
        name String,
        kind DefKind,
        module_path List[String],
        source_file String,
        access AccessModifier,
        span SourceSpan,
    ) DefId = {
        return self.def_id_map.allocate_full(name, kind, module_path, source_file, "", access, span)
    }

    public allocate_full_in_package(
        self ref,
        name String,
        kind DefKind,
        module_path List[String],
        source_file String,
        package_id String,
        access AccessModifier,
        span SourceSpan,
    ) DefId = {
        return self.def_id_map.allocate_full(name, kind, module_path, source_file, package_id, access, span)
    }

    // ── 符号创建 ──────────────────────────────────────────────────────────

    public create_symbol(
        self mut ref,
        name String,
        module_path List[String],
        source_file String,
        symbol_type Type,
        kind SymbolKind,
        method_kind MethodKind,
        access AccessModifier,
        span SourceSpan,
        is_mutable Bool,
    ) Symbol = {
        let def_kind = when kind in {
            .Function() then DefKind.Function(),
            .Variable(_) then DefKind.Variable(),
            .TypeSymbol() then {
                yield when symbol_type in {
                    .OpaqueType(_) then DefKind.TypeDef(TypeDefKind.Opaque()),
                    _ then DefKind.TypeDef(TypeDefKind.Structure()),
                }
            },
            .Module() then DefKind.Module(),
        }

        let def_id = when access in {
            .Private() then when self.def_id_map.lookup_exact(module_path, name, source_file) in {
                .Some(existing) then existing,
                .None() then self.def_id_map.allocate_full(name, def_kind, module_path, source_file, "", access, span),
            },
            _ then when self.def_id_map.lookup(module_path, name, Option[String].None()) in {
                .Some(existing) then existing,
                .None() then self.def_id_map.allocate_full(name, def_kind, module_path, source_file, "", access, span),
            },
        }

        self.def_id_map.set_symbol_info(def_id, SymbolInfo(symbol_type, kind, method_kind, is_mutable))

        return Symbol(def_id, symbol_type, kind)
    }

    public create_symbol_with_package(
        self mut ref,
        name String,
        module_path List[String],
        source_file String,
        symbol_type Type,
        kind SymbolKind,
        method_kind MethodKind,
        access AccessModifier,
        span SourceSpan,
        is_mutable Bool,
        package_id String,
    ) Symbol = {
        let def_kind = when kind in {
            .Function() then DefKind.Function(),
            .Variable(_) then DefKind.Variable(),
            .TypeSymbol() then {
                yield when symbol_type in {
                    .OpaqueType(_) then DefKind.TypeDef(TypeDefKind.Opaque()),
                    _ then DefKind.TypeDef(TypeDefKind.Structure()),
                }
            },
            .Module() then DefKind.Module(),
        }

        let def_id = when access in {
            .Private() then when self.def_id_map.lookup_exact(module_path, name, source_file) in {
                .Some(existing) then existing,
                .None() then self.def_id_map.allocate_full(name, def_kind, module_path, source_file, package_id, access, span),
            },
            _ then when self.def_id_map.lookup(module_path, name, Option[String].None()) in {
                .Some(existing) then existing,
                .None() then self.def_id_map.allocate_full(name, def_kind, module_path, source_file, package_id, access, span),
            },
        }

        self.def_id_map.set_symbol_info(def_id, SymbolInfo(symbol_type, kind, method_kind, is_mutable))

        return Symbol(def_id, symbol_type, kind)
    }

    // ── 类型定义查询 ──────────────────────────────────────────────────────

    public get_struct_fields(self ref, def_id DefId) Option[List[StructField]] = {
        return self.def_id_map.get_struct_fields(def_id)
    }

    public get_struct_fields_by_raw_id(self ref, raw_id UInt) Option[List[StructField]] = {
        return self.def_id_map.get_struct_fields(DefId(raw_id))
    }

    public def_id_name_equals(self ref, def_id DefId, expected String) Bool = {
        for entry in self.def_id_map.names then {
            if entry.first == def_id.id then {
                return entry.second == expected
            }
        }
        return false
    }

    public get_enum_cases(self ref, def_id DefId) Option[List[EnumCaseInfo]] = {
        return self.def_id_map.get_enum_cases(def_id)
    }

    public get_enum_cases_by_raw_id(self ref, raw_id UInt) Option[List[EnumCaseInfo]] = {
        return self.def_id_map.get_enum_cases(DefId(raw_id))
    }

    public enum_case_tag_index_by_raw_id(self ref, raw_id UInt, case_name String) UInt = {
        let zero UInt = 0
        for entry in self.def_id_map.enum_cases.iterator() then {
            if entry.first == raw_id then {
                let cases = entry.second
                let mut idx UInt = 0
                for case_info in cases then {
                    if case_info.name == case_name or case_info.name.ends_with(".\(case_name)") then {
                        return idx
                    }
                    idx += 1(UInt)
                }
                return zero
            }
        }
        return zero
    }

    public enum_case_param_specs_by_raw_id(self ref, raw_id UInt, case_name String) List[FunctionParamSpec] = {
        for entry in self.def_id_map.enum_cases.iterator() then {
            if entry.first == raw_id then {
                let cases = entry.second
                let mut specs = List[FunctionParamSpec].new()
                for case_info in cases then {
                    if case_info.name == case_name or case_info.name.ends_with(".\(case_name)") then {
                        for param in case_info.params then {
                            specs.push(FunctionParamSpec(param.name, param.named))
                        }
                    }
                }
                return specs
            }
        }
        return List[FunctionParamSpec].new()
    }

    public enum_case_params_by_raw_id(self ref, raw_id UInt, case_name String) List[EnumCaseParam] = {
        for entry in self.def_id_map.enum_cases.iterator() then {
            if entry.first == raw_id then {
                let cases = entry.second
                for case_info in cases then {
                    if case_info.name == case_name or case_info.name.ends_with(".\(case_name)") then {
                        return case_info.params
                    }
                }
                return List[EnumCaseParam].new()
            }
        }
        return List[EnumCaseParam].new()
    }

    public enum_has_case_by_raw_id(self ref, raw_id UInt, case_name String) Bool = {
        for entry in self.def_id_map.enum_cases.iterator() then {
            if entry.first == raw_id then {
                let cases = entry.second
                for case_info in cases then {
                    if case_info.name == case_name or case_info.name.ends_with(".\(case_name)") then {
                        return true
                    }
                }
                return false
            }
        }
        return false
    }

    public is_foreign_struct(self ref, def_id DefId) Bool = {
        return self.def_id_map.is_foreign_struct(def_id)
    }

    public get_foreign_struct_fields(self ref, def_id DefId) Option[List[StructField]] = {
        return self.def_id_map.get_foreign_struct_fields(def_id)
    }

    public get_param_specs(self ref, def_id DefId) Option[List[FunctionParamSpec]] = {
        return self.def_id_map.get_param_specs(def_id)
    }

    public get_function_type(self ref, def_id DefId) Option[Type] = {
        return when self.get_symbol_type(def_id) in {
            .Some(symbol_type) then when symbol_type in {
                .FunctionType(_, _) then Option[Type].Some(symbol_type),
                _ then Option[Type].None(),
            },
            .None() then Option[Type].None(),
        }
    }

    public get_function_return_type(self ref, def_id DefId) Option[Type] = {
        return when self.get_function_type(def_id) in {
            .Some(function_type) then when function_type in {
                .FunctionType(_, return_type_ref) then Option[Type].Some(return_type_ref.val),
                _ then Option[Type].None(),
            },
            .None() then Option[Type].None(),
        }
    }

    public get_function_param_type(self ref, def_id DefId, arg_index UInt) Option[Type] = {
        return when self.get_function_type(def_id) in {
            .Some(function_type) then when function_type in {
                .FunctionType(params, _) then {
                    yield if arg_index < params.count()
                    then Option[Type].Some(params[arg_index].val.param_type)
                    else Option[Type].None()
                },
                _ then Option[Type].None(),
            },
            .None() then Option[Type].None(),
        }
    }

    public signature_param_type(self ref, def_id DefId, arg_index UInt) Option[Type] = {
        return self.get_function_param_type(def_id, arg_index)
    }

    public signature_param_type_or_unknown(self ref, def_id DefId, arg_index UInt) Type = {
        return self.get_function_param_type(def_id, arg_index) or else Type.Unknown()
    }

    public get_original_def_id(self ref, def_id DefId) Option[DefId] = {
        return self.def_id_map.get_original_def_id(def_id)
    }

    public lookup_type(self ref, def_id DefId) Option[Type] = {
        return self.def_id_map.lookup_type(def_id)
    }

    public is_not_deref(self ref, def_id DefId) Bool = {
        return self.def_id_map.is_not_deref(def_id)
    }

    public type_display_name(self ref, t Type) String = {
        return self.def_id_map.type_display_name(t)
    }

    public get_cname(self ref, def_id DefId) Option[String] = {
        return self.def_id_map.get_cname(def_id)
    }

    public next_def_id(self ref) UInt = {
        return self.def_id_map.next_id
    }

    public get_names(self ref) Dict[UInt, String] = {
        return self.def_id_map.names
    }

    public is_generic_instantiation(self ref, def_id DefId) Bool = {
        return when self.def_id_map.get_generic_instantiation(def_id) in {
            .Some(v) then v,
            .None() then false,
        }
    }

    public get_type_arguments(self ref, def_id DefId) Option[List[Type]] = {
        return self.def_id_map.get_type_arguments(def_id)
    }

    public get_template_name(self ref, def_id DefId) Option[String] = {
        return self.def_id_map.get_template_name(def_id)
    }

    // ── 类型定义更新 ──────────────────────────────────────────────────────

    public update_struct_info(
        self ref,
        def_id DefId,
        members List[StructField],
        is_generic_instantiation Bool,
        type_arguments Option[List[Type]],
        template_name Option[String],
    ) Void = {
        self.def_id_map.set_struct_info(def_id, StructTypeInfo(
            members,
            is_generic_instantiation,
            type_arguments,
            template_name,
        ))
    }

    public update_union_info(
        self ref,
        def_id DefId,
        cases List[EnumCaseInfo],
        is_generic_instantiation Bool,
        type_arguments Option[List[Type]],
        template_name Option[String],
    ) Void = {
        self.def_id_map.set_enum_info(def_id, EnumTypeInfo(
            cases,
            is_generic_instantiation,
            type_arguments,
            template_name,
        ))
    }

    public set_symbol_info(self ref, def_id DefId, info SymbolInfo) Void = {
        self.def_id_map.set_symbol_info(def_id, info)
    }

    public set_param_specs(self ref, def_id DefId, specs List[FunctionParamSpec]) Void = {
        self.def_id_map.set_param_specs(def_id, specs)
    }

    public set_span(self ref, def_id DefId, span SourceSpan) Void = {
        self.def_id_map.set_span(def_id, span)
    }

    public set_struct_info(self ref, def_id DefId, info StructTypeInfo) Void = {
        self.def_id_map.set_struct_info(def_id, info)
    }

    public set_enum_info(self ref, def_id DefId, info EnumTypeInfo) Void = {
        self.def_id_map.set_enum_info(def_id, info)
    }

    public set_struct_fields(self ref, def_id DefId, fields List[StructField]) Void = {
        self.def_id_map.set_struct_fields(def_id, fields)
    }

    public set_enum_cases(self ref, def_id DefId, cases List[EnumCaseInfo]) Void = {
        self.def_id_map.set_enum_cases(def_id, cases)
    }

    public add_type(self ref, def_id DefId, t Type) Void = {
        self.def_id_map.add_type(def_id, t)
    }

    public set_not_deref(self ref, def_id DefId) Void = {
        self.def_id_map.set_not_deref(def_id)
    }

    // ── 类型查询 ──────────────────────────────────────────────────────────

    /// 获取类型的人类可读名称
    public get_type_name(self, t Type) String = {
        return when t in {
            .StructureType(def_id) then {
                yield when self.def_id_map.get_name(def_id) in {
                    .Some(name) then name,
                    .None() then "<unknown>",
                }
            },
            .EnumType(def_id) then {
                yield when self.def_id_map.get_name(def_id) in {
                    .Some(name) then name,
                    .None() then "<unknown>",
                }
            },
            .OpaqueType(def_id) then {
                yield when self.def_id_map.get_name(def_id) in {
                    .Some(name) then name,
                    .None() then "<unknown>",
                }
            },
            .ModuleType(info) then {
                yield if info.module_path.is_empty() then "<module>" else join_strings(info.module_path, ".")
            },
            _ then type_to_string(t),
        }
    }

    /// 获取类型的调试名称（含泛型参数展开）
    public get_debug_name(self, t Type) String = {
        return when t in {
            .IntType() then "Int",
            .Int8Type() then "Int8",
            .Int16Type() then "Int16",
            .Int32Type() then "Int32",
            .Int64Type() then "Int64",
            .UIntType() then "UInt",
            .UInt8Type() then "UInt8",
            .UInt16Type() then "UInt16",
            .UInt32Type() then "UInt32",
            .UInt64Type() then "UInt64",
            .Float32Type() then "Float32",
            .Float64Type() then "Float64",
            .BoolType() then "Bool",
            .VoidType() then "Void",
            .NeverType() then "Never",
            .FunctionType(params, ret) then {
                let mut parts = List[String].new()
                for entry in params then {
                    parts.push(self.get_debug_name(entry.param_type))
                }
                let mut out = "Func["
                out.push_string(join_strings(parts, ", "))
                if not parts.is_empty() then {
                    out.push_string(", ")
                }
                out.push_string(self.get_debug_name(ret.val))
                out.push_byte(']')
                yield out
            },
            .ReferenceType(inner) then "ref \(self.get_debug_name(inner.val))",
            .MutableReferenceType(inner) then "mut ref \(self.get_debug_name(inner.val))",
            .PointerType(inner) then "ptr \(self.get_debug_name(inner.val))",
            .MutablePointerType(inner) then "mut ptr \(self.get_debug_name(inner.val))",
            .WeakReferenceType(inner) then "weakref \(self.get_debug_name(inner.val))",
            .MutableWeakReferenceType(inner) then "mut weakref \(self.get_debug_name(inner.val))",
            .StructureType(def_id) then {
                let base_name = when self.def_id_map.get_name(def_id) in {
                    .Some(n) then n,
                    .None() then "<unknown>",
                }
                yield when self.def_id_map.get_type_arguments(def_id) in {
                    .Some(args) then if not args.is_empty() then {
                        let mut arg_parts = List[String].new()
                        for a in args then {
                            arg_parts.push(self.get_debug_name(a))
                        }
                        yield "\(base_name)[\(join_strings(arg_parts, ", "))]"
                    } else base_name,
                    .None() then base_name,
                }
            },
            .EnumType(def_id) then {
                let base_name = when self.def_id_map.get_name(def_id) in {
                    .Some(n) then n,
                    .None() then "<unknown>",
                }
                yield when self.def_id_map.get_type_arguments(def_id) in {
                    .Some(args) then if not args.is_empty() then {
                        let mut arg_parts = List[String].new()
                        for a in args then {
                            arg_parts.push(self.get_debug_name(a))
                        }
                        yield "\(base_name)[\(join_strings(arg_parts, ", "))]"
                    } else base_name,
                    .None() then base_name,
                }
            },
            .OpaqueType(def_id) then {
                yield when self.def_id_map.get_name(def_id) in {
                    .Some(n) then n,
                    .None() then "<unknown>",
                }
            },
            .ModuleType(info) then {
                yield if info.module_path.is_empty() then "<module>" else join_strings(info.module_path, ".")
            },
            .GenericParameter(name) then name,
            .GenericStruct(template, args) then {
                let mut arg_parts = List[String].new()
                for a in args then {
                    arg_parts.push(self.get_debug_name(a.val))
                }
                yield "\(template)[\(join_strings(arg_parts, ", "))]"
            },
            .GenericEnum(template, args) then {
                let mut arg_parts = List[String].new()
                for a in args then {
                    arg_parts.push(self.get_debug_name(a.val))
                }
                yield "\(template)[\(join_strings(arg_parts, ", "))]"
            },
            .TraitObject(name, _) then name,
            .TypeVar(tv) then "?\(tv.val.id)",
            .Unknown() then "?",
        }
    }

    // ── 类型变量查询 ──────────────────────────────────────────────────────

    /// 检查类型是否包含类型变量
    public contains_type_variable(self, t Type) Bool = {
        return when t in {
            .TypeVar(_) then true,
            .FunctionType(params, ret) then {
                if self.contains_type_variable(ret.val) then { return true }
                for entry in params then {
                    if self.contains_type_variable(entry.param_type) then { return true }
                }
                yield false
            },
            .ReferenceType(inner) then self.contains_type_variable(inner.val),
            .MutableReferenceType(inner) then self.contains_type_variable(inner.val),
            .PointerType(inner) then self.contains_type_variable(inner.val),
            .MutablePointerType(inner) then self.contains_type_variable(inner.val),
            .WeakReferenceType(inner) then self.contains_type_variable(inner.val),
            .MutableWeakReferenceType(inner) then self.contains_type_variable(inner.val),
            .GenericStruct(_, args) then {
                for a in args then {
                    if self.contains_type_variable(a.val) then { return true }
                }
                yield false
            },
            .GenericEnum(_, args) then {
                for a in args then {
                    if self.contains_type_variable(a.val) then { return true }
                }
                yield false
            },
            _ then false,
        }
    }

    /// 检查类型是否包含泛型参数
    public contains_generic_parameter(self ref, t Type) Bool = {
        return type_contains_generic_parameter(t, self)
    }

    /// 检查类型表面是否仍提及未解析的泛型占位。
    public mentions_unresolved_generic_placeholder(self ref, t Type) Bool = {
        return type_mentions_unresolved_generic_placeholder(t)
    }

    // ── Layout Key 生成 ───────────────────────────────────────────────────

    /// 生成类型的布局键（用于 C 标识符生成）
    public get_layout_key(self, t Type) String = {
        return when t in {
            .IntType() then "I",
            .Int8Type() then "I8",
            .Int16Type() then "I16",
            .Int32Type() then "I32",
            .Int64Type() then "I64",
            .UIntType() then "U",
            .UInt8Type() then "U8",
            .UInt16Type() then "U16",
            .UInt32Type() then "U32",
            .UInt64Type() then "U64",
            .Float32Type() then "F32",
            .Float64Type() then "F64",
            .BoolType() then "B",
            .VoidType() then "V",
            .NeverType() then "N",
            .FunctionType(_, _) then "Fn",
            .ReferenceType(inner) then "R_\(self.get_layout_key(inner.val))",
            .MutableReferenceType(inner) then "MR_\(self.get_layout_key(inner.val))",
            .PointerType(inner) then "P_\(self.get_layout_key(inner.val))",
            .MutablePointerType(inner) then "MP_\(self.get_layout_key(inner.val))",
            .WeakReferenceType(inner) then "W_\(self.get_layout_key(inner.val))",
            .MutableWeakReferenceType(inner) then "MW_\(self.get_layout_key(inner.val))",
            .StructureType(def_id) then self.layout_key_for_def_id(def_id),
            .EnumType(def_id) then self.layout_key_for_def_id(def_id),
            .OpaqueType(def_id) then self.layout_key_for_def_id(def_id),
            .GenericParameter(name) then "Param_\(name)",
            .GenericStruct(template, args) then {
                let mut arg_keys = List[String].new()
                for a in args then {
                    arg_keys.push(self.get_layout_key(a.val))
                }
                yield "\(template)_\(join_strings(arg_keys, "_"))"
            },
            .GenericEnum(template, args) then {
                let mut arg_keys = List[String].new()
                for a in args then {
                    arg_keys.push(self.get_layout_key(a.val))
                }
                yield "\(template)_\(join_strings(arg_keys, "_"))"
            },
            .TraitObject(name, _) then "TO_\(name)",
            .ModuleType(info) then {
                let path_key = if info.module_path.is_empty() then "root" else join_strings(info.module_path, "_")
                yield "M_\(path_key)"
            },
            .TypeVar(tv) then "TV_\(tv.val.id)",
            .Unknown() then "Unknown",
        }
    }

    private layout_key_for_def_id(self, def_id DefId) String = {
        let name_opt = self.def_id_map.get_name(def_id)
        let module_opt = self.def_id_map.get_module_path(def_id)
        let access_opt = self.def_id_map.get_access(def_id)
        let source_opt = self.def_id_map.get_source_file(def_id)

        let mut parts = List[String].new()

        if module_opt is .Some(mod_path) and not mod_path.is_empty() then {
            parts.push(join_strings(mod_path, "_"))
        }

        // private 符号添加文件哈希
        let is_private = when access_opt in {
            .Some(a) then when a in {
                .Private() then true,
                _ then false,
            },
            .None() then false,
        }
        if is_private then {
            if source_opt is .Some(sf) then {
                let mut hash UInt = 0
                // 简单哈希
                let bytes = sf.bytes()
                for b in bytes then {
                    hash = hash.wrapping_mul(31(UInt)).wrapping_add(b(UInt))
                }
                parts.push("f\(hash % 10000)")
            }
        }

        when name_opt in {
            .Some(n) then parts.push(n),
            .None() then parts.push("T_\(def_id.id)"),
        }

        // 泛型实例化的类型参数
        if self.def_id_map.get_type_arguments(def_id) is .Some(args) then {
            let is_inst = when self.def_id_map.get_generic_instantiation(def_id) in {
                .Some(v) then v,
                .None() then false,
            }
            if not is_inst and not args.is_empty() then {
                let mut arg_keys = List[String].new()
                for a in args then {
                    arg_keys.push(self.get_layout_key(a))
                }
                parts.push(join_strings(arg_keys, "_"))
            }
        }

        return join_strings(parts, "_")
    }
}

// ── 辅助函数 ──────────────────────────────────────────────────────────────────

private let join_strings(parts List[String], sep String) String = {
    let mut result = String.new()
    let mut first = true
    for p in parts then {
        if not first then { result.push_string(sep) }
        result.push_string(p)
        first = false
    }
    return result
}
