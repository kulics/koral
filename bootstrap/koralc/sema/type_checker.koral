// Type Checker - Pass 2 + 3

using std::os { env }

// Pass 2: collect_signatures - resolves type members and function signatures
// Pass 3: check_decl - checks function bodies and generates TypedAST
// All mutable checker state lives in storage so TypeChecker can be passed by
// value without losing mutations (mirrors the List/storage ref pattern).

protected type TypeCheckerStorage(
    mut global_scope Scope,
    mut context CompilerContext,
    mut method_table MethodTable,
    mut diagnostics DiagnosticCollector,
    mut file_path String,
    mut module_path List[String],
    mut package_id String,
    mut function_return_context FunctionReturnContext,
    mut in_loop Bool,
    mut in_finally Bool,
    mut yield_targets List[mut ref YieldTarget],
    mut constraint_solver ConstraintSolver,
    mut trait_registry TraitRegistry,
    mut generic_param_constraints Dict[String, List[GenericConstraintBound]],
    mut generic_templates mut ref GenericTemplateRegistry,
    mut instantiation_requests Set[InstantiationRequest],
    mut import_graph Option[ImportGraph],
    mut explicit_trait_conformances Set[ExplicitTraitConformanceKey],
    mut generic_trait_conformance_templates List[GenericTraitConformanceTemplate],
    mut conformance_index Dict[String, List[GenericTraitConformanceTemplate]],
    mut trait_requirement_in_progress Set[ExplicitTraitConformanceKey],
    mut generic_trait_status_in_progress Set[ExplicitTraitConformanceKey],
    mut trait_requirement_cache Dict[ExplicitTraitConformanceKey, Bool],
    mut generic_trait_status_cache Dict[ExplicitTraitConformanceKey, GenericTraitConformanceStatus],
    /// Current scope for type resolution — analogous to Swift's `currentScope`.
    /// When set, `resolve_named_type` checks this scope before falling back to global scope.
    /// This eliminates the need for separate resolve_type_in_scope / resolve_type_with_bindings variants.
    mut resolution_scope Option[Scope],
)

public type TypeChecker(protected mut storage mut ref TypeCheckerStorage)

protected type IfChain(
    arms List[Pair[ref Expr, ref Expr]],
    final_else Option[ref Expr],
)

protected type YieldTarget(
    span SourceSpan,
    mut did_explicit_yield Bool,
)

protected type FunctionReturnContext(
    mut expected_return_type Option[Type],
    mut inferred_return_type Option[Type],
    mut is_inferring Bool,
)

/// A single trait bound on a generic parameter, preserving type arguments.
/// For example, `[R Iterator[T]]` produces GenericConstraintBound("Iterator", [GenericParameter("T")]).
public type GenericConstraintBound(
    trait_name String,
    type_args List[Type],
)

protected type GenericConstraintSnapshot(
    previous_constraints Dict[String, Option[List[GenericConstraintBound]]],
)

protected type GenericTraitConformanceTemplate(
    target_type Type,
    owner_type_params List[TypeParameterDecl],
    trait_name String,
    trait_arg_types List[Type],
)

protected type ExplicitTraitConformanceKey(
    target_type Type,
    trait_name String,
    trait_arg_types List[Type],
)

given ExplicitTraitConformanceKey as Eq {
    public equals(self, other ExplicitTraitConformanceKey) Bool = {
        return self.target_type == other.target_type
            and self.trait_name == other.trait_name
            and self.trait_arg_types == other.trait_arg_types
    }
}

given ExplicitTraitConformanceKey as Hash {
    public hash(self) UInt = {
        let mut h = self.target_type.hash().combine_hash(self.trait_name.hash())
        for arg in self.trait_arg_types then {
            h = h.combine_hash(arg.hash())
        }
        return h
    }
}

protected type GenericTraitConformanceStatus {
    Satisfied(),
    MissingConstraint(target_type Type, constraint_param String, trait_name String),
    MissingConformance(),
}

given TypeChecker {
    public new(global_scope Scope, context CompilerContext, file_path String) TypeChecker = {
        let s = box(TypeCheckerStorage(
            global_scope,
            context,
            MethodTable.new(),
            DiagnosticCollector.new(),
            file_path,
            List[String].new(),
            "",
            FunctionReturnContext(Option[Type].None(), Option[Type].None(), false),
            false,
            false,
            List[mut ref YieldTarget].new(),
            ConstraintSolver.new(),
            TraitRegistry.new(),
            Dict[String, List[GenericConstraintBound]].new(),
            box(GenericTemplateRegistry.new()),
            Set[InstantiationRequest].new(),
            Option[ImportGraph].None(),
            Set[ExplicitTraitConformanceKey].new(),
            List[GenericTraitConformanceTemplate].new(),
            Dict[String, List[GenericTraitConformanceTemplate]].new(),
            Set[ExplicitTraitConformanceKey].new(),
            Set[ExplicitTraitConformanceKey].new(),
            Dict[ExplicitTraitConformanceKey, Bool].new(),
            Dict[ExplicitTraitConformanceKey, GenericTraitConformanceStatus].new(),
            Option[Scope].None()
        ))
        return TypeChecker(s)
    }

    public has_errors(self) Bool = self.storage.diagnostics.has_errors()

    public compiler_context(self) CompilerContext = {
        return self.context()
    }

    protected register_receiver_dispatch_for_given_members(
        self mut ref,
        target_type Type,
        trait_name Option[String],
        members List[TypedGivenMember],
    ) Void = {
        let owner = Option[ReceiverMethodOwner].Some(ReceiverMethodOwner.ConcreteType(self.context().type_display_name(target_type)))
        for member in members then {
            let is_receiver_style = member.params.count() > 0(UInt) and member.params[0(UInt)].name == "self"
            if is_receiver_style then {
                self.storage.generic_templates.receiver_method_dispatch.insert(
                    member.def_id,
                    ReceiverMethodDispatchInfo(member.def_id, member.name, owner, trait_name),
                )
            } else {
                self.storage.generic_templates.receiver_method_dispatch.remove(member.def_id)
            }
        }
    }

    private duplicate_definition_message(self, name String) String = {
        let _ = self
        let mut message = "Duplicate definition: "
        message.push_string(name)
        return message
    }

    protected invalidate_trait_requirement_caches(self) Void = {
        self.storage.trait_requirement_in_progress = Set[ExplicitTraitConformanceKey].new()
        self.storage.generic_trait_status_in_progress = Set[ExplicitTraitConformanceKey].new()
        self.storage.trait_requirement_cache = Dict[ExplicitTraitConformanceKey, Bool].new()
        self.storage.generic_trait_status_cache = Dict[ExplicitTraitConformanceKey, GenericTraitConformanceStatus].new()
    }

    protected push_diagnostic(self, message String) Void = {
        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, message))
    }

    private sema_progress_debug_enabled(self) Bool = {
        let _ = self
        if env("KORAL_DEBUG_SEMA_PROGRESS") is .Some(value) and (value == "1" or value == "true" or value == "TRUE") then {
            return true
        }
        return false
    }

    protected skip_given_body_debug_enabled(self) Bool = {
        let _ = self
        if env("KORAL_DEBUG_SKIP_GIVEN_BODY") is .Some(value) and (value == "1" or value == "true" or value == "TRUE") then {
