    protected reset_constraint_solver_each_decl_debug_enabled(self) Bool = {
        let _ = self
        if env("KORAL_DEBUG_RESET_CONSTRAINT_SOLVER_EACH_DECL") is .Some(value) and (value == "1" or value == "true" or value == "TRUE") then {
