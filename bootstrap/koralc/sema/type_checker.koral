    private log_sema_progress(self, checked_decl_count UInt, total_nodes UInt) Void = {
        let pending_constraints = self.storage.constraint_solver.constraints.count()
        let pending_default_constraints = self.storage.constraint_solver.default_constraints.count()
        let next_def_id = self.context().next_def_id()
        let instantiation_request_count = self.storage.instantiation_requests.count()
        let generic_param_constraint_name_count = self.storage.generic_param_constraints.count()
        let extension_key_count = self.storage.generic_templates.extension_methods.count()
        let mut extension_template_count = 0(UInt)
        for entry in self.storage.generic_templates.extension_methods then {
            extension_template_count += entry.second.val.count()
        }
        let method_type_key_count = self.storage.method_table.methods.count()
        let global_scope_entry_count = self.storage.global_scope.entry_count()
        let global_scope_local_entry_count = self.storage.global_scope.local_entry_count()
        let global_scope_type_count = self.storage.global_scope.type_entry_count()
        let global_scope_generic_param_count = self.storage.global_scope.generic_param_count()
        let context = self.context()
        let def_id_name_count = context.def_id_map.names.count()
        let def_id_symbol_type_count = context.def_id_map.symbol_types.count()
        let def_id_symbol_kind_count = context.def_id_map.symbol_kinds.count()
        let def_id_param_spec_count = context.def_id_map.param_specs.count()
        let def_id_module_path_count = context.def_id_map.module_paths.count()
        let mut binding_count = 0(UInt)
        for _entry in self.storage.constraint_solver.unifier.current_bindings() then {
            binding_count += 1
        }
        println("[sema-progress] checked=\(checked_decl_count)/\(total_nodes) file=\(self.storage.file_path) constraints=\(pending_constraints) bindings=\(binding_count) diagnostics=\(self.storage.diagnostics.count()) next_def_id=\(next_def_id) extension_keys=\(extension_key_count) extension_templates=\(extension_template_count) method_type_keys=\(method_type_key_count) instantiation_requests=\(instantiation_request_count) global_scope_entries=\(global_scope_entry_count) global_scope_types=\(global_scope_type_count) def_names=\(def_id_name_count) def_symbol_types=\(def_id_symbol_type_count) def_symbol_kinds=\(def_id_symbol_kind_count) def_param_specs=\(def_id_param_spec_count) def_module_paths=\(def_id_module_path_count)")
    }

    private decl_debug_label(self, decl Decl) String = {
        let _ = self
        return when decl in {
            .LetDecl(_, name, _, _, _, _) then "let \(name)",
            .FunctionDecl(_, name, _, _, _, _, _) then "fn \(name)",
            .IntrinsicFunctionDecl(_, name, _, _, _, _) then "intrinsic fn \(name)",
            .ForeignFunctionDecl(_, name, _, _, _) then "foreign fn \(name)",
            .ForeignLetDecl(_, name, _, _, _) then "foreign let \(name)",
            .TypeStructDecl(_, name, _, _, _) then "struct \(name)",
            .TypeEnumDecl(_, name, _, _, _) then "enum \(name)",
            .TypeAliasDecl(_, name, _, _) then "type \(name)",
            .IntrinsicTypeDecl(_, name, _, _) then "intrinsic type \(name)",
            .ForeignTypeDecl(_, name, _, _, _) then "foreign type \(name)",
            .FileUsingDecl(file_name, _) then "using file \(file_name)",
            .ModuleUsingDecl(_, _, _) then "using module",
            .TraitDecl(_, name, _, _, _, _) then "trait \(name)",
            .GivenDecl(_, _, _, _) then "given",
            .GivenTraitDecl(_, _, _, _, _) then "given as trait",
            .IntrinsicGivenDecl(_, _, _, _) then "intrinsic given",
            .GivenNotTraitDecl(_, _, trait_name, _) then "given-not-trait as \(trait_name)",
        }
    }

    protected record_instantiation_request(self, request InstantiationRequest) Void = {
        self.storage.instantiation_requests.insert(request)
    }

    protected register_trait_metadata(
        self,
        name String,
        type_params List[TypeParameter],
        parent_constraints List[ParentTraitConstraint],
        raw_members List[TraitMember],
        typed_members List[TypedTraitMember],
    ) Void = {
        let mut param_names = List[String].new()
        for tp in type_params then {
            param_names.push(tp.name)
        }
        let info = TraitInfo(name, param_names, parent_constraints, typed_members, self.storage.module_path)
        self.storage.trait_registry.register(info)
        self.storage.generic_templates.traits.insert(
            name,
            TraitDeclInfo(name, self.to_template_type_params(type_params), parent_constraints, raw_members, typed_members, self.storage.module_path)
        )
    }

    protected template_checked_body(self, body Option[ref TypedExpr], retain_checked_template_bodies Bool) Option[ref TypedExpr] = {
        return if retain_checked_template_bodies then when body in {
            .Some(typed_body) then Option[ref TypedExpr].Some(typed_body),
            .None() then Option[ref TypedExpr].None(),
        } else Option[ref TypedExpr].None()
    }

    protected push_diagnostic_at_span(self, message String, span SourceSpan) Void = {
        self.storage.diagnostics.push(make_diagnostic_at(DiagnosticStage.Semantic(), self.storage.file_path, message, span))
    }

    protected push_expr_diagnostic(self, expr ref Expr, message String) Void = {
        self.push_diagnostic_at_span(message, expr_span(expr))
    }

    protected push_pattern_diagnostic(self, pattern ref PatternNode, message String) Void = {
        self.push_diagnostic_at_span(message, pattern_span(pattern))
    }

    protected context(self) CompilerContext = {
        return self.storage.context
    }

    protected in_function_context(self) Bool = {
        if self.storage.function_return_context.is_inferring then {
            return true
        }
        return self.storage.function_return_context.expected_return_type is .Some(_)
    }

    protected allocate_unindexed_def_id(self, name String, kind DefKind) DefId = {
        let mut context = self.context()
        return context.allocate_unindexed(name, kind)
    }

    protected fresh_type_variable(self, name Option[String], span SourceSpan) TypeVariable = {
        return self.storage.constraint_solver.fresh_type_variable(name, span)
    }

    protected fresh_literal_type_variable(self, kind LiteralDefaultKind, span SourceSpan) TypeVariable = {
        return self.storage.constraint_solver.fresh_literal_type_variable(kind, span)
    }

    protected typed_expr_span(self, expr ref TypedExpr) SourceSpan = {
        return when expr.expr_kind in {
            .Variable(symbol) then self.context().get_span(symbol.def_id) or else unknown_span(),
            .CastExpr(_, inner) then self.typed_expr_span(inner),
            .Unary(_, inner) then self.typed_expr_span(inner),
            .RefExpr(inner) then self.typed_expr_span(inner),
            .PtrExpr(inner) then self.typed_expr_span(inner),
            .DerefExpr(inner) then self.typed_expr_span(inner),
            .ArithmeticExpr(left, _, _) then self.typed_expr_span(left),
            .ComparisonExpr(left, _, _) then self.typed_expr_span(left),
            .BitwiseExpr(left, _, _) then self.typed_expr_span(left),
            .AndExpr(left, _) then self.typed_expr_span(left),
            .OrExpr(left, _) then self.typed_expr_span(left),
            .IsExpr(subject, _, _) then {
                let subject_span = self.typed_expr_span(subject)
                yield if is_known_span(subject_span) then subject_span else unknown_span()
            },
            .Call(callee, _) then self.typed_expr_span(callee),
            .GenericCall(function_symbol, _, args) then {
                let function_span = self.context().get_span(function_symbol.def_id) or else unknown_span()
                yield if is_known_span(function_span) then function_span else if args.is_empty() then unknown_span() else self.typed_expr_span(args[0(UInt)])
            },
            .MemberPath(base, _) then self.typed_expr_span(base),
            .MethodReference(base, _, method, _, _, _) then {
                let base_span = self.typed_expr_span(base)
                yield if is_known_span(base_span) then base_span else self.context().get_span(method.def_id) or else unknown_span()
            },
            .Block(statements) then if statements.is_empty() then unknown_span() else when statements[0(UInt)] in {
                .LetStmt(_, _, span) then span,
                .PairLetStmt(_, _, _, span) then span,
                .AssignmentStmt(_, _, span) then span,
                .ExprStmt(_, span) then span,
                .IfStmt(_, _, _, span) then span,
                .WhileStmt(_, _, span) then span,
                .WhenStmt(_, _, span) then span,
                .ReturnStmt(_, span) then span,
                .BreakStmt(span) then span,
                .ContinueStmt(span) then span,
                .FinallyStmt(_, span) then span,
                .YieldStmt(_, span) then span,
            },
            .IfExpr(condition, _, _) then self.typed_expr_span(condition),
            .WhenExpr(subject, _) then self.typed_expr_span(subject),
            .LambdaExpr(_, _, body) then self.typed_expr_span(body),
            .StaticMethodCall(_, _, method, _, _, args) then {
                let method_span = self.context().get_span(method.def_id) or else unknown_span()
                yield if is_known_span(method_span) then method_span else if args.is_empty() then unknown_span() else self.typed_expr_span(args[0(UInt)])
            },
            .TypeConstruction(identifier, _, args) then {
                let type_span = self.context().get_span(identifier.def_id) or else unknown_span()
                yield if is_known_span(type_span) then type_span else if args.is_empty() then unknown_span() else self.typed_expr_span(args[0(UInt)])
            },
            .EnumConstruction(_, _, args) then if args.is_empty() then unknown_span() else self.typed_expr_span(args[0(UInt)]),
            .TraitMethodPlaceholder(base, _, method, _, _) then {
                let base_span = self.typed_expr_span(base)
                yield if is_known_span(base_span) then base_span else self.context().get_span(method.def_id) or else unknown_span()
            },
            .TraitObjectConversion(inner, _, _) then self.typed_expr_span(inner),
            .TraitMethodCall(receiver, _, _, _, _) then self.typed_expr_span(receiver),
            .GenericInstantiation(base_type, _) then when base_type in {
                .StructureType(def_id) then self.context().get_span(def_id) or else unknown_span(),
                .EnumType(def_id) then self.context().get_span(def_id) or else unknown_span(),
                .OpaqueType(def_id) then self.context().get_span(def_id) or else unknown_span(),
                _ then unknown_span(),
            },
            _ then unknown_span(),
        }
    }

    protected push_typed_expr_diagnostic(self, expr ref TypedExpr, message String) Void = {
        self.push_diagnostic_at_span(message, self.typed_expr_span(expr))
    }

    protected statement_span(self, stmt Statement) SourceSpan = {
        return when stmt in {
            .LetStmt(_, _, _, _, span) then span,
            .PairLetStmt(_, _, _, span) then span,
            .AssignmentStmt(_, _, _, span) then span,
            .ExprStmt(_, span) then span,
            .ReturnStmt(_, span) then span,
            .BreakStmt(span) then span,
            .ContinueStmt(span) then span,
            .FinallyStmt(_, span) then span,
            .YieldStmt(_, span) then span,
        }
    }

    protected push_statement_diagnostic(self, stmt Statement, message String) Void = {
        self.push_diagnostic_at_span(message, self.statement_span(stmt))
    }

    protected canonical_trait_object_type(self, trait_name String) Type = {
        return when self.storage.global_scope.lookup_type(trait_name) in {
            .Some(resolved_type) then when resolved_type in {
                .TraitObject(existing_trait_name, existing_args) then {
                    yield if existing_trait_name == trait_name
                        then Type.TraitObject(existing_trait_name, existing_args)
                        else Type.TraitObject(trait_name, List[ref Type].new())
                },
                _ then Type.TraitObject(trait_name, List[ref Type].new()),
            },
            .None() then Type.TraitObject(trait_name, List[ref Type].new()),
        }
    }

    // Treat both Unknown and TypeVar as unresolved so they do not leak into codegen.
    private is_unresolved_expr_type(self, t Type) Bool = when t in {
        .Unknown() then true,
        .TypeVar(_) then true,
        _ then false,
    }

    private is_value_expr_type(self, t Type) Bool = when t in {
        .VoidType() then false,
        .NeverType() then false,
        _ then not self.is_unresolved_expr_type(t),
    }

    private is_ffi_compatible_type(self, t Type) Bool = {
        return when t in {
            .IntType() then true,
            .Int8Type() then true,
            .Int16Type() then true,
            .Int32Type() then true,
            .Int64Type() then true,
            .UIntType() then true,
            .UInt8Type() then true,
            .UInt16Type() then true,
            .UInt32Type() then true,
            .UInt64Type() then true,
            .Float32Type() then true,
            .Float64Type() then true,
            .BoolType() then true,
            .VoidType() then true,
            .NeverType() then true,
            .PointerType(_) then true,
            .MutablePointerType(_) then true,
            .OpaqueType(_) then true,
            _ then false,
        }
    }

    private ffi_type_error(self, t Type) String = {
        return when t in {
            .StructureType(_) then "Koral struct types cannot be used in foreign functions",
            .EnumType(_) then "Koral enum types cannot be used in foreign functions",
            .ReferenceType(_) then "Reference types (ref) cannot be used in foreign functions",
            .WeakReferenceType(_) then "Weak reference types cannot be used in foreign functions",
            .MutableWeakReferenceType(_) then "Weak reference types cannot be used in foreign functions",
            .FunctionType(_, _) then "Function types cannot be used in foreign functions",
            .GenericParameter(_) then "Generic parameters cannot be used in foreign functions",
            _ then "Type '\(self.context().type_display_name(t))' is not compatible with FFI",
        }
    }

    private same_expr_type(self, left Type, right Type) Bool = {
        let normalized_left = self.canonicalize_alias_type(self.concretize_default_literal_type(left))
        let normalized_right = self.canonicalize_alias_type(self.concretize_default_literal_type(right))
        return normalized_left == normalized_right
    }

    private canonicalize_alias_type(self, t Type) Type = {
        return when t in {
            .StructureType(def_id) then when self.context().lookup_type(def_id) in {
                .Some(mapped) then {
                    if mapped == t then {
                        return t
                    }
                    return self.canonicalize_alias_type(mapped)
                },
                .None() then t,
            },
            .EnumType(def_id) then when self.context().lookup_type(def_id) in {
                .Some(mapped) then {
                    if mapped == t then {
                        return t
                    }
                    return self.canonicalize_alias_type(mapped)
                },
                .None() then t,
            },
            .OpaqueType(def_id) then when self.context().lookup_type(def_id) in {
                .Some(mapped) then {
                    if mapped == t then {
                        return t
                    }
                    return self.canonicalize_alias_type(mapped)
                },
                .None() then t,
            },
            .ReferenceType(inner) then Type.ReferenceType(box(self.canonicalize_alias_type(inner.val))),
            .MutableReferenceType(inner) then Type.MutableReferenceType(box(self.canonicalize_alias_type(inner.val))),
            .PointerType(inner) then Type.PointerType(box(self.canonicalize_alias_type(inner.val))),
            .MutablePointerType(inner) then Type.MutablePointerType(box(self.canonicalize_alias_type(inner.val))),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.canonicalize_alias_type(inner.val))),
            .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(self.canonicalize_alias_type(inner.val))),
            .FunctionType(fn_params, return_type) then {
                let param_types = param_entry_types(fn_params)
                let mut resolved_params = List[ref Type].new()
                for pt in param_types then {
                    resolved_params.push(intern_type(self.canonicalize_alias_type(pt.val)))
                }
                let resolved_ret = self.canonicalize_alias_type(return_type.val)
                yield make_function_type(resolved_params, resolved_ret)
            },
            _ then t,
        }
    }

    private concretize_default_literal_type(self, t Type) Type = {
        let resolved = self.storage.constraint_solver.resolve(t)
        return when resolved in {
            .TypeVar(tv) then when tv.literal_default_kind in {
                .Some(kind) then when kind in {
                    .Int() then Type.IntType(),
                    .Float() then Type.Float64Type(),
                },
                .None() then resolved,
            },
            .ReferenceType(inner) then Type.ReferenceType(box(self.concretize_default_literal_type(inner.val))),
            .MutableReferenceType(inner) then Type.MutableReferenceType(box(self.concretize_default_literal_type(inner.val))),
            .PointerType(inner) then Type.PointerType(box(self.concretize_default_literal_type(inner.val))),
            .MutablePointerType(inner) then Type.MutablePointerType(box(self.concretize_default_literal_type(inner.val))),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.concretize_default_literal_type(inner.val))),
            .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(self.concretize_default_literal_type(inner.val))),
            .FunctionType(fn_params, return_type) then {
                let param_types = param_entry_types(fn_params)
                let mut resolved_params = List[ref Type].new()
                for pt in param_types then {
                    resolved_params.push(box(self.concretize_default_literal_type(pt.val)))
                }
                yield Type.FunctionType(types_to_param_entries(resolved_params), box(self.concretize_default_literal_type(return_type.val)))
            },
            .GenericStruct(template, args) then {
                let mut resolved_args = List[ref Type].new()
                for arg in args then {
                    resolved_args.push(box(self.concretize_default_literal_type(arg.val)))
                }
                yield Type.GenericStruct(template, resolved_args)
            },
            .GenericEnum(template, args) then {
                let mut resolved_args = List[ref Type].new()
                for arg in args then {
                    resolved_args.push(box(self.concretize_default_literal_type(arg.val)))
                }
                yield Type.GenericEnum(template, resolved_args)
            },
            _ then resolved,
        }
    }

    protected display_type_name(self, t Type) String = {
        let resolved = self.canonicalize_alias_type(self.concretize_default_literal_type(t))
        return when resolved in {
            .StructureType(def_id) then when self.context().get_name(def_id) in {
                .Some(name) then name,
                .None() then when self.context().get_original_def_id(def_id) in {
                    .Some(original_def_id) then when self.context().get_name(original_def_id) in {
                        .Some(original_name) then original_name,
                        .None() then type_to_string(resolved),
                    },
                    .None() then type_to_string(resolved),
                },
            },
            .EnumType(def_id) then when self.context().get_name(def_id) in {
                .Some(name) then name,
                .None() then when self.context().get_original_def_id(def_id) in {
                    .Some(original_def_id) then when self.context().get_name(original_def_id) in {
                        .Some(original_name) then original_name,
                        .None() then type_to_string(resolved),
                    },
                    .None() then type_to_string(resolved),
                },
            },
            .OpaqueType(def_id) then when self.context().lookup_type(def_id) in {
                .Some(mapped) then self.display_type_name(mapped),
                .None() then type_to_string(resolved),
            },
            .ReferenceType(inner) then {
                let mut out = "ref "
                out.push_string(self.display_type_name(inner.val))
                yield out
            },
            .MutableReferenceType(inner) then {
                let mut out = "mut ref "
                out.push_string(self.display_type_name(inner.val))
                yield out
            },
            .PointerType(inner) then {
                let mut out = "ptr "
                out.push_string(self.display_type_name(inner.val))
                yield out
            },
            .MutablePointerType(inner) then {
                let mut out = "mut ptr "
                out.push_string(self.display_type_name(inner.val))
                yield out
            },
            .WeakReferenceType(inner) then {
                let mut out = "weakref "
                out.push_string(self.display_type_name(inner.val))
                yield out
            },
            .MutableWeakReferenceType(inner) then {
                let mut out = "mut weakref "
                out.push_string(self.display_type_name(inner.val))
                yield out
            },
            .FunctionType(fn_params, return_type) then {
                let param_types = param_entry_types(fn_params)
                let mut out = "Func["
                let mut first = true
                for pt in param_types then {
                    if not first then { out.push_string(", ") }
                    out.push_string(self.display_type_name(pt.val))
                    first = false
                }
                if not param_types.is_empty() then {
                    out.push_string(", ")
                }
                out.push_string(self.display_type_name(return_type.val))
                out.push_byte(']')
                yield out
            },
            .GenericStruct(template, args) then {
                let mut out = template
                out.push_byte('[')
                let mut first = true
                for arg in args then {
                    if not first then { out.push_string(", ") }
                    out.push_string(self.display_type_name(arg.val))
                    first = false
                }
                out.push_byte(']')
                yield out
            },
            .GenericEnum(template, args) then {
                let mut out = template
                out.push_byte('[')
                let mut first = true
                for arg in args then {
                    if not first then { out.push_string(", ") }
                    out.push_string(self.display_type_name(arg.val))
                    first = false
                }
                out.push_byte(']')
                yield out
            },
            _ then type_to_string(resolved),
        }
    }

    private choose_conditional_result_type(self, expected Option[Type], then_type Type, else_type Option[Type]) Type = {
        when expected in {
            .Some(et) then {
                if not self.contains_generic_parameter(et) then {
                    return et
                }
            },
            .None() then {},
        }
        if else_type is .None() then { return Type.VoidType() }

        let else_t = when else_type in {
            .Some(t) then t,
            .None() then { return Type.VoidType() },
        }

        if self.same_expr_type(then_type, else_t) then {
            return then_type
        }

        when then_type in {
            .ReferenceType(then_inner_ref) then when else_t in {
                .ReferenceType(else_inner_ref) then {
                    when else_inner_ref.val in {
                        .TraitObject(trait_name, _) then {
                            if self.can_convert_to_trait_object(then_inner_ref.val, trait_name) then {
                                return else_t
                            }
                        },
                        _ then {},
                    }
                    when then_inner_ref.val in {
                        .TraitObject(trait_name, _) then {
                            if self.can_convert_to_trait_object(else_inner_ref.val, trait_name) then {
                                return then_type
                            }
                        },
                        _ then {},
                    }
                },
                .MutableReferenceType(else_inner_ref) then {
                    when then_inner_ref.val in {
                        .TraitObject(trait_name, _) then {
                            if self.can_convert_to_trait_object(else_inner_ref.val, trait_name) then {
                                return then_type
                            }
                        },
                        _ then {},
                    }
                },
                _ then {},
            },
            .MutableReferenceType(then_inner_ref) then when else_t in {
                .ReferenceType(else_inner_ref) then {
                    when else_inner_ref.val in {
                        .TraitObject(trait_name, _) then {
                            if self.can_convert_to_trait_object(then_inner_ref.val, trait_name) then {
                                return else_t
                            }
                        },
                        _ then {},
                    }
                },
                .MutableReferenceType(else_inner_ref) then {
                    when else_inner_ref.val in {
                        .TraitObject(trait_name, _) then {
                            if self.can_convert_to_trait_object(then_inner_ref.val, trait_name) then {
                                return else_t
                            }
                        },
                        _ then {},
                    }
                    when then_inner_ref.val in {
                        .TraitObject(trait_name, _) then {
                            if self.can_convert_to_trait_object(else_inner_ref.val, trait_name) then {
                                return then_type
                            }
                        },
                        _ then {},
                    }
                },
                _ then {},
            },
            _ then {},
        }

        if then_type is .NeverType() then {
            return else_t
        }
        if else_t is .NeverType() then {
            return then_type
        }

        let then_unresolved = self.is_unresolved_expr_type(then_type)
        let else_unresolved = self.is_unresolved_expr_type(else_t)
        if then_unresolved and not else_unresolved then {
            return else_t
        }
        if else_unresolved and not then_unresolved then {
            return then_type
        }
        when expected in {
            .Some(et) then {
                if not self.is_unresolved_expr_type(et) then {
                    return et
                }
            },
            .None() then {},
        }
        return then_type
    }

    private is_enum_decl_type(self, t Type) Bool = when t in {
        .EnumType(_) then true,
        _ then false,
    }

    private is_enum_base_name(self, base String) Bool = {
        if self.storage.global_scope.lookup_type(base) is .Some(t) then {
            return self.is_enum_decl_type(t)
        }
        return false
    }

    private is_enum_base_name_in_scope(self, base String, scope Scope) Bool = {
        if self.try_resolve_named_type_in_scope_without_diag(base, scope) is .Some(t) then {
            return self.is_enum_decl_type(t)
        }
        return false
    }

    public check_program(self mut ref, program Program, retain_checked_template_bodies Bool) TypedProgram = {
        self.collect_signatures(program)
        let mut typed_decls = List[TypedDecl].new()
        for decl in program.declarations then {
            when decl in {
                .GivenNotTraitDecl(target_type, type_params, trait_name, span) then {
                    self.check_given_not_trait_decl(target_type, type_params, trait_name, span)
                },
                _ then {
                    let td = self.check_decl(decl, retain_checked_template_bodies)
                    let finalized_decl = self.finalize_checked_decl_constraints(if retain_checked_template_bodies then Option[TypedDecl].Some(td) else Option[TypedDecl].None())
                    if retain_checked_template_bodies then when finalized_decl in {
                        .Some(resolved) then typed_decls.push(resolved),
                        .None() then {},
                    }
                },
            }
        }
        if self.has_errors() then {
            return TypedProgram(typed_decls, self.context().get_names())
        }
        return TypedProgram(typed_decls, self.context().get_names())
    }

    // Multi-module variant: check a flat list of LoadedNodes (std + user combined).
    // Each node carries its own source_file for accurate diagnostics.
    public check_loaded_nodes(self mut ref, nodes List[Pair[LoadedNode, List[String]]], retain_checked_template_bodies Bool) TypedProgram = {
        let debug_progress = self.sema_progress_debug_enabled()
        if debug_progress then {
            println("[sema-phase] pass2: collect signatures begin nodes=\(nodes.count())")
        }

        // Pass 2: collect signatures (with per-node file_path context)
        // Match the Swift pipeline and the single-program path by registering
        // all traits first. Otherwise cross-file references like
        // `ref Error` inside generic enum templates can degrade to Unknown
        // when the owning declaration is visited before the trait file.
        for pair in nodes then {
            when pair.first.decl in {
                .TraitDecl(_, _, _, _, _, _) then {
                    self.storage.file_path = pair.first.source_file
                    self.storage.module_path = pair.second
                    self.storage.package_id = pair.first.package_id
                    if debug_progress then {
                        println("[sema-pass2] trait file=\(self.storage.file_path) label=\(self.decl_debug_label(pair.first.decl))")
                    }
                    self.collect_decl_signature(pair.first.decl)
                },
                _ then {},
            }
        }
        for pair in nodes then {
            when pair.first.decl in {
                .TraitDecl(_, _, _, _, _, _) then {},
                _ then {
                    self.storage.file_path = pair.first.source_file
                    self.storage.module_path = pair.second
                    self.storage.package_id = pair.first.package_id
                    if debug_progress then {
                        println("[sema-pass2] decl file=\(self.storage.file_path) label=\(self.decl_debug_label(pair.first.decl))")
                    }
                    self.collect_decl_signature(pair.first.decl)
                },
            }
        }
        if debug_progress then {
            println("[sema-phase] pass2: collect signatures done next_def_id=\(self.context().next_def_id())")
            println("[sema-phase] pass3: check decl begin")
        }
        // Pass 3: check bodies
        let mut typed_decls = List[TypedDecl].new()
        let total_nodes = nodes.count()
        let mut checked_decl_count = 0(UInt)
        let skip_decl_check = self.skip_decl_check_debug_enabled()
        let skip_function_decl_check = self.skip_function_decl_check_debug_enabled()
        let skip_let_decl_check = self.skip_let_decl_check_debug_enabled()
        let skip_given_decl_check = self.skip_given_decl_check_debug_enabled()
        let reset_constraint_solver_each_decl = self.reset_constraint_solver_each_decl_debug_enabled()
        let skip_call_family = self.skip_call_family_debug_enabled()
        let skip_member_path = self.skip_member_path_debug_enabled()
        for pair in nodes then {
            self.storage.file_path = pair.first.source_file
            self.storage.module_path = pair.second
            self.storage.package_id = pair.first.package_id
            let decl_start_def_id = self.context().next_def_id()
            if debug_progress then {
                println("[sema-decl] next=\(checked_decl_count + 1(UInt))/\(total_nodes) file=\(self.storage.file_path) label=\(self.decl_debug_label(pair.first.decl))")
            }
            when pair.first.decl in {
                .GivenNotTraitDecl(target_type, type_params, trait_name, span) then {
                    self.check_given_not_trait_decl(target_type, type_params, trait_name, span)
                    checked_decl_count += 1
                },
                _ then {
                    let skip_this_decl = if skip_decl_check then true else when pair.first.decl in {
                        .FunctionDecl(_, _, _, _, _, _, _) then skip_function_decl_check,
                        .LetDecl(_, _, _, _, _, _) then skip_let_decl_check,
                        .GivenDecl(_, _, _, _) then skip_given_decl_check,
                        .GivenTraitDecl(_, _, _, _, _) then skip_given_decl_check,
                        .GivenNotTraitDecl(_, _, _, _) then skip_given_decl_check,
                        .IntrinsicGivenDecl(_, _, _, _) then skip_given_decl_check,
                        _ then false,
                    }
                    if not skip_this_decl then {
                        let td = self.check_decl(pair.first.decl, retain_checked_template_bodies)
                        let finalized_decl = self.finalize_checked_decl_constraints(if retain_checked_template_bodies then Option[TypedDecl].Some(td) else Option[TypedDecl].None())
                        if retain_checked_template_bodies then when finalized_decl in {
                            .Some(resolved) then typed_decls.push(resolved),
                            .None() then {},
                        }
                    }
                    checked_decl_count += 1
                },
            }
            if reset_constraint_solver_each_decl then {
                self.storage.constraint_solver.clear_debug_state()
            }
            if not retain_checked_template_bodies then {
                let decl_end_def_id = self.context().next_def_id()
                let mut context = self.context()
                context.clear_variable_symbol_types_in_range(decl_start_def_id, decl_end_def_id)
            }
            if debug_progress and checked_decl_count % 8(UInt) == 0(UInt) then {
                self.log_sema_progress(checked_decl_count, total_nodes)
            }
        }
        if self.has_errors() then {
            return TypedProgram(typed_decls, self.context().get_names())
        }
        if debug_progress then {
            println("[sema-phase] pass3: check decl done next_def_id=\(self.context().next_def_id())")
        }
        return TypedProgram(typed_decls, self.context().get_names())
    }

    private finalize_checked_decl_constraints(self mut ref, typed_decl Option[TypedDecl]) Option[TypedDecl] = {
        let subst_result = self.storage.constraint_solver.solve()
        return when subst_result in {
            .Ok(subst) then {
                let resolved_decl = when typed_decl in {
                    .Some(td) then Option[TypedDecl].Some(self.apply_subst_to_decl(subst, td)),
                    .None() then Option[TypedDecl].None(),
                }
                self.storage.constraint_solver.clear_debug_state()
                yield resolved_decl
            },
            .Error(e) then {
                let partial_bindings = self.storage.constraint_solver.unifier.current_bindings()
                let mut resolved_bindings = Dict[UInt, Type].new()
                for entry in partial_bindings then {
                    resolved_bindings.insert(entry.first, self.storage.constraint_solver.unifier.resolve_deep(entry.second))
                }
                let partial_subst = TypeSubstitution(resolved_bindings)
                let resolved_decl = when typed_decl in {
                    .Some(td) then Option[TypedDecl].Some(self.apply_subst_to_decl(partial_subst, td)),
                    .None() then Option[TypedDecl].None(),
                }
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, e.message()))
                self.storage.constraint_solver.clear_debug_state()
                yield resolved_decl
            },
        }
    }

    private collect_signatures(self mut ref, program Program) Void = {
        for decl in program.declarations then {
            when decl in {
                .TraitDecl(_, _, _, _, _, _) then self.collect_decl_signature(decl),
                _ then {},
            }
        }
        for decl in program.declarations then {
            when decl in {
                .TraitDecl(_, _, _, _, _, _) then {},
                _ then self.collect_decl_signature(decl),
            }
        }
    }

    private collect_decl_signature(self mut ref, decl Decl) Void = {
        when decl in {
            .TypeStructDecl(access, name, type_params, fields, span) then {
                let resolved_type = self.lookup_current_file_type_symbol(name)
                    or else panic("TypeChecker pass2 error: missing struct symbol for \(name)")
                if type_params.is_empty() then {
                    self.storage.generic_templates.concrete_struct_types.insert(name, resolved_type)
                } else when resolved_type in {
                    .StructureType(def_id) then {
                        let mut template_fields = List[TemplateField].new()
                        for field in fields then {
                            template_fields.push(TemplateField(field.access, field.name, field.mutable, self.copy_type_node(field.type_name), field.named))
                        }
                        self.storage.generic_templates.struct_templates.insert(
                            name,
                            GenericStructTemplate(def_id, name, self.to_template_type_params(type_params), template_fields)
                        )
                    },
                    _ then panic("TypeChecker pass2 error: generic struct symbol for \(name) is not a structure"),
                }
                if resolved_type is .StructureType(def_id) then {
                    let mut sf = List[StructField].new()
                    if type_params.is_empty() then {
                        for f in fields then {
                            sf.push(StructField(f.name, self.resolve_type(f.type_name), f.mutable, f.access, f.named))
                        }
                    } else {
                        let bindings = self.generic_type_param_bindings(type_params)
                        for f in fields then {
                            sf.push(StructField(f.name, self.resolve_type_with_bindings(f.type_name, bindings), f.mutable, f.access, f.named))
                        }
                    }
                    let mut context = self.context()
                    context.set_struct_fields(def_id, sf)
                } else {
                    panic("TypeChecker pass2 error: struct declaration \(name) resolved to non-structure type")
                }
            },
            .TypeEnumDecl(access, name, type_params, cases, span) then {
                let resolved_type = self.lookup_current_file_type_symbol(name)
                    or else panic("TypeChecker pass2 error: missing enum symbol for \(name)")
                if type_params.is_empty() then {
                    self.storage.generic_templates.concrete_enum_types.insert(name, resolved_type)
                } else when resolved_type in {
                    .EnumType(def_id) then {
                        let mut template_cases = List[TemplateCase].new()
                        for case_ in cases then {
                            let mut template_params = List[TemplateParam].new()
                            for field in case_.fields then {
                                template_params.push(TemplateParam(field.name, false, self.copy_type_node(field.type_name), field.named))
                            }
                            template_cases.push(TemplateCase(case_.name, template_params))
                        }
                        self.storage.generic_templates.enum_templates.insert(
                            name,
                            GenericEnumTemplate(def_id, name, self.to_template_type_params(type_params), template_cases)
                        )
                    },
                    _ then panic("TypeChecker pass2 error: generic enum symbol for \(name) is not an enum"),
                }
                if resolved_type is .EnumType(def_id) then {
                    let mut uc = List[EnumCaseInfo].new()
                    if type_params.is_empty() then {
                        for c in cases then {
                            let mut params = List[EnumCaseParam].new()
                            for f in c.fields then {
                                params.push(EnumCaseParam(f.name, self.resolve_type(f.type_name), f.named))
                            }
                            uc.push(EnumCaseInfo(c.name, params))
                        }
                    } else {
                        let bindings = self.generic_type_param_bindings(type_params)
                        for c in cases then {
                            let mut params = List[EnumCaseParam].new()
                            for f in c.fields then {
                                params.push(EnumCaseParam(f.name, self.resolve_type_with_bindings(f.type_name, bindings), f.named))
                            }
                            uc.push(EnumCaseInfo(c.name, params))
                        }
                    }
                    let mut context = self.context()
                    context.set_enum_cases(def_id, uc)
                } else {
                    panic("TypeChecker pass2 error: enum declaration \(name) resolved to non-enum type")
                }
            },
            .FunctionDecl(access, name, type_params, params, return_type, body, span) then {
                if not type_params.is_empty() then {
                    self.register_generic_function_template(name, type_params, params, return_type, Option[ref TypedExpr].None(), Option[Type].None())
                }
                let mut param_types = List[Type].new()
                let resolved_ret = if type_params.is_empty() then {
                    for p in params then {
                        param_types.push(self.resolve_type(p.type_name))
                    }
                    yield self.resolve_type(return_type)
                } else {
                    let bindings = self.generic_type_param_bindings(type_params)
                    for p in params then {
                        param_types.push(self.resolve_type_with_bindings(p.type_name, bindings))
                    }
                    yield self.resolve_type_with_bindings(return_type, bindings)
                }
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    let mut stable_param_types = List[Type].new()
                    for param_type in param_types then {
                        stable_param_types.push(param_type)
                    }
                    let stable_ret = resolved_ret
                    let mut context = self.context()
                    let typed_params_for_specs = self.build_typed_params_from_resolved(params, param_types)
                    context.set_param_specs(sym.def_id, self.function_param_specs_from_typed_params(typed_params_for_specs))
                    let mut pt_refs = List[ref Type].new()
                    for pt in stable_param_types then {
                        pt_refs.push(box(pt))
                    }
                    let fn_type = make_function_type(pt_refs, stable_ret)
                    let updated = Symbol(sym.def_id, fn_type, sym.kind)
                    context.set_symbol_info(sym.def_id, SymbolInfo(fn_type, sym.kind, MethodKind.Normal(), false))
                    self.storage.global_scope.define(self.context(), updated)
                }
            },
            .IntrinsicFunctionDecl(access, name, type_params, params, return_type, span) then {
                let mut param_types = List[Type].new()
                let resolved_ret = if type_params.is_empty() then {
                    for p in params then {
                        param_types.push(self.resolve_type(p.type_name))
                    }
                    yield self.resolve_type(return_type)
                } else {
                    let bindings = self.generic_type_param_bindings(type_params)
                    for p in params then {
                        param_types.push(self.resolve_type_with_bindings(p.type_name, bindings))
                    }
                    yield self.resolve_type_with_bindings(return_type, bindings)
                }
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    let mut stable_param_types = List[Type].new()
                    for param_type in param_types then {
                        stable_param_types.push(param_type)
                    }
                    let stable_ret = resolved_ret
                    let mut context = self.context()
                    let typed_params_for_specs = self.build_typed_params_from_resolved(params, param_types)
                    context.set_param_specs(sym.def_id, self.function_param_specs_from_typed_params(typed_params_for_specs))
                    context.set_symbol_info(sym.def_id, SymbolInfo(Type.FunctionType(types_to_param_entries(self.to_type_ref_list(stable_param_types)), box(stable_ret)), sym.kind, MethodKind.Normal(), false))
                }
            },
            .ForeignFunctionDecl(access, name, params, return_type, span) then {
                let resolved_ret = self.resolve_type(return_type)
                let mut param_types = List[Type].new()
                for p in params then {
                    param_types.push(self.resolve_type(p.type_name))
                }
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    let mut stable_param_types = List[Type].new()
                    for param_type in param_types then {
                        stable_param_types.push(param_type)
                    }
                    let stable_ret = resolved_ret
                    let mut context = self.context()
                    context.set_param_specs(sym.def_id, self.function_param_specs_from_typed_params(self.check_params(params)))
                    context.set_symbol_info(sym.def_id, SymbolInfo(Type.FunctionType(types_to_param_entries(self.to_type_ref_list(stable_param_types)), box(stable_ret)), sym.kind, MethodKind.Normal(), false))
                }
            },
            .ForeignTypeDecl(access, name, cname, fields, span) then {
                if fields is .Some(raw_fields) and self.lookup_current_file_type_symbol(name) is .Some(t) and t is .StructureType(def_id) then {
                    let mut sf = List[StructField].new()
                    for f in raw_fields then {
                        sf.push(StructField(f.name, self.resolve_type(f.type_name), true, f.access, f.named))
                    }
                    let mut context = self.context()
                    context.set_struct_fields(def_id, sf)
                }
            },
            .TypeAliasDecl(_, name, target, _) then {
                let resolved_target = self.canonicalize_alias_type(self.resolve_type(target))
                if self.lookup_current_file_def_id(name) is .Some(def_id) then {
                    let mut context = self.context()
                    context.add_type(def_id, resolved_target)
                }
                if self.lookup_current_file_def_id(name) is .Some(_) then {
                    self.storage.global_scope.define_type(name, resolved_target)
                }
            },
            .GivenDecl(target_type, type_params, members, span) then {
                if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params) then {
                } else {
                    let bindings = self.generic_type_param_bindings(type_params)
                    let resolved_target = if type_params.is_empty()
                        then self.resolve_type(target_type)
                        else self.resolve_type_with_bindings(target_type, bindings)
                    let extension_type_key = self.extension_template_key_for_target_node(target_type, resolved_target)
                    let target_type_name = self.type_node_name(target_type)
                    let trait_tool_target_name = if type_params.is_empty() and self.storage.trait_registry.get(target_type_name) is .Some(_) then Option[String].Some(target_type_name) else Option[String].None()
                    self.collect_given_signatures(members, resolved_target, type_params, Option[String].None())
                    for member in members then {
                        let method_name = member.name
                        let method_access = member.access
                        let method_type_params = member.type_params
                        let method_params = member.params
                        let method_return_type_node = member.return_type
                        let no_checked_body = Option[ref TypedExpr].None()
                        let should_register_template = if not type_params.is_empty() then true else if not member.type_params.is_empty() then true else when resolved_target in {
                            .TraitObject(_, _) then true,
                            _ then self.mentions_unresolved_generic_placeholder(resolved_target),
                        }
                        if should_register_template then {
                            self.register_extension_method_template(
                                extension_type_key,
                                type_params,
                                method_name,
                                method_access,
                                method_type_params,
                                method_params,
                                method_return_type_node,
                                Option[String].None(),
                                no_checked_body,
                                Option[Type].None(),
                            )
                        }
                        when trait_tool_target_name in {
                            .Some(trait_name) then {
                                let all_bindings = self.merged_type_param_bindings(type_params, method_type_params)
                                self.backfill_trait_tool_method_to_existing_conformances(
                                    trait_name,
                                    method_name,
                                    method_access,
                                    method_type_params,
                                    method_params,
                                    method_return_type_node,
                                    self.resolve_given_member_type_with_bindings(member.return_type, resolved_target, all_bindings),
                                )
                            },
                            .None() then {
                            },
                        }
                    }
                }
            },
            .GivenTraitDecl(target_type, type_params, trait_type, members, span) then {
                if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params) then {
                } else {
                    let bindings = self.generic_type_param_bindings(type_params)
                    let resolved_target = if type_params.is_empty()
                        then self.resolve_type(target_type)
                        else self.resolve_type_with_bindings(target_type, bindings)
                    let extension_type_key = self.extension_template_key_for_target_node(target_type, resolved_target)
                    let trait_name = self.type_node_name(trait_type)
                    let resolved_trait_args = self.trait_type_args_with_bindings(trait_type, bindings)
                    if self.sema_progress_debug_enabled() then {
                        println("[sema-pass2-giventrait] target=\(self.context().type_display_name(resolved_target)) step=record-conformance trait=\(trait_name)")
                    }
                    self.record_explicit_trait_conformance(resolved_target, trait_name, resolved_trait_args)
                    self.record_generic_trait_conformance_template(resolved_target, type_params, trait_name, resolved_trait_args)
                    if self.sema_progress_debug_enabled() then {
                        println("[sema-pass2-giventrait] target=\(self.context().type_display_name(resolved_target)) step=iterator-conformance trait=\(trait_name)")
                    }
                    self.maybe_record_iterator_conformance_with_bindings(resolved_target, trait_type, bindings)
                    if self.sema_progress_debug_enabled() then {
                        println("[sema-pass2-giventrait] target=\(self.context().type_display_name(resolved_target)) step=collect-signatures trait=\(trait_name)")
                    }
                    self.collect_given_signatures(members, resolved_target, type_params, Option[String].Some(trait_name))
                    if self.sema_progress_debug_enabled() then {
                        println("[sema-pass2-giventrait] target=\(self.context().type_display_name(resolved_target)) step=collect-signatures-done trait=\(trait_name)")
                    }
                    let mut needs_template_registration = not type_params.is_empty()
                    if not needs_template_registration then {
                        for member in members then {
                            if not member.type_params.is_empty() then {
                                needs_template_registration = true
                            } else when resolved_target in {
                                .TraitObject(_, _) then {
                                    needs_template_registration = true
                                },
                                _ then {
                                    if self.mentions_unresolved_generic_placeholder(resolved_target) then {
                                        needs_template_registration = true
                                    }
                                },
                            }
                        }
                    }
                    if needs_template_registration then {
                        // Only the template-registration path needs trait generic bindings in scope.
                        if self.sema_progress_debug_enabled() then {
                            println("[sema-pass2-giventrait] target=\(self.context().type_display_name(resolved_target)) step=inject-trait-type-args trait=\(trait_name)")
                        }
                        let prev_resolution_scope = self.storage.resolution_scope
                        finally { self.storage.resolution_scope = prev_resolution_scope }
                        self.inject_trait_type_args_with_bindings(trait_type, trait_name, bindings)
                        for member in members then {
                            let should_register_template = if not type_params.is_empty() then true else if not member.type_params.is_empty() then true else when resolved_target in {
                                .TraitObject(_, _) then true,
                                _ then self.mentions_unresolved_generic_placeholder(resolved_target),
                            }
                            if not should_register_template then {
                                continue
                            }
                            let method_name = member.name
                            let method_access = member.access
                            let method_type_params = member.type_params
                            let method_params = member.params
                            let method_return_type_node = member.return_type
                            let no_checked_body = Option[ref TypedExpr].None()
                            self.register_extension_method_template(
                                extension_type_key,
                                type_params,
                                method_name,
                                method_access,
                                method_type_params,
                                method_params,
                                method_return_type_node,
                                Option[String].Some(trait_name),
                                no_checked_body,
                                Option[Type].None(),
                            )
                        }
                    }
                    if self.sema_progress_debug_enabled() then {
                        println("[sema-pass2-giventrait] target=\(self.context().type_display_name(resolved_target)) step=restore trait=\(trait_name)")
                    }
                }
            },
            .IntrinsicGivenDecl(target_type, type_params, members, span) then {
                if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params) then {
                } else {
                    let bindings = self.generic_type_param_bindings(type_params)
                    let resolved_target = if type_params.is_empty()
                        then self.resolve_type(target_type)
                        else self.resolve_type_with_bindings(target_type, bindings)
                    let extension_type_key = self.extension_template_key_for_target_node(target_type, resolved_target)
                    self.collect_given_signatures(members, resolved_target, type_params, Option[String].None())
                    for member in members then {
                        let should_register_template = if not type_params.is_empty() then true else if not member.type_params.is_empty() then true else when resolved_target in {
                            .TraitObject(_, _) then true,
                            _ then self.mentions_unresolved_generic_placeholder(resolved_target),
                        }
                        if not should_register_template then {
                            continue
                        }
                        let method_name = member.name
                        let method_access = member.access
                        let method_type_params = member.type_params
                        let method_params = member.params
                        let method_return_type_node = member.return_type
                        let no_checked_body = Option[ref TypedExpr].None()
                        self.register_extension_method_template(
                            extension_type_key,
                            type_params,
                            method_name,
                            method_access,
                            method_type_params,
                            method_params,
                            method_return_type_node,
                            Option[String].None(),
                            no_checked_body,
                            Option[Type].None(),
                        )
                    }
                }
            },
            .GivenNotTraitDecl(_, _, _, _) then {},
            .LetDecl(access, name, mutable, type_name, initializer, span) then {
                let resolved = self.resolve_type(type_name)
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    let updated = Symbol(sym.def_id, resolved, sym.kind)
                    self.storage.global_scope.define(self.context(), updated)
                    let mut context = self.context()
                    context.set_symbol_info(
                        sym.def_id,
                        SymbolInfo(resolved, sym.kind, MethodKind.Normal(), mutable)
                    )
                }
            },
            .ForeignLetDecl(access, name, mutable, type_name, span) then {
                let resolved = self.resolve_type(type_name)
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    let updated = Symbol(sym.def_id, resolved, sym.kind)
                    self.storage.global_scope.define(self.context(), updated)
                    let mut context = self.context()
                    context.set_symbol_info(
                        sym.def_id,
                        SymbolInfo(resolved, sym.kind, MethodKind.Normal(), mutable)
                    )
                }
            },
            .TraitDecl(access, name, type_params, parents, members, span) then {
                // 在 signature 收集阶段注册完整 Trait（包含方法）,
                // 确保跨模块 given 检查能读取到正确的 requirement 集合。
                let mut parent_constraints = List[ParentTraitConstraint].new()
                for p in parents then {
                    let pname = self.type_node_name(p)
                    let type_arg_nodes = when p in {
                        .Generic(_, args) then {
                            let mut nodes = List[TypeNode].new()
                            for arg in args then {
                                nodes.push(arg.val)
                            }
                            yield nodes
                        },
                        _ then List[TypeNode].new(),
                    }
                    parent_constraints.push(ParentTraitConstraint(pname, type_arg_nodes))
                }
                let typed_members = self.check_trait_members(members, type_params)
                self.register_trait_metadata(name, type_params, parent_constraints, members, typed_members)
            },
            _ then {},
        }
    }

    private collect_given_signatures(self, members List[GivenMember], target_type Type, owner_type_params List[TypeParameter], conformance_trait_name Option[String]) Void = {
        // Build a resolution scope with owner type params so resolve_type sees them
        // Always set resolution_scope (like Swift's withNewScope) so generic params are visible
        let prev_resolution_scope = self.storage.resolution_scope
        finally { self.storage.resolution_scope = prev_resolution_scope }
        let mut sig_scope = Scope.new_child(self.storage.global_scope)
        for tp in owner_type_params then {
            sig_scope.define_generic_param(tp.name)
        }
        self.storage.resolution_scope = Option[Scope].Some(sig_scope)
        let type_key = self.extension_template_key(target_type)
        let has_template_key = when target_type in {
            .GenericStruct(_, _) then true,
            .GenericEnum(_, _) then true,
            _ then false,
        }
        let template_lookup_key = when target_type in {
            .GenericStruct(template, _) then template,
            .GenericEnum(template, _) then template,
            _ then "",
        }
        let mut seen_names = List[String].new()
        for m in members then {
            if self.sema_progress_debug_enabled() then {
                println("[sema-pass2-given] target=\(self.context().type_display_name(target_type)) member=\(m.name)")
            }
            if self.string_list_contains(seen_names, m.name) then {
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, self.duplicate_definition_message(m.name)))
                continue
            }
            seen_names.push(m.name)
            let should_register_as_inherent = when conformance_trait_name in {
                .Some(_) then false,
                .None() then owner_type_params.is_empty() and m.type_params.is_empty(),
            }
            if should_register_as_inherent then {
                if self.lookup_method_signature(type_key, m.name) is .Some(_) then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, self.duplicate_definition_message(m.name)))
                    continue
                }
                if has_template_key then {
                    if self.lookup_method_signature(template_lookup_key, m.name) is .Some(_) then {
                        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, self.duplicate_definition_message(m.name)))
                        continue
                    }
                }
            }
            // Always resolve types for all members (inherent + conformance)
            // so cross-references within the same given block work.
            let member_bindings = self.merged_type_param_bindings(owner_type_params, m.type_params)
            if self.sema_progress_debug_enabled() then {
                println("[sema-pass2-given-step] member=\(m.name) step=resolve-return")
            }
            let ret = self.resolve_given_member_type_with_bindings(m.return_type, target_type, member_bindings)
            let mut param_types = List[Type].new()
            for param in m.params then {
                param_types.push(self.resolve_given_member_type_with_bindings(param.type_name, target_type, member_bindings))
            }
            if not should_register_as_inherent then {
                continue
            }
            if self.sema_progress_debug_enabled() then {
                println("[sema-pass2-given-step] member=\(m.name) step=make-symbol")
            }
            let method_symbol = self.make_method_callable_symbol_with_param_types(
                m.name,
                param_types,
                self.function_param_specs_from_params(m.params),
                ret,
                m.access,
                self.storage.module_path,
                self.storage.file_path,
                self.storage.package_id,
            )
            if should_register_as_inherent then {
                if self.sema_progress_debug_enabled() then {
                    println("[sema-pass2-given-step] member=\(m.name) step=register")
                }
                self.storage.method_table.register(type_key, m.name, method_symbol)
                if has_template_key then {
                    self.storage.method_table.register(template_lookup_key, m.name, method_symbol)
                }
            }
        }
    }

    private string_list_contains(self, values List[String], target String) Bool = {
        let mut index = 0(UInt)
        while index < values.count() then {
            if values[index] == target then {
                return true
            }
            index += 1(UInt)
        }
        return false
    }

    private to_template_type_params(self, type_params List[TypeParameter]) List[TypeParameterDecl] = {
        let mut out = List[TypeParameterDecl].new()
        for tp in type_params then {
            let mut constraints = List[TypeNode].new()
            for constraint in tp.constraints then {
                constraints.push(constraint.val)
            }
            out.push(TypeParameterDecl(tp.name, constraints))
        }
        return out
    }

    private generic_type_param_bindings(self, type_params List[TypeParameter]) Dict[String, Type] = {
        let mut bindings = Dict[String, Type].new()
        for tp in type_params then {
            bindings.insert(tp.name, Type.GenericParameter(tp.name))
        }
        return bindings
    }

    private merged_type_param_bindings(self, owner_params List[TypeParameter], method_params List[TypeParameter]) Dict[String, Type] = {
        let mut bindings = Dict[String, Type].new()
        for tp in owner_params then {
            bindings.insert(tp.name, Type.GenericParameter(tp.name))
        }
        for tp in method_params then {
            bindings.insert(tp.name, Type.GenericParameter(tp.name))
        }
        return bindings
    }

    private to_template_params(self, params List[Param]) List[TemplateParam] = {
        let mut out = List[TemplateParam].new()
        for p in params then {
            out.push(TemplateParam(p.name, p.mutable, self.copy_type_node(p.type_name), p.named))
        }
        return out
    }

    private copy_type_node_ref(self, type_node ref TypeNode) ref TypeNode = {
        return box(self.copy_type_node(type_node.val))
    }

    private copy_type_node_ref_list(self, type_nodes List[ref TypeNode]) List[ref TypeNode] = {
        let mut copied = List[ref TypeNode].with_capacity(type_nodes.count())
        for type_node in type_nodes then {
            copied.push(self.copy_type_node_ref(type_node))
        }
        return copied
    }

    private copy_type_node(self, type_node TypeNode) TypeNode = {
        return when type_node in {
            .Identifier(name) then TypeNode.Identifier(name),
            .Reference(inner, mutable) then TypeNode.Reference(self.copy_type_node_ref(inner), mutable),
            .Pointer(inner, mutable) then TypeNode.Pointer(self.copy_type_node_ref(inner), mutable),
            .WeakReference(inner, mutable) then TypeNode.WeakReference(self.copy_type_node_ref(inner), mutable),
            .Generic(base, args) then TypeNode.Generic(base, self.copy_type_node_ref_list(args)),
            .InferredSelf() then TypeNode.InferredSelf(),
            .FunctionType(param_types, return_type) then TypeNode.FunctionType(self.copy_type_node_ref_list(param_types), self.copy_type_node_ref(return_type)),
        }
    }

    private to_type_ref_list(self, types List[Type]) List[ref Type] = {
        let mut out = List[ref Type].new()
        for t in types then {
            out.push(box(t))
        }
        return out
    }

    private from_template_type_params(self, type_params List[TypeParameterDecl]) List[TypeParameter] = {
        let mut out = List[TypeParameter].new()
        for tp in type_params then {
            let mut constraints = List[ref TypeNode].new()
            for constraint in tp.constraints then {
                constraints.push(box(constraint))
            }
            out.push(TypeParameter(tp.name, constraints))
        }
        return out
    }


    private constraint_bounds_for_type_param(self, tp TypeParameter) List[GenericConstraintBound] = {
        let mut constraints = List[GenericConstraintBound].new()
        for c in tp.constraints then {
            constraints.push(self.resolve_constraint_bound(c.val))
        }
        return constraints
    }

    /// Resolve a constraint TypeNode into a GenericConstraintBound, preserving type arguments.
    /// Unlike resolve_type, this does NOT emit diagnostics for unresolved names —
    /// forward-referenced generic params (e.g. T in [R Iterator[T], T]) fall back to GenericParameter.
    private resolve_constraint_bound(self, node TypeNode) GenericConstraintBound = {
        return when node in {
            .Identifier(name) then GenericConstraintBound(name, List[Type].new()),
            .Generic(base, args) then {
                let mut resolved_args = List[Type].new()
                for arg in args then {
                    resolved_args.push(self.resolve_constraint_type_arg(arg.val))
                }
                yield GenericConstraintBound(base, resolved_args)
            },
            _ then GenericConstraintBound("?", List[Type].new()),
        }
    }

    /// Lightweight type arg resolution for constraint bounds — no diagnostics on miss.
    private resolve_constraint_type_arg(self, node TypeNode) Type = {
        return when node in {
            .Identifier(name) then self.resolve_constraint_identifier(name),
            .Generic(base, args) then self.resolve_constraint_generic_type(base, args),
            .Reference(inner, mutable) then self.resolve_constraint_ref_type(inner.val, mutable),
            _ then Type.Unknown(),
        }
    }

    private resolve_constraint_identifier(self, name String) Type = {
        return when self.storage.global_scope.lookup_type(name) in {
            .Some(t) then t,
            .None() then Type.GenericParameter(name),
        }
    }

    private resolve_constraint_generic_type(self, base String, args List[ref TypeNode]) Type = {
        let mut resolved_args = List[Type].new()
        for arg in args then {
            resolved_args.push(self.resolve_constraint_type_arg(arg.val))
        }
        return Type.GenericStruct(base, self.to_type_ref_list_in_resolution(resolved_args))
    }

    private resolve_constraint_ref_type(self, inner TypeNode, mutable Bool) Type = {
        let resolved_inner = self.resolve_constraint_type_arg(inner)
        if mutable then {
            return Type.MutableReferenceType(box(resolved_inner))
        }
        return Type.ReferenceType(box(resolved_inner))
    }

    private snapshot_generic_constraints(self, type_params List[TypeParameter]) GenericConstraintSnapshot = {
        let mut previous_constraints = Dict[String, Option[List[GenericConstraintBound]]].new()
        for tp in type_params then {
            let previous = when self.storage.generic_param_constraints.get(tp.name) in {
                .Some(existing) then {
                    let mut copied = List[GenericConstraintBound].with_capacity(existing.count())
                    for constraint in existing then {
                        copied.push(constraint)
                    }
                    yield Option[List[GenericConstraintBound]].Some(copied)
                },
                .None() then Option[List[GenericConstraintBound]].None(),
            }
            previous_constraints.insert(tp.name, previous)
        }
        return GenericConstraintSnapshot(previous_constraints)
    }

    private register_generic_constraints(self, type_params List[TypeParameter]) Void = {
        self.invalidate_trait_requirement_caches()
        for tp in type_params then {
            self.storage.generic_param_constraints.insert(tp.name, self.constraint_bounds_for_type_param(tp))
        }
    }

    private restore_generic_constraints(self, snapshot GenericConstraintSnapshot) Void = {
        self.invalidate_trait_requirement_caches()
        for entry in snapshot.previous_constraints then {
            let name = entry.first
            when entry.second in {
                .Some(previous) then self.storage.generic_param_constraints.insert(name, previous),
                .None() then self.storage.generic_param_constraints.remove(name),
            }
        }
    }

    private nominal_def_id_for_type(self, t Type) Option[DefId] = {
        return when t in {
            .StructureType(def_id) then .Some(def_id),
            .EnumType(def_id) then .Some(def_id),
            .OpaqueType(def_id) then .Some(def_id),
            .GenericStruct(name, _) then when self.storage.global_scope.lookup_type(name) in {
                .Some(resolved) then self.nominal_def_id_for_type(resolved),
                .None() then Option[DefId].None(),
            },
            .GenericEnum(name, _) then when self.storage.global_scope.lookup_type(name) in {
                .Some(resolved) then self.nominal_def_id_for_type(resolved),
                .None() then Option[DefId].None(),
            },
            _ then Option[DefId].None(),
        }
    }

    private check_not_deref_constraint(self, inner_type Type, expr ref Expr) Bool = {
        return when self.nominal_def_id_for_type(inner_type) in {
            .Some(def_id) then {
                if self.context().is_not_deref(def_id) then {
                    let type_name = when self.context().get_name(def_id) in {
                        .Some(name) then name,
                        .None() then self.display_type_name(inner_type),
                    }
                    self.push_expr_diagnostic(expr, "Type '\(type_name)' is marked as 'not Deref' and cannot be dereferenced with '.val'")
                    return false
                }
                yield true
            },
            .None() then true,
        }
    }

    private mark_not_deref_type(self mut ref, type_params List[TypeParameter], type_node TypeNode, trait_name String) Void = {
        if trait_name <> "Deref" then {
            self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Only 'not Deref' is currently supported"))
            return
        }

        // Use child scope instead of mutating global_scope (Swift: withNewScope)
        let prev_resolution_scope = self.storage.resolution_scope
        finally { self.storage.resolution_scope = prev_resolution_scope }
        let child = Scope.new_child(self.storage.global_scope)
        for tp in type_params then {
            child.define_generic_param(tp.name)
        }
        self.storage.resolution_scope = Option[Scope].Some(child)
        let resolved_type = self.resolve_type(type_node)
        when self.nominal_def_id_for_type(resolved_type) in {
            .Some(def_id) then {
                let mut context = self.context()
                context.set_not_deref(def_id)
            },
            .None() then {
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Only nominal types can be marked as 'not Deref'"))
            },
        }
    }

    private check_given_not_trait_decl(self mut ref, target_type TypeNode, type_params List[TypeParameter], trait_name String, span SourceSpan) Void = {
        let _ = span
        self.mark_not_deref_type(type_params, target_type, trait_name)
    }

}
