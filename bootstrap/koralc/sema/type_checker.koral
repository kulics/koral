// Type Checker - Pass 2 + 3
// Pass 2: collect_signatures - resolves type members and function signatures
// Pass 3: check_decl - checks function bodies and generates TypedAST

using Std.Os.*

// All mutable checker state lives in storage so TypeChecker can be passed by
// value without losing mutations (mirrors the List/storage ref pattern).
protected type TypeCheckerStorage(
    mut global_scope Scope,
    mut def_id_map DefIdMap,
    mut method_table MethodTable,
    mut diagnostics [DiagnosticError]List,
    mut file_path String,
    mut module_path [String]List,
    mut in_function Bool,
    mut current_function_return_type [Type]Option,
    mut in_loop Bool,
    mut in_finally Bool,
    mut constraint_solver ConstraintSolver,
    mut trait_registry TraitRegistry,
    mut generic_param_constraints [String, [String]List]Dict,
    mut generic_templates GenericTemplateRegistry,
    mut instantiation_requests [InstantiationRequest]List,
    mut import_graph [ImportGraph]Option,
    mut known_root_modules [String]Set,
    mut explicit_trait_conformances [String]Set,
    mut generic_trait_conformance_templates [GenericTraitConformanceTemplate]List,
    mut explicit_iterator_conformances [String]Set,
    mut explicit_iterator_template_item_index [String, UInt]Dict,
    mut top_level_decl_def_ids [[DefId]Option]List,
    sema_debug_enabled Bool,
)

public type TypeChecker(protected mut storage TypeCheckerStorage ref)

protected type IfChain(
    arms [[Expr ref, Expr ref]Pair]List,
    final_else [Expr ref]Option,
)

protected type TypeBindingSnapshot(
    type_entries [String, Type]Dict,
    generic_params [String]Set,
    generic_param_constraints [String, [String]List]Dict,
)

protected type GenericTraitConformanceTemplate(
    target_type Type,
    owner_type_params [TypeParameterDecl]List,
    trait_name String,
    trait_arg_types [Type]List,
)

protected type GenericTraitConformanceStatus {
    Satisfied(),
    MissingConstraint(target_type Type, trait_name String),
    MissingConformance(),
}

given TypeChecker {
    public new(global_scope Scope, def_id_map DefIdMap, file_path String, top_level_decl_def_ids [[DefId]Option]List) TypeChecker = {
        let debug_enabled = when env("KORAL_DEBUG_SEMA") in {
            .Some(value) then value == "1" or value == "true" or value == "TRUE",
            .None() then false,
        }
        let s = box(TypeCheckerStorage(
            global_scope,
            def_id_map,
            MethodTable.new(),
            [DiagnosticError]List.new(),
            file_path,
            [String]List.new(),
            false,
            [Type]Option.None(),
            false,
            false,
            ConstraintSolver.new(),
            TraitRegistry.new(),
            [String, [String]List]Dict.new(),
            GenericTemplateRegistry.new(),
            [InstantiationRequest]List.new(),
            [ImportGraph]Option.None(),
            [String]Set.new(),
            [String]Set.new(),
            [GenericTraitConformanceTemplate]List.new(),
            [String]Set.new(),
            [String, UInt]Dict.new(),
            top_level_decl_def_ids,
            debug_enabled
        ))
        return TypeChecker(s)
    }

    public has_errors(self) Bool = not self.storage.diagnostics.is_empty()

    private sema_debug(self, message String) Void = {
        if self.storage.sema_debug_enabled then {
            eprintln("[sema] \(message)")
        }
    }

    protected push_diagnostic(self, message String) Void = {
        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, message))
    }

    protected push_diagnostic_at_span(self, message String, span SourceSpan) Void = {
        self.storage.diagnostics.push(make_diagnostic_at(DiagnosticStage.Semantic(), self.storage.file_path, message, span))
    }

    protected push_expr_diagnostic(self, expr Expr ref, message String) Void = {
        self.push_diagnostic_at_span(message, expr_span(expr))
    }

    protected push_pattern_diagnostic(self, pattern PatternNode ref, message String) Void = {
        self.push_diagnostic_at_span(message, pattern_span(pattern))
    }

    protected typed_expr_span(self, expr TypedExpr ref) SourceSpan = {
        return when expr.expr_kind in {
            .Variable(symbol) then self.storage.def_id_map.get_span(symbol.def_id) or else unknown_span(),
            .CastExpr(_, inner) then self.typed_expr_span(inner),
            .Unary(_, inner) then self.typed_expr_span(inner),
            .RefExpr(inner) then self.typed_expr_span(inner),
            .PtrExpr(inner) then self.typed_expr_span(inner),
            .DerefExpr(inner) then self.typed_expr_span(inner),
            .ArithmeticExpr(left, _, _) then self.typed_expr_span(left),
            .ComparisonExpr(left, _, _) then self.typed_expr_span(left),
            .BitwiseExpr(left, _, _) then self.typed_expr_span(left),
            .AndExpr(left, _) then self.typed_expr_span(left),
            .OrExpr(left, _) then self.typed_expr_span(left),
            .IsExpr(subject, pattern, _) then {
                let subject_span = self.typed_expr_span(subject)
                yield if is_known_span(subject_span) then subject_span else pattern_span(pattern)
            },
            .Call(callee, _) then self.typed_expr_span(callee),
            .MemberExpr(base, _) then self.typed_expr_span(base),
            .MemberPath(base, _) then self.typed_expr_span(base),
            .Block(statements) then if statements.is_empty() then unknown_span() else when statements.at((UInt)0) in {
                .LetStmt(_, _, span) then span,
                .PairLetStmt(_, _, _, span) then span,
                .AssignmentStmt(_, _, span) then span,
                .ExprStmt(_, span) then span,
                .ReturnStmt(_, span) then span,
                .BreakStmt(span) then span,
                .ContinueStmt(span) then span,
                .FinallyStmt(_, span) then span,
                .YieldStmt(_, span) then span,
            },
            .IfExpr(condition, _, _) then self.typed_expr_span(condition),
            .WhileExpr(condition, _) then self.typed_expr_span(condition),
            .WhenExpr(subject, _) then self.typed_expr_span(subject),
            .LambdaExpr(_, _, body) then self.typed_expr_span(body),
            .StaticMethodCall(_, method, args) then {
                let method_span = self.storage.def_id_map.get_span(method.def_id) or else unknown_span()
                yield if is_known_span(method_span) then method_span else if args.is_empty() then unknown_span() else self.typed_expr_span(args.at((UInt)0))
            },
            .GenericMethodCall(base, _, method, _, _) then {
                let base_span = self.typed_expr_span(base)
                yield if is_known_span(base_span) then base_span else self.storage.def_id_map.get_span(method.def_id) or else unknown_span()
            },
            .TraitObjectConversion(inner, _, _) then self.typed_expr_span(inner),
            .QualifiedMethodCall(base, _, method, _, _) then {
                let base_span = self.typed_expr_span(base)
                yield if is_known_span(base_span) then base_span else self.storage.def_id_map.get_span(method.def_id) or else unknown_span()
            },
            .GenericInstantiation(base_type, _) then when base_type in {
                .StructureType(def_id) then self.storage.def_id_map.get_span(def_id) or else unknown_span(),
                .EnumType(def_id) then self.storage.def_id_map.get_span(def_id) or else unknown_span(),
                .OpaqueType(def_id) then self.storage.def_id_map.get_span(def_id) or else unknown_span(),
                _ then unknown_span(),
            },
            _ then unknown_span(),
        }
    }

    protected push_typed_expr_diagnostic(self, expr TypedExpr ref, message String) Void = {
        self.push_diagnostic_at_span(message, self.typed_expr_span(expr))
    }

    protected statement_span(self, stmt Statement) SourceSpan = {
        return when stmt in {
            .LetStmt(_, _, _, _, span) then span,
            .PairLetStmt(_, _, _, span) then span,
            .AssignmentStmt(_, _, _, span) then span,
            .ExprStmt(_, span) then span,
            .ReturnStmt(_, span) then span,
            .BreakStmt(span) then span,
            .ContinueStmt(span) then span,
            .FinallyStmt(_, span) then span,
            .YieldStmt(_, span) then span,
        }
    }

    protected push_statement_diagnostic(self, stmt Statement, message String) Void = {
        self.push_diagnostic_at_span(message, self.statement_span(stmt))
    }

    // Treat both Unknown and TypeVar as unresolved so they do not leak into codegen.
    private is_unresolved_expr_type(self, t Type) Bool = when t in {
        .Unknown() then true,
        .TypeVar(_) then true,
        _ then false,
    }

    private is_value_expr_type(self, t Type) Bool = when t in {
        .VoidType() then false,
        .NeverType() then false,
        _ then not self.is_unresolved_expr_type(t),
    }

    private is_ffi_compatible_type(self, t Type) Bool = {
        return when t in {
            .IntType() then true,
            .Int8Type() then true,
            .Int16Type() then true,
            .Int32Type() then true,
            .Int64Type() then true,
            .UIntType() then true,
            .UInt8Type() then true,
            .UInt16Type() then true,
            .UInt32Type() then true,
            .UInt64Type() then true,
            .Float32Type() then true,
            .Float64Type() then true,
            .BoolType() then true,
            .VoidType() then true,
            .NeverType() then true,
            .PointerType(_) then true,
            .OpaqueType(_) then true,
            _ then false,
        }
    }

    private ffi_type_error(self, t Type) String = {
        return when t in {
            .StructureType(_) then "Koral struct types cannot be used in foreign functions",
            .EnumType(_) then "Koral enum types cannot be used in foreign functions",
            .ReferenceType(_) then "Reference types (ref) cannot be used in foreign functions",
            .WeakReferenceType(_) then "Weak reference types cannot be used in foreign functions",
            .FunctionType(_, _) then "Function types cannot be used in foreign functions",
            .GenericParameter(_) then "Generic parameters cannot be used in foreign functions",
            _ then "Type '\(self.storage.def_id_map.type_display_name(t))' is not compatible with FFI",
        }
    }

    private same_expr_type(self, left Type, right Type) Bool = type_to_string(left) == type_to_string(right)

    private canonicalize_alias_type(self, t Type) Type = {
        return when t in {
            .StructureType(def_id) then when self.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped) then {
                    if type_to_string(mapped) == type_to_string(t) then {
                        return t
                    }
                    return self.canonicalize_alias_type(mapped)
                },
                .None() then t,
            },
            .EnumType(def_id) then when self.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped) then {
                    if type_to_string(mapped) == type_to_string(t) then {
                        return t
                    }
                    return self.canonicalize_alias_type(mapped)
                },
                .None() then t,
            },
            .OpaqueType(def_id) then when self.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped) then {
                    if type_to_string(mapped) == type_to_string(t) then {
                        return t
                    }
                    return self.canonicalize_alias_type(mapped)
                },
                .None() then t,
            },
            .ReferenceType(inner) then Type.ReferenceType(box(self.canonicalize_alias_type(inner.val))),
            .PointerType(inner) then Type.PointerType(box(self.canonicalize_alias_type(inner.val))),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.canonicalize_alias_type(inner.val))),
            .FunctionType(param_types, return_type) then {
                let mut resolved_params = [Type ref]List.new()
                for pt in param_types then {
                    resolved_params.push(box(self.canonicalize_alias_type(pt.val)))
                }
                let resolved_ret = self.canonicalize_alias_type(return_type.val)
                yield Type.FunctionType(resolved_params, box(resolved_ret))
            },
            _ then t,
        }
    }

    private concretize_default_literal_type(self, t Type) Type = {
        let resolved = self.storage.constraint_solver.resolve(t)
        return when resolved in {
            .TypeVar(tv) then when tv.name in {
                .Some(name) then {
                    if name == "int_lit" then {
                        return Type.IntType()
                    }
                    if name == "float_lit" then {
                        return Type.Float64Type()
                    }
                    return resolved
                },
                .None() then resolved,
            },
            .ReferenceType(inner) then Type.ReferenceType(box(self.concretize_default_literal_type(inner.val))),
            .PointerType(inner) then Type.PointerType(box(self.concretize_default_literal_type(inner.val))),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.concretize_default_literal_type(inner.val))),
            .FunctionType(param_types, return_type) then {
                let mut resolved_params = [Type ref]List.new()
                for pt in param_types then {
                    resolved_params.push(box(self.concretize_default_literal_type(pt.val)))
                }
                yield Type.FunctionType(resolved_params, box(self.concretize_default_literal_type(return_type.val)))
            },
            .GenericStruct(template, args) then {
                let mut resolved_args = [Type ref]List.new()
                for arg in args then {
                    resolved_args.push(box(self.concretize_default_literal_type(arg.val)))
                }
                yield Type.GenericStruct(template, resolved_args)
            },
            .GenericEnum(template, args) then {
                let mut resolved_args = [Type ref]List.new()
                for arg in args then {
                    resolved_args.push(box(self.concretize_default_literal_type(arg.val)))
                }
                yield Type.GenericEnum(template, resolved_args)
            },
            _ then resolved,
        }
    }

    protected display_type_name(self, t Type) String = {
        let resolved = self.canonicalize_alias_type(self.concretize_default_literal_type(t))
        return when resolved in {
            .StructureType(def_id) then when self.storage.def_id_map.get_name(def_id) in {
                .Some(name) then name,
                .None() then when self.storage.def_id_map.get_original_def_id(def_id) in {
                    .Some(original_def_id) then when self.storage.def_id_map.get_name(original_def_id) in {
                        .Some(original_name) then original_name,
                        .None() then type_to_string(resolved),
                    },
                    .None() then type_to_string(resolved),
                },
            },
            .EnumType(def_id) then when self.storage.def_id_map.get_name(def_id) in {
                .Some(name) then name,
                .None() then when self.storage.def_id_map.get_original_def_id(def_id) in {
                    .Some(original_def_id) then when self.storage.def_id_map.get_name(original_def_id) in {
                        .Some(original_name) then original_name,
                        .None() then type_to_string(resolved),
                    },
                    .None() then type_to_string(resolved),
                },
            },
            .OpaqueType(def_id) then when self.storage.def_id_map.lookup_type(def_id) in {
                .Some(mapped) then self.display_type_name(mapped),
                .None() then type_to_string(resolved),
            },
            .ReferenceType(inner) then "\(self.display_type_name(inner.val)) ref",
            .PointerType(inner) then "\(self.display_type_name(inner.val)) ptr",
            .WeakReferenceType(inner) then "\(self.display_type_name(inner.val)) weakref",
            .FunctionType(param_types, return_type) then {
                let mut out = "["
                let mut first = true
                for pt in param_types then {
                    if not first then { out.push_string(", ") }
                    out.push_string(self.display_type_name(pt.val))
                    first = false
                }
                out.push_string("]Func -> ")
                out.push_string(self.display_type_name(return_type.val))
                yield out
            },
            .GenericStruct(template, args) then {
                let mut out = "["
                let mut first = true
                for arg in args then {
                    if not first then { out.push_string(", ") }
                    out.push_string(self.display_type_name(arg.val))
                    first = false
                }
                out.push_byte(']')
                out.push_string(template)
                yield out
            },
            .GenericEnum(template, args) then {
                let mut out = "["
                let mut first = true
                for arg in args then {
                    if not first then { out.push_string(", ") }
                    out.push_string(self.display_type_name(arg.val))
                    first = false
                }
                out.push_byte(']')
                out.push_string(template)
                yield out
            },
            _ then type_to_string(resolved),
        }
    }

    private choose_conditional_result_type(self, expected [Type]Option, then_type Type, else_type [Type]Option) Type = {
        when expected in {
            .Some(et) then {
                if not self.contains_generic_parameter(et) then {
                    return et
                }
            },
            .None() then {},
        }
        if else_type is .None() then { return then_type }

        let else_t = when else_type in {
            .Some(t) then t,
            .None() then { return then_type },
        }

        if self.same_expr_type(then_type, else_t) then {
            return then_type
        }
        if then_type is .NeverType() then {
            return else_t
        }
        if else_t is .NeverType() then {
            return then_type
        }

        let then_unresolved = self.is_unresolved_expr_type(then_type)
        let else_unresolved = self.is_unresolved_expr_type(else_t)
        if then_unresolved and not else_unresolved then {
            return else_t
        }
        if else_unresolved and not then_unresolved then {
            return then_type
        }
        when expected in {
            .Some(et) then {
                if not self.is_unresolved_expr_type(et) then {
                    return et
                }
            },
            .None() then {},
        }
        return then_type
    }

    private is_enum_decl_type(self, t Type) Bool = when t in {
        .EnumType(_) then true,
        _ then false,
    }

    private is_enum_base_name(self, base String) Bool = {
        if self.storage.global_scope.lookup_type(base) is .Some(t) then {
            return self.is_enum_decl_type(t)
        }
        return false
    }

    private is_enum_base_name_in_scope(self, base String, scope Scope) Bool = {
        if self.try_resolve_named_type_in_scope_without_diag(base, scope) is .Some(t) then {
            return self.is_enum_decl_type(t)
        }
        return false
    }

    public check_program(self, program Program) TypedProgram = {
        self.collect_signatures(program)
        let mut typed_decls = [TypedDecl]List.new()
        for decl in program.declarations then {
            let td = self.check_decl(decl)
            typed_decls.push(td)
        }
        return self.finalize_typed_decls(typed_decls)
    }

    // Multi-module variant: check a flat list of LoadedNodes (std + user combined).
    // Each node carries its own source_file for accurate diagnostics.
    public check_loaded_nodes(self, nodes [[LoadedNode, [String]List]Pair]List) TypedProgram = {
        self.storage.known_root_modules = [String]Set.new()
        for pair in nodes then {
            if pair.second.count() > (UInt)0 then {
                self.storage.known_root_modules.insert(pair.second.at((UInt)0))
            }
        }

        // Pass 2: collect signatures (with per-node file_path context)
        let mut sig_index UInt = 0
        for pair in nodes then {
            self.storage.file_path = pair.first.source_file
            self.storage.module_path = pair.second
            self.sema_debug("pass2 collect signature node=\(sig_index) file=\(pair.first.source_file)")
            self.collect_decl_signature(pair.first.decl)
            sig_index += 1
        }
        // Pass 3: check bodies
        let mut typed_decls = [TypedDecl]List.new()
        let mut body_index UInt = 0
        for pair in nodes then {
            self.storage.file_path = pair.first.source_file
            self.storage.module_path = pair.second
            self.sema_debug("pass3 check decl node=\(body_index) file=\(pair.first.source_file) decl=\(decl_brief_name(pair.first.decl))")
            let td = self.check_decl(pair.first.decl)
            typed_decls.push(td)
            body_index += 1
        }
        // Pass 4: constraint solving + type substitution
        return self.finalize_typed_decls(typed_decls)
    }

    private finalize_typed_decls(self, typed_decls [TypedDecl]List) TypedProgram = {
        let subst_result = self.storage.constraint_solver.solve()
        return when subst_result in {
            .Ok(subst) then {
                let mut final_decls = [TypedDecl]List.new()
                for td in typed_decls then {
                    final_decls.push(self.apply_subst_to_decl(subst, td))
                }
                yield TypedProgram(final_decls, self.storage.def_id_map.names, self.storage.top_level_decl_def_ids)
            },
            .Error(e) then {
                // 即使约束求解失败，仍然尝试应用已有的绑定（部分替换）。
                // 这样可以让后续阶段获得尽可能多的类型信息。
                let partial_bindings = self.storage.constraint_solver.unifier.current_bindings()
                let mut resolved_bindings = [UInt, Type]Dict.new()
                for entry in partial_bindings then {
                    resolved_bindings.insert(entry.first, self.storage.constraint_solver.unifier.resolve_deep(entry.second))
                }
                let partial_subst = TypeSubstitution(resolved_bindings)
                let mut final_decls = [TypedDecl]List.new()
                for td in typed_decls then {
                    final_decls.push(self.apply_subst_to_decl(partial_subst, td))
                }
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, e.message()))
                yield TypedProgram(final_decls, self.storage.def_id_map.names, self.storage.top_level_decl_def_ids)
            },
        }
    }

    private collect_signatures(self, program Program) Void = {
        for decl in program.declarations then {
            self.collect_decl_signature(decl)
        }
    }

    private collect_decl_signature(self, decl Decl) Void = {
        when decl in {
            .TypeStructDecl(access, name, type_params, fields, span) then {
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                if self.lookup_current_file_type_symbol(name) is .Some(t) then {
                    if type_params.is_empty() then {
                        self.storage.generic_templates.concrete_struct_types.insert(name, t)
                    } else when t in {
                        .StructureType(def_id) then {
                            let mut template_fields = [TemplateField]List.new()
                            for field in fields then {
                                template_fields.push(TemplateField(field.access, field.name, field.mutable, field.type_name, field.named))
                            }
                            self.storage.generic_templates.struct_templates.insert(
                                name,
                                GenericStructTemplate(def_id, name, self.to_template_type_params(type_params), template_fields)
                            )
                        },
                        _ then {},
                    }
                }
                if self.lookup_current_file_type_symbol(name) is .Some(t) and t is .StructureType(def_id) then {
                    let mut sf = [StructField]List.new()
                    for f in fields then {
                        sf.push(StructField(f.name, self.resolve_type(f.type_name), f.mutable, f.access, f.named))
                    }
                    self.storage.def_id_map.set_struct_fields(def_id, sf)
                }
                self.restore_type_bindings(type_binding_snapshot)
            },
            .TypeEnumDecl(access, name, type_params, cases, span) then {
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                if self.lookup_current_file_type_symbol(name) is .Some(t) then {
                    if type_params.is_empty() then {
                        self.storage.generic_templates.concrete_enum_types.insert(name, t)
                    } else when t in {
                        .EnumType(def_id) then {
                            let mut template_cases = [TemplateCase]List.new()
                            for case_ in cases then {
                                let mut template_params = [TemplateParam]List.new()
                                for field in case_.fields then {
                                    template_params.push(TemplateParam(field.name, false, field.type_name, field.named))
                                }
                                template_cases.push(TemplateCase(case_.name, template_params))
                            }
                            self.storage.generic_templates.enum_templates.insert(
                                name,
                                GenericEnumTemplate(def_id, name, self.to_template_type_params(type_params), template_cases)
                            )
                        },
                        _ then {},
                    }
                }
                if self.lookup_current_file_type_symbol(name) is .Some(t) and t is .EnumType(def_id) then {
                    let mut uc = [EnumCaseInfo]List.new()
                    for c in cases then {
                        let mut params = [EnumCaseParam]List.new()
                        for f in c.fields then {
                            params.push(EnumCaseParam(f.name, self.resolve_type(f.type_name), f.named))
                        }
                        uc.push(EnumCaseInfo(c.name, params))
                    }
                    self.storage.def_id_map.set_enum_cases(def_id, uc)
                }
                self.restore_type_bindings(type_binding_snapshot)
            },
            .FunctionDecl(access, name, type_params, params, return_type, body, span) then {
                if not type_params.is_empty() then {
                    self.register_generic_function_template(name, type_params, params, return_type, [TypedExpr]Option.None(), [Type]Option.None())
                }
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                let resolved_ret = self.resolve_type(return_type)
                let mut param_types = [Type]List.new()
                let mut param_specs = [FunctionParamSpec]List.new()
                for p in params then {
                    param_types.push(self.resolve_type(p.type_name))
                    param_specs.push(FunctionParamSpec(p.name, p.named))
                }
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    self.storage.def_id_map.set_signature(sym.def_id, FunctionSignature(param_types, resolved_ret, param_specs))
                    let mut pt_refs = [Type ref]List.new()
                    for pt in param_types then {
                        pt_refs.push(box(pt))
                    }
                    let fn_type = Type.FunctionType(pt_refs, box(resolved_ret))
                    let updated = Symbol(sym.def_id, sym.name, fn_type, sym.kind)
                    self.storage.def_id_map.set_symbol_info(sym.def_id, SymbolInfo(fn_type, sym.kind, MethodKind.Normal(), false))
                    self.storage.global_scope.define(updated)
                }
                self.restore_type_bindings(type_binding_snapshot)
            },
            .IntrinsicFunctionDecl(access, name, type_params, params, return_type, span) then {
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                let resolved_ret = self.resolve_type(return_type)
                let mut param_types = [Type]List.new()
                let mut param_specs = [FunctionParamSpec]List.new()
                for p in params then {
                    param_types.push(self.resolve_type(p.type_name))
                    param_specs.push(FunctionParamSpec(p.name, p.named))
                }
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    self.storage.def_id_map.set_signature(sym.def_id, FunctionSignature(param_types, resolved_ret, param_specs))
                    self.storage.def_id_map.set_symbol_info(sym.def_id, SymbolInfo(Type.FunctionType(self.to_type_ref_list(param_types), box(resolved_ret)), sym.kind, MethodKind.Normal(), false))
                }
                self.restore_type_bindings(type_binding_snapshot)
            },
            .ForeignFunctionDecl(access, name, params, return_type, span) then {
                let resolved_ret = self.resolve_type(return_type)
                let mut param_types = [Type]List.new()
                let mut param_specs = [FunctionParamSpec]List.new()
                for p in params then {
                    param_types.push(self.resolve_type(p.type_name))
                    param_specs.push(FunctionParamSpec(p.name, p.named))
                }
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    self.storage.def_id_map.set_signature(sym.def_id, FunctionSignature(param_types, resolved_ret, param_specs))
                    self.storage.def_id_map.set_symbol_info(sym.def_id, SymbolInfo(Type.FunctionType(self.to_type_ref_list(param_types), box(resolved_ret)), sym.kind, MethodKind.Normal(), false))
                }
            },
            .ForeignTypeDecl(access, name, cname, fields, span) then {
                if fields is .Some(raw_fields) and self.lookup_current_file_type_symbol(name) is .Some(t) and t is .StructureType(def_id) then {
                    let mut sf = [StructField]List.new()
                    for f in raw_fields then {
                        sf.push(StructField(f.name, self.resolve_type(f.type_name), true, f.access, f.named))
                    }
                    self.storage.def_id_map.set_struct_fields(def_id, sf)
                }
            },
            .TypeAliasDecl(_, name, target, _) then {
                let resolved_target = self.canonicalize_alias_type(self.resolve_type(target))
                if self.lookup_current_file_def_id(name) is .Some(def_id) then {
                    self.storage.def_id_map.add_type(def_id, resolved_target)
                }
                if self.lookup_current_file_def_id(name) is .Some(_) then {
                    self.storage.global_scope.define_type(name, resolved_target)
                }
            },
            .GivenDecl(target_type, type_params, members, span) then {
                if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params) then {
                } else {
                    let type_binding_snapshot = self.snapshot_type_bindings()
                    for tp in type_params then {
                        self.bind_type_param(tp)
                    }
                    let resolved_target = self.resolve_type(target_type)
                    self.collect_given_signatures(members, resolved_target, type_params, [String]Option.None())
                    for member in members then {
                        let member_type_binding_snapshot = self.snapshot_type_bindings()
                        for tp in member.type_params then {
                            self.bind_type_param(tp)
                        }
                        let member_type_scope = self.make_given_member_type_scope(resolved_target, type_params, member.type_params)
                        let method_params = self.check_params_in_scope(member.params, member_type_scope)
                        let method_return_type = self.resolve_type_in_scope(member.return_type, member_type_scope)
                        self.register_extension_method_template(resolved_target, type_params, member, method_params, [String]Option.None(), [TypedExpr]Option.None(), [Type]Option.None())
                        when resolved_target in {
                            .TraitObject(trait_name) then {
                                self.backfill_trait_tool_method_to_existing_conformances(trait_name, member, method_params, method_return_type)
                            },
                            _ then {},
                        }
                        self.restore_type_bindings(member_type_binding_snapshot)
                    }
                    self.restore_type_bindings(type_binding_snapshot)
                }
            },
            .GivenTraitDecl(target_type, type_params, trait_type, members, span) then {
                if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params) then {
                } else {
                    let type_binding_snapshot = self.snapshot_type_bindings()
                    for tp in type_params then {
                        self.bind_type_param(tp)
                    }
                    let resolved_target = self.resolve_type(target_type)
                    let trait_name = self.type_node_name(trait_type)
                    self.record_explicit_trait_conformance(resolved_target, trait_name)
                    self.record_generic_trait_conformance_template(resolved_target, type_params, trait_type, trait_name)
                    self.maybe_record_iterator_conformance(resolved_target, trait_type)
                    // 注入 trait 类型参数
                    self.inject_trait_type_args(trait_type, trait_name)
                    self.collect_given_signatures(members, resolved_target, type_params, [String]Option.Some(trait_name))
                    for member in members then {
                        let member_type_binding_snapshot = self.snapshot_type_bindings()
                        for tp in member.type_params then {
                            self.bind_type_param(tp)
                        }
                        let member_type_scope = self.make_given_member_type_scope(resolved_target, type_params, member.type_params)
                        let method_params = self.check_params_in_scope(member.params, member_type_scope)
                        self.register_extension_method_template(resolved_target, type_params, member, method_params, [String]Option.Some(trait_name), [TypedExpr]Option.None(), [Type]Option.None())
                        self.restore_type_bindings(member_type_binding_snapshot)
                    }
                    self.restore_type_bindings(type_binding_snapshot)
                }
            },
            .IntrinsicGivenDecl(target_type, type_params, members, span) then {
                if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params) then {
                } else {
                    let type_binding_snapshot = self.snapshot_type_bindings()
                    for tp in type_params then {
                        self.bind_type_param(tp)
                    }
                    let resolved_target = self.resolve_type(target_type)
                    self.collect_given_signatures(members, resolved_target, type_params, [String]Option.None())
                    for member in members then {
                        let member_type_binding_snapshot = self.snapshot_type_bindings()
                        for tp in member.type_params then {
                            self.bind_type_param(tp)
                        }
                        let member_type_scope = self.make_given_member_type_scope(resolved_target, type_params, member.type_params)
                        let method_params = self.check_params_in_scope(member.params, member_type_scope)
                        self.register_extension_method_template(resolved_target, type_params, member, method_params, [String]Option.None(), [TypedExpr]Option.None(), [Type]Option.None())
                        self.restore_type_bindings(member_type_binding_snapshot)
                    }
                    self.restore_type_bindings(type_binding_snapshot)
                }
            },
            .LetDecl(access, name, mutable, type_name, initializer, span) then {
                let resolved = self.resolve_type(type_name)
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    let updated = Symbol(sym.def_id, sym.name, resolved, sym.kind)
                    self.storage.global_scope.define(updated)
                    self.storage.def_id_map.set_symbol_info(
                        sym.def_id,
                        SymbolInfo(resolved, sym.kind, MethodKind.Normal(), mutable)
                    )
                }
            },
            .ForeignLetDecl(access, name, mutable, type_name, span) then {
                let resolved = self.resolve_type(type_name)
                if self.lookup_current_file_symbol(name) is .Some(sym) then {
                    let updated = Symbol(sym.def_id, sym.name, resolved, sym.kind)
                    self.storage.global_scope.define(updated)
                    self.storage.def_id_map.set_symbol_info(
                        sym.def_id,
                        SymbolInfo(resolved, sym.kind, MethodKind.Normal(), mutable)
                    )
                }
            },
            .TraitDecl(access, name, type_params, parents, members, span) then {
                // 在 signature 收集阶段注册完整 Trait（包含方法）,
                // 确保跨模块 given 检查能读取到正确的 requirement 集合。
                let mut parent_names = [String]List.new()
                for p in parents then {
                    parent_names.push(self.type_node_name(p))
                }
                let mut param_names = [String]List.new()
                for tp in type_params then {
                    param_names.push(tp.name)
                }
                let typed_members = self.check_trait_members(members, type_params)
                let info = TraitInfo(name, param_names, parent_names, typed_members, self.storage.module_path)
                self.storage.trait_registry.register(info)
            },
            _ then {},
        }
    }

    private collect_given_signatures(self, members [GivenMember]List, target_type Type, owner_type_params [TypeParameter]List, conformance_trait_name [String]Option) Void = {
        let type_key = self.storage.def_id_map.type_display_name(target_type)
        let template_key = when target_type in {
            .GenericStruct(template, _) then [String]Option.Some(template),
            .GenericEnum(template, _) then [String]Option.Some(template),
            _ then [String]Option.None(),
        }
        let mut seen_names = [String]Set.new()
        for m in members then {
            if seen_names.contains(m.name) then {
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Duplicate definition: \(m.name)"))
                continue
            }
            seen_names.insert(m.name)
            let should_register_as_inherent = when conformance_trait_name in {
                .Some(_) then false,
                .None() then true,
            }
            if should_register_as_inherent then {
                if self.storage.method_table.lookup(type_key, m.name) is .Some(_) then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Duplicate definition: \(m.name)"))
                    continue
                }
                if template_key is .Some(key) and self.storage.method_table.lookup(key, m.name) is .Some(_) then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Duplicate definition: \(m.name)"))
                    continue
                }
            }
            let type_binding_snapshot = self.snapshot_type_bindings()
            for tp in m.type_params then {
                self.storage.global_scope.define_type(tp.name, Type.GenericParameter(tp.name))
            }
            let member_type_scope = self.make_given_member_type_scope(target_type, owner_type_params, m.type_params)
            let ret = self.resolve_type_in_scope(m.return_type, member_type_scope)
            let mut param_types = [Type]List.new()
            let typed_params = self.check_params_in_scope(m.params, member_type_scope)
            for p in typed_params then {
                param_types.push(p.param_type)
            }
            let mut param_specs = [FunctionParamSpec]List.new()
            for p in typed_params then {
                param_specs.push(FunctionParamSpec(p.name, p.named))
            }
            let sig = FunctionSignature(param_types, ret, param_specs)
            if should_register_as_inherent then {
                self.storage.method_table.register(type_key, m.name, sig)
                if template_key is .Some(key) then { self.storage.method_table.register(key, m.name, sig) }
            }
            self.restore_type_bindings(type_binding_snapshot)
        }
    }

    private to_template_type_params(self, type_params [TypeParameter]List) [TypeParameterDecl]List = {
        let mut out = [TypeParameterDecl]List.new()
        for tp in type_params then {
            let mut constraints = [String]List.new()
            for constraint in tp.constraints then {
                constraints.push(self.type_node_name(constraint.val))
            }
            out.push(TypeParameterDecl(tp.name, constraints))
        }
        return out
    }

    private to_template_params(self, params [Param]List) [TemplateParam]List = {
        let mut out = [TemplateParam]List.new()
        for p in params then {
            out.push(TemplateParam(p.name, p.mutable, p.type_name, p.named))
        }
        return out
    }

    private to_type_ref_list(self, types [Type]List) [Type ref]List = {
        let mut out = [Type ref]List.new()
        for t in types then {
            out.push(box(t))
        }
        return out
    }

    private from_template_type_params(self, type_params [TypeParameterDecl]List) [TypeParameter]List = {
        let mut out = [TypeParameter]List.new()
        for tp in type_params then {
            let mut constraints = [TypeNode ref]List.new()
            for constraint in tp.constraints then {
                constraints.push(box(TypeNode.Identifier(constraint)))
            }
            out.push(TypeParameter(tp.name, constraints))
        }
        return out
    }

    private snapshot_type_bindings(self) TypeBindingSnapshot = {
        return TypeBindingSnapshot(
            self.storage.global_scope.all_types(),
            self.storage.global_scope.all_generic_params(),
            self.storage.generic_param_constraints,
        )
    }

    private restore_type_bindings(self, snapshot TypeBindingSnapshot) Void = {
        self.storage.global_scope.restore_type_state(snapshot.type_entries, snapshot.generic_params)
        self.storage.generic_param_constraints = snapshot.generic_param_constraints
    }

    private bind_type_param(self, tp TypeParameter) Void = {
        self.storage.global_scope.define_type(tp.name, Type.GenericParameter(tp.name))
        let mut constraints = [String]List.new()
        for c in tp.constraints then {
            constraints.push(self.type_node_name(c.val))
        }
        self.storage.generic_param_constraints.insert(tp.name, constraints)
    }

    private to_typed_expr_option(self, value [TypedExpr ref]Option) [TypedExpr]Option = {
        return when value in {
            .Some(expr) then [TypedExpr]Option.Some(expr.val),
            .None() then [TypedExpr]Option.None(),
        }
    }

    private contains_generic_parameter(self, t Type) Bool = {
        return type_contains_generic_parameter(t, self.storage.def_id_map.ref)
    }

    private mentions_unresolved_generic_placeholder(self, t Type) Bool = {
        return type_mentions_unresolved_generic_placeholder(t)
    }

    private contains_generic_parameter_in_list(self, types [Type]List) Bool = {
        for t in types then {
            if self.contains_generic_parameter(t) then { return true }
        }
        return false
    }

    private upsert_extension_template(self, key String, template GenericExtensionMethodTemplate) Void = {
        when self.storage.generic_templates.extension_methods.get(key) in {
            .Some(existing) then {
                let mut updated = existing
                let mut index = (UInt)0
                let mut replaced = false
                while index < updated.count() then {
                    let current = updated.at(index)
                    let same_name = current.method.name == template.method.name
                    let same_owner_type_param_count = current.type_params.count() == template.type_params.count()
                    let same_method_type_param_count = current.method.type_params.count() == template.method.type_params.count()
                    if same_name and same_owner_type_param_count and same_method_type_param_count then {
                        let should_replace = when template.checked_body in {
                            .Some(_) then true,
                            .None() then when current.checked_body in {
                                .Some(_) then false,
                                .None() then true,
                            },
                        }
                        if should_replace then {
                            updated.set_at(index, template)
                        }
                        replaced = true
                        break
                    }
                    index += (UInt)1
                }
                if not replaced then {
                    updated.push(template)
                }
                self.storage.generic_templates.extension_methods.insert(key, updated)
            },
            .None() then {
                let mut list = [GenericExtensionMethodTemplate]List.new()
                list.push(template)
                self.storage.generic_templates.extension_methods.insert(key, list)
            },
        }
    }

    private register_extension_method_template(
        self,
        target_type Type,
        owner_type_params [TypeParameter]List,
        member GivenMember,
        method_params [TypedParam]List,
        conformance_trait_name [String]Option,
        checked_body [TypedExpr]Option,
        checked_return_type [Type]Option,
    ) Void = {
        let method_decl = MethodDeclaration(
            member.name,
            member.access,
            self.to_template_type_params(member.type_params),
            method_params,
            member.return_type,
            unknown_span(),
        )
        let template = GenericExtensionMethodTemplate(
            self.to_template_type_params(owner_type_params),
            method_decl,
            conformance_trait_name,
            [Type]List.new(),
            checked_body,
            [[Symbol]List]Option.None(),
            checked_return_type,
        )
        let type_key = self.storage.def_id_map.type_display_name(target_type)
        self.upsert_extension_template(type_key, template)
        when target_type in {
            .GenericStruct(template_name, _) then self.upsert_extension_template(template_name, template),
            .GenericEnum(template_name, _) then self.upsert_extension_template(template_name, template),
            _ then {},
        }
    }

    private register_trait_tool_templates_for_concrete_type(self, target_type Type, owner_type_params [TypeParameter]List, trait_name String, existing_members [TypedGivenMember]List) Void = {
        self.register_conformance_method_signatures_for_concrete_type(target_type, existing_members)
        when self.storage.generic_templates.lookup_extension_methods(trait_name) in {
            .Some(tool_templates) then {
                let type_key = self.storage.def_id_map.type_display_name(target_type)
                let concrete_type_params = self.to_template_type_params(owner_type_params)
                let mut conformance_trait_args = [Type]List.new()
                for conformance in self.storage.generic_trait_conformance_templates then {
                    if conformance.trait_name == trait_name and self.storage.def_id_map.type_display_name(conformance.target_type) == type_key then {
                        for trait_arg in conformance.trait_arg_types then {
                            conformance_trait_args.push(trait_arg)
                        }
                        break
                    }
                }
                for template in tool_templates then {
                    let mut already_present = false
                    for member in existing_members then {
                        if member.name == template.method.name then {
                            already_present = true
                        }
                    }
                    if already_present then {
                        continue
                    }

                    let concrete_template = GenericExtensionMethodTemplate(
                        concrete_type_params,
                        template.method,
                        [String]Option.Some(trait_name),
                        conformance_trait_args,
                        template.checked_body,
                        template.checked_parameters,
                        template.checked_return_type,
                    )
                    if self.storage.method_table.lookup(type_key, template.method.name) is .None() then {
                        let mut param_types = [Type]List.new()
                        let mut param_specs = [FunctionParamSpec]List.new()
                        let mut concrete_params = [TypedParam]List.new()
                        let mut method_bindings = [String, Type]Dict.new()
                        when self.storage.trait_registry.get(trait_name) in {
                            .Some(info) then {
                                let param_count = info.type_params.count()
                                let arg_count = conformance_trait_args.count()
                                let n = if param_count < arg_count then param_count else arg_count
                                let mut i UInt = 0
                                while i < n then {
                                    method_bindings.insert(info.type_params.at(i), conformance_trait_args.at(i))
                                    i += 1
                                }
                            },
                            .None() then {},
                        }
                        let source_params = when template.checked_parameters in {
                            .Some(checked_params) then {
                                let mut params = [TypedParam]List.new()
                                for sym in checked_params then {
                                    params.push(TypedParam(sym.name, sym.is_mutable(), sym.symbol_type, false))
                                }
                                yield params
                            },
                            .None() then template.method.params,
                        }
                        for p in source_params then {
                            let bound_param_type = self.bind_conformance_trait_self_type(
                                self.apply_trait_self_binding(self.apply_type_bindings(p.param_type, method_bindings), target_type),
                                trait_name,
                                target_type,
                            )
                            concrete_params.push(TypedParam(p.name, p.mutable, bound_param_type, p.named))
                            param_types.push(bound_param_type)
                            param_specs.push(FunctionParamSpec(p.name, p.named))
                        }
                        let source_return_type = when template.checked_return_type in {
                            .Some(checked_return_type) then checked_return_type,
                            .None() then self.resolve_type_in_scope(
                                template.method.return_type,
                                self.make_given_member_type_scope(
                                    target_type,
                                    owner_type_params,
                                    self.from_template_type_params(template.method.type_params),
                                ),
                            ),
                        }
                        let bound_return_type = self.bind_conformance_trait_self_type(
                            self.apply_trait_self_binding(self.apply_type_bindings(source_return_type, method_bindings), target_type),
                            trait_name,
                            target_type,
                        )
                        let sig = FunctionSignature(param_types, bound_return_type, param_specs)
                        self.storage.method_table.register(type_key, template.method.name, sig)
                        when target_type in {
                            .GenericStruct(template_name, _) then self.storage.method_table.register(template_name, template.method.name, sig),
                            .GenericEnum(template_name, _) then self.storage.method_table.register(template_name, template.method.name, sig),
                            .StructureType(def_id) then {
                                if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                                    self.storage.method_table.register(name, template.method.name, sig)
                                }
                            },
                            .EnumType(def_id) then {
                                if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                                    self.storage.method_table.register(name, template.method.name, sig)
                                }
                            },
                            _ then {},
                        }
                    }
                    self.upsert_extension_template(type_key, concrete_template)
                    when target_type in {
                        .GenericStruct(template_name, _) then {
                            self.upsert_extension_template(template_name, concrete_template)
                        },
                        .GenericEnum(template_name, _) then {
                            self.upsert_extension_template(template_name, concrete_template)
                        },
                        .StructureType(def_id) then {
                            if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                                self.upsert_extension_template(name, concrete_template)
                            }
                        },
                        .EnumType(def_id) then {
                            if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                                self.upsert_extension_template(name, concrete_template)
                            }
                        },
                        _ then {},
                    }
                }
            },
            .None() then {},
        }
    }

    private register_conformance_method_signatures_for_concrete_type(self, target_type Type, members [TypedGivenMember]List) Void = {
        let type_key = self.storage.def_id_map.type_display_name(target_type)
        for member in members then {
            if self.storage.method_table.lookup(type_key, member.name) is .Some(_) then {
                continue
            }

            let mut param_types = [Type]List.new()
            let mut param_specs = [FunctionParamSpec]List.new()
            for p in member.params then {
                param_types.push(p.param_type)
                param_specs.push(FunctionParamSpec(p.name, p.named))
            }
            let sig = FunctionSignature(param_types, member.return_type, param_specs)
            self.storage.method_table.register(type_key, member.name, sig)
            when target_type in {
                .GenericStruct(template_name, _) then self.storage.method_table.register(template_name, member.name, sig),
                .GenericEnum(template_name, _) then self.storage.method_table.register(template_name, member.name, sig),
                .StructureType(def_id) then {
                    if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                        self.storage.method_table.register(name, member.name, sig)
                    }
                },
                .EnumType(def_id) then {
                    if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                        self.storage.method_table.register(name, member.name, sig)
                    }
                },
                _ then {},
            }
        }
    }

    private backfill_trait_tool_method_to_existing_conformances(
        self,
        trait_name String,
        member GivenMember,
        method_params [TypedParam]List,
        return_type Type,
    ) Void = {
        let method_decl = MethodDeclaration(
            member.name,
            member.access,
            self.to_template_type_params(member.type_params),
            method_params,
            member.return_type,
            unknown_span(),
        )

        for conformance in self.storage.generic_trait_conformance_templates then {
            if conformance.trait_name <> trait_name then {
                continue
            }

            let type_key = self.storage.def_id_map.type_display_name(conformance.target_type)
            if self.storage.method_table.lookup(type_key, member.name) is .None() then {
                let mut param_types = [Type]List.new()
                let mut param_specs = [FunctionParamSpec]List.new()
                for p in method_params then {
                    let bound_param_type = self.bind_conformance_trait_self_type(
                        self.apply_trait_self_binding(p.param_type, conformance.target_type),
                        trait_name,
                        conformance.target_type,
                    )
                    param_types.push(bound_param_type)
                    param_specs.push(FunctionParamSpec(p.name, p.named))
                }
                let bound_return_type = self.bind_conformance_trait_self_type(
                    self.apply_trait_self_binding(return_type, conformance.target_type),
                    trait_name,
                    conformance.target_type,
                )
                let sig = FunctionSignature(param_types, bound_return_type, param_specs)
                self.storage.method_table.register(type_key, member.name, sig)
                when conformance.target_type in {
                    .GenericStruct(template_name, _) then self.storage.method_table.register(template_name, member.name, sig),
                    .GenericEnum(template_name, _) then self.storage.method_table.register(template_name, member.name, sig),
                    .StructureType(def_id) then {
                        if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                            self.storage.method_table.register(name, member.name, sig)
                        }
                    },
                    .EnumType(def_id) then {
                        if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                            self.storage.method_table.register(name, member.name, sig)
                        }
                    },
                    _ then {},
                }
            }

            let concrete_template = GenericExtensionMethodTemplate(
                conformance.owner_type_params,
                method_decl,
                [String]Option.Some(trait_name),
                conformance.trait_arg_types,
                [TypedExpr]Option.None(),
                [[Symbol]List]Option.None(),
                [Type]Option.Some(return_type),
            )
            self.upsert_extension_template(type_key, concrete_template)
            when conformance.target_type in {
                .GenericStruct(template_name, _) then self.upsert_extension_template(template_name, concrete_template),
                .GenericEnum(template_name, _) then self.upsert_extension_template(template_name, concrete_template),
                .StructureType(def_id) then {
                    if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                        self.upsert_extension_template(name, concrete_template)
                    }
                },
                .EnumType(def_id) then {
                    if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                        self.upsert_extension_template(name, concrete_template)
                    }
                },
                _ then {},
            }
        }
    }

    private backfill_checked_trait_tool_method_to_existing_conformances(
        self,
        trait_name String,
        member GivenMember,
        method_params [TypedParam]List,
        checked_body [TypedExpr]Option,
        checked_return_type Type,
    ) Void = {
        let method_decl = MethodDeclaration(
            member.name,
            member.access,
            self.to_template_type_params(member.type_params),
            method_params,
            member.return_type,
            unknown_span(),
        )

        for conformance in self.storage.generic_trait_conformance_templates then {
            if conformance.trait_name <> trait_name then {
                continue
            }

            let type_key = self.storage.def_id_map.type_display_name(conformance.target_type)
            let concrete_template = GenericExtensionMethodTemplate(
                conformance.owner_type_params,
                method_decl,
                [String]Option.Some(trait_name),
                conformance.trait_arg_types,
                checked_body,
                [[Symbol]List]Option.None(),
                [Type]Option.Some(checked_return_type),
            )
            self.upsert_extension_template(type_key, concrete_template)
            when conformance.target_type in {
                .GenericStruct(template_name, _) then self.upsert_extension_template(template_name, concrete_template),
                .GenericEnum(template_name, _) then self.upsert_extension_template(template_name, concrete_template),
                .StructureType(def_id) then {
                    if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                        self.upsert_extension_template(name, concrete_template)
                    }
                },
                .EnumType(def_id) then {
                    if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                        self.upsert_extension_template(name, concrete_template)
                    }
                },
                _ then {},
            }
        }
    }

    private register_generic_function_template(
        self,
        name String,
        type_params [TypeParameter]List,
        params [Param]List,
        return_type TypeNode,
        checked_body [TypedExpr]Option,
        checked_return_type [Type]Option,
    ) Void = {
        if self.storage.global_scope.lookup(name) is .Some(sym) then {
            let template = GenericFunctionTemplate(
                sym.def_id,
                name,
                self.to_template_type_params(type_params),
                self.to_template_params(params),
                return_type,
                checked_body,
                [[Symbol]List]Option.None(),
                checked_return_type,
            )
            self.storage.generic_templates.function_templates.insert(name, template)
        }
    }

    private maybe_record_extension_method_instantiation(self, base_type Type, method_name String, method_type_args [Type]List) Void = {
        let normalized_base = base_type
        if self.contains_generic_parameter(normalized_base) then { return }
        if self.contains_generic_parameter_in_list(method_type_args) then { return }

        let mut template_name_opt = [String]Option.None()
        let mut extension_type_args = [Type ref]List.new()
        when normalized_base in {
            .GenericStruct(template_name, args) then {
                template_name_opt = [String]Option.Some(template_name)
                for arg in args then {
                    extension_type_args.push(box(arg.val))
                }
            },
            .GenericEnum(template_name, args) then {
                template_name_opt = [String]Option.Some(template_name)
                for arg in args then {
                    extension_type_args.push(box(arg.val))
                }
            },
            .StructureType(def_id) then {
                if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                    template_name_opt = [String]Option.Some(name)
                }
            },
            .EnumType(def_id) then {
                if self.storage.def_id_map.get_name(def_id) is .Some(name) then {
                    template_name_opt = [String]Option.Some(name)
                }
            },
            .ReferenceType(inner) then {
                template_name_opt = [String]Option.Some("T ref")
                extension_type_args.push(box(inner.val))
            },
            .PointerType(inner) then {
                template_name_opt = [String]Option.Some("T ptr")
                extension_type_args.push(box(inner.val))
            },
            .WeakReferenceType(inner) then {
                template_name_opt = [String]Option.Some("T weakref")
                extension_type_args.push(box(inner.val))
            },
            _ then {},
        }

        let template_name = when template_name_opt in {
            .Some(name) then name,
            .None() then { return },
        }
        let method_type_args_ref = self.to_type_ref_list(method_type_args)
        let receiver_is_generic_instance = when normalized_base in {
            .GenericStruct(_, _) then true,
            .GenericEnum(_, _) then true,
            _ then false,
        }
        if self.storage.generic_templates.lookup_extension_methods(template_name) is .Some(ext_templates) then {
            if select_extension_template(
                ext_templates,
                method_name,
                [UInt]Option.Some(method_type_args_ref.count()),
                [UInt]Option.Some(extension_type_args.count()),
            ) is .Some(template) then {
                let request_template = GenericExtensionMethodTemplate(
                    template.type_params,
                    template.method,
                    template.conformance_trait_name,
                    template.conformance_trait_args,
                    [TypedExpr]Option.None(),
                    [[Symbol]List]Option.None(),
                    [Type]Option.None(),
                )
                self.storage.instantiation_requests.push(InstantiationRequest(
                    InstantiationKind.ExtensionMethod(
                        template_name,
                        normalized_base,
                        request_template,
                        extension_type_args,
                        method_type_args_ref,
                    ),
                    0,
                    self.storage.file_path,
                ))
            }
        }
    }

    private maybe_record_trait_method_instantiation(self, base_type Type, method_name String, method_type_args [Type]List) Void = {
        let normalized_base = when base_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then base_type,
        }
        if self.contains_generic_parameter(normalized_base) then { return }
        if self.contains_generic_parameter_in_list(method_type_args) then { return }
        self.storage.instantiation_requests.push(InstantiationRequest(
            InstantiationKind.TraitMethod(normalized_base, method_name, self.to_type_ref_list(method_type_args)),
            0,
            self.storage.file_path,
        ))
    }

    private resolve_type(self, node TypeNode) Type = {
        return when node in {
            .Identifier(name) then self.resolve_named_type(name),
            .Reference(inner) then self.resolve_reference_type(self.resolve_type(inner.val)),
            .Pointer(inner) then Type.PointerType(box(self.resolve_type(inner.val))),
            .WeakReference(inner) then Type.WeakReferenceType(box(self.resolve_type(inner.val))),
            .Generic(base, args) then {
                let mut resolved_args = [Type ref]List.new()
                for a in args then {
                    resolved_args.push(box(self.resolve_type(a.val)))
                }
                if self.is_enum_base_name(base) then {
                    return Type.GenericEnum(base, resolved_args)
                }
                return Type.GenericStruct(base, resolved_args)
            },
            .InferredSelf() then Type.Unknown(),
            .FunctionType(param_types, return_type) then {
                let mut resolved_params = [Type ref]List.new()
                for pt in param_types then {
                    resolved_params.push(box(self.resolve_type(pt.val)))
                }
                let resolved_ret = self.resolve_type(return_type.val)
                return Type.FunctionType(resolved_params, box(resolved_ret))
            },
            .ModuleQualified(module_name, name) then self.resolve_module_qualified_type(module_name, name),
            .ModuleQualifiedGeneric(_, base, args) then {
                let mut resolved_args = [Type ref]List.new()
                for a in args then {
                    resolved_args.push(box(self.resolve_type(a.val)))
                }
                if self.is_enum_base_name(base) then {
                    return Type.GenericEnum(base, resolved_args)
                }
                return Type.GenericStruct(base, resolved_args)
            },
        }
    }

    private try_resolve_named_type_in_scope_without_diag(self, name String, scope Scope) [Type]Option = {
        if name == "Self" then {
            return scope.lookup_type("Self")
        }
        if scope.lookup_type(name) is .Some(t) then {
            return [Type]Option.Some(t)
        }
        return self.try_resolve_named_type_without_diag(name)
    }

    private resolve_named_type_in_scope(self, name String, scope Scope) Type = {
        if self.try_resolve_named_type_in_scope_without_diag(name, scope) is .Some(t) then {
            let canonical = self.canonicalize_alias_type(t)
            self.check_type_visibility(canonical, name, scope)
            return canonical
        }
        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Undefined type: \(name)"))
        return Type.Unknown()
    }

    private resolve_type_in_scope(self, node TypeNode, scope Scope) Type = {
        return when node in {
            .Identifier(name) then self.resolve_named_type_in_scope(name, scope),
            .Reference(inner) then self.resolve_reference_type(self.resolve_type_in_scope(inner.val, scope)),
            .Pointer(inner) then Type.PointerType(box(self.resolve_type_in_scope(inner.val, scope))),
            .WeakReference(inner) then Type.WeakReferenceType(box(self.resolve_type_in_scope(inner.val, scope))),
            .Generic(base, args) then {
                let mut resolved_args = [Type ref]List.new()
                for a in args then {
                    resolved_args.push(box(self.resolve_type_in_scope(a.val, scope)))
                }
                if self.is_enum_base_name_in_scope(base, scope) then {
                    return Type.GenericEnum(base, resolved_args)
                }
                return Type.GenericStruct(base, resolved_args)
            },
            .InferredSelf() then {
                if scope.lookup_type("Self") is .Some(t) then {
                    return t
                }
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Undefined type: Self"))
                return Type.Unknown()
            },
            .FunctionType(param_types, return_type) then {
                let mut resolved_params = [Type ref]List.new()
                for pt in param_types then {
                    resolved_params.push(box(self.resolve_type_in_scope(pt.val, scope)))
                }
                let resolved_ret = self.resolve_type_in_scope(return_type.val, scope)
                return Type.FunctionType(resolved_params, box(resolved_ret))
            },
            .ModuleQualified(module_name, name) then self.resolve_module_qualified_type(module_name, name),
            .ModuleQualifiedGeneric(_, base, args) then {
                let mut resolved_args = [Type ref]List.new()
                for a in args then {
                    resolved_args.push(box(self.resolve_type_in_scope(a.val, scope)))
                }
                return when node in {
                    .ModuleQualifiedGeneric(module_name, _, _) then {
                        if not self.is_module_symbol_imported(module_name) then {
                            self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Module '\(module_name)' is not imported"))
                            return Type.Unknown()
                        }

                        let resolved_type = if self.is_enum_base_name_in_scope(base, scope)
                            then Type.GenericEnum(base, resolved_args)
                            else Type.GenericStruct(base, resolved_args)

                        when self.resolve_visible_module_path(module_name) in {
                            .Some(expected_module_path) then {
                                if self.type_module_path(self.canonicalize_alias_type(resolved_type)) is .Some(owner_path) and not string_list_eq(owner_path, expected_module_path) then {
                                    self.storage.diagnostics.push(
                                        make_diagnostic(
                                            DiagnosticStage.Semantic(),
                                            self.storage.file_path,
                                            "Type '\(base)' does not belong to module '\(module_name)'"
                                        )
                                    )
                                    return Type.Unknown()
                                }
                            },
                            .None() then {},
                        }

                        return resolved_type
                    },
                    _ then Type.Unknown(),
                }
            },
        }
    }

    private variable_kind_for_param_type(self, param_type Type, mutable Bool) VariableKind = {
        let is_ref_like = when param_type in {
            .ReferenceType(_) then true,
            .WeakReferenceType(_) then true,
            _ then false,
        }
        if is_ref_like then {
            return if mutable then VariableKind.MutableReference() else VariableKind.Reference()
        }
        return if mutable then VariableKind.MutableValue() else VariableKind.Value()
    }

    private try_resolve_named_type_without_diag(self, name String) [Type]Option = {
        if name == "Int" then { return [Type]Option.Some(Type.IntType()) }
        if name == "Int8" then { return [Type]Option.Some(Type.Int8Type()) }
        if name == "Int16" then { return [Type]Option.Some(Type.Int16Type()) }
        if name == "Int32" then { return [Type]Option.Some(Type.Int32Type()) }
        if name == "Int64" then { return [Type]Option.Some(Type.Int64Type()) }
        if name == "UInt" then { return [Type]Option.Some(Type.UIntType()) }
        if name == "UInt8" then { return [Type]Option.Some(Type.UInt8Type()) }
        if name == "UInt16" then { return [Type]Option.Some(Type.UInt16Type()) }
        if name == "UInt32" then { return [Type]Option.Some(Type.UInt32Type()) }
        if name == "UInt64" then { return [Type]Option.Some(Type.UInt64Type()) }
        if name == "Float32" then { return [Type]Option.Some(Type.Float32Type()) }
        if name == "Float64" then { return [Type]Option.Some(Type.Float64Type()) }
        if name == "Bool" then { return [Type]Option.Some(Type.BoolType()) }
        if name == "Void" then { return [Type]Option.Some(Type.VoidType()) }
        if name == "Never" then { return [Type]Option.Some(Type.NeverType()) }
        if name == "Self" then { return [Type]Option.None() }
        if self.lookup_current_file_type_symbol(name) is .Some(t) then {
            return [Type]Option.Some(self.canonicalize_alias_type(t))
        }
        if self.storage.global_scope.lookup_type(name) is .Some(t) then {
            return [Type]Option.Some(self.canonicalize_alias_type(t))
        }
        // 某些模块加载顺序下，Trait 可能尚未写入 type scope；
        // 回退到 trait registry，避免 given Writer 之类退化为 Unknown。
        if self.storage.trait_registry.get(name) is .Some(_) then {
            return [Type]Option.Some(Type.TraitObject(name))
        }
        return [Type]Option.None()
    }

    protected builtin_string_type(self) Type = {
        return when self.storage.global_scope.lookup_type("String") in {
            .Some(t) then self.canonicalize_alias_type(t),
            .None() then Type.Unknown(),
        }
    }

    protected builtin_rune_type(self) Type = {
        return when self.storage.global_scope.lookup_type("Rune") in {
            .Some(t) then self.canonicalize_alias_type(t),
            .None() then Type.Unknown(),
        }
    }

    private rune_literal_scalar_value(self, value String) String = {
        let bytes = value.to_bytes()
        if bytes.is_empty() then {
            return "0"
        }
        let b0 = (UInt)bytes.at((UInt)0)
        if b0 < (UInt)128 then {
            return b0.to_string()
        }
        if b0 < (UInt)224 and bytes.count() >= (UInt)2 then {
            let b1 = (UInt)bytes.at((UInt)1)
            let cp = ((b0 & (UInt)31) << (UInt)6) | (b1 & (UInt)63)
            return cp.to_string()
        }
        if b0 < (UInt)240 and bytes.count() >= (UInt)3 then {
            let b1 = (UInt)bytes.at((UInt)1)
            let b2 = (UInt)bytes.at((UInt)2)
            let cp = ((b0 & (UInt)15) << (UInt)12) | ((b1 & (UInt)63) << (UInt)6) | (b2 & (UInt)63)
            return cp.to_string()
        }
        if b0 < (UInt)248 and bytes.count() >= (UInt)4 then {
            let b1 = (UInt)bytes.at((UInt)1)
            let b2 = (UInt)bytes.at((UInt)2)
            let b3 = (UInt)bytes.at((UInt)3)
            let cp = ((b0 & (UInt)7) << (UInt)18) | ((b1 & (UInt)63) << (UInt)12) | ((b2 & (UInt)63) << (UInt)6) | (b3 & (UInt)63)
            return cp.to_string()
        }
        return "0"
    }

    private build_rune_constructor_expr(self, scalar_value String, rune_type Type) TypedExpr = {
        return when rune_type in {
            .StructureType(def_id) then {
                let type_name = self.storage.def_id_map.get_name(def_id) or else "Rune"
                let callee = make_typed_expr(
                    TypedExprKind.Variable(box(Symbol(def_id, type_name, rune_type, SymbolKind.TypeSymbol()))),
                    rune_type,
                )
                let mut args = [TypedExpr ref]List.new()
                args.push(box(make_typed_expr(TypedExprKind.IntegerLiteral(scalar_value), Type.UInt32Type())))
                yield make_typed_expr(TypedExprKind.Call(box(callee), args), rune_type)
            },
            _ then make_typed_expr(TypedExprKind.IntegerLiteral(scalar_value), Type.Unknown()),
        }
    }

    protected lower_rune_literal(self, value String, expected [Type]Option) TypedExpr = {
        let scalar_value = self.rune_literal_scalar_value(value)
        when expected in {
            .Some(target_type) then {
                if self.is_integer_type(target_type) then {
                    return make_typed_expr(TypedExprKind.IntegerLiteral(scalar_value), target_type)
                }
                if self.is_rune_type(target_type) then {
                    return self.build_rune_constructor_expr(scalar_value, target_type)
                }
            },
            .None() then {},
        }

        let rune_type = self.builtin_rune_type()
        return when rune_type in {
            .Unknown() then {
                self.storage.diagnostics.push(
                    make_diagnostic(
                        DiagnosticStage.Semantic(),
                        self.storage.file_path,
                        "Rune type not found. Make sure the standard library is imported."
                    )
                )
                yield make_typed_expr(TypedExprKind.IntegerLiteral(scalar_value), Type.Unknown())
            },
            _ then self.build_rune_constructor_expr(scalar_value, rune_type),
        }
    }

    protected lower_rune_literal_for_cast(self, value String, target_type Type) TypedExpr = {
        let scalar_value = self.rune_literal_scalar_value(value)
        if self.is_numeric_type(target_type) or self.is_float_type(target_type) then {
            return make_typed_expr(TypedExprKind.IntegerLiteral(scalar_value), target_type)
        }
        if self.is_rune_type(target_type) then {
            return self.build_rune_constructor_expr(scalar_value, target_type)
        }
        return self.lower_rune_literal(value, [Type]Option.None())
    }

    protected is_string_type(self, t Type) Bool = is_named_structure_type(t, self.storage.def_id_map, "String")

    protected is_rune_type(self, t Type) Bool = is_named_structure_type(t, self.storage.def_id_map, "Rune")

    private type_module_path(self, t Type) [[String]List]Option = {
        return when t in {
            .StructureType(def_id) then self.storage.def_id_map.get_module_path(def_id),
            .EnumType(def_id) then self.storage.def_id_map.get_module_path(def_id),
            .OpaqueType(def_id) then self.storage.def_id_map.get_module_path(def_id),
            .GenericStruct(template, _) then when self.try_resolve_named_type_without_diag(template) in {
                .Some(resolved) then self.type_module_path(self.canonicalize_alias_type(resolved)),
                .None() then [[String]List]Option.None(),
            },
            .GenericEnum(template, _) then when self.try_resolve_named_type_without_diag(template) in {
                .Some(resolved) then self.type_module_path(self.canonicalize_alias_type(resolved)),
                .None() then [[String]List]Option.None(),
            },
            _ then [[String]List]Option.None(),
        }
    }

    private resolve_visible_module_path(self, module_name String) [[String]List]Option = {
        if module_name == "Std" then {
            let mut path = [String]List.new()
            path.push("Std")
            return [[String]List]Option.Some(path)
        }

        return when self.storage.import_graph in {
            .Some(graph) then {
                let current_module = self.storage.module_path
                let current_file = [String]Option.Some(self.storage.file_path)

                let mut alias_idx Int = (Int)graph.module_aliases.count()
                while alias_idx > 0 then {
                    alias_idx -= 1
                    let entry = graph.module_aliases.at((UInt)alias_idx)
                    if string_list_eq(entry.module, current_module) and
                       source_file_matches(entry.source_file, current_file) and
                       entry.alias == module_name then {
                        return [[String]List]Option.Some(entry.target)
                    }
                }

                for si in graph.symbol_imports then {
                    if string_list_eq(si.module, current_module) and
                       source_file_matches(si.source_file, current_file) and
                       si.symbol == module_name then {
                        return [[String]List]Option.Some(si.target)
                    }
                }

                for edge in graph.edges then {
                    if string_list_eq(edge.source, current_module) and
                       source_file_matches(edge.source_file, current_file) and
                       edge.target.count() > (UInt)0 and
                       edge.target.at(edge.target.count() - (UInt)1) == module_name then {
                        return [[String]List]Option.Some(edge.target)
                    }
                }

                return [[String]List]Option.None()
            },
            .None() then [[String]List]Option.None(),
        }
    }

    private resolve_module_qualified_type(self, module_name String, type_name String) Type = {
        if not self.is_module_symbol_imported(module_name) then {
            self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Module '\(module_name)' is not imported"))
            return Type.Unknown()
        }

        let resolved = when self.try_resolve_named_type_without_diag(type_name) in {
            .Some(t) then t,
            .None() then {
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Undefined type: \(type_name)"))
                return Type.Unknown()
            },
        }

        when self.resolve_visible_module_path(module_name) in {
            .Some(expected_module_path) then {
                if self.type_module_path(resolved) is .Some(owner_path) and not string_list_eq(owner_path, expected_module_path) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "Type '\(type_name)' does not belong to module '\(module_name)'"
                        )
                    )
                    return Type.Unknown()
                }
            },
            .None() then {},
        }

        return resolved
    }

    private resolve_named_type(self, name String) Type = {
        if self.try_resolve_named_type_without_diag(name) is .Some(t) then {
            let scope = Scope.new_root()
            let canonical = self.canonicalize_alias_type(t)
            self.check_type_visibility(canonical, name, scope)
            return canonical
        }
        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Undefined type: \(name)"))
        return Type.Unknown()
    }

    private check_decl(self, decl Decl) TypedDecl = {
        return when decl in {
            .LetDecl(access, name, mutable, type_name, initializer, span) then {
                let resolved = self.resolve_type(type_name)
                if resolved is .TraitObject(_) then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "use trait as type"))
                }
                let typed_init = self.check_expr_global_ref(initializer, .Some(resolved))
                yield TypedDecl.LetDecl(access, name, mutable, resolved, box(typed_init), span)
            },
            .FunctionDecl(access, name, type_params, params, return_type, body, span) then {
                self.sema_debug("check_decl function start: \(name) file=\(self.storage.file_path)")
                let prev_in_function = self.storage.in_function
                let prev_current_function_return_type = self.storage.current_function_return_type
                let prev_in_loop = self.storage.in_loop
                let prev_in_finally = self.storage.in_finally
                self.storage.in_function = true
                self.storage.in_loop = false
                self.storage.in_finally = false
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                let result = if type_params.is_empty() then {
                    let resolved_ret = self.resolve_type(return_type)
                    self.storage.current_function_return_type = [Type]Option.Some(resolved_ret)
                    let typed_params = self.check_params(params)
                    let mut fn_scope = self.make_fn_scope(typed_params)
                    let typed_body = self.check_expr_scoped_ref(body, .Some(resolved_ret), fn_scope)
                    yield TypedDecl.FunctionDecl(access, name, typed_params, resolved_ret, box(typed_body), span)
                } else {
                    let mut generic_type_scope = Scope.new_root()
                    for tp in type_params then {
                        generic_type_scope.define_type(tp.name, Type.GenericParameter(tp.name))
                    }
                    let typed_params = self.check_params_in_scope(params, generic_type_scope)
                    let resolved_ret = self.resolve_type_in_scope(return_type, generic_type_scope)
                    self.storage.current_function_return_type = [Type]Option.Some(resolved_ret)
                    let mut fn_scope = self.make_generic_fn_scope(typed_params, type_params)
                    let typed_body = self.check_expr_scoped_ref(body, .Some(resolved_ret), fn_scope)
                    self.register_generic_function_template(
                        name,
                        type_params,
                        params,
                        return_type,
                        [TypedExpr]Option.Some(typed_body),
                        [Type]Option.Some(resolved_ret),
                    )
                    yield TypedDecl.GenericFunctionDecl(access, name, typed_params, resolved_ret, box(typed_body), span)
                }
                self.storage.in_function = prev_in_function
                self.storage.current_function_return_type = prev_current_function_return_type
                self.storage.in_loop = prev_in_loop
                self.storage.in_finally = prev_in_finally
                self.restore_type_bindings(type_binding_snapshot)
                self.sema_debug("check_decl function done: \(name) file=\(self.storage.file_path)")
                yield result
            },
            .IntrinsicFunctionDecl(access, name, type_params, params, return_type, span) then {
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                let resolved_ret = self.resolve_type(return_type)
                let typed_params = self.check_params(params)
                self.restore_type_bindings(type_binding_snapshot)
                yield TypedDecl.IntrinsicFunctionDecl(access, name, typed_params, resolved_ret, span)
            },
            .ForeignFunctionDecl(access, name, params, return_type, span) then {
                let resolved_ret = self.resolve_type(return_type)
                let typed_params = self.check_params(params)
                if not self.is_ffi_compatible_type(resolved_ret) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "FFI incompatible type '\(self.storage.def_id_map.type_display_name(resolved_ret))': \(self.ffi_type_error(resolved_ret))"
                        )
                    )
                }
                for p in typed_params then {
                    if not self.is_ffi_compatible_type(p.param_type) then {
                        self.storage.diagnostics.push(
                            make_diagnostic(
                                DiagnosticStage.Semantic(),
                                self.storage.file_path,
                                "FFI incompatible type '\(self.storage.def_id_map.type_display_name(p.param_type))': \(self.ffi_type_error(p.param_type))"
                            )
                        )
                    }
                }
                yield TypedDecl.ForeignFunctionDecl(access, name, typed_params, resolved_ret, span)
            },
            .ForeignLetDecl(access, name, mutable, type_name, span) then {
                let resolved = self.resolve_type(type_name)
                if not self.is_ffi_compatible_type(resolved) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "FFI incompatible type '\(self.storage.def_id_map.type_display_name(resolved))': \(self.ffi_type_error(resolved))"
                        )
                    )
                }
                yield TypedDecl.ForeignLetDecl(access, name, mutable, resolved, span)
            },
            .TypeStructDecl(access, name, type_params, fields, span) then {
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                let typed_fields = self.check_fields(fields)
                self.restore_type_bindings(type_binding_snapshot)
                yield if type_params.is_empty() then TypedDecl.TypeStructDecl(access, name, typed_fields, span)
                else TypedDecl.GenericTypeStructDecl(access, name, typed_fields, span)
            },
            .TypeEnumDecl(access, name, type_params, cases, span) then {
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                let typed_cases = self.check_enum_cases(cases)
                self.restore_type_bindings(type_binding_snapshot)
                yield if type_params.is_empty() then TypedDecl.TypeEnumDecl(access, name, typed_cases, span)
                else TypedDecl.GenericTypeEnumDecl(access, name, typed_cases, span)
            },
            .TypeAliasDecl(access, name, target, span) then {
                let self_referential_target = when target in {
                    .Identifier(target_name) then target_name == name,
                    .Generic(base, _) then base == name,
                    .ModuleQualified(_, target_name) then target_name == name,
                    .ModuleQualifiedGeneric(_, base, _) then base == name,
                    _ then false,
                }
                let mut resolved_target = self.resolve_type(target)
                if self_referential_target then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Undefined type: \(name)"))
                    resolved_target = Type.Unknown()
                }
                self.storage.global_scope.define_type(name, resolved_target)
                yield TypedDecl.TypeAliasDecl(access, name, resolved_target, span)
            },
            .IntrinsicTypeDecl(access, name, type_params, span) then {
                yield TypedDecl.IntrinsicTypeDecl(access, name, span)
            },
            .ForeignTypeDecl(access, name, cname, fields, span) then {
                let typed_fields = when fields in {
                    .Some(raw_fields) then {
                        let mut out = [TypedField]List.new()
                        for f in raw_fields then {
                            out.push(TypedField(f.access, f.name, true, self.resolve_type(f.type_name), f.named))
                        }
                        yield [[TypedField]List]Option.Some(out)
                    },
                    .None() then [[TypedField]List]Option.None(),
                }
                yield TypedDecl.ForeignTypeDecl(access, name, typed_fields, span)
            },
            .PathUsingDecl(access, path_segments, imported_symbol, is_batch, alias, span) then {
                yield TypedDecl.UsingDecl(access, path_segments, span)
            },
            .ParentUsingDecl(access, path_segments, imported_symbol, is_batch, alias, span) then {
                yield TypedDecl.UsingDecl(access, path_segments, span)
            },
            .FileUsingDecl(access, file_name, alias, span) then {
                let mut path_segments = [String]List.new()
                path_segments.push(file_name)
                yield TypedDecl.UsingDecl(access, path_segments, span)
            },
            .ForeignUsingDecl(access, library, span) then {
                yield TypedDecl.ForeignUsingDecl(access, library, span)
            },
            .TraitDecl(access, name, type_params, parents, members, span) then {
                let type_binding_snapshot = self.snapshot_type_bindings()
                for tp in type_params then {
                    self.bind_type_param(tp)
                }
                self.validate_trait_parent_type_arguments(parents)
                self.restore_type_bindings(type_binding_snapshot)
                // 注册 Trait 到 TraitRegistry
                let mut parent_names = [String]List.new()
                for p in parents then {
                    parent_names.push(self.type_node_name(p))
                }
                let mut param_names = [String]List.new()
                for tp in type_params then {
                    param_names.push(tp.name)
                }
                let typed_members = self.check_trait_members(members, type_params)
                let info = TraitInfo(name, param_names, parent_names, typed_members, self.storage.module_path)
                self.storage.trait_registry.register(info)
                self.storage.generic_templates.traits.insert(
                    name,
                    TraitDeclInfo(name, self.to_template_type_params(type_params), parent_names, members, typed_members, self.storage.module_path)
                )
                yield TypedDecl.TraitDecl(access, name, typed_members, span)
            },
            .GivenDecl(target_type, type_params, members, span) then {
                yield if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params)
                then TypedDecl.GivenDecl(Type.Unknown(), [TypedGivenMember]List.new(), span)
                else {
                    let type_binding_snapshot = self.snapshot_type_bindings()
                    for tp in type_params then {
                        self.bind_type_param(tp)
                    }
                    let resolved_target = self.resolve_type(target_type)
                    // Given locality check: target type must be in current module
                    let locality_checker = GivenLocalityChecker.new(
                        self.storage.def_id_map.ref,
                        self.storage.trait_registry.ref,
                        self.storage.module_path,
                        self.storage.generic_templates.ref,
                        self.storage.global_scope.ref,
                    )
                    if locality_checker.check_given_owner_locality(resolved_target) is .Some(msg) then {
                        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, msg))
                    }
                    let typed_members = self.check_given_members_for_type(members, resolved_target, type_params, [String]Option.None())
                    self.restore_type_bindings(type_binding_snapshot)
                    yield TypedDecl.GivenDecl(resolved_target, typed_members, span)
                }
            },
            .GivenTraitDecl(target_type, type_params, trait_type, members, span) then {
                yield if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params)
                then TypedDecl.GivenTraitDecl(Type.Unknown(), self.type_node_name(trait_type), [Type]List.new(), [TypedGivenMember]List.new(), span)
                else {
                    let type_binding_snapshot = self.snapshot_type_bindings()
                    for tp in type_params then {
                        self.bind_type_param(tp)
                    }
                    let resolved_target = self.resolve_type(target_type)
                    let trait_name = self.type_node_name(trait_type)
                    self.record_explicit_trait_conformance(resolved_target, trait_name)
                    self.maybe_record_iterator_conformance(resolved_target, trait_type)
                    // Given conformance locality check (orphan rule)
                    let locality_checker = GivenLocalityChecker.new(
                        self.storage.def_id_map.ref,
                        self.storage.trait_registry.ref,
                        self.storage.module_path,
                        self.storage.generic_templates.ref,
                        self.storage.global_scope.ref,
                    )
                    if locality_checker.check_given_conformance_locality(resolved_target, trait_name) is .Some(msg) then {
                        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, msg))
                    }
                    // 注入 trait 类型参数：如 given Duration [Int]Scale，把 Scale 的 Scalar 绑定为 Int
                    let resolved_trait_args = self.trait_type_args(trait_type)
                    self.inject_trait_type_args(trait_type, trait_name)
                    let typed_members = self.check_given_members_for_type(members, resolved_target, type_params, [String]Option.Some(trait_name))
                    // 检查 Trait 一致性
                    let checker = TraitChecker.new(
                        self.storage.trait_registry.ref,
                        self.storage.method_table.ref,
                        self.storage.def_id_map.ref
                    )
                    when self.storage.trait_registry.get(trait_name) in {
                        .Some(info) then {
                            for parent in info.parent_traits then {
                                if not self.has_explicit_trait_conformance(resolved_target, parent) then {
                                    self.storage.diagnostics.push(make_diagnostic(
                                        DiagnosticStage.Semantic(),
                                        self.storage.file_path,
                                        "Parent trait '\(parent)' must be explicitly implemented for child trait '\(trait_name)'"
                                    ))
                                }
                            }
                        },
                        .None() then {},
                    }
                    if checker.check_conformance(resolved_target, trait_name, typed_members, span) is .Error(e) then {
                        self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, e.message()))
                    }
                    self.register_trait_tool_templates_for_concrete_type(resolved_target, type_params, trait_name, typed_members)
                    self.restore_type_bindings(type_binding_snapshot)
                    yield TypedDecl.GivenTraitDecl(resolved_target, trait_name, resolved_trait_args, typed_members, span)
                }
            },
            .IntrinsicGivenDecl(target_type, type_params, members, span) then {
                yield if self.reject_concrete_type_modifier_given_if_needed(target_type, type_params)
                then TypedDecl.IntrinsicGivenDecl(Type.Unknown(), [TypedGivenMember]List.new(), span)
                else {
                    let type_binding_snapshot = self.snapshot_type_bindings()
                    for tp in type_params then {
                        self.bind_type_param(tp)
                    }
                    let resolved_target = self.resolve_type(target_type)
                    let typed_members = self.check_given_members_for_type(members, resolved_target, type_params, [String]Option.None())
                    self.restore_type_bindings(type_binding_snapshot)
                    yield TypedDecl.IntrinsicGivenDecl(resolved_target, typed_members, span)
                }
            },
        }
    }

    private type_node_name(self, node TypeNode) String = {
        return when node in {
            .Identifier(name) then name,
            .Generic(base, _) then base,
            .ModuleQualified(_, name) then name,
            _ then "?",
        }
    }

    private concrete_type_modifier_given_message(self) String = {
        return "Concrete type modifier given declarations are not allowed. Use generic form instead, e.g., 'given [T SomeTrait] T ref SomeTrait { ... }'"
    }

    private is_concrete_type_modifier_given_target(self, target_type TypeNode, type_params [TypeParameter]List) Bool = {
        if not type_params.is_empty() then {
            return false
        }
        return when target_type in {
            .Reference(_) then true,
            .Pointer(_) then true,
            .WeakReference(_) then true,
            _ then false,
        }
    }

    private reject_concrete_type_modifier_given_if_needed(self, target_type TypeNode, type_params [TypeParameter]List) Bool = {
        if self.is_concrete_type_modifier_given_target(target_type, type_params) then {
            self.storage.diagnostics.push(
                make_diagnostic(
                    DiagnosticStage.Semantic(),
                    self.storage.file_path,
                    self.concrete_type_modifier_given_message()
                )
            )
            return true
        }
        return false
    }

    private validate_trait_parent_arity(self, trait_name String, actual_count UInt) Void = {
        if actual_count == (UInt)0 then {
            return
        }
        when self.storage.trait_registry.get(trait_name) in {
            .Some(info) then {
                let expected_count = info.type_params.count()
                if expected_count <> actual_count then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "Type mismatch: expected \(expected_count) generic arguments, got \(actual_count)"
                        )
                    )
                }
            },
            .None() then {},
        }
    }

    private validate_trait_parent_type_arguments(self, parents [TypeNode]List) Void = {
        for parent in parents then {
            when parent in {
                .Identifier(name) then {
                    self.validate_trait_parent_arity(name, (UInt)0)
                },
                .ModuleQualified(_, name) then {
                    self.validate_trait_parent_arity(name, (UInt)0)
                },
                .Generic(base, args) then {
                    self.validate_trait_parent_arity(base, args.count())
                    for arg in args then {
                        let _ = self.resolve_type(arg.val)
                    }
                },
                .ModuleQualifiedGeneric(_, base, args) then {
                    self.validate_trait_parent_arity(base, args.count())
                    for arg in args then {
                        let _ = self.resolve_type(arg.val)
                    }
                },
                _ then {},
            }
        }
    }

    private is_upper_first_char(self, s String) Bool = {
        if s.is_empty() then { return false }
        when s.get(0) in {
            .Some(c) then { return c >= 'A' and c <= 'Z' },
            .None() then { return false },
        }
    }

    private make_visibility_checker(self) [VisibilityChecker]Option = {
        return when self.storage.import_graph in {
            .Some(graph) then [VisibilityChecker]Option.Some(VisibilityChecker.new(box(graph), self.storage.module_path, self.storage.file_path)),
            .None() then [VisibilityChecker]Option.None(),
        }
    }

    protected check_type_visibility(self, t Type, type_name String, scope Scope) Void = {
        if self.make_visibility_checker() is .Some(checker) then {
            let is_local_binding = if scope.lookup_type(type_name) is .Some(_) then true else false
            let is_generic_param = scope.is_generic_param(type_name)
            when checker.check_type(t, type_name, self.storage.def_id_map, is_local_binding, is_generic_param) in {
                .Ok(_) then {},
                .Error(message) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, message.message())
                    )
                },
            }
        }
    }

    protected check_symbol_visibility(self, sym Symbol) Void = {
        if self.make_visibility_checker() is .Some(checker) and self.storage.def_id_map.get_module_path(sym.def_id) is .Some(module_path) then {
            when checker.check_symbol(module_path, sym.name, false) in {
                .Ok(_) then {},
                .Error(message) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, message.message())
                    )
                },
            }
        }
    }

    protected is_field_accessible_from_current_context(self, field_access AccessModifier, def_id DefId) Bool = {
        return when field_access in {
            .Public() then true,
            .Private() then {
                let def_source_file = self.storage.def_id_map.get_source_file(def_id) or else ""
                yield def_source_file == self.storage.file_path
            },
            .Protected() then {
                let def_module_path = self.storage.def_id_map.get_module_path(def_id) or else [String]List.new()
                if string_list_eq(def_module_path, self.storage.module_path) then {
                    return true
                }
                if self.storage.module_path.count() > def_module_path.count() then {
                    let mut matches_prefix = true
                    let mut i UInt = 0
                    while i < def_module_path.count() then {
                        if self.storage.module_path.at(i) <> def_module_path.at(i) then {
                            matches_prefix = false
                            break
                        }
                        i += 1
                    }
                    if matches_prefix then {
                        return true
                    }
                }
                yield false
            },
        }
    }

    protected ensure_struct_construction_access(self, type_name String, def_id DefId) Void = {
        when self.storage.def_id_map.get_struct_fields(def_id) in {
            .Some(fields) then {
                for field in fields then {
                    if not self.is_field_accessible_from_current_context(field.access, def_id) then {
                        let access_label = when field.access in {
                            .Private() then "private",
                            _ then "protected",
                        }
                        self.storage.diagnostics.push(
                            make_diagnostic(
                                DiagnosticStage.Semantic(),
                                self.storage.file_path,
                                "Cannot directly construct type '\(type_name)' because field '\(field.name)' is \(access_label). Use a public factory method instead."
                            )
                        )
                        return
                    }
                }
            },
            .None() then {},
        }
    }

    protected module_root_exists(self, module_name String) Bool = {
        if module_name == "Std" then {
            return true
        }

        if self.storage.known_root_modules.contains(module_name) then {
            return true
        }

        return when self.storage.import_graph in {
            .Some(graph) then {
                for edge in graph.edges then {
                    if edge.target.count() > (UInt)0 and edge.target.at((UInt)0) == module_name then {
                        return true
                    }
                    if edge.target.count() > (UInt)1 and edge.target.at((UInt)0) == "Std" and edge.target.at((UInt)1) == module_name then {
                        return true
                    }
                }
                for si in graph.symbol_imports then {
                    if si.symbol == module_name then {
                        return true
                    }
                    if si.target.count() > (UInt)1 and si.target.at((UInt)0) == "Std" and si.target.at((UInt)1) == module_name then {
                        return true
                    }
                }
                for ma in graph.module_aliases then {
                    if ma.alias == module_name then {
                        return true
                    }
                    if ma.target.count() > (UInt)1 and ma.target.at((UInt)0) == "Std" and ma.target.at((UInt)1) == module_name then {
                        return true
                    }
                }
                return false
            },
            .None() then false,
        }
    }

    protected def_id_is_in_std_module(self, def_id DefId) Bool = {
        return when self.storage.def_id_map.get_module_path(def_id) in {
            .Some(module_path) then module_path.count() > (UInt)0 and module_path.at((UInt)0) == "Std",
            .None() then false,
        }
    }

    protected is_module_symbol_imported(self, module_name String) Bool = {
        if module_name == "Std" then {
            return true
        }

        if self.storage.module_path.count() > (UInt)0 and self.storage.module_path.at((UInt)0) == module_name then {
            return true
        }

        if self.resolve_visible_module_path(module_name) is .Some(_) then {
            return true
        }

        return when self.storage.import_graph in {
            .Some(graph) then {
                let current_module = self.storage.module_path
                let current_file = [String]Option.Some(self.storage.file_path)

                let mut target_path = [String]List.new()
                target_path.push(module_name)
                let mut std_submodule_path = [String]List.new()
                std_submodule_path.push("Std")
                std_submodule_path.push(module_name)

                for edge in graph.edges then {
                    if string_list_eq(edge.source, current_module) and
                       source_file_matches(edge.source_file, current_file) and
                       (string_list_eq(edge.target, target_path) or string_list_eq(edge.target, std_submodule_path)) then {
                        return true
                    }
                }

                for si in graph.symbol_imports then {
                    if string_list_eq(si.module, current_module) and
                       source_file_matches(si.source_file, current_file) and
                       si.symbol == module_name then {
                        return true
                    }
                }

                for ma in graph.module_aliases then {
                    if string_list_eq(ma.module, current_module) and
                       source_file_matches(ma.source_file, current_file) and
                       ma.alias == module_name then {
                        return true
                    }
                }

                return false
            },
            .None() then false,
        }
    }

    protected lookup_current_file_def_id(self, name String) [DefId]Option = {
        return self.storage.def_id_map.lookup(self.storage.module_path, name, [String]Option.Some(self.storage.file_path))
    }

    protected lookup_current_file_symbol(self, name String) [Symbol]Option = {
        return when self.lookup_current_file_def_id(name) in {
            .Some(def_id) then self.symbol_for_def_id(def_id),
            .None() then [Symbol]Option.None(),
        }
    }

    protected lookup_current_file_type_symbol(self, name String) [Type]Option = {
        return when self.lookup_current_file_def_id(name) in {
            .Some(def_id) then when self.storage.def_id_map.get_kind(def_id) in {
                .Some(kind) then when kind in {
                    .TypeDef(type_kind) then when type_kind in {
                        .Structure() then [Type]Option.Some(Type.StructureType(def_id)),
                        .Enum() then [Type]Option.Some(Type.EnumType(def_id)),
                        .Opaque() then [Type]Option.Some(Type.OpaqueType(def_id)),
                        .Trait() then {
                            let trait_name = self.storage.def_id_map.get_name(def_id) or else name
                            yield [Type]Option.Some(Type.TraitObject(trait_name))
                        },
                    },
                    .GenericTemplate(template_kind) then when template_kind in {
                        .Structure() then [Type]Option.Some(Type.StructureType(def_id)),
                        .Enum() then [Type]Option.Some(Type.EnumType(def_id)),
                        _ then [Type]Option.None(),
                    },
                    _ then [Type]Option.None(),
                },
                .None() then [Type]Option.None(),
            },
            .None() then [Type]Option.None(),
        }
    }

    protected symbol_for_def_id(self, def_id DefId) [Symbol]Option = {
        return when self.storage.def_id_map.get_name(def_id) in {
            .Some(name) then {
                let kind_opt = self.storage.def_id_map.get_kind(def_id)
                let symbol_type = when self.storage.def_id_map.get_symbol_type(def_id) in {
                    .Some(t) then t,
                    .None() then when kind_opt in {
                        .Some(kind) then when kind in {
                            .TypeDef(type_kind) then when type_kind in {
                                .Structure() then Type.StructureType(def_id),
                                .Enum() then Type.EnumType(def_id),
                                .Opaque() then Type.OpaqueType(def_id),
                                .Trait() then Type.TraitObject(name),
                            },
                            .GenericTemplate(template_kind) then when template_kind in {
                                .Structure() then Type.StructureType(def_id),
                                .Enum() then Type.EnumType(def_id),
                                _ then Type.Unknown(),
                            },
                            _ then Type.Unknown(),
                        },
                        .None() then Type.Unknown(),
                    },
                }
                let symbol_kind = when self.storage.def_id_map.get_symbol_kind(def_id) in {
                    .Some(kind) then kind,
                    .None() then when kind_opt in {
                        .Some(kind) then when kind in {
                            .Function() then SymbolKind.Function(),
                            .Variable() then SymbolKind.Variable(VariableKind.Value()),
                            .TypeDef(_) then SymbolKind.TypeSymbol(),
                            .GenericTemplate(template_kind) then when template_kind in {
                                .Function() then SymbolKind.Function(),
                                _ then SymbolKind.TypeSymbol(),
                            },
                            _ then SymbolKind.Variable(VariableKind.Value()),
                        },
                        .None() then SymbolKind.Variable(VariableKind.Value()),
                    },
                }
                yield [Symbol]Option.Some(Symbol(def_id, name, symbol_type, symbol_kind))
            },
            .None() then [Symbol]Option.None(),
        }
    }

    protected lookup_visible_module_member_symbol(self, module_name String, member_name String) [Symbol]Option = {
        let resolved_by_imports = when self.resolve_visible_module_path(module_name) in {
            .Some(module_path) then when self.storage.def_id_map.lookup(module_path, member_name, [String]Option.None()) in {
                .Some(def_id) then self.symbol_for_def_id(def_id),
                .None() then [Symbol]Option.None(),
            },
            .None() then [Symbol]Option.None(),
        }
        if resolved_by_imports is .Some(sym) then { return resolved_by_imports }

        let mut local_child_path = self.storage.module_path
        local_child_path.push(module_name)
        return when self.storage.def_id_map.lookup(local_child_path, member_name, [String]Option.None()) in {
            .Some(def_id) then self.symbol_for_def_id(def_id),
            .None() then [Symbol]Option.None(),
        }
    }

    private trait_conformance_key(self, target_type Type, trait_name String) String = {
        let type_key = self.storage.def_id_map.type_display_name(self.canonicalize_alias_type(target_type))
        return "\(type_key)::\(trait_name)"
    }

    private record_explicit_trait_conformance(self, target_type Type, trait_name String) Void = {
        self.storage.explicit_trait_conformances.insert(self.trait_conformance_key(target_type, trait_name))
    }

    private primitive_scalar_satisfies_std_trait(self, target_type Type, trait_name String) Bool = {
        let is_eq_or_ord = trait_name == "Eq" or trait_name == "Ord"
        let is_to_string = trait_name == "ToString"
        let is_hash = trait_name == "Hash"
        return when target_type in {
            .BoolType() then is_eq_or_ord or is_to_string or is_hash,
            .IntType() then is_eq_or_ord or is_to_string or is_hash,
            .Int8Type() then is_eq_or_ord or is_to_string or is_hash,
            .Int16Type() then is_eq_or_ord or is_to_string or is_hash,
            .Int32Type() then is_eq_or_ord or is_to_string or is_hash,
            .Int64Type() then is_eq_or_ord or is_to_string or is_hash,
            .UIntType() then is_eq_or_ord or is_to_string or is_hash,
            .UInt8Type() then is_eq_or_ord or is_to_string or is_hash,
            .UInt16Type() then is_eq_or_ord or is_to_string or is_hash,
            .UInt32Type() then is_eq_or_ord or is_to_string or is_hash,
            .UInt64Type() then is_eq_or_ord or is_to_string or is_hash,
            .Float32Type() then is_eq_or_ord or is_to_string,
            .Float64Type() then is_eq_or_ord or is_to_string,
            _ then false,
        }
    }

    private is_implicitly_satisfied_trait_requirement(self, target_type Type, trait_name String) Bool = {
        if trait_name == "Any" then {
            return true
        }
        if trait_name == "Deref" then {
            return when target_type in {
                .TraitObject(_) then false,
                .OpaqueType(_) then false,
                _ then true,
            }
        }
        if self.primitive_scalar_satisfies_std_trait(target_type, trait_name) then {
            return true
        }
        return false
    }

    private satisfies_trait_requirement(self, target_type Type, trait_name String) Bool = {
        if self.is_implicitly_satisfied_trait_requirement(target_type, trait_name) then {
            return true
        }
        if self.has_explicit_trait_conformance(target_type, trait_name) then {
            return true
        }
        let empty_trait_args = [Type]List.new()
        return when self.generic_trait_conformance_status(target_type, trait_name, empty_trait_args) in {
            .Satisfied() then true,
            _ then false,
        }
    }

    private has_explicit_trait_conformance(self, target_type Type, trait_name String) Bool = {
        if self.is_implicitly_satisfied_trait_requirement(target_type, trait_name) then {
            return true
        }
        return self.storage.explicit_trait_conformances.contains(self.trait_conformance_key(target_type, trait_name))
    }

    private trait_type_args(self, trait_type TypeNode) [Type]List = {
        return when trait_type in {
            .Generic(_, trait_args) then {
                let mut out = [Type]List.new()
                for arg in trait_args then {
                    out.push(self.resolve_type(arg.val))
                }
                yield out
            },
            .ModuleQualifiedGeneric(_, _, trait_args) then {
                let mut out = [Type]List.new()
                for arg in trait_args then {
                    out.push(self.resolve_type(arg.val))
                }
                yield out
            },
            _ then [Type]List.new(),
        }
    }

    private record_generic_trait_conformance_template(self, target_type Type, owner_type_params [TypeParameter]List, trait_type TypeNode, trait_name String) Void = {
        self.storage.generic_trait_conformance_templates.push(
            GenericTraitConformanceTemplate(
                target_type,
                self.to_template_type_params(owner_type_params),
                trait_name,
                self.trait_type_args(trait_type),
            )
        )
    }

    private conformance_type_key_matches(self, pattern Type, actual Type, bindings [String, Type]Dict ref) Bool = {
        return when pattern in {
            .GenericParameter(name) then {
                return when bindings.get(name) in {
                    .Some(bound) then self.same_expr_type(bound, actual),
                    .None() then {
                        bindings.insert(name, actual)
                        yield true
                    },
                }
            },
            .ReferenceType(p_inner) then when actual in {
                .ReferenceType(a_inner) then self.conformance_type_key_matches(p_inner.val, a_inner.val, bindings),
                _ then false,
            },
            .WeakReferenceType(p_inner) then when actual in {
                .WeakReferenceType(a_inner) then self.conformance_type_key_matches(p_inner.val, a_inner.val, bindings),
                _ then false,
            },
            .PointerType(p_inner) then when actual in {
                .PointerType(a_inner) then self.conformance_type_key_matches(p_inner.val, a_inner.val, bindings),
                _ then false,
            },
            .GenericStruct(template, p_args) then when actual in {
                .GenericStruct(actual_template, a_args) then {
                    if not (template == actual_template and p_args.count() == a_args.count()) then {
                        return false
                    }
                    let mut i UInt = 0
                    while i < p_args.count() then {
                        if not self.conformance_type_key_matches(p_args.at(i).val, a_args.at(i).val, bindings) then {
                            return false
                        }
                        i += 1
                    }
                    return true
                },
                .StructureType(def_id) then {
                    let actual_template = self.storage.def_id_map.get_template_name(def_id) or else {
                        return false
                    }
                    let actual_args = self.storage.def_id_map.get_type_arguments(def_id) or else {
                        return false
                    }
                    if not (template == actual_template and p_args.count() == actual_args.count()) then {
                        return false
                    }
                    let mut i UInt = 0
                    while i < p_args.count() then {
                        if not self.conformance_type_key_matches(p_args.at(i).val, actual_args.at(i), bindings) then {
                            return false
                        }
                        i += 1
                    }
                    return true
                },
                _ then false,
            },
            .GenericEnum(template, p_args) then when actual in {
                .GenericEnum(actual_template, a_args) then {
                    if not (template == actual_template and p_args.count() == a_args.count()) then {
                        return false
                    }
                    let mut i UInt = 0
                    while i < p_args.count() then {
                        if not self.conformance_type_key_matches(p_args.at(i).val, a_args.at(i).val, bindings) then {
                            return false
                        }
                        i += 1
                    }
                    return true
                },
                .EnumType(def_id) then {
                    let actual_template = self.storage.def_id_map.get_template_name(def_id) or else {
                        return false
                    }
                    let actual_args = self.storage.def_id_map.get_type_arguments(def_id) or else {
                        return false
                    }
                    if not (template == actual_template and p_args.count() == actual_args.count()) then {
                        return false
                    }
                    let mut i UInt = 0
                    while i < p_args.count() then {
                        if not self.conformance_type_key_matches(p_args.at(i).val, actual_args.at(i), bindings) then {
                            return false
                        }
                        i += 1
                    }
                    return true
                },
                _ then false,
            },
            _ then self.same_expr_type(pattern, actual),
        }
    }

    private generic_trait_conformance_status(self, target_type Type, trait_name String, trait_args [Type]List) GenericTraitConformanceStatus = {
        let mut matched_template = false
        for template in self.storage.generic_trait_conformance_templates then {
            if not (template.trait_name == trait_name) then {
                continue
            }
            let mut bindings = [String, Type]Dict.new()
            if not self.conformance_type_key_matches(template.target_type, target_type, bindings) then {
                continue
            }
            if not (template.trait_arg_types.count() == trait_args.count()) then {
                continue
            }
            let mut i UInt = 0
            let mut trait_args_match = true
            while i < trait_args.count() then {
                let expected_arg = self.apply_type_bindings(template.trait_arg_types.at(i), bindings)
                if not self.same_expr_type(expected_arg, trait_args.at(i)) then {
                    trait_args_match = false
                    break
                }
                i += 1
            }
            if not trait_args_match then {
                continue
            }
            matched_template = true
            for tp in template.owner_type_params then {
                if bindings.get(tp.name) is .Some(bound_type) then {
                    for constraint in tp.constraints then {
                        if not self.satisfies_trait_requirement(bound_type, constraint) then {
                            return GenericTraitConformanceStatus.MissingConstraint(bound_type, constraint)
                        }
                    }
                }
            }
            return GenericTraitConformanceStatus.Satisfied()
        }
        if matched_template then {
            return GenericTraitConformanceStatus.MissingConformance()
        }
        return GenericTraitConformanceStatus.MissingConformance()
    }

    protected enforce_explicit_generic_trait_conformance(self, target_type Type, trait_name String, trait_args [Type]List) Bool = {
        return when self.generic_trait_conformance_status(target_type, trait_name, trait_args) in {
            .Satisfied() then true,
            .MissingConstraint(bound_type, constraint) then {
                self.storage.diagnostics.push(
                    make_diagnostic(
                        DiagnosticStage.Semantic(),
                        self.storage.file_path,
                        "Type \(self.storage.def_id_map.type_display_name(bound_type)) does not explicitly implement trait \(constraint)"
                    )
                )
                yield false
            },
            .MissingConformance() then {
                let mut args_display = String.new()
                let mut first = true
                for arg in trait_args then {
                    if not first then { args_display.push_string(", ") }
                    args_display.push_string(type_to_string(arg))
                    first = false
                }
                let message = if trait_args.is_empty()
                    then "Type \(self.storage.def_id_map.type_display_name(target_type)) does not explicitly implement trait \(trait_name)"
                    else "Type \(self.storage.def_id_map.type_display_name(target_type)) does not explicitly implement trait [\(args_display)]\(trait_name)"
                self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, message))
                yield false
            },
        }
    }

    protected enforce_explicit_trait_requirement(self, target_type Type, trait_name String) Bool = {
        when target_type in {
            .Unknown() then { return true },
            .TypeVar(_) then { return true },
            .GenericParameter(_) then { return true },
            _ then {},
        }

        if self.has_explicit_trait_conformance(target_type, trait_name) then {
            return true
        }

        let empty_trait_args = [Type]List.new()
        return when self.generic_trait_conformance_status(target_type, trait_name, empty_trait_args) in {
            .Satisfied() then true,
            .MissingConstraint(bound_type, constraint) then {
                self.storage.diagnostics.push(
                    make_diagnostic(
                        DiagnosticStage.Semantic(),
                        self.storage.file_path,
                        "Type '\(self.storage.def_id_map.type_display_name(target_type))' does not satisfy trait '\(trait_name)' because inner type '\(self.storage.def_id_map.type_display_name(bound_type))' does not implement '\(constraint)'"
                    )
                )
                yield false
            },
            .MissingConformance() then {
                self.storage.diagnostics.push(
                    make_diagnostic(
                        DiagnosticStage.Semantic(),
                        self.storage.file_path,
                        "Type \(self.storage.def_id_map.type_display_name(target_type)) does not explicitly implement trait \(trait_name)"
                    )
                )
                yield false
            },
        }
    }

    private maybe_record_iterator_conformance(self, target_type Type, trait_type TypeNode) Void = {
        if not (self.type_node_name(trait_type) == "Iterator") then {
            return
        }
        when trait_type in {
            .Generic(_, trait_args) then {
                if trait_args.count() > (UInt)0 then {
                    let item_type = self.resolve_type(trait_args.at((UInt)0).val)
                    self.record_explicit_iterator_conformance(target_type, item_type)
                }
            },
            .ModuleQualifiedGeneric(_, _, trait_args) then {
                if trait_args.count() > (UInt)0 then {
                    let item_type = self.resolve_type(trait_args.at((UInt)0).val)
                    self.record_explicit_iterator_conformance(target_type, item_type)
                }
            },
            _ then {},
        }
    }

    private iterator_conformance_key(self, iterator_type Type, item_type Type) String = {
        let iter_key = self.storage.def_id_map.type_display_name(iterator_type)
        let item_key = type_to_string(item_type)
        return "\(iter_key)::\(item_key)"
    }

    private iterator_template_key(self, iterator_type Type) [String]Option = {
        return when iterator_type in {
            .GenericStruct(template, _) then [String]Option.Some("S:\(template)"),
            .GenericEnum(template, _) then [String]Option.Some("U:\(template)"),
            _ then [String]Option.None(),
        }
    }

    private generic_argument_index_for_item(self, type_args [Type ref]List, item_type Type) [UInt]Option = {
        let item_key = type_to_string(item_type)
        let mut i UInt = 0
        while i < type_args.count() then {
            if type_to_string(type_args.at(i).val) == item_key then {
                return [UInt]Option.Some(i)
            }
            i += 1
        }
        return [UInt]Option.None()
    }

    protected has_explicit_iterator_conformance(self, iterator_type Type, item_type Type) Bool = {
        if self.storage.explicit_iterator_conformances.contains(self.iterator_conformance_key(iterator_type, item_type)) then {
            return true
        }
        when iterator_type in {
            .GenericStruct(template, args) then {
                if self.storage.explicit_iterator_template_item_index.get("S:\(template)") is .Some(item_index) then {
                    if item_index < args.count() and self.same_expr_type(args.at(item_index).val, item_type) then {
                        return true
                    }
                }
            },
            .GenericEnum(template, args) then {
                if self.storage.explicit_iterator_template_item_index.get("U:\(template)") is .Some(item_index) then {
                    if item_index < args.count() and self.same_expr_type(args.at(item_index).val, item_type) then {
                        return true
                    }
                }
            },
            _ then {},
        }
        return false
    }

    private record_explicit_iterator_conformance(self, iterator_type Type, item_type Type) Void = {
        self.storage.explicit_iterator_conformances.insert(self.iterator_conformance_key(iterator_type, item_type))
        when iterator_type in {
            .GenericStruct(template, args) then {
                if self.generic_argument_index_for_item(args, item_type) is .Some(item_index) then {
                    self.storage.explicit_iterator_template_item_index.insert("S:\(template)", item_index)
                }
            },
            .GenericEnum(template, args) then {
                if self.generic_argument_index_for_item(args, item_type) is .Some(item_index) then {
                    self.storage.explicit_iterator_template_item_index.insert("U:\(template)", item_index)
                }
            },
            _ then {},
        }
    }

    private make_method_symbol(self, method_name String, return_type Type) Symbol = {
        let def_id = self.storage.def_id_map.allocate(method_name, DefKind.Function())
        return Symbol(def_id, method_name, return_type, SymbolKind.Function())
    }

    // Recover static receiver types from member chains like Time.DateTime.
    private resolve_static_receiver_type(self, expr TypedExpr ref) [Type]Option = {
        return when expr.expr_kind in {
            .MemberExpr(_, member_name) then {
                if self.storage.global_scope.lookup_type(member_name) is .Some(t) then {
                    return [Type]Option.Some(t)
                }
                return self.try_resolve_named_type_without_diag(member_name)
            },
            .Variable(sym) then {
                if not self.is_unresolved_expr_type(sym.symbol_type) then {
                    return [Type]Option.Some(sym.symbol_type)
                }
                if self.storage.global_scope.lookup_type(sym.name) is .Some(t) then {
                    return [Type]Option.Some(t)
                }
                return self.try_resolve_named_type_without_diag(sym.name)
            },
            _ then [Type]Option.None(),
        }
    }

    private trait_name_from_type(self, trait_type Type) String = {
        return when trait_type in {
            .TraitObject(name) then name,
            _ then self.storage.def_id_map.type_display_name(trait_type),
        }
    }

    private check_params(self, params [Param]List) [TypedParam]List = {
        let mut out = [TypedParam]List.new()
        for p in params then {
            out.push(TypedParam(p.name, p.mutable, self.resolve_type(p.type_name), p.named))
        }
        return out
    }

    private check_params_in_scope(self, params [Param]List, scope Scope) [TypedParam]List = {
        let mut out = [TypedParam]List.new()
        for p in params then {
            out.push(TypedParam(p.name, p.mutable, self.resolve_type_in_scope(p.type_name, scope), p.named))
        }
        return out
    }

    private make_given_member_type_scope(self, self_type Type, owner_type_params [TypeParameter]List, method_type_params [TypeParameter]List) Scope = {
        let mut scope = Scope.new_root()
        for tp in owner_type_params then {
            scope.define_type(tp.name, Type.GenericParameter(tp.name))
        }
        for tp in method_type_params then {
            scope.define_type(tp.name, Type.GenericParameter(tp.name))
        }
        scope.define_type("Self", self_type)
        return scope
    }

    private check_method_params(self, params [Param]List, self_type Type) [TypedParam]List = {
        let mut out = [TypedParam]List.new()
        let mut first = true
        for p in params then {
            if first and p.name == "self" then {
                out.push(TypedParam(p.name, p.mutable, self.resolve_type_with_self(p.type_name, self_type), p.named))
            } else {
                out.push(TypedParam(p.name, p.mutable, self.resolve_type_with_self(p.type_name, self_type), p.named))
            }
            first = false
        }
        return out
    }

    private resolve_type_with_self(self, node TypeNode, self_type Type) Type = {
        return when node in {
            .Identifier(name) then self.resolve_named_type(name),
            .Reference(inner) then self.resolve_reference_type(self.resolve_type_with_self(inner.val, self_type)),
            .Pointer(inner) then Type.PointerType(box(self.resolve_type_with_self(inner.val, self_type))),
            .WeakReference(inner) then Type.WeakReferenceType(box(self.resolve_type_with_self(inner.val, self_type))),
            .Generic(base, args) then {
                let mut resolved_args = [Type ref]List.new()
                for a in args then {
                    resolved_args.push(box(self.resolve_type_with_self(a.val, self_type)))
                }
                if self.is_enum_base_name(base) then {
                    return Type.GenericEnum(base, resolved_args)
                }
                return Type.GenericStruct(base, resolved_args)
            },
            .InferredSelf() then self_type,
            .FunctionType(param_types, return_type) then {
                let mut resolved_params = [Type ref]List.new()
                for pt in param_types then {
                    resolved_params.push(box(self.resolve_type_with_self(pt.val, self_type)))
                }
                let resolved_ret = self.resolve_type_with_self(return_type.val, self_type)
                return Type.FunctionType(resolved_params, box(resolved_ret))
            },
            .ModuleQualified(_, name) then self.resolve_named_type(name),
            .ModuleQualifiedGeneric(_, base, args) then {
                let mut resolved_args = [Type ref]List.new()
                for a in args then {
                    resolved_args.push(box(self.resolve_type_with_self(a.val, self_type)))
                }
                if self.is_enum_base_name(base) then {
                    return Type.GenericEnum(base, resolved_args)
                }
                return Type.GenericStruct(base, resolved_args)
            },
        }
    }

    private check_fields(self, fields [Field]List) [TypedField]List = {
        let mut out = [TypedField]List.new()
        for f in fields then {
            out.push(TypedField(f.access, f.name, f.mutable, self.resolve_type(f.type_name), f.named))
        }
        return out
    }

    private resolve_reference_type(self, inner_type Type) Type = {
        when inner_type in {
            .TraitObject(trait_name) then {
                when self.storage.trait_registry.check_object_safety(trait_name) in {
                    .Ok(is_safe) then {
                        if not is_safe then {
                            self.storage.diagnostics.push(
                                make_diagnostic(
                                    DiagnosticStage.Semantic(),
                                    self.storage.file_path,
                                    "Trait '\(trait_name)' is not object-safe"
                                )
                            )
                            return Type.Unknown()
                        }
                    },
                    .Error(_) then {},
                }
            },
            _ then {},
        }
        return Type.ReferenceType(box(inner_type))
    }

    private check_enum_cases(self, cases [EnumCase]List) [TypedEnumCase]List = {
        let mut out = [TypedEnumCase]List.new()
        for c in cases then {
            let mut typed_fields = [TypedEnumCaseField]List.new()
            for f in c.fields then {
                typed_fields.push(TypedEnumCaseField(f.name, self.resolve_type(f.type_name), f.named))
            }
            out.push(TypedEnumCase(c.name, typed_fields))
        }
        return out
    }

    private check_trait_members(self, members [TraitMember]List, type_params [TypeParameter]List) [TypedTraitMember]List = {
        let mut trait_scope = Scope.new_root()
        for tp in type_params then {
            trait_scope.define_generic_param(tp.name)
        }
        trait_scope.define_generic_param("Self")
        let mut out = [TypedTraitMember]List.new()
        for m in members then {
            let mut member_scope = Scope.new_child(trait_scope)
            for tp in m.type_params then {
                member_scope.define_generic_param(tp.name)
            }
            let mut typed_params = [TypedParam]List.new()
            for p in m.params then {
                typed_params.push(TypedParam(p.name, p.mutable, self.resolve_type_in_scope(p.type_name, member_scope), p.named))
            }
            out.push(TypedTraitMember(m.name, typed_params, self.resolve_type_in_scope(m.return_type, member_scope)))
        }
        return out
    }

    private check_given_members(self, members [GivenMember]List) [TypedGivenMember]List = {
        let mut out = [TypedGivenMember]List.new()
        for m in members then {
            let typed_params = self.check_params(m.params)
            let ret = self.resolve_type(m.return_type)
            let typed_body = when m.body in {
                .Some(b) then [TypedExpr ref]Option.Some(box(self.check_expr_global_ref(b, .Some(ret)))),
                .None() then [TypedExpr ref]Option.None(),
            }
            let method_def_id = self.storage.def_id_map.allocate(m.name, DefKind.Function())
            // Register method signature so mono can look it up by DefId
            let mut param_types = [Type]List.new()
            for p in typed_params then {
                param_types.push(p.param_type)
            }
            let mut param_specs = [FunctionParamSpec]List.new()
            for p in typed_params then {
                param_specs.push(FunctionParamSpec(p.name, p.named))
            }
            self.storage.def_id_map.set_signature(method_def_id, FunctionSignature(param_types, ret, param_specs))
            out.push(TypedGivenMember(method_def_id, m.name, typed_params, ret, typed_body))
        }
        return out
    }

    private check_given_members_for_type(self, members [GivenMember]List, target_type Type, type_params [TypeParameter]List, conformance_trait_name [String]Option) [TypedGivenMember]List = {
        let mut out = [TypedGivenMember]List.new()
        for m in members then {
            self.sema_debug("given member check start: \(m.name) file=\(self.storage.file_path)")
            let type_binding_snapshot = self.snapshot_type_bindings()
            // 注入方法级别的泛型类型参数（如 [K Ord]max_by 里的 K）
            for tp in m.type_params then {
                self.bind_type_param(tp)
            }
            let member_type_scope = self.make_given_member_type_scope(target_type, type_params, m.type_params)
            let typed_params = self.check_params_in_scope(m.params, member_type_scope)
            let ret = self.resolve_type_in_scope(m.return_type, member_type_scope)
            let typed_body = when m.body in {
                .Some(b) then {
                    let prev_in_function = self.storage.in_function
                    let prev_current_function_return_type = self.storage.current_function_return_type
                    let prev_in_loop = self.storage.in_loop
                    let prev_in_finally = self.storage.in_finally
                    self.storage.in_function = true
                    self.storage.current_function_return_type = [Type]Option.Some(ret)
                    self.storage.in_loop = false
                    self.storage.in_finally = false
                    let mut method_scope = self.make_method_scope(typed_params, target_type, type_params)
                    // 注入方法级别的泛型类型参数到 method scope
                    for tp in m.type_params then {
                        method_scope.define_type(tp.name, Type.GenericParameter(tp.name))
                    }
                    let result = self.check_expr_scoped_ref(b, .Some(ret), method_scope)
                    self.storage.in_function = prev_in_function
                    self.storage.current_function_return_type = prev_current_function_return_type
                    self.storage.in_loop = prev_in_loop
                    self.storage.in_finally = prev_in_finally
                    yield [TypedExpr ref]Option.Some(box(result))
                },
                .None() then [TypedExpr ref]Option.None(),
            }
            self.register_extension_method_template(target_type, type_params, m, typed_params, conformance_trait_name, self.to_typed_expr_option(typed_body), [Type]Option.Some(ret))
            when target_type in {
                .TraitObject(trait_name) then {
                    self.backfill_checked_trait_tool_method_to_existing_conformances(
                        trait_name,
                        m,
                        typed_params,
                        self.to_typed_expr_option(typed_body),
                        ret,
                    )
                },
                _ then {},
            }
            let method_def_id = self.storage.def_id_map.allocate(m.name, DefKind.Function())
            // Register method signature so mono can look it up by DefId
            let mut param_types = [Type]List.new()
            for p in typed_params then {
                param_types.push(p.param_type)
            }
            let mut param_specs = [FunctionParamSpec]List.new()
            for p in typed_params then {
                param_specs.push(FunctionParamSpec(p.name, p.named))
            }
            self.storage.def_id_map.set_signature(method_def_id, FunctionSignature(param_types, ret, param_specs))
            out.push(TypedGivenMember(method_def_id, m.name, typed_params, ret, typed_body))
            self.restore_type_bindings(type_binding_snapshot)
            self.sema_debug("given member check done: \(m.name) file=\(self.storage.file_path)")
        }
        return out
    }

    private resolve_given_return_type(self, return_type TypeNode, target_type Type) Type = {
        when return_type in {
            .InferredSelf() then { return target_type },
            _ then {},
        }
        return self.resolve_type_with_self(return_type, target_type)
    }

    private make_method_scope(self, params [TypedParam]List, self_type Type, type_params [TypeParameter]List) Scope = {
        let mut scope = Scope.new_root()
        // 注入泛型类型参数
        for tp in type_params then {
            scope.define_type(tp.name, Type.GenericParameter(tp.name))
        }
        scope.define_type("Self", self_type)
        let mut first = true
        for p in params then {
            if first and p.name == "self" then {
                let kind = SymbolKind.Variable(self.variable_kind_for_param_type(p.param_type, p.mutable))
                let def_id = self.storage.def_id_map.allocate("self", DefKind.Variable())
                scope.define(Symbol(def_id, "self", p.param_type, kind))
                first = false
            } else {
                first = false
                let kind = SymbolKind.Variable(self.variable_kind_for_param_type(p.param_type, p.mutable))
                let def_id = self.storage.def_id_map.allocate(p.name, DefKind.Variable())
                scope.define(Symbol(def_id, p.name, p.param_type, kind))
            }
        }
        return scope
    }

    private make_fn_scope(self, params [TypedParam]List) Scope = {
        let mut scope = Scope.new_root()
        for p in params then {
            let kind = if p.mutable
                then SymbolKind.Variable(VariableKind.MutableValue())
                else SymbolKind.Variable(VariableKind.Value())
            let def_id = self.storage.def_id_map.allocate(p.name, DefKind.Variable())
            scope.define(Symbol(def_id, p.name, p.param_type, kind))
        }
        return scope
    }

    private make_generic_fn_scope(self, params [TypedParam]List, type_params [TypeParameter]List) Scope = {
        let mut scope = Scope.new_root()
        for tp in type_params then {
            scope.define_type(tp.name, Type.GenericParameter(tp.name))
        }
        for p in params then {
            let kind = if p.mutable
                then SymbolKind.Variable(VariableKind.MutableValue())
                else SymbolKind.Variable(VariableKind.Value())
            let def_id = self.storage.def_id_map.allocate(p.name, DefKind.Variable())
            scope.define(Symbol(def_id, p.name, p.param_type, kind))
        }
        return scope
    }

}
