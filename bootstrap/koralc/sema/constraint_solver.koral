// ConstraintSolver – 约束求解器，按优先级求解所有类型约束并生成类型替换。
// 对应 Swift 实现中的 ConstraintSolver。

// 约束求解错误类型。
public type ConstraintSolverError {
    // 合一失败
    UnificationFailed(message String, span SourceSpan),
    // 类型变量未被解析
    UnsolvedTypeVariable(tv TypeVariable, span SourceSpan),
    // Trait 约束未满足
    TraitNotSatisfied(target Type, trait_name String, span SourceSpan),
    // 约束冲突
    ConflictingConstraints(message String, span SourceSpan),
}

given ConstraintSolverError as Error {

    public message(self ref) String = {
        return when self in {
            .UnificationFailed(message, _) then message,
            .UnsolvedTypeVariable(tv, _) then "Unsolved type variable: \(tv.display())",
            .TraitNotSatisfied(target, trait_name, _) then "Type '\(type_to_string(target))' does not satisfy trait '\(trait_name)'",
            .ConflictingConstraints(message, _) then "Conflicting constraints: \(message)",
        }
    }
}

// 类型替换：将类型变量 ID 映射到具体类型。
public type TypeSubstitution(
    mapping Dict[UInt, Type],
)

given TypeSubstitution {

    public new() TypeSubstitution = {
        return TypeSubstitution(Dict[UInt, Type].new())
    }

    // 将替换应用到类型 t，递归替换所有已知的类型变量。
    public apply(self, t Type) Type = {
        return when t in {
            .TypeVar(tv_ref) then {
                let tv = tv_ref.val
                yield when self.mapping.get(tv.id) in {
                    .Some(resolved) then self.apply(resolved),
                    .None() then t,
                }
            },
            .FunctionType(params, ret) then {
                let mut new_params = List[ref Type].new()
                let mut i = 0(UInt)
                while i < params.count() then {
                    new_params.push(box(self.apply(params[i].val.param_type)))
                    i += 1(UInt)
                }
                yield Type.FunctionType(types_to_param_entries(new_params), box(self.apply(ret.val)))
            },
            .MutableReferenceType(inner) then {
                yield Type.MutableReferenceType(box(self.apply(inner.val)))
            },
            .ReferenceType(inner) then {
                yield Type.ReferenceType(box(self.apply(inner.val)))
            },
            .MutablePointerType(inner) then {
                yield Type.MutablePointerType(box(self.apply(inner.val)))
            },
            .PointerType(inner) then {
                yield Type.PointerType(box(self.apply(inner.val)))
            },
            .WeakReferenceType(inner) then {
                yield Type.WeakReferenceType(box(self.apply(inner.val)))
            },
            .MutableWeakReferenceType(inner) then {
                yield Type.MutableWeakReferenceType(box(self.apply(inner.val)))
            },
            .GenericStruct(template, args) then {
                let mut new_args = List[ref Type].new()
                let mut i = 0(UInt)
                while i < args.count() then {
                    new_args.push(box(self.apply(args[i].val)))
                    i += 1(UInt)
                }
                yield Type.GenericStruct(template, new_args)
            },
            .GenericEnum(template, args) then {
                let mut new_args = List[ref Type].new()
                let mut i = 0(UInt)
                while i < args.count() then {
                    new_args.push(box(self.apply(args[i].val)))
                    i += 1(UInt)
                }
                yield Type.GenericEnum(template, new_args)
            },
            _ then t,
        }
    }
}

// 约束求解器。
public type ConstraintSolver(
    mut unifier Unifier,
    mut constraints List[Constraint],
    mut default_constraints List[Constraint],
    mut errors List[ConstraintSolverError],
    mut next_type_variable_id UInt,
    // 用于 Instantiate 约束判断 struct/enum 的类型查找回调。
    // 由 TypeChecker 在创建 ConstraintSolver 后注入。
    mut enum_type_names Set[String],
)

given ConstraintSolver {

    public new() ConstraintSolver = {
        return ConstraintSolver(
            Unifier.new(),
            List[Constraint].new(),
            List[Constraint].new(),
            List[ConstraintSolverError].new(),
            0(UInt),
            Set[String].new()
        )
    }

    public fresh_type_variable(self mut ref, name Option[String], span SourceSpan) TypeVariable = {
        let id = self.next_type_variable_id
        self.next_type_variable_id += 1
        return TypeVariable(id, name, Option[LiteralDefaultKind].None(), span)
    }

    public fresh_literal_type_variable(self mut ref, kind LiteralDefaultKind, span SourceSpan) TypeVariable = {
        let id = self.next_type_variable_id
        self.next_type_variable_id += 1
        return TypeVariable(id, Option[String].None(), Option[LiteralDefaultKind].Some(kind), span)
    }

    // 注册一个 enum 类型名称，用于 Instantiate 约束判断。
    public register_enum_type(self mut ref, name String) Void = {
        self.enum_type_names.insert(name)
    }

    // 添加约束：DefaultInt/DefaultFloat 放入 default_constraints，其余放入 constraints。
    public add_constraint(self mut ref, c Constraint) Void = {
        when c in {
            .DefaultInt(_, _) then { self.default_constraints.push(c) },
            .DefaultFloat(_, _) then { self.default_constraints.push(c) },
            _ then { self.constraints.push(c) },
        }
    }

    // 对 constraints 按 priority 做插入排序（priority 越小越优先）。
    private sort_constraints(self mut ref) Void = {
        let n = self.constraints.count()
        let mut i = 1(UInt)
        while i < n then {
            let key = self.constraints[i]
            let key_priority = key.priority()
            let mut j = i
            while j > 0(UInt) then {
                let prev = self.constraints[j - 1(UInt)]
                if prev.priority() > key_priority then {
                    self.constraints[j] = prev
                    j -= 1(UInt)
                } else {
                    break
                }
            }
            self.constraints[j] = key
            i += 1(UInt)
        }
    }

    // 求解所有约束，返回 TypeSubstitution。
    public solve(self mut ref) Result[TypeSubstitution] = {
        // 1. 按优先级排序
        self.sort_constraints()

        // 2. 依次处理每个约束（支持 re-queue）
        let mut max_iterations = self.constraints.count() * 3(UInt) + 100(UInt)
        let mut iteration = 0(UInt)
        while self.constraints.count() > 0(UInt) and iteration < max_iterations then {
            let c = self.constraints[0(UInt)]
            // 移除第一个约束
            let mut remaining = List[Constraint].new()
            let mut j = 1(UInt)
            while j < self.constraints.count() then {
                remaining.push(self.constraints[j])
                j += 1(UInt)
            }
            self.constraints = remaining
            self.process_constraint(c)
            iteration += 1(UInt)
        }

        // 3. 处理 default_constraints
        let mut di = 0(UInt)
        while di < self.default_constraints.count() then {
            let c = self.default_constraints[di]
            self.process_default_constraint(c)
            di += 1(UInt)
        }

        // 4. 若有错误，返回第一个错误
        if self.errors.count() > 0(UInt) then {
            return Result[TypeSubstitution].Error(box(self.errors[0(UInt)]))
        }

        // 5. 构建 TypeSubstitution（完全解析所有绑定）
        let bindings = self.unifier.current_bindings()
        let mut resolved_bindings = Dict[UInt, Type].new()
        for entry in bindings then {
            resolved_bindings.insert(entry.first, self.unifier.resolve_deep(entry.second))
        }
        return Result[TypeSubstitution].Ok(TypeSubstitution(resolved_bindings))
    }

    // 处理单个约束。
    private process_constraint(self mut ref, c Constraint) Void = {
        when c in {
            .Equal(lhs, rhs, span) then {
                let result = self.unifier.unify(lhs, rhs, span)
                when result in {
                    .Error(e) then {
                        self.errors.push(ConstraintSolverError.UnificationFailed(e.message(), span))
                    },
                    .Ok(_) then {},
                }
            },
            .Instantiate(tv, template, args, span) then {
                // 创建泛型实例类型并与类型变量合一。
                // 使用注册的 enum 类型名称集合判断是 struct 还是 enum。
                let is_enum = self.enum_type_names.contains(template)
                let instance_type = if is_enum
                    then Type.GenericEnum(template, self.types_to_refs(args))
                    else Type.GenericStruct(template, self.types_to_refs(args))
                let result = self.unifier.unify(Type.TypeVar(box(tv)), instance_type, span)
                when result in {
                    .Error(e) then {
                        self.errors.push(ConstraintSolverError.UnificationFailed(e.message(), span))
                    },
                    .Ok(_) then {},
                }
            },
            .TraitBound(target, trait_name, span) then {
                // 解析目标类型
                let resolved = self.unifier.resolve(target)
                // 如果类型仍包含类型变量，重新入队稍后处理。
                let still_has_tv = self.type_contains_tv(resolved)
                if still_has_tv then {
                    self.constraints.push(Constraint.TraitBound(resolved, trait_name, span))
                }
                // 完整的 trait 一致性检查在 check_decl 阶段的 TraitChecker 中完成。
            },
            // DefaultInt/DefaultFloat 不应出现在 constraints 中，跳过
            _ then {},
        }
    }

    // 处理默认类型约束。
    private process_default_constraint(self mut ref, c Constraint) Void = {
        when c in {
            .DefaultInt(tv, span) then {
                let resolved = self.unifier.resolve(Type.TypeVar(box(tv)))
                // 若类型变量仍未解决，应用默认类型 Int
                when resolved in {
                    .TypeVar(_) then {
                        let result = self.unifier.unify(Type.TypeVar(box(tv)), Type.IntType(), span)
                        when result in {
                            .Error(e) then {
                                self.errors.push(ConstraintSolverError.UnificationFailed(e.message(), span))
                            },
                            .Ok(_) then {},
                        }
                    },
                    _ then {},
                }
            },
            .DefaultFloat(tv, span) then {
                let resolved = self.unifier.resolve(Type.TypeVar(box(tv)))
                // 若类型变量仍未解决，应用默认类型 Float64
                when resolved in {
                    .TypeVar(_) then {
                        let result = self.unifier.unify(Type.TypeVar(box(tv)), Type.Float64Type(), span)
                        when result in {
                            .Error(e) then {
                                self.errors.push(ConstraintSolverError.UnificationFailed(e.message(), span))
                            },
                            .Ok(_) then {},
                        }
                    },
                    _ then {},
                }
            },
            _ then {},
        }
    }

    // 辅助：将 [Type]List 转换为 [Type ref]List。
    private types_to_refs(self, types List[Type]) List[ref Type] = {
        let mut out = List[ref Type].new()
        for t in types then {
            out.push(box(t))
        }
        return out
    }

    // 辅助：检查类型是否包含类型变量。
    private type_contains_tv(self mut ref, t Type) Bool = {
        return when t in {
            .TypeVar(_) then true,
            .FunctionType(params, ret) then {
                for entry in params then {
                    if self.type_contains_tv(entry.param_type) then { return true }
                }
                yield self.type_contains_tv(ret.val)
            },
            .MutableReferenceType(inner) then self.type_contains_tv(inner.val),
            .ReferenceType(inner) then self.type_contains_tv(inner.val),
            .MutablePointerType(inner) then self.type_contains_tv(inner.val),
            .PointerType(inner) then self.type_contains_tv(inner.val),
            .WeakReferenceType(inner) then self.type_contains_tv(inner.val),
            .MutableWeakReferenceType(inner) then self.type_contains_tv(inner.val),
            .GenericStruct(_, args) then {
                for a in args then {
                    if self.type_contains_tv(a.val) then { return true }
                }
                yield false
            },
            .GenericEnum(_, args) then {
                for a in args then {
                    if self.type_contains_tv(a.val) then { return true }
                }
                yield false
            },
            _ then false,
        }
    }

    // 解析类型：将类型变量替换为已绑定的类型。
    public resolve(self mut ref, t Type) Type = {
        return self.unifier.resolve(t)
    }
}
