// TypeVariable – represents an unknown type during type inference.
// IDs are allocated by TypeChecker state.

public type LiteralDefaultKind {
    Int(),
    Float(),
}

public type TypeVariable(
    id UInt,
    name [String]Option,
    literal_default_kind [LiteralDefaultKind]Option,
    span SourceSpan,
)

given TypeVariable {
    // Display the TypeVariable as a human-readable string.
    // With a name: "?{name}_{id}", without: "?T{id}"
    public display(self) String = {
        return when self.name in {
            .Some(n) then {
                let mut out = "?"
                out.push_string(n)
                out.push_byte('_')
                out.push_string(self.id.to_string())
                yield out
            },
            .None() then {
                yield when self.literal_default_kind in {
                    .Some(kind) then {
                        let mut out = "?"
                        when kind in {
                            .Int() then out.push_string("int_lit"),
                            .Float() then out.push_string("float_lit"),
                        }
                        out.push_byte('_')
                        out.push_string(self.id.to_string())
                        yield out
                    },
                    .None() then {
                        let mut out = "?T"
                        out.push_string(self.id.to_string())
                        yield out
                    },
                }
            },
        }
    }
}
