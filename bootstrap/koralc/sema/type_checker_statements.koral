// type_checker_statements.koral - 语句类型检查与类型替换
//
// 实现 TypeChecker 的语句检查、模式匹配、类型推断辅助、
// 类型替换（apply_subst_to_*）等方法。

given TypeChecker {
    private check_block(self, statements [Statement]List, expected [Type]Option, scope Scope) TypedExpr = {
        let mut block_scope = Scope.new_child(scope)
        return self.check_block_in_scope(statements, expected, block_scope)
    }

    private make_assignment_temp_symbol(self, prefix String, t Type) Symbol ref = {
        let def_id = self.storage.def_id_map.allocate(prefix, DefKind.Variable())
        let unique_name = "\(prefix)_\(def_id.id.to_string())"
        return box(Symbol(def_id, unique_name, t, SymbolKind.Variable(VariableKind.Value())))
    }

    private push_assignment_temp_decl(self, prefix String, value TypedExpr, statements [TypedStatement]List ref) Symbol ref = {
        let sym = self.make_assignment_temp_symbol(prefix, value.expr_type)
        statements.push(TypedStatement.LetStmt(sym, box(value), unknown_span()))
        return sym
    }

    private lower_subscript_assignment_stmt(self, base Expr ref, args [Expr ref]List, value Expr ref, typed_target TypedExpr, op [CompoundAssignmentOperator]Option, scope Scope) TypedStatement = {
        let typed_base = self.check_expr_scoped_ref(base, .None(), scope)
        let set_param_types = self.resolve_method_param_types(typed_base.expr_type, "set_at")
        let expected_index_count = if not set_param_types.is_empty() then set_param_types.count() - (UInt)1 else (UInt)0

        let mut typed_args = [TypedExpr ref]List.new()
        let mut arg_idx UInt = 0
        for arg in args then {
            let arg_expected = if arg_idx < expected_index_count then [Type]Option.Some(set_param_types.at(arg_idx)) else [Type]Option.None()
            typed_args.push(box(self.check_expr_scoped_ref(arg, arg_expected, scope)))
            arg_idx += 1
        }

        let expected_value_type = if not set_param_types.is_empty() then set_param_types.at(set_param_types.count() - (UInt)1) else typed_target.expr_type
        let expected_self_type = self.resolve_method_self_type(typed_base.expr_type, "set_at")
        let adapted_base = self.adapt_receiver_to_expected_self_type(typed_base, expected_self_type)
        let normalized_base_type = when typed_base.expr_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then typed_base.expr_type,
        }
        self.maybe_record_extension_method_instantiation(normalized_base_type, "set_at", [Type]List.new())
        let set_return_type = self.resolve_method_return_type(adapted_base.expr_type, "set_at")
        let set_method_symbol = self.make_method_symbol("set_at", set_return_type)

        let mut block_statements = [TypedStatement]List.new()
        let base_symbol = self.push_assignment_temp_decl("__sub_base", adapted_base, block_statements.ref)
        let mut arg_symbols = [Symbol ref]List.new()
        for typed_arg in typed_args then {
            arg_symbols.push(self.push_assignment_temp_decl("__sub_idx", typed_arg.val, block_statements.ref))
        }

        let base_var = make_typed_expr(TypedExprKind.Variable(base_symbol), base_symbol.symbol_type)
        let mut arg_vars = [TypedExpr ref]List.new()
        for arg_symbol in arg_symbols then {
            arg_vars.push(box(make_typed_expr(TypedExprKind.Variable(arg_symbol), arg_symbol.symbol_type)))
        }

        let lowered_value = when op in {
            .Some(compound_op) then {
                let read_expr = self.lower_subscript_read_expr(base_var, arg_vars, typed_target.expr_type)
                let old_symbol = self.push_assignment_temp_decl("__sub_old", read_expr, block_statements.ref)
                let typed_rhs = self.check_expr_scoped_ref(value, .Some(expected_value_type), scope)
                let rhs_symbol = self.push_assignment_temp_decl("__sub_rhs", typed_rhs, block_statements.ref)
                let lhs_var = make_typed_expr(TypedExprKind.Variable(old_symbol), old_symbol.symbol_type)
                let rhs_var = make_typed_expr(TypedExprKind.Variable(rhs_symbol), rhs_symbol.symbol_type)
                yield when compound_op in {
                    .AddAssign() then make_typed_expr(TypedExprKind.ArithmeticExpr(box(lhs_var), ArithmeticOperator.Add(), box(rhs_var)), typed_target.expr_type),
                    .SubtractAssign() then make_typed_expr(TypedExprKind.ArithmeticExpr(box(lhs_var), ArithmeticOperator.Subtract(), box(rhs_var)), typed_target.expr_type),
                    .MultiplyAssign() then make_typed_expr(TypedExprKind.ArithmeticExpr(box(lhs_var), ArithmeticOperator.Multiply(), box(rhs_var)), typed_target.expr_type),
                    .DivideAssign() then make_typed_expr(TypedExprKind.ArithmeticExpr(box(lhs_var), ArithmeticOperator.Divide(), box(rhs_var)), typed_target.expr_type),
                    .RemainderAssign() then make_typed_expr(TypedExprKind.ArithmeticExpr(box(lhs_var), ArithmeticOperator.Remainder(), box(rhs_var)), typed_target.expr_type),
                    .BitAndAssign() then make_typed_expr(TypedExprKind.BitwiseExpr(box(lhs_var), BitwiseOperator.BitAnd(), box(rhs_var)), typed_target.expr_type),
                    .BitOrAssign() then make_typed_expr(TypedExprKind.BitwiseExpr(box(lhs_var), BitwiseOperator.BitOr(), box(rhs_var)), typed_target.expr_type),
                    .BitXorAssign() then make_typed_expr(TypedExprKind.BitwiseExpr(box(lhs_var), BitwiseOperator.BitXor(), box(rhs_var)), typed_target.expr_type),
                    .LeftShiftAssign() then make_typed_expr(TypedExprKind.BitwiseExpr(box(lhs_var), BitwiseOperator.LeftShift(), box(rhs_var)), typed_target.expr_type),
                    .RightShiftAssign() then make_typed_expr(TypedExprKind.BitwiseExpr(box(lhs_var), BitwiseOperator.RightShift(), box(rhs_var)), typed_target.expr_type),
                }
            },
            .None() then self.check_expr_scoped_ref(value, .Some(expected_value_type), scope),
        }

        let value_symbol = self.push_assignment_temp_decl("__sub_val", lowered_value, block_statements.ref)
        let value_var = make_typed_expr(TypedExprKind.Variable(value_symbol), value_symbol.symbol_type)

        let mut call_args = [TypedExpr ref]List.new()
        for arg_var in arg_vars then {
            call_args.push(arg_var)
        }
        call_args.push(box(value_var))
        let call_expr = make_typed_expr(
            TypedExprKind.GenericMethodCall(box(base_var), base_var.expr_type, box(set_method_symbol), call_args),
            set_return_type,
        )
        block_statements.push(TypedStatement.ExprStmt(box(call_expr), unknown_span()))
        return TypedStatement.ExprStmt(box(make_typed_expr(TypedExprKind.Block(block_statements), Type.VoidType())), unknown_span())
    }

    private check_block_in_scope(self, statements [Statement]List, expected [Type]Option, scope Scope) TypedExpr = {
        let mut typed_stmts = [TypedStatement]List.new()
        let mut block_type = Type.VoidType()
        let mut stmt_idx Int = 0
        for stmt in statements then {
            if stmt is .YieldStmt(_, _) and stmt_idx <> (Int)statements.count() - 1 then {
                self.storage.diagnostics.push(
                    make_diagnostic(
                        DiagnosticStage.Semantic(),
                        self.storage.file_path,
                        "yield must be the last statement in a block expression"
                    )
                )
            }
            self.sema_debug("check_block stmt start: \(stmt_idx) file=\(self.storage.file_path)")
            let ts = self.check_statement(stmt, expected, scope)
            self.sema_debug("check_block stmt done: \(stmt_idx) file=\(self.storage.file_path)")
            if ts is .YieldStmt(expr, _) then {
                block_type = expr.expr_type
            }
            typed_stmts.push(ts)
            stmt_idx = stmt_idx + 1
        }
        return make_typed_expr(TypedExprKind.Block(typed_stmts), block_type)
    }

    private check_statement(self, stmt Statement, expected [Type]Option, scope Scope) TypedStatement = {
        self.sema_debug("check_statement enter kind=\(self.describe_statement_kind(stmt)) file=\(self.storage.file_path)")

        return when stmt in {
            .LetStmt(name, mutable, type_annotation, value, span) then {
                // 重复定义检查：只查当前层
                if name <> "_" and scope.lookup_local(name) is .Some(_) then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Duplicate definition: \(name)"))
                }
                let val_expected = when type_annotation in {
                    .Some(ta) then [Type]Option.Some(self.resolve_type_in_scope(ta, scope)),
                    .None() then [Type]Option.None(),
                }
                if val_expected is .Some(t) and t is .TraitObject(_) then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "use trait as type"))
                }
                let typed_val = when value in {
                    .Identifier(sym_name) then self.check_identifier_expr(sym_name, scope),
                    .MemberExpr(base, member) then self.check_member_expr_ref(base, member, scope),
                    .ArithmeticExpr(left, op, right) then self.check_arithmetic_expr_ref(left, op, right, val_expected, scope),
                    .ComparisonExpr(left, op, right) then self.check_comparison_expr_ref(left, op, right, scope),
                    .BitwiseExpr(left, op, right) then self.check_bitwise_expr_ref(left, op, right, val_expected, scope),
                    _ then self.check_expr_scoped_ref(value, val_expected, scope),
                }
                if val_expected is .Some(expected_t) then {
                    if not self.same_expr_type(typed_val.expr_type, expected_t)
                       and not self.is_unresolved_expr_type(expected_t)
                       and not self.is_unresolved_expr_type(typed_val.expr_type) then {
                        self.storage.diagnostics.push(
                            make_diagnostic(
                                DiagnosticStage.Semantic(),
                                self.storage.file_path,
                                "Type mismatch: expected \(type_to_string(expected_t)), got \(type_to_string(typed_val.expr_type))"
                            )
                        )
                    }
                }
                let binding_type = when val_expected in {
                    .Some(t) then t,
                    .None() then self.concretize_default_literal_type(typed_val.expr_type),
                }
                let kind = if mutable
                    then SymbolKind.Variable(VariableKind.MutableValue())
                    else SymbolKind.Variable(VariableKind.Value())
                let def_id = self.storage.def_id_map.allocate(name, DefKind.Variable())
                let sym = Symbol(def_id, name, binding_type, kind)
                scope.define(sym)
                return TypedStatement.LetStmt(box(sym), box(typed_val), span)
            },
            .PairLetStmt(first, second, value, span) then {
                let typed_val = self.check_expr_scoped_ref(value, .None(), scope)
                let pair_type = self.concretize_default_literal_type(typed_val.expr_type)

                let mut first_type = self.get_pair_binding_type(pair_type, "first")
                let mut second_type = self.get_pair_binding_type(pair_type, "second")
                if self.pair_binding_type_needs_literal_inference(first_type) or self.pair_binding_type_needs_literal_inference(second_type) then {
                    let literal_first_type = self.infer_pair_literal_binding_type(value, first, (UInt)0, scope)
                    let literal_second_type = self.infer_pair_literal_binding_type(value, second, (UInt)1, scope)
                    if self.pair_binding_type_needs_literal_inference(first_type) and literal_first_type is .Some(_) then {
                        first_type = literal_first_type
                    }
                    if self.pair_binding_type_needs_literal_inference(second_type) and literal_second_type is .Some(_) then {
                        second_type = literal_second_type
                    }
                }
                if first_type is .None() or second_type is .None() then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "Type mismatch: expected Pair, got \(type_to_string(pair_type))"
                        )
                    )
                }

                let first_symbol = self.bind_pair_let_symbol(first, first_type or else Type.Unknown(), scope)
                let second_symbol = self.bind_pair_let_symbol(second, second_type or else Type.Unknown(), scope)
                return TypedStatement.PairLetStmt(first_symbol, second_symbol, box(typed_val), span)
            },
            .AssignmentStmt(target, op, value, span) then {
                let typed_target = self.check_expr_scoped_ref(target, .None(), scope)
                when self.first_immutable_field_in_assignment_target(box(typed_target)) in {
                    .Some(name) then {
                        self.storage.diagnostics.push(
                            make_diagnostic(
                                DiagnosticStage.Semantic(),
                                self.storage.file_path,
                                "Cannot assign to immutable variable: \(name)"
                            )
                        )
                    },
                    .None() then {
                        if not self.assignment_target_root_is_mutable(target, box(typed_target), scope) then {
                            let target_name = self.assignment_target_error_name(box(typed_target))
                            self.storage.diagnostics.push(
                                make_diagnostic(
                                    DiagnosticStage.Semantic(),
                                    self.storage.file_path,
                                    "Cannot assign to immutable variable: \(target_name)"
                                )
                            )
                        }
                    },
                }
                if typed_target.expr_kind is .DerefExpr(inner)
                    and (inner.expr_type is .ReferenceType(_) or inner.expr_type is .WeakReferenceType(_)) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "Managed references (T ref) do not support whole-value write-back through .val"
                        )
                    )
                }
                when target in {
                    .SubscriptExpr(base, args) then {
                        let should_lower = when typed_target.expr_kind in {
                            .DerefExpr(_) then false,
                            _ then true,
                        }
                        if should_lower then {
                            return self.lower_subscript_assignment_stmt(base, args, value, typed_target, op, scope)
                        }
                    },
                    _ then {},
                }
                let rhs_expr = when op in {
                    .Some(compound_op) then {
                        yield when compound_op in {
                            .AddAssign() then box(Expr.ArithmeticExpr(target, ArithmeticOperator.Add(), value)),
                            .SubtractAssign() then box(Expr.ArithmeticExpr(target, ArithmeticOperator.Subtract(), value)),
                            .MultiplyAssign() then box(Expr.ArithmeticExpr(target, ArithmeticOperator.Multiply(), value)),
                            .DivideAssign() then box(Expr.ArithmeticExpr(target, ArithmeticOperator.Divide(), value)),
                            .RemainderAssign() then box(Expr.ArithmeticExpr(target, ArithmeticOperator.Remainder(), value)),
                            .BitAndAssign() then box(Expr.BitwiseExpr(target, BitwiseOperator.BitAnd(), value)),
                            .BitOrAssign() then box(Expr.BitwiseExpr(target, BitwiseOperator.BitOr(), value)),
                            .BitXorAssign() then box(Expr.BitwiseExpr(target, BitwiseOperator.BitXor(), value)),
                            .LeftShiftAssign() then box(Expr.BitwiseExpr(target, BitwiseOperator.LeftShift(), value)),
                            .RightShiftAssign() then box(Expr.BitwiseExpr(target, BitwiseOperator.RightShift(), value)),
                        }
                    },
                    .None() then value,
                }
                let typed_val = self.check_expr_scoped_ref(rhs_expr, .Some(typed_target.expr_type), scope)
                if not self.same_expr_type(typed_target.expr_type, typed_val.expr_type)
                   and not self.is_unresolved_expr_type(typed_target.expr_type)
                   and not self.is_unresolved_expr_type(typed_val.expr_type) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "Type mismatch: expected \(type_to_string(typed_target.expr_type)), got \(type_to_string(typed_val.expr_type))"
                        )
                    )
                }
                return TypedStatement.AssignmentStmt(box(typed_target), box(typed_val), span)
            },
            .ExprStmt(expr, span) then {
                let typed_expr = self.check_expr_core_ref(expr, .None(), scope)
                return TypedStatement.ExprStmt(box(typed_expr), span)
            },
            .ReturnStmt(value, span) then {
                if not self.storage.in_function then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "'return' used outside of function"))
                }
                if self.storage.in_finally then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "control flow statement 'return' is not allowed in finally expression"))
                }
                let expected_return = self.storage.current_function_return_type
                let typed_val = when value in {
                    .Some(v) then {
                        self.sema_debug("return value check start file=\(self.storage.file_path)")
                        let checked = when v in {
                            .StaticMethodCall(type_name, type_args, method_name, args) then {
                                yield self.check_static_method_call_ref(type_name, type_args, method_name, args, expected_return, scope)
                            },
                            .Call(callee, args) then {
                                yield self.check_call_expr_ref(callee, args, expected_return, scope)
                            },
                            _ then self.check_expr_scoped_ref(v, expected_return, scope),
                        }
                        self.sema_debug("return value check done type=\(type_to_string(checked.expr_type)) file=\(self.storage.file_path)")
                        yield [TypedExpr ref]Option.Some(box(checked))
                    },
                    .None() then [TypedExpr ref]Option.None(),
                }
                return TypedStatement.ReturnStmt(typed_val, span)
            },
            .BreakStmt(span) then {
                if not self.storage.in_loop then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "'break' used outside of loop"))
                }
                if self.storage.in_finally then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "'break' is not allowed inside 'finally'"))
                }
                return TypedStatement.BreakStmt(span)
            },
            .ContinueStmt(span) then {
                if not self.storage.in_loop then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "'continue' used outside of loop"))
                }
                if self.storage.in_finally then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "'continue' is not allowed inside 'finally'"))
                }
                return TypedStatement.ContinueStmt(span)
            },
            .FinallyStmt(expr, span) then {
                if self.storage.in_finally then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "'finally' is not allowed inside 'finally'"))
                }
                let prev_in_finally = self.storage.in_finally
                self.storage.in_finally = true
                let typed_expr = self.check_expr_scoped_ref(expr, .None(), scope)
                self.storage.in_finally = prev_in_finally
                return TypedStatement.FinallyStmt(box(typed_expr), span)
            },
            .YieldStmt(expr, span) then {
                return TypedStatement.YieldStmt(box(self.check_expr_scoped_ref(expr, expected, scope)), span)
            },
        }
    }

    private describe_statement_kind(self, stmt Statement) String = {
        return when stmt in {
            .LetStmt(_, _, _, _, _) then "let",
            .PairLetStmt(_, _, _, _) then "pair-let",
            .AssignmentStmt(_, _, _, _) then "assign",
            .ExprStmt(_, _) then "expr",
            .ReturnStmt(_, _) then "return",
            .BreakStmt(_) then "break",
            .ContinueStmt(_) then "continue",
            .FinallyStmt(_, _) then "finally",
            .YieldStmt(_, _) then "yield",
        }
    }

    private assignment_target_error_name(self, target TypedExpr ref) String = {
        return when target.expr_kind in {
            .Variable(sym) then sym.name,
            .MemberExpr(_, member) then member,
            .MemberPath(_, path) then if path.is_empty() then "member" else path.at(path.count() - 1),
            .DerefExpr(_) then ".val",
            _ then "value",
        }
    }

    private is_ref_like_assignment_type(self, t Type) Bool = {
        return when t in {
            .ReferenceType(_) then true,
            .PointerType(_) then true,
            .WeakReferenceType(_) then true,
            _ then false,
        }
    }

    private assignment_target_root_identifier(self, target Expr ref) [String]Option = {
        return when target in {
            .Identifier(name) then [String]Option.Some(name),
            .MemberExpr(base, _) then self.assignment_target_root_identifier(base),
            .MemberPath(base, _) then self.assignment_target_root_identifier(base),
            .SubscriptExpr(base, _) then self.assignment_target_root_identifier(base),
            .DerefExpr(_) then [String]Option.None(),
            _ then [String]Option.None(),
        }
    }
    private lookup_assignment_root_symbol(self, name String, scope Scope) [Symbol]Option = {
        let local_sym_opt = scope.lookup(name)
        if local_sym_opt is .Some(_) then {
            return local_sym_opt
        }
        return self.storage.global_scope.lookup(name)
    }

    private assignment_target_traverses_ref_like_link(self, target TypedExpr ref) Bool = {
        return when target.expr_kind in {
            .Variable(sym) then self.is_ref_like_assignment_type(sym.symbol_type),
            .MemberExpr(base, member) then {
                let member_type = self.resolve_member_type(base.expr_type, member)
                yield if base.expr_kind is .DerefExpr(_)
                    or self.is_ref_like_assignment_type(base.expr_type)
                    or self.is_ref_like_assignment_type(member_type)
                    then true
                    else self.assignment_target_traverses_ref_like_link(base)
            },
            .MemberPath(base, _) then self.assignment_target_traverses_ref_like_link(base),
            .DerefExpr(_) then true,
            _ then false,
        }
    }

    private assignment_target_root_is_mutable_typed(self, target TypedExpr ref) Bool = {
        if self.assignment_target_traverses_ref_like_link(target) then {
            return true
        }
        return when target.expr_kind in {
            .Variable(sym) then sym.is_mutable(),
            .MemberExpr(base, _) then self.assignment_target_root_is_mutable_typed(base),
            .MemberPath(base, _) then self.assignment_target_root_is_mutable_typed(base),
            .DerefExpr(_) then true,
            _ then false,
        }
    }

    private assignment_target_root_is_mutable(self, original_target Expr ref, target TypedExpr ref, scope Scope) Bool = {
        return when self.assignment_target_root_identifier(original_target) in {
            .Some(name) then when self.lookup_assignment_root_symbol(name, scope) in {
                .Some(sym) then if sym.is_mutable()
                    then true
                    else if self.is_ref_like_assignment_type(sym.symbol_type)
                        then true
                        else self.assignment_target_root_is_mutable_typed(target),
                .None() then self.assignment_target_root_is_mutable_typed(target),
            },
            .None() then self.assignment_target_root_is_mutable_typed(target),
        }
    }

    private member_is_mutable_for_assignment(self, base_type Type, member String) Bool = {
        let inner_type = when base_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .PointerType(inner) then inner.val,
            _ then base_type,
        }
        return when inner_type in {
            .RuneType() then false,
            .StringType() then false,
            .StructureType(def_id) then when self.storage.def_id_map.get_struct_fields(def_id) in {
                .Some(fields) then {
                    let mut found = false
                    for f in fields then {
                        if f.name == member then {
                            found = true
                            return f.mutable
                        }
                    }
                    yield not found
                },
                .None() then true,
            },
            .GenericStruct(template_name, _) then when self.storage.generic_templates.lookup_struct(template_name) in {
                .Some(struct_template) then when self.storage.def_id_map.get_struct_fields(struct_template.def_id) in {
                    .Some(fields) then {
                        let mut found = false
                        for f in fields then {
                            if f.name == member then {
                                found = true
                                return f.mutable
                            }
                        }
                        yield not found
                    },
                    .None() then true,
                },
                .None() then true,
            },
            _ then true,
        }
    }

    private first_immutable_field_in_assignment_target(self, target TypedExpr ref) [String]Option = {
        return when target.expr_kind in {
            .MemberExpr(base, member) then {
                let member_type = self.resolve_member_type(base.expr_type, member)
                if base.expr_kind is .DerefExpr(_)
                    or self.is_ref_like_assignment_type(base.expr_type)
                    or self.is_ref_like_assignment_type(member_type) then {
                    return self.first_immutable_field_in_assignment_target(base)
                }
                return when self.first_immutable_field_in_assignment_target(base) in {
                    .Some(name) then [String]Option.Some(name),
                    .None() then if self.member_is_mutable_for_assignment(base.expr_type, member)
                        then [String]Option.None()
                        else [String]Option.Some(member),
                }
            },
            .MemberPath(base, path) then {
                let prior = self.first_immutable_field_in_assignment_target(base)
                if prior is .Some(_) then {
                    return prior
                }
                let mut current = base.expr_type
                let mut traverses_ref_like = if base.expr_kind is .DerefExpr(_)
                    or self.is_ref_like_assignment_type(base.expr_type)
                    then true
                    else false
                let mut idx UInt = 0
                while idx < path.count() then {
                    let segment = path.at(idx)
                    let segment_type = self.resolve_member_type(current, segment)
                    if not traverses_ref_like
                        and not self.member_is_mutable_for_assignment(current, segment) then {
                        return [String]Option.Some(segment)
                    }
                    if self.is_ref_like_assignment_type(current) or self.is_ref_like_assignment_type(segment_type) then {
                        traverses_ref_like = true
                    }
                    current = segment_type
                    idx += 1
                }
                return [String]Option.None()
            },
            _ then [String]Option.None(),
        }
    }

    private bind_pattern_vars(self, pattern PatternNode ref, subject_type Type, scope Scope) Void = {
        when pattern in {
            .Variable(name, mutable, span) then {
                if not (name == "_") then {
                    let kind = if mutable
                        then SymbolKind.Variable(VariableKind.MutableValue())
                        else SymbolKind.Variable(VariableKind.Value())
                    let def_id = self.storage.def_id_map.allocate(name, DefKind.Variable())
                    scope.define(Symbol(def_id, name, subject_type, kind))
                }
            },
            .EnumCase(case_name, elements, span) then {
                // 尝试从 subject_type 中查找 enum case 的字段类型
                let case_field_types = self.get_enum_case_field_types(subject_type, case_name)
                let mut i UInt = 0
                for elem in elements then {
                    let field_type = when case_field_types.get(i) in {
                        .Some(t) then t,
                        .None() then Type.Unknown(),
                    }
                    self.bind_pattern_vars(elem.pattern, field_type, scope)
                    i += 1
                }
            },
            .StructPattern(type_name, elements, span) then {
                let field_types = self.get_struct_pattern_field_types(subject_type, type_name)
                let mut i UInt = 0
                for elem in elements then {
                    let field_type = when field_types.get(i) in {
                        .Some(t) then t,
                        .None() then Type.Unknown(),
                    }
                    self.bind_pattern_vars(elem.pattern, field_type, scope)
                    i += 1
                }
            },
            .AndPattern(left, right, span) then {
                self.bind_pattern_vars(left, subject_type, scope)
                self.bind_pattern_vars(right, subject_type, scope)
            },
            .OrPattern(left, right, span) then {
                self.bind_pattern_vars(left, subject_type, scope)
            },
            .NotPattern(inner, span) then {
                self.bind_pattern_vars(inner, subject_type, scope)
            },
            _ then {},
        }
    }

    private ensure_pattern_bindings_present(self, pattern PatternNode ref, subject_type Type, scope Scope) Void = {
        when pattern in {
            .Variable(name, mutable, span) then {
                if not (name == "_") then {
                    if scope.lookup_local(name) is .None() then {
                        let kind = if mutable
                            then SymbolKind.Variable(VariableKind.MutableValue())
                            else SymbolKind.Variable(VariableKind.Value())
                        let def_id = self.storage.def_id_map.allocate(name, DefKind.Variable())
                        scope.define(Symbol(def_id, name, subject_type, kind))
                    }
                }
            },
            .EnumCase(case_name, elements, span) then {
                self.validate_named_pattern_arguments(elements, self.get_enum_case_param_specs(subject_type, case_name))
                let case_field_types = self.get_enum_case_field_types(subject_type, case_name)
                let mut i UInt = 0
                for elem in elements then {
                    let field_type = when case_field_types.get(i) in {
                        .Some(t) then t,
                        .None() then Type.Unknown(),
                    }
                    self.ensure_pattern_bindings_present(elem.pattern, field_type, scope)
                    i += 1
                }
            },
            .StructPattern(type_name, elements, span) then {
                self.validate_named_pattern_arguments(elements, self.get_struct_pattern_param_specs(subject_type, type_name))
                let field_types = self.get_struct_pattern_field_types(subject_type, type_name)
                let mut i UInt = 0
                for elem in elements then {
                    let field_type = when field_types.get(i) in {
                        .Some(t) then t,
                        .None() then Type.Unknown(),
                    }
                    self.ensure_pattern_bindings_present(elem.pattern, field_type, scope)
                    i += 1
                }
            },
            .AndPattern(left, right, span) then {
                self.ensure_pattern_bindings_present(left, subject_type, scope)
                self.ensure_pattern_bindings_present(right, subject_type, scope)
            },
            .OrPattern(left, right, span) then {
                self.ensure_pattern_bindings_present(left, subject_type, scope)
            },
            .NotPattern(inner, span) then {
                self.ensure_pattern_bindings_present(inner, subject_type, scope)
            },
            _ then {},
        }
    }

    private validate_named_pattern_arguments(self, elements [PatternElement]List, param_specs [FunctionParamSpec]List) Void = {
        let count = if elements.count() < param_specs.count() then elements.count() else param_specs.count()
        let mut idx UInt = 0
        while idx < count then {
            let spec = param_specs.at(idx)
            let element = elements.at(idx)
            when element.label in {
                .Some(label) then {
                    if not spec.named then {
                        self.storage.diagnostics.push(
                            make_diagnostic(
                                DiagnosticStage.Semantic(),
                                self.storage.file_path,
                                "Unexpected named argument label '\(label)' in pattern at position \(idx + 1): this parameter is positional"
                            )
                        )
                        return
                    }
                    if label <> spec.name then {
                        self.storage.diagnostics.push(
                            make_diagnostic(
                                DiagnosticStage.Semantic(),
                                self.storage.file_path,
                                "Named argument mismatch in pattern: expected '\(spec.name)', got '\(label)' at position \(idx + 1)"
                            )
                        )
                        return
                    }
                },
                .None() then {
                    if spec.named then {
                        self.storage.diagnostics.push(
                            make_diagnostic(
                                DiagnosticStage.Semantic(),
                                self.storage.file_path,
                                "Missing named argument label in pattern: expected '\(spec.name)' at position \(idx + 1)"
                            )
                        )
                        return
                    }
                },
            }
            idx += 1
        }
    }

    private enum_case_name_matches(self, pattern_case_name String, enum_case_name String) Bool = {
        if enum_case_name == pattern_case_name then { return true }
        if enum_case_name.ends_with("_" + pattern_case_name) then { return true }

        let pattern_tail = when pattern_case_name.split_last_once(".") in {
            .Some(parts) then parts.second,
            .None() then pattern_case_name,
        }
        if enum_case_name == pattern_tail then { return true }
        if enum_case_name.ends_with("_" + pattern_tail) then { return true }

        let enum_tail = when enum_case_name.split_last_once("_") in {
            .Some(parts) then parts.second,
            .None() then enum_case_name,
        }
        return enum_tail == pattern_tail
    }

    private get_enum_case_field_types(self, subject_type Type, case_name String) [Type]List = {
        let inner_type = when subject_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then subject_type,
        }
        let def_id_opt = when inner_type in {
            .EnumType(def_id) then [DefId]Option.Some(def_id),
            .GenericEnum(template, _) then when self.storage.global_scope.lookup_type(template) in {
                .Some(t) then when t in {
                    .EnumType(def_id) then [DefId]Option.Some(def_id),
                    _ then [DefId]Option.None(),
                },
                .None() then [DefId]Option.None(),
            },
            _ then [DefId]Option.None(),
        }
        return when def_id_opt in {
            .Some(def_id) then when self.storage.def_id_map.get_enum_cases(def_id) in {
                .Some(cases) then {
                    let mut bindings = [String, Type]Dict.new()
                    when inner_type in {
                        .GenericEnum(template_name, args) then {
                            if self.storage.generic_templates.lookup_enum(template_name) is .Some(enum_template) then {
                                let mut i UInt = 0
                                let param_count = enum_template.type_parameters.count()
                                let arg_count = args.count()
                                let n = if param_count < arg_count then param_count else arg_count
                                while i < n then {
                                    let tp = enum_template.type_parameters.at(i)
                                    bindings.insert(tp.name, args.at(i).val)
                                    i += 1
                                }
                            }
                        },
                        _ then {},
                    }
                    let mut result = [Type]List.new()
                    for c in cases then {
                        if self.enum_case_name_matches(case_name, c.name) then {
                            for p in c.params then {
                                let concrete_param_type = self.apply_type_bindings(p.param_type, bindings)
                                result.push(concrete_param_type)
                            }
                        }
                    }
                    yield result
                },
                .None() then [Type]List.new(),
            },
            .None() then [Type]List.new(),
        }
    }

    private get_enum_case_param_specs(self, subject_type Type, case_name String) [FunctionParamSpec]List = {
        let inner_type = when subject_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then subject_type,
        }
        let def_id_opt = when inner_type in {
            .EnumType(def_id) then [DefId]Option.Some(def_id),
            .GenericEnum(template, _) then when self.storage.global_scope.lookup_type(template) in {
                .Some(t) then when t in {
                    .EnumType(def_id) then [DefId]Option.Some(def_id),
                    _ then [DefId]Option.None(),
                },
                .None() then [DefId]Option.None(),
            },
            _ then [DefId]Option.None(),
        }
        return when def_id_opt in {
            .Some(def_id) then when self.storage.def_id_map.get_enum_cases(def_id) in {
                .Some(cases) then {
                    let mut specs = [FunctionParamSpec]List.new()
                    for c in cases then {
                        if self.enum_case_name_matches(case_name, c.name) then {
                            for p in c.params then {
                                specs.push(FunctionParamSpec(p.name, p.named))
                            }
                        }
                    }
                    yield specs
                },
                .None() then [FunctionParamSpec]List.new(),
            },
            .None() then [FunctionParamSpec]List.new(),
        }
    }

    private get_struct_pattern_field_types(self, subject_type Type, type_name String) [Type]List = {
        let inner_type = when subject_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then subject_type,
        }

        return when inner_type in {
            .StructureType(def_id) then {
                let actual_name = self.storage.def_id_map.get_name(def_id) or else self.storage.def_id_map.type_display_name(inner_type)
                let mut result = [Type]List.new()
                if actual_name == type_name then {
                    when self.storage.def_id_map.get_struct_fields(def_id) in {
                        .Some(fields) then {
                            for field in fields then {
                                result.push(field.field_type)
                            }
                        },
                        .None() then {},
                    }
                }
                yield result
            },
            .GenericStruct(template, args) then {
                let mut result = [Type]List.new()
                if template == type_name then {
                    when self.storage.generic_templates.lookup_struct(template) in {
                        .Some(struct_template) then when self.storage.def_id_map.get_struct_fields(struct_template.def_id) in {
                            .Some(fields) then {
                                let mut bindings = [String, Type]Dict.new()
                                let mut i UInt = 0
                                let param_count = struct_template.type_parameters.count()
                                let arg_count = args.count()
                                let n = if param_count < arg_count then param_count else arg_count
                                while i < n then {
                                    let tp = struct_template.type_parameters.at(i)
                                    bindings.insert(tp.name, args.at(i).val)
                                    i += 1
                                }
                                for field in fields then {
                                    result.push(self.apply_type_bindings(field.field_type, bindings))
                                }
                            },
                            .None() then {},
                        },
                        .None() then {},
                    }
                }
                yield result
            },
            _ then [Type]List.new(),
        }
    }

    private get_struct_pattern_param_specs(self, subject_type Type, type_name String) [FunctionParamSpec]List = {
        let inner_type = when subject_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then subject_type,
        }

        return when inner_type in {
            .StructureType(def_id) then {
                let actual_name = self.storage.def_id_map.get_name(def_id) or else self.storage.def_id_map.type_display_name(inner_type)
                let mut specs = [FunctionParamSpec]List.new()
                if actual_name == type_name then {
                    when self.storage.def_id_map.get_struct_fields(def_id) in {
                        .Some(fields) then {
                            for field in fields then {
                                specs.push(FunctionParamSpec(field.name, field.named))
                            }
                        },
                        .None() then {},
                    }
                }
                yield specs
            },
            .GenericStruct(template, _) then {
                let mut specs = [FunctionParamSpec]List.new()
                if template == type_name then {
                    when self.storage.generic_templates.lookup_struct(template) in {
                        .Some(struct_template) then when self.storage.def_id_map.get_struct_fields(struct_template.def_id) in {
                            .Some(fields) then {
                                for field in fields then {
                                    specs.push(FunctionParamSpec(field.name, field.named))
                                }
                            },
                            .None() then {},
                        },
                        .None() then {},
                    }
                }
                yield specs
            },
            _ then [FunctionParamSpec]List.new(),
        }
    }

    private infer_for_pattern_item_type(self, iter_type Type) Type = {
        let inner_iter_type = when iter_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then iter_type,
        }

        when inner_iter_type in {
            .GenericStruct(template, args) then {
                if (template == "List" or template == "Deque" or template == "Queue" or template == "Stack" or template == "Set") and args.count() > 0 then {
                    return args.at(0).val
                }
                if template == "Dict" and args.count() > 1 then {
                    let mut pair_args = [Type ref]List.new()
                    pair_args.push(box(args.at(0).val))
                    pair_args.push(box(args.at(1).val))
                    return Type.GenericStruct("Pair", pair_args)
                }
            },
            .StringType() then {
                return Type.RuneType()
            },
            _ then {},
        }

        let direct_next_type = self.resolve_method_return_type(inner_iter_type, "next")
        let direct_item_type = self.extract_option_result_inner(direct_next_type)
        if direct_item_type is not .Unknown() then { return direct_item_type }

        let iterator_type = self.resolve_method_return_type(inner_iter_type, "iterator")
        let next_type = self.resolve_method_return_type(iterator_type, "next")
        let item_type = self.extract_option_result_inner(next_type)
        return item_type
    }

    // 注入 trait 类型参数到 global_scope
    // 例：given Duration [Int]Scale，trait_type = Generic("Scale", [Int])
    // Scale 的 type_params = ["Scalar"]，则把 Scalar -> Int 注入
    private inject_trait_type_args(self, trait_type TypeNode, trait_name String) Void = {
        if trait_type is .Generic(_, args) then {
            // 从 TraitRegistry 查找 trait 的类型参数名
            if self.storage.trait_registry.get(trait_name) is .Some(info) then {
                let mut i UInt = 0
                for param_name in info.type_params then {
                    if self.storage.global_scope.lookup_type(param_name) is .Some(_) then {
                        i += 1
                        continue
                    }
                    if i < args.count() and args.get(i) is .Some(arg_ref) then {
                        let resolved_arg = self.resolve_type(arg_ref.val)
                        self.storage.global_scope.define_type(param_name, resolved_arg)
                    }
                    i += 1
                }
            }
        }
    }

    // 提取 Option<T> 或 Result<T> 的内部类型 T，用于 and then / or else 的 _ 绑定
    private extract_option_result_inner(self, t Type) Type = {
        if t is .GenericEnum(template, args) and (template == "Option" or template == "Result") then {
            return when args.get(0) in {
                .Some(arg_ref) then arg_ref.val,
                .None() then Type.Unknown(),
            }
        }
        return Type.Unknown()
    }

    private infer_or_else_success_type(self, t Type) Type = {
        let ok_fields = self.get_enum_case_field_types(t, "Ok")
        if not ok_fields.is_empty() then {
            return ok_fields.at((UInt)0)
        }
        let some_fields = self.get_enum_case_field_types(t, "Some")
        if not some_fields.is_empty() then {
            return some_fields.at((UInt)0)
        }
        return self.extract_option_result_inner(t)
    }

    private infer_or_else_error_binding_type(self, t Type) Type = {
        let err_fields = self.get_enum_case_field_types(t, "Error")
        if not err_fields.is_empty() then {
            return err_fields.at((UInt)0)
        }
        return when t in {
            .GenericEnum(template, args) then
                if template == "Result" and args.count() > 1
                then args.at(1).val
                else self.extract_option_result_inner(t),
            _ then self.extract_option_result_inner(t),
        }
    }

    private is_option_result_wrapper(self, t Type, template_name String) Bool = {
        when t in {
            .GenericEnum(template, _) then {
                return template == template_name
            },
            _ then {},
        }

        if template_name == "Option" then {
            return not self.get_enum_case_field_types(t, "Some").is_empty()
        }
        if template_name == "Result" then {
            return not self.get_enum_case_field_types(t, "Ok").is_empty()
                and not self.get_enum_case_field_types(t, "Error").is_empty()
        }
        return false
    }

    private compute_and_then_result_type(self, operand_type Type, transform_result_type Type) Type = {
        let has_ok = not self.get_enum_case_field_types(operand_type, "Ok").is_empty()
        let has_error = not self.get_enum_case_field_types(operand_type, "Error").is_empty()
        if has_ok and has_error then {
            if self.is_option_result_wrapper(transform_result_type, "Result") then {
                return transform_result_type
            }
            let mut args = [Type ref]List.new()
            args.push(box(transform_result_type))
            return Type.GenericEnum("Result", args)
        }

        let has_some = not self.get_enum_case_field_types(operand_type, "Some").is_empty()
        if has_some then {
            if self.is_option_result_wrapper(transform_result_type, "Option") then {
                return transform_result_type
            }
            let mut args = [Type ref]List.new()
            args.push(box(transform_result_type))
            return Type.GenericEnum("Option", args)
        }

        when operand_type in {
            .GenericEnum(template, _) then {
                if template == "Result" then {
                    if self.is_option_result_wrapper(transform_result_type, "Result") then {
                        return transform_result_type
                    }
                    let mut args = [Type ref]List.new()
                    args.push(box(transform_result_type))
                    return Type.GenericEnum("Result", args)
                }
                if template == "Option" then {
                    if self.is_option_result_wrapper(transform_result_type, "Option") then {
                        return transform_result_type
                    }
                    let mut args = [Type ref]List.new()
                    args.push(box(transform_result_type))
                    return Type.GenericEnum("Option", args)
                }
            },
            _ then {},
        }

        return transform_result_type
    }

    private refine_and_then_result_type_from_expected(self, operand_type Type, computed_type Type, expected [Type]Option) Type = {
        return when expected in {
            .Some(expected_type) then {
                let operand_is_result = not self.get_enum_case_field_types(operand_type, "Ok").is_empty()
                    and not self.get_enum_case_field_types(operand_type, "Error").is_empty()
                let operand_is_option = not self.get_enum_case_field_types(operand_type, "Some").is_empty()
                    or when operand_type in {
                        .GenericEnum(template, _) then template == "Option",
                        _ then false,
                    }

                if operand_is_result and self.is_option_result_wrapper(expected_type, "Result") then {
                    return expected_type
                }
                if operand_is_option and self.is_option_result_wrapper(expected_type, "Option") then {
                    return expected_type
                }
                return computed_type
            },
            .None() then computed_type,
        }
    }

    private resolve_member_type_ref(self, base_type_ref Type ref, member String) Type = {
        let inner_type = when base_type_ref.val in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then base_type_ref.val,
        }
        return when inner_type in {
            .RuneType() then if member == "value" then Type.UInt32Type() else Type.Unknown(),
            .StringType() then
                // String 在类型系统里有内建表示，但字段来自 std.String 结构体定义。
                when self.storage.global_scope.lookup_type("String") in {
                    .Some(t) then self.resolve_member_type(t, member),
                    .None() then Type.Unknown(),
                },
            .StructureType(def_id) then when self.storage.def_id_map.get_struct_fields(def_id) in {
                .Some(fields) then {
                    let mut found = Type.Unknown()
                    for f in fields then {
                        if f.name == member then {
                            found = f.field_type
                        }
                    }
                    yield found
                },
                .None() then Type.Unknown(),
            },
            .GenericStruct(template_name, args) then {
                // 直接从泛型模板的 def_id 读取字段，避免再次依赖全局类型表。
                let raw_field_type = when self.storage.generic_templates.lookup_struct(template_name) in {
                    .Some(struct_template) then when self.storage.def_id_map.get_struct_fields(struct_template.def_id) in {
                        .Some(fields) then {
                            let mut found = Type.Unknown()
                            for f in fields then {
                                if f.name == member then {
                                    found = f.field_type
                                }
                            }
                            yield found
                        },
                        .None() then Type.Unknown(),
                    },
                    .None() then Type.Unknown(),
                }

                // 将模板字段类型中的泛型参数替换为当前实例的实参类型。
                yield when self.storage.generic_templates.lookup_struct(template_name) in {
                    .Some(struct_template) then {
                        let mut bindings = [String, Type]Dict.new()
                        let mut i UInt = 0
                        let param_count = struct_template.type_parameters.count()
                        let arg_count = args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = struct_template.type_parameters.at(i)
                            bindings.insert(tp.name, args.at(i).val)
                            i += 1
                        }
                        yield self.apply_type_bindings(raw_field_type, bindings)
                    },
                    .None() then raw_field_type,
                }
            },
            .GenericEnum(template, _) then
                // 泛型 enum 的成员访问（通常不常见，返回 Unknown）
                Type.Unknown(),
            _ then Type.Unknown(),
        }
    }

    private resolve_member_type(self, base_type Type, member String) Type = {
        return self.resolve_member_type_ref(box(base_type), member)
    }

    private normalize_type_for_bindings(self, t Type) Type = {
        return when t in {
            .StructureType(def_id) then {
                let template_name_opt = self.storage.def_id_map.get_template_name(def_id)
                let type_args_opt = self.storage.def_id_map.get_type_arguments(def_id)
                yield when template_name_opt in {
                    .Some(template_name) then when type_args_opt in {
                        .Some(type_args) then {
                            let mut args = [Type ref]List.new()
                            for arg in type_args then {
                                args.push(box(arg))
                            }
                            yield Type.GenericStruct(template_name, args)
                        },
                        .None() then t,
                    },
                    .None() then t,
                }
            },
            .EnumType(def_id) then {
                let template_name_opt = self.storage.def_id_map.get_template_name(def_id)
                let type_args_opt = self.storage.def_id_map.get_type_arguments(def_id)
                yield when template_name_opt in {
                    .Some(template_name) then when type_args_opt in {
                        .Some(type_args) then {
                            let mut args = [Type ref]List.new()
                            for arg in type_args then {
                                args.push(box(arg))
                            }
                            yield Type.GenericEnum(template_name, args)
                        },
                        .None() then t,
                    },
                    .None() then t,
                }
            },
            _ then t,
        }
    }

    private infer_type_bindings(self, pattern Type, concrete Type, bindings [String, Type]Dict ref) Void = {
        let normalized_pattern = self.normalize_type_for_bindings(pattern)
        let normalized_concrete = self.normalize_type_for_bindings(concrete)
        when normalized_pattern in {
            .GenericParameter(name) then {
                bindings.insert(name, normalized_concrete)
            },
            .ReferenceType(p_inner) then {
                when normalized_concrete in {
                    .ReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .WeakReferenceType(p_inner) then {
                when normalized_concrete in {
                    .WeakReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .PointerType(p_inner) then {
                when normalized_concrete in {
                    .PointerType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .FunctionType(p_params, p_ret) then {
                when normalized_concrete in {
                    .FunctionType(c_params, c_ret) then {
                        if p_params.count() == c_params.count() then {
                            let mut i UInt = 0
                            while i < p_params.count() then {
                                self.infer_type_bindings(p_params.at(i).val, c_params.at(i).val, bindings)
                                i += 1
                            }
                            self.infer_type_bindings(p_ret.val, c_ret.val, bindings)
                        }
                    },
                    _ then {},
                }
            },
            .GenericStruct(p_template, p_args) then {
                when normalized_concrete in {
                    .GenericStruct(c_template, c_args) then {
                        if p_template == c_template then {
                            let p_count = p_args.count()
                            let c_count = c_args.count()
                            let min_count = if p_count < c_count then p_count else c_count
                            let mut i UInt = 0
                            while i < min_count then {
                                self.infer_type_bindings(p_args.at(i).val, c_args.at(i).val, bindings)
                                i += 1
                            }
                        }
                    },
                    _ then {},
                }
            },
            .GenericEnum(p_template, p_args) then {
                when normalized_concrete in {
                    .GenericEnum(c_template, c_args) then {
                        if p_template == c_template then {
                            let p_count = p_args.count()
                            let c_count = c_args.count()
                            let min_count = if p_count < c_count then p_count else c_count
                            let mut i UInt = 0
                            while i < min_count then {
                                self.infer_type_bindings(p_args.at(i).val, c_args.at(i).val, bindings)
                                i += 1
                            }
                        }
                    },
                    _ then {},
                }
            },
            _ then {},
        }
    }

    private apply_type_bindings(self, t Type, bindings [String, Type]Dict) Type = {
        return when t in {
            .GenericParameter(name) then when bindings.get(name) in {
                .Some(bound) then bound,
                .None() then t,
            },
            .ReferenceType(inner) then Type.ReferenceType(box(self.apply_type_bindings(inner.val, bindings))),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.apply_type_bindings(inner.val, bindings))),
            .PointerType(inner) then Type.PointerType(box(self.apply_type_bindings(inner.val, bindings))),
            .FunctionType(param_types, return_type) then {
                let mut replaced_params = [Type ref]List.new()
                for param_ref in param_types then {
                    replaced_params.push(box(self.apply_type_bindings(param_ref.val, bindings)))
                }
                yield Type.FunctionType(replaced_params, box(self.apply_type_bindings(return_type.val, bindings)))
            },
            .GenericStruct(template, args) then {
                let mut replaced = [Type ref]List.new()
                for arg_ref in args then {
                    replaced.push(box(self.apply_type_bindings(arg_ref.val, bindings)))
                }
                yield Type.GenericStruct(template, replaced)
            },
            .GenericEnum(template, args) then {
                let mut replaced = [Type ref]List.new()
                for arg_ref in args then {
                    replaced.push(box(self.apply_type_bindings(arg_ref.val, bindings)))
                }
                yield Type.GenericEnum(template, replaced)
            },
            _ then t,
        }
    }

    private concrete_receiver_for_signature(self, base_type Type, sig FunctionSignature) Type = {
        if sig.param_types.is_empty() then {
            return base_type
        }
        let inner_type = when base_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .PointerType(inner) then inner.val,
            _ then base_type,
        }
        return when sig.param_types.at((UInt)0) in {
            .ReferenceType(_) then when base_type in {
                .ReferenceType(_) then base_type,
                _ then Type.ReferenceType(box(inner_type)),
            },
            .WeakReferenceType(_) then when base_type in {
                .WeakReferenceType(_) then base_type,
                _ then Type.WeakReferenceType(box(inner_type)),
            },
            .PointerType(_) then when base_type in {
                .PointerType(_) then base_type,
                _ then Type.PointerType(box(inner_type)),
            },
            _ then inner_type,
        }
    }

    private resolve_bound_method_self_type(self, base_type Type, sig FunctionSignature) [Type]Option = {
        if sig.param_types.count() == 0 then {
            return [Type]Option.None()
        }
        let concrete_receiver_type = self.concrete_receiver_for_signature(base_type, sig)
        let mut bindings = [String, Type]Dict.new()
        self.infer_type_bindings(sig.param_types.at((UInt)0), concrete_receiver_type, bindings)
        return [Type]Option.Some(self.apply_type_bindings(sig.param_types.at((UInt)0), bindings))
    }

    private replace_type_occurrence(self, t Type, pattern Type, replacement Type) Type = {
        if self.same_expr_type(t, pattern) then {
            return replacement
        }
        return when t in {
            .ReferenceType(inner) then Type.ReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .PointerType(inner) then Type.PointerType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .GenericStruct(template, args) then {
                let mut replaced = [Type ref]List.new()
                for arg_ref in args then {
                    replaced.push(box(self.replace_type_occurrence(arg_ref.val, pattern, replacement)))
                }
                yield Type.GenericStruct(template, replaced)
            },
            .GenericEnum(template, args) then {
                let mut replaced = [Type ref]List.new()
                for arg_ref in args then {
                    replaced.push(box(self.replace_type_occurrence(arg_ref.val, pattern, replacement)))
                }
                yield Type.GenericEnum(template, replaced)
            },
            .FunctionType(params, ret) then {
                let mut replaced_params = [Type ref]List.new()
                for param_ref in params then {
                    replaced_params.push(box(self.replace_type_occurrence(param_ref.val, pattern, replacement)))
                }
                let replaced_ret = self.replace_type_occurrence(ret.val, pattern, replacement)
                yield Type.FunctionType(replaced_params, box(replaced_ret))
            },
            _ then t,
        }
    }

    private resolve_signature_return_type(self, receiver_type Type, sig FunctionSignature) Type = {
        if sig.param_types.is_empty() then {
            return sig.return_type
        }
        let mut bindings = [String, Type]Dict.new()
        self.infer_type_bindings(sig.param_types.at(0), receiver_type, bindings)
        let concrete_self_type = when receiver_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        bindings.insert("Self", concrete_self_type)
        let bound_self_type = self.apply_type_bindings(sig.param_types.at(0), bindings)
        let bound_return_type = self.apply_type_bindings(sig.return_type, bindings)
        return self.replace_type_occurrence(bound_return_type, bound_self_type, concrete_self_type)
    }

    private resolve_method_template_key(self, inner_type Type) [String]Option = {
        return when inner_type in {
            .GenericStruct(template, _) then [String]Option.Some(template),
            .GenericEnum(template, _) then [String]Option.Some(template),
            .StructureType(def_id) then self.storage.def_id_map.get_template_name(def_id),
            .EnumType(def_id) then self.storage.def_id_map.get_template_name(def_id),
            _ then [String]Option.None(),
        }
    }

    private resolve_conformance_method_signature(self, receiver_type Type, method_name String) [FunctionSignature]Option = {
        let normalized_receiver = when receiver_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }

        for template in self.storage.generic_trait_conformance_templates then {
            let mut bindings = [String, Type]Dict.new()
            if not self.conformance_type_key_matches(template.target_type, normalized_receiver, bindings) then {
                continue
            }

            let trait_name = template.trait_name
            let mut method_bindings = bindings
            when self.storage.trait_registry.get(trait_name) in {
                .Some(info) then {
                    let param_count = info.type_params.count()
                    let arg_count = template.trait_arg_types.count()
                    let n = if param_count < arg_count then param_count else arg_count
                    let mut i UInt = 0
                    while i < n then {
                        let arg_type = self.apply_type_bindings(template.trait_arg_types.at(i), bindings)
                        method_bindings.insert(info.type_params.at(i), arg_type)
                        i += 1
                    }
                },
                .None() then {},
            }

            when self.storage.trait_registry.flatten_methods(trait_name) in {
                .Ok(methods) then {
                    when methods.get(method_name) in {
                        .Some(member) then {
                            let mut bound_param_types = [Type]List.new()
                            let mut bound_param_specs = [FunctionParamSpec]List.new()
                            for param in member.params then {
                                let bound_param = self.bind_conformance_trait_self_type(self.apply_trait_self_binding(self.apply_type_bindings(param.param_type, method_bindings), receiver_type), trait_name, receiver_type)
                                bound_param_types.push(bound_param)
                                bound_param_specs.push(FunctionParamSpec(param.name, param.named))
                            }
                            let bound_return = self.bind_conformance_trait_self_type(self.apply_trait_self_binding(self.apply_type_bindings(member.return_type, method_bindings), receiver_type), trait_name, receiver_type)
                            return [FunctionSignature]Option.Some(FunctionSignature(bound_param_types, bound_return, bound_param_specs))
                        },
                        .None() then {},
                    }
                },
                .Error(_) then {},
            }
            let raw_sig_opt = self.storage.method_table.lookup(trait_name, method_name)
            if raw_sig_opt is .None() then {
                continue
            }
            let raw_sig = when raw_sig_opt in {
                .Some(sig) then sig,
                .None() then FunctionSignature([Type]List.new(), Type.Unknown(), [FunctionParamSpec]List.new()),
            }

            let mut bound_param_types = [Type]List.new()
            for param_type in raw_sig.param_types then {
                bound_param_types.push(self.bind_conformance_trait_self_type(self.apply_type_bindings(param_type, method_bindings), trait_name, receiver_type))
            }
            if not bound_param_types.is_empty() then {
                bound_param_types.set_at((UInt)0, self.concrete_receiver_for_signature(receiver_type, raw_sig))
            }
            let bound_return = self.bind_conformance_trait_self_type(self.apply_type_bindings(raw_sig.return_type, method_bindings), trait_name, receiver_type)
            return [FunctionSignature]Option.Some(FunctionSignature(bound_param_types, bound_return, raw_sig.param_specs))
        }

        return [FunctionSignature]Option.None()
    }

    private apply_trait_self_binding(self, t Type, receiver_type Type) Type = {
        let concrete_receiver = when receiver_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        let mut bindings = [String, Type]Dict.new()
        bindings.insert("Self", concrete_receiver)
        return self.apply_type_bindings(t, bindings)
    }

    private bind_conformance_trait_self_type(self, t Type, trait_name String, receiver_type Type) Type = {
        let concrete_receiver = when receiver_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        return when t in {
            .TraitObject(name) then if name == trait_name then concrete_receiver else t,
            .ReferenceType(inner) then Type.ReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .PointerType(inner) then Type.PointerType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .FunctionType(param_types, return_type) then {
                let mut replaced_params = [Type ref]List.new()
                for param_ref in param_types then {
                    replaced_params.push(box(self.bind_conformance_trait_self_type(param_ref.val, trait_name, concrete_receiver)))
                }
                yield Type.FunctionType(replaced_params, box(self.bind_conformance_trait_self_type(return_type.val, trait_name, concrete_receiver)))
            },
            .GenericStruct(template, args) then {
                let mut replaced_args = [Type ref]List.new()
                for arg_ref in args then {
                    replaced_args.push(box(self.bind_conformance_trait_self_type(arg_ref.val, trait_name, concrete_receiver)))
                }
                yield Type.GenericStruct(template, replaced_args)
            },
            .GenericEnum(template, args) then {
                let mut replaced_args = [Type ref]List.new()
                for arg_ref in args then {
                    replaced_args.push(box(self.bind_conformance_trait_self_type(arg_ref.val, trait_name, concrete_receiver)))
                }
                yield Type.GenericEnum(template, replaced_args)
            },
            _ then t,
        }
    }

    private resolve_method_return_type(self, base_type Type, method_name String) Type = {
        let inner_type = when base_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then base_type,
        }

        // Enum case 构造器：Option.Some/None、Result.Ok/Error 等返回接收者 enum 自身类型。
        when inner_type in {
            .GenericEnum(_, _) then {
                if method_name == "Some" or method_name == "None" or method_name == "Ok" or method_name == "Error" then {
                    return inner_type
                }
            },
            .EnumType(def_id) then {
                if self.storage.def_id_map.get_enum_cases(def_id) is .Some(cases) then {
                    for enum_case in cases then {
                        if self.enum_case_name_matches(method_name, enum_case.name) then {
                            return inner_type
                        }
                    }
                }
            },
            _ then {},
        }

        // GenericParameter 方法：通过约束 trait / method table 回退解析
        if inner_type is .GenericParameter(name) and self.storage.generic_param_constraints.get(name) is .Some(constraints) then {
            for trait_name in constraints then {
                when self.storage.trait_registry.flatten_methods(trait_name) in {
                    .Ok(methods) then {
                        if methods.get(method_name) is .Some(member) then {
                            return self.apply_trait_self_binding(member.return_type, inner_type)
                        }
                    },
                    .Error(_) then {},
                }
                if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
                    return sig.return_type
                }
            }
        }

        // Generic Option/Result 常用方法的返回类型快速路径
        if inner_type is .GenericEnum(template, args) then {
            if method_name == "unwrap" and args.count() > 0 then {
                return args.at(0).val
            }
            if template == "Result" and method_name == "unwrap_error" and args.count() > 1 then {
                return args.at(1).val
            }
        }

        // TraitObject 方法：从 trait registry 的扁平方法集中解析签名
        if inner_type is .TraitObject(trait_name) then {
            when self.storage.trait_registry.flatten_methods(trait_name) in {
                .Ok(methods) then {
                    if methods.get(method_name) is .Some(member) then {
                        return self.apply_trait_self_binding(member.return_type, inner_type)
                    }
                },
                .Error(_) then {},
            }
        }

        let type_key = self.storage.def_id_map.type_display_name(inner_type)
        let exact = self.storage.method_table.lookup(type_key, method_name)
        if exact is .Some(sig) then {
            return self.resolve_signature_return_type(self.concrete_receiver_for_signature(base_type, sig), sig)
        }

        let template_key = self.resolve_method_template_key(inner_type)
        when template_key in {
            .Some(key) then {
                if self.storage.method_table.lookup(key, method_name) is .Some(sig) then {
                    return self.resolve_signature_return_type(self.concrete_receiver_for_signature(base_type, sig), sig)
                }
            },
            .None() then {},
        }

        when self.resolve_conformance_method_signature(inner_type, method_name) in {
            .Some(sig) then {
                return self.resolve_signature_return_type(self.concrete_receiver_for_signature(base_type, sig), sig)
            },
            .None() then {},
        }

        return Type.Unknown()
    }

    protected resolve_method_self_type(self, base_type Type, method_name String) [Type]Option = {
        let inner_type = when base_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then base_type,
        }

        when inner_type in {
            .GenericParameter(name) then {
                if self.storage.generic_param_constraints.get(name) is .Some(constraints) then {
                    for trait_name in constraints then {
                        if self.resolve_trait_method_self_type(trait_name, method_name, inner_type) is .Some(self_type) then {
                            return [Type]Option.Some(self_type)
                        }
                        if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) and sig.param_types.count() > (UInt)0 then {
                            return [Type]Option.Some(sig.param_types.at((UInt)0))
                        }
                    }
                }
            },
            .TraitObject(trait_name) then {
                return self.resolve_trait_method_self_type(trait_name, method_name, inner_type)
            },
            _ then {},
        }

        let type_key = self.storage.def_id_map.type_display_name(inner_type)
        if self.storage.method_table.lookup(type_key, method_name) is .Some(sig) then {
            return self.resolve_bound_method_self_type(base_type, sig)
        }

        let template_key = self.resolve_method_template_key(inner_type)
        if template_key is .Some(key) and self.storage.method_table.lookup(key, method_name) is .Some(sig) then {
            return self.resolve_bound_method_self_type(base_type, sig)
        }

        when self.resolve_conformance_method_signature(inner_type, method_name) in {
            .Some(sig) then {
                return self.resolve_bound_method_self_type(base_type, sig)
            },
            .None() then {},
        }

        return [Type]Option.None()
    }

    private resolve_static_method_return_type(self, type_name String, method_name String) Type = {
        return when self.storage.method_table.lookup(type_name, method_name) in {
            .Some(sig) then sig.return_type,
            .None() then Type.Unknown(),
        }
    }

    // 从 base_type 的 method_table 中提取实例方法的参数类型列表（不含 self）。
    // 会根据 receiver_type 推断泛型绑定并应用到参数类型上。
    protected resolve_method_param_types(self, base_type Type, method_name String) [Type]List = {
        let inner_type = when base_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then base_type,
        }
        when inner_type in {
            .GenericParameter(name) then {
                if self.storage.generic_param_constraints.get(name) is .Some(constraints) then {
                    for trait_name in constraints then {
                        if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
                            return self.resolve_signature_param_types(inner_type, sig)
                        }
                        let trait_params = self.resolve_trait_method_param_types(trait_name, method_name, inner_type)
                        if not trait_params.is_empty() then {
                            return trait_params
                        }
                    }
                }
            },
            .TraitObject(trait_name) then {
                if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
                    return self.resolve_signature_param_types(inner_type, sig)
                }
                let trait_params = self.resolve_trait_method_param_types(trait_name, method_name, inner_type)
                if not trait_params.is_empty() then {
                    return trait_params
                }
            },
            _ then {},
        }
        let type_key = self.storage.def_id_map.type_display_name(inner_type)
        if self.storage.method_table.lookup(type_key, method_name) is .Some(sig) then {
            return self.resolve_signature_param_types(self.concrete_receiver_for_signature(base_type, sig), sig)
        }
        let template_key = self.resolve_method_template_key(inner_type)
        if template_key is .Some(key) and self.storage.method_table.lookup(key, method_name) is .Some(sig) then {
            return self.resolve_signature_param_types(self.concrete_receiver_for_signature(base_type, sig), sig)
        }
        when self.resolve_conformance_method_signature(inner_type, method_name) in {
            .Some(sig) then {
                return self.resolve_signature_param_types(self.concrete_receiver_for_signature(base_type, sig), sig)
            },
            .None() then {},
        }
        return [Type]List.new()
    }

    // 从 FunctionSignature 中提取参数类型（不含 self），并应用从 receiver_type 推断的泛型绑定。
    private resolve_signature_param_types(self, receiver_type Type, sig FunctionSignature) [Type]List = {
        if sig.param_types.count() <= (UInt)1 then {
            return [Type]List.new()
        }
        let mut bindings = [String, Type]Dict.new()
        self.infer_type_bindings(sig.param_types.at(0), receiver_type, bindings)
        let mut out = [Type]List.new()
        let mut i = (UInt)1
        while i < sig.param_types.count() then {
            out.push(self.apply_type_bindings(sig.param_types.at(i), bindings))
            i += (UInt)1
        }
        return out
    }

    private collect_unbound_method_generic_param_names(self, t Type, receiver_bindings [String, Type]Dict, ordered [String]List ref, seen [String]Set ref) Void = {
        when t in {
            .GenericParameter(name) then {
                if not receiver_bindings.contains_key(name) and not seen.contains(name) then {
                    seen.insert(name)
                    ordered.push(name)
                }
            },
            .ReferenceType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .WeakReferenceType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .PointerType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .FunctionType(params, ret) then {
                for p in params then {
                    self.collect_unbound_method_generic_param_names(p.val, receiver_bindings, ordered, seen)
                }
                self.collect_unbound_method_generic_param_names(ret.val, receiver_bindings, ordered, seen)
            },
            .GenericStruct(_, args) then {
                for arg in args then {
                    self.collect_unbound_method_generic_param_names(arg.val, receiver_bindings, ordered, seen)
                }
            },
            .GenericEnum(_, args) then {
                for arg in args then {
                    self.collect_unbound_method_generic_param_names(arg.val, receiver_bindings, ordered, seen)
                }
            },
            _ then {},
        }
    }

    private resolve_signature_method_type_bindings(self, receiver_type Type, sig FunctionSignature, method_type_args [Type]List) [String, Type]Dict = {
        let mut bindings = [String, Type]Dict.new()
        if not sig.param_types.is_empty() then {
            self.infer_type_bindings(sig.param_types.at(0), receiver_type, bindings)
        }
        if method_type_args.is_empty() then {
            return bindings
        }

        let mut ordered = [String]List.new()
        let mut seen = [String]Set.new()
        let mut i UInt = 1
        while i < sig.param_types.count() then {
            self.collect_unbound_method_generic_param_names(sig.param_types.at(i), bindings, ordered, seen)
            i += 1
        }
        self.collect_unbound_method_generic_param_names(sig.return_type, bindings, ordered, seen)

        let mut arg_i UInt = 0
        while arg_i < method_type_args.count() and arg_i < ordered.count() then {
            bindings.insert(ordered.at(arg_i), method_type_args.at(arg_i))
            arg_i += 1
        }
        return bindings
    }

    private resolve_signature_call_type_bindings(self, base_type Type, sig FunctionSignature, args [TypedExpr ref]List, method_type_args [Type]List) [String, Type]Dict = {
        let receiver_type = self.concrete_receiver_for_signature(base_type, sig)
        let mut bindings = self.resolve_signature_method_type_bindings(receiver_type, sig, method_type_args)
        let mut arg_i UInt = 0
        while arg_i < args.count() and arg_i + (UInt)1 < sig.param_types.count() then {
            self.infer_type_bindings(sig.param_types.at(arg_i + (UInt)1), args.at(arg_i).expr_type, bindings)
            arg_i += 1
        }
        return bindings
    }

    protected resolve_method_type_args_for_call(self, base_type Type, sig FunctionSignature, args [TypedExpr ref]List, method_type_args [Type]List) [Type]List = {
        let bindings = self.resolve_signature_call_type_bindings(base_type, sig, args, method_type_args)
        let mut ordered = [String]List.new()
        let mut seen = [String]Set.new()
        let mut i UInt = 1
        while i < sig.param_types.count() then {
            self.collect_unbound_method_generic_param_names(sig.param_types.at(i), bindings, ordered, seen)
            i += 1
        }
        self.collect_unbound_method_generic_param_names(sig.return_type, bindings, ordered, seen)

        let mut resolved = [Type]List.new()
        for name in ordered then {
            when bindings.get(name) in {
                .Some(bound) then {
                    if self.is_unresolved_expr_type(bound) or self.contains_generic_parameter(bound) then {
                        return [Type]List.new()
                    }
                    resolved.push(bound)
                },
                .None() then {
                    return [Type]List.new()
                },
            }
        }
        return resolved
    }

    protected resolve_method_return_type_for_call(self, base_type Type, sig FunctionSignature, args [TypedExpr ref]List, method_type_args [Type]List) Type = {
        let bindings = self.resolve_signature_call_type_bindings(base_type, sig, args, method_type_args)
        return self.apply_type_bindings(sig.return_type, bindings)
    }

    protected resolve_method_signature(self, base_type Type, method_name String) [FunctionSignature]Option = {
        let inner_type = when base_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then base_type,
        }

        when inner_type in {
            .GenericParameter(name) then {
                if self.storage.generic_param_constraints.get(name) is .Some(constraints) then {
                    for trait_name in constraints then {
                        when self.storage.trait_registry.flatten_methods(trait_name) in {
                            .Ok(methods) then {
                                if methods.get(method_name) is .Some(member) then {
                                    let mut param_types = [Type]List.new()
                                    let mut param_specs = [FunctionParamSpec]List.new()
                                    for p in member.params then {
                                        param_types.push(p.param_type)
                                        param_specs.push(FunctionParamSpec(p.name, p.named))
                                    }
                                    return [FunctionSignature]Option.Some(FunctionSignature(param_types, member.return_type, param_specs))
                                }
                            },
                            .Error(_) then {},
                        }
                        if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
                            return [FunctionSignature]Option.Some(sig)
                        }
                    }
                }
            },
            .TraitObject(trait_name) then {
                when self.storage.trait_registry.flatten_methods(trait_name) in {
                    .Ok(methods) then {
                        if methods.get(method_name) is .Some(member) then {
                            let mut param_types = [Type]List.new()
                                let mut param_specs = [FunctionParamSpec]List.new()
                            for p in member.params then {
                                param_types.push(p.param_type)
                                    param_specs.push(FunctionParamSpec(p.name, p.named))
                            }
                                return [FunctionSignature]Option.Some(FunctionSignature(param_types, member.return_type, param_specs))
                        }
                    },
                    .Error(_) then {},
                }
                if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
                    return [FunctionSignature]Option.Some(sig)
                }
            },
            _ then {},
        }

        let type_key = self.storage.def_id_map.type_display_name(inner_type)
        if self.storage.method_table.lookup(type_key, method_name) is .Some(sig) then {
            return [FunctionSignature]Option.Some(sig)
        }

        let template_key = self.resolve_method_template_key(inner_type)
        let template_result = when template_key in {
            .Some(key) then when self.storage.method_table.lookup(key, method_name) in {
                .Some(sig) then [FunctionSignature]Option.Some(sig),
                .None() then [FunctionSignature]Option.None(),
            },
            .None() then [FunctionSignature]Option.None(),
        }
        if template_result is .Some(_) then {
            return template_result
        }

        return self.resolve_conformance_method_signature(inner_type, method_name)
    }

    protected resolve_method_param_types_with_method_type_args(self, base_type Type, method_name String, method_type_args [Type]List) [Type]List = {
        return when self.resolve_method_signature(base_type, method_name) in {
            .Some(sig) then {
                let mut out = [Type]List.new()
                if sig.param_types.count() > (UInt)1 then {
                    let receiver_type = self.concrete_receiver_for_signature(base_type, sig)
                    let bindings = self.resolve_signature_method_type_bindings(receiver_type, sig, method_type_args)
                    let mut i UInt = 1
                    while i < sig.param_types.count() then {
                        out.push(self.apply_type_bindings(sig.param_types.at(i), bindings))
                        i += 1
                    }
                }
                yield out
            },
            .None() then self.resolve_method_param_types(base_type, method_name),
        }
    }

    protected resolve_method_return_type_with_method_type_args(self, base_type Type, method_name String, method_type_args [Type]List) Type = {
        return when self.resolve_method_signature(base_type, method_name) in {
            .Some(sig) then {
                let receiver_type = self.concrete_receiver_for_signature(base_type, sig)
                let bindings = self.resolve_signature_method_type_bindings(receiver_type, sig, method_type_args)
                yield self.apply_type_bindings(sig.return_type, bindings)
            },
            .None() then self.resolve_method_return_type(base_type, method_name),
        }
    }

    // 从 trait registry 中提取 trait 方法的参数类型列表（不含 self）。
    protected resolve_trait_method_param_types(self, trait_name String, method_name String, receiver_type Type) [Type]List = {
        if self.storage.trait_registry.flatten_methods(trait_name) is .Ok(methods) and methods.get(method_name) is .Some(member) then {
            // member.params 包含 self，跳过第一个
            if member.params.count() > (UInt)0 then {
                let mut out = [Type]List.new()
                let mut i = (UInt)1
                while i < member.params.count() then {
                    out.push(self.apply_trait_self_binding(member.params.at(i).param_type, receiver_type))
                    i += (UInt)1
                }
                return out
            }
            return [Type]List.new()
        }
        if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
            if sig.param_types.count() > (UInt)0 then {
                let concrete_receiver_type = self.concrete_receiver_for_signature(receiver_type, sig)
                let mut bindings = [String, Type]Dict.new()
                self.infer_type_bindings(sig.param_types.at((UInt)0), concrete_receiver_type, bindings)
                let mut out = [Type]List.new()
                let mut i UInt = 1
                while i < sig.param_types.count() then {
                    out.push(self.apply_type_bindings(sig.param_types.at(i), bindings))
                    i += 1
                }
                return out
            }
            return [Type]List.new()
        }
        return [Type]List.new()
    }

    protected resolve_trait_method_self_type(self, trait_name String, method_name String, receiver_type Type) [Type]Option = {
        if self.storage.trait_registry.flatten_methods(trait_name) is .Ok(methods) and methods.get(method_name) is .Some(member) and member.params.count() > (UInt)0 then {
            return [Type]Option.Some(self.apply_trait_self_binding(member.params.at((UInt)0).param_type, receiver_type))
        }
        if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
            return self.resolve_bound_method_self_type(receiver_type, sig)
        }
        return [Type]Option.None()
    }

    // 从 trait registry 解析 qualified method call 的返回类型。
    // 先查 trait registry，再回退到 base_type 的 method_table。
    protected resolve_qualified_method_return_type(self, trait_name String, method_name String, base_type Type) Type = {
        when self.storage.trait_registry.flatten_methods(trait_name) in {
            .Ok(methods) then {
                when methods.get(method_name) in {
                    .Some(member) then {
                        when member.return_type in {
                            .Unknown() then {},
                            _ then { return self.apply_trait_self_binding(member.return_type, base_type) },
                        }
                    },
                    .None() then {},
                }
            },
            .Error(_) then {},
        }
        if self.storage.method_table.lookup(trait_name, method_name) is .Some(sig) then {
            return self.resolve_signature_return_type(self.concrete_receiver_for_signature(base_type, sig), sig)
        }
        // 回退到 base_type 的 method_table
        return self.resolve_method_return_type(base_type, method_name)
    }

    // 从 method_table 中提取静态方法/enum case 构造器的参数类型列表。
    protected resolve_static_method_param_types(self, type_name String, method_name String) [Type]List = {
        return when self.storage.method_table.lookup(type_name, method_name) in {
            .Some(sig) then sig.param_types,
            .None() then
                // 尝试从 enum case 字段获取参数类型
                when self.storage.global_scope.lookup_type(type_name) in {
                    .Some(t) then self.get_enum_case_field_types(t, method_name),
                    .None() then [Type]List.new(),
                },
        }
    }

    private apply_static_method_type_bindings(self, type_name String, type_args [Type ref]List, return_type Type) Type = {
        if type_args.is_empty() then {
            return return_type
        }

        let mut bindings = [String, Type]Dict.new()
        let receiver_type = when self.storage.global_scope.lookup_type(type_name) in {
            .Some(t) then when t in {
                .StructureType(_) then Type.GenericStruct(type_name, type_args),
                .EnumType(_) then Type.GenericEnum(type_name, type_args),
                _ then Type.Unknown(),
            },
            .None() then Type.Unknown(),
        }
        when receiver_type in {
            .Unknown() then {},
            _ then { bindings.insert("Self", receiver_type) },
        }

        when self.storage.generic_templates.lookup_struct(type_name) in {
            .Some(struct_template) then {
                let mut i UInt = 0
                let param_count = struct_template.type_parameters.count()
                let arg_count = type_args.count()
                let n = if param_count < arg_count then param_count else arg_count
                while i < n then {
                    let tp = struct_template.type_parameters.at(i)
                    bindings.insert(tp.name, type_args.at(i).val)
                    i += 1
                }
            },
            .None() then {
                when self.storage.generic_templates.lookup_enum(type_name) in {
                    .Some(enum_template) then {
                        let mut i UInt = 0
                        let param_count = enum_template.type_parameters.count()
                        let arg_count = type_args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = enum_template.type_parameters.at(i)
                            bindings.insert(tp.name, type_args.at(i).val)
                            i += 1
                        }
                    },
                    .None() then {},
                }
            },
        }

        return self.apply_type_bindings(return_type, bindings)
    }

    private resolve_call_return_type(self, callee TypedExpr ref) Type = {
        when callee.expr_kind in {
            .Variable(sym) then {
                if self.storage.def_id_map.get_signature(sym.def_id) is .Some(sig) then {
                    return sig.return_type
                }
                return when sym.symbol_type in {
                    .FunctionType(_, ret) then ret.val,
                    .StructureType(_) then sym.symbol_type,
                    .EnumType(_) then sym.symbol_type,
                    .GenericStruct(_, _) then sym.symbol_type,
                    .GenericEnum(_, _) then sym.symbol_type,
                    _ then if self.storage.global_scope.lookup_type(sym.name) is .Some(t) then t else Type.Unknown(),
                }
            },
            .MemberExpr(base, method_name) then {
                return self.resolve_method_return_type(base.expr_type, method_name)
            },
            .StaticMethodCall(receiver_type, method, _) then {
                if method.symbol_type is .Unknown() then {
                    return self.resolve_method_return_type(receiver_type, method.name)
                }
                return method.symbol_type
            },
            .GenericInstantiation(_, _) then {
                return callee.expr_type
            },
            .GenericMethodCall(base, _, method, _) then {
                return self.resolve_method_return_type(base.expr_type, method.name)
            },
            .QualifiedMethodCall(base, trait_type, method, _) then {
                let trait_name = self.trait_name_from_type(trait_type)
                when self.storage.trait_registry.flatten_methods(trait_name) in {
                    .Ok(methods) then {
                        if methods.get(method.name) is .Some(member) then {
                            if member.return_type is .Unknown() then {
                                return Type.TraitObject(trait_name)
                            }
                            return member.return_type
                        }
                    },
                    .Error(_) then {},
                }
                return self.resolve_method_return_type(base.expr_type, method.name)
            },
            _ then {},
        }
        when callee.expr_type in {
            .FunctionType(_, ret) then { return ret.val },
            _ then {},
        }
        return Type.Unknown()
    }

    // 从 callee 的类型信息中提取参数类型列表，用于向调用参数传播期望类型。
    // 返回空列表表示无法确定参数类型。
    protected resolve_call_param_types(self, callee TypedExpr ref) [Type]List = {
        when callee.expr_kind in {
            .Variable(sym) then {
                if self.storage.def_id_map.get_signature(sym.def_id) is .Some(sig) then {
                    return sig.param_types
                }
                let constructor_param_types = self.struct_constructor_param_types(sym.symbol_type)
                if not constructor_param_types.is_empty() then {
                    return constructor_param_types
                }
                when sym.symbol_type in {
                    .FunctionType(params, _) then {
                        let mut out = [Type]List.new()
                        for p in params then {
                            out.push(p.val)
                        }
                        return out
                    },
                    _ then {},
                }
                return [Type]List.new()
            },
            .MemberExpr(base, method_name) then {
                return self.resolve_method_param_types(base.expr_type, method_name)
            },
            .GenericMethodCall(base, _, method, _) then {
                return self.resolve_method_param_types(base.expr_type, method.name)
            },
            .QualifiedMethodCall(base, trait_type, method, _) then {
                let trait_name = self.trait_name_from_type(trait_type)
                let trait_params = self.resolve_trait_method_param_types(trait_name, method.name, base.expr_type)
                if trait_params.is_empty() then {
                    return self.resolve_method_param_types(base.expr_type, method.name)
                }
                return trait_params
            },
            _ then {},
        }
        when callee.expr_type in {
            .FunctionType(params, _) then {
                let mut out = [Type]List.new()
                for p in params then {
                    out.push(p.val)
                }
                return out
            },
            _ then {},
        }
        return [Type]List.new()
    }

    private struct_constructor_param_types(self, constructor_type Type) [Type]List = {
        let inner_type = when constructor_type in {
            .ReferenceType(inner) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            _ then constructor_type,
        }

        return when inner_type in {
            .StructureType(def_id) then when self.storage.def_id_map.get_struct_fields(def_id) in {
                .Some(fields) then {
                    let mut types = [Type]List.new()
                    for field in fields then {
                        types.push(field.field_type)
                    }
                    yield types
                },
                .None() then [Type]List.new(),
            },
            .GenericStruct(template_name, args) then when self.storage.generic_templates.lookup_struct(template_name) in {
                .Some(struct_template) then when self.storage.def_id_map.get_struct_fields(struct_template.def_id) in {
                    .Some(fields) then {
                        let mut bindings = [String, Type]Dict.new()
                        let mut i UInt = 0
                        let param_count = struct_template.type_parameters.count()
                        let arg_count = args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = struct_template.type_parameters.at(i)
                            bindings.insert(tp.name, args.at(i).val)
                            i += 1
                        }
                        let mut types = [Type]List.new()
                        for field in fields then {
                            types.push(self.apply_type_bindings(field.field_type, bindings))
                        }
                        yield types
                    },
                    .None() then [Type]List.new(),
                },
                .None() then [Type]List.new(),
            },
            _ then [Type]List.new(),
        }
    }

    // 将 TypeSubstitution 应用到 TypedDecl（递归替换所有类型变量）
    private apply_subst_to_decl(self, subst TypeSubstitution, decl TypedDecl) TypedDecl = {
        return when decl in {
            .LetDecl(access, name, mutable, decl_type, initializer, span) then {
                yield TypedDecl.LetDecl(access, name, mutable, subst.apply(decl_type), self.apply_subst_to_expr(subst, initializer), span)
            },
            .FunctionDecl(access, name, params, return_type, body, span) then {
                yield TypedDecl.FunctionDecl(access, name, self.apply_subst_to_params(subst, params), subst.apply(return_type), self.apply_subst_to_expr(subst, body), span)
            },
            .IntrinsicFunctionDecl(access, name, params, return_type, span) then {
                yield TypedDecl.IntrinsicFunctionDecl(access, name, self.apply_subst_to_params(subst, params), subst.apply(return_type), span)
            },
            .ForeignFunctionDecl(access, name, params, return_type, span) then {
                yield TypedDecl.ForeignFunctionDecl(access, name, self.apply_subst_to_params(subst, params), subst.apply(return_type), span)
            },
            .ForeignLetDecl(access, name, mutable, decl_type, span) then {
                yield TypedDecl.ForeignLetDecl(access, name, mutable, subst.apply(decl_type), span)
            },
            .TypeStructDecl(access, name, fields, span) then {
                yield TypedDecl.TypeStructDecl(access, name, self.apply_subst_to_fields(subst, fields), span)
            },
            .TypeEnumDecl(access, name, cases, span) then {
                yield TypedDecl.TypeEnumDecl(access, name, self.apply_subst_to_enum_cases(subst, cases), span)
            },
            .TypeAliasDecl(access, name, target, span) then {
                yield TypedDecl.TypeAliasDecl(access, name, subst.apply(target), span)
            },
            .ForeignTypeDecl(access, name, fields, span) then {
                let new_fields = when fields in {
                    .Some(field_list) then [[TypedField]List]Option.Some(self.apply_subst_to_fields(subst, field_list)),
                    .None() then [[TypedField]List]Option.None(),
                }
                yield TypedDecl.ForeignTypeDecl(access, name, new_fields, span)
            },
            .TraitDecl(access, name, members, span) then {
                yield TypedDecl.TraitDecl(access, name, self.apply_subst_to_trait_members(subst, members), span)
            },
            .GenericFunctionDecl(access, name, params, return_type, body, span) then {
                yield TypedDecl.GenericFunctionDecl(access, name, self.apply_subst_to_params(subst, params), subst.apply(return_type), self.apply_subst_to_expr(subst, body), span)
            },
            .GenericTypeStructDecl(access, name, fields, span) then {
                yield TypedDecl.GenericTypeStructDecl(access, name, self.apply_subst_to_fields(subst, fields), span)
            },
            .GenericTypeEnumDecl(access, name, cases, span) then {
                yield TypedDecl.GenericTypeEnumDecl(access, name, self.apply_subst_to_enum_cases(subst, cases), span)
            },
            .GivenDecl(target_type, members, span) then {
                yield TypedDecl.GivenDecl(subst.apply(target_type), self.apply_subst_to_given_members(subst, members), span)
            },
            .GivenTraitDecl(target_type, trait_name, trait_args, members, span) then {
                let mut substituted_trait_args = [Type]List.new()
                for trait_arg in trait_args then {
                    substituted_trait_args.push(subst.apply(trait_arg))
                }
                yield TypedDecl.GivenTraitDecl(subst.apply(target_type), trait_name, substituted_trait_args, self.apply_subst_to_given_members(subst, members), span)
            },
            .IntrinsicGivenDecl(target_type, members, span) then {
                yield TypedDecl.IntrinsicGivenDecl(subst.apply(target_type), self.apply_subst_to_given_members(subst, members), span)
            },
            _ then decl,
        }
    }

    private apply_subst_to_params(self, subst TypeSubstitution, params [TypedParam]List) [TypedParam]List = {
        let mut out = [TypedParam]List.new()
        for p in params then {
            out.push(TypedParam(p.name, p.mutable, subst.apply(p.param_type), p.named))
        }
        return out
    }

    private apply_subst_to_fields(self, subst TypeSubstitution, fields [TypedField]List) [TypedField]List = {
        let mut out = [TypedField]List.new()
        for field in fields then {
            out.push(TypedField(field.access, field.name, field.mutable, subst.apply(field.field_type), field.named))
        }
        return out
    }

    private apply_subst_to_enum_cases(self, subst TypeSubstitution, cases [TypedEnumCase]List) [TypedEnumCase]List = {
        let mut out = [TypedEnumCase]List.new()
        for case_ in cases then {
            let mut new_fields = [TypedEnumCaseField]List.new()
            for field in case_.fields then {
                new_fields.push(TypedEnumCaseField(field.name, subst.apply(field.field_type), field.named))
            }
            out.push(TypedEnumCase(case_.name, new_fields))
        }
        return out
    }

    private apply_subst_to_trait_members(self, subst TypeSubstitution, members [TypedTraitMember]List) [TypedTraitMember]List = {
        let mut out = [TypedTraitMember]List.new()
        for member in members then {
            out.push(TypedTraitMember(member.name, self.apply_subst_to_params(subst, member.params), subst.apply(member.return_type)))
        }
        return out
    }

    private apply_subst_to_given_members(self, subst TypeSubstitution, members [TypedGivenMember]List) [TypedGivenMember]List = {
        let mut out = [TypedGivenMember]List.new()
        for m in members then {
            let new_body = when m.body in {
                .Some(b) then [TypedExpr ref]Option.Some(self.apply_subst_to_expr(subst, b)),
                .None() then [TypedExpr ref]Option.None(),
            }
            out.push(TypedGivenMember(m.def_id, m.name, self.apply_subst_to_params(subst, m.params), subst.apply(m.return_type), new_body))
        }
        return out
    }

    private apply_subst_to_symbol(self, subst TypeSubstitution, symbol Symbol ref) Symbol = {
        return Symbol(symbol.def_id, symbol.name, subst.apply(symbol.symbol_type), symbol.kind)
    }

    private apply_subst_to_statement(self, subst TypeSubstitution, stmt TypedStatement) TypedStatement = {
        return when stmt in {
            .LetStmt(symbol, value, span) then {
                yield TypedStatement.LetStmt(box(self.apply_subst_to_symbol(subst, symbol)), self.apply_subst_to_expr(subst, value), span)
            },
            .PairLetStmt(first_symbol, second_symbol, value, span) then {
                let new_first_symbol = when first_symbol in {
                    .Some(symbol) then [Symbol ref]Option.Some(box(self.apply_subst_to_symbol(subst, symbol))),
                    .None() then [Symbol ref]Option.None(),
                }
                let new_second_symbol = when second_symbol in {
                    .Some(symbol) then [Symbol ref]Option.Some(box(self.apply_subst_to_symbol(subst, symbol))),
                    .None() then [Symbol ref]Option.None(),
                }
                yield TypedStatement.PairLetStmt(new_first_symbol, new_second_symbol, self.apply_subst_to_expr(subst, value), span)
            },
            .AssignmentStmt(target, value, span) then {
                yield TypedStatement.AssignmentStmt(self.apply_subst_to_expr(subst, target), self.apply_subst_to_expr(subst, value), span)
            },
            .ExprStmt(expr, span) then {
                yield TypedStatement.ExprStmt(self.apply_subst_to_expr(subst, expr), span)
            },
            .ReturnStmt(value, span) then {
                let new_value = when value in {
                    .Some(expr) then [TypedExpr ref]Option.Some(self.apply_subst_to_expr(subst, expr)),
                    .None() then [TypedExpr ref]Option.None(),
                }
                yield TypedStatement.ReturnStmt(new_value, span)
            },
            .BreakStmt(_) then stmt,
            .ContinueStmt(_) then stmt,
            .FinallyStmt(expr, span) then {
                yield TypedStatement.FinallyStmt(self.apply_subst_to_expr(subst, expr), span)
            },
            .YieldStmt(expr, span) then {
                yield TypedStatement.YieldStmt(self.apply_subst_to_expr(subst, expr), span)
            },
        }
    }

    private bind_pair_let_symbol(self, binding PairBindingElement, binding_type Type, scope Scope) [Symbol ref]Option = {
        if binding.is_discard then {
            return [Symbol ref]Option.None()
        }

        if binding.name <> "_" and scope.lookup_local(binding.name) is .Some(_) then {
            self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "Duplicate definition: \(binding.name)"))
        }

        when binding.type_name in {
            .Some(type_annotation) then {
                let expected_type = self.resolve_type_in_scope(type_annotation, scope)
                if expected_type is .TraitObject(_) then {
                    self.storage.diagnostics.push(make_diagnostic(DiagnosticStage.Semantic(), self.storage.file_path, "use trait as type"))
                }
                if not self.same_expr_type(binding_type, expected_type)
                   and not self.is_unresolved_expr_type(binding_type)
                   and not self.is_unresolved_expr_type(expected_type) then {
                    self.storage.diagnostics.push(
                        make_diagnostic(
                            DiagnosticStage.Semantic(),
                            self.storage.file_path,
                            "Type mismatch: expected \(type_to_string(expected_type)), got \(type_to_string(binding_type))"
                        )
                    )
                }
            },
            .None() then {},
        }

        let kind = if binding.mutable
            then SymbolKind.Variable(VariableKind.MutableValue())
            else SymbolKind.Variable(VariableKind.Value())
        let def_id = self.storage.def_id_map.allocate(binding.name, DefKind.Variable())
        let sym = Symbol(def_id, binding.name, binding_type, kind)
        scope.define(sym)
        return [Symbol ref]Option.Some(box(sym))
    }

    private get_pair_binding_type(self, pair_type Type, field_name String) [Type]Option = {
        let field_types = self.get_struct_pattern_field_types(pair_type, "Pair")
        if field_name == "first" and field_types.count() > 0 then {
            return [Type]Option.Some(field_types.at((UInt)0))
        }
        if field_name == "second" and field_types.count() > 1 then {
            return [Type]Option.Some(field_types.at((UInt)1))
        }
        return [Type]Option.None()
    }

    private pair_binding_type_needs_literal_inference(self, binding_type [Type]Option) Bool = {
        return when binding_type in {
            .Some(t) then when t in {
                .GenericParameter(_) then true,
                _ then self.is_unresolved_expr_type(t),
            },
            .None() then true,
        }
    }

    private infer_pair_literal_binding_type(self, value Expr ref, binding PairBindingElement, index UInt, scope Scope) [Type]Option = {
        return when value in {
            .Call(callee, args) then when callee in {
                .Identifier(name) then {
                    let expected_type = when binding.type_name in {
                        .Some(type_name) then [Type]Option.Some(self.resolve_type_in_scope(type_name, scope)),
                        .None() then [Type]Option.None(),
                    }
                    yield if name <> "Pair" or args.count() <= index then [Type]Option.None() else {
                        let typed_arg = self.check_expr_scoped_ref(args.at(index), expected_type, scope)
                        yield [Type]Option.Some(self.concretize_default_literal_type(typed_arg.expr_type))
                    }
                },
                _ then [Type]Option.None(),
            },
            _ then [Type]Option.None(),
        }
    }

    private apply_subst_to_when_arms(self, subst TypeSubstitution, arms [TypedWhenArm]List) [TypedWhenArm]List = {
        let mut out = [TypedWhenArm]List.new()
        for arm in arms then {
            out.push(TypedWhenArm(arm.pattern, self.apply_subst_to_expr(subst, arm.body), subst.apply(arm.arm_type)))
        }
        return out
    }

    private apply_subst_to_expr_list(self, subst TypeSubstitution, exprs [TypedExpr ref]List) [TypedExpr ref]List = {
        let mut out = [TypedExpr ref]List.new()
        for expr in exprs then {
            out.push(self.apply_subst_to_expr(subst, expr))
        }
        return out
    }

    private apply_subst_to_expr_pair_list(self, subst TypeSubstitution, entries [TypedExprPair]List) [TypedExprPair]List = {
        let mut out = [TypedExprPair]List.new()
        for entry in entries then {
            out.push(TypedExprPair(
                self.apply_subst_to_expr(subst, entry.first),
                self.apply_subst_to_expr(subst, entry.second)
            ))
        }
        return out
    }

    private apply_subst_to_optional_expr(self, subst TypeSubstitution, expr [TypedExpr ref]Option) [TypedExpr ref]Option = {
        return when expr in {
            .Some(e) then [TypedExpr ref]Option.Some(self.apply_subst_to_expr(subst, e)),
            .None() then [TypedExpr ref]Option.None(),
        }
    }

    private apply_subst_to_expr_kind(self, subst TypeSubstitution, kind TypedExprKind ref) TypedExprKind ref = {
        return when kind in {
            .Variable(symbol) then box(TypedExprKind.Variable(box(self.apply_subst_to_symbol(subst, symbol)))),
            .IntegerLiteral(_) then kind,
            .FloatLiteral(_) then kind,
            .StringLiteral(_) then kind,
            .RuneLiteral(_) then kind,
            .BoolLiteral(_) then kind,
            .EmptyLiteral() then kind,
            .CastExpr(target_type, expr) then box(TypedExprKind.CastExpr(subst.apply(target_type), self.apply_subst_to_expr(subst, expr))),
            .Unary(op, expr) then box(TypedExprKind.Unary(op, self.apply_subst_to_expr(subst, expr))),
            .RefExpr(expr) then box(TypedExprKind.RefExpr(self.apply_subst_to_expr(subst, expr))),
            .PtrExpr(expr) then box(TypedExprKind.PtrExpr(self.apply_subst_to_expr(subst, expr))),
            .DerefExpr(expr) then box(TypedExprKind.DerefExpr(self.apply_subst_to_expr(subst, expr))),
            .ArithmeticExpr(left, op, right) then box(TypedExprKind.ArithmeticExpr(self.apply_subst_to_expr(subst, left), op, self.apply_subst_to_expr(subst, right))),
            .ComparisonExpr(left, op, right) then box(TypedExprKind.ComparisonExpr(self.apply_subst_to_expr(subst, left), op, self.apply_subst_to_expr(subst, right))),
            .BitwiseExpr(left, op, right) then box(TypedExprKind.BitwiseExpr(self.apply_subst_to_expr(subst, left), op, self.apply_subst_to_expr(subst, right))),
            .AndExpr(left, right) then box(TypedExprKind.AndExpr(self.apply_subst_to_expr(subst, left), self.apply_subst_to_expr(subst, right))),
            .OrExpr(left, right) then box(TypedExprKind.OrExpr(self.apply_subst_to_expr(subst, left), self.apply_subst_to_expr(subst, right))),
            .RangeExpr(op, left, right) then box(TypedExprKind.RangeExpr(op, self.apply_subst_to_optional_expr(subst, left), self.apply_subst_to_optional_expr(subst, right))),
            .CollectionLiteral(elements) then box(TypedExprKind.CollectionLiteral(self.apply_subst_to_expr_list(subst, elements))),
            .DictLiteral(entries) then box(TypedExprKind.DictLiteral(self.apply_subst_to_expr_pair_list(subst, entries))),
            .Call(callee, args) then box(TypedExprKind.Call(self.apply_subst_to_expr(subst, callee), self.apply_subst_to_expr_list(subst, args))),
            .IntrinsicCall(node) then {
                let new_node = when node in {
                    .AllocMemory(count, result_type) then TypedIntrinsic.AllocMemory(self.apply_subst_to_expr(subst, count), subst.apply(result_type)),
                    .DeallocMemory(pointer_expr) then TypedIntrinsic.DeallocMemory(self.apply_subst_to_expr(subst, pointer_expr)),
                    .CopyMemory(dest, source, count) then TypedIntrinsic.CopyMemory(self.apply_subst_to_expr(subst, dest), self.apply_subst_to_expr(subst, source), self.apply_subst_to_expr(subst, count)),
                    .MoveMemory(dest, source, count) then TypedIntrinsic.MoveMemory(self.apply_subst_to_expr(subst, dest), self.apply_subst_to_expr(subst, source), self.apply_subst_to_expr(subst, count)),
                    .InitMemory(pointer_expr, value_expr) then TypedIntrinsic.InitMemory(self.apply_subst_to_expr(subst, pointer_expr), self.apply_subst_to_expr(subst, value_expr)),
                    .DeinitMemory(pointer_expr) then TypedIntrinsic.DeinitMemory(self.apply_subst_to_expr(subst, pointer_expr)),
                    .TakeMemory(pointer_expr, result_type) then TypedIntrinsic.TakeMemory(self.apply_subst_to_expr(subst, pointer_expr), subst.apply(result_type)),
                    .NullPtr(result_type) then TypedIntrinsic.NullPtr(subst.apply(result_type)),
                }
                yield box(TypedExprKind.IntrinsicCall(new_node))
            },
            .MemberExpr(base, member) then box(TypedExprKind.MemberExpr(self.apply_subst_to_expr(subst, base), member)),
            .MemberPath(base, path) then box(TypedExprKind.MemberPath(self.apply_subst_to_expr(subst, base), path)),
            .Block(statements) then {
                let mut new_statements = [TypedStatement]List.new()
                for stmt in statements then {
                    new_statements.push(self.apply_subst_to_statement(subst, stmt))
                }
                yield box(TypedExprKind.Block(new_statements))
            },
            .IfExpr(condition, then_branch, else_branch) then box(TypedExprKind.IfExpr(self.apply_subst_to_expr(subst, condition), self.apply_subst_to_expr(subst, then_branch), self.apply_subst_to_optional_expr(subst, else_branch))),
            .WhileExpr(condition, body) then box(TypedExprKind.WhileExpr(self.apply_subst_to_expr(subst, condition), self.apply_subst_to_expr(subst, body))),
            .IsExpr(subject, pattern) then box(TypedExprKind.IsExpr(self.apply_subst_to_expr(subst, subject), pattern)),
            .IsNotExpr(subject, pattern) then box(TypedExprKind.IsNotExpr(self.apply_subst_to_expr(subst, subject), pattern)),
            .IfPatternExpr(subject, pattern, then_branch, else_branch) then box(TypedExprKind.IfPatternExpr(self.apply_subst_to_expr(subst, subject), pattern, self.apply_subst_to_expr(subst, then_branch), self.apply_subst_to_optional_expr(subst, else_branch))),
            .WhilePatternExpr(subject, pattern, body) then box(TypedExprKind.WhilePatternExpr(self.apply_subst_to_expr(subst, subject), pattern, self.apply_subst_to_expr(subst, body))),
            .ForExpr(pattern, iterable, body) then box(TypedExprKind.ForExpr(pattern, self.apply_subst_to_expr(subst, iterable), self.apply_subst_to_expr(subst, body))),
            .WhenExpr(subject, arms) then box(TypedExprKind.WhenExpr(self.apply_subst_to_expr(subst, subject), self.apply_subst_to_when_arms(subst, arms))),
            .LambdaExpr(params, return_type, body) then box(TypedExprKind.LambdaExpr(self.apply_subst_to_params(subst, params), subst.apply(return_type), self.apply_subst_to_expr(subst, body))),
            .ImplicitMemberExpr(member_name, args) then box(TypedExprKind.ImplicitMemberExpr(member_name, self.apply_subst_to_expr_list(subst, args))),
            .StaticMethodCall(receiver_type, method, args) then box(TypedExprKind.StaticMethodCall(subst.apply(receiver_type), box(self.apply_subst_to_symbol(subst, method)), self.apply_subst_to_expr_list(subst, args))),
            .GenericMethodCall(base, receiver_type, method, args) then box(TypedExprKind.GenericMethodCall(self.apply_subst_to_expr(subst, base), subst.apply(receiver_type), box(self.apply_subst_to_symbol(subst, method)), self.apply_subst_to_expr_list(subst, args))),
            .TraitObjectConversion(inner, trait_type, concrete_type) then box(TypedExprKind.TraitObjectConversion(self.apply_subst_to_expr(subst, inner), subst.apply(trait_type), subst.apply(concrete_type))),
            .QualifiedMethodCall(base, trait_type, method, args) then {
                let substituted_method = self.apply_subst_to_symbol(subst, method)
                let preserved_method = Symbol(substituted_method.def_id, method.name, substituted_method.symbol_type, substituted_method.kind)
                yield box(TypedExprKind.QualifiedMethodCall(self.apply_subst_to_expr(subst, base), subst.apply(trait_type), box(preserved_method), self.apply_subst_to_expr_list(subst, args)))
            },
            .GenericInstantiation(base_type, type_args) then {
                let mut new_type_args = [Type]List.new()
                for type_arg in type_args then {
                    new_type_args.push(subst.apply(type_arg))
                }
                yield box(TypedExprKind.GenericInstantiation(subst.apply(base_type), new_type_args))
            },
        }
    }

    // 将 TypeSubstitution 应用到 TypedExpr，递归替换整个 typed AST 中的类型变量。
    private apply_subst_to_expr(self, subst TypeSubstitution, expr TypedExpr ref) TypedExpr ref = {
        let new_type = subst.apply(expr.expr_type)
        let new_kind = self.apply_subst_to_expr_kind(subst, expr.expr_kind)
        return box(TypedExpr(new_kind, new_type))
    }
}


private let decl_brief_name(decl Decl) String = {
    return when decl in {
        .TypeStructDecl(_, name, _, _, _) then "TypeStruct:\(name)",
        .TypeEnumDecl(_, name, _, _, _) then "TypeUnion:\(name)",
        .TypeAliasDecl(_, name, _, _) then "TypeAlias:\(name)",
        .FunctionDecl(_, name, _, _, _, _, _) then "Function:\(name)",
        .IntrinsicFunctionDecl(_, name, _, _, _, _) then "IntrinsicFunction:\(name)",
        .ForeignFunctionDecl(_, name, _, _, _) then "ForeignFunction:\(name)",
        .LetDecl(_, name, _, _, _, _) then "Let:\(name)",
        .ForeignLetDecl(_, name, _, _, _) then "ForeignLet:\(name)",
        .IntrinsicTypeDecl(_, name, _, _) then "IntrinsicType:\(name)",
        .ForeignTypeDecl(_, name, _, _, _) then "ForeignType:\(name)",
        .ForeignUsingDecl(_, library, _) then "ForeignUsing:\(library)",
        .TraitDecl(_, name, _, _, _, _) then "Trait:\(name)",
        .GivenDecl(_, _, members, _) then "Given:\(members.count())members",
        .GivenTraitDecl(_, _, _, members, _) then "GivenTrait:\(members.count())members",
        .IntrinsicGivenDecl(_, _, members, _) then "IntrinsicGiven:\(members.count())members",
        .PathUsingDecl(_, path_segments, _, _, _, _) then "PathUsing:\(join_path(path_segments, "."))",
        .ParentUsingDecl(_, path_segments, _, _, _, _) then "ParentUsing:\(join_path(path_segments, "."))",
        .FileUsingDecl(_, file_name, alias, _) then when alias in {
            .Some(a) then "FileUsing:\"\(file_name)\" as \(a)",
            .None() then "FileUsing:\"\(file_name)\"",
        },
        _ then "OtherDecl",
    }
}

public type TypeCheckResult(
    program [TypedProgram]Option,
    diagnostics [DiagnosticError]List,
    def_id_map DefIdMap,
    generic_templates GenericTemplateRegistry,
    instantiation_requests [InstantiationRequest]List,
)

public let type_check(program Program, file_path String) TypeCheckResult = {
    let mut collector = NameCollector.new_with_context([String]List.new(), file_path)
    collector.collect(program)

    let mut diags = [DiagnosticError]List.new()

    if not collector.errors.is_empty() then {
        diags.push(make_diagnostic(DiagnosticStage.Semantic(), file_path, collector.errors.at(0)))
        return TypeCheckResult([TypedProgram]Option.None(), diags, DefIdMap.new(), GenericTemplateRegistry.new(), [InstantiationRequest]List.new())
    }

    let mut checker = TypeChecker.new(collector.global_scope, collector.def_id_map, file_path, collector.top_level_decl_def_ids)
    let typed = checker.check_program(program)

    if checker.has_errors() then {
        return TypeCheckResult([TypedProgram]Option.None(), checker.storage.diagnostics, DefIdMap.new(), GenericTemplateRegistry.new(), [InstantiationRequest]List.new())
    }

    return TypeCheckResult([TypedProgram]Option.Some(typed), diags, checker.storage.def_id_map, checker.storage.generic_templates, checker.storage.instantiation_requests)
}

// Multi-module type checking: combines std + user compilation units.
// Mirrors Swift Driver.process() std+user merge logic.
public let type_check_compilation_units(
    std_unit [CompilationUnit]Option,
    user_unit CompilationUnit,
    user_file_path String,
) TypeCheckResult = {
    // Collect all nodes with their module paths (std first, then user)
    let mut all_pairs = [[LoadedNode, [String]List]Pair]List.new()
    if std_unit is .Some(su) then {
        for pair in su.collect_all_nodes_with_path() then {
            all_pairs.push(pair)
        }
    }
    for pair in user_unit.collect_all_nodes_with_path() then {
        all_pairs.push(pair)
    }

    // Pass 1: collect all names into a shared global scope
    let mut collector = NameCollector.new_with_context([String]List.new(), user_file_path)
    collector.collect_loaded_nodes_with_path(all_pairs)

    let mut diags = [DiagnosticError]List.new()
    if not collector.errors.is_empty() then {
        diags.push(make_diagnostic(DiagnosticStage.Semantic(), user_file_path, collector.errors.at(0)))
        return TypeCheckResult([TypedProgram]Option.None(), diags, DefIdMap.new(), GenericTemplateRegistry.new(), [InstantiationRequest]List.new())
    }

    // Build merged import graph (std + user)
    let mut merged_graph = ImportGraph.new()
    if std_unit is .Some(su) then { merged_graph.merge(su.import_graph()) }
    merged_graph.merge(user_unit.import_graph())

    // Inject std prelude: make std symbols visible from all user modules
    if std_unit is .Some(su) then { inject_std_prelude_imports(su, user_unit, merged_graph.ref) }

    // Pass 2+3: type check all nodes together
    let mut checker = TypeChecker.new(collector.global_scope, collector.def_id_map, user_file_path, collector.top_level_decl_def_ids)
    checker.storage.import_graph = [ImportGraph]Option.Some(merged_graph)

    // 注入 enum 类型名称到 constraint solver，用于 Instantiate 约束判断。
    for type_entry in collector.global_scope.all_types() then {
        when type_entry.second in {
            .EnumType(_) then checker.storage.constraint_solver.register_enum_type(type_entry.first),
            _ then {},
        }
    }

    let typed = checker.check_loaded_nodes(all_pairs)

    if checker.has_errors() then {
        return TypeCheckResult([TypedProgram]Option.None(), checker.storage.diagnostics, DefIdMap.new(), GenericTemplateRegistry.new(), [InstantiationRequest]List.new())
    }

    // Pass 4: recursive type detection (three-color marking DFS)
    let mut recursive_checker = RecursiveTypeChecker.new(checker.storage.def_id_map.ref)
    let cycles = recursive_checker.check()
    for cycle in cycles then {
        let cycle_msg = cycle.path_string(checker.storage.def_id_map.ref)
        diags.push(make_diagnostic(DiagnosticStage.Semantic(), user_file_path, "Indirect recursion detected: \(cycle_msg). This creates an infinite-size type. Consider using 'ref' to break the cycle."))
    }

    if not diags.is_empty() then {
        return TypeCheckResult([TypedProgram]Option.None(), diags, DefIdMap.new(), GenericTemplateRegistry.new(), [InstantiationRequest]List.new())
    }

    return TypeCheckResult([TypedProgram]Option.Some(typed), diags, checker.storage.def_id_map, checker.storage.generic_templates, checker.storage.instantiation_requests)
}

// Inject batch imports from every module into the std root, so std symbols
// are directly accessible without explicit module prefix.
// Mirrors Swift Driver.injectStdPreludeImports().
private let inject_std_prelude_imports(
    std_unit CompilationUnit,
    user_unit CompilationUnit,
    graph ImportGraph ref,
) Void = {
    let std_root_path = std_unit.root_module().path()

    // Collect unique module paths from both units (excluding std root itself)
    let mut seen = [String]Set.new()
    let mut module_paths = [[String]List]List.new()

    let std_root_key = std_unit.root_module().path_string()

    for pair in std_unit.collect_all_nodes_with_path() then {
        let key = join_path(pair.second, ".")
        if key <> std_root_key and not seen.contains(key) then {
            seen.insert(key)
            module_paths.push(pair.second)
        }
    }
    for pair in user_unit.collect_all_nodes_with_path() then {
        let key = join_path(pair.second, ".")
        if key <> std_root_key and not seen.contains(key) then {
            seen.insert(key)
            module_paths.push(pair.second)
        }
    }

    for mod_path in module_paths then {
        // Check if already injected (source=mod_path, target=std_root, kind=BatchImport, source_file=None)
        let mut already = false
        for edge in graph.edges then {
            if string_list_eq(edge.source, mod_path) and
               string_list_eq(edge.target, std_root_path) and
               (when edge.kind in { .BatchImport() then true, _ then false }) and
               (when edge.source_file in { .None() then true, _ then false }) then {
                already = true
                break
            }
        }
        if not already then {
            graph.add_module_import(mod_path, std_root_path, ImportKind.BatchImport(), [String]Option.None())
        }
    }
}