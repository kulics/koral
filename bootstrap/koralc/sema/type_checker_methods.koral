private type BuiltinSubscriptKind {
    String(),
    List(element Type),
    Deque(element Type),
    Dict(key Type, value Type),
    Pointer(element Type, mutable Bool),
}

given TypeChecker {
    private method_param_specs(self, method Symbol) List[FunctionParamSpec] = {
        return self.context().get_param_specs(method.def_id) or else List[FunctionParamSpec].new()
    }

    private method_param_count(self, method Symbol) UInt = {
        return when method.symbol_type in {
            .FunctionType(params, _) then params.count(),
            _ then 0(UInt),
        }
    }

    private method_param_type(self, method Symbol, index UInt) Option[Type] = {
        return when method.symbol_type in {
            .FunctionType(params, _) then
                if index < params.count()
                then Option[Type].Some(params[index].val.param_type)
                else Option[Type].None(),
            _ then Option[Type].None(),
        }
    }

    private method_return_type(self, method Symbol) Type = {
        return when method.symbol_type in {
            .FunctionType(_, return_type_ref) then return_type_ref.val,
            _ then Type.Unknown(),
        }
    }

    private bind_method_symbol_type(self, method Symbol, bindings Dict[String, Type]) Symbol = {
        return Symbol(method.def_id, self.apply_type_bindings(method.symbol_type, bindings), method.kind)
    }

    private method_param_types(self, method Symbol) List[Type] = {
        return when method.symbol_type in {
            .FunctionType(params, _) then {
                let mut out = List[Type].new()
                for entry in params then {
                    out.push(entry.param_type)
                }
                yield out
            },
            _ then List[Type].new(),
        }
    }

    private rebuild_method_symbol(self, method_name String, base_method Symbol, param_types List[Type], return_type Type) Symbol = {
        let param_specs = self.method_param_specs(base_method)
        let mut typed_params = List[TypedParam].new()
        let mut idx UInt = 0
        while idx < param_types.count() then {
            let spec = if idx < param_specs.count() then param_specs[idx] else FunctionParamSpec("", false)
            let param_type = param_types[idx]
            let mutable = pass_kind_from_type(param_type) is .ByMutableReference()
            typed_params.push(TypedParam(spec.name, mutable, param_type, spec.named))
            idx += 1
        }
        return self.make_method_callable_symbol(method_name, typed_params, return_type)
    }

    protected builtin_subscript_base_type(self, t Type) Type = {
        let _ = self
        return when t in {
            .ReferenceType(inner) then inner.val,
            .MutableReferenceType(inner) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            _ then t,
        }
    }

    protected resolve_builtin_subscript_kind(self, base_type Type) Option[BuiltinSubscriptKind] = {
        let unwrapped = self.builtin_subscript_base_type(base_type)
        return when unwrapped in {
            .StructureType(def_id) then {
                let type_name = self.context().get_name(def_id) or else ""
                if type_name == "String" then {
                    return Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.String())
                }
                let template_name_opt = self.context().get_template_name(def_id)
                let type_args_opt = self.context().get_type_arguments(def_id)
                yield when template_name_opt in {
                    .Some(template_name) then when type_args_opt in {
                        .Some(type_args) then {
                            if type_args.count() == 1(UInt) and template_name == "List" then {
                                return Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.List(type_args[0(UInt)]))
                            }
                            if type_args.count() == 1(UInt) and template_name == "Deque" then {
                                return Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.Deque(type_args[0(UInt)]))
                            }
                            if type_args.count() == 2(UInt) and template_name == "Dict" then {
                                return Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.Dict(type_args[0(UInt)], type_args[1(UInt)]))
                            }
                            yield Option[BuiltinSubscriptKind].None()
                        },
                        .None() then Option[BuiltinSubscriptKind].None(),
                    },
                    .None() then Option[BuiltinSubscriptKind].None(),
                }
            },
            .GenericStruct(template_name, type_args) then {
                if template_name == "List" and type_args.count() == 1(UInt) then {
                    return Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.List(type_args[0(UInt)].val))
                }
                if template_name == "Deque" and type_args.count() == 1(UInt) then {
                    return Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.Deque(type_args[0(UInt)].val))
                }
                if template_name == "Dict" and type_args.count() == 2(UInt) then {
                    return Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.Dict(type_args[0(UInt)].val, type_args[1(UInt)].val))
                }
                yield Option[BuiltinSubscriptKind].None()
            },
            .PointerType(inner) then Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.Pointer(inner.val, false)),
            .MutablePointerType(inner) then Option[BuiltinSubscriptKind].Some(BuiltinSubscriptKind.Pointer(inner.val, true)),
            _ then Option[BuiltinSubscriptKind].None(),
        }
    }

    protected build_builtin_subscript_helper_call(self, base TypedExpr, args List[ref TypedExpr], helper_name String) TypedExpr = {
        let expected_self_type = self.resolve_method_self_type(base.expr_type, helper_name)
        let prepared_base = self.prepare_call_receiver(base, expected_self_type)
        let adapted_base = self.adapt_receiver_to_expected_self_type_for_method(prepared_base.first, expected_self_type, helper_name)
        let param_types = self.resolve_method_param_types(adapted_base.expr_type, helper_name)

        let mut typed_args = List[ref TypedExpr].new()
        let mut arg_idx UInt = 0
        for arg_ref in args then {
            let expected_arg_type = when param_types.get(arg_idx) in {
                .Some(param_type) then Option[Type].Some(param_type),
                .None() then Option[Type].None(),
            }
            typed_args.push(box(self.adapt_expr_to_expected_type(arg_ref.val, expected_arg_type)))
            arg_idx += 1
        }

        let normalized_base_type = self.builtin_subscript_base_type(base.expr_type)
        self.maybe_record_extension_method_instantiation(normalized_base_type, helper_name, List[Type].new())
        let return_type = self.resolve_method_return_type(adapted_base.expr_type, helper_name)
        let method_symbol = self.make_method_symbol(helper_name, return_type)
        let callee = make_typed_expr(
            TypedExprKind.MethodReference(box(adapted_base), adapted_base.expr_type, box(method_symbol), List[Type].new(), List[Type].new(), .None()),
            method_symbol.symbol_type,
        )
        let call_expr = make_typed_expr(TypedExprKind.Call(box(callee), typed_args), return_type)
        return self.wrap_receiver_materialized_call(prepared_base.second, base, call_expr)
    }

    protected resolve_builtin_subscript_as_reference(self, base TypedExpr, args List[ref TypedExpr], mutable Bool) TypedExpr = {
        return when self.resolve_builtin_subscript_kind(base.expr_type) in {
            .Some(kind) then when kind in {
                .String() then {
                    self.push_diagnostic_at_span("String subscript is not addressable", self.typed_expr_span(box(base)))
                    yield make_typed_expr(TypedExprKind.Block(List[ref TypedStatement].new()), Type.Unknown())
                },
                .Dict(_, _) or .List(_) or .Deque(_) then {
                    let helper_name = if mutable then "__index_mut_ref" else "__index_ref"
                    yield self.build_builtin_subscript_helper_call(base, args, helper_name)
                },
                .Pointer(element_type, _) then {
                    let index_expr = if args.is_empty()
                        then make_typed_expr(TypedExprKind.IntegerLiteral("0"), Type.UIntType())
                        else args[0(UInt)].val
                    let pointer_base_type = self.builtin_subscript_base_type(base.expr_type)
                    let pointer_expr = when base.expr_type in {
                        .ReferenceType(_) then make_typed_expr(TypedExprKind.DerefExpr(box(base)), pointer_base_type),
                        .MutableReferenceType(_) then make_typed_expr(TypedExprKind.DerefExpr(box(base)), pointer_base_type),
                        .BorrowedReferenceType(_, _) then make_typed_expr(TypedExprKind.DerefExpr(box(base)), pointer_base_type),
                        .MutableBorrowedReferenceType(_, _) then make_typed_expr(TypedExprKind.DerefExpr(box(base)), pointer_base_type),
                        _ then base,
                    }
                    let offset_expr = make_typed_expr(
                        TypedExprKind.ArithmeticExpr(box(pointer_expr), ArithmeticOperator.Add(), box(index_expr)),
                        pointer_base_type,
                    )
                    let deref_expr = make_typed_expr(TypedExprKind.DerefExpr(box(offset_expr)), element_type)
                    let expected_ref_type = if mutable
                        then Option[Type].Some(Type.MutableReferenceType(box(element_type)))
                        else Option[Type].Some(Type.ReferenceType(box(element_type)))
                    yield self.adapt_expr_to_expected_type(deref_expr, expected_ref_type)
                },
            },
            .None() then {
                self.push_diagnostic_at_span(
                    "subscript is only supported for String, List, Deque, Dict, and pointer types",
                    self.typed_expr_span(box(base))
                )
                yield make_typed_expr(TypedExprKind.Block(List[ref TypedStatement].new()), Type.Unknown())
            },
        }
    }

    protected lookup_method_signature(self, type_key String, method_name String) Option[Symbol] = {
        return self.storage.method_table.lookup(type_key, method_name)
    }

    private inject_trait_type_args(self, trait_type TypeNode, trait_name String) Void = {
        self.inject_trait_type_args_with_bindings(trait_type, trait_name, Dict[String, Type].new())
    }

    private inject_trait_type_args_with_bindings(self, trait_type TypeNode, trait_name String, bindings Dict[String, Type]) Void = {
        if trait_type is .Generic(_, args) then {
            // Create a child scope with trait type params instead of mutating global_scope
            // (Swift: withNewScope { defineGenericParameter(...) })
            if self.storage.trait_registry.get(trait_name) is .Some(info) then {
                let mut child = Scope.new_child(self.storage.global_scope)
                let mut i UInt = 0
                for param_name in info.type_params then {
                    if i < args.count() and args.get(i) is .Some(arg_ref) then {
                        let resolved_arg = self.resolve_type_with_bindings(arg_ref.val, bindings)
                        child.define_type(param_name, resolved_arg)
                    }
                    i += 1
                }
                self.storage.current_scope = child
            }
        }
    }

    /// Bind type parameters from ancestor traits in the inheritance chain.
    /// For example, if FloatingPoint inherits Numeric which inherits [Self]Add,
    /// then Add's type parameter R should be bound to self_type.
    /// This is needed when resolving method signatures inherited from generic parent traits.
    private bind_ancestor_trait_type_params(self, trait_name String, self_type Type) Void = {
        let mut visited = Set[String].new()
        self.bind_ancestor_trait_type_params_recursive(trait_name, self_type, visited.ref)
    }

    private bind_ancestor_trait_type_params_recursive(self, trait_name String, self_type Type, visited ref mut Set[String]) Void = {
        if visited.contains(trait_name) then { return }
        visited.insert(trait_name);
        when self.storage.trait_registry.get(trait_name) in {
            .Some(info) then {
                for parent in info.parent_traits then {
                    when self.storage.trait_registry.get(parent.name) in {
                        .Some(parent_info) then {
                            if not parent.type_arg_nodes.is_empty() and not parent_info.type_params.is_empty() then {
                                // Generic parent — resolve arg nodes in a child scope (Swift: withNewScope)
                                let prev_scope = self.storage.current_scope
                                finally { self.storage.current_scope = prev_scope }
                                let child = Scope.new_child(self.storage.current_scope)
                                child.define_type("Self", self_type)
                                // Set current_scope BEFORE resolving so generic params are visible
                                self.storage.current_scope = child
                                let mut idx UInt = 0
                                while idx < parent_info.type_params.count() and idx < parent.type_arg_nodes.count() then {
                                    let param_name = parent_info.type_params[idx]
                                    let resolved = self.resolve_type(parent.type_arg_nodes[idx])
                                    child.define_type(param_name, resolved)
                                    idx += 1
                                }
                                // Recurse with child scope active
                                self.bind_ancestor_trait_type_params_recursive(parent.name, self_type, visited)
                            }
                        },
                        .None() then {},
                    }
                }
            },
            .None() then {},
        }
    }

    // 提取 Option<T> 或 Result<T> 的内部类型 T，用于 and then / or else 的 _ 绑定
    private extract_option_result_inner(self, t Type) Type = {
        if t is .GenericEnum(template, args) and (template == "Option" or template == "Result") then {
            return when args.get(0) in {
                .Some(arg_ref) then arg_ref.val,
                .None() then Type.Unknown(),
            }
        }
        return Type.Unknown()
    }

    private infer_or_else_success_type(self, t Type) Type = {
        let ok_fields = self.get_enum_case_field_types(t, "Ok")
        if not ok_fields.is_empty() then {
            return ok_fields[0(UInt)]
        }
        let some_fields = self.get_enum_case_field_types(t, "Some")
        if not some_fields.is_empty() then {
            return some_fields[0(UInt)]
        }
        return self.extract_option_result_inner(t)
    }

    private infer_or_else_error_binding_type(self, t Type) Type = {
        let err_fields = self.get_enum_case_field_types(t, "Error")
        if not err_fields.is_empty() then {
            return err_fields[0(UInt)]
        }
        return when t in {
            .GenericEnum(template, args) then
                if template == "Result" and args.count() > 1
                then args[1].val
                else self.extract_option_result_inner(t),
            _ then self.extract_option_result_inner(t),
        }
    }

    private is_option_result_wrapper(self, t Type, template_name String) Bool = {
        when t in {
            .GenericEnum(template, _) then {
                return template == template_name
            },
            _ then {},
        }

        if template_name == "Option" then {
            return not self.get_enum_case_field_types(t, "Some").is_empty()
        }
        if template_name == "Result" then {
            return not self.get_enum_case_field_types(t, "Ok").is_empty()
                and not self.get_enum_case_field_types(t, "Error").is_empty()
        }
        return false
    }

    private compute_and_then_result_type(self, operand_type Type, transform_result_type Type) Type = {
        let has_ok = not self.get_enum_case_field_types(operand_type, "Ok").is_empty()
        let has_error = not self.get_enum_case_field_types(operand_type, "Error").is_empty()
        if has_ok and has_error then {
            if self.is_option_result_wrapper(transform_result_type, "Result") then {
                return transform_result_type
            }
            let mut args = List[ref Type].new()
            args.push(box(transform_result_type))
            return Type.GenericEnum("Result", args)
        }

        let has_some = not self.get_enum_case_field_types(operand_type, "Some").is_empty()
        if has_some then {
            if self.is_option_result_wrapper(transform_result_type, "Option") then {
                return transform_result_type
            }
            let mut args = List[ref Type].new()
            args.push(box(transform_result_type))
            return Type.GenericEnum("Option", args)
        }

        when operand_type in {
            .GenericEnum(template, _) then {
                if template == "Result" then {
                    if self.is_option_result_wrapper(transform_result_type, "Result") then {
                        return transform_result_type
                    }
                    let mut args = List[ref Type].new()
                    args.push(box(transform_result_type))
                    return Type.GenericEnum("Result", args)
                }
                if template == "Option" then {
                    if self.is_option_result_wrapper(transform_result_type, "Option") then {
                        return transform_result_type
                    }
                    let mut args = List[ref Type].new()
                    args.push(box(transform_result_type))
                    return Type.GenericEnum("Option", args)
                }
            },
            _ then {},
        }

        return transform_result_type
    }

    private refine_and_then_result_type_from_expected(self, operand_type Type, computed_type Type, expected Option[Type]) Type = {
        return when expected in {
            .Some(expected_type) then {
                let operand_is_result = not self.get_enum_case_field_types(operand_type, "Ok").is_empty()
                    and not self.get_enum_case_field_types(operand_type, "Error").is_empty()
                let operand_is_option = not self.get_enum_case_field_types(operand_type, "Some").is_empty()
                    or when operand_type in {
                        .GenericEnum(template, _) then template == "Option",
                        _ then false,
                    }

                if operand_is_result and self.is_option_result_wrapper(expected_type, "Result") then {
                    return expected_type
                }
                if operand_is_option and self.is_option_result_wrapper(expected_type, "Option") then {
                    return expected_type
                }
                return computed_type
            },
            .None() then computed_type,
        }
    }

    private resolve_member_type_ref(self, base_type_ref ref Type, member String) Type = {
        let inner_type = when base_type_ref.val in {
            .MutableReferenceType(inner) then inner.val,
            .MutablePointerType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            .PointerType(inner) then inner.val,
            _ then base_type_ref.val,
        }
        return when inner_type in {
            .StructureType(def_id) then {
                let fields_opt = when self.context().is_foreign_struct(def_id) in {
                    true then self.context().get_foreign_struct_fields(def_id),
                    false then self.context().get_struct_fields(def_id),
                }
                yield when fields_opt in {
                    .Some(fields) then {
                        let mut found = Type.Unknown()
                        for f in fields then {
                            if f.name == member then {
                                if self.context().is_foreign_struct(def_id) or self.is_field_accessible_from_current_context(f.access, def_id) then {
                                    found = f.field_type
                                } else {
                                    let access_label = when f.access in {
                                        .Private() then "private",
                                        _ then "protected",
                                    }
                                    self.storage.diagnostics.push(
                                        make_diagnostic(
                                            DiagnosticStage.Semantic(),
                                            self.storage.file_path,
                                            "Cannot access \(access_label) field '\(member)' of type '\(self.context().get_name(def_id) or else self.context().type_display_name(inner_type))'"
                                        )
                                    )
                                }
                                break
                            }
                        }
                        yield found
                    },
                    .None() then Type.Unknown(),
                }
            },
            .GenericStruct(template_name, args) then {
                // 直接从泛型模板的 def_id 读取字段，避免再次依赖全局类型表。
                let raw_field_type = when self.storage.generic_templates.lookup_struct(template_name) in {
                    .Some(struct_template) then when self.context().get_struct_fields(struct_template.def_id) in {
                        .Some(fields) then {
                            let mut found = Type.Unknown()
                            for f in fields then {
                                if f.name == member then {
                                    if self.is_field_accessible_from_current_context(f.access, struct_template.def_id) then {
                                        found = f.field_type
                                    } else {
                                        let access_label = when f.access in {
                                            .Private() then "private",
                                            _ then "protected",
                                        }
                                        self.storage.diagnostics.push(
                                            make_diagnostic(
                                                DiagnosticStage.Semantic(),
                                                self.storage.file_path,
                                                "Cannot access \(access_label) field '\(member)' of type '\(template_name)'"
                                            )
                                        )
                                    }
                                    break
                                }
                            }
                            yield found
                        },
                        .None() then Type.Unknown(),
                    },
                    .None() then Type.Unknown(),
                }

                // 将模板字段类型中的泛型参数替换为当前实例的实参类型。
                yield when self.storage.generic_templates.lookup_struct(template_name) in {
                    .Some(struct_template) then {
                        let mut bindings = Dict[String, Type].new()
                        let mut i UInt = 0
                        let param_count = struct_template.type_parameters.count()
                        let arg_count = args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = struct_template.type_parameters[i]
                            bindings.insert(tp.name, args[i].val)
                            i += 1
                        }
                        yield self.apply_type_bindings(raw_field_type, bindings)
                    },
                    .None() then raw_field_type,
                }
            },
            .GenericEnum(template, _) then
                // 泛型 enum 的成员访问（通常不常见，返回 Unknown）
                Type.Unknown(),
            _ then Type.Unknown(),
        }
    }

    private resolve_member_type(self, base_type Type, member String) Type = {
        return self.resolve_member_type_ref(box(base_type), member)
    }

    private normalize_type_for_bindings(self, t Type) Type = {
        return when t in {
            .StructureType(def_id) then {
                let template_name_opt = self.context().get_template_name(def_id)
                let type_args_opt = self.context().get_type_arguments(def_id)
                yield when template_name_opt in {
                    .Some(template_name) then when type_args_opt in {
                        .Some(type_args) then {
                            let mut args = List[ref Type].new()
                            for arg in type_args then {
                                args.push(box(arg))
                            }
                            yield Type.GenericStruct(template_name, args)
                        },
                        .None() then t,
                    },
                    .None() then t,
                }
            },
            .EnumType(def_id) then {
                let template_name_opt = self.context().get_template_name(def_id)
                let type_args_opt = self.context().get_type_arguments(def_id)
                yield when template_name_opt in {
                    .Some(template_name) then when type_args_opt in {
                        .Some(type_args) then {
                            let mut args = List[ref Type].new()
                            for arg in type_args then {
                                args.push(box(arg))
                            }
                            yield Type.GenericEnum(template_name, args)
                        },
                        .None() then t,
                    },
                    .None() then t,
                }
            },
            _ then t,
        }
    }

    private infer_type_bindings(self, pattern Type, concrete Type, bindings ref mut Dict[String, Type]) Void = {
        let normalized_pattern = self.normalize_type_for_bindings(pattern)
        let normalized_concrete = self.normalize_type_for_bindings(concrete)
        when normalized_pattern in {
            .GenericParameter(name) then {
                when bindings.get(name) in {
                    .Some(existing) then {
                        if self.same_expr_type(existing, normalized_concrete) then {
                        }
                    },
                    .None() then {
                        bindings.insert(name, normalized_concrete)
                    },
                }
            },
            .ReferenceType(p_inner) then {
                when normalized_concrete in {
                    .ReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutableReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .BorrowedReferenceType(c_inner, _) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .MutableReferenceType(p_inner) then {
                when normalized_concrete in {
                    .MutableReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .BorrowedReferenceType(p_inner, _) then {
                when normalized_concrete in {
                    .ReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutableReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .BorrowedReferenceType(c_inner, _) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .MutableBorrowedReferenceType(p_inner, _) then {
                when normalized_concrete in {
                    .MutableReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .WeakReferenceType(p_inner) then {
                when normalized_concrete in {
                    .WeakReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutableWeakReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .MutableWeakReferenceType(p_inner) then {
                when normalized_concrete in {
                    .MutableWeakReferenceType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .PointerType(p_inner) then {
                when normalized_concrete in {
                    .PointerType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    .MutablePointerType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .MutablePointerType(p_inner) then {
                when normalized_concrete in {
                    .MutablePointerType(c_inner) then self.infer_type_bindings(p_inner.val, c_inner.val, bindings),
                    _ then {},
                }
            },
            .FunctionType(p_params, p_ret) then {
                when normalized_concrete in {
                    .FunctionType(c_params, c_ret) then {
                        if p_params.count() == c_params.count() then {
                            let mut i UInt = 0
                            while i < p_params.count() then {
                                self.infer_type_bindings(p_params[i].val.param_type, c_params[i].val.param_type, bindings)
                                i += 1
                            }
                            self.infer_type_bindings(p_ret.val, c_ret.val, bindings)
                        }
                    },
                    _ then {},
                }
            },
            .GenericStruct(p_template, p_args) then {
                when normalized_concrete in {
                    .GenericStruct(c_template, c_args) then {
                        if p_template == c_template and p_args.count() == c_args.count() then {
                            let mut i UInt = 0
                            while i < p_args.count() then {
                                self.infer_type_bindings(p_args[i].val, c_args[i].val, bindings)
                                i += 1
                            }
                        }
                    },
                    _ then {},
                }
            },
            .GenericEnum(p_template, p_args) then {
                when normalized_concrete in {
                    .GenericEnum(c_template, c_args) then {
                        if p_template == c_template and p_args.count() == c_args.count() then {
                            let mut i UInt = 0
                            while i < p_args.count() then {
                                self.infer_type_bindings(p_args[i].val, c_args[i].val, bindings)
                                i += 1
                            }
                        }
                    },
                    _ then {},
                }
            },
            _ then {},
        }
    }

    private infer_type_bindings_persistent(self, pattern Type, concrete Type, bindings Dict[String, Type]) Dict[String, Type] = {
        let normalized_pattern = self.normalize_type_for_bindings(pattern)
        let normalized_concrete = self.normalize_type_for_bindings(concrete)
        return when normalized_pattern in {
            .GenericParameter(name) then {
                yield when bindings.get(name) in {
                    .Some(existing) then if self.same_expr_type(existing, normalized_concrete) then bindings else bindings,
                    .None() then {
                        let mut next_bindings = bindings
                        next_bindings.insert(name, normalized_concrete)
                        yield next_bindings
                    },
                }
            },
            .ReferenceType(p_inner) then when normalized_concrete in {
                .ReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutableReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .BorrowedReferenceType(c_inner, _) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .MutableReferenceType(p_inner) then when normalized_concrete in {
                .MutableReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .BorrowedReferenceType(p_inner, _) then when normalized_concrete in {
                .ReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutableReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .BorrowedReferenceType(c_inner, _) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .MutableBorrowedReferenceType(p_inner, _) then when normalized_concrete in {
                .MutableReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutableBorrowedReferenceType(c_inner, _) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .WeakReferenceType(p_inner) then when normalized_concrete in {
                .WeakReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutableWeakReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .MutableWeakReferenceType(p_inner) then when normalized_concrete in {
                .MutableWeakReferenceType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .PointerType(p_inner) then when normalized_concrete in {
                .PointerType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                .MutablePointerType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .MutablePointerType(p_inner) then when normalized_concrete in {
                .MutablePointerType(c_inner) then self.infer_type_bindings_persistent(p_inner.val, c_inner.val, bindings),
                _ then bindings,
            },
            .FunctionType(p_params, p_ret) then when normalized_concrete in {
                .FunctionType(c_params, c_ret) then {
                    if p_params.count() <> c_params.count() then {
                        return bindings
                    }
                    let mut current_bindings = bindings
                    let mut i UInt = 0
                    while i < p_params.count() then {
                        current_bindings = self.infer_type_bindings_persistent(p_params[i].val.param_type, c_params[i].val.param_type, current_bindings)
                        i += 1
                    }
                    yield self.infer_type_bindings_persistent(p_ret.val, c_ret.val, current_bindings)
                },
                _ then bindings,
            },
            .GenericStruct(p_template, p_args) then when normalized_concrete in {
                .GenericStruct(c_template, c_args) then {
                    if not (p_template == c_template and p_args.count() == c_args.count()) then {
                        return bindings
                    }
                    let mut current_bindings = bindings
                    let mut i UInt = 0
                    while i < p_args.count() then {
                        current_bindings = self.infer_type_bindings_persistent(p_args[i].val, c_args[i].val, current_bindings)
                        i += 1
                    }
                    yield current_bindings
                },
                _ then bindings,
            },
            .GenericEnum(p_template, p_args) then when normalized_concrete in {
                .GenericEnum(c_template, c_args) then {
                    if not (p_template == c_template and p_args.count() == c_args.count()) then {
                        return bindings
                    }
                    let mut current_bindings = bindings
                    let mut i UInt = 0
                    while i < p_args.count() then {
                        current_bindings = self.infer_type_bindings_persistent(p_args[i].val, c_args[i].val, current_bindings)
                        i += 1
                    }
                    yield current_bindings
                },
                _ then bindings,
            },
            _ then bindings,
        }
    }

    private apply_type_bindings(self, t Type, bindings Dict[String, Type]) Type = {
        return when t in {
            .GenericParameter(name) then when bindings.get(name) in {
                .Some(bound) then bound,
                .None() then t,
            },
            .ReferenceType(inner) then Type.ReferenceType(box(self.apply_type_bindings(inner.val, bindings))),
            .MutableReferenceType(inner) then Type.MutableReferenceType(box(self.apply_type_bindings(inner.val, bindings))),
            .BorrowedReferenceType(inner, lt) then Type.BorrowedReferenceType(box(self.apply_type_bindings(inner.val, bindings)), lt),
            .MutableBorrowedReferenceType(inner, lt) then Type.MutableBorrowedReferenceType(box(self.apply_type_bindings(inner.val, bindings)), lt),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.apply_type_bindings(inner.val, bindings))),
            .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(self.apply_type_bindings(inner.val, bindings))),
            .PointerType(inner) then Type.PointerType(box(self.apply_type_bindings(inner.val, bindings))),
            .MutablePointerType(inner) then Type.MutablePointerType(box(self.apply_type_bindings(inner.val, bindings))),
            .FunctionType(fn_params, return_type) then {
                let param_types = param_entry_types(fn_params)
                let mut replaced_params = List[ref Type].new()
                for param_ref in param_types then {
                    replaced_params.push(box(self.apply_type_bindings(param_ref.val, bindings)))
                }
                yield Type.FunctionType(types_to_param_entries(replaced_params), box(self.apply_type_bindings(return_type.val, bindings)))
            },
            .GenericStruct(template, args) then {
                let mut replaced = List[ref Type].new()
                for arg_ref in args then {
                    replaced.push(box(self.apply_type_bindings(arg_ref.val, bindings)))
                }
                yield Type.GenericStruct(template, replaced)
            },
            .GenericEnum(template, args) then {
                let mut replaced = List[ref Type].new()
                for arg_ref in args then {
                    replaced.push(box(self.apply_type_bindings(arg_ref.val, bindings)))
                }
                yield Type.GenericEnum(template, replaced)
            },
            _ then t,
        }
    }

    private normalize_method_receiver_type(self, base_type Type) Type = {
        return when base_type in {
            .MutableReferenceType(inner) then Type.MutableReferenceType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val)))),
            .ReferenceType(inner) then Type.ReferenceType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val)))),
            .MutableBorrowedReferenceType(inner, lt) then Type.MutableBorrowedReferenceType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val))), lt),
            .BorrowedReferenceType(inner, lt) then Type.BorrowedReferenceType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val))), lt),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val)))),
            .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val)))),
            .MutablePointerType(inner) then Type.MutablePointerType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val)))),
            .PointerType(inner) then Type.PointerType(box(self.canonicalize_alias_type(self.concretize_default_literal_type(inner.val)))),
            _ then self.canonicalize_alias_type(self.concretize_default_literal_type(base_type)),
        }
    }

    private receiver_type_args(self, inner_type Type) List[Type] = {
        return when inner_type in {
            .GenericStruct(_, args) then {
                let mut out = List[Type].new()
                for arg in args then {
                    out.push(arg.val)
                }
                yield out
            },
            .GenericEnum(_, args) then {
                let mut out = List[Type].new()
                for arg in args then {
                    out.push(arg.val)
                }
                yield out
            },
            .StructureType(def_id) then self.context().get_type_arguments(def_id) or else List[Type].new(),
            .EnumType(def_id) then self.context().get_type_arguments(def_id) or else List[Type].new(),
            _ then List[Type].new(),
        }
    }

    private generic_extension_lookup_key(self, inner_type Type) Option[String] = {
        return when inner_type in {
            .GenericStruct(template_name, _) then when self.storage.generic_templates.lookup_extension_methods(template_name) in {
                .Some(_) then Option[String].Some(template_name),
                .None() then Option[String].None(),
            },
            .GenericEnum(template_name, _) then when self.storage.generic_templates.lookup_extension_methods(template_name) in {
                .Some(_) then Option[String].Some(template_name),
                .None() then Option[String].None(),
            },
            .StructureType(def_id) then {
                when self.context().get_template_name(def_id) in {
                    .Some(template_name) then when self.storage.generic_templates.lookup_extension_methods(template_name) in {
                        .Some(_) then { return Option[String].Some(template_name) },
                        .None() then {},
                    },
                    .None() then {},
                }
                let type_name = self.context().get_name(def_id) or else ""
                yield when self.storage.generic_templates.lookup_extension_methods(type_name) in {
                    .Some(_) then Option[String].Some(type_name),
                    .None() then Option[String].None(),
                }
            },
            .EnumType(def_id) then {
                when self.context().get_template_name(def_id) in {
                    .Some(template_name) then when self.storage.generic_templates.lookup_extension_methods(template_name) in {
                        .Some(_) then { return Option[String].Some(template_name) },
                        .None() then {},
                    },
                    .None() then {},
                }
                let type_name = self.context().get_name(def_id) or else ""
                yield when self.storage.generic_templates.lookup_extension_methods(type_name) in {
                    .Some(_) then Option[String].Some(type_name),
                    .None() then Option[String].None(),
                }
            },
            .ReferenceType(_) then when self.storage.generic_templates.lookup_extension_methods("Ref") in {
                .Some(_) then Option[String].Some("Ref"),
                .None() then Option[String].None(),
            },
            .MutableReferenceType(_) then when self.storage.generic_templates.lookup_extension_methods("MutRef") in {
                .Some(_) then Option[String].Some("MutRef"),
                .None() then Option[String].None(),
            },
            .BorrowedReferenceType(_, _) then when self.storage.generic_templates.lookup_extension_methods("Ref") in {
                .Some(_) then Option[String].Some("Ref"),
                .None() then Option[String].None(),
            },
            .MutableBorrowedReferenceType(_, _) then when self.storage.generic_templates.lookup_extension_methods("MutRef") in {
                .Some(_) then Option[String].Some("MutRef"),
                .None() then Option[String].None(),
            },
            .WeakReferenceType(_) then when self.storage.generic_templates.lookup_extension_methods("WeakRef") in {
                .Some(_) then Option[String].Some("WeakRef"),
                .None() then Option[String].None(),
            },
            .MutableWeakReferenceType(_) then when self.storage.generic_templates.lookup_extension_methods("MutWeakRef") in {
                .Some(_) then Option[String].Some("MutWeakRef"),
                .None() then Option[String].None(),
            },
            .PointerType(_) then when self.storage.generic_templates.lookup_extension_methods("Ptr") in {
                .Some(_) then Option[String].Some("Ptr"),
                .None() then Option[String].None(),
            },
            .MutablePointerType(_) then when self.storage.generic_templates.lookup_extension_methods("MutPtr") in {
                .Some(_) then Option[String].Some("MutPtr"),
                .None() then Option[String].None(),
            },
            .IntType() then when self.storage.generic_templates.lookup_extension_methods("Int") in {
                .Some(_) then Option[String].Some("Int"),
                .None() then Option[String].None(),
            },
            .Int8Type() then when self.storage.generic_templates.lookup_extension_methods("Int8") in {
                .Some(_) then Option[String].Some("Int8"),
                .None() then Option[String].None(),
            },
            .Int16Type() then when self.storage.generic_templates.lookup_extension_methods("Int16") in {
                .Some(_) then Option[String].Some("Int16"),
                .None() then Option[String].None(),
            },
            .Int32Type() then when self.storage.generic_templates.lookup_extension_methods("Int32") in {
                .Some(_) then Option[String].Some("Int32"),
                .None() then Option[String].None(),
            },
            .Int64Type() then when self.storage.generic_templates.lookup_extension_methods("Int64") in {
                .Some(_) then Option[String].Some("Int64"),
                .None() then Option[String].None(),
            },
            .UIntType() then when self.storage.generic_templates.lookup_extension_methods("UInt") in {
                .Some(_) then Option[String].Some("UInt"),
                .None() then Option[String].None(),
            },
            .UInt8Type() then when self.storage.generic_templates.lookup_extension_methods("UInt8") in {
                .Some(_) then Option[String].Some("UInt8"),
                .None() then Option[String].None(),
            },
            .UInt16Type() then when self.storage.generic_templates.lookup_extension_methods("UInt16") in {
                .Some(_) then Option[String].Some("UInt16"),
                .None() then Option[String].None(),
            },
            .UInt32Type() then when self.storage.generic_templates.lookup_extension_methods("UInt32") in {
                .Some(_) then Option[String].Some("UInt32"),
                .None() then Option[String].None(),
            },
            .UInt64Type() then when self.storage.generic_templates.lookup_extension_methods("UInt64") in {
                .Some(_) then Option[String].Some("UInt64"),
                .None() then Option[String].None(),
            },
            .Float32Type() then when self.storage.generic_templates.lookup_extension_methods("Float32") in {
                .Some(_) then Option[String].Some("Float32"),
                .None() then Option[String].None(),
            },
            .Float64Type() then when self.storage.generic_templates.lookup_extension_methods("Float64") in {
                .Some(_) then Option[String].Some("Float64"),
                .None() then Option[String].None(),
            },
            .BoolType() then when self.storage.generic_templates.lookup_extension_methods("Bool") in {
                .Some(_) then Option[String].Some("Bool"),
                .None() then Option[String].None(),
            },
            _ then Option[String].None(),
        }
    }

    private resolve_extension_template_signature(self, base_type Type, inner_type Type, method_name String) Option[Symbol] = {
        let template_key = self.generic_extension_lookup_key(inner_type)
        return when template_key in {
            .Some(key) then when self.storage.generic_templates.lookup_extension_method(
                key,
                method_name,
                Option[UInt].None(),
                Option[UInt].Some(self.receiver_type_args(inner_type).count()),
            ) in {
                .Some(template) then {
                    let actual_type_args = self.receiver_type_args(inner_type)
                    let mut bindings = Dict[String, Type].new()
                    let mut i UInt = 0
                    while i < template.type_params.count() and i < actual_type_args.count() then {
                        bindings.insert(template.type_params[i].name, actual_type_args[i])
                        i += 1
                    }
                    // Also bind method-level type params as GenericParameter
                    // so resolve_template_type_node_with_bindings can find them
                    for mtp in template.method.type_params then {
                        if not bindings.contains_key(mtp.name) then {
                            bindings.insert(mtp.name, Type.GenericParameter(mtp.name))
                        }
                    }
                    bindings.insert("Self", base_type)
                    self.bind_extension_template_conformance_trait_args(inner_type, template.val, bindings.ref)
                    let mut typed_params = List[TypedParam].new()
                    for param in template.method.params then {
                        typed_params.push(
                            TypedParam(
                                param.name,
                                param.mutable,
                                self.resolve_template_type_node_with_bindings(param.param_type, bindings),
                                param.named,
                            )
                        )
                    }
                    let return_type = when template.checked_return_type in {
                        .Some(ret) then self.apply_type_bindings(ret, bindings),
                        .None() then self.resolve_template_type_node_with_bindings(template.method.return_type, bindings),
                    }
                    yield Option[Symbol].Some(
                        self.make_method_callable_symbol_with_visibility(
                            method_name,
                            typed_params,
                            return_type,
                            template.method.access,
                            template.module_path,
                            template.source_file,
                            template.package_id,
                        )
                    )
                },
                .None() then Option[Symbol].None(),
            },
            .None() then Option[Symbol].None(),
        }
    }

    private concrete_receiver_for_method(self, base_type Type, method Symbol) Type = {
        let normalized_base_type = self.normalize_method_receiver_type(base_type)
        if self.method_param_count(method) == 0 then {
            return normalized_base_type
        }
        let inner_type = when normalized_base_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            .MutablePointerType(inner) then inner.val,
            .PointerType(inner) then inner.val,
            _ then normalized_base_type,
        }
        let receiver_param_type = self.method_param_type(method, 0(UInt)) or else normalized_base_type
        return when receiver_param_type in {
            .MutableReferenceType(_) then when normalized_base_type in {
                .MutableReferenceType(_) then normalized_base_type,
                .MutableBorrowedReferenceType(_, _) then normalized_base_type,
                .ReferenceType(actual_inner) then {
                    yield if self.same_expr_type(actual_inner.val, inner_type) then normalized_base_type else Type.MutableReferenceType(box(inner_type))
                },
                .BorrowedReferenceType(actual_inner, _) then {
                    yield if self.same_expr_type(actual_inner.val, inner_type) then normalized_base_type else Type.MutableReferenceType(box(inner_type))
                },
                _ then Type.MutableReferenceType(box(inner_type)),
            },
            .MutableBorrowedReferenceType(_, _) then when normalized_base_type in {
                .MutableReferenceType(_) then normalized_base_type,
                .MutableBorrowedReferenceType(_, _) then normalized_base_type,
                .ReferenceType(actual_inner) then {
                    yield if self.same_expr_type(actual_inner.val, inner_type) then normalized_base_type else Type.MutableBorrowedReferenceType(box(inner_type), "'_")
                },
                .BorrowedReferenceType(actual_inner, _) then {
                    yield if self.same_expr_type(actual_inner.val, inner_type) then normalized_base_type else Type.MutableBorrowedReferenceType(box(inner_type), "'_")
                },
                _ then Type.MutableBorrowedReferenceType(box(inner_type), "'_"),
            },
            .ReferenceType(_) then when normalized_base_type in {
                .ReferenceType(_) then normalized_base_type,
                .BorrowedReferenceType(_, _) then normalized_base_type,
                _ then Type.ReferenceType(box(inner_type)),
            },
            .BorrowedReferenceType(_, lt) then when normalized_base_type in {
                .ReferenceType(_) then normalized_base_type,
                .BorrowedReferenceType(_, _) then normalized_base_type,
                _ then Type.BorrowedReferenceType(box(inner_type), lt),
            },
            .WeakReferenceType(_) then when normalized_base_type in {
                .WeakReferenceType(_) then normalized_base_type,
                .MutableWeakReferenceType(_) then normalized_base_type,
                _ then Type.WeakReferenceType(box(inner_type)),
            },
            .MutableWeakReferenceType(_) then when normalized_base_type in {
                .MutableWeakReferenceType(_) then normalized_base_type,
                _ then Type.MutableWeakReferenceType(box(inner_type)),
            },
            .MutablePointerType(_) then when normalized_base_type in {
                .MutablePointerType(_) then normalized_base_type,
                _ then Type.MutablePointerType(box(inner_type)),
            },
            .PointerType(_) then when normalized_base_type in {
                .PointerType(_) then normalized_base_type,
                _ then Type.PointerType(box(inner_type)),
            },
            _ then inner_type,
        }
    }

    private bind_extension_template_conformance_trait_args(
        self,
        receiver_type Type,
        template GenericExtensionMethodTemplate,
        bindings ref mut Dict[String, Type],
    ) Void = {
        when template.conformance_trait_name in {
            .Some(trait_name) then {
                // Use the type-keyed index for O(1) lookup instead of O(N) scan
                let key = self.conformance_template_key(receiver_type)
                let conformances = when self.storage.conformance_index.get(key) in {
                    .Some(list) then list,
                    .None() then {
                        return
                    },
                }
                for conformance in conformances then {
                    if conformance.trait_name <> trait_name then {
                        continue
                    }

                    let mut conformance_bindings = Dict[String, Type].new()
                    if not self.conformance_type_key_matches(conformance.target_type, receiver_type, conformance_bindings.ref) then {
                        continue
                    }

                    when self.storage.trait_registry.get(trait_name) in {
                        .Some(info) then {
                            let param_count = info.type_params.count()
                            let arg_count = conformance.trait_arg_types.count()
                            let n = if param_count < arg_count then param_count else arg_count
                            let mut trait_i UInt = 0
                            while trait_i < n then {
                                let bound_trait_arg = self.apply_type_bindings(conformance.trait_arg_types[trait_i], conformance_bindings)
                                bindings.insert(info.type_params[trait_i], bound_trait_arg)
                                trait_i += 1
                            }
                        },
                        .None() then {},
                    }
                    return
                }
            },
            .None() then {},
        }
    }

    private resolve_bound_method_self_type(self, base_type Type, method Symbol) Option[Type] = {
        if self.method_param_count(method) == 0 then {
            return Option[Type].None()
        }
        return Option[Type].Some(self.concrete_receiver_for_method(base_type, method))
    }

    private bind_direct_method_signature(self, base_type Type, method_name String, raw_method Symbol) Symbol = {
        let receiver_type = self.concrete_receiver_for_method(base_type, raw_method)
        let mut bindings = Dict[String, Type].new()
        if self.method_param_count(raw_method) > 0(UInt) then {
            let self_param_type = self.method_param_type(raw_method, 0(UInt)) or else Type.Unknown()
            self.infer_type_bindings(self_param_type, receiver_type, bindings.ref)
        }
        let concrete_self = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        bindings.insert("Self", concrete_self)

        let mut bound_param_types = List[Type].new()
        for parameter_type in self.method_param_types(raw_method) then {
            bound_param_types.push(self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(parameter_type, bindings))))
        }
        if not bound_param_types.is_empty() then {
            bound_param_types[0(UInt)] = receiver_type
        }
        let bound_return_type = self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(self.method_return_type(raw_method), bindings)))
        return self.rebuild_method_symbol(method_name, raw_method, bound_param_types, bound_return_type)
    }

    private replace_type_occurrence(self, t Type, pattern Type, replacement Type) Type = {
        if self.same_expr_type(t, pattern) then {
            return replacement
        }
        return when t in {
            .MutableReferenceType(inner) then Type.MutableReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .ReferenceType(inner) then Type.ReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .MutableBorrowedReferenceType(inner, lt) then Type.MutableBorrowedReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement)), lt),
            .BorrowedReferenceType(inner, lt) then Type.BorrowedReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement)), lt),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .MutablePointerType(inner) then Type.MutablePointerType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .PointerType(inner) then Type.PointerType(box(self.replace_type_occurrence(inner.val, pattern, replacement))),
            .GenericStruct(template, args) then {
                let mut replaced = List[ref Type].new()
                for arg_ref in args then {
                    replaced.push(box(self.replace_type_occurrence(arg_ref.val, pattern, replacement)))
                }
                yield Type.GenericStruct(template, replaced)
            },
            .GenericEnum(template, args) then {
                let mut replaced = List[ref Type].new()
                for arg_ref in args then {
                    replaced.push(box(self.replace_type_occurrence(arg_ref.val, pattern, replacement)))
                }
                yield Type.GenericEnum(template, replaced)
            },
            .FunctionType(params, ret) then {
                let mut replaced_params = List[ref Type].new()
                for entry in params then {
                    replaced_params.push(box(self.replace_type_occurrence(entry.param_type, pattern, replacement)))
                }
                let replaced_ret = self.replace_type_occurrence(ret.val, pattern, replacement)
                yield make_function_type(replaced_params, replaced_ret)
            },
            _ then t,
        }
    }

    private resolve_signature_return_type(self, receiver_type Type, method Symbol) Type = {
        if self.method_param_count(method) == 0 then {
            return self.method_return_type(method)
        }
        let mut bindings = Dict[String, Type].new()
        let self_param_type = self.method_param_type(method, 0(UInt)) or else Type.Unknown()
        let concrete_self_type = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        // Only infer type bindings from self if parameter 0 is actually a self parameter
        // (i.e., its type matches the receiver type pattern). For static methods like
        // constructors (e.g., Random[DefaultRandomSource].new(rng)), parameter 0 is NOT self.
        let is_self_param = when self_param_type in {
            .GenericParameter(_) then true,
            .ReferenceType(inner) then when inner.val in {
                .GenericParameter(_) then true,
                _ then self.same_expr_type(inner.val, concrete_self_type)
                    or self.type_matches_expected_pattern(concrete_self_type, inner.val),
            },
            .MutableReferenceType(inner) then when inner.val in {
                .GenericParameter(_) then true,
                _ then self.same_expr_type(inner.val, concrete_self_type)
                    or self.type_matches_expected_pattern(concrete_self_type, inner.val),
            },
            .BorrowedReferenceType(inner, _) then when inner.val in {
                .GenericParameter(_) then true,
                _ then self.same_expr_type(inner.val, concrete_self_type)
                    or self.type_matches_expected_pattern(concrete_self_type, inner.val),
            },
            .MutableBorrowedReferenceType(inner, _) then when inner.val in {
                .GenericParameter(_) then true,
                _ then self.same_expr_type(inner.val, concrete_self_type)
                    or self.type_matches_expected_pattern(concrete_self_type, inner.val),
            },
            _ then self.same_expr_type(self_param_type, concrete_self_type)
                or self.type_matches_expected_pattern(concrete_self_type, self_param_type),
        }
        if is_self_param then {
            self.infer_type_bindings(self_param_type, receiver_type, bindings.ref)
        }
        bindings.insert("Self", concrete_self_type)
        let bound_self_type = self.apply_type_bindings(self_param_type, bindings)
        let bound_return_type = self.apply_type_bindings(self.method_return_type(method), bindings)
        if is_self_param then {
            return self.replace_type_occurrence(bound_return_type, bound_self_type, concrete_self_type)
        }
        return bound_return_type
    }

    private resolve_method_template_key(self, inner_type Type) Option[String] = {
        return when inner_type in {
            .GenericStruct(template, _) then {
                yield Option[String].Some(template)
            },
            .GenericEnum(template, _) then {
                yield Option[String].Some(template)
            },
            .StructureType(def_id) then {
                yield self.context().get_template_name(def_id)
            },
            .EnumType(def_id) then {
                yield self.context().get_template_name(def_id)
            },
            _ then Option[String].None(),
        }
    }

    private resolve_conformance_method_signature(self, receiver_type Type, method_name String) Option[Symbol] = {
        let normalized_receiver = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        // Use the type-keyed index for O(1) lookup instead of O(N) scan
        let key = self.conformance_template_key(normalized_receiver)
        let templates = when self.storage.conformance_index.get(key) in {
            .Some(list) then list,
            .None() then {
                // No conformance templates for this type key — skip the scan
                return Option[Symbol].None()
            },
        }
        for template in templates then {
            let mut bindings = Dict[String, Type].new()
            if not self.conformance_type_key_matches(template.target_type, normalized_receiver, bindings.ref) then {
                continue
            }

            let trait_name = template.trait_name
            let mut method_bindings = bindings
            when self.storage.trait_registry.get(trait_name) in {
                .Some(info) then {
                    let param_count = info.type_params.count()
                    let arg_count = template.trait_arg_types.count()
                    let n = if param_count < arg_count then param_count else arg_count
                    let mut i UInt = 0
                    while i < n then {
                        let arg_type = self.apply_type_bindings(template.trait_arg_types[i], bindings)
                        method_bindings.insert(info.type_params[i], arg_type)
                        i += 1
                    }
                },
                .None() then {},
            }

            when self.storage.trait_registry.flatten_methods(trait_name) in {
                .Ok(methods) then {
                    when methods.get(method_name) in {
                        .Some(member) then {
                            let mut typed_params = List[TypedParam].new()
                            for param in member.params then {
                                let bound_param = self.bind_conformance_trait_self_type(self.apply_trait_self_binding(self.apply_type_bindings(param.param_type, method_bindings), receiver_type), trait_name, receiver_type)
                                typed_params.push(TypedParam(param.name, param.mutable, bound_param, param.named))
                            }
                            let bound_return = self.bind_conformance_trait_self_type(self.apply_trait_self_binding(self.apply_type_bindings(member.return_type, method_bindings), receiver_type), trait_name, receiver_type)
                            return Option[Symbol].Some(self.make_method_callable_symbol(method_name, typed_params, bound_return))
                        },
                        .None() then {},
                    }
                },
                .Error(_) then {},
            }
            let raw_method_opt = self.lookup_method_signature(trait_name, method_name)
            if raw_method_opt is .None() then {
                continue
            }
            let raw_method = when raw_method_opt in {
                .Some(method) then method,
                .None() then Symbol(DefId(0(UInt)), Type.Unknown(), SymbolKind.Function()),
            }

            let mut bound_param_types = List[Type].new()
            for parameter_type in self.method_param_types(raw_method) then {
                let bound_type = self.bind_conformance_trait_self_type(self.apply_type_bindings(parameter_type, method_bindings), trait_name, receiver_type)
                bound_param_types.push(bound_type)
            }
            if not bound_param_types.is_empty() then {
                bound_param_types[0(UInt)] = self.concrete_receiver_for_method(receiver_type, raw_method)
            }
            let bound_return = self.bind_conformance_trait_self_type(self.apply_type_bindings(self.method_return_type(raw_method), method_bindings), trait_name, receiver_type)
            let bound_symbol_type = make_function_type(self.to_type_ref_list(bound_param_types), bound_return)
            return Option[Symbol].Some(Symbol(raw_method.def_id, bound_symbol_type, raw_method.kind))
        }

        return Option[Symbol].None()
    }

    private resolve_conformance_extension_template_signature(self, base_type Type, receiver_type Type, method_name String) Option[Symbol] = {
        let normalized_receiver = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        let key = self.conformance_template_key(normalized_receiver)
        let conformances = when self.storage.conformance_index.get(key) in {
            .Some(list) then list,
            .None() then {
                return Option[Symbol].None()
            },
        }
        for conformance in conformances then {
            let mut conformance_bindings = Dict[String, Type].new()
            if not self.conformance_type_key_matches(conformance.target_type, normalized_receiver, conformance_bindings.ref) then {
                continue
            }

            let trait_name = conformance.trait_name
            let template_opt = self.storage.generic_templates.lookup_extension_method(
                trait_name,
                method_name,
                Option[UInt].None(),
                Option[UInt].Some(conformance.trait_arg_types.count()),
            )
            let template = when template_opt in {
                .Some(found) then found,
                .None() then {
                    continue
                },
            }

            let mut bindings = Dict[String, Type].new()
            for entry in conformance_bindings then {
                bindings.insert(entry.first, entry.second)
            }
            when self.storage.trait_registry.get(trait_name) in {
                .Some(info) then {
                    let param_count = info.type_params.count()
                    let arg_count = conformance.trait_arg_types.count()
                    let n = if param_count < arg_count then param_count else arg_count
                    let mut trait_i UInt = 0
                    while trait_i < n then {
                        let bound_trait_arg = self.apply_type_bindings(conformance.trait_arg_types[trait_i], conformance_bindings)
                        bindings.insert(info.type_params[trait_i], bound_trait_arg)
                        trait_i += 1
                    }
                },
                .None() then {},
            }
            for mtp in template.method.type_params then {
                if not bindings.contains_key(mtp.name) then {
                    bindings.insert(mtp.name, Type.GenericParameter(mtp.name))
                }
            }
            bindings.insert("Self", base_type)

            let mut typed_params = List[TypedParam].new()
            for param in template.method.params then {
                typed_params.push(
                    TypedParam(
                        param.name,
                        param.mutable,
                        self.resolve_template_type_node_with_bindings(param.param_type, bindings),
                        param.named,
                    )
                )
            }
            let return_type = when template.checked_return_type in {
                .Some(ret) then self.apply_type_bindings(ret, bindings),
                .None() then self.resolve_template_type_node_with_bindings(template.method.return_type, bindings),
            }
            return Option[Symbol].Some(
                self.make_method_callable_symbol_with_visibility(
                    method_name,
                    typed_params,
                    return_type,
                    template.method.access,
                    template.module_path,
                    template.source_file,
                    template.package_id,
                )
            )
        }

        return Option[Symbol].None()
    }

    private resolve_conformance_trait_method_signature(self, receiver_type Type, trait_name String, method_name String) Option[Symbol] = {
        let normalized_receiver = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        // Use the type-keyed index for O(1) lookup instead of O(N) scan
        let key = self.conformance_template_key(normalized_receiver)
        let templates = when self.storage.conformance_index.get(key) in {
            .Some(list) then list,
            .None() then {
                return Option[Symbol].None()
            },
        }
        for template in templates then {
            if template.trait_name <> trait_name then {
                continue
            }

            let mut bindings = Dict[String, Type].new()
            if not self.conformance_type_key_matches(template.target_type, normalized_receiver, bindings.ref) then {
                continue
            }

            let mut method_bindings = bindings
            when self.storage.trait_registry.get(trait_name) in {
                .Some(info) then {
                    let param_count = info.type_params.count()
                    let arg_count = template.trait_arg_types.count()
                    let n = if param_count < arg_count then param_count else arg_count
                    let mut i UInt = 0
                    while i < n then {
                        let arg_type = self.apply_type_bindings(template.trait_arg_types[i], bindings)
                        method_bindings.insert(info.type_params[i], arg_type)
                        i += 1
                    }
                },
                .None() then {},
            }

            when self.storage.trait_registry.flatten_methods(trait_name) in {
                .Ok(methods) then {
                    when methods.get(method_name) in {
                        .Some(member) then {
                            let mut typed_params = List[TypedParam].new()
                            for param in member.params then {
                                let bound_param = self.bind_conformance_trait_self_type(self.apply_trait_self_binding(self.apply_type_bindings(param.param_type, method_bindings), receiver_type), trait_name, receiver_type)
                                typed_params.push(TypedParam(param.name, param.mutable, bound_param, param.named))
                            }
                            let bound_return = self.bind_conformance_trait_self_type(self.apply_trait_self_binding(self.apply_type_bindings(member.return_type, method_bindings), receiver_type), trait_name, receiver_type)
                            return Option[Symbol].Some(self.make_method_callable_symbol(method_name, typed_params, bound_return))
                        },
                        .None() then {},
                    }
                },
                .Error(_) then {},
            }

            when self.lookup_method_signature(trait_name, method_name) in {
                .Some(raw_method) then {
                    let mut bound_param_types = List[Type].new()
                    for parameter_type in self.method_param_types(raw_method) then {
                        let bound_type = self.bind_conformance_trait_self_type(self.apply_type_bindings(parameter_type, method_bindings), trait_name, receiver_type)
                        bound_param_types.push(bound_type)
                    }
                    if not bound_param_types.is_empty() then {
                        bound_param_types[0(UInt)] = self.concrete_receiver_for_method(receiver_type, raw_method)
                    }
                    let bound_return = self.bind_conformance_trait_self_type(self.apply_type_bindings(self.method_return_type(raw_method), method_bindings), trait_name, receiver_type)
                    let bound_symbol_type = make_function_type(self.to_type_ref_list(bound_param_types), bound_return)
                    return Option[Symbol].Some(Symbol(raw_method.def_id, bound_symbol_type, raw_method.kind))
                },
                .None() then {},
            }
        }

        return Option[Symbol].None()
    }

    private apply_trait_self_binding(self, t Type, receiver_type Type) Type = {
        let concrete_receiver = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        let mut bindings = Dict[String, Type].new()
        bindings.insert("Self", concrete_receiver)
        return self.apply_type_bindings(t, bindings)
    }

    /// Resolve a trait member type by substituting Self and ancestor trait type params.
    /// For example, for method `add(self, other R) Self` from [R Any]Add inherited through
    /// Numeric (which declares [Self]Add), this resolves R -> Self and Self -> receiver_type.
    private resolve_trait_member_type(self, t Type, receiver_type Type) Type = {
        let concrete_receiver = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        // Build bindings from Self + any ancestor trait type params currently in scope
        let mut bindings = Dict[String, Type].new()
        bindings.insert("Self", concrete_receiver)
        // Check if there are any GenericParameter references in the type that are
        // bound in the global scope (from bind_ancestor_trait_type_params)
        self.collect_ancestor_bindings(t, bindings.ref)
        return self.apply_type_bindings(t, bindings)
    }

    private trait_method_bindings(self, trait_name String, receiver_type Type) Dict[String, Type] = {
        let concrete_receiver = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        let mut bindings = Dict[String, Type].new()
        bindings.insert("Self", concrete_receiver)

        // If receiver is a GenericParameter, extract constraint type args for this trait
        // to populate bindings. e.g. [R Iterator[T]] → Element -> T
        let receiver_inner = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            _ then receiver_type,
        }
        when receiver_inner in {
            .GenericParameter(gp_name) then {
                when self.storage.generic_param_constraints.get(gp_name) in {
                    .Some(constraints) then {
                        for constraint in constraints then {
                            if constraint.trait_name == trait_name then {
                                when self.storage.trait_registry.get(trait_name) in {
                                    .Some(info) then {
                                        let mut idx UInt = 0
                                        while idx < info.type_params.count() and idx < constraint.type_args.count() then {
                                            let param_name = info.type_params[idx]
                                            if not bindings.contains_key(param_name) then {
                                                bindings.insert(param_name, constraint.type_args[idx])
                                            }
                                            idx += 1
                                        }
                                    },
                                    .None() then {},
                                }
                            }
                        }
                    },
                    .None() then {},
                }
            },
            _ then {},
        }

        // Fill in any remaining unresolved trait type params from global_scope
        when self.storage.trait_registry.get(trait_name) in {
            .Some(info) then {
                for type_param in info.type_params then {
                    if not bindings.contains_key(type_param) then {
                        let bound_type = when self.storage.global_scope.lookup_type(type_param) in {
                            .Some(existing) then existing,
                            .None() then Type.GenericParameter(type_param),
                        }
                        bindings.insert(type_param, bound_type)
                    }
                }
            },
            .None() then panic("trait_method_bindings: missing trait info for \(trait_name)"),
        }
        let mut visited = Set[String].new()
        return self.collect_trait_method_bindings_recursive(trait_name, bindings, visited.ref)
    }

    private collect_trait_method_bindings_recursive(
        self,
        trait_name String,
        bindings Dict[String, Type],
        visited ref mut Set[String],
    ) Dict[String, Type] = {
        if visited.contains(trait_name) then {
            return bindings
        }
        visited.insert(trait_name)
        when self.storage.trait_registry.get(trait_name) in {
            .Some(info) then {
                let mut collected = bindings
                for parent in info.parent_traits then {
                    if parent.name == "Any" then {
                        continue
                    }
                    when self.storage.trait_registry.get(parent.name) in {
                        .Some(parent_info) then {
                            let mut parent_bindings = Dict[String, Type].new()
                            for entry in collected then {
                                parent_bindings.insert(entry.first, entry.second)
                            }
                            let mut idx UInt = 0
                            while idx < parent_info.type_params.count() and idx < parent.type_arg_nodes.count() then {
                                let param_name = parent_info.type_params[idx]
                                let resolved_arg = self.resolve_type_with_bindings(parent.type_arg_nodes[idx], collected)
                                parent_bindings.insert(param_name, resolved_arg)
                                if not collected.contains_key(param_name) then {
                                    collected.insert(param_name, resolved_arg)
                                }
                                idx += 1
                            }
                            parent_bindings = self.collect_trait_method_bindings_recursive(parent.name, parent_bindings, visited)
                            for entry in parent_bindings then {
                                if not collected.contains_key(entry.first) then {
                                    collected.insert(entry.first, entry.second)
                                }
                            }
                        },
                        .None() then panic("collect_trait_method_bindings_recursive: missing trait info for \(parent.name)"),
                    }
                }
                return collected
            },
            .None() then panic("collect_trait_method_bindings_recursive: missing trait info for \(trait_name)"),
        }
    }

    private resolve_trait_registry_method_signature(self, trait_name String, method_name String, receiver_type Type) Option[Symbol] = {
        let bindings = self.trait_method_bindings(trait_name, receiver_type)
        if self.lookup_method_signature(trait_name, method_name) is .Some(raw_method) then {
            let mut bound_param_types = List[Type].new()
            for parameter_type in self.method_param_types(raw_method) then {
                bound_param_types.push(self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(parameter_type, bindings))))
            }
            let bound_return_type = self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(self.method_return_type(raw_method), bindings)))
            return Option[Symbol].Some(self.rebuild_method_symbol(method_name, raw_method, bound_param_types, bound_return_type))
        }
        return when self.storage.trait_registry.flatten_methods(trait_name) in {
            .Ok(methods) then when methods.get(method_name) in {
                .Some(member) then {
                    let mut typed_params = List[TypedParam].new()
                    for p in member.params then {
                        let resolved_param_type = self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(p.param_type, bindings)))
                        typed_params.push(TypedParam(p.name, p.mutable, resolved_param_type, p.named))
                    }
                    let resolved_return_type = self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(member.return_type, bindings)))
                    yield Option[Symbol].Some(self.make_method_callable_symbol(method_name, typed_params, resolved_return_type))
                },
                .None() then Option[Symbol].None(),
            },
            .Error(_) then panic("resolve_trait_registry_method_signature: failed to flatten trait methods"),
        }
    }

    private collect_ancestor_bindings(self, t Type, bindings ref mut Dict[String, Type]) Void = {
        when t in {
            .GenericParameter(name) then {
                if not bindings.contains_key(name) then {
                    when self.storage.global_scope.lookup_type(name) in {
                        .Some(resolved) then {
                            if not (resolved is .GenericParameter(_) and when resolved in { .GenericParameter(n) then n == name, _ then false }) then {
                                bindings.insert(name, resolved)
                            }
                        },
                        .None() then {},
                    }
                }
            },
            .ReferenceType(inner) then self.collect_ancestor_bindings(inner.val, bindings),
            .MutableReferenceType(inner) then self.collect_ancestor_bindings(inner.val, bindings),
            .BorrowedReferenceType(inner, _) then self.collect_ancestor_bindings(inner.val, bindings),
            .MutableBorrowedReferenceType(inner, _) then self.collect_ancestor_bindings(inner.val, bindings),
            .PointerType(inner) then self.collect_ancestor_bindings(inner.val, bindings),
            .MutablePointerType(inner) then self.collect_ancestor_bindings(inner.val, bindings),
            .GenericStruct(_, args) then {
                for arg in args then { self.collect_ancestor_bindings(arg.val, bindings) }
            },
            .GenericEnum(_, args) then {
                for arg in args then { self.collect_ancestor_bindings(arg.val, bindings) }
            },
            .FunctionType(params, ret) then {
                for entry in params then { self.collect_ancestor_bindings(entry.param_type, bindings) }
                self.collect_ancestor_bindings(ret.val, bindings)
            },
            _ then {},
        }
    }

    private bind_conformance_trait_self_type(self, t Type, trait_name String, receiver_type Type) Type = {
        let concrete_receiver = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        return when t in {
            .TraitObject(name, _) then if name == trait_name then concrete_receiver else t,
            .MutableReferenceType(inner) then Type.MutableReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .ReferenceType(inner) then Type.ReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .MutableBorrowedReferenceType(inner, lt) then Type.MutableBorrowedReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver)), lt),
            .BorrowedReferenceType(inner, lt) then Type.BorrowedReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver)), lt),
            .WeakReferenceType(inner) then Type.WeakReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .MutableWeakReferenceType(inner) then Type.MutableWeakReferenceType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .MutablePointerType(inner) then Type.MutablePointerType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .PointerType(inner) then Type.PointerType(box(self.bind_conformance_trait_self_type(inner.val, trait_name, concrete_receiver))),
            .FunctionType(fn_params, return_type) then {
                let param_types = param_entry_types(fn_params)
                let mut replaced_params = List[ref Type].new()
                for param_ref in param_types then {
                    replaced_params.push(box(self.bind_conformance_trait_self_type(param_ref.val, trait_name, concrete_receiver)))
                }
                yield Type.FunctionType(types_to_param_entries(replaced_params), box(self.bind_conformance_trait_self_type(return_type.val, trait_name, concrete_receiver)))
            },
            .GenericStruct(template, args) then {
                yield when template == trait_name in {
                    true then concrete_receiver,
                    false then {
                        let mut replaced_args = List[ref Type].new()
                        for arg_ref in args then {
                            replaced_args.push(box(self.bind_conformance_trait_self_type(arg_ref.val, trait_name, concrete_receiver)))
                        }
                        yield Type.GenericStruct(template, replaced_args)
                    },
                }
            },
            .GenericEnum(template, args) then {
                yield when template == trait_name in {
                    true then concrete_receiver,
                    false then {
                        let mut replaced_args = List[ref Type].new()
                        for arg_ref in args then {
                            replaced_args.push(box(self.bind_conformance_trait_self_type(arg_ref.val, trait_name, concrete_receiver)))
                        }
                        yield Type.GenericEnum(template, replaced_args)
                    },
                }
            },
            _ then t,
        }
    }

    // Unified: delegates to resolve_method_signature (8-layer cascade).
    private resolve_method_return_type(self, base_type Type, method_name String) Type = {
        return when self.resolve_method_signature(base_type, method_name) in {
            .Some(method) then self.method_return_type(method),
            .None() then Type.Unknown(),
        }
    }

    // Unified: delegates to resolve_method_signature (8-layer cascade).
    protected resolve_method_self_type(self, base_type Type, method_name String) Option[Type] = {
        return when self.resolve_method_signature(base_type, method_name) in {
            .Some(method) then self.resolve_bound_method_self_type(base_type, method),
            .None() then Option[Type].None(),
        }
    }

    private resolve_static_method_return_type(self, type_name String, method_name String) Type = {
        return when self.lookup_method_signature(type_name, method_name) in {
            .Some(method) then self.method_return_type(method),
            .None() then Type.Unknown(),
        }
    }

    private extension_template_is_receiver_style(self, template ref GenericExtensionMethodTemplate) Bool = {
        let _ = self
        return if template.method.params.is_empty() then false else template.method.params[0(UInt)].name == "self"
    }

    private resolve_static_extension_template_signature(self, receiver_type Type, method_name String) Option[Symbol] = {
        let template_key = self.generic_extension_lookup_key(receiver_type)
        return when template_key in {
            .Some(key) then {
                let actual_type_args = self.receiver_type_args(receiver_type)
                yield when self.storage.generic_templates.lookup_extension_method(
                    key,
                    method_name,
                    Option[UInt].None(),
                    Option[UInt].Some(actual_type_args.count()),
                ) in {
                    .Some(template) then {
                        yield if self.extension_template_is_receiver_style(template) then Option[Symbol].None() else {
                            let mut bindings = Dict[String, Type].new()
                            let mut i UInt = 0
                            while i < template.type_params.count() and i < actual_type_args.count() then {
                                bindings.insert(template.type_params[i].name, actual_type_args[i])
                                i += 1
                            }
                            for mtp in template.method.type_params then {
                                if not bindings.contains_key(mtp.name) then {
                                    bindings.insert(mtp.name, Type.GenericParameter(mtp.name))
                                }
                            }
                            bindings.insert("Self", receiver_type)
                            self.bind_extension_template_conformance_trait_args(receiver_type, template.val, bindings.ref)
                            let mut typed_params = List[TypedParam].new()
                            for param in template.method.params then {
                                typed_params.push(
                                    TypedParam(
                                        param.name,
                                        param.mutable,
                                        self.resolve_template_type_node_with_bindings(param.param_type, bindings),
                                        param.named,
                                    )
                                )
                            }
                            let return_type = when template.checked_return_type in {
                                .Some(ret) then self.apply_type_bindings(ret, bindings),
                                .None() then self.resolve_template_type_node_with_bindings(template.method.return_type, bindings),
                            }
                            yield Option[Symbol].Some(
                                self.make_method_callable_symbol_with_visibility(
                                    method_name,
                                    typed_params,
                                    return_type,
                                    template.method.access,
                                    template.module_path,
                                    template.source_file,
                                    template.package_id,
                                )
                            )
                        }
                    },
                    .None() then Option[Symbol].None(),
                }
            },
            .None() then Option[Symbol].None(),
        }
    }

    protected resolve_static_method_signature_for_receiver(self, type_name String, receiver_type Type, method_name String) Option[Symbol] = {
        return when self.lookup_method_signature(type_name, method_name) in {
            .Some(method) then Option[Symbol].Some(method),
            .None() then when self.resolve_static_extension_template_signature(receiver_type, method_name) in {
                .Some(method) then Option[Symbol].Some(method),
                .None() then self.resolve_conformance_method_signature(receiver_type, method_name),
            },
        }
    }

    // Unified: delegates to resolve_method_signature (8-layer cascade).
    protected resolve_method_param_types(self, base_type Type, method_name String) List[Type] = {
        return when self.resolve_method_signature(base_type, method_name) in {
            .Some(method) then self.resolve_signature_param_types(base_type, method),
            .None() then List[Type].new(),
        }
    }

    private resolve_signature_param_types(self, receiver_type Type, method Symbol) List[Type] = {
        if self.method_param_count(method) <= 1(UInt) then {
            return List[Type].new()
        }
        let mut bindings = Dict[String, Type].new()
        self.infer_type_bindings(self.method_param_type(method, 0(UInt)) or else Type.Unknown(), receiver_type, bindings.ref)
        let mut out = List[Type].new()
        let mut i = 1(UInt)
        while i < self.method_param_count(method) then {
            let param_type = self.method_param_type(method, i) or else Type.Unknown()
            out.push(self.apply_type_bindings(param_type, bindings))
            i += 1(UInt)
        }
        return out
    }

    private collect_unbound_method_generic_param_names(self, t Type, receiver_bindings Dict[String, Type], ordered ref mut List[String], seen ref mut Set[String]) Void = {
        when t in {
            .GenericParameter(name) then {
                if not receiver_bindings.contains_key(name) and not seen.contains(name) then {
                    seen.insert(name)
                    ordered.push(name)
                }
            },
            .MutableReferenceType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .ReferenceType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .MutableBorrowedReferenceType(inner, _) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .BorrowedReferenceType(inner, _) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .WeakReferenceType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .MutableWeakReferenceType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .MutablePointerType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .PointerType(inner) then self.collect_unbound_method_generic_param_names(inner.val, receiver_bindings, ordered, seen),
            .FunctionType(params, ret) then {
                for entry in params then {
                    self.collect_unbound_method_generic_param_names(entry.param_type, receiver_bindings, ordered, seen)
                }
                self.collect_unbound_method_generic_param_names(ret.val, receiver_bindings, ordered, seen)
            },
            .GenericStruct(_, args) then {
                for arg in args then {
                    self.collect_unbound_method_generic_param_names(arg.val, receiver_bindings, ordered, seen)
                }
            },
            .GenericEnum(_, args) then {
                for arg in args then {
                    self.collect_unbound_method_generic_param_names(arg.val, receiver_bindings, ordered, seen)
                }
            },
            _ then {},
        }
    }

    private collect_method_generic_param_names_from_params(self, method Symbol, receiver_bindings Dict[String, Type], ordered ref mut List[String], seen ref mut Set[String]) Void = {
        let mut i UInt = 1
        while i < self.method_param_count(method) then {
            let param_type = self.method_param_type(method, i) or else Type.Unknown()
            self.collect_unbound_method_generic_param_names(param_type, receiver_bindings, ordered, seen)
            i += 1
        }
    }

    private collect_method_generic_param_names(self, method Symbol, receiver_bindings Dict[String, Type], ordered ref mut List[String], seen ref mut Set[String]) Void = {
        self.collect_method_generic_param_names_from_params(method, receiver_bindings, ordered, seen)
        self.collect_unbound_method_generic_param_names(self.method_return_type(method), receiver_bindings, ordered, seen)
    }

    private resolve_signature_method_type_bindings(self, receiver_type Type, method Symbol, method_type_args List[Type]) Dict[String, Type] = {
        let mut bindings = Dict[String, Type].new()
        if self.method_param_count(method) > 0 then {
            self.infer_type_bindings(self.method_param_type(method, 0(UInt)) or else Type.Unknown(), receiver_type, bindings.ref)
        }
        if method_type_args.is_empty() then {
            return bindings
        }

        let mut ordered = List[String].new()
        let mut seen = Set[String].new()
        self.collect_method_generic_param_names(method, bindings, ordered.ref, seen.ref)

        let mut arg_i UInt = 0
        while arg_i < method_type_args.count() and arg_i < ordered.count() then {
            bindings.insert(ordered[arg_i], method_type_args[arg_i])
            arg_i += 1
        }
        return bindings
    }

    private resolve_signature_call_type_bindings(self, base_type Type, method Symbol, args List[ref TypedExpr], method_type_args List[Type]) Dict[String, Type] = {
        let receiver_type = self.concrete_receiver_for_method(base_type, method)
        let mut bindings = self.resolve_signature_method_type_bindings(receiver_type, method, method_type_args)
        let mut arg_i UInt = 0
        while arg_i < args.count() and arg_i + 1(UInt) < self.method_param_count(method) then {
            let param_type = self.method_param_type(method, arg_i + 1(UInt)) or else Type.Unknown()
            self.infer_type_bindings(param_type, args[arg_i].expr_type, bindings.ref)
            arg_i += 1
        }
        return bindings
    }

    private bind_static_receiver_type_args(self, type_name String, receiver_type_args List[Type], bindings ref mut Dict[String, Type]) Void = {
        when self.storage.generic_templates.lookup_struct(type_name) in {
            .Some(struct_template) then {
                let mut i UInt = 0
                let param_count = struct_template.type_parameters.count()
                let arg_count = receiver_type_args.count()
                let n = if param_count < arg_count then param_count else arg_count
                while i < n then {
                    let tp = struct_template.type_parameters[i]
                    bindings.insert(tp.name, receiver_type_args[i])
                    i += 1
                }
            },
            .None() then {
                when self.storage.generic_templates.lookup_enum(type_name) in {
                    .Some(enum_template) then {
                        let mut i UInt = 0
                        let param_count = enum_template.type_parameters.count()
                        let arg_count = receiver_type_args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = enum_template.type_parameters[i]
                            bindings.insert(tp.name, receiver_type_args[i])
                            i += 1
                        }
                    },
                    .None() then {},
                }
            },
        }
    }

    protected resolve_static_declared_receiver_type(self, type_name String, receiver_type_args List[Type]) Type = {
        when self.storage.generic_templates.lookup_struct(type_name) in {
            .Some(struct_template) then {
                let mut args = List[ref Type].new()
                if receiver_type_args.is_empty() then {
                    for tp in struct_template.type_parameters then {
                        args.push(box(Type.GenericParameter(tp.name)))
                    }
                } else {
                    for arg in receiver_type_args then {
                        args.push(box(arg))
                    }
                }
                return Type.GenericStruct(type_name, args)
            },
            .None() then {
                when self.storage.generic_templates.lookup_enum(type_name) in {
                    .Some(enum_template) then {
                        let mut args = List[ref Type].new()
                        if receiver_type_args.is_empty() then {
                            for tp in enum_template.type_parameters then {
                                args.push(box(Type.GenericParameter(tp.name)))
                            }
                        } else {
                            for arg in receiver_type_args then {
                                args.push(box(arg))
                            }
                        }
                        return Type.GenericEnum(type_name, args)
                    },
                    .None() then {},
                }
            },
        }

        return when self.try_resolve_named_type_without_diag(type_name) in {
            .Some(t) then t,
            .None() then Type.Unknown(),
        }
    }

    private collect_unbound_static_generic_param_names(self, method Symbol, bindings Dict[String, Type], ordered ref mut List[String], seen ref mut Set[String]) Void = {
        for parameter_type in self.method_param_types(method) then {
            self.collect_unbound_method_generic_param_names(parameter_type, bindings, ordered, seen)
        }
        self.collect_unbound_method_generic_param_names(self.method_return_type(method), bindings, ordered, seen)
    }

    private collect_static_generic_param_names_from_params(self, method Symbol, receiver_bindings Dict[String, Type], ordered ref mut List[String], seen ref mut Set[String]) Void = {
        for parameter_type in self.method_param_types(method) then {
            self.collect_unbound_method_generic_param_names(parameter_type, receiver_bindings, ordered, seen)
        }
    }

    private collect_static_generic_param_names(self, method Symbol, receiver_bindings Dict[String, Type], ordered ref mut List[String], seen ref mut Set[String]) Void = {
        self.collect_static_generic_param_names_from_params(method, receiver_bindings, ordered, seen)
        self.collect_unbound_method_generic_param_names(self.method_return_type(method), receiver_bindings, ordered, seen)
    }

    protected resolve_static_call_type_bindings(self, type_name String, receiver_type_args List[Type], method Symbol, args List[ref TypedExpr], method_type_args List[Type], expected Option[Type]) Dict[String, Type] = {
        let mut bindings = Dict[String, Type].new()
        self.bind_static_receiver_type_args(type_name, receiver_type_args, bindings.ref)

        let mut ordered = List[String].new()
        let mut seen = Set[String].new()
        self.collect_static_generic_param_names(method, bindings, ordered.ref, seen.ref)

        let mut type_arg_i UInt = 0
        while type_arg_i < method_type_args.count() and type_arg_i < ordered.count() then {
            bindings.insert(ordered[type_arg_i], method_type_args[type_arg_i])
            type_arg_i += 1
        }

        let mut arg_i UInt = 0
        while arg_i < args.count() and arg_i < self.method_param_count(method) then {
            let param_type = self.method_param_type(method, arg_i) or else Type.Unknown()
            self.infer_type_bindings(param_type, args[arg_i].expr_type, bindings.ref)
            arg_i += 1
        }

        when expected in {
            .Some(expected_type) then self.infer_type_bindings(self.method_return_type(method), expected_type, bindings.ref),
            .None() then {},
        }
        return bindings
    }

    protected resolve_static_method_type_args_for_call(self, type_name String, receiver_type_args List[Type], method Symbol, args List[ref TypedExpr], method_type_args List[Type], expected Option[Type]) List[Type] = {
        let bindings = self.resolve_static_call_type_bindings(type_name, receiver_type_args, method, args, method_type_args, expected)
        let mut receiver_bindings = Dict[String, Type].new()
        self.bind_static_receiver_type_args(type_name, receiver_type_args, receiver_bindings.ref)
        let mut ordered = List[String].new()
        let mut seen = Set[String].new()
        self.collect_static_generic_param_names(method, receiver_bindings, ordered.ref, seen.ref)

        let mut resolved = List[Type].new()
        for name in ordered then {
            when bindings.get(name) in {
                .Some(bound) then {
                    if self.is_unresolved_expr_type(bound) or self.contains_generic_parameter(bound) then {
                        return List[Type].new()
                    }
                    resolved.push(bound)
                },
                .None() then {
                    return List[Type].new()
                },
            }
        }
        return resolved
    }

    protected resolve_static_method_return_type_for_call(self, type_name String, receiver_type_args List[Type], method Symbol, args List[ref TypedExpr], method_type_args List[Type], expected Option[Type]) Type = {
        let bindings = self.resolve_static_call_type_bindings(type_name, receiver_type_args, method, args, method_type_args, expected)
        return self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(self.method_return_type(method), bindings)))
    }

    protected resolve_method_type_args_for_call(self, base_type Type, method Symbol, args List[ref TypedExpr], method_type_args List[Type]) List[Type] = {
        let receiver_type = self.concrete_receiver_for_method(base_type, method)
        let receiver_bindings = self.resolve_signature_method_type_bindings(receiver_type, method, List[Type].new())
        let bindings = self.resolve_signature_call_type_bindings(base_type, method, args, method_type_args)
        let mut ordered = List[String].new()
        let mut seen = Set[String].new()
        self.collect_method_generic_param_names(method, receiver_bindings, ordered.ref, seen.ref)

        let mut resolved = List[Type].new()
        for name in ordered then {
            when bindings.get(name) in {
                .Some(bound) then {
                    if self.is_unresolved_expr_type(bound) or self.contains_generic_parameter(bound) then {
                        return List[Type].new()
                    }
                    resolved.push(bound)
                },
                .None() then {
                    return List[Type].new()
                },
            }
        }
        return resolved
    }

    protected resolve_method_type_args_for_call_with_expected(self, base_type Type, method Symbol, args List[ref TypedExpr], method_type_args List[Type], expected Option[Type]) List[Type] = {
        let receiver_type = self.concrete_receiver_for_method(base_type, method)
        let receiver_bindings = self.resolve_signature_method_type_bindings(receiver_type, method, List[Type].new())
        let mut bindings = self.resolve_signature_call_type_bindings(base_type, method, args, method_type_args)
        let mut ordered_from_params = List[String].new()
        let mut seen_from_params = Set[String].new()
        self.collect_method_generic_param_names_from_params(method, receiver_bindings, ordered_from_params.ref, seen_from_params.ref)
        if args.is_empty() and method_type_args.is_empty() and self.method_param_count(method) == 1(UInt) and expected is .None() then {
            return List[Type].new()
        }
        // Align with Swift sema: if arguments produced no method-level bindings and
        // there is no expected return type or explicit method type args, we do not
        // infer method generics from return position alone.
        if ordered_from_params.is_empty() and method_type_args.is_empty() and expected is .None() then {
            return List[Type].new()
        }
        let mut ordered = ordered_from_params
        let mut seen = seen_from_params
        self.collect_unbound_method_generic_param_names(self.method_return_type(method), receiver_bindings, ordered.ref, seen.ref)
        if ordered.is_empty() then {
            return List[Type].new()
        }
        when expected in {
            .Some(expected_type) then self.infer_type_bindings(self.method_return_type(method), expected_type, bindings.ref),
            .None() then {},
        }

        let mut resolved = List[Type].new()
        for name in ordered then {
            when bindings.get(name) in {
                .Some(bound) then {
                    if self.is_unresolved_expr_type(bound) or self.contains_generic_parameter(bound) then {
                        return List[Type].new()
                    }
                    resolved.push(bound)
                },
                .None() then {
                    return List[Type].new()
                },
            }
        }
        return resolved
    }

    protected resolve_method_return_type_for_call(self, base_type Type, method Symbol, args List[ref TypedExpr], method_type_args List[Type]) Type = {
        if self.method_param_count(method) == 0 then {
            let bindings = self.resolve_signature_call_type_bindings(base_type, method, args, method_type_args)
            return self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(self.method_return_type(method), bindings)))
        }

        let receiver_type = self.concrete_receiver_for_method(base_type, method)
        let mut bindings = self.resolve_signature_call_type_bindings(base_type, method, args, method_type_args)
        let self_param_type = self.method_param_type(method, 0(UInt)) or else Type.Unknown()
        if bindings.is_empty() and self.same_expr_type(self_param_type, receiver_type) then {
            let concrete_return_type = self.canonicalize_alias_type(self.concretize_default_literal_type(self.method_return_type(method)))
            return concrete_return_type
        }
        let concrete_self_type = when receiver_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then receiver_type,
        }
        bindings.insert("Self", concrete_self_type)
        let bound_self_type = self.apply_type_bindings(self_param_type, bindings)
        let bound_return_type = self.apply_type_bindings(self.method_return_type(method), bindings)
        return self.canonicalize_alias_type(self.concretize_default_literal_type(self.replace_type_occurrence(bound_return_type, bound_self_type, concrete_self_type)))
    }

    protected resolve_method_signature(self, base_type Type, method_name String) Option[Symbol] = {
        let normalized_base_type = self.normalize_method_receiver_type(base_type)
        let inner_type = when normalized_base_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then normalized_base_type,
        }

        when inner_type in {
            .GenericParameter(name) then {
                if self.storage.generic_param_constraints.get(name) is .Some(constraints) then {
                    for constraint in constraints then {
                        let cn = constraint.trait_name
                        if cn == "Any" then {
                            continue
                        }
                        when self.resolve_trait_registry_method_signature(cn, method_name, inner_type) in {
                            .Some(method) then { return Option[Symbol].Some(method) },
                            .None() then {},
                        }
                    }
                }
            },
            .TraitObject(trait_name, _) then {
                when self.storage.trait_registry.flatten_methods(trait_name) in {
                    .Ok(methods) then {
                        if methods.get(method_name) is .Some(member) then {
                            let mut typed_params = List[TypedParam].new()
                            for p in member.params then {
                                typed_params.push(TypedParam(p.name, p.mutable, p.param_type, p.named))
                            }
                            return Option[Symbol].Some(self.make_method_callable_symbol(method_name, typed_params, member.return_type))
                        }
                    },
                    .Error(_) then {},
                }
                if self.lookup_method_signature(trait_name, method_name) is .Some(raw_method) then {
                    return Option[Symbol].Some(raw_method)
                }
            },
            _ then {},
        }

        let type_key = self.context().type_display_name(inner_type)
        if self.lookup_method_signature(type_key, method_name) is .Some(raw_method) then {
            return Option[Symbol].Some(self.bind_direct_method_signature(base_type, method_name, raw_method))
        }

        when self.resolve_extension_template_signature(normalized_base_type, inner_type, method_name) in {
            .Some(method) then { return Option[Symbol].Some(method) },
            .None() then {},
        }

        let template_key = self.resolve_method_template_key(inner_type)
        if template_key is .Some(key) and self.lookup_method_signature(key, method_name) is .Some(raw_method) then {
            return Option[Symbol].Some(self.bind_direct_method_signature(base_type, method_name, raw_method))
        }

        // Check weakref intrinsic given extension methods (e.g., to_ref on T weakref / T weakref mut)
        when self.resolve_weakref_extension_template_signature(normalized_base_type, method_name) in {
            .Some(method_symbol) then { return Option[Symbol].Some(method_symbol) },
            .None() then {},
        }

        when self.resolve_conformance_method_signature(inner_type, method_name) in {
            .Some(method) then { return Option[Symbol].Some(method) },
            .None() then {},
        }

        when self.resolve_conformance_extension_template_signature(normalized_base_type, inner_type, method_name) in {
            .Some(method) then { return Option[Symbol].Some(method) },
            .None() then {},
        }

        when self.resolve_modifier_extension_template_signature(normalized_base_type, method_name) in {
            .Some(method_symbol) then { return Option[Symbol].Some(method_symbol) },
            .None() then {},
        }

        return Option[Symbol].None()
    }

    protected resolve_method_param_types_with_method_type_args(self, base_type Type, method_name String, method_type_args List[Type]) List[Type] = {
        return when self.resolve_method_signature(base_type, method_name) in {
            .Some(method) then {
                let mut out = List[Type].new()
                if self.method_param_count(method) > 1(UInt) then {
                    let receiver_type = self.concrete_receiver_for_method(base_type, method)
                    let bindings = self.resolve_signature_method_type_bindings(receiver_type, method, method_type_args)
                    let mut i UInt = 1
                    while i < self.method_param_count(method) then {
                        let param_type = self.method_param_type(method, i) or else Type.Unknown()
                        out.push(self.apply_type_bindings(param_type, bindings))
                        i += 1
                    }
                }
                yield out
            },
            .None() then self.resolve_method_param_types(base_type, method_name),
        }
    }

    protected resolve_method_return_type_with_method_type_args(self, base_type Type, method_name String, method_type_args List[Type]) Type = {
        return when self.resolve_method_signature(base_type, method_name) in {
            .Some(method) then {
                let receiver_type = self.concrete_receiver_for_method(base_type, method)
                let bindings = self.resolve_signature_method_type_bindings(receiver_type, method, method_type_args)
                yield self.canonicalize_alias_type(self.concretize_default_literal_type(self.apply_type_bindings(self.method_return_type(method), bindings)))
            },
            .None() then self.resolve_method_return_type(base_type, method_name),
        }
    }

    // 从 trait registry 中提取 trait 方法的参数类型列表（不含 self）。
    protected resolve_trait_method_param_types(self, trait_name String, method_name String, receiver_type Type) List[Type] = {
        when self.resolve_conformance_trait_method_signature(receiver_type, trait_name, method_name) in {
            .Some(method) then {
                let mut out = List[Type].new()
                let mut i UInt = 1
                while i < self.method_param_count(method) then {
                    out.push(self.method_param_type(method, i) or else Type.Unknown())
                    i += 1
                }
                return out
            },
            .None() then {},
        }
        if self.storage.trait_registry.flatten_methods(trait_name) is .Ok(methods) and methods.get(method_name) is .Some(member) then {
            // member.params 包含 self，跳过第一个
            if member.params.count() > 0(UInt) then {
                let mut out = List[Type].new()
                let mut i = 1(UInt)
                while i < member.params.count() then {
                    out.push(self.apply_trait_self_binding(member.params[i].param_type, receiver_type))
                    i += 1(UInt)
                }
                return out
            }
            return List[Type].new()
        }
        if self.lookup_method_signature(trait_name, method_name) is .Some(method) then {
            if self.method_param_count(method) > 0(UInt) then {
                let concrete_receiver_type = self.concrete_receiver_for_method(receiver_type, method)
                let mut bindings = Dict[String, Type].new()
                self.infer_type_bindings(self.method_param_type(method, 0(UInt)) or else Type.Unknown(), concrete_receiver_type, bindings.ref)
                let mut out = List[Type].new()
                let mut i UInt = 1
                while i < self.method_param_count(method) then {
                    let param_type = self.method_param_type(method, i) or else Type.Unknown()
                    out.push(self.apply_type_bindings(param_type, bindings))
                    i += 1
                }
                return out
            }
            return List[Type].new()
        }
        return List[Type].new()
    }

    protected resolve_trait_method_self_type(self, trait_name String, method_name String, receiver_type Type) Option[Type] = {
        when self.resolve_conformance_trait_method_signature(receiver_type, trait_name, method_name) in {
            .Some(method) then {
                if self.method_param_count(method) > 0(UInt) then {
                    return Option[Type].Some(self.method_param_type(method, 0(UInt)) or else Type.Unknown())
                }
            },
            .None() then {},
        }
        if self.storage.trait_registry.flatten_methods(trait_name) is .Ok(methods) and methods.get(method_name) is .Some(member) and member.params.count() > 0(UInt) then {
            return Option[Type].Some(self.apply_trait_self_binding(member.params[0(UInt)].param_type, receiver_type))
        }
        if self.lookup_method_signature(trait_name, method_name) is .Some(method) then {
            return self.resolve_bound_method_self_type(receiver_type, method)
        }
        return Option[Type].None()
    }

    private collect_ordered_trait_members(
        self,
        trait_name String,
        ordered ref mut List[TypedTraitMember],
        seen ref mut Set[String],
        visited ref mut Set[String],
    ) Void = {
        if visited.contains(trait_name) then {
            return
        }
        visited.insert(trait_name)
        let info = self.storage.trait_registry.get(trait_name) or else {
            return
        }
        for parent in info.parent_traits then {
            self.collect_ordered_trait_members(parent.name, ordered, seen, visited)
        }
        for member in info.methods then {
            if not seen.contains(member.name) then {
                seen.insert(member.name)
                ordered.push(member)
            }
        }
    }

    protected trait_vtable_method_index(self, trait_name String, method_name String) Option[Int] = {
        let mut ordered = List[TypedTraitMember].new()
        let mut seen = Set[String].new()
        let mut visited = Set[String].new()
        self.collect_ordered_trait_members(trait_name, ordered.ref, seen.ref, visited.ref)
        let mut index UInt = 0
        while index < ordered.count() then {
            if ordered[index].name == method_name then {
                return Option[Int].Some(index(Int))
            }
            index += 1
        }
        return Option[Int].None()
    }

    // 从 trait registry 解析 qualified method call 的返回类型。
    // 先查 trait registry，再回退到 base_type 的 method_table。
    protected resolve_qualified_method_return_type(self, trait_name String, method_name String, base_type Type) Type = {
        when self.resolve_conformance_trait_method_signature(base_type, trait_name, method_name) in {
            .Some(method) then { return self.method_return_type(method) },
            .None() then {},
        }
        when self.storage.trait_registry.flatten_methods(trait_name) in {
            .Ok(methods) then {
                when methods.get(method_name) in {
                    .Some(member) then {
                        when member.return_type in {
                            .Unknown() then {},
                            _ then { return self.apply_trait_self_binding(member.return_type, base_type) },
                        }
                    },
                    .None() then {},
                }
            },
            .Error(_) then {},
        }
        if self.lookup_method_signature(trait_name, method_name) is .Some(method) then {
            return self.resolve_signature_return_type(self.concrete_receiver_for_method(base_type, method), method)
        }
        // 回退到 base_type 的 method_table
        return self.resolve_method_return_type(base_type, method_name)
    }

    // 从 method_table 中提取静态方法/enum case 构造器的参数类型列表。
    protected resolve_static_method_param_types(self, type_name String, method_name String) List[Type] = {
        return when self.lookup_method_signature(type_name, method_name) in {
            .Some(method) then {
                let mut out = List[Type].new()
                for parameter_type in self.method_param_types(method) then {
                    out.push(parameter_type)
                }
                yield out
            },
            .None() then
                // 尝试从 enum case 字段获取参数类型
                when self.storage.global_scope.lookup_type(type_name) in {
                    .Some(t) then self.get_enum_case_field_types(t, method_name),
                    .None() then List[Type].new(),
                },
        }
    }

    protected resolve_static_method_param_types_for_receiver(self, type_name String, receiver_type Type, method_name String) List[Type] = {
        return when self.resolve_static_method_signature_for_receiver(type_name, receiver_type, method_name) in {
            .Some(method) then {
                let mut out = List[Type].new()
                for parameter_type in self.method_param_types(method) then {
                    out.push(parameter_type)
                }
                yield out
            },
            .None() then self.resolve_static_method_param_types(type_name, method_name),
        }
    }

    private apply_static_method_type_bindings(self, type_name String, type_args List[ref Type], return_type Type) Type = {
        if type_args.is_empty() then {
            return return_type
        }

        let mut bindings = Dict[String, Type].new()
        let receiver_type = when self.storage.global_scope.lookup_type(type_name) in {
            .Some(t) then when t in {
                .StructureType(_) then Type.GenericStruct(type_name, type_args),
                .EnumType(_) then Type.GenericEnum(type_name, type_args),
                _ then Type.Unknown(),
            },
            .None() then Type.Unknown(),
        }
        when receiver_type in {
            .Unknown() then {},
            _ then { bindings.insert("Self", receiver_type) },
        }

        when self.storage.generic_templates.lookup_struct(type_name) in {
            .Some(struct_template) then {
                let mut i UInt = 0
                let param_count = struct_template.type_parameters.count()
                let arg_count = type_args.count()
                let n = if param_count < arg_count then param_count else arg_count
                while i < n then {
                    let tp = struct_template.type_parameters[i]
                    bindings.insert(tp.name, type_args[i].val)
                    i += 1
                }
            },
            .None() then {
                when self.storage.generic_templates.lookup_enum(type_name) in {
                    .Some(enum_template) then {
                        let mut i UInt = 0
                        let param_count = enum_template.type_parameters.count()
                        let arg_count = type_args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = enum_template.type_parameters[i]
                            bindings.insert(tp.name, type_args[i].val)
                            i += 1
                        }
                    },
                    .None() then {},
                }
            },
        }

        return self.apply_type_bindings(return_type, bindings)
    }

    protected bind_static_method_param_types(self, type_name String, type_args List[ref Type], param_types List[Type]) List[Type] = {
        if type_args.is_empty() then {
            return param_types
        }

        let mut bindings = Dict[String, Type].new()
        let receiver_type = when self.storage.global_scope.lookup_type(type_name) in {
            .Some(t) then when t in {
                .StructureType(_) then Type.GenericStruct(type_name, type_args),
                .EnumType(_) then Type.GenericEnum(type_name, type_args),
                _ then Type.Unknown(),
            },
            .None() then Type.Unknown(),
        }
        when receiver_type in {
            .Unknown() then {},
            _ then { bindings.insert("Self", receiver_type) },
        }

        when self.storage.generic_templates.lookup_struct(type_name) in {
            .Some(struct_template) then {
                let mut i UInt = 0
                let param_count = struct_template.type_parameters.count()
                let arg_count = type_args.count()
                let n = if param_count < arg_count then param_count else arg_count
                while i < n then {
                    let tp = struct_template.type_parameters[i]
                    bindings.insert(tp.name, type_args[i].val)
                    i += 1
                }
            },
            .None() then {
                when self.storage.generic_templates.lookup_enum(type_name) in {
                    .Some(enum_template) then {
                        let mut i UInt = 0
                        let param_count = enum_template.type_parameters.count()
                        let arg_count = type_args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = enum_template.type_parameters[i]
                            bindings.insert(tp.name, type_args[i].val)
                            i += 1
                        }
                    },
                    .None() then {},
                }
            },
        }

        let mut bound = List[Type].new()
        for param_type in param_types then {
            bound.push(self.apply_type_bindings(param_type, bindings))
        }
        return bound
    }

    private resolve_call_return_type(self, callee ref TypedExpr) Type = {
        when callee.expr_kind in {
            .Variable(sym) then {
                if self.context().get_function_return_type(sym.def_id) is .Some(return_type) then {
                    return return_type
                }
                let sym_name = self.context().symbol_name(sym.val)
                return when sym.symbol_type in {
                    .FunctionType(_, ret) then ret.val,
                    .StructureType(_) then sym.symbol_type,
                    .EnumType(_) then sym.symbol_type,
                    .GenericStruct(_, _) then sym.symbol_type,
                    .GenericEnum(_, _) then sym.symbol_type,
                    _ then if self.storage.global_scope.lookup_type(sym_name) is .Some(t) then t else Type.Unknown(),
                }
            },
            .MemberPath(base, path) then if not path.is_empty() then {
                return self.resolve_method_return_type(base.expr_type, path[path.count() - 1])
            },
            .MethodReference(base, _, method, _, _, _) then {
                when method.symbol_type in {
                    .FunctionType(_, ret) then {
                        return ret.val
                    },
                    _ then {},
                }
                if self.context().get_function_return_type(method.def_id) is .Some(return_type) then {
                    return return_type
                }
                return self.resolve_method_return_type(base.expr_type, self.context().symbol_name(method.val))
            },
            .TraitMethodPlaceholder(base, trait_type, method, _, _) then {
                let trait_name = self.trait_name_from_type(trait_type)
                let method_name = self.context().symbol_name(method.val)
                let qualified_return_type = self.resolve_qualified_method_return_type(trait_name, method_name, base.expr_type)
                return when qualified_return_type in {
                    .Unknown() then self.resolve_method_return_type(base.expr_type, self.context().symbol_name(method.val)),
                    _ then qualified_return_type,
                }
            },
            .StaticMethodCall(receiver_type, _, method, _, _, _) then {
                when method.symbol_type in {
                    .FunctionType(_, ret) then {
                        return ret.val
                    },
                    .Unknown() then {},
                    _ then {
                        return method.symbol_type
                    },
                }
                if self.context().get_function_return_type(method.def_id) is .Some(return_type) then {
                    return return_type
                }
                return self.resolve_method_return_type(receiver_type, self.context().symbol_name(method.val))
            },
            .GenericInstantiation(_, _) then {
                return callee.expr_type
            },
            .TraitMethodCall(base, trait_type, method_name, _, _) then {
                let trait_name = self.trait_name_from_type(trait_type)
                let qualified_return_type = self.resolve_qualified_method_return_type(trait_name, method_name, base.expr_type)
                return when qualified_return_type in {
                    .Unknown() then self.resolve_method_return_type(base.expr_type, method_name),
                    _ then qualified_return_type,
                }
            },
            _ then {},
        }
        when callee.expr_type in {
            .FunctionType(_, ret) then { return ret.val },
            _ then {},
        }
        return Type.Unknown()
    }

    // 从 callee 的类型信息中提取参数类型列表，用于向调用参数传播期望类型。
    // 返回空列表表示无法确定参数类型。
    protected resolve_call_param_types(self, callee ref TypedExpr) List[Type] = {
        when callee.expr_kind in {
            .Variable(sym) then {
                if self.context().get_function_type(sym.def_id) is .Some(function_type) then {
                    let mut out = List[Type].new()
                    when function_type in {
                        .FunctionType(fn_params, _) then {
                            for parameter in fn_params then {
                                out.push(parameter.param_type)
                            }
                        },
                        _ then {},
                    }
                    return out
                }
                let constructor_param_types = self.struct_constructor_param_types(sym.symbol_type)
                if not constructor_param_types.is_empty() then {
                    let mut out = List[Type].new()
                    for param_type in constructor_param_types then {
                        out.push(param_type)
                    }
                    return out
                }
                when sym.symbol_type in {
                    .FunctionType(params, _) then {
                        let mut out = List[Type].new()
                        for entry in params then {
                            out.push(entry.param_type)
                        }
                        return out
                    },
                    _ then {},
                }
                return List[Type].new()
            },
            .MemberPath(base, path) then if not path.is_empty() then {
                let mut out = List[Type].new()
                for param_type in self.resolve_method_param_types(base.expr_type, path[path.count() - 1]) then {
                    out.push(param_type)
                }
                return out
            },
            .MethodReference(base, _, method, _, _, _) then {
                let method_name = self.context().symbol_name(method.val)
                let mut out = List[Type].new()
                for param_type in self.resolve_method_param_types(base.expr_type, method_name) then {
                    out.push(param_type)
                }
                return out
            },
            .TraitMethodPlaceholder(base, trait_type, method, _, _) then {
                let trait_name = self.trait_name_from_type(trait_type)
                let method_name = self.context().symbol_name(method.val)
                let trait_params = self.resolve_trait_method_param_types(trait_name, method_name, base.expr_type)
                if trait_params.is_empty() then {
                    let mut out = List[Type].new()
                    for param_type in self.resolve_method_param_types(base.expr_type, method_name) then {
                        out.push(param_type)
                    }
                    return out
                }
                let mut out = List[Type].new()
                for param_type in trait_params then {
                    out.push(param_type)
                }
                return out
            },
            .TraitMethodCall(base, trait_type, method_name, _, _) then {
                let trait_name = self.trait_name_from_type(trait_type)
                let trait_params = self.resolve_trait_method_param_types(trait_name, method_name, base.expr_type)
                if trait_params.is_empty() then {
                    let mut out = List[Type].new()
                    for param_type in self.resolve_method_param_types(base.expr_type, method_name) then {
                        out.push(param_type)
                    }
                    return out
                }
                let mut out = List[Type].new()
                for param_type in trait_params then {
                    out.push(param_type)
                }
                return out
            },
            _ then {},
        }
        when callee.expr_type in {
            .FunctionType(params, _) then {
                let mut out = List[Type].new()
                for entry in params then {
                    out.push(entry.param_type)
                }
                return out
            },
            _ then {},
        }
        return List[Type].new()
    }

    private struct_constructor_param_types(self, constructor_type Type) List[Type] = {
        let inner_type = when constructor_type in {
            .MutableReferenceType(inner) then inner.val,
            .ReferenceType(inner) then inner.val,
            .MutableBorrowedReferenceType(inner, _) then inner.val,
            .BorrowedReferenceType(inner, _) then inner.val,
            .WeakReferenceType(inner) then inner.val,
            .MutableWeakReferenceType(inner) then inner.val,
            _ then constructor_type,
        }

        return when inner_type in {
            .StructureType(DefId(def_id)) then when self.context().get_struct_fields_by_raw_id(def_id(UInt)) in {
                .Some(fields) then {
                    let mut types = List[Type].new()
                    for field in fields then {
                        types.push(field.field_type)
                    }
                    yield types
                },
                .None() then List[Type].new(),
            },
            .GenericStruct(template_name, args) then when self.storage.generic_templates.lookup_struct(template_name) in {
                .Some(struct_template) then when self.context().get_struct_fields(struct_template.def_id) in {
                    .Some(fields) then {
                        let mut bindings = Dict[String, Type].new()
                        let mut i UInt = 0
                        let param_count = struct_template.type_parameters.count()
                        let arg_count = args.count()
                        let n = if param_count < arg_count then param_count else arg_count
                        while i < n then {
                            let tp = struct_template.type_parameters[i]
                            bindings.insert(tp.name, args[i].val)
                            i += 1
                        }
                        let mut types = List[Type].new()
                        for field in fields then {
                            types.push(self.apply_type_bindings(field.field_type, bindings))
                        }
                        yield types
                    },
                    .None() then List[Type].new(),
                },
                .None() then List[Type].new(),
            },
            _ then List[Type].new(),
        }
    }

    // 将 TypeSubstitution 应用到 TypedDecl（递归替换所有类型变量）
}
