using Std.Os.*

private type ParseDeclFlags(
    access AccessModifier,
    has_explicit_access Bool,
    is_foreign Bool,
    is_intrinsic Bool,
)

public type Parser(
    tokens [Token]List,
    mut index UInt,
)

given Parser {
    private parse_debug(self, message String) Void = {
        if env("KORAL_DEBUG_PARSE") is .Some(value) and (value == "1" or value == "true" or value == "TRUE") then {
            eprintln("[parse] \(message)")
        }
    }

    private previous_token(self) [Token]Option = {
        if self.index == 0 then {
            return .None()
        }
        return .Some(self.tokens.at(self.index - 1))
    }

    private span_from_start(self, start Token) SourceSpan = {
        let start_loc = SourceLocation(start.line, start.column)
        let end_tok = self.previous_token() or else {
            return SourceSpan(start_loc, start_loc)
        }
        let end_loc = SourceLocation(end_tok.line, end_tok.column)
        return SourceSpan(start_loc, end_loc)
    }

    private token_span(self, token Token) SourceSpan = {
        let loc = SourceLocation(token.line, token.column)
        return SourceSpan(loc, loc)
    }

    private span_from_expr_start(self, expr Expr ref) SourceSpan = {
        let expr_base_span = expr_span(expr)
        let end_tok = self.previous_token() or else {
            return expr_base_span
        }
        if not is_known_span(expr_base_span) then {
            let end_loc = SourceLocation(end_tok.line, end_tok.column)
            return SourceSpan(end_loc, end_loc)
        }
        let end_loc = SourceLocation(end_tok.line, end_tok.column)
        return SourceSpan(expr_base_span.start, end_loc)
    }

    private is_decimal_digits(self, text String) Bool = {
        let runes = text.to_runes()
        if runes.is_empty() then {
            return false
        }
        for r in runes then {
            if not r.is_ascii_digit() then {
                return false
            }
        }
        return true
    }

    // 按顶层 | 分割 pattern 文本（忽略括号内的 |）
    private split_or_pattern(self, text String) [String]List = {
        let mut result = [String]List.new()
        let mut current = String.new()
        let mut depth UInt = 0
        let runes = text.to_runes()
        for ch in runes then {
            if ch == '(' or ch == '[' then {
                depth += 1
                current.push_rune(ch)
            } else if ch == ')' or ch == ']' then {
                if depth > 0 then { depth -= 1 }
                current.push_rune(ch)
            } else if ch == '|' and depth == 0 then {
                result.push(current)
                current = String.new()
            } else {
                current.push_rune(ch)
            }
        }
        result.push(current)
        return result
    }

    private pattern_from_text(self, text String, span SourceSpan) PatternNode = {
        // 先检查顶层 | 分割（or 模式）
        let or_parts = self.split_or_pattern(text)
        if or_parts.count() > 1 then {
            // 有多个 or 分支，递归构建 OrPattern（右结合）
            let mut i UInt = or_parts.count()
            let last_part = or_parts.at(i - 1).trim_ascii()
            let mut result = self.pattern_from_text(last_part, span)
            while i > 1 then {
                i -= 1
                let part = or_parts.at(i - 1).trim_ascii()
                let left = self.pattern_from_text(part, span)
                result = PatternNode.OrPattern(box(left), box(result), span)
            }
            return result
        }

        if text == "_" then {
            return PatternNode.Wildcard(span)
        }
        if text == "true" then {
            return PatternNode.BoolLiteral(true, span)
        }
        if text == "false" then {
            return PatternNode.BoolLiteral(false, span)
        }
        if self.is_decimal_digits(text) then {
            return PatternNode.IntegerLiteral(text, span)
        }
        if text.starts_with("mut ") then {
            let name = text.substring(4..)
            if not name.is_empty() then {
                return PatternNode.Variable(name, true, span)
            }
        }
        if text.starts_with(".") then {
            let rest = text.substring(1..)
            // 检查是否有括号参数：". SomeName ( ... )"
            when rest.find("(") in {
                .Some(lparen_idx) then {
                    let case_name = rest.substring((UInt)0..<lparen_idx).trim_ascii()
                    // 找最后一个 ')'
                    when rest.find_last(")") in {
                        .Some(rparen_idx) then {
                            let inner = rest.substring(lparen_idx + 1..<rparen_idx).trim_ascii()
                            let mut elements = [PatternElement]List.new()
                            if not inner.is_empty() then {
                                // 按逗号分割，每个子 pattern 递归解析
                                let parts = self.split_pattern_args(inner)
                                for part in parts then {
                                    let trimmed = part.trim_ascii()
                                    if not trimmed.is_empty() then {
                                        elements.push(PatternElement([String]Option.None(), box(self.pattern_from_text(trimmed, span))))
                                    }
                                }
                            }
                            return PatternNode.EnumCase(case_name, elements, span)
                        },
                        .None() then {},
                    }
                },
                .None() then {
                    let case_name = rest.trim_ascii()
                    if not case_name.is_empty() then {
                        return PatternNode.EnumCase(case_name, [PatternElement]List.new(), span)
                    }
                },
            }
        }
        return PatternNode.Variable(text, false, span)
    }

    // 按顶层逗号分割 pattern 参数列表（忽略括号内的逗号）
    private split_pattern_args(self, text String) [String]List = {
        let mut result = [String]List.new()
        let mut current = String.new()
        let mut depth UInt = 0
        let runes = text.to_runes()
        for ch in runes then {
            if ch == '(' or ch == '[' then {
                depth += 1
                current.push_rune(ch)
            } else if ch == ')' or ch == ']' then {
                if depth > 0 then { depth -= 1 }
                current.push_rune(ch)
            } else if ch == ',' and depth == 0 then {
                result.push(current)
                current = String.new()
            } else {
                current.push_rune(ch)
            }
        }
        if not current.trim_ascii().is_empty() then {
            result.push(current)
        }
        return result
    }

    public new(tokens [Token]List) Parser = {
        return Parser(tokens, 0)
    }

    private current(self) Token = {
        if self.index < self.tokens.count() then {
            return self.tokens.at(self.index)
        }
        return Token(TokenKind.Eof(), 0, 0, false, (UInt)0)
    }

    private save_state(self) UInt = self.index

    private restore_state(self ref, saved UInt) Void = {
        self.index = saved
    }

    private peek_kind(self) [TokenKind]Option = {
        if self.index + 1 < self.tokens.count() then {
            return .Some(self.tokens.at(self.index + 1).kind)
        }
        return .None()
    }

    private is_eof(self) Bool = {
        when self.current().kind in {
            .Eof() then { return true },
            _ then { return false },
        }
    }

    // 检查 token 是否是表达式开始（用于区分类型转换和括号表达式）
    private is_expr_start_token(self, kind TokenKind) Bool = {
        return when kind in {
            .Identifier(_) then true,
            .IntegerLiteral(_) then true,
            .DurationLiteral(_, _) then true,
            .FloatLiteral(_) then true,
            .StringLiteral(_) then true,
            .RuneLiteral(_) then true,
            .KwTrue() then true,
            .KwFalse() then true,
            .LParen() then true,
            .LBrace() then true,
            .LBracket() then true,
            .KwNot() then true,
            .Minus() then true,
            .Tilde() then true,
            .KwIf() then true,
            .KwWhile() then true,
            .KwFor() then true,
            .KwWhen() then true,
            .KwLet() then true,
            .KwSelf() then true,
            .Dot() then true,
            _ then false,
        }
    }

    // 检查当前位置是否是泛型类型表达式 [T, U]TypeName
    // 判断字符串首字母是否大写（用于区分类型名和变量名）
    private is_upper_first(self, s String) Bool = {
        if s.is_empty() then { return false }
        let runes = s.to_runes()
        if runes.is_empty() then { return false }
        return runes.at(0).is_ascii_uppercase()
    }

    // 通过 lookahead 检查 [...] 后面是否跟着标识符
    private is_generic_type_expr(self) Bool = {
        when self.current().kind in {
            .LBracket() then {},
            _ then { return false },
        }
        
        // Lookahead: 跳过 [...] 找到 ] 后的 token
        let mut depth UInt = 0
        let mut i = self.index
        while i < self.tokens.count() then {
            let tok = self.tokens.at(i)
            when tok.kind in {
                .LBracket() then { depth += 1 },
                .RBracket() then {
                    if depth == 1 then {
                        // 找到匹配的 ]，检查下一个 token
                        if i + 1 < self.tokens.count() then {
                            let next_tok = self.tokens.at(i + 1)
                            return when next_tok.kind in {
                                .Identifier(_) then not next_tok.has_newline_before,
                                _ then false,
                            }
                        }
                        return false
                    }
                    depth -= 1
                },
                .Eof() then { return false },
                _ then {},
            }
            i += 1
        }
        return false
    }

    private advance(self ref) Token = {
        let t = self.current()
        if not self.is_eof() then {
            self.index += 1
        }
        return t
    }

    private consume_semicolon(self ref) Void = {
        if self.current().kind is .Semicolon() then {
            self.advance()
        }
    }

    // 判断当前 token 是否是续行 token（出现在行首时不触发自动分号）
    private is_continuation_token(self) Bool = {
        return when self.current().kind in {
            // 算术中缀运算符
            .Plus() then true,
            .Minus() then true,
            .Star() then true,
            .Slash() then true,
            .Percent() then true,
            // 逻辑运算符
            .KwAnd() then true,
            .KwOr() then true,
            // 位运算符（不含 ~ 前缀运算符）
            .Ampersand() then true,
            .Pipe() then true,
            .Caret() then true,
            .LeftShift() then true,
            .RightShift() then true,
            // 比较运算符
            .EqualEqual() then true,
            .NotEqual() then true,
            .Greater() then true,
            .Less() then true,
            .GreaterEqual() then true,
            .LessEqual() then true,
            // 成员访问和链式调用
            .Dot() then true,
            // lambda 箭头
            .Arrow() then true,
            // 范围运算符
            .Range() then true,
            .RangeLess() then true,
            .LessRange() then true,
            .LessRangeLess() then true,
            _ then false,
        }
    }

    // 判断是否应该终止当前语句（自动分号插入规则）
    private should_terminate_statement(self) Bool = {
        // 显式分号
        if self.current().kind is .Semicolon() then {
            return true
        }
        // 文件结束或块结束
        if self.current().kind is .Eof() then {
            return true
        }
        if self.current().kind is .RBrace() then {
            return true
        }
        // 换行规则：有换行且当前 token 不是续行 token
        if self.current().has_newline_before then {
            if not self.is_continuation_token() then {
                return true
            }
        }
        return false
    }

    // 消耗可选的语句终止符（分号或换行）
    private consume_statement_terminator(self ref) Void = {
        if self.current().kind is .Semicolon() then {
            self.advance()
        }
        // 换行自动终止不需要消耗 token
    }

    private can_continue_dot_postfix(self) Bool = {
        if self.current().kind is not .Dot() then {
            return false
        }
        return not self.current().has_newline_before or self.current().newline_count_before <= (UInt)1
    }

    private should_continue_postfix_after_expression(self) Bool = {
        return when self.current().kind in {
            .LParen() then not self.current().has_newline_before,
            .LBracket() then not self.current().has_newline_before,
            .Dot() then self.can_continue_dot_postfix(),
            _ then false,
        }
    }

    private expect_identifier(self ref, label String) [String]Result = {
        let t = self.current()
        if t.kind is .Identifier(name) then {
            self.advance()
            return .Ok(name)
        }
        return .Error(box("Expected identifier for \(label) at \(t.line):\(t.column)"))
    }

    private parse_decl_flags(self ref) ParseDeclFlags = {
        let mut access = AccessModifier.Protected()
        let mut has_explicit_access = false
        let mut is_foreign = false
        let mut is_intrinsic = false

        while true then {
            when self.current().kind in {
                .KwPublic() then {
                    has_explicit_access = true
                    access = AccessModifier.Public()
                    self.advance()
                },
                .KwProtected() then {
                    has_explicit_access = true
                    access = AccessModifier.Protected()
                    self.advance()
                },
                .KwPrivate() then {
                    has_explicit_access = true
                    access = AccessModifier.Private()
                    self.advance()
                },
                .KwForeign() then {
                    is_foreign = true
                    self.advance()
                },
                .KwIntrinsic() then {
                    is_intrinsic = true
                    self.advance()
                },
                _ then {
                    break
                },
            }
        }

        return ParseDeclFlags(access, has_explicit_access, is_foreign, is_intrinsic)
    }

    private wrap_decl(self, access AccessModifier, is_foreign Bool, is_intrinsic Bool, base Decl) [Decl]Result = {
        if is_foreign and is_intrinsic then {
            return .Error(box("foreign and intrinsic cannot be used together"))
        }

        if is_foreign then {
            return when base in {
                .FunctionDecl(_, name, _, params, return_type, _, span) then .Ok(Decl.ForeignFunctionDecl(access, name, params, return_type, span)),
                .LetDecl(_, name, mutable, type_name, _, span) then .Ok(Decl.ForeignLetDecl(access, name, mutable, type_name, span)),
                .TypeStructDecl(_, name, _, fields, span) then .Ok(Decl.ForeignTypeDecl(access, name, [String]Option.None(), [[Field]List]Option.Some(fields), span)),
                .PathUsingDecl(_, path_segments, _, _, _, span) then if path_segments.is_empty()
                    then .Error(box("foreign using declaration requires library name"))
                    else .Ok(Decl.ForeignUsingDecl(access, path_segments.at(0), span)),
                .FileUsingDecl(_, file_name, _, span) then .Ok(Decl.ForeignUsingDecl(access, file_name, span)),
                .GivenDecl(_, _, _, _) then .Error(box("foreign given declaration is not supported")),
                .GivenTraitDecl(_, _, _, _, _) then .Error(box("foreign given declaration is not supported")),
                _ then .Error(box("unsupported foreign declaration kind")),
            }
        }

        if is_intrinsic then {
            return when base in {
                .FunctionDecl(_, name, type_params, params, return_type, _, span) then .Ok(Decl.IntrinsicFunctionDecl(access, name, type_params, params, return_type, span)),
                .GivenDecl(target_type, type_params, members, span) then .Ok(Decl.IntrinsicGivenDecl(target_type, type_params, members, span)),
                .GivenTraitDecl(_, _, _, _, _) then .Error(box("intrinsic given trait declaration is not supported")),
                .TypeStructDecl(_, name, type_params, _, span) then .Ok(Decl.IntrinsicTypeDecl(access, name, type_params, span)),
                _ then .Error(box("unsupported intrinsic declaration kind")),
            }
        }
        return .Ok(base)
    }

    private is_type_start(self) Bool = {
        return when self.current().kind in {
            .KwSelfType() then true,
            .Identifier(_) then true,
            .LBracket() then true,
            _ then false,
        }
    }

    private parse_type_suffixes(self ref, base TypeNode) TypeNode = {
        let mut base = base
        while true then {
            when self.current().kind in {
                .KwRef() then {
                    self.advance()
                    base = TypeNode.Reference(box(base))
                },
                .KwPtr() then {
                    self.advance()
                    base = TypeNode.Pointer(box(base))
                },
                .KwWeakref() then {
                    self.advance()
                    base = TypeNode.WeakReference(box(base))
                },
                _ then {
                    break
                },
            }
        }
        return base
    }

    private parse_type_arg_list(self ref) [[TypeNode ref]List]Result = {
        when self.current().kind in {
            .LBracket() then { self.advance() },
            _ then { return .Error(box("Expected '[' to start type argument list")) },
        }

        let mut args = [TypeNode ref]List.new()
        while true then {
            if self.current().kind is .RBracket() then {
                self.advance()
                break
            }
            let arg = self.parse_type() or else {
                return .Error(box("parse type argument error"))
            }
            args.push(box(arg))

            when self.current().kind in {
                .Comma() then {
                    self.advance()
                },
                .RBracket() then {},
                _ then {
                    return .Error(box("Expected ',' or ']' in type argument list"))
                },
            }
        }

        return .Ok(args)
    }

    private parse_type(self ref) [TypeNode]Result = {
        when self.current().kind in {
            .KwSelfType() then {
                self.advance()
                return .Ok(self.parse_type_suffixes(TypeNode.InferredSelf()))
            },
            .LBracket() then {
                let args = self.parse_type_arg_list() or else {
                    return .Error(box("parse type error"))
                }
                let base_name = self.expect_identifier("type name") or else {
                    return .Error(box("Expected type identifier after type arguments"))
                }

                if base_name == "Func" then {
                    if args.is_empty() then {
                        return .Error(box("Function type must include a return type"))
                    }
                    let mut param_types = [TypeNode ref]List.new()
                    let mut i UInt = 0
                    while i + 1 < args.count() then {
                        param_types.push(args.at(i))
                        i += 1
                    }
                    let return_type = args.at(args.count() - 1)
                    return .Ok(self.parse_type_suffixes(TypeNode.FunctionType(param_types, return_type)))
                }

                return .Ok(self.parse_type_suffixes(TypeNode.Generic(base_name, args)))
            },
            .Identifier(module_or_name) then {
                self.advance()

                if self.current().kind is .Dot() then {
                    self.advance()
                    if self.current().kind is .LBracket() then {
                        let args = self.parse_type_arg_list() or else {
                            return .Error(box("parse type error"))
                        }
                        let base_name = self.expect_identifier("qualified generic type name") or else {
                            return .Error(box("Expected qualified generic type name"))
                        }
                        return .Ok(self.parse_type_suffixes(TypeNode.ModuleQualifiedGeneric(module_or_name, base_name, args)))
                    }
                    let name = self.expect_identifier("qualified type name") or else {
                        return .Error(box("Expected qualified type name"))
                    }
                    return .Ok(self.parse_type_suffixes(TypeNode.ModuleQualified(module_or_name, name)))
                }

                return .Ok(self.parse_type_suffixes(TypeNode.Identifier(module_or_name)))
            },
            _ then {
                return .Error(box("Expected type"))
            },
        }
    }

    private parse_type_parameters(self ref) [[TypeParameter]List]Result = {
        let mut params = [TypeParameter]List.new()

        if self.current().kind is .LBracket() then {
            self.advance()
        } else {
            return .Ok(params)
        }

        while true then {
            if self.current().kind is .RBracket() then {
                self.advance()
                break
            }

            let param_name = self.expect_identifier("type parameter") or else {
                return .Error(box("parse type parameter error"))
            }

            // 泛型类型参数必须跟约束
            if not self.is_type_start() then {
                let t = self.current()
                return .Error(box("Type parameter '\(param_name)' requires a constraint at \(t.line):\(t.column)"))
            }
            let mut constraints = [TypeNode ref]List.new()
            let first_constraint = self.parse_type() or else {
                return .Error(box("parse type parameter constraint error"))
            }
            constraints.push(box(first_constraint))

            while self.current().kind is .KwAnd() then {
                self.advance()
                let next_constraint = self.parse_type() or else {
                    return .Error(box("parse type parameter constraint error"))
                }
                constraints.push(box(next_constraint))
            }

            params.push(TypeParameter(param_name, constraints))

            when self.current().kind in {
                .Comma() then {
                    self.advance()
                },
                .RBracket() then {},
                _ then {
                    return .Error(box("Expected ',' or ']' in type parameter list"))
                },
            }
        }

        return .Ok(params)
    }

    private parse_param_list(self ref) [[Param]List]Result = {
        let mut params = [Param]List.new()

        while true then {
            if self.current().kind is .RParen() then {
                return .Ok(params)
            }

            let mut is_mut = false
            if self.current().kind is .KwMut() then {
                is_mut = true
                self.advance()
            }

            if self.current().kind is .KwSelf() then {
                self.advance()
                // self 后面只允许 ref，不允许 weakref 或 ptr
                let mut self_type = TypeNode.InferredSelf()
                if self.current().kind is .KwRef() then {
                    self.advance()
                    self_type = TypeNode.Reference(box(TypeNode.InferredSelf()))
                } else if self.current().kind is .KwWeakref() then {
                    return .Error(box("'self' parameter cannot use 'weakref'; only 'ref' is allowed"))
                } else if self.current().kind is .KwPtr() then {
                    return .Error(box("'self' parameter cannot use 'ptr'; only 'ref' is allowed"))
                }
                if self.current().kind is .KwSelfType() then {
                    return .Error(box("Invalid receiver parameter syntax: use 'self' or 'self ref' only"))
                }
                if self.is_type_start() then {
                    return .Error(box("Invalid receiver parameter syntax: use 'self' or 'self ref' only"))
                }
                params.push(Param("self", false, self_type, false))
            } else {
                let name = self.expect_identifier("parameter") or else {
                    return .Error(box("parse parameter error"))
                }

                let mut is_named = false
                if self.current().kind is .Colon() then {
                    is_named = true
                    self.advance()
                }

                if not self.is_type_start() then {
                    return .Error(box("parameter type is required"))
                }
                let param_type = self.parse_type() or else {
                    return .Error(box("parse parameter type error"))
                }

                params.push(Param(name, is_mut, param_type, is_named))
            }

            when self.current().kind in {
                .Comma() then {
                    self.advance()
                },
                .RParen() then {
                    return .Ok(params)
                },
                .Eof() then {
                    return .Error(box("Unexpected EOF in parameter list"))
                },
                _ then {
                    return .Error(box("Expected ',' or ')' in parameter list"))
                },
            }
        }

        return .Ok(params)
    }

    private parse_let_decl(self ref, access AccessModifier, is_foreign Bool, is_intrinsic Bool) [Decl]Result = {
        let start = self.current()
        self.advance()

        let type_params = self.parse_type_parameters() or else {
            return .Error(box("parse type parameter error"))
        }

        let mut is_mut = false
        if self.current().kind is .KwMut() then {
            is_mut = true
            self.advance()
        }

        let name = self.expect_identifier("let declaration") or return

        if self.current().kind is .LParen() then {
            if is_mut then {
                return .Error(box("Function declaration cannot use mut before name"))
            }

            if is_foreign and not type_params.is_empty() then {
                return .Error(box("foreign function does not support generics"))
            }

            self.advance()
            let params = self.parse_param_list() or return

            if is_foreign then {
                for param in params then {
                    if param.named then {
                        return .Error(box("Named parameters are not supported in foreign declarations"))
                    }
                }
            }

            when self.current().kind in {
                .RParen() then {},
                _ then { return .Error(box("Expected ')' after parameters")) },
            }
            self.advance()

            let mut return_type = TypeNode.Identifier("Void")
            if self.is_type_start() then {
                return_type = self.parse_type() or else {
                    return .Error(box("parse function return type error"))
                }
            }

            if is_foreign or is_intrinsic then {
                if self.current().kind is .Assign() then {
                    if is_foreign then {
                        return .Error(box("foreign function cannot have a body"))
                    }
                    return .Error(box("intrinsic function declaration should not have body"))
                }
                self.consume_semicolon()
                let span = self.span_from_start(start)
                let base = Decl.FunctionDecl(access, name, type_params, params, return_type, box(Expr.Identifier("<intrinsic-body>", span)), span)
                return self.wrap_decl(access, is_foreign, is_intrinsic, base)
            }

            while true then {
                when self.current().kind in {
                    .Assign() then {
                        break
                    },
                    .Eof() then {
                        return .Error(box("Unexpected EOF in function declaration"))
                    },
                    _ then {
                        self.advance()
                    },
                }
            }

            self.advance()
            let body = self.parse_expression_checked("function body") or return
            self.consume_semicolon()
            let base = Decl.FunctionDecl(access, name, type_params, params, return_type, body, self.span_from_start(start))
            return self.wrap_decl(access, is_foreign, is_intrinsic, base)
        }

        // Variable declaration
        if not type_params.is_empty() then {
            return .Error(box("variable declaration cannot use type parameters"))
        }

        if is_foreign then {
            if not self.is_type_start() then {
                return .Error(box("foreign let declaration requires explicit type"))
            }
            let foreign_type = self.parse_type() or else {
                return .Error(box("parse foreign let type error"))
            }
            self.consume_semicolon()
            let span = self.span_from_start(start)
            let base = Decl.LetDecl(access, name, is_mut, foreign_type, box(Expr.Identifier("<foreign-init>", span)), span)
            return self.wrap_decl(access, is_foreign, is_intrinsic, base)
        }

        let mut type_name = TypeNode.Identifier("Int")
        if self.is_type_start() then {
            type_name = self.parse_type() or else {
                return .Error(box("parse let declaration type error"))
            }
        }

        // skip to '='
        if self.current().kind is .Eof() then {
            return .Error(box("Expected '=' in let declaration"))
        }

        self.advance()
        let initializer = self.parse_expression_checked("let declaration initializer") or return
        self.consume_semicolon()
        let base = Decl.LetDecl(access, name, is_mut, type_name, initializer, self.span_from_start(start))
        return self.wrap_decl(access, is_foreign, is_intrinsic, base)
    }

    private parse_type_decl(self ref, access AccessModifier, is_foreign Bool, is_intrinsic Bool) [Decl]Result = {
        let start = self.current()
        self.advance()

        let type_params = self.parse_type_parameters() or else {
            return .Error(box("parse type parameter error"))
        }

        let mut foreign_cname = [String]Option.None()
        if is_foreign then {
            if self.current().kind is .StringLiteral(v) then {
                foreign_cname = .Some(v)
                self.advance()
            }
        }

        let name = self.expect_identifier("type declaration") or return
        if not self.is_upper_first(name) then {
            return .Error(box("Type name '\(name)' must start with an uppercase letter"))
        }

        when self.current().kind in {
            .Assign() then {
                self.advance()
                let target = self.parse_type() or else {
                    return .Error(box("parse type alias target error"))
                }
                self.consume_semicolon()
                let base = Decl.TypeAliasDecl(access, name, target, self.span_from_start(start))
                return self.wrap_decl(access, is_foreign, is_intrinsic, base)
            },
            .LParen() then {
                self.advance()
                let mut fields = [Field]List.new()
                while true then {
                    when self.current().kind in {
                        .RParen() then {
                            self.advance()
                            break
                        },
                        .Eof() then {
                            return .Error(box("Unexpected EOF in struct declaration"))
                        },
                        _ then {
                            let field_access = self.parse_access_modifier(AccessModifier.Public())
                            let mut field_mut = false
                            if self.current().kind is .KwMut() then {
                                field_mut = true
                                self.advance()
                            }

                            let field_name = self.expect_identifier("field name") or return
                            let mut field_named = false
                            if self.current().kind is .Colon() then {
                                field_named = true
                                self.advance()
                            }

                            let field_type = self.parse_type() or else {
                                return .Error(box("parse field type error"))
                            }

                            fields.push(Field(field_access, field_name, field_mut, field_type, field_named))
                            if self.current().kind is .Comma() then {
                                self.advance()
                            }
                        },
                    }
                }
                self.consume_semicolon()
                if is_foreign then {
                    return .Ok(Decl.ForeignTypeDecl(access, name, foreign_cname, [[Field]List]Option.Some(fields), self.span_from_start(start)))
                }
                let base = Decl.TypeStructDecl(access, name, type_params, fields, self.span_from_start(start))
                return self.wrap_decl(access, is_foreign, is_intrinsic, base)
            },
            .LBrace() then {
                if is_foreign then {
                    return .Error(box("foreign type cannot have a body"))
                }
                self.advance()
                let mut cases = [EnumCase]List.new()
                while true then {
                    when self.current().kind in {
                        .RBrace() then {
                            self.advance()
                            break
                        },
                        .Eof() then {
                            return .Error(box("Unexpected EOF in enum declaration"))
                        },
                        _ then {
                            let case_name = self.expect_identifier("enum case") or return
                            let mut case_fields = [EnumCaseField]List.new()

                            if self.current().kind is .LParen() then {
                                self.advance()
                                while true then {
                                    when self.current().kind in {
                                        .RParen() then {
                                            self.advance()
                                            break
                                        },
                                        .Eof() then {
                                            return .Error(box("Unexpected EOF in enum payload"))
                                        },
                                        _ then {
                                            let payload_name = self.expect_identifier("enum payload name") or return
                                            let mut payload_named = false
                                            if self.current().kind is .Colon() then {
                                                payload_named = true
                                                self.advance()
                                            }
                                            let payload_type = self.parse_type() or else {
                                                return .Error(box("parse enum payload type error"))
                                            }
                                            case_fields.push(EnumCaseField(payload_name, payload_type, payload_named))
                                            when self.current().kind in {
                                                .Comma() then {
                                                    self.advance()
                                                },
                                                .RParen() then {},
                                                _ then {
                                                    return .Error(box("Expected ',' or ')' in enum payload"))
                                                },
                                            }
                                        },
                                    }
                                }
                            }

                            cases.push(EnumCase(case_name, case_fields))
                            if self.current().kind is .Comma() then {
                                self.advance()
                            }
                        },
                    }
                }
                self.consume_semicolon()
                let base = Decl.TypeEnumDecl(access, name, type_params, cases, self.span_from_start(start))
                return self.wrap_decl(access, is_foreign, is_intrinsic, base)
            },
            .Semicolon() then {
                if is_foreign then {
                    self.consume_semicolon()
                    return .Ok(Decl.ForeignTypeDecl(access, name, foreign_cname, [[Field]List]Option.None(), self.span_from_start(start)))
                }
                if is_intrinsic then {
                    self.consume_semicolon()
                    return .Ok(Decl.IntrinsicTypeDecl(access, name, type_params, self.span_from_start(start)))
                }
                return .Error(box("Expected '=', '(' or '{' after type name"))
            },
            _ then {
                if is_foreign then {
                    return .Ok(Decl.ForeignTypeDecl(access, name, foreign_cname, [[Field]List]Option.None(), self.span_from_start(start)))
                }
                if is_intrinsic then {
                    return .Ok(Decl.IntrinsicTypeDecl(access, name, type_params, self.span_from_start(start)))
                }
                return .Error(box("Expected '=', '(' or '{' after type name"))
            },
        }
    }

    private parse_let_statement(self ref) [Statement]Result = {
        let start = self.current()
        self.advance()

        if self.current().kind is .LParen() then {
            return self.parse_pair_let_statement(start)
        }

        let mut is_mut = false
        if self.current().kind is .KwMut() then {
            is_mut = true
            self.advance()
        }

        let name = self.expect_identifier("let statement") or return

        let mut type_name = [TypeNode]Option.None()
        if self.is_type_start() then {
            let parsed_type_name = self.parse_type() or else {
                return .Error(box("parse let statement type error"))
            }
            type_name = .Some(parsed_type_name)
        }

        // skip to '='
        if self.current().kind is .Eof() then {
            return .Error(box("Expected '=' in let statement"))
        }

        self.advance()
        let mut value = self.parse_expression_checked("let statement value") or return
        if self.should_continue_postfix_after_expression() then {
            value = self.parse_postfix_suffixes(value) or return
        }
        self.consume_semicolon()
        return .Ok(Statement.LetStmt(name, is_mut, type_name, value, self.span_from_start(start)))
    }

    private parse_pair_let_statement(self ref, start Token) [Statement]Result = {
        self.advance()

        let first = self.parse_pair_binding_element() or return

        if self.current().kind is not .Comma() then {
            return .Error(box("Expected ',' in pair let statement"))
        }
        self.advance()

        let second = self.parse_pair_binding_element() or return

        if self.current().kind is not .RParen() then {
            return .Error(box("Expected ')' in pair let statement"))
        }
        self.advance()

        if self.current().kind is .Eof() then {
            return .Error(box("Expected '=' in pair let statement"))
        }
        self.advance()

        let value = self.parse_expression_checked("pair let statement value") or return
        self.consume_semicolon()
        return .Ok(Statement.PairLetStmt(first, second, value, self.span_from_start(start)))
    }

    private parse_pair_binding_element(self ref) [PairBindingElement]Result = {
        let start = self.current()

        if start.kind is .Identifier(name) and name == "_" then {
            self.advance()
            return .Ok(PairBindingElement("_", false, [TypeNode]Option.None(), true, self.span_from_start(start)))
        }

        let mut is_mut = false
        if self.current().kind is .KwMut() then {
            is_mut = true
            self.advance()
        }

        let name = self.expect_identifier("pair let binding") or return

        let mut type_name = [TypeNode]Option.None()
        when self.current().kind in {
            .Comma() then {},
            .RParen() then {},
            _ then {
                let parsed_type_name = self.parse_type() or else {
                    return .Error(box("parse pair let binding type error"))
                }
                type_name = .Some(parsed_type_name)
            },
        }

        return .Ok(PairBindingElement(name, is_mut, type_name, false, self.span_from_start(start)))
    }

    private is_assignment_operator(self) Bool = {
        return when self.current().kind in {
            .Assign() then true,
            .PlusAssign() then true,
            .MinusAssign() then true,
            .StarAssign() then true,
            .SlashAssign() then true,
            .PercentAssign() then true,
            .AmpersandAssign() then true,
            .PipeAssign() then true,
            .CaretAssign() then true,
            .LeftShiftAssign() then true,
            .RightShiftAssign() then true,
            _ then false,
        }
    }

    private parse_assignment_operator(self) [[CompoundAssignmentOperator]Option]Result = {
        return when self.current().kind in {
            .Assign() then .Ok([CompoundAssignmentOperator]Option.None()),
            .PlusAssign() then .Ok(.Some(CompoundAssignmentOperator.AddAssign())),
            .MinusAssign() then .Ok(.Some(CompoundAssignmentOperator.SubtractAssign())),
            .StarAssign() then .Ok(.Some(CompoundAssignmentOperator.MultiplyAssign())),
            .SlashAssign() then .Ok(.Some(CompoundAssignmentOperator.DivideAssign())),
            .PercentAssign() then .Ok(.Some(CompoundAssignmentOperator.RemainderAssign())),
            .AmpersandAssign() then .Ok(.Some(CompoundAssignmentOperator.BitAndAssign())),
            .PipeAssign() then .Ok(.Some(CompoundAssignmentOperator.BitOrAssign())),
            .CaretAssign() then .Ok(.Some(CompoundAssignmentOperator.BitXorAssign())),
            .LeftShiftAssign() then .Ok(.Some(CompoundAssignmentOperator.LeftShiftAssign())),
            .RightShiftAssign() then .Ok(.Some(CompoundAssignmentOperator.RightShiftAssign())),
            _ then .Error(box("token is not an assignment operator")),
        }
    }

    private parse_expression_checked(self ref, context String) [Expr ref]Result = {
        let t = self.current()
        self.parse_debug("expr begin: \(context) @ \(t.line):\(t.column) token=\(token_text(t))")
        let before = self.index
        let parsed_expr = self.parse_expression() or return
        if self.index == before then {
            let t = self.current()
            return .Error(box("Parser made no progress while parsing \(context) at \(t.line):\(t.column) (token: \(token_text(t)))"))
        }
        let mut expr = parsed_expr
        if self.should_continue_postfix_after_expression() then {
            expr = self.parse_postfix_suffixes(expr) or return
        }
        return .Ok(expr)
    }

    private parse_statement_list_until_rbrace(self ref, context String) [[Statement]List]Result = {
        let mut statements = [Statement]List.new()
        self.parse_debug("stmt-list begin: \(context)")
        while true then {
            when self.current().kind in {
                .RBrace() then {
                    self.advance()
                    break
                },
                .Eof() then {
                    return .Error(box("Unexpected EOF in \(context)"))
                },
                _ then {
                    let before = self.index
                    let parsed_statement = self.parse_statement() or return
                    let parsed = self.parse_statement_postfix_continuations(parsed_statement) or return
                    if self.index == before then {
                        let t = self.current()
                        return .Error(box("Parser made no progress in \(context) at \(t.line):\(t.column) (token: \(token_text(t)))"))
                    }
                    statements.push(parsed)
                },
            }
        }
        return .Ok(statements)
    }

    private apply_statement_postfix_continuation(self, base Expr ref, continuation Expr ref) [Expr ref]Result = {
        return when continuation in {
            .ImplicitMemberExpr(member_name, args, _) then {
                let span = expr_span(continuation)
                let callee = box(Expr.MemberExpr(base, member_name, span))
                yield [Expr ref]Result.Ok(box(Expr.Call(callee, args, span)))
            },
            _ then [Expr ref]Result.Error(box("Expected postfix continuation expression")),
        }
    }

    private parse_statement_postfix_continuations(self ref, statement Statement) [Statement]Result = {
        let mut current = statement
        while self.can_continue_dot_postfix() then {
            self.parse_debug("statement postfix continuation @ \(self.current().line):\(self.current().column)")
            let continuation = self.parse_expression_checked("statement postfix continuation") or return
            current = when current in {
                .LetStmt(name, mutable, type_name, value, span) then {
                    let updated = self.apply_statement_postfix_continuation(value, continuation) or return
                    yield Statement.LetStmt(name, mutable, type_name, updated, span)
                },
                .ExprStmt(expr, span) then {
                    let updated = self.apply_statement_postfix_continuation(expr, continuation) or return
                    yield Statement.ExprStmt(updated, span)
                },
                _ then { return .Ok(current) },
            }
        }
        return .Ok(current)
    }

    private parse_statement(self ref) [Statement]Result = {
        let start = self.current()
        self.parse_debug("statement dispatch @ \(start.line):\(start.column) token=\(token_text(start))")
        when self.current().kind in {
            .KwLet() then {
                return self.parse_let_statement()
            },
            .KwReturn() then {
                self.advance()
                // return 后面如果是分号、右括号、或换行（自动终止），则返回 None
                if self.should_terminate_statement() then {
                    self.consume_semicolon()
                    return .Ok(Statement.ReturnStmt([Expr ref]Option.None(), self.span_from_start(start)))
                }
                let value = self.parse_expression_checked("return statement value") or return
                self.consume_semicolon()
                return .Ok(Statement.ReturnStmt(.Some(value), self.span_from_start(start)))
            },
            .KwBreak() then {
                self.advance()
                self.consume_semicolon()
                return .Ok(Statement.BreakStmt(self.span_from_start(start)))
            },
            .KwContinue() then {
                self.advance()
                self.consume_semicolon()
                return .Ok(Statement.ContinueStmt(self.span_from_start(start)))
            },
            .KwFinally() then {
                self.advance()
                let value = self.parse_expression_checked("finally statement value") or return
                self.consume_semicolon()
                return .Ok(Statement.FinallyStmt(value, self.span_from_start(start)))
            },
            .KwYield() then {
                self.advance()
                let value = self.parse_expression_checked("yield statement value") or return
                self.consume_semicolon()
                return .Ok(Statement.YieldStmt(value, self.span_from_start(start)))
            },
            _ then {
                let mut value = self.parse_expression_checked("statement expression") or return
                if self.should_continue_postfix_after_expression() then {
                    value = self.parse_postfix_suffixes(value) or return
                }

                if self.is_assignment_operator() then {
                    let op = self.parse_assignment_operator() or else {
                        return .Error(box("Unknown assignment operator"))
                    }
                    self.advance()
                    let rhs = self.parse_expression_checked("assignment right-hand side") or return
                    self.consume_semicolon()
                    return .Ok(Statement.AssignmentStmt(value, op, rhs, self.span_from_start(start)))
                }

                self.consume_semicolon()
                return .Ok(Statement.ExprStmt(value, self.span_from_start(start)))
            },
        }
    }

    // Lookahead: check if current position starts a lambda expression.
    // Lambda forms: () [RetType] ->  or  (name [Type], ...) [RetType] ->
}
