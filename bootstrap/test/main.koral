using std.os.*
using std.proc.*

type AstCase(
    name String,
    path String,
    expected_errors [String]List,
)

private let trim_leading_spaces(text String) String = {
    let runes = text.to_runes()
    let mut start UInt = 0
    while start < runes.count() and runes.at(start).is_whitespace() then {
        start += 1
    }
    let mut out = String.new()
    let mut j UInt = start
    while j < runes.count() then {
        out.push_rune(runes.at(j))
        j += 1
    }
    return out
}

private let collect_expected_errors(source String) [String]List = {
    let marker = "EXPECT-ERROR:"
    let runes = source.to_runes()
    let mut out = [String]List.new()
    let mut line = String.new()

    for ch in runes then {
        if ch.is_newline() then {
            if line.find(marker) is .Some(idx) then {
                let msg = trim_leading_spaces(line.substring(idx + marker.count()...))
                if not msg.is_empty() then {
                    out.push(msg)
                }
            }
            line = String.new()
        } else {
            line.push_rune(ch)
        }
    }

    if line.find(marker) is .Some(idx) then {
        let msg = trim_leading_spaces(line.substring(idx + marker.count()...))
        if not msg.is_empty() then {
            out.push(msg)
        }
    }

    return out
}

let load_case(name String, path String) [AstCase]Result = {
    let source = read_text_file(Path.new(path)) or else {
        return [AstCase]Result.Error(_)
    }
    return [AstCase]Result.Ok(AstCase(name, path, collect_expected_errors(source)))
}

let run_and_capture(program String, args [String]List) [CommandOutput]Result = {
    return run_command_output(program, args)
}

let ensure_output_dir() [Void]Result = {
    return create_dir_all(Path.new("bootstrap/test/out"))
}

let build_bootstrap_compiler() [Void]Result = {
    let mut args = [String]List.new()
    args.push("build")
    args.push("bootstrap/koralc/main.koral")
    args.push("-o")
    args.push("/tmp/bootstrap_koralc")

    let out = run_and_capture("./bin/koralc", args) or else {
        return [Void]Result.Error(_)
    }

    if out.is_success() then {
        return [Void]Result.Ok({})
    }

    eprintln("build bootstrap compiler failed")
    if not out.stdout.is_empty() then { eprintln(out.stdout) }
    if not out.stderr.is_empty() then { eprintln(out.stderr) }
    return [Void]Result.Error(box("build failed"))
}

let write_ast_output(case_name String, content String) [Void]Result = {
    let path = Path.new("bootstrap/test/out").join(case_name + ".typed-ast.txt")
    return write_text_file(path, content)
}

let run_case(c AstCase) Bool = {
    let mut args = [String]List.new()
    args.push("--emit-typed-ast")
    args.push(c.path)

    let out = run_and_capture("/tmp/bootstrap_koralc/main", args) or else {
        eprintln("[FAIL] \(c.name): run command failed")
        eprintln(_.message())
        return false
    }

    let combined_output = out.stdout + "\n" + out.stderr

    if not c.expected_errors.is_empty() then {
        if out.is_success() then {
            eprintln("[FAIL] \(c.name): expected non-zero exit")
            if not out.stdout.is_empty() then { eprintln(out.stdout) }
            if not out.stderr.is_empty() then { eprintln(out.stderr) }
            return false
        }

        for needle in c.expected_errors then {
            if not combined_output.contains(needle) then {
                eprintln("[FAIL] \(c.name): missing expected error fragment")
                eprintln("expected: \(needle)")
                if not out.stdout.is_empty() then { eprintln(out.stdout) }
                if not out.stderr.is_empty() then { eprintln(out.stderr) }
                return false
            }
        }

        println("[PASS] \(c.name)")
        return true
    }

    if not out.is_success() then {
        eprintln("[FAIL] \(c.name): non-zero exit")
        if not out.stdout.is_empty() then { eprintln(out.stdout) }
        if not out.stderr.is_empty() then { eprintln(out.stderr) }
        return false
    }

    write_ast_output(c.name, out.stdout) or else {
        eprintln("[FAIL] \(c.name): cannot write ast output")
        eprintln(_.message())
        return false
    }

    println("[PASS] \(c.name)")
    return true
}

let main() Int = {
    let argv = args()
    let mut filter = [String]Option.None()
    // argv[0] is program name, scan from index 1
    // use index loop because we may need to consume the next arg
    let mut i UInt = 1
    while i < argv.count() then {
        let arg = argv.at(i)
        if arg == "--case" or arg == "-c" then {
            i += 1
            if i < argv.count() then {
                filter = .Some(argv.at(i))
            } else {
                eprintln("error: --case requires a case name argument")
                return 1
            }
        }
        i += 1
    }

    let mut cases = [AstCase]List.new()
    cases.push(load_case("00_declarations", "bootstrap/test/cases/00_declarations.koral") or else {
        eprintln("load case failed: 00_declarations")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("01_expressions", "bootstrap/test/cases/01_expressions.koral") or else {
        eprintln("load case failed: 01_expressions")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("02_control_flow", "bootstrap/test/cases/02_control_flow.koral") or else {
        eprintln("load case failed: 02_control_flow")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("03_strings_and_calls", "bootstrap/test/cases/03_strings_and_calls.koral") or else {
        eprintln("load case failed: 03_strings_and_calls")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("04_basic_test", "bootstrap/test/cases/04_basic_test.koral") or else {
        eprintln("load case failed: 04_basic_test")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("05_types_recursive", "bootstrap/test/cases/05_types_recursive.koral") or else {
        eprintln("load case failed: 05_types_recursive")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("06_expected_errors", "bootstrap/test/cases/06_expected_errors.koral") or else {
        eprintln("load case failed: 06_expected_errors")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("07_using_rules_error", "bootstrap/test/cases/07_using_rules_error.koral") or else {
        eprintln("load case failed: 07_using_rules_error")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("08_match_and_literals", "bootstrap/test/cases/08_match_and_literals.koral") or else {
        eprintln("load case failed: 08_match_and_literals")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("09_scope_errors", "bootstrap/test/cases/09_scope_errors.koral") or else {
        eprintln("load case failed: 09_scope_errors")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("10_duplicate_def", "bootstrap/test/cases/10_duplicate_def.koral") or else {
        eprintln("load case failed: 10_duplicate_def")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("11_break_outside_loop", "bootstrap/test/cases/11_break_outside_loop.koral") or else {
        eprintln("load case failed: 11_break_outside_loop")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("12_continue_outside_loop", "bootstrap/test/cases/12_continue_outside_loop.koral") or else {
        eprintln("load case failed: 12_continue_outside_loop")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("13_finally_errors", "bootstrap/test/cases/13_finally_errors.koral") or else {
        eprintln("load case failed: 13_finally_errors")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("14_finally_nested", "bootstrap/test/cases/14_finally_nested.koral") or else {
        eprintln("load case failed: 14_finally_nested")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("15_exhaustiveness", "bootstrap/test/cases/15_exhaustiveness.koral") or else {
        eprintln("load case failed: 15_exhaustiveness")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("16_exhaustiveness_errors", "bootstrap/test/cases/16_exhaustiveness_errors.koral") or else {
        eprintln("load case failed: 16_exhaustiveness_errors")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("17_exhaustiveness_bool_error", "bootstrap/test/cases/17_exhaustiveness_bool_error.koral") or else {
        eprintln("load case failed: 17_exhaustiveness_bool_error")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("18_unreachable_pattern", "bootstrap/test/cases/18_unreachable_pattern.koral") or else {
        eprintln("load case failed: 18_unreachable_pattern")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("19_trait_conformance", "bootstrap/test/cases/19_trait_conformance.koral") or else {
        eprintln("load case failed: 19_trait_conformance")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("20_trait_missing_method", "bootstrap/test/cases/20_trait_missing_method.koral") or else {
        eprintln("load case failed: 20_trait_missing_method")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("21_trait_param_mismatch", "bootstrap/test/cases/21_trait_param_mismatch.koral") or else {
        eprintln("load case failed: 21_trait_param_mismatch")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("22_generics", "bootstrap/test/cases/22_generics.koral") or else {
        eprintln("load case failed: 22_generics")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("23_type_inference", "bootstrap/test/cases/23_type_inference.koral") or else {
        eprintln("load case failed: 23_type_inference")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("24_union_pattern_matching", "bootstrap/test/cases/24_union_pattern_matching.koral") or else {
        eprintln("load case failed: 24_union_pattern_matching")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("25_access_modifiers", "bootstrap/test/cases/25_access_modifiers.koral") or else {
        eprintln("load case failed: 25_access_modifiers")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("26_trait_inheritance", "bootstrap/test/cases/26_trait_inheritance.koral") or else {
        eprintln("load case failed: 26_trait_inheritance")
        eprintln(_.message())
        return 1
    })
    cases.push(load_case("27_when_int_missing_catchall", "bootstrap/test/cases/27_when_int_missing_catchall.koral") or else {
        eprintln("load case failed: 27_when_int_missing_catchall")
        eprintln(_.message())
        return 1
    })

    ensure_output_dir() or else {
        eprintln("prepare output dir failed")
        eprintln(_.message())
        return 1
    }

    build_bootstrap_compiler() or else {
        return 1
    }

    let mut filtered_cases = [AstCase]List.new()
    if filter is .Some(name) then {
        for c in cases then {
            if c.name == name then {
                filtered_cases.push(c)
            }
        }
        if filtered_cases.is_empty() then {
            eprintln("error: no case named '\(name)'")
            return 1
        }
    } else {
        for c in cases then {
            filtered_cases.push(c)
        }
    }

    let mut pass_count UInt = 0
    for c in filtered_cases then {
        if run_case(c) then {
            pass_count += 1
        }
    }

    println("Typed AST test summary: \(pass_count)/\(filtered_cases.count()) passed")
    return if pass_count == filtered_cases.count() then 0 else 1
}
