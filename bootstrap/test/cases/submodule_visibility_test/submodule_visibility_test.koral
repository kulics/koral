// Test submodule visibility control
// A submodule should only be visible to other modules if the parent module exports it
// EXPECT-ERROR: Cannot access private symbol 'Child'

// Import child module but don't re-export it (default is private)
using "child" as Child

// Import sibling module - this should trigger an error because sibling tries to access child
using "sibling" as Sibling

public let main() Void = {
    // We can access child module's public symbols through the module name
    let result = child.child_value()
    println(result)
    
    print("Submodule visibility test passed!")
}
