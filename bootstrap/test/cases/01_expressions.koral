foreign let x Int
foreign let y Int
foreign let a Int
foreign let b Int
foreign let left Int
foreign let right Int
foreign let arr [Int]List
foreign let i UInt
foreign let matrix [Int]List
foreign let row UInt
foreign let opt [Int]Option
foreign let result [Int]Result
foreign let next Int
foreign let fallback Int

let unary_not = not false;
let unary_minus = -(1 + 2);
let ptr_chain = ref ptr deptr deref x;

let arithmetic = 1 + 2 * 3 - 4 / 2 % 2;
let comparison = a + 1 >= b - 2;
let bitwise = (x << 1) | (y & 3) ^ 2;
let ranges = left ..< right;
let subs_1 = arr[i];
let subs_2 = matrix[row + 1];

let and_then_expr = opt and then next;
let or_else_expr = result or else fallback;
let mixed_logic = not false and true or false;
