// EXPECT: let_not_none: PASS
// EXPECT: let_not_some: PASS
// EXPECT: if_not_none: PASS
// EXPECT: and_not_chain: PASS
// EXPECT: All is not expression tests passed!

type MyOption {
    None(),
    Some(value Int),
}

let main() Int = {
    let some = MyOption.Some(9)
    let none = MyOption.None()

    let let_not_none = some is not .None()
    let let_not_some = none is not .None()
    let and_not_chain = some is not .None() and none is not .Some(_)

    if let_not_none then {
        println("let_not_none: PASS")
    } else {
        println("let_not_none: FAIL")
        return 1
    }

    if not let_not_some then {
        println("let_not_some: PASS")
    } else {
        println("let_not_some: FAIL")
        return 1
    }

    if some is not .None() then {
        println("if_not_none: PASS")
    } else {
        println("if_not_none: FAIL")
        return 1
    }

    if and_not_chain then {
        println("and_not_chain: PASS")
    } else {
        println("and_not_chain: FAIL")
        return 1
    }

    println("All is not expression tests passed!")
    yield 0
}