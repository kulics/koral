// Test: access modifiers on types and functions

// public 类型和函数
public type PublicPoint(x Int, y Int)
public let public_add(a Int, b Int) Int = a + b

// private 类型和函数
private type PrivateHelper(data Int)
private let private_compute(x Int) Int = x * 2

// protected 类型
protected type ProtectedBase(value Int)

// 带访问修饰符的 Trait
public trait Printable {
    print(self) String
}

// 带访问修饰符的 given
given PublicPoint Printable {
    print(self) String = "(\(self.x), \(self.y))"
}

// 访问修饰符在 Union 类型上
public type Visibility {
    Public(),
    Private(),
    Protected(),
}

// 函数使用 public 类型（合法）
public let make_point(x Int, y Int) PublicPoint = PublicPoint(x, y)
