// EXPECT-ERROR: Cannot assign to immutable variable: value

// Tests that auto-deref for method calls on T ref still works alongside blanket given
// Feature: type-modifier-trait-conformance

type Counter(value Int)

given Counter {
    public increment(self ref) Void = {
        self.value = self.value + 1
    }
    public get(self) Int = self.value
}

let main() Void = {
    let c = Counter(0).ref
    c.increment()
    c.increment()
    println(c.get())
}