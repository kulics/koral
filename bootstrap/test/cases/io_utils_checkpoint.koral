// EXPECT: utils checkpoint passed
using Std.Io.*

let main() Void = {
    // Verify write_all compiles with empty buffer
    let dst = ByteBuffer.zero()
    let empty_buf = [UInt8]List.new()
    let wr = dst.write_all(from: empty_buf, ..)
    when wr in {
        .Ok(_) then {},
        .Error(_) then {},
    }

    // Verify read_all compiles
    let src = ByteBuffer.from_string("hello")
    let rb = src.read_all()
    when rb in {
        .Ok(_) then {},
        .Error(_) then {},
    }

    // Verify copy_all_to compiles
    let src2 = ByteBuffer.from_string("world")
    let dst2 = ByteBuffer.zero()
    let cb = src2.copy_all_to(dst2)
    when cb in {
        .Ok(_) then {},
        .Error(_) then {},
    }

    print("utils checkpoint passed")
}
