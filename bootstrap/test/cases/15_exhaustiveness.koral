// Test: exhaustiveness checking for when expressions

type Color {
    Red(),
    Green(),
    Blue(),
}

type Direction {
    North(),
    South(),
    East(),
    West(),
}

// ── 正常情况：完整覆盖 ────────────────────────────────────────────────────────

// Union 类型：覆盖所有 case
let color_name(c Color) String = {
    return when c in {
        .Red() then "red",
        .Green() then "green",
        .Blue() then "blue",
    }
}

// Union 类型：通配符兜底
let color_index(c Color) Int = {
    return when c in {
        .Red() then 0,
        _ then 1,
    }
}

// Bool 类型：覆盖 true 和 false
let bool_to_int(b Bool) Int = {
    return when b in {
        true then 1,
        false then 0,
    }
}

// Bool 类型：通配符兜底
let bool_desc(b Bool) String = {
    return when b in {
        true then "yes",
        _ then "no",
    }
}

// Int 类型：通配符兜底
foreign let n Int
let int_case = when n in {
    0 then "zero",
    1 then "one",
    _ then "other",
}

// or 模式覆盖多个 case
let direction_axis(d Direction) String = {
    return when d in {
        .North() | .South() then "vertical",
        .East() | .West() then "horizontal",
    }
}

// 绑定模式作为 catchall
let color_binding(c Color) String = {
    return when c in {
        .Red() then "red",
        other then "not red",
    }
}
