// Test: Value type parameter copy for struct, enum, and closure
// EXPECT: === Test Struct Copy ===
// EXPECT: Person(Alice, 30)
// EXPECT: === Test Enum Copy ===
// EXPECT: Identifier(hello)
// EXPECT: === Test Closure Copy ===
// EXPECT: 10
// EXPECT: 15
// EXPECT: === Test Nested Type Copy ===
// EXPECT: Container(Identifier(nested), 42)
// EXPECT: === Test String Copy ===
// EXPECT: hello world
// EXPECT: All tests passed!
// This test verifies that managed types are properly copied when passed
// as lvalue arguments to functions.
// Bug: Enum types were not being copied when passed as lvalue parameters,
// causing use-after-free when the same value was used multiple times.

public type Person(name String, age Int)

given Person {
    public to_string(self) String = {
        let mut s = String.zero()
        s.push_string("Person(")
        s.push_string(self.name)
        s.push_string(", ")
        s.push_string(self.age.to_string())
        s.push_byte(')')
        yield s
    }
}

let consume_person(p Person) String = p.to_string()

let test_struct_copy() Void = {
    println("=== Test Struct Copy ===")

    let person = Person("Alice", 30)

    println(consume_person(person))
    println(consume_person(person))
    println(person.to_string())

    let mut people = [Person]List.new()
    people.push(person)

    for p in people then {
        println(p.to_string())
    }
}

public type Token {
    Number(value Int),
    Identifier(name String),
    Plus(),
}

given Token {
    public to_string(self) String = when self in {
        .Number(v) then {
            let mut s = String.zero()
            s.push_string("Number(")
            s.push_string(v.to_string())
            s.push_byte(')')
            yield s
        },
        .Identifier(name) then {
            let mut s = String.zero()
            s.push_string("Identifier(")
            s.push_string(name)
            s.push_byte(')')
            yield s
        },
        .Plus then "Plus",
    }
}

let consume_token(t Token) String = t.to_string()

let test_enum_copy() Void = {
    println("=== Test Enum Copy ===")

    let token = Token.Identifier("hello")

    println(consume_token(token))
    println(consume_token(token))
    println(token.to_string())

    let mut tokens = [Token]List.new()
    tokens.push(token)

    for t in tokens then {
        println(t.to_string())
    }
}

let call_fn(f [Int, Int]Func, x Int) Int = f(x)

let test_closure_copy() Void = {
    println("=== Test Closure Copy ===")

    let double [Int, Int]Func = (x) -> x * 2
    println(call_fn(double, 5).to_string())
    println(call_fn(double, 10).to_string())
    println(call_fn(double, 15).to_string())

    let multiplier = 3
    let triple [Int, Int]Func = (x) -> x * multiplier

    println(call_fn(triple, 5).to_string())
    println(call_fn(triple, 10).to_string())
    println(call_fn(triple, 15).to_string())
}

public type Container(token Token, count Int)

given Container {
    public to_string(self) String = {
        let mut s = String.zero()
        s.push_string("Container(")
        s.push_string(self.token.to_string())
        s.push_string(", ")
        s.push_string(self.count.to_string())
        s.push_byte(')')
        yield s
    }
}

let consume_container(c Container) String = c.to_string()

let test_nested_copy() Void = {
    println("=== Test Nested Type Copy ===")

    let container = Container(Token.Identifier("nested"), 42)

    println(consume_container(container))
    println(consume_container(container))
    println(container.to_string())
}

let consume_string(s String) String = s

let test_string_copy() Void = {
    println("=== Test String Copy ===")

    let text = "hello world"

    println(consume_string(text))
    println(consume_string(text))
    println(text)
}

public let main() Void = {
    test_struct_copy()
    println("")

    test_enum_copy()
    println("")

    test_closure_copy()
    println("")

    test_nested_copy()
    println("")

    test_string_copy()
    println("")

    println("All tests passed!")
}

// Expected output:
// === Test Struct Copy ===
// Person(Alice, 30)
// Person(Alice, 30)
// Person(Alice, 30)
// Person(Alice, 30)
//
// === Test Enum Copy ===
// Identifier(hello)
// Identifier(hello)
// Identifier(hello)
// Identifier(hello)
//
// === Test Closure Copy ===
// 10
// 20
// 30
// 15
// 30
// 45
//
// === Test Nested Type Copy ===
// Container(Identifier(nested), 42)
// Container(Identifier(nested), 42)
// Container(Identifier(nested), 42)
//
// === Test String Copy ===
// hello world
// hello world
// hello world
//
// All tests passed!
