// Tests that T ref satisfies Eq when T implements Eq (blanket given)
// Feature: type-modifier-trait-conformance

type Point(x Int, y Int)

given Point Eq {
    public equals(self, other Point) Bool = self.x == other.x and self.y == other.y
}

let [T Eq] are_equal(a T, b T) Bool = a == b

let main() Void = {
    let mut p1 = Point(1, 2)
    let mut p2 = Point(1, 2)
    let mut p3 = Point(3, 4)
    let a = p1.ref
    let b = p2.ref
    let c = p3.ref
    println(are_equal(a, b))
    println(are_equal(a, c))
}
// EXPECT: true
// EXPECT: false
