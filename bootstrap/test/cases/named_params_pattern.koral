// EXPECT: 50
// EXPECT: 10

type Rect(width: Int, height: Int)

type Cmd {
    Draw(at_x: Int, at_y: Int),
    Clear(),
}

let main() Int = {
    let r = Rect(width: 5, height: 10)
    if r is Rect(width: w, height: h) then println(w * h)
    
    let cmd = Cmd.Draw(at_x: 10, at_y: 20)
    when cmd in {
        .Draw(at_x: x, at_y: _) then println(x),
        .Clear() then println(0),
    }
    return 0
}
