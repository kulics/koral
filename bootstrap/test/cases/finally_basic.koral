// Test basic finally functionality
// Test 1: Single finally
// EXPECT: test_single_defer:
// EXPECT: before finally
// EXPECT: after finally
// EXPECT: deferred action
// Test 2: Multiple defers in LIFO order
// EXPECT: test_multiple_defer_lifo:
// EXPECT: first
// EXPECT: second
// EXPECT: third
// EXPECT: finally C
// EXPECT: finally B
// EXPECT: finally A
// Test 3: Finally executes before drop
// EXPECT: test_defer_before_drop:
// EXPECT: created resource
// EXPECT: deferred cleanup
// EXPECT: Drop Resource 1

public type Resource(id Int)

given Resource Drop {
    drop(self mut ref) Void = {
        print("Drop Resource ")
        println(self.id)
    }
}

let test_single_defer() Void = {
    println("test_single_defer:")
    println("before finally")
    finally println("deferred action")
    println("after finally")
}

let test_multiple_defer_lifo() Void = {
    println("test_multiple_defer_lifo:")
    finally println("finally A")
    println("first")
    finally println("finally B")
    println("second")
    finally println("finally C")
    println("third")
}

let test_defer_before_drop() Void = {
    println("test_defer_before_drop:")
    let r = Resource(1)
    println("created resource")
    finally println("deferred cleanup")
}

public let main() Int = {
    test_single_defer()
    test_multiple_defer_lifo()
    test_defer_before_drop()
    yield 0
}
