// Lambda basic syntax test
// EXPECT: 42

let main() Int = {
    let doubler [Int, Int]Func = (x Int) Int -> x * 2
    let r1 = doubler(21)
    println(r1)

    let tripler [Int, Int]Func = (x) -> x * 3
    let r2 = tripler(14)
    println(r2)

    let add [Int, Int, Int]Func = (x, y) -> x + y
    let r3 = add(20, 22)
    println(r3)

    let answer [Int]Func = () -> 42
    let r4 = answer()
    println(r4)

    let compute [Int, Int]Func = (x) -> {
        let y = x * 2
        let z = y + 1
        yield z
    }
    let r5 = compute(20)
    println(r5)

    let printer [Int, Void]Func = (x) -> println(x)
    printer(42)

    let f [Int, Int]Func = (x) -> x + 1
    let g [Int, Int]Func = (x) -> x * 2
    let r7 = f(g(20))
    println(r7)

    yield r1
}
