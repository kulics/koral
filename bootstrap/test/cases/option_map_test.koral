// Test Option methods: map, unwrap_or, filter
// EXPECT: map Some: 84
// EXPECT: map None: None
// EXPECT: unwrap_or Some: 42
// EXPECT: unwrap_or None: 99
// EXPECT: filter pass: 42
// EXPECT: filter fail: None
// EXPECT: filter None: None

let print_opt(label String, opt [Int]Option) Void = {
    print(label)
    when opt in {
        .Some(v) then println(v.to_string()),
        .None then println("None"),
    }
}

let main() Int = {
    // map
    let opt = [Int]Option.Some(42)
    let none = [Int]Option.None()
    print_opt("map Some: ", opt.[Int]map((x) -> x * 2))
    print_opt("map None: ", none.[Int]map((x) -> x * 2))

    // unwrap_or
    println("unwrap_or Some: " + opt.unwrap_or(99).to_string())
    println("unwrap_or None: " + none.unwrap_or(99).to_string())

    // filter
    print_opt("filter pass: ", opt.filter((x) -> x > 10))
    print_opt("filter fail: ", opt.filter((x) -> x > 100))
    print_opt("filter None: ", none.filter((x) -> x > 10))

    yield 0
}
