// Test: trait conformance - correct implementations

trait Describable {
    describe(self) String;
}

trait Countable {
    count(self) Int;
    is_empty(self) Bool;
}

// 父 Trait
trait Named {
    name(self) String;
}

// 子 Trait 继承父 Trait（Koral 语法：trait NamedDescribable Named）
trait NamedDescribable Named {
    describe(self) String;
}

type Point(x Int, y Int)
type Container(items [Int]List)

// 正确实现单个 Trait
given Point Describable {
    describe(self) String = "point";
}

// 正确实现多方法 Trait
given Container Countable {
    count(self) Int = 0;
    is_empty(self) Bool = true;
}

// 实现父 Trait
given Point Named {
    name(self) String = "Point";
}

// 实现子 Trait（父 Trait 已实现）
given Point NamedDescribable {
    describe(self) String = "named point";
}
