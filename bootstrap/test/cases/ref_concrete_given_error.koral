// Tests that a concrete type modifier given declaration is rejected
// Feature: type-modifier-trait-conformance
// EXPECT-ERROR: Concrete type modifier given declarations are not allowed

type Foo(x Int)

given Foo Eq {
    public equals(self, other Foo) Bool = self.x == other.x
}

given Foo ref Eq {
    public equals(self, other Foo ref) Bool = (deref self).equals(deref other)
}

let main() Void = {
    println("should not compile")
}
