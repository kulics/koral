type [T Any] Box(mut value T)

given[T Any] [T]Box {
    get_val(self ref) T = self.value
    
    set_val(self ref, v T) Void = {
        self.value = v
    }
}

let main() Void = {
    let mut b = [Int]Box(10)
    println(b.get_val())
    b.set_val(20)
    println(b.get_val())
}
// EXPECT: 10
// EXPECT: 20
