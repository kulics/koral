// Test: comprehensive union type pattern matching

type Result {
    Ok(value Int),
    Err(code Int, message String),
}

type Tree {
    Leaf(value Int),
    Node(left Tree ref, right Tree ref),
}

type Option2 {
    Some(value Int),
    None(),
}

// 完整覆盖所有 case
let result_message(r Result) String = {
    return when r in {
        .Ok(v) then "ok: \(v)",
        .Err(code, msg) then "error \(code): \(msg)",
    }
}

// 嵌套 union 模式
let option_value(o Option2) Int = {
    return when o in {
        .Some(v) then v,
        .None() then 0,
    }
}

// or 模式
let is_error(r Result) Bool = {
    return when r in {
        .Err(_, _) then true,
        _ then false,
    }
}

// 带绑定的模式
let extract_ok(r Result) Option2 = {
    return when r in {
        .Ok(v) then Option2.Some(v),
        _ then Option2.None(),
    }
}

// 重复 case 检测
// EXPECT-ERROR: Unreachable pattern: case 'Ok' is already covered
foreign let r Result
let duplicate_case = when r in {
    .Ok(v) then 1,
    .Ok(v) then 2,
    .Err(_, _) then 3,
}
