// Test: generic types and functions

type [T Any]Box(value T)
type [A Any, B Any]Pair(first A, second B)

type [T Any]Stack(
    items [T]List,
)

trait [T Any]Container {
    get(self) T
}

given [T Any] [T]Box [T]Container {
    get(self) T = self.value
}

// 泛型函数
let [T Any]identity(x T) T = x

let [A Any, B Any]swap(p [A, B]Pair) [B, A]Pair = {
    return [B, A]Pair(p.second, p.first)
}

// 使用泛型类型（类型推断）
let int_box = Box(42)
let str_box = Box("hello")
let mixed_pair = Pair(1, "one")

// 嵌套泛型
let nested = Box(Box(100))
