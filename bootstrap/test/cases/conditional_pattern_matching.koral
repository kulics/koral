// Test conditional pattern matching: if expr is pattern then ... else ...
// and while expr is pattern then ...
// EXPECT: test_if_is_some: PASS
// EXPECT: test_if_is_none: PASS
// EXPECT: test_if_is_with_binding: PASS
// EXPECT: test_if_is_with_else: PASS
// EXPECT: test_if_is_comparison: PASS
// EXPECT: test_if_is_combinator: PASS
// EXPECT: test_while_is_iterator: PASS
// EXPECT: test_nested_if_is: PASS
// EXPECT: All conditional pattern matching tests passed!

type MyOption {
    None(),
    Some(value Int),
}

type MyIterator(mut current Int, max Int)

given MyIterator {
    next(self ref) MyOption = {
        yield if self.current < self.max then {
            let v = self.current
            self.current = self.current + 1
            yield MyOption.Some(v)
        } else {
            yield MyOption.None()
        }
    }
}

let test_if_is_some() Int = {
    let opt = MyOption.Some(42)
    yield if opt is .Some(v) then v else 0
}

let test_if_is_none() Int = {
    let opt = MyOption.None()
    yield if opt is .None then 1 else 0
}

let test_if_is_with_binding() Int = {
    let opt = MyOption.Some(10)
    let mut result = 0
    if opt is .Some(v) then {
        result = v * 2
    }
    yield result
}

let test_if_is_with_else() Int = {
    let opt = MyOption.None()
    yield if opt is .Some(v) then v else 99
}

let test_if_is_comparison() Int = {
    let x = 15
    yield if x is > 10 then 1 else 0
}

let test_if_is_combinator() Int = {
    let x = 5
    yield if x is > 0 and x < 10 then 1 else 0
}

let test_while_is_iterator() Int = {
    let mut iter = MyIterator(0, 5)
    let mut sum = 0
    while iter.next() is .Some(v) then {
        sum = sum + v
    }
    yield sum
}

let test_nested_if_is() Int = {
    let outer = MyOption.Some(42)
    yield if outer is .Some(v) then {
        yield v
    } else {
        yield 0
    }
}

let main() Int = {
    if test_if_is_some() == 42 then {
        println("test_if_is_some: PASS")
    } else {
        println("test_if_is_some: FAIL")
        return 1
    }

    if test_if_is_none() == 1 then {
        println("test_if_is_none: PASS")
    } else {
        println("test_if_is_none: FAIL")
        return 1
    }

    if test_if_is_with_binding() == 20 then {
        println("test_if_is_with_binding: PASS")
    } else {
        println("test_if_is_with_binding: FAIL")
        return 1
    }

    if test_if_is_with_else() == 99 then {
        println("test_if_is_with_else: PASS")
    } else {
        println("test_if_is_with_else: FAIL")
        return 1
    }

    if test_if_is_comparison() == 1 then {
        println("test_if_is_comparison: PASS")
    } else {
        println("test_if_is_comparison: FAIL")
        return 1
    }

    if test_if_is_combinator() == 1 then {
        println("test_if_is_combinator: PASS")
    } else {
        println("test_if_is_combinator: FAIL")
        return 1
    }

    if test_while_is_iterator() == 10 then {
        println("test_while_is_iterator: PASS")
    } else {
        println("test_while_is_iterator: FAIL")
        return 1
    }

    if test_nested_if_is() == 42 then {
        println("test_nested_if_is: PASS")
    } else {
        println("test_nested_if_is: FAIL")
        return 1
    }

    println("All conditional pattern matching tests passed!")
    yield 0
}
