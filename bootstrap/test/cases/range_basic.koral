// EXPECT: All range basic tests passed!

// Test basic Range type construction and contains method

let main() = {
    // Test Closed: 1..5 (1 <= x <= 5)
    let r1 = 1..5
    assert(r1.contains(1), "Closed should contain start")
    assert(r1.contains(3), "Closed should contain middle")
    assert(r1.contains(5), "Closed should contain end")
    assert(not r1.contains(0), "Closed should not contain below start")
    assert(not r1.contains(6), "Closed should not contain above end")
    
    // Test ClosedOpen: 1..<5 (1 <= x < 5)
    let r2 = 1..<5
    assert(r2.contains(1), "ClosedOpen should contain start")
    assert(r2.contains(4), "ClosedOpen should contain end-1")
    assert(not r2.contains(5), "ClosedOpen should not contain end")
    assert(not r2.contains(0), "ClosedOpen should not contain below start")
    
    // Test OpenClosed: 1<..5 (1 < x <= 5)
    let r3 = 1<..5
    assert(not r3.contains(1), "OpenClosed should not contain start")
    assert(r3.contains(2), "OpenClosed should contain start+1")
    assert(r3.contains(5), "OpenClosed should contain end")
    
    // Test Open: 1<..<5 (1 < x < 5)
    let r4 = 1<..<5
    assert(not r4.contains(1), "Open should not contain start")
    assert(r4.contains(2), "Open should contain start+1")
    assert(r4.contains(4), "Open should contain end-1")
    assert(not r4.contains(5), "Open should not contain end")
    
    // Test From: 5.. (5 <= x <= max)
    let r5 = 5..
    assert(r5.contains(5), "From should contain start")
    assert(r5.contains(100), "From should contain large value")
    assert(not r5.contains(4), "From should not contain below start")
    
    // Test After: 5<.. (5 < x <= max)
    let r6 = 5<..
    assert(not r6.contains(5), "After should not contain start")
    assert(r6.contains(6), "After should contain start+1")
    
    // Test To: ..5 (min <= x <= 5)
    let r7 = ..5
    assert(r7.contains(5), "To should contain end")
    assert(r7.contains(0), "To should contain zero")
    assert(r7.contains(0 - 100), "To should contain negative")
    assert(not r7.contains(6), "To should not contain above end")
    
    // Test Until: ..<5 (min <= x < 5)
    let r8 = ..<5
    assert(r8.contains(4), "Until should contain end-1")
    assert(not r8.contains(5), "Until should not contain end")
    
    println("All range basic tests passed!")
}
