// file_a.koral - First file with private symbols

private let secret_value_a Int = 111

private let compute_secret_a() Int = 1000

private type SecretDataA(value Int)

// Public wrapper type to expose private type's value
public type WrapperA(value Int)

// Public accessors to test the private symbols
public let get_private_var_a() Int = secret_value_a

public let call_private_func_a() Int = compute_secret_a()

public let create_private_type_a() WrapperA = {
    let secret = SecretDataA(10)
    yield WrapperA(secret.value)
}
