// EXPECT: All private isolation tests passed!
// Test private symbol encapsulation across sibling submodules.
// Each module exposes private state only through its own public wrappers.

using "file_a" as FileA
using "file_b" as FileB
using FileA.get_private_var_a
using FileA.call_private_func_a
using FileA.create_private_type_a
using FileB.get_private_var_b
using FileB.call_private_func_b
using FileB.create_private_type_b

public let main() Void = {
    // Test private variables from different files
    let a_val = get_private_var_a()
    let b_val = get_private_var_b()
    
    assert(a_val == 111, "file_a private var should be 111")
    assert(b_val == 222, "file_b private var should be 222")
    
    // Test private functions from different files
    let a_func = call_private_func_a()
    let b_func = call_private_func_b()
    
    assert(a_func == 1000, "file_a private func should return 1000")
    assert(b_func == 2000, "file_b private func should return 2000")
    
    // Test private types from different files (via public wrappers)
    let a_type = create_private_type_a()
    let b_type = create_private_type_b()
    
    assert(a_type.value == 10, "file_a private type value should be 10")
    assert(b_type.value == 10, "file_b private type value should be 10")
    
    print("All private isolation tests passed!")
}
