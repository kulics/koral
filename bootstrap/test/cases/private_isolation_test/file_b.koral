// file_b.koral - Second file with private symbols

private let secret_value_b Int = 222

private let compute_secret_b() Int = 2000

private type SecretDataB(value Int)

// Public wrapper type to expose private type's value
public type WrapperB(value Int)

// Public accessors to test the private symbols
public let get_private_var_b() Int = secret_value_b

public let call_private_func_b() Int = compute_secret_b()

public let create_private_type_b() WrapperB = {
    let secret = SecretDataB(10)
    yield WrapperB(secret.value)
}
