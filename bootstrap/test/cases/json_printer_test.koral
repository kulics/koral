// JSON printer (serialization) tests
// EXPECT: compact_null_ok
// EXPECT: compact_bool_true_ok
// EXPECT: compact_bool_false_ok
// EXPECT: compact_number_int_ok
// EXPECT: compact_number_float_ok
// EXPECT: compact_string_ok
// EXPECT: compact_array_ok
// EXPECT: compact_object_ok
// EXPECT: compact_empty_array_ok
// EXPECT: compact_empty_object_ok
// EXPECT: pretty_array_ok
// EXPECT: pretty_object_ok
// EXPECT: pretty_empty_array_ok
// EXPECT: pretty_empty_object_ok
// EXPECT: pretty_nested_ok
// EXPECT: num_format_int_ok
// EXPECT: num_format_float_ok
// EXPECT: num_format_zero_ok
// EXPECT: num_format_negative_ok
// EXPECT: escape_quote_ok
// EXPECT: escape_backslash_ok
// EXPECT: escape_newline_ok
// EXPECT: escape_tab_ok
// EXPECT: escape_control_ok
// EXPECT: nested_array_of_objects_ok
// EXPECT: nested_object_with_array_ok

using Std.Json.*

let main() Int = {
    // === to_string compact format for each variant ===

    // null
    let null_json = JsonValue.Null().to_string()
    if null_json == "null" then println("compact_null_ok")
    else println("FAIL compact_null: " + null_json)

    // bool true
    let true_json = JsonValue.Bool(true).to_string()
    if true_json == "true" then println("compact_bool_true_ok")
    else println("FAIL compact_bool_true: " + true_json)

    // bool false
    let false_json = JsonValue.Bool(false).to_string()
    if false_json == "false" then println("compact_bool_false_ok")
    else println("FAIL compact_bool_false: " + false_json)

    // number integer-valued
    let int_json = JsonValue.Number(42.0).to_string()
    if int_json == "42" then println("compact_number_int_ok")
    else println("FAIL compact_number_int: " + int_json)

    // number float
    let float_json = JsonValue.Number(3.14).to_string()
    if float_json == "3.14" then println("compact_number_float_ok")
    else println("FAIL compact_number_float: " + float_json)

    // string
    let str_json = JsonValue.String("hello").to_string()
    if str_json == "\"hello\"" then println("compact_string_ok")
    else println("FAIL compact_string: " + str_json)

    // array
    let mut arr = [JsonValue ref]List.new()
    arr.push(box(JsonValue.Number(1.0)))
    arr.push(box(JsonValue.Number(2.0)))
    arr.push(box(JsonValue.Number(3.0)))
    let arr_json = JsonValue.Array(arr).to_string()
    if arr_json == "[1,2,3]" then println("compact_array_ok")
    else println("FAIL compact_array: " + arr_json)

    // object
    let mut obj = [String, JsonValue ref]Dict.new()
    obj.insert("a", box(JsonValue.Number(1.0)))
    let obj_json = JsonValue.Object(obj).to_string()
    if obj_json == "{\"a\":1}" then println("compact_object_ok")
    else println("FAIL compact_object: " + obj_json)

    // empty array
    let empty_arr = JsonValue.Array([JsonValue ref]List.new())
    if empty_arr.to_string() == "[]" then println("compact_empty_array_ok")
    else println("FAIL compact_empty_array: " + empty_arr.to_string())

    // empty object
    let empty_obj = JsonValue.Object([String, JsonValue ref]Dict.new())
    if empty_obj.to_string() == "{}" then println("compact_empty_object_ok")
    else println("FAIL compact_empty_object: " + empty_obj.to_string())

    // === to_string_pretty with 2-space indentation ===

    // pretty array
    let mut parr = [JsonValue ref]List.new()
    parr.push(box(JsonValue.Number(1.0)))
    parr.push(box(JsonValue.Number(2.0)))
    let pretty_arr = JsonValue.Array(parr).to_string_pretty()
    let expected_arr = "[\n  1,\n  2\n]"
    if pretty_arr == expected_arr then println("pretty_array_ok")
    else println("FAIL pretty_array: " + pretty_arr)

    // pretty object
    let mut pobj = [String, JsonValue ref]Dict.new()
    pobj.insert("x", box(JsonValue.Number(10.0)))
    let pretty_obj = JsonValue.Object(pobj).to_string_pretty()
    let expected_obj = "{\n  \"x\": 10\n}"
    if pretty_obj == expected_obj then println("pretty_object_ok")
    else println("FAIL pretty_object: " + pretty_obj)

    // pretty empty array
    let pretty_empty_arr = JsonValue.Array([JsonValue ref]List.new()).to_string_pretty()
    if pretty_empty_arr == "[]" then println("pretty_empty_array_ok")
    else println("FAIL pretty_empty_array: " + pretty_empty_arr)

    // pretty empty object
    let pretty_empty_obj = JsonValue.Object([String, JsonValue ref]Dict.new()).to_string_pretty()
    if pretty_empty_obj == "{}" then println("pretty_empty_object_ok")
    else println("FAIL pretty_empty_object: " + pretty_empty_obj)

    // pretty nested: object containing an array
    let mut nested_arr = [JsonValue ref]List.new()
    nested_arr.push(box(JsonValue.Number(1.0)))
    nested_arr.push(box(JsonValue.Number(2.0)))
    let mut nested_obj = [String, JsonValue ref]Dict.new()
    nested_obj.insert("items", box(JsonValue.Array(nested_arr)))
    let pretty_nested = JsonValue.Object(nested_obj).to_string_pretty()
    let expected_nested = "{\n  \"items\": [\n    1,\n    2\n  ]\n}"
    if pretty_nested == expected_nested then println("pretty_nested_ok")
    else println("FAIL pretty_nested: " + pretty_nested)

    // === Integer-valued float formatting ===

    // 42.0 -> "42"
    let fmt_int = JsonValue.Number(42.0).to_string()
    if fmt_int == "42" then println("num_format_int_ok")
    else println("FAIL num_format_int: " + fmt_int)

    // 3.14 -> "3.14"
    let fmt_float = JsonValue.Number(3.14).to_string()
    if fmt_float == "3.14" then println("num_format_float_ok")
    else println("FAIL num_format_float: " + fmt_float)

    // 0.0 -> "0"
    let fmt_zero = JsonValue.Number(0.0).to_string()
    if fmt_zero == "0" then println("num_format_zero_ok")
    else println("FAIL num_format_zero: " + fmt_zero)

    // -5.0 -> "-5"
    let fmt_neg = JsonValue.Number(0.0 - 5.0).to_string()
    if fmt_neg == "-5" then println("num_format_negative_ok")
    else println("FAIL num_format_negative: " + fmt_neg)

    // === Special character escaping in string output ===

    // quote
    let esc_quote = JsonValue.String("a\"b").to_string()
    if esc_quote == "\"a\\\"b\"" then println("escape_quote_ok")
    else println("FAIL escape_quote: " + esc_quote)

    // backslash
    let esc_bs = JsonValue.String("a\\b").to_string()
    if esc_bs == "\"a\\\\b\"" then println("escape_backslash_ok")
    else println("FAIL escape_backslash: " + esc_bs)

    // newline
    let esc_nl = JsonValue.String("a\nb").to_string()
    if esc_nl == "\"a\\nb\"" then println("escape_newline_ok")
    else println("FAIL escape_newline: " + esc_nl)

    // tab
    let esc_tab = JsonValue.String("a\tb").to_string()
    if esc_tab == "\"a\\tb\"" then println("escape_tab_ok")
    else println("FAIL escape_tab: " + esc_tab)

    // control character (U+0001 -> \u0001)
    let mut ctrl_str = String.new()
    ctrl_str.push_byte((UInt8)1)
    let esc_ctrl = JsonValue.String(ctrl_str).to_string()
    if esc_ctrl == "\"\\u0001\"" then println("escape_control_ok")
    else println("FAIL escape_control: " + esc_ctrl)

    // === Nested structures ===

    // array of objects: [{"a":1},{"b":2}]
    let mut obj1 = [String, JsonValue ref]Dict.new()
    obj1.insert("a", box(JsonValue.Number(1.0)))
    let mut obj2 = [String, JsonValue ref]Dict.new()
    obj2.insert("b", box(JsonValue.Number(2.0)))
    let mut arr_of_obj = [JsonValue ref]List.new()
    arr_of_obj.push(box(JsonValue.Object(obj1)))
    arr_of_obj.push(box(JsonValue.Object(obj2)))
    let aoo_json = JsonValue.Array(arr_of_obj).to_string()
    if aoo_json == "[{\"a\":1},{\"b\":2}]" then println("nested_array_of_objects_ok")
    else println("FAIL nested_array_of_objects: " + aoo_json)

    // object with array value: {"nums":[1,2,3]}
    let mut inner_arr = [JsonValue ref]List.new()
    inner_arr.push(box(JsonValue.Number(1.0)))
    inner_arr.push(box(JsonValue.Number(2.0)))
    inner_arr.push(box(JsonValue.Number(3.0)))
    let mut outer_obj = [String, JsonValue ref]Dict.new()
    outer_obj.insert("nums", box(JsonValue.Array(inner_arr)))
    let owa_json = JsonValue.Object(outer_obj).to_string()
    if owa_json == "{\"nums\":[1,2,3]}" then println("nested_object_with_array_ok")
    else println("FAIL nested_object_with_array: " + owa_json)

    yield 0
}
