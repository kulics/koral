// 1. Recursive Enum Type
type TreeNode {
    Leaf(value Int),
    Node(value Int, left TreeNode ref, right TreeNode ref),
    Empty(),
}

// 2. Generic Enum Type (Option)
type [T Any]MyOption {
    Some(value T),
    None(),
}

// 3. Generic Enum Type (Result)
type [O Any, E Any]MyResult {
    Ok(value O),
    Err(err E),
}

let main() Int = {
    let mut leaf = TreeNode.Leaf(10)
    let mut empty = TreeNode.Empty()

    let node = TreeNode.Node(5, leaf.ref, empty.ref)

    let opt = [Int]MyOption.Some(42)
    let none = [Int]MyOption.None()

    let resOk = [Int, Int]MyResult.Ok(200)
    let resErr = [Int, Int]MyResult.Err(404)

    println("All Enum Constructions Passed")
    yield 0
}
// EXPECT: All Enum Constructions Passed
