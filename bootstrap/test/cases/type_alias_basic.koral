// Test basic type alias functionality
// EXPECT: meters_test:
// EXPECT: 42
// EXPECT: alias_chain:
// EXPECT: 100
// EXPECT: alias_struct:
// EXPECT: 10
// EXPECT: alias_func_param:
// EXPECT: 7

type Meters = Int
type Distance = Meters
type Point(x Int, y Int)
type Coord = Point

let add_meters(a Meters, b Meters) Meters = a + b

let main() Int = {
    let m Meters = 42
    println("meters_test:")
    println(m)

    let d Distance = 100
    println("alias_chain:")
    println(d)

    let c = Coord(10, 20)
    println("alias_struct:")
    println(c.x)

    let result = add_meters(3, 4)
    println("alias_func_param:")
    println(result)

    yield 0
}
