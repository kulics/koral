// Test or return propagation for Option and Result
// EXPECT: Option Some path: 14
// EXPECT: Option None path: None
// EXPECT: Result Ok path: 18
// EXPECT: Result Error path: err
// EXPECT: Precedence Ok path: 11
// EXPECT: Precedence Error path: boom

let print_option(label String, value [Int]Option) Void = {
    print(label)
    when value in {
        .Some(v) then println(v.to_string()),
        .None then println("None"),
    }
}

let print_result(label String, value [Int]Result) Void = {
    print(label)
    when value in {
        .Ok(v) then println(v.to_string()),
        .Error(e) then println(e.message()),
    }
}

let double_option(opt [Int]Option) [Int]Option = {
    let value = opt or return
    yield [Int]Option.Some(value * 2)
}

let double_result(res [Int]Result) [Int]Result = {
    let value = res or return
    yield [Int]Result.Ok(value * 2)
}

let double_then_increment(res [Int]Result) [Int]Result = {
    let value = res and then it * 2 or return
    yield [Int]Result.Ok(value + 1)
}

let main() Int = {
    print_option("Option Some path: ", double_option([Int]Option.Some(7)))
    print_option("Option None path: ", double_option([Int]Option.None()))
    print_result("Result Ok path: ", double_result([Int]Result.Ok(9)))
    print_result("Result Error path: ", double_result([Int]Result.Error(box("err"))))
    print_result("Precedence Ok path: ", double_then_increment([Int]Result.Ok(5)))
    print_result("Precedence Error path: ", double_then_increment([Int]Result.Error(box("boom"))))
    yield 0
}
