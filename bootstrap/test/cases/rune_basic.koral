// Test basic Rune type functionality
// EXPECT: All Rune basic tests passed!

let main() Int = {
    let r1 = Rune.from_uint32((UInt32)65).unwrap()
    assert(r1.to_uint32() == (UInt32)65, "Rune value should be 65")

    let r2 = Rune.from_uint32_unchecked((UInt32)65)
    assert(r1 == r2, "Runes with same value should be equal")

    let r3 = Rune.from_uint32_unchecked((UInt32)66)
    assert(r1 <> r3, "Runes with different values should not be equal")

    assert(r1 < r3, "A should be less than B")
    assert(r3 > r1, "B should be greater than A")

    let valid_rune = Rune.from_uint32_unchecked((UInt32)20013)
    assert(valid_rune.is_valid(), "Valid Unicode code point should be valid")

    let invalid_rune = Rune.from_uint32_unchecked((UInt32)55296)
    assert(not invalid_rune.is_valid(), "Surrogate should be invalid")

    let too_large = Rune.from_uint32_unchecked((UInt32)1114112)
    assert(not too_large.is_valid(), "Code point beyond 0x10FFFF should be invalid")

    let ascii = Rune.from_uint32_unchecked((UInt32)65)
    assert(ascii.byte_count() == 1, "ASCII should be 1 byte")

    let latin = Rune.from_uint32_unchecked((UInt32)233)
    assert(latin.byte_count() == 2, "Latin extended should be 2 bytes")

    let cjk = Rune.from_uint32_unchecked((UInt32)20013)
    assert(cjk.byte_count() == 3, "CJK should be 3 bytes")

    let emoji = Rune.from_uint32_unchecked((UInt32)128512)
    assert(emoji.byte_count() == 4, "Emoji should be 4 bytes")

    let a_str = Rune.from_uint32_unchecked((UInt32)65).to_string()
    assert(a_str == "A", "Rune 'A' to_string should be 'A'")
    assert(a_str.count() == 1, "ASCII string should be 1 byte")

    assert(Rune.from_uint32_unchecked((UInt32)65).is_ascii(), "ASCII char should be ASCII")
    assert(not Rune.from_uint32_unchecked((UInt32)20013).is_ascii(), "CJK char should not be ASCII")

    assert(Rune.from_uint32_unchecked((UInt32)48).is_ascii_digit(), "'0' should be digit")
    assert(Rune.from_uint32_unchecked((UInt32)57).is_ascii_digit(), "'9' should be digit")
    assert(not Rune.from_uint32_unchecked((UInt32)65).is_ascii_digit(), "'A' should not be digit")

    assert(Rune.from_uint32_unchecked((UInt32)32).is_ascii_whitespace(), "Space should be whitespace")
    assert(Rune.from_uint32_unchecked((UInt32)10).is_ascii_whitespace(), "LF should be whitespace")
    assert(not Rune.from_uint32_unchecked((UInt32)65).is_ascii_whitespace(), "'A' should not be whitespace")

    assert(Rune.from_uint32_unchecked((UInt32)65).is_ascii_alphabetic(), "'A' should be ASCII alphabetic")
    assert(Rune.from_uint32_unchecked((UInt32)97).is_ascii_alphabetic(), "'a' should be ASCII alphabetic")
    assert(not Rune.from_uint32_unchecked((UInt32)20013).is_ascii_alphabetic(), "CJK char should not be ASCII alphabetic")
    assert(not Rune.from_uint32_unchecked((UInt32)48).is_ascii_alphabetic(), "'0' should not be ASCII alphabetic")

    assert(Rune.from_uint32_unchecked((UInt32)65).is_identifier_start(), "'A' can start identifier")
    assert(Rune.from_uint32_unchecked((UInt32)95).is_identifier_start(), "'_' can start identifier")
    assert(not Rune.from_uint32_unchecked((UInt32)48).is_identifier_start(), "'0' cannot start identifier")

    assert(Rune.from_uint32_unchecked((UInt32)65).is_identifier_continue(), "'A' can continue identifier")
    assert(Rune.from_uint32_unchecked((UInt32)48).is_identifier_continue(), "'0' can continue identifier")
    assert(Rune.from_uint32_unchecked((UInt32)95).is_identifier_continue(), "'_' can continue identifier")
    assert(not Rune.from_uint32_unchecked((UInt32)32).is_identifier_continue(), "Space cannot continue identifier")

    assert(Rune.from_uint32_unchecked((UInt32)10).is_newline(), "LF should be newline")
    assert(Rune.from_uint32_unchecked((UInt32)13).is_newline(), "CR should be newline")
    assert(not Rune.from_uint32_unchecked((UInt32)32).is_newline(), "Space should not be newline")

    println("All Rune basic tests passed!")
    yield 0
}
