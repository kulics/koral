// Tests for generic types and functions
// Combines: basic generic types, generic functions, pairs, and copy semantics

// EXPECT: 1
// EXPECT: hello
// EXPECT: 42
// EXPECT: 42
// EXPECT: hello
// EXPECT: 10
// EXPECT: 20
// EXPECT: 1
// EXPECT: hello
// EXPECT: world
// EXPECT: 2
// EXPECT: 100
// EXPECT: 100
// EXPECT: 10
// EXPECT: 20
// EXPECT: 123
// EXPECT: 123

type [T Any] Box(value T)
type [T Any, U Any] TestPair(first T, second U)
type Point(x Int, y Int)

let [T Any] identity(x T) T = x

let [T Any] makePair(a T, b T) [T, T]TestPair = {
    yield [T, T]TestPair(a, b)
}

let [T Any] duplicate(x T) [T, T]TestPair = {
    yield [T, T]TestPair(x, x)
}

let main() = {
    let b1 = [Int]Box(1)
    println(b1.value)

    let b2 = [String]Box("hello")
    println(b2.value)

    let r = box(42)
    let b3 = [Int ref]Box(r)
    println(b3.value.val)

    println(identity(42))
    println(identity("hello"))

    let p = makePair(10, 20)
    println(p.first)
    println(p.second)

    let pair1 = [Int, String]TestPair(1, "hello")
    println(pair1.first)
    println(pair1.second)

    let pair2 = [String, Int]TestPair("world", 2)
    println(pair2.first)
    println(pair2.second)

    let dup1 = duplicate(100)
    println(dup1.first)
    println(dup1.second)

    let pt = Point(10, 20)
    let dup2 = duplicate(pt)
    println(dup2.first.x)
    println(dup2.second.y)

    let r2 = box(123)
    let dup3 = duplicate(r2)
    println(dup3.first.val)
    println(dup3.second.val)
}
