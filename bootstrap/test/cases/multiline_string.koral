// EXPECT: basic ok
// EXPECT: indent ok
// EXPECT: escape ok
// EXPECT: interp ok
// EXPECT: empty lines ok
// EXPECT: no trailing newline ok

let main() Int = {
    // Basic multiline string
    let s1 = """
        hello
        world
        """
    assert(s1 == "hello\nworld", "basic multiline")
    println("basic ok")

    // Indentation stripping: closing """ sets the indent level
    let s2 = """
        line one
        line two
        """
    assert(s2 == "line one\nline two", "indent stripping")
    println("indent ok")

    // Escape sequences inside multiline strings
    let s3 = """
        tab:\there
        newline inside: done
        """
    assert(s3 == "tab:\there\nnewline inside: done", "escape in multiline")
    println("escape ok")

    // String interpolation inside multiline strings
    let name = "Koral"
    let s4 = """
        Hello \(name)!
        Welcome.
        """
    assert(s4 == "Hello Koral!\nWelcome.", "interpolation in multiline")
    println("interp ok")

    // Empty lines in the middle are preserved
    let s5 = """
        first

        third
        """
    assert(s5 == "first\n\nthird", "empty lines preserved")
    println("empty lines ok")

    // Single line content (no trailing newline after last content line)
    let s6 = """
        only
        """
    assert(s6 == "only", "single line multiline")
    println("no trailing newline ok")

    yield 0
}
