// EXPECT: list_slice_bounds_closed_open_ok
// EXPECT: list_slice_bounds_from_ok
// EXPECT: string_slice_bounds_full_ok
// EXPECT: string_slice_bounds_slice_ok

let main() Void = {
    let mut values = [Int]List.new()
    values.push(10)
    values.push(20)
    values.push(30)
    values.push(40)

    let list_span = values.slice_bounds(1..<3)
    assert(list_span.first == 1, "list start")
    assert(list_span.second == 3, "list end")
    println("list_slice_bounds_closed_open_ok")

    let from_span = values.slice_bounds(2...)
    assert(from_span.first == 2, "from start")
    assert(from_span.second == 4, "from end")
    println("list_slice_bounds_from_ok")

    let text = "hello"
    let full_span = text.slice_bounds(....)
    assert(full_span.first == 0, "string full start")
    assert(full_span.second == 5, "string full end")
    println("string_slice_bounds_full_ok")

    let slice_span = text.slice_bounds(1..<(text.count() - 1))
    assert(slice_span.first == 1, "string slice start")
    assert(slice_span.second == 4, "string slice end")
    println("string_slice_bounds_slice_ok")
}