// Test that single-branch if...is (pattern match without else) rejects non-Void/Never then branch
// EXPECT-ERROR: Single-branch 'if' must have Void or Never type in then branch

type MyOption {
    Some(val Int),
    None(),
}

let main() Int = {
    let opt = MyOption.Some(10)
    // This should fail: yield produces Int in a single-branch if...is
    if opt is .Some(v) then { yield v }
    yield 0
}
