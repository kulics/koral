// Test: type inference for literals and expressions

// 整数字面量默认推断为 Int
let int_lit = 42
let neg_lit = -10
let zero = 0

// 浮点字面量默认推断为 Float
let float_lit = 3.14
let neg_float = -2.5

// 布尔字面量
let bool_true = true
let bool_false = false

// 字符串字面量
let str_lit = "hello"

// 复合表达式类型推断
let sum = 1 + 2
let product = 3 * 4
let mixed = 1 + 2 * 3

// 条件表达式类型推断
foreign let cond Bool
let conditional = if cond then 1 else 2

// 块表达式类型推断
let block_val = {
    let x = 10
    let y = 20
    yield x + y
}
