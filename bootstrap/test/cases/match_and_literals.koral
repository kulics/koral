type [T Any]Option {
    Some(value T),
    None(),
}

let n = 42
let opt = [Int]Option.Some(10)

let empty = [];
let numbers = [1, 2, 3];
let lookup = [1: 10, 2: 20];

let m1 = when n in {
    0 then 100,
    42 then 200,
    _ then 999,
};

let m2 = when opt in {
    .Some(v) then v,
    .None() then 0,
};
