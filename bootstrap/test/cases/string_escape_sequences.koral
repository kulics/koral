// EXPECT: escape_basic_ok
// EXPECT: escape_hex_ok
// EXPECT: escape_unicode_ok
// EXPECT: escape_unicode_multibyte_ok

let main() Int = {
    assert("\n" == "\n", "newline")
    assert("\t" == "\t", "tab")
    assert("\\" == "\\", "backslash")
    assert("\0".count() == 1, "null byte count")
    println("escape_basic_ok")

    let a = "\x41"
    assert(a == "A", "\\x41 should be A")
    let b = "\x00"
    assert(b.count() == 1, "\\x00 count")
    assert(b[0] == 0, "\\x00 value")
    let c = "\x61\x62\x63"
    assert(c == "abc", "\\x hex sequence")
    println("escape_hex_ok")

    let d = "\u{41}"
    assert(d == "A", "\\u{41} should be A")
    let e = "\u{0041}"
    assert(e == "A", "\\u{0041} should be A")
    let f = "\u{1F600}"
    assert(f.count() == 4, "emoji should be 4 UTF-8 bytes")
    println("escape_unicode_ok")

    let g = "\u{4E2D}\u{6587}"
    assert(g.count() == 6, "two CJK chars = 6 UTF-8 bytes")
    println("escape_unicode_multibyte_ok")

    yield 0
}
