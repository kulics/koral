// EXPECT: let_some: PASS
// EXPECT: let_none: PASS
// EXPECT: return_expr: PASS
// EXPECT: call_arg: PASS
// EXPECT: and_chain: PASS
// EXPECT: or_chain: PASS
// EXPECT: compare_and_is: PASS
// EXPECT: All is expression tests passed!

type MyOption {
    None(),
    Some(value Int),
}

let returns_some(opt MyOption) Bool =
    opt is .Some(_)

let describe(flag Bool) String =
    if flag then "yes" else "no"

let main() Int = {
    let some = MyOption.Some(7)
    let none = MyOption.None()

    let let_some = some is .Some(_)
    let let_none = none is .Some(_)
    let and_chain = some is .Some(_) and none is .None()
    let or_chain = none is .Some(_) or some is .Some(_)
    let compare_and_is = 3 > 0 and some is .Some(_)

    if let_some then {
        println("let_some: PASS")
    } else {
        println("let_some: FAIL")
        return 1
    }

    if not let_none then {
        println("let_none: PASS")
    } else {
        println("let_none: FAIL")
        return 1
    }

    if returns_some(some) then {
        println("return_expr: PASS")
    } else {
        println("return_expr: FAIL")
        return 1
    }

    if describe(some is .Some(_)) == "yes" then {
        println("call_arg: PASS")
    } else {
        println("call_arg: FAIL")
        return 1
    }

    if and_chain then {
        println("and_chain: PASS")
    } else {
        println("and_chain: FAIL")
        return 1
    }

    if or_chain then {
        println("or_chain: PASS")
    } else {
        println("or_chain: FAIL")
        return 1
    }

    if compare_and_is then {
        println("compare_and_is: PASS")
    } else {
        println("compare_and_is: FAIL")
        return 1
    }

    println("All is expression tests passed!")
    yield 0
}