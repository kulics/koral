// EXPECT: 2
// EXPECT: 9

type Flag {
    Stop(),
    Go(),
}

let decide(flag Flag) Int = {
    when flag in {
        .Stop then {
            return 2
        },
        .Go then {},
    }

    yield 9
}

let main() Int = {
    println(decide(Flag.Stop()))
    println(decide(Flag.Go()))
    yield 0
}