using self.io...;
foreign using m;

public trait Show {
    show(self) String
}

given Int Show {
    show(self) String = "ok"
}

intrinsic let abs(v Int) Int;
foreign let ext_counter Int;
foreign let c_abs(v Int) Int;

intrinsic type Builtin;
foreign type "size_t" Size;
foreign type CPair(left Int, right Int);

intrinsic given Int {
    show(self) String;
}

type Pair(left Int, right Int)

type Choice {
    A(value Int),
    B(),
}

type Alias = Int;

public let one Int = 1;
private let sum(a Int, b Int) Int = a + b;
