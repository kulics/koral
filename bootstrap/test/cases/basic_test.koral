foreign let value Int
foreign let flag Bool
foreign let next_value Int
foreign let fallback_value Int
foreign let a Int
foreign let b Int
foreign let left Int
foreign let right Int
foreign let opt [Int]Option
foreign let current [Int]Option
foreign let items [Int]List
foreign let n Int

using std.io;

trait Show {
    show(self) String
}

given Int Show {
    show(self) String = "int"
}

type Pair(left Int, right Int)

type MaybeInt {
    Some(value Int),
    None(),
}

let add(a Int, b Int) Int = a + b;

let decl_and_expr = let mut x = 1 then x + 2;

let pointer_prefix = ref ptr deptr deref value;

let logical_chain = flag and then next_value or else fallback_value;

let bitwise_expr = (a << 1) | (b & 3) ^ 2;

let ranged = left ..< right;

let flow_if = if opt is .Some(v) then v else 0;

let flow_while = while current is .Some(v) then v;

let flow_for = for mut item in items then item + 1;

let flow_when = when n in {
    0 then 1,
    1 then 2,
    _ then 3,
};

let block_stmt = {
    let mut local = 41;
    yield local + 1;
};