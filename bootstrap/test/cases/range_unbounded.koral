// EXPECT: All unbounded range tests passed!

// Test unbounded Range iterator functionality (uses T.max() and T.min())

let main() = {
    // Test From with small iteration (5... but only iterate a few)
    let mut count = 0
    for i in 5... then {
        count = count + 1
        if count >= 5 then {
            break
        }
    }
    assert(count == 5, "From should iterate at least 5 times")
    
    // Test After (5<... starts from 6)
    let mut first_val = 0
    for i in 5<... then {
        first_val = i
        break
    }
    assert(first_val == 6, "After should start from 6")
    
    // Test To with small values (...5 from min to 5)
    // We can't iterate from min, so just test contains
    let r1 = ...5
    assert(r1.contains(5), "To should contain 5")
    assert(r1.contains(0 - 1000), "To should contain negative values")
    
    // Test Until
    let r2 = ...<5
    assert(r2.contains(4), "Until should contain 4")
    assert(not r2.contains(5), "Until should not contain 5")
    
    // Test Full contains
    let r3 = [Int]Range.Full()
    assert(r3.contains(0), "Full should contain 0")
    assert(r3.contains(1000), "Full should contain 1000")
    assert(r3.contains(0 - 1000), "Full should contain -1000")
    
    println("All unbounded range tests passed!")
}
