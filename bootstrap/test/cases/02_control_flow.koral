let if_expr = if cond then a else b;
let if_pattern = if opt is .Some(v) then v else 0;

let while_expr = while i < 10 then i + 1;
let while_pattern = while current is .Some(v) then v;

let for_expr = for mut item in items then item + 1;

let when_expr = when n in {
    0 then 1,
    1 then 2,
    _ then 3,
};

let block_expr = {
    let mut x Int = 1;
    x += 2;
    deptr ptr_value = x;
    self.value = x;
    yield x + 1;
    return x;
};
