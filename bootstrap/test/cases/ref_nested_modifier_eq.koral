// Tests that T ref ref satisfies Eq when T implements Eq (recursive blanket given check)
// Feature: type-modifier-trait-conformance

type Val(n Int)

given Val Eq {
    public equals(self, other Val) Bool = self.n == other.n
}

let [T Eq] are_equal(a T, b T) Bool = a == b

let main() Void = {
    let mut v1 = Val(7)
    let mut v2 = Val(7)
    let inner1 = ref v1
    let inner2 = ref v2
    let mut r1 = inner1
    let mut r2 = inner2
    let a = ref r1
    let b = ref r2
    println(are_equal(a, b))
}
// EXPECT: true
