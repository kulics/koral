// EXPECT: Drop Box 0
// EXPECT: Drop Box 1
// EXPECT: overwrite drop regression passed
// EXPECT: Drop Box 2
// EXPECT: Drop Box 3

type Box(id Int)

given Box Drop {
    drop(self mut ref) Void = {
        print("Drop Box ")
        println(self.id)
    }
}

let main() Int = {
    let mut value = Box(0)
    value = Box(1)
    value = Box(2)
    println("overwrite drop regression passed")
    value = Box(3)
    yield 0
}