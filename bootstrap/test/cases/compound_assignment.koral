// EXPECT: 110
// EXPECT: 100
// EXPECT: 200
// EXPECT: 100
// EXPECT: 1
// EXPECT: 11

type Point(mut x Int, y Int)

let main() Int = {
    let mut a = 100
    a += 10
    println(a)

    a -= 10
    println(a)

    a *= 2
    println(a)

    a /= 2
    println(a)

    a %= 3
    println(a)

    let mut p = Point(10, 20)
    p.x += 1
    println(p.x)

    yield 0
}