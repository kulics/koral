// Test: trait inheritance and parent trait satisfaction

trait Animal {
    name(self) String
    sound(self) String
}

trait Pet Animal {
    owner(self) String
}

trait ServicePet Pet {
    service_type(self) String
}

type Dog(dog_name String, dog_owner String)
type GuideDog(dog_name String, dog_owner String)

// 实现基础 Trait
given Dog Animal {
    name(self) String = self.dog_name
    sound(self) String = "woof"
}

// 实现子 Trait（父 Trait 已实现）
given Dog Pet {
    owner(self) String = self.dog_owner
}

// 多层继承：实现 ServicePet（需要 Pet 和 Animal 都已实现）
given GuideDog Animal {
    name(self) String = self.dog_name
    sound(self) String = "woof"
}

given GuideDog Pet {
    owner(self) String = self.dog_owner
}

given GuideDog ServicePet {
    service_type(self) String = "guide"
}
