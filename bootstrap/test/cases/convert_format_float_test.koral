// std.text float formatting tests
// EXPECT: fixed_ok
// EXPECT: fixed_prec_ok
// EXPECT: sci_ok
// EXPECT: sci_upper_ok
// EXPECT: percent_ok
// EXPECT: nan_ok
// EXPECT: inf_ok
// EXPECT: neg_inf_ok
// EXPECT: width_ok
// EXPECT: sign_plus_ok
// EXPECT: f32_ok
// EXPECT: round_tie_even_ok
// EXPECT: round_binary_edge_ok
// EXPECT: g_sci_ok
// EXPECT: g_small_ok
// EXPECT: upper_inf_nan_ok

using Std.Text

let main() Int = {
    // Fixed format (default precision 6)
    let s1 = 3.14159.format("f")
    if s1.starts_with("3.1415") then println("fixed_ok")
    else println("FAIL fixed: " + s1)

    // Fixed with precision 2
    let s2 = 3.14159.format(".2f")
    if s2.equals("3.14") then println("fixed_prec_ok")
    else println("FAIL fixed_prec: " + s2)

    // Scientific notation
    let s3 = 1500.0.format(".2e")
    if s3.equals("1.50e+03") then println("sci_ok")
    else println("FAIL sci: " + s3)

    // Scientific uppercase
    let s4 = 1500.0.format(".2E")
    if s4.equals("1.50E+03") then println("sci_upper_ok")
    else println("FAIL sci_upper: " + s4)

    // Percentage
    let s5 = 0.125.format(".1%")
    if s5.equals("12.5%") then println("percent_ok")
    else println("FAIL percent: " + s5)

    // NaN
    let nan = Float64.nan()
    if nan.format("f").equals("nan") then println("nan_ok")
    else println("FAIL nan: " + nan.format("f"))

    // Inf
    let inf = Float64.inf()
    if inf.format("f").equals("inf") then println("inf_ok")
    else println("FAIL inf: " + inf.format("f"))

    // -Inf
    let neg_inf = 0.0 - Float64.inf()
    if neg_inf.format("f").equals("-inf") then println("neg_inf_ok")
    else println("FAIL neg_inf: " + neg_inf.format("f"))

    // Width
    let s6 = 3.14.format("10.2f")
    if s6.equals("      3.14") then println("width_ok")
    else println("FAIL width: [" + s6 + "]")

    // Sign +
    let s7 = 3.14.format("+.2f")
    if s7.equals("+3.14") then println("sign_plus_ok")
    else println("FAIL sign_plus: " + s7)

    // Float32
    let f32 Float32 = 2.5
    let s8 = f32.format(".1f")
    if s8.equals("2.5") then println("f32_ok")
    else println("FAIL f32: " + s8)

    // Round half even
    if 2.5.format(".0f").equals("2") then println("round_tie_even_ok")
    else println("FAIL round_tie_even: " + 2.5.format(".0f"))

    // Binary representation edge case should match Python behavior
    if 2.675.format(".2f").equals("2.67") then println("round_binary_edge_ok")
    else println("FAIL round_binary_edge: " + 2.675.format(".2f"))

    // General format significant digits
    if 1500.0.format(".2g").equals("1.5e+03") then println("g_sci_ok")
    else println("FAIL g_sci: " + 1500.0.format(".2g"))

    if 0.0001234.format(".2g").equals("0.00012") then println("g_small_ok")
    else println("FAIL g_small: " + 0.0001234.format(".2g"))

    // Uppercase type should uppercase INF/NAN
    if inf.format("F").equals("INF") and nan.format("F").equals("NAN") then println("upper_inf_nan_ok")
    else println("FAIL upper_inf_nan: inf=" + inf.format("F") + " nan=" + nan.format("F"))

    yield 0
}
