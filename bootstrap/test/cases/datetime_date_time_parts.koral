// EXPECT: from_parts_ok
// EXPECT: from_date_at_midnight_ok
// EXPECT: date_accessor_ok
// EXPECT: time_accessor_ok
// EXPECT: weekday_ok

using Std.Time.*

let main() Int = {
    // from_parts roundtrip
    let d = Date.new(year: 2024, month: 6, day: 15).unwrap()
    let t = ClockTime.new_full(hour: 10, minute: 30, second: 45, nanosecond: 500_000_000).unwrap()
    let dt = DateTime.from_parts(d, t, TimeZone.utc())
    assert(dt.year() == 2024, "year")
    assert(dt.month() == 6, "month")
    assert(dt.day() == 15, "day")
    assert(dt.hour() == 10, "hour")
    assert(dt.minute() == 30, "min")
    assert(dt.second() == 45, "sec")
    println("from_parts_ok")

    // from_date_at_midnight
    let d2 = Date.new(year: 2024, month: 3, day: 1).unwrap()
    let dt2 = DateTime.from_date_at_midnight(d2, TimeZone.utc())
    assert(dt2.year() == 2024, "midnight year")
    assert(dt2.month() == 3, "midnight month")
    assert(dt2.day() == 1, "midnight day")
    assert(dt2.hour() == 0, "midnight hour")
    assert(dt2.minute() == 0, "midnight min")
    assert(dt2.second() == 0, "midnight sec")
    println("from_date_at_midnight_ok")

    // date() accessor
    let epoch = DateTime.epoch()
    let ed = epoch.date()
    assert(ed.year() == 1970, "epoch date year")
    assert(ed.month() == 1, "epoch date month")
    assert(ed.day() == 1, "epoch date day")
    println("date_accessor_ok")

    // time() accessor
    let et = epoch.time()
    assert(et.hour() == 0, "epoch time hour")
    assert(et.minute() == 0, "epoch time min")
    assert(et.second() == 0, "epoch time sec")
    // from_parts time roundtrip
    let rt = dt.time()
    assert(rt.hour() == 10, "rt time hour")
    assert(rt.minute() == 30, "rt time min")
    assert(rt.second() == 45, "rt time sec")
    assert(rt.nanosecond() == 500_000_000, "rt time nanos")
    println("time_accessor_ok")

    // weekday: 2024-06-15 is Saturday (ISO 8601 = 6)
    assert(dt.weekday() == 6, "weekday sat")
    // epoch 1970-01-01 is Thursday (ISO 8601 = 4)
    assert(epoch.weekday() == 4, "epoch thursday")
    println("weekday_ok")

    yield 0
}
