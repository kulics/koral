// Test: trait conformance error - missing required method

// EXPECT-ERROR: does not implement method 'area' required by trait 'Shape'

trait Shape {
    area(self) Int;
    perimeter(self) Int;
}

type Circle(radius Int)

// 只实现了 perimeter，缺少 area
given Circle Shape {
    perimeter(self) Int = 0;
}
