foreign let name String
foreign let add [Int, Int, Int]Func
foreign let foo [Int, Int]Func
foreign let bar [Int, Int, Int]Func
foreign let baz [String, Int]Func

let simple = "hello";
let interp = "hello \(name), value=\(1 + 2)";
let multiline = """
line1
line2 \(name)
""";

let nested_let = let x = 1 then add(x, 2);
let call_chain = foo(bar(1, 2), baz("x"));
