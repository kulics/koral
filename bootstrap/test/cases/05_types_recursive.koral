type FnAlias = [Int, String]Func ref;

type Qualified = std.[Int]List weakref;

type Holder(
    plain Int,
    generic [String]List,
    func [Int, Bool]Func,
    module_generic std.[Int]List ptr,
    self_like Self ref,
)

let pick(input [Int]List, f [Int, Bool]Func) [Int]List = input;

trait Printer {
    render(self weakref, value std.[Int]List ref) [String]List
}

given Self Printer {
    render(self weakref, value std.[Int]List ref) [String]List = value
}
