using Std.Os.*

using "model"
using "cli"
using "discovery"
using "expectation"
using "executor"
using "reporter"
using "scheduler"

public let run_bootstrap_tests() Int = {
    let config = parse_runner_config() or else {
        eprintln(_.message())
        print_usage()
        return 2
    }

    if not path_exist(config.bootstrap_koralc) then {
        eprintln("bootstrap-koralc not found: \(config.bootstrap_koralc.to_string())")
        eprintln("Hint: build with host Swift compiler first, e.g.")
        eprintln("  compiler/.build/debug/koralc build bootstrap/koralc/main.koral -o out/bootstrap")
        return 2
    }

    let cases = discover_cases(config) or else {
        eprintln("failed to discover cases: \(_.message())")
        return 1
    }

    let summary = run_cases(config, cases)
    return summary.exit_code
}
