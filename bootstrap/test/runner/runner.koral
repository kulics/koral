using Std.Os.*

using "model"
using "cli"
using "discovery"
using "expectation"
using "executor"
using "reporter"
using "scheduler"

public let run_bootstrap_tests() Int = {
    let config = parse_runner_config() or else {
        eprintln(_.message())
        print_usage()
        return 2
    }

    init_report_file(config) or else {
        eprintln("failed to initialize report file: " + config.report_file.to_string() + ": " + _.message())
        return 2
    }

    if not path_exist(config.bootstrap_koralc) then {
        report_error_line(config, "bootstrap-koralc not found: \(config.bootstrap_koralc.to_string())")
        report_error_line(config, "Hint: build with host Swift compiler first, e.g.")
        report_error_line(config, "  compiler/.build/debug/koralc build bootstrap/koralc/main.koral -o out/bootstrap")
        return 2
    }

    let cases = discover_cases(config) or else {
        report_error_line(config, "failed to discover cases: \(_.message())")
        return 1
    }

    let summary = run_cases(config, cases)
    return summary.exit_code
}
