public let print_case_result(index UInt, total UInt, result CaseResult) Void = {
    if result.passed then {
        println(
            "PASS "
            + index.to_string()
            + "/"
            + total.to_string()
            + " "
            + result.case_info.relative_path
            + " "
            + result.duration_ms.to_string()
            + "ms"
        )
    } else {
        println(
            "FAIL "
            + index.to_string()
            + "/"
            + total.to_string()
            + " "
            + result.case_info.relative_path
            + " "
            + result.failure_type
            + " "
            + result.duration_ms.to_string()
            + "ms"
        )
        if not result.failure_message.is_empty() then {
            println("  reason: " + result.failure_message)
        }
    }
}

public let print_summary(summary RunSummary) Void = {
    println(
        "SUMMARY total="
        + summary.total.to_string()
        + " passed="
        + summary.passed.to_string()
        + " failed="
        + summary.failed.to_string()
        + " timed_out="
        + summary.timed_out.to_string()
        + " infra_failed="
        + summary.infra_failed.to_string()
        + " duration_ms="
        + summary.duration_ms.to_string()
    )
    println("EXIT " + summary.exit_code.to_string())
}
