public let print_case_result(index UInt, total UInt, result CaseResult) Void = {
    if result.passed then {
        println("PASS \(index)/\(total) \(result.case_info.relative_path) \(result.duration_ms)ms")
    } else {
        println("FAIL \(index)/\(total) \(result.case_info.relative_path) \(result.failure_type) \(result.duration_ms)ms")
        if not result.failure_message.is_empty() then {
            println("  reason: \(result.failure_message)")
        }
    }
}

public let print_summary(summary RunSummary) Void = {
    println("SUMMARY total=\(summary.total) passed=\(summary.passed) failed=\(summary.failed) timed_out=\(summary.timed_out) infra_failed=\(summary.infra_failed) duration_ms=\(summary.duration_ms)")
    println("EXIT \(summary.exit_code)")
}
