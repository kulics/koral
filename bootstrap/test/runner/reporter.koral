using Std.Os.*

private let append_report_line(config RunnerConfig, line String) Void = {
    let _ = append_text_file(config.report_file, content: line + "\n")
}

private let case_result_primary_line(index UInt, total UInt, result CaseResult) String = {
    return if result.passed then {
        yield "PASS "
            + index.to_string()
            + "/"
            + total.to_string()
            + " "
            + result.case_info.relative_path
            + " "
            + result.duration_ms.to_string()
            + "ms"
    } else {
        yield "FAIL "
            + index.to_string()
            + "/"
            + total.to_string()
            + " "
            + result.case_info.relative_path
            + " "
            + result.failure_type
            + " "
            + result.duration_ms.to_string()
            + "ms"
    }
}

private let case_started_line(index UInt, total UInt, info CaseInfo) String = {
    let base = "START "
        + index.to_string()
        + "/"
        + total.to_string()
        + " "
        + info.relative_path
    return if info.group_key == "normal" then base else base + " group=" + info.group_key
}

public let init_report_file(config RunnerConfig) [Void]Result = {
    create_dir_all(config.report_file.dir_name()) or else {
        return [Void]Result.Error(it)
    }
    return write_text_file(config.report_file, content: String.new())
}

public let report_line(config RunnerConfig, line String) Void = {
    println(line)
    append_report_line(config, line)
}

public let report_error_line(config RunnerConfig, line String) Void = {
    eprintln(line)
    append_report_line(config, line)
}

public let print_case_started(config RunnerConfig, index UInt, total UInt, info CaseInfo) Void = {
    let line = case_started_line(index, total, info)
    println(line)
    append_report_line(config, line)
}

public let print_case_result(config RunnerConfig, index UInt, total UInt, result CaseResult) Void = {
    let primary = case_result_primary_line(index, total, result)
    println(primary)
    append_report_line(config, primary)
    if not result.failure_message.is_empty() then {
        let reason_line = "  reason: " + result.failure_message
        println(reason_line)
        append_report_line(config, reason_line)
    }
}

public let print_summary(config RunnerConfig, summary RunSummary) Void = {
    let summary_line = "SUMMARY total="
        + summary.total.to_string()
        + " passed="
        + summary.passed.to_string()
        + " failed="
        + summary.failed.to_string()
        + " timed_out="
        + summary.timed_out.to_string()
        + " infra_failed="
        + summary.infra_failed.to_string()
        + " duration_ms="
        + summary.duration_ms.to_string()
    println(summary_line)
    append_report_line(config, summary_line)
    let exit_line = "EXIT " + summary.exit_code.to_string()
    println(exit_line)
    append_report_line(config, exit_line)
    let report_path_line = "REPORT_FILE " + config.report_file.to_string()
    println(report_path_line)
    append_report_line(config, report_path_line)
}

public let write_failure_summary(config RunnerConfig, results [CaseResult]List) Void = {
    append_report_line(config, "FAILED_CASES")
    let mut had_failure = false
    let total = results.count()
    let mut i UInt = 0
    while i < total then {
        let result = results.at(i)
        if not result.passed then {
            had_failure = true
            append_report_line(config, case_result_primary_line(i + 1, total, result))
            if not result.failure_message.is_empty() then {
                append_report_line(config, "  reason: " + result.failure_message)
            }
        }
        i += 1
    }
    if not had_failure then {
        append_report_line(config, "  <none>")
    }
}
