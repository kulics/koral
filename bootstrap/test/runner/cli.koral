using Std.*
using Std.Os.*

private let default_bootstrap_koralc_path() Path = {
    if env("OS") is .Some(os) and os.contains("Windows") then {
        return Path.new("out/bootstrap/main.exe")
    }
    return Path.new("out/bootstrap/main")
}

private let parse_uint(value String, flag_name String) [UInt]Result = {
    return when UInt.parse(value) in {
        .Ok(v) then [UInt]Result.Ok(v),
        .Error(_) then [UInt]Result.Error(box("invalid value for \(flag_name): \(value)")),
    }
}

private let parse_int(value String, flag_name String) [Int]Result = {
    return when Int.parse(value) in {
        .Ok(v) then [Int]Result.Ok(v),
        .Error(_) then [Int]Result.Error(box("invalid value for \(flag_name): \(value)")),
    }
}

private let make_absolute(base Path, path Path) Path = {
    return if path.is_absolute() then path else base.join(path.to_string()).normalize()
}

public let print_usage() Void = {
    eprintln("bootstrap test runner")
    eprintln("usage: bootstrap-test [options]")
    eprintln("options:")
    eprintln("  --cases <dir>                cases root (default: bootstrap/test/cases)")
    eprintln("  --filter <substring>         run only matching case name/path")
    eprintln("  -j <N> | -j=<N>              parallel workers (default: 1)")
    eprintln("  --timeout <sec>              per-case timeout seconds (default: 60)")
    eprintln("  --bootstrap-koralc <path>    bootstrap compiler executable path")
    eprintln("  --report-file <path>         write stable summary log (default: cases_output/_reports/latest-summary.log)")
    eprintln("  --verbose                    print verbose case command logs")
    eprintln("  -h, --help                   show this help")
}

public let parse_runner_config() [RunnerConfig]Result = {
    let argv = args()

    let run_root = current_dir() or else {
        return [RunnerConfig]Result.Error(box("failed to determine current working directory: " + it.message()))
    }
    let mut cases_root = Path.new("bootstrap/test/cases")
    let mut filter = [String]Option.None()
    let mut jobs UInt = 1
    let mut timeout_secs Int = 60
    let mut bootstrap_koralc = default_bootstrap_koralc_path()
    let mut report_file_opt = [Path]Option.None()
    let mut verbose = false

    let mut i UInt = 1
    while i < argv.count() then {
        let arg = argv.at(i)

        if arg == "-h" or arg == "--help" then {
            print_usage()
            return [RunnerConfig]Result.Error(box(""))
        }

        if arg == "--verbose" then {
            verbose = true
            i += 1
            continue
        }

        if arg == "--cases" then {
            i += 1
            if i >= argv.count() then {
                return [RunnerConfig]Result.Error(box("missing value for --cases"))
            }
            cases_root = Path.new(argv.at(i))
            i += 1
            continue
        }

        if arg == "--filter" then {
            i += 1
            if i >= argv.count() then {
                return [RunnerConfig]Result.Error(box("missing value for --filter"))
            }
            filter = [String]Option.Some(argv.at(i))
            i += 1
            continue
        }

        if arg == "--timeout" then {
            i += 1
            if i >= argv.count() then {
                return [RunnerConfig]Result.Error(box("missing value for --timeout"))
            }
            timeout_secs = parse_int(argv.at(i), "--timeout") or else {
                return [RunnerConfig]Result.Error(it)
            }
            if timeout_secs <= 0 then {
                return [RunnerConfig]Result.Error(box("--timeout must be > 0"))
            }
            i += 1
            continue
        }

        if arg == "--bootstrap-koralc" then {
            i += 1
            if i >= argv.count() then {
                return [RunnerConfig]Result.Error(box("missing value for --bootstrap-koralc"))
            }
            bootstrap_koralc = Path.new(argv.at(i))
            i += 1
            continue
        }

        if arg == "--report-file" then {
            i += 1
            if i >= argv.count() then {
                return [RunnerConfig]Result.Error(box("missing value for --report-file"))
            }
            report_file_opt = [Path]Option.Some(Path.new(argv.at(i)))
            i += 1
            continue
        }

        if arg == "-j" then {
            i += 1
            if i >= argv.count() then {
                return [RunnerConfig]Result.Error(box("missing value for -j"))
            }
            jobs = parse_uint(argv.at(i), "-j") or else {
                return [RunnerConfig]Result.Error(it)
            }
            if jobs == 0 then {
                return [RunnerConfig]Result.Error(box("-j must be >= 1"))
            }
            i += 1
            continue
        }

        if arg.starts_with("-j=") then {
            jobs = parse_uint(arg.trim_prefix("-j="), "-j") or else {
                return [RunnerConfig]Result.Error(it)
            }
            if jobs == 0 then {
                return [RunnerConfig]Result.Error(box("-j must be >= 1"))
            }
            i += 1
            continue
        }

        return [RunnerConfig]Result.Error(box("unknown argument: \(arg)"))
    }

    let abs_cases_root = make_absolute(run_root, cases_root)
    let abs_bootstrap_koralc = make_absolute(run_root, bootstrap_koralc)
    let output_root = abs_cases_root.dir_name().join("cases_output").normalize()
    let default_report_file = output_root.join("_reports").join("latest-summary.log").normalize()
    let report_file = when report_file_opt in {
        .Some(path) then make_absolute(run_root, path).normalize(),
        .None() then default_report_file,
    }

    return [RunnerConfig]Result.Ok(RunnerConfig(
        run_root,
        abs_cases_root,
        output_root,
        report_file,
        filter,
        jobs,
        timeout_secs,
        abs_bootstrap_koralc,
        verbose
    ))
}
