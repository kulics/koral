using std { .. }
using std::os { .. }
using std::proc { .. }
using std::time { .. }
using std::async { .. }
using std::sync { .. }

private let failure_result(
    info CaseInfo,
    status String,
    failure_type String,
    message String,
    exit_code Int,
    duration_ms Int64,
) CaseResult = {
    return CaseResult(
        info,
        false,
        status,
        failure_type,
        message,
        exit_code,
        duration_ms,
    )
}

private let pass_result(
    info CaseInfo,
    duration_ms Int64,
    exit_code Int,
) CaseResult = {
    return CaseResult(
        info,
        true,
        "passed",
        "",
        "",
        exit_code,
        duration_ms,
    )
}

private let infer_exit_code(status ExitStatus) Int = {
    return when status.code() in {
        .Some(c) then c,
        .None then when status.signal() in {
            .Some(sig) then 0 - sig,
            .None then -1,
        },
    }
}

private let is_windows_host() Bool =
    if env("OS") is .Some(os) then os.contains("Windows") else false

private type CommandExecution {
    Finished(output CommandOutput),
    TimedOut(exit_code Int),
    InfrastructureError(message String),
}

private let build_command_args_for_case(config RunnerConfig, info CaseInfo, output_dir Path) Result[List[String]] = {
    let mut args = ["build"]
    when find_case_manifest(config, info) in {
        .Some(manifest_path) then {
            args.push("--package-config")
            args.push(manifest_path.to_string())
            when find_case_deps_root(manifest_path) in {
                .Some(deps_root) then {
                    args.push("--deps-root")
                    args.push(deps_root.to_string())
                },
                .None() then {},
            }
        },
        .None() then {
            args.push(info.absolute_path.to_string())
        },
    }
    args.push("-o")
    args.push(output_dir.to_string())
    return Result[List[String]].Ok(args)
}

private let check_command_args_for_case(config RunnerConfig, info CaseInfo, output_dir Path) Result[List[String]] = {
    let mut args = ["check"]
    when find_case_manifest(config, info) in {
        .Some(manifest_path) then {
            args.push("--package-config")
            args.push(manifest_path.to_string())
            when find_case_deps_root(manifest_path) in {
                .Some(deps_root) then {
                    args.push("--deps-root")
                    args.push(deps_root.to_string())
                },
                .None() then {},
            }
        },
        .None() then {
            args.push(info.absolute_path.to_string())
        },
    }
    let _ = output_dir
    return Result[List[String]].Ok(args)
}

private let executable_path_for_case(info CaseInfo, output_dir Path) Path = {
    let base = info.absolute_path.base_name()
    let ext = info.absolute_path.ext_name()
    let stem = if ext.is_empty() then base else base.substring(.Until(base.count() - ext.count()))
    let exe_name = if is_windows_host() then stem + ".exe" else stem
    return output_dir.join(exe_name)
}

private let find_case_manifest(config RunnerConfig, info CaseInfo) Option[Path] = {
    let cases_root = config.cases_root.normalize()
    let mut current = info.absolute_path.dir_name().normalize()
    while true then {
        let candidate = current.join("koral.json")
        if path_exist(candidate) then {
            return Option[Path].Some(candidate)
        }
        if current == cases_root then {
            return Option[Path].None()
        }
        let parent = current.dir_name().normalize()
        if parent == current then {
            return Option[Path].None()
        }
        current = parent
    }
    return Option[Path].None()
}

private let find_case_deps_root(manifest_path Path) Option[Path] = {
    let deps_root = manifest_path.dir_name().join("deps").normalize()
    if path_exist(deps_root) then {
        return Option[Path].Some(deps_root)
    }
    return Option[Path].None()
}

private let find_built_executable(output_dir Path) Result[Path] = {
    let is_windows = is_windows_host()
    let mut iter = read_dir(output_dir) or else {
        return Result[Path].Error(it)
    }

    let mut found = List[Path].new()
    while iter.next() is .Some(entry) then {
        if not entry.is_file() then {
            continue
        }
        let name = entry.name()
        if name.ends_with(".txt") or name.ends_with(".c") then {
            continue
        }
        if is_windows then {
            if name.ends_with(".exe") then {
                found.push(entry.path())
            }
        } else {
            found.push(entry.path())
        }
    }

    if found.count() == 1 then {
        return Result[Path].Ok(found[0].normalize())
    }
    if found.count() == 0 then {
        return Result[Path].Error(box("no executable produced"))
    }
    return Result[Path].Error(box("multiple executable candidates produced"))
}

private let prepared_run_executable_path(info CaseInfo, output_dir Path, launch_attempt UInt) Result[Path] = {
    let exe_path = when path_exist(executable_path_for_case(info, output_dir)) in {
        true then executable_path_for_case(info, output_dir),
        false then find_built_executable(output_dir) or return,
    }
    if not is_windows_host() then {
        return Result[Path].Ok(exe_path)
    }

    // Windows can apply elevation / compatibility heuristics based on the
    // executable basename. Test names such as "...dispatch..." contain
    // "patch", which can make the exact same binary fail to launch normally.
    // Run through a fresh neutral filename on each attempt to avoid transient
    // Windows file-visibility and file-lock races immediately after build.
    let mut copy_attempt = launch_attempt
    while copy_attempt < launch_attempt + 16 then {
        let launch_path = output_dir.join("run-" + copy_attempt.to_string() + ".exe")
        if path_exist(launch_path) then {
            copy_attempt += 1
            continue
        }
        when copy_file(exe_path, to: launch_path) in {
            .Ok(_) then {
                sleep(100ms)
                return Result[Path].Ok(launch_path)
            },
            .Error(e) then {
                if path_exist(launch_path) then {
                    copy_attempt += 1
                    continue
                }
                return Result[Path].Error(e)
            },
        }
    }

    return Result[Path].Error(box("failed to create launch executable copy"))
}

private let run_command_args_for_case() List[String] = List[String].new()

private let read_text_file_or_empty(path Path) String = {
    return when read_text_file(path) in {
        .Ok(content) then content,
        .Error(_) then String.new(),
    }
}

private let has_runtime_expect_error(expect_error List[String]) Bool = {
    for line in expect_error then {
        if line.trim_ascii().starts_with("Panic:") then {
            return true
        }
    }
    return false
}

private let non_empty_lines(lines List[String]) List[String] = {
    let mut out = List[String].new()
    for line in lines then {
        if not line.is_empty() then {
            out.push(line)
        }
    }
    return out
}

private let match_exact_lines(actual List[String], expected List[String]) Pair[Bool, String] = {
    if actual.count() <> expected.count() then {
        return Pair[Bool, String](false, "line count mismatch: expected " + expected.count().to_string() + ", got " + actual.count().to_string())
    }

    for i in 0..<expected.count() then {
        if actual[i] <> expected[i] then {
            return Pair[Bool, String](false, "line " + i.to_string() + " mismatch: expected '" + expected[i] + "', got '" + actual[i] + "'")
        }
    }

    return Pair[Bool, String](true, "")
}

private let build_captured_command(
    config RunnerConfig,
    program String,
    args List[String],
    capture_root Path,
    capture_prefix String,
) Result[Command] = {
    let stdout_path = capture_root.join(capture_prefix + "_stdout.txt")
    let stderr_path = capture_root.join(capture_prefix + "_stderr.txt")
    let stdout_file = open_file(stdout_path, OpenMode.Write()) or else {
        return Result[Command].Error(box("failed to open stdout capture file: " + it.message()))
    }
    let stderr_file = open_file(stderr_path, OpenMode.Write()) or else {
        return Result[Command].Error(box("failed to open stderr capture file: " + it.message()))
    }
    return Result[Command].Ok(Command.new(program)
        .args(args)
        .set_stdout(IoRedirect.File(stdout_file))
        .set_stderr(IoRedirect.File(stderr_file)))
}

/// Execute a command with a timeout using synchronous polling.
/// Uses try_wait() in a loop instead of async watchdog to avoid codegen bugs
/// with when-expression branches and AtomicBool.load().
private let execute_command_with_timeout(
    config RunnerConfig,
    program String,
    args List[String],
    capture_root Path,
    capture_prefix String,
    start MonoTime,
    timeout_secs Int64,
    spawn_error_prefix String,
) CommandExecution = {
    let stdout_path = capture_root.join(capture_prefix + "_stdout.txt")
    let stderr_path = capture_root.join(capture_prefix + "_stderr.txt")
    let cmd = build_captured_command(config, program, args, capture_root, capture_prefix) or else {
            return .InfrastructureError(spawn_error_prefix + ": " + it.message())
        }
    let proc = cmd.spawn() or else {
            return .InfrastructureError(spawn_error_prefix + ": " + it.message())
        }

    let pid = proc.pid()
    let poll_sleep = Duration.new(seconds: 0, nanoseconds: 100_000_000).unwrap()
    let mut did_timeout = false
    let mut exit_code = -1
    let mut exit_signal = 0

    // Synchronous polling loop
    let mut finished = false
    while not finished then {
        let try_result = proc.try_wait()
        let mut found_exit = false
        when try_result in {
            .Ok(opt) then {
                when opt in {
                    .Some(status) then {
                        exit_code = infer_exit_code(status)
                        exit_signal = when status.signal() in { .Some(s) then s, .None then 0 }
                        found_exit = true
                    },
                    .None then {},
                }
            },
            .Error(_) then {
                found_exit = true
            },
        }
        if found_exit then {
            finished = true
        } else if start.elapsed().as_seconds() >= timeout_secs then {
            did_timeout = true
            let _ = kill_process(pid)
            let wait_after_kill = proc.wait()
            when wait_after_kill in {
                .Ok(status) then {
                    exit_code = infer_exit_code(status)
                    exit_signal = when status.signal() in { .Some(s) then s, .None then 0 }
                },
                .Error(_) then {},
            }
            finished = true
        } else {
            sleep(poll_sleep)
        }
    }

    let stdout_content = read_text_file_or_empty(stdout_path)
    let stderr_content = read_text_file_or_empty(stderr_path)

    let status = if exit_signal > 0 then ExitStatus.from_signal(exit_signal) else ExitStatus.from_code(exit_code)
    if did_timeout then {
        return .TimedOut(exit_code)
    } else {
        return .Finished(CommandOutput(status, stdout_content, stderr_content))
    }
}

private let execute_built_executable_with_retry(
    config RunnerConfig,
    info CaseInfo,
    output_dir Path,
    capture_root Path,
    start MonoTime,
    timeout_secs Int64,
) CommandExecution = {
    let first_program = prepared_run_executable_path(info, output_dir, 0(UInt)) or else {
        return .InfrastructureError("failed to prepare built executable: " + it.message())
    }
    let first = execute_command_with_timeout(
        config,
        first_program.to_string(),
        run_command_args_for_case(),
        capture_root,
        "run",
        start,
        timeout_secs,
        "failed to spawn built executable",
    )
    let is_infra_err = when first in {
        .InfrastructureError(_) then true,
        _ then false,
    }
    if is_infra_err then {
        sleep(100ms)
        let second_program = prepared_run_executable_path(info, output_dir, 1(UInt)) or else {
            return .InfrastructureError("failed to prepare built executable: " + it.message())
        }
        let second = execute_command_with_timeout(
            config,
            second_program.to_string(),
            run_command_args_for_case(),
            capture_root,
            "run",
            start,
            timeout_secs,
            "failed to spawn built executable",
        )
        let is_infra_err_2 = when second in {
            .InfrastructureError(_) then true,
            _ then false,
        }
        if is_infra_err_2 then {
            sleep(150ms)
            let third_program = prepared_run_executable_path(info, output_dir, 2(UInt)) or else {
                return .InfrastructureError("failed to prepare built executable: " + it.message())
            }
            return execute_command_with_timeout(
                config,
                third_program.to_string(),
                run_command_args_for_case(),
                capture_root,
                "run",
                start,
                timeout_secs,
                "failed to spawn built executable",
            )
        } else {
            return second
        }
    } else {
        return first
    }
}

private let create_case_output_dir(config RunnerConfig, info CaseInfo) Result[Path] = {
    let root = config.output_root
    when create_dir_all(root) in {
        .Ok(_) then {},
        .Error(e) then {
            return Result[Path].Error(e)
        },
    }

    let case_stem = info.relative_path
        .replace_all("\\", with: "/")
        .replace_all("/", with: "__")
        .replace_all(".koral", with: "")
    let case_root = root.join(case_stem)
    when create_dir_all(case_root) in {
        .Ok(_) then {},
        .Error(e) then {
            return Result[Path].Error(e)
        },
    }

    let mut attempt UInt = 0
    while attempt < 4096 then {
        let candidate = case_root.join(attempt.to_string())
        when create_dir(candidate) in {
            .Ok(_) then {
                return Result[Path].Ok(candidate)
            },
            .Error(e) then {
                if path_exist(candidate) then {
                    attempt += 1
                } else {
                    return Result[Path].Error(e)
                }
            },
        }
    }

    return Result[Path].Error(box("failed to create unique temp output dir"))
}

public let run_single_case(config RunnerConfig, info CaseInfo) CaseResult = {
    let start = MonoTime.now()
    let timeout_secs = config.timeout_secs(Int64)

    let expectations = parse_expectations(info.absolute_path) or else {
        let duration_ms = start.elapsed().as_milliseconds()
        return failure_result(
            info,
            "failed",
            "infrastructure_error",
            "failed to parse expectations: \(it.message())",
            -1,
            duration_ms,
        )
    }

    let temp_output_dir = create_case_output_dir(config, info) or else {
        let duration_ms = start.elapsed().as_milliseconds()
        return failure_result(
            info,
            "failed",
            "infrastructure_error",
            "failed to create temp output dir: \(it.message())",
            -1,
            duration_ms,
        )
    }

    let mut active_output_dir = temp_output_dir

    let check_only_expect_error = expectations.expect_error.count() > 0
        and expectations.expect_output.is_empty()
        and expectations.expect_exact_output.is_empty()
        and not has_runtime_expect_error(expectations.expect_error)

    let mut build_args = when if check_only_expect_error
        then check_command_args_for_case(config, info, active_output_dir)
        else build_command_args_for_case(config, info, active_output_dir) in {
        .Ok(args) then args,
        .Error(err) then {
            let duration_ms = start.elapsed().as_milliseconds()
            return failure_result(
                info,
                "failed",
                "infrastructure_error",
                "failed to prepare compiler arguments: \(err.message())",
                -1,
                duration_ms,
            )
        },
    }
    let mut compile_command_name = if check_only_expect_error then "check" else "build"

    if config.verbose then {
        println("RUN \(info.relative_path)")
        println("  cmd: \(config.compiler_bin.to_string()) \(build_args.join_to_string(" "))")
    }

    let build_exec = execute_command_with_timeout(
        config,
        config.compiler_bin.to_string(),
        build_args,
        active_output_dir,
        compile_command_name,
        start,
        timeout_secs,
        "failed to spawn compiler",
    )
    let mut build_output = when build_exec in {
        .Finished(output) then output,
        .TimedOut(exit_code) then {
            let duration_ms = start.elapsed().as_milliseconds()
            return failure_result(
                info,
                "timed_out",
                "timeout",
                "case timed out after \(config.timeout_secs) seconds",
                exit_code,
                duration_ms,
            )
        },
        .InfrastructureError(message) then {
            let duration_ms = start.elapsed().as_milliseconds()
            return failure_result(
                info,
                "failed",
                "infrastructure_error",
                message,
                -1,
                duration_ms,
            )
        },
    }

    let mut build_combined = normalize_output(build_output.stdout + build_output.stderr)
    let mut build_lines = output_lines_trimmed(build_combined)
    let mut build_exit_code = infer_exit_code(build_output.status)
    let duration_ms = start.elapsed().as_milliseconds()

    if expectations.expect_error.is_empty() and build_exit_code <> 0 and build_combined.is_empty() then {
        let retry_output_dir = create_case_output_dir(config, info) or else {
            return failure_result(
                info,
                "failed",
                "infrastructure_error",
                "failed to create retry temp output dir: \(it.message())",
                build_exit_code,
                duration_ms,
            )
        }

        active_output_dir = retry_output_dir
        build_args = build_command_args_for_case(config, info, active_output_dir) or else {
            let duration_ms = start.elapsed().as_milliseconds()
            return failure_result(
                info,
                "failed",
                "infrastructure_error",
                "failed to prepare retry compiler arguments: \(it.message())",
                build_exit_code,
                duration_ms,
            )
        }
        compile_command_name = "build"

        let retry_exec = execute_command_with_timeout(
            config,
            config.compiler_bin.to_string(),
            build_args,
            active_output_dir,
            compile_command_name,
            start,
            timeout_secs,
            "failed to spawn compiler",
        )
        build_output = when retry_exec in {
            .Finished(output) then output,
            .TimedOut(exit_code) then {
                let current_duration_ms = start.elapsed().as_milliseconds()
                return failure_result(
                    info,
                    "timed_out",
                    "timeout",
                    "case timed out after \(config.timeout_secs) seconds",
                    exit_code,
                    current_duration_ms,
                )
            },
            .InfrastructureError(message) then {
                let current_duration_ms = start.elapsed().as_milliseconds()
                return failure_result(
                    info,
                    "failed",
                    "infrastructure_error",
                    message,
                    build_exit_code,
                    current_duration_ms,
                )
            },
        }

        build_combined = normalize_output(build_output.stdout + build_output.stderr)
        build_lines = output_lines_trimmed(build_combined)
        build_exit_code = infer_exit_code(build_output.status)
    }

    if expectations.expect_error.count() > 0 then {
        if build_exit_code <> 0 then {
            if expectations.expected_exit is .Some(expected_exit) and expected_exit <> build_exit_code then {
                return failure_result(
                    info,
                    "failed",
                    "unexpected_exit",
                    "expected exit code \(expected_exit), got \(build_exit_code)",
                    build_exit_code,
                    duration_ms,
                )
            }

            let match_result = match_expectations_in_order(build_lines, expectations.expect_error)
            if not match_result.first then {
                return failure_result(
                    info,
                    "failed",
                    "missing_expected_error",
                    "missing expected error: \(match_result.second)",
                    build_exit_code,
                    duration_ms,
                )
            }

            return pass_result(info, duration_ms, build_exit_code)
        }

        let run_exec_result = execute_built_executable_with_retry(
            config,
            info,
            active_output_dir,
            active_output_dir,
            start,
            timeout_secs,
        )
        let run_output = when run_exec_result in {
            .Finished(output) then output,
            .TimedOut(exit_code) then {
                let current_duration_ms = start.elapsed().as_milliseconds()
                return failure_result(
                    info,
                    "timed_out",
                    "timeout",
                    "case timed out after \(config.timeout_secs) seconds",
                    exit_code,
                    current_duration_ms,
                )
            },
            .InfrastructureError(message) then {
                let current_duration_ms = start.elapsed().as_milliseconds()
                return failure_result(
                    info,
                    "failed",
                    "infrastructure_error",
                    message,
                    build_exit_code,
                    current_duration_ms,
                )
            },
        }

        let run_combined = normalize_output(run_output.stdout + run_output.stderr)
        let run_lines = output_lines_trimmed(run_combined)
        let run_exit_code = infer_exit_code(run_output.status)
        let total_duration_ms = start.elapsed().as_milliseconds()

        if expectations.expected_exit is .Some(expected_exit) then {
            if run_exit_code <> expected_exit then {
                return failure_result(
                    info,
                    "failed",
                    "unexpected_exit",
                    "expected exit code \(expected_exit), got \(run_exit_code)",
                    run_exit_code,
                    total_duration_ms,
                )
            }
        } else {
            if run_exit_code == 0 then {
                return failure_result(
                    info,
                    "failed",
                    "unexpected_success",
                    "expected non-zero exit code for EXPECT-ERROR case",
                    run_exit_code,
                    total_duration_ms,
                )
            }
        }

        let match_result = match_expectations_in_order(run_lines, expectations.expect_error)
        if not match_result.first then {
            return failure_result(
                info,
                "failed",
                "missing_expected_error",
                "missing expected error: \(match_result.second)",
                run_exit_code,
                total_duration_ms,
            )
        }

        return pass_result(info, total_duration_ms, run_exit_code)
    }

    if build_exit_code <> 0 then {
        return failure_result(
            info,
            "failed",
            "unexpected_nonzero_exit",
            "compiler build exited with non-zero status",
            build_exit_code,
            duration_ms,
        )
    }

    if expectations.expect_output.is_empty() and expectations.expect_exact_output.is_empty() and expectations.expected_exit is .None() then {
        return pass_result(info, duration_ms, build_exit_code)
    }

    let run_exec_result2 = execute_built_executable_with_retry(
        config,
        info,
        active_output_dir,
        active_output_dir,
        start,
        timeout_secs,
    )
    let run_output = when run_exec_result2 in {
        .Finished(output) then output,
        .TimedOut(exit_code) then {
            let current_duration_ms = start.elapsed().as_milliseconds()
            return failure_result(
                info,
                "timed_out",
                "timeout",
                "case timed out after \(config.timeout_secs) seconds",
                exit_code,
                current_duration_ms,
            )
        },
        .InfrastructureError(message) then {
            let current_duration_ms = start.elapsed().as_milliseconds()
            return failure_result(
                info,
                "failed",
                "infrastructure_error",
                message,
                build_exit_code,
                current_duration_ms,
            )
        },
    }

    let run_combined = normalize_output(run_output.stdout + run_output.stderr)
    let run_lines = output_lines_trimmed(run_combined)
    let run_exit_code = infer_exit_code(run_output.status)
    let total_duration_ms = start.elapsed().as_milliseconds()

    if expectations.expected_exit is .Some(expected_exit) and run_exit_code <> expected_exit then {
        return failure_result(
            info,
            "failed",
            "unexpected_exit",
            "expected exit code \(expected_exit), got \(run_exit_code)",
            run_exit_code,
            total_duration_ms,
        )
    }

    if expectations.expected_exit is .None() and run_exit_code <> 0 then {
        return failure_result(
            info,
            "failed",
            "unexpected_nonzero_exit",
            "expected exit code 0, got \(run_exit_code)",
            run_exit_code,
            total_duration_ms,
        )
    }

    if expectations.expect_exact_output.count() > 0 then {
        let exact_match = match_exact_lines(non_empty_lines(run_lines), expectations.expect_exact_output)
        if not exact_match.first then {
            return failure_result(
                info,
                "failed",
                "unexpected_exact_output",
                exact_match.second,
                run_exit_code,
                total_duration_ms,
            )
        }
    }

    let match_result = match_expectations_in_order(run_lines, expectations.expect_output)
    if not match_result.first then {
        return failure_result(
            info,
            "failed",
            "missing_expected_output",
            "missing expected output: \(match_result.second)",
            run_exit_code,
            total_duration_ms,
        )
    }

    return pass_result(info, total_duration_ms, run_exit_code)
}
