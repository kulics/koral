using std { .. }
using std::os { .. }

private let is_windows_host() Bool =
    if env("OS") is .Some(os) then os.contains("Windows") else false

private let default_bootstrap_koralc_path() Path = {
    if is_windows_host() then {
        return "bin/bootstrap/koralc.exe".into_path()
    }
    return "bin/bootstrap/koralc".into_path()
}

private let default_swift_koralc_path() Path = {
    if is_windows_host() then {
        return "compiler/.build/debug/koralc.exe".into_path()
    }
    return "compiler/.build/debug/koralc".into_path()
}

private let parse_uint(value String, flag_name String) Result[UInt] = {
    return when UInt.parse(value) in {
        .Ok(v) then Result[UInt].Ok(v),
        .Error(_) then Result[UInt].Error(box("invalid value for \(flag_name): \(value)")),
    }
}

private let parse_int(value String, flag_name String) Result[Int] = {
    return when Int.parse(value) in {
        .Ok(v) then Result[Int].Ok(v),
        .Error(_) then Result[Int].Error(box("invalid value for \(flag_name): \(value)")),
    }
}

private let make_absolute(base Path, path Path) Path = {
    return if path.is_absolute() then path else base.join(path.to_string()).normalize()
}

private let default_output_root(run_root Path) Path = {
    return run_root.join("tests/compiler-cases_output").normalize()
}

public let print_usage() Void =
    eprintln("""
        compiler test runner
        usage: compiler-test-runner [options]
        options:
          --cases <dir>                cases root (default: tests/compiler-cases)
          --compiler <kind>            compiler kind: bootstrap|swift|custom (default: bootstrap)
          --filter <substring>         run only matching case name/path
          -j <N> | -j=<N>              parallel workers (default: 1)
          --timeout <sec>              per-case timeout seconds (default: 120)
          --compiler-bin <path>        compiler executable path when --compiler custom
          --bootstrap-koralc <path>    bootstrap compiler executable path
          --swift-koralc <path>        swift compiler executable path
          --report-file <path>         write stable summary log (default: tests/compiler-cases_output/_reports/latest-summary.log)
          --verbose                    print verbose case command logs
          -h, --help                   show this help
        """)

public let parse_runner_config() Result[RunnerConfig] = {
    let argv = args()

    let run_root = current_dir() or else {
        return Result[RunnerConfig].Error(box("failed to determine current working directory: " + it.message()))
    }
    let mut cases_root = "tests/compiler-cases".into_path()
    let mut filter = Option[String].None()
    let mut jobs UInt = 1
    let mut timeout_secs Int = 120
    let mut compiler_kind = "bootstrap"
    let mut compiler_bin_opt = Option[Path].None()
    let mut bootstrap_koralc = default_bootstrap_koralc_path()
    let mut swift_koralc = default_swift_koralc_path()
    let mut report_file_opt = Option[Path].None()
    let mut verbose = false

    let mut i UInt = 1
    while i < argv.count() then {
        let arg = argv[i]

        if arg == "-h" or arg == "--help" then {
            return Result[RunnerConfig].Error(box("__HELP__"))
        }

        if arg == "--verbose" then {
            verbose = true
            i += 1
            continue
        }

        if arg == "--compiler" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --compiler"))
            }
            let value = argv[i]
            if value <> "bootstrap" and value <> "swift" and value <> "custom" then {
                return Result[RunnerConfig].Error(box("invalid value for --compiler: " + value))
            }
            compiler_kind = value
            i += 1
            continue
        }

        if arg == "--cases" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --cases"))
            }
            cases_root = argv[i].into_path()
            i += 1
            continue
        }

        if arg == "--filter" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --filter"))
            }
            filter = Option[String].Some(argv[i])
            i += 1
            continue
        }

        if arg == "--timeout" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --timeout"))
            }
            timeout_secs = parse_int(argv[i], "--timeout") or else {
                return Result[RunnerConfig].Error(it)
            }
            if timeout_secs <= 0 then {
                return Result[RunnerConfig].Error(box("--timeout must be > 0"))
            }
            i += 1
            continue
        }

        if arg == "--bootstrap-koralc" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --bootstrap-koralc"))
            }
            bootstrap_koralc = argv[i].into_path()
            i += 1
            continue
        }

        if arg == "--swift-koralc" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --swift-koralc"))
            }
            swift_koralc = argv[i].into_path()
            i += 1
            continue
        }

        if arg == "--compiler-bin" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --compiler-bin"))
            }
            compiler_bin_opt = Option[Path].Some(argv[i].into_path())
            i += 1
            continue
        }

        if arg == "--report-file" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for --report-file"))
            }
            report_file_opt = Option[Path].Some(argv[i].into_path())
            i += 1
            continue
        }

        if arg == "-j" then {
            i += 1
            if i >= argv.count() then {
                return Result[RunnerConfig].Error(box("missing value for -j"))
            }
            jobs = parse_uint(argv[i], "-j") or else {
                return Result[RunnerConfig].Error(it)
            }
            if jobs == 0 then {
                return Result[RunnerConfig].Error(box("-j must be >= 1"))
            }
            i += 1
            continue
        }

        if arg.starts_with("-j=") then {
            jobs = parse_uint(arg.trim_prefix("-j="), "-j") or else {
                return Result[RunnerConfig].Error(it)
            }
            if jobs == 0 then {
                return Result[RunnerConfig].Error(box("-j must be >= 1"))
            }
            i += 1
            continue
        }

        return Result[RunnerConfig].Error(box("unknown argument: \(arg)"))
    }

    let abs_cases_root = make_absolute(run_root, cases_root)
    let abs_bootstrap_koralc = make_absolute(run_root, bootstrap_koralc)
    let abs_swift_koralc = make_absolute(run_root, swift_koralc)
    let output_root = default_output_root(run_root)
    let default_report_file = output_root.join("_reports").join("latest-summary.log").normalize()
    let report_file = when report_file_opt in {
        .Some(path) then make_absolute(run_root, path).normalize(),
        .None() then default_report_file,
    }

    let compiler_bin = when compiler_kind in {
        "bootstrap" then abs_bootstrap_koralc,
        "swift" then abs_swift_koralc,
        "custom" then when compiler_bin_opt in {
            .Some(path) then make_absolute(run_root, path).normalize(),
            .None() then {
                return Result[RunnerConfig].Error(box("--compiler-bin is required when --compiler custom"))
            },
        },
        _ then {
            return Result[RunnerConfig].Error(box("invalid compiler kind: " + compiler_kind))
        },
    }

    return Result[RunnerConfig].Ok(RunnerConfig(
        run_root,
        abs_cases_root,
        output_root,
        report_file,
        filter,
        jobs,
        timeout_secs,
        compiler_kind,
        compiler_bin,
        abs_bootstrap_koralc,
        abs_swift_koralc,
        verbose
    ))
}
