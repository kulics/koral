using std::os { .. }

public let normalize_output(raw String) String = {
    let lf = raw.replace_all("\r\n", with: "\n")
    return lf.replace_all("\r", with: "\n")
}

public let output_lines_trimmed(output String) List[String] = {
    let mut lines = List[String].new()
    for line in output.lines() then {
        lines.push(line.trim_ascii())
    }
    return lines
}

public let parse_expectations(case_path Path) Result[ExpectationSet] = {
    let content = read_text_file(case_path) or else {
        return Result[ExpectationSet].Error(it)
    }

    let mut expected_output = List[String].new()
    let mut expected_exact_output = List[String].new()
    let mut expected_error = List[String].new()
    let mut expected_exit = Option[Int].None()

    for line in content.lines() then {
        let trimmed = line.trim_ascii()
        if trimmed.starts_with("// EXPECT-EXACT: ") then {
            let want = trimmed.trim_prefix("// EXPECT-EXACT: ").trim_ascii()
            expected_exact_output.push(want)
        } else if trimmed.starts_with("// EXPECT_EXACT: ") then {
            let want = trimmed.trim_prefix("// EXPECT_EXACT: ").trim_ascii()
            expected_exact_output.push(want)
        } else if trimmed.starts_with("// EXPECT EXACT: ") then {
            let want = trimmed.trim_prefix("// EXPECT EXACT: ").trim_ascii()
            expected_exact_output.push(want)
        } else if trimmed.starts_with("// EXPECT: ") then {
            let want = trimmed.trim_prefix("// EXPECT: ").trim_ascii()
            expected_output.push(want)
        } else if trimmed.starts_with("// EXPECT-ERROR: ") then {
            let want = trimmed.trim_prefix("// EXPECT-ERROR: ").trim_ascii()
            expected_error.push(want)
        } else if trimmed.starts_with("// EXPECT_ERROR: ") then {
            let want = trimmed.trim_prefix("// EXPECT_ERROR: ").trim_ascii()
            expected_error.push(want)
        } else if trimmed.starts_with("// EXPECT ERROR: ") then {
            let want = trimmed.trim_prefix("// EXPECT ERROR: ").trim_ascii()
            expected_error.push(want)
        } else if trimmed.starts_with("// EXIT: ") then {
            let text = trimmed.trim_prefix("// EXIT: ").trim_ascii()
            let parsed = Int.parse(text) or else {
                return Result[ExpectationSet].Error(box("invalid // EXIT value in " + case_path.to_string() + ": " + text))
            }
            expected_exit = Option[Int].Some(parsed)
        }
    }

    return Result[ExpectationSet].Ok(ExpectationSet(expected_output, expected_exact_output, expected_error, expected_exit))
}

public let match_expectations_in_order(lines List[String], expected List[String]) Pair[Bool, String] = {
    let mut current UInt = 0

    for i in 0..<expected.count() then {
        let want = expected[i].trim_ascii()
        if want.is_empty() then {
            continue
        }

        let mut found = false
        for j in current..<lines.count() then {
            if lines[j].contains(want) then {
                found = true
                current = j + 1
                break
            }
        }

        if not found then {
            return Pair[Bool, String](false, want)
        }
    }

    return Pair[Bool, String](true, "")
}
