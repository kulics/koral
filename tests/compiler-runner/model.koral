using Std.Os.*

public type RunnerConfig(
    run_root Path,
    cases_root Path,
    output_root Path,
    report_file Path,
    filter Option[String],
    jobs UInt,
    timeout_secs Int,
    compiler_kind String,
    compiler_bin Path,
    bootstrap_koralc Path,
    swift_koralc Path,
    verbose Bool,
)

public type CaseInfo(
    name String,
    relative_path String,
    absolute_path Path,
    group_key String,
)

given CaseInfo as Eq {

    public equals(self, other CaseInfo) Bool = self.relative_path == other.relative_path
}

given CaseInfo as Ord {

    public compare(self, other CaseInfo) Int = self.relative_path.compare(other.relative_path)
}

public type ExpectationSet(
    expect_output List[String],
    expect_exact_output List[String],
    expect_error List[String],
    expected_exit Option[Int],
)

public type CaseResult(
    case_info CaseInfo,
    passed Bool,
    status String,
    failure_type String,
    failure_message String,
    exit_code Int,
    duration_ms Int64,
)

given CaseResult as Eq {

    public equals(self, other CaseResult) Bool = self.case_info == other.case_info
}

given CaseResult as Ord {

    public compare(self, other CaseResult) Int = self.case_info.compare(other.case_info)
}

public type RunSummary(
    total UInt,
    passed UInt,
    failed UInt,
    timed_out UInt,
    infra_failed UInt,
    duration_ms Int64,
    exit_code Int,
)
