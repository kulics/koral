using std { .. }
using std::async { .. }
using std::os { .. }
using std::rand { .. }
using std::sync { .. }
using std::time { .. }

private type CaseWorkerEvent {
    Started(info CaseInfo),
    Finished(result CaseResult),
}

private let finalize_summary(total UInt, passed UInt, failed UInt, timed_out UInt, infra_failed UInt, start MonoTime) RunSummary = {
    let duration_ms = start.elapsed().as_milliseconds()
    let exit_code = if failed == 0 then 0 else 1
    return RunSummary(total, passed, failed, timed_out, infra_failed, duration_ms, exit_code)
}

private let run_cases_serial(config RunnerConfig, cases List[CaseInfo]) RunSummary = {
    let start = MonoTime.now()
    let total = cases.count()
    let mut passed UInt = 0
    let mut failed UInt = 0
    let mut timed_out UInt = 0
    let mut infra_failed UInt = 0

    for i in 0..<total then {
        print_case_started(config, i + 1, total, cases[i])
        let result = run_single_case(config, cases[i])
        print_case_result(config, i + 1, total, result)
        if result.passed then {
            passed += 1
        } else {
            failed += 1
            if result.failure_type == "timeout" then {
                timed_out += 1
            }
            if result.failure_type == "infrastructure_error" then {
                infra_failed += 1
            }
        }
    }

    return finalize_summary(total, passed, failed, timed_out, infra_failed, start)
}

private let run_case_and_emit_events(config RunnerConfig, info CaseInfo, sender SendChannel[CaseWorkerEvent]) Void = {
    let _ = sender.send(.Started(info))
    let result = run_single_case(config, info)
    let _ = sender.send(.Finished(result))
}

private let run_case_with_group_lock(
    config RunnerConfig,
    info CaseInfo,
    sync_lock Mutex,
    net_lock Mutex,
    env_lock Mutex,
    sender SendChannel[CaseWorkerEvent],
) Void = {
    when info.group_key in {
        "sync" then {
            sync_lock.lock()
            run_case_and_emit_events(config, info, sender)
            sync_lock.unlock()
        },
        "net" then {
            net_lock.lock()
            run_case_and_emit_events(config, info, sender)
            net_lock.unlock()
        },
        "env" then {
            env_lock.lock()
            run_case_and_emit_events(config, info, sender)
            env_lock.unlock()
        },
        _ then run_case_and_emit_events(config, info, sender),
    }
}

private let run_cases_parallel(config RunnerConfig, cases List[CaseInfo]) RunSummary = {
    let start = MonoTime.now()
    let total = cases.count()
    if total == 0 then {
        return finalize_summary(0, 0, 0, 0, 0, start)
    }

    let worker_count = min(config.jobs, total)
    let mut shuffled_cases = cases
    let random = default_random()
    random.shuffle(shuffled_cases.ref)

    let next_index = AtomicInt.new(0)
    let channels = make_channel[CaseWorkerEvent](total + total)
    let sender = channels.first
    let receiver = channels.second
    let sync_lock = Mutex.new()
    let net_lock = Mutex.new()
    let env_lock = Mutex.new()
    let mut started UInt = 0
    let mut received UInt = 0
    let mut passed UInt = 0
    let mut failed UInt = 0
    let mut timed_out UInt = 0
    let mut infra_failed UInt = 0

    for _ in 0..<worker_count then {
        let shared_sender = sender
        let shared_cases = shuffled_cases
        let shared_config = config
        let shared_index = next_index
        let shared_sync_lock = sync_lock
        let shared_net_lock = net_lock
        let shared_env_lock = env_lock

        let _ = run_task(() -> {
            while true then {
                let idx = shared_index.fetch_add(1)
                if idx < 0 or idx(UInt) >= shared_cases.count() then {
                    break
                }

                let case_info = shared_cases[idx(UInt)]
                run_case_with_group_lock(shared_config, case_info, shared_sync_lock, shared_net_lock, shared_env_lock, shared_sender)
            }
        })
    }

    while received < total then {
        when receiver.recv() in {
            .Ok(event) then {
                when event in {
                    .Started(info) then {
                        started += 1
                        print_case_started(config, started, total, info)
                    },
                    .Finished(result) then {
                        print_case_result(config, received + 1, total, result)
                        if result.passed then {
                            passed += 1
                        } else {
                            failed += 1
                            if result.failure_type == "timeout" then {
                                timed_out += 1
                            }
                            if result.failure_type == "infrastructure_error" then {
                                infra_failed += 1
                            }
                        }
                        received += 1
                    },
                }
            },
            .Error(_) then {
                break
            },
        }
    }

    return finalize_summary(total, passed, failed, timed_out, infra_failed, start)
}

public let run_cases(config RunnerConfig, cases List[CaseInfo]) RunSummary = {
    if cases.is_empty() then {
        report_error_line(config, "No test cases matched current filter")
        return RunSummary(0, 0, 1, 0, 0, 0, 1)
    }

    report_line(config, "Running " + cases.count().to_string() + " case(s) with jobs=" + config.jobs.to_string())

    let summary = if config.jobs <= 1 then
        run_cases_serial(config, cases)
    else
        run_cases_parallel(config, cases)

    print_summary(config, summary)
    return summary
}
