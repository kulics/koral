let count_some_twice(value Option[String]) Int = {
    let mut total = 0
    let mut index = 0
    while index < 2 then {
        total += when value in {
            .Some(_) then 1,
            .None() then 0,
        }
        index += 1
    }
    return total
}

let main() Void = {
    assert(count_some_twice(Option[String].Some("x")) == 2, "when subject must not consume lvalue parameters")
    println("ok")
}

// EXPECT: ok
