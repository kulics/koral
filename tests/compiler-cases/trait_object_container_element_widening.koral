// EXPECT: 13

trait CounterOps {
    peek(self ref) Int
}

type Counter(value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let main() Int = {
    let mut items = List[ref CounterOps].new()
    let strong ref mut Counter = box(Counter(13))
    items.push(strong)
    let first = items[0]
    println(first.peek().to_string())
    return 0
}