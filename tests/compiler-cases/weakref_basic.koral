// EXPECT: WeakRef Basic Test:
// EXPECT: Strong ref unique mutable: true
// EXPECT: After downgrade, unique mutable: true
// EXPECT: Upgrade succeeded: true
// EXPECT: Upgraded value: 42
// EXPECT: Test passed!

let testWeakRefBasic() Int = {
    // Create a strong reference
    let strongRef ref Int = box(42)
    
    println("WeakRef Basic Test:")
    
    // Check initial ref count
    let unique1 = is_unique_mutable(strongRef.ptr)
    print("Strong ref unique mutable: ")
    println(unique1)
    
    // Downgrade to weak reference
    let weakRef weakref Int = strongRef.weakref
    
    // Strong count should still be 1
    let unique2 = is_unique_mutable(strongRef.ptr)
    print("After downgrade, unique mutable: ")
    println(unique2)
    
    // Upgrade weak reference back to strong
    let upgraded_opt = weakRef.to_ref()
    when upgraded_opt in {
        .Some(upgraded) then {
            println("Upgrade succeeded: true")
            print("Upgraded value: ")
            println(upgraded.val)
        },
        .None then {
            println("Upgrade succeeded: false")
        },
    }
    
    println("Test passed!")
    return 0
}

let main() Int = {
    testWeakRefBasic()
    return 0
}
