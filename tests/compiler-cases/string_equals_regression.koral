// EXPECT: string equals regression passed

using std::text { .. }

let main() Void = {
    let pattern = "(\\w+)@(\\w+)"
    assert(pattern == "(\\w+)@(\\w+)", "string equality should terminate and compare correctly")

    let regex = Regex.compile(pattern).expect("compile regex")
    assert(regex.pattern() == pattern, "regex pattern roundtrip")

    println("string equals regression passed")
}
