// EXPECT: 42
// EXPECT: hello

// Test that a `self ref mut` receiver can call methods declared with `self ref`.
// This is the method-dispatch variant of ref mut → ref widening.

type Counter(mut value Int)

given Counter {

    // Method taking self ref (read-only)
    read(self ref) Int = self.value

    // Method taking self ref mut (mutable)
    increment(self ref mut) Void = {
        self.value = self.value + 1
    }

    // ref mut method that calls a ref method on self
    read_via_mut(self ref mut) Int = self.read()
}

type Printer(mut buffer ref String)

given Printer {

    // ref method
    get_buffer(self ref) String = self.buffer.to_string()

    // ref mut method that calls ref method on self
    print_buffer(self ref mut) Void = {
        println(self.get_buffer())
    }
}

let main() Void = {
    let mut c = Counter(41)
    c.increment()
    // Call ref method on ref mut receiver directly
    println(c.read().to_string())

    let p ref mut Printer = box(Printer(box("hello")))
    // ref mut method internally calls ref method
    p.print_buffer()
}
