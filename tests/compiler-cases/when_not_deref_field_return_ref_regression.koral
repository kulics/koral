// EXPECT: ok

type Kind {
    A(),
    B(),
}

given Kind not Deref

type Expr(kind Kind ref)

let clone_kind(expr Expr ref) Kind ref = when expr.kind in {
    .A() then box(Kind.A()),
    .B() then box(Kind.B()),
}

let classify(kind Kind ref) Int = when kind in {
    .A() then 1,
    .B() then 2,
}

let main() Void = {
    let kind_a Kind mut ref = box(Kind.A())
    let kind_b Kind mut ref = box(Kind.B())
    let expr_a = Expr(kind_a)
    let expr_b = Expr(kind_b)
    assert(classify(clone_kind(expr_a)) == 1, "A branch should clone to ref")
    assert(classify(clone_kind(expr_b)) == 2, "B branch should clone to ref")
    println("ok")
}
