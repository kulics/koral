// EXPECT: memberexpr_owned_field_copy_regression_ok

using Std.*

type Holder(items [String]List)

given Holder {
    first(self) String = self.items[0]

    second(self) String = self.items[1]

    item_count(self) UInt = self.items.count()
}

let main() Int = {
    let mut items = [String]List.new()
    items.push("alpha")
    items.push("beta")

    let holder = Holder(items)

    assert(holder.item_count() == 2, "count before")
    assert(holder.first() == "alpha", "first")
    assert(holder.second() == "beta", "second")
    assert(holder.item_count() == 2, "count after")
    assert(holder.first() == "alpha", "first again")

    println("memberexpr_owned_field_copy_regression_ok")
    yield 0
}
