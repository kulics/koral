// EXPECT: All Set tests passed

let main() Int = {
    // === Basic Operations ===
    let mut s = Set[Int].new()
    assert(s.count() == 0, "new set count 0")
    assert(s.is_empty(), "new set is_empty")

    // === insert ===
    s.insert(1)
    assert(s.count() == 1, "count after insert")
    assert(not s.is_empty(), "not empty")

    s.insert(2);
    s.insert(3);
    assert(s.count() == 3, "count 3")

    // === try_insert ===
    assert(not s.try_insert(1), "try_insert duplicate returns false")
    assert(s.try_insert(4), "try_insert new returns true")
    assert(s.count() == 4, "count after try_insert")

    // === contains ===
    assert(s.contains(1), "contains 1")
    assert(s.contains(2), "contains 2")
    assert(not s.contains(999), "not contains 999")

    // === remove ===
    assert(s.try_remove(2), "try_remove existing")
    assert(s.count() == 3, "count after remove")
    assert(not s.contains(2), "not contains after remove")
    assert(not s.try_remove(999), "try_remove missing")
    s.remove(3)
    s.remove(999)
    assert(not s.contains(3), "remove existing")
    assert(s.count() == 2, "count after remove and try_remove")

    // === clear ===
    s.clear()
    assert(s.count() == 0, "count after clear")
    assert(s.is_empty(), "is_empty after clear")

    // === Rehash test ===
    let mut s2 = Set[Int].new()
    let mut i = 0
    while i < 50 then {
        s2.insert(i);
        i = i + 1
    }
    assert(s2.count() == 50, "count after 50 inserts")

    i = 0
    while i < 50 then {
        assert(s2.contains(i), "contains after rehash")
        i = i + 1
    }

    // === iterator ===
    let mut s3 = Set[Int].new()
    s3.insert(10);
    s3.insert(20);
    s3.insert(30);

    let mut count = 0
    let mut sum = 0
    for v in s3.iterator() then {
        count = count + 1
        sum = sum + v
    }
    assert(count == 3, "iterator count")
    assert(sum == 60, "iterator sum")

    // === Set operations ===
    let mut a = Set[Int].new()
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b = Set[Int].new()
    b.insert(2);
    b.insert(3);
    b.insert(4);

    // union
    let mut u = a.union(b.ref)
    assert(u.count() == 4, "union count")
    assert(u.contains(1) and u.contains(2) and u.contains(3) and u.contains(4), "union values")

    // intersection
    let mut inter = a.intersection(b.ref)
    assert(inter.count() == 2, "intersection count")
    assert(inter.contains(2) and inter.contains(3), "intersection values")
    assert(not inter.contains(1) and not inter.contains(4), "intersection excludes")

    // difference
    let mut diff = a.difference(b.ref)
    assert(diff.count() == 1, "difference count")
    assert(diff.contains(1), "difference value")

    // symmetric_difference
    let mut sym = a.symmetric_difference(b.ref)
    assert(sym.count() == 2, "symmetric_difference count")
    assert(sym.contains(1) and sym.contains(4), "symmetric_difference values")
    assert(not sym.contains(2) and not sym.contains(3), "symmetric_difference excludes intersection")

    // === COW (Copy-On-Write) semantics ===
    let mut original = Set[Int].new()
    original.insert(1);
    original.insert(2);

    let mut copy = original  // Shallow copy

    // Modify copy triggers COW
    copy.insert(3);
    copy.remove(1);

    // Original unchanged
    assert(original.count() == 2, "original count unchanged")
    assert(original.contains(1), "original contains 1")
    assert(not original.contains(3), "original not contains 3")

    // Copy modified
    assert(copy.count() == 2, "copy count")
    assert(not copy.contains(1), "copy not contains 1")
    assert(copy.contains(3), "copy contains 3")

    // === String set ===
    let mut ss = Set[String].new()
    ss.insert("apple");
    ss.insert("banana");
    assert(ss.contains("apple"), "string set contains")
    assert(not ss.try_insert("apple"), "string set duplicate")

    // === insert_all ===
    let mut ia1 = Set[Int].new()
    ia1.insert(1);
    ia1.insert(2);
    let mut ia2 = Set[Int].new()
    ia2.insert(2);
    ia2.insert(3);
    ia2.insert(4);
    ia1.insert_set(ia2)
    assert(ia1.count() == 4, "insert_all count")
    assert(ia1.contains(1) and ia1.contains(2) and ia1.contains(3) and ia1.contains(4), "insert_all values")

    // insert_all empty set
    let mut ia3 = Set[Int].new()
    ia3.insert(10);
    let ia_empty = Set[Int].new()
    ia3.insert_set(ia_empty)
    assert(ia3.count() == 1, "insert_all empty no change")

    // === retain ===
    let mut rs = Set[Int].new()
    rs.insert(1);
    rs.insert(2);
    rs.insert(3);
    rs.insert(4);
    rs.insert(5);
    rs.retain((x) -> x % 2 == 0)
    assert(rs.count() == 2, "retain count")
    assert(rs.contains(2) and rs.contains(4), "retain values")
    assert(not rs.contains(1) and not rs.contains(3) and not rs.contains(5), "retain removed odds")

    let mut rs_none = Set[Int].new()
    rs_none.insert(1);
    rs_none.insert(2);
    rs_none.retain((x) -> false)
    assert(rs_none.is_empty(), "retain none")

    let mut rs_all = Set[Int].new()
    rs_all.insert(1);
    rs_all.insert(2);
    rs_all.retain((x) -> true)
    assert(rs_all.count() == 2, "retain all")

    println("All Set tests passed")
    return 0
}
