// EXPECT: ok

let main() Void = {
    let mut states = Dict[UInt, UInt].new()
    states.insert(1(UInt), 7(UInt))

    let present = when states.get(1(UInt)) in {
        .Some(s) then s,
        .None() then 0,
    }
    let missing = when states.get(2(UInt)) in {
        .Some(s) then s,
        .None() then 0,
    }

    assert(present == 7, "present state")
    assert(missing == 0, "missing state")
    println("ok")
}
