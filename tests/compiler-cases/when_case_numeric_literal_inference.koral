// EXPECT: ok

let main() Void = {
    let mut states = [UInt, UInt]Dict.new()
    states.insert((UInt)1, (UInt)7)

    let present = when states.get((UInt)1) in {
        .Some(s) then s,
        .None() then 0,
    }
    let missing = when states.get((UInt)2) in {
        .Some(s) then s,
        .None() then 0,
    }

    assert(present == 7, "present state")
    assert(missing == 0, "missing state")
    println("ok")
}
