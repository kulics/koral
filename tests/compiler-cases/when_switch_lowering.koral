// EXPECT: 10
// EXPECT: 20
// EXPECT: 1
// EXPECT: 2
// EXPECT: 107
// EXPECT: 30
// EXPECT: 40

type MaybeInt {
    None(),
    Some(value Int),
    Other(extra Int),
}

let classify_num(n Int) Int = when n in {
    0 then 10,
    17 then 20,
    v then v + 1,
}

let classify_flag(flag Bool) Int = when flag in {
    true then 1,
    _ then 2,
}

let classify_union(value MaybeInt) Int = when value in {
    .Some(v) then v + 100,
    .Other(_) then 30,
    _ then 40,
}

let main() Int = {
    println(classify_num(0))
    println(classify_num(17))
    println(classify_flag(true))
    println(classify_flag(false))
    println(classify_union(MaybeInt.Some(7)))
    println(classify_union(MaybeInt.Other(9)))
    println(classify_union(MaybeInt.None()))
    yield 0
}