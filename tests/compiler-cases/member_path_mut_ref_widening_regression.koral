// EXPECT: ok

type Big(value Int)
given Big not Deref

type Holder(mut value Big ref)

let read_value(holder Holder mut ref) Big ref = holder.value

let main() Void = {
    let big Big mut ref = box(Big(7))
    let holder Holder mut ref = box(Holder(big))
    let value Big ref = read_value(holder)
    assert(value.value == 7, "mutable field ref should widen to readonly ref")
    println("ok")
}
