// EXPECT: ok

type Big(value Int)
given Big not Deref

type Holder(mut value ref Big)

let read_value(holder mut ref Holder) ref Big = holder.value

let main() Void = {
    let big mut ref Big = box(Big(7))
    let holder mut ref Holder = box(Holder(big))
    let value ref Big = read_value(holder)
    assert(value.value == 7, "mutable field ref should widen to readonly ref")
    println("ok")
}
