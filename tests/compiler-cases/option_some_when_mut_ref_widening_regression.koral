// EXPECT: ok

type Big(value Int)
given Big not Deref

type Wrapped(mut kind ref Big)

let select(flag Bool, wrapped ref mut Wrapped, fallback ref Big) Option[ref Big] = {
    let subject = if flag then Option[ref mut Wrapped].Some(wrapped) else Option[ref mut Wrapped].None()
    return Option[ref Big].Some(when subject in {
        .Some(value) then value.kind,
        .None() then fallback,
    })
}

let main() Void = {
    let big1 ref mut Big = box(Big(7))
    let big2 ref mut Big = box(Big(9))
    let wrapped ref mut Wrapped = box(Wrapped(big1))
    let selected_true = select(true, wrapped, big2)
    let selected_false = select(false, wrapped, big2)
    assert(selected_true.unwrap().value == 7, "true branch should widen ref mut to ref")
    assert(selected_false.unwrap().value == 9, "false branch should use fallback")
    println("ok")
}
