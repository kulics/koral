// EXPECT: ok

type Big(value Int)
given Big not Deref

type Wrapped(mut kind ref Big)

let select(flag Bool, wrapped mut ref Wrapped, fallback ref Big) Option[ref Big] = {
    let subject = if flag then Option[mut ref Wrapped].Some(wrapped) else Option[mut ref Wrapped].None()
    return Option[ref Big].Some(when subject in {
        .Some(value) then value.kind,
        .None() then fallback,
    })
}

let main() Void = {
    let big1 mut ref Big = box(Big(7))
    let big2 mut ref Big = box(Big(9))
    let wrapped mut ref Wrapped = box(Wrapped(big1))
    let selected_true = select(true, wrapped, big2)
    let selected_false = select(false, wrapped, big2)
    assert(selected_true.unwrap().value == 7, "true branch should widen mut ref to ref")
    assert(selected_false.unwrap().value == 9, "false branch should use fallback")
    println("ok")
}
