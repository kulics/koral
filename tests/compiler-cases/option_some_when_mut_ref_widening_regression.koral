// EXPECT: ok

type Big(value Int)
given Big not Deref

type Wrapped(mut kind Big ref)

let select(flag Bool, wrapped Wrapped mut ref, fallback Big ref) [Big ref]Option = {
    let subject = if flag then [Wrapped mut ref]Option.Some(wrapped) else [Wrapped mut ref]Option.None()
    return [Big ref]Option.Some(when subject in {
        .Some(value) then value.kind,
        .None() then fallback,
    })
}

let main() Void = {
    let big1 Big mut ref = box(Big(7))
    let big2 Big mut ref = box(Big(9))
    let wrapped Wrapped mut ref = box(Wrapped(big1))
    let selected_true = select(true, wrapped, big2)
    let selected_false = select(false, wrapped, big2)
    assert(selected_true.unwrap().value == 7, "true branch should widen mut ref to ref")
    assert(selected_false.unwrap().value == 9, "false branch should use fallback")
    println("ok")
}
