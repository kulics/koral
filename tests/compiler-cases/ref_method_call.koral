// Test: Method calls on ref types should auto-dereference
// EXPECT: 3
// EXPECT: 42

public type Counter(value Int)

given Counter {

    public count(self) Int = self.value
}

// Function that takes a ref parameter and calls method on it
let get_count(c ref Counter) Int = c.count()

// Function that takes a List ref and uses subscript
let get_first(list ref List[Int]) Int = list[0]

public let main() Void = {
    let mut counter = Counter(3)
    println(get_count(counter.ref).to_string())
    
    let mut nums = List[Int].new()
    nums.push(42)
    nums.push(10)
    nums.push(20)
    println(get_first(nums.ref).to_string())
}
