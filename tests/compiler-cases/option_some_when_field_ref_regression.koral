// EXPECT: ok

type Kind {
    A(),
    B(),
}

given Kind not Deref

type Expr(kind ref Kind)

let lower(flag Bool, expr Expr) Option[ref Kind] = {
    let subject = if flag then Option[Expr].Some(expr) else Option[Expr].None()
    return Option[ref Kind].Some(when subject in {
        .Some(lowered_expr) then lowered_expr.kind,
        .None() then box(Kind.B()),
    })
}

let classify(kind ref Kind) Int = when kind in {
    .A() then 1,
    .B() then 2,
}

let main() Void = {
    let kind_a ref mut Kind = box(Kind.A())
    let expr = Expr(kind_a)
    let lowered_true = lower(true, expr).unwrap()
    let lowered_false = lower(false, expr).unwrap()
    assert(classify(lowered_true) == 1, "some branch should return field ref")
    assert(classify(lowered_false) == 2, "none branch should return boxed ref")
    println("ok")
}
