// EXPECT: 6

trait CounterOps {
    peek(self ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let read_counter(counter ref CounterOps) Int = counter.peek()

let main() Int = {
    let strong ref mut Counter = box(Counter(6))
    println(read_counter(strong).to_string())
    return 0
}