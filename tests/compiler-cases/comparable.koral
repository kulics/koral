// EXPECT: true
// EXPECT: false
// EXPECT: true
// EXPECT: true
// EXPECT: b
// EXPECT: a
// EXPECT: true
// EXPECT: true
// EXPECT: true
// EXPECT: false
// EXPECT: clamp_ok

let main() Int = {
    println("a" < "b")
    println("ab" < "aa")
    println("a" < "aa")
    println("b" >= "a")

    println(max("a", "b"))
    println(min("a", "b"))

    println(false < true)
    println(true > false)

    println(max(false, true))
    println(min(false, true))

    // clamp tests
    if 5.clamp(min: 1, max: 10) == 5 and (-3).clamp(min: 0, max: 10) == 0 and 15.clamp(min: 0, max: 10) == 10 and 0.clamp(min: 0, max: 10) == 0 and 10.clamp(min: 0, max: 10) == 10 and 3.5.clamp(min: 1.0, max: 5.0) == 3.5 and 0.0.clamp(min: 1.0, max: 5.0) == 1.0 and 9.9.clamp(min: 1.0, max: 5.0) == 5.0 then {
        println("clamp_ok")
    }

    yield 0
}
