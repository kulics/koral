// JSON basic parsing tests
// EXPECT: parse_null_ok
// EXPECT: parse_true_ok
// EXPECT: parse_false_ok
// EXPECT: parse_number_ok
// EXPECT: parse_string_ok
// EXPECT: parse_array_ok
// EXPECT: parse_object_ok
// EXPECT: escape_quote_ok
// EXPECT: escape_backslash_ok
// EXPECT: escape_slash_ok
// EXPECT: escape_backspace_ok
// EXPECT: escape_formfeed_ok
// EXPECT: escape_newline_ok
// EXPECT: escape_return_ok
// EXPECT: escape_tab_ok
// EXPECT: escape_unicode_ok
// EXPECT: escape_surrogate_pair_ok
// EXPECT: num_int_ok
// EXPECT: num_neg_frac_ok
// EXPECT: num_sci_ok
// EXPECT: num_sci_upper_ok
// EXPECT: num_zero_ok
// EXPECT: num_neg_zero_ok
// EXPECT: err_empty_ok
// EXPECT: err_truncated_ok
// EXPECT: err_invalid_escape_ok
// EXPECT: err_trailing_ok
// EXPECT: err_message_format_ok
// EXPECT: err_tostring_ok

using Std.Json.*

let main() Int = {
    // === Parse six top-level types ===

    // null
    when JsonValue.parse("null") in {
        .Ok(v) then {
            if v.is_null() then println("parse_null_ok")
            else println("FAIL parse_null")
        },
        .Error(e) then println("FAIL parse_null: " + e.message()),
    }

    // true
    when JsonValue.parse("true") in {
        .Ok(v) then {
            when v in {
                .Bool(b) then {
                    if b then println("parse_true_ok")
                    else println("FAIL parse_true: got false")
                },
                _ then println("FAIL parse_true: not Bool"),
            }
        },
        .Error(e) then println("FAIL parse_true: " + e.message()),
    }

    // false
    when JsonValue.parse("false") in {
        .Ok(v) then {
            when v in {
                .Bool(b) then {
                    if not b then println("parse_false_ok")
                    else println("FAIL parse_false: got true")
                },
                _ then println("FAIL parse_false: not Bool"),
            }
        },
        .Error(e) then println("FAIL parse_false: " + e.message()),
    }

    // number
    when JsonValue.parse("42") in {
        .Ok(v) then {
            when v in {
                .Number(n) then {
                    if n == 42.0 then println("parse_number_ok")
                    else println("FAIL parse_number: wrong value")
                },
                _ then println("FAIL parse_number: not Number"),
            }
        },
        .Error(e) then println("FAIL parse_number: " + e.message()),
    }

    // string
    when JsonValue.parse("\"hello\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s == "hello" then println("parse_string_ok")
                    else println("FAIL parse_string: got " + s)
                },
                _ then println("FAIL parse_string: not String"),
            }
        },
        .Error(e) then println("FAIL parse_string: " + e.message()),
    }

    // array
    when JsonValue.parse("[1,2,3]") in {
        .Ok(v) then {
            when v in {
                .Array(elems) then {
                    if elems.count() == 3 then println("parse_array_ok")
                    else println("FAIL parse_array: wrong count")
                },
                _ then println("FAIL parse_array: not Array"),
            }
        },
        .Error(e) then println("FAIL parse_array: " + e.message()),
    }

    // object
    when JsonValue.parse("{\"a\":1}") in {
        .Ok(v) then {
            when v in {
                .Object(entries) then {
                    if entries.count() == 1 then println("parse_object_ok")
                    else println("FAIL parse_object: wrong count")
                },
                _ then println("FAIL parse_object: not Object"),
            }
        },
        .Error(e) then println("FAIL parse_object: " + e.message()),
    }

    // === Escape sequence tests ===

    // \"
    when JsonValue.parse("\"a\\\"b\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s == "a\"b" then println("escape_quote_ok")
                    else println("FAIL escape_quote")
                },
                _ then println("FAIL escape_quote: not String"),
            }
        },
        .Error(e) then println("FAIL escape_quote: " + e.message()),
    }

    // \\
    when JsonValue.parse("\"a\\\\b\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s == "a\\b" then println("escape_backslash_ok")
                    else println("FAIL escape_backslash")
                },
                _ then println("FAIL escape_backslash: not String"),
            }
        },
        .Error(e) then println("FAIL escape_backslash: " + e.message()),
    }

    // \/
    when JsonValue.parse("\"a\\/b\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s == "a/b" then println("escape_slash_ok")
                    else println("FAIL escape_slash")
                },
                _ then println("FAIL escape_slash: not String"),
            }
        },
        .Error(e) then println("FAIL escape_slash: " + e.message()),
    }

    // \b (backspace = 0x08)
    when JsonValue.parse("\"a\\bb\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s.count() == 3 and s[1] == (UInt8)8 then println("escape_backspace_ok")
                    else println("FAIL escape_backspace")
                },
                _ then println("FAIL escape_backspace: not String"),
            }
        },
        .Error(e) then println("FAIL escape_backspace: " + e.message()),
    }

    // \f (form feed = 0x0C)
    when JsonValue.parse("\"a\\fb\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s.count() == 3 and s[1] == (UInt8)12 then println("escape_formfeed_ok")
                    else println("FAIL escape_formfeed")
                },
                _ then println("FAIL escape_formfeed: not String"),
            }
        },
        .Error(e) then println("FAIL escape_formfeed: " + e.message()),
    }

    // \n
    when JsonValue.parse("\"a\\nb\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s == "a\nb" then println("escape_newline_ok")
                    else println("FAIL escape_newline")
                },
                _ then println("FAIL escape_newline: not String"),
            }
        },
        .Error(e) then println("FAIL escape_newline: " + e.message()),
    }

    // \r
    when JsonValue.parse("\"a\\rb\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s.count() == 3 and s[1] == (UInt8)13 then println("escape_return_ok")
                    else println("FAIL escape_return")
                },
                _ then println("FAIL escape_return: not String"),
            }
        },
        .Error(e) then println("FAIL escape_return: " + e.message()),
    }

    // \t
    when JsonValue.parse("\"a\\tb\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    if s == "a\tb" then println("escape_tab_ok")
                    else println("FAIL escape_tab")
                },
                _ then println("FAIL escape_tab: not String"),
            }
        },
        .Error(e) then println("FAIL escape_tab: " + e.message()),
    }

    // \uXXXX (euro sign U+20AC)
    when JsonValue.parse("\"\\u20AC\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    // Euro sign is 3 bytes in UTF-8: 0xE2 0x82 0xAC
                    if s.count() == 3 and s[0] == (UInt8)0xE2 and s[1] == (UInt8)0x82 and s[2] == (UInt8)0xAC then println("escape_unicode_ok")
                    else println("FAIL escape_unicode")
                },
                _ then println("FAIL escape_unicode: not String"),
            }
        },
        .Error(e) then println("FAIL escape_unicode: " + e.message()),
    }

    // Surrogate pair: U+1F600 (grinning face) = \uD83D\uDE00
    when JsonValue.parse("\"\\uD83D\\uDE00\"") in {
        .Ok(v) then {
            when v in {
                .String(s) then {
                    // U+1F600 is 4 bytes in UTF-8: 0xF0 0x9F 0x98 0x80
                    if s.count() == 4 and s[0] == (UInt8)0xF0 and s[1] == (UInt8)0x9F and s[2] == (UInt8)0x98 and s[3] == (UInt8)0x80 then println("escape_surrogate_pair_ok")
                    else println("FAIL escape_surrogate_pair")
                },
                _ then println("FAIL escape_surrogate_pair: not String"),
            }
        },
        .Error(e) then println("FAIL escape_surrogate_pair: " + e.message()),
    }

    // === Number format tests ===

    // integer
    when JsonValue.parse("1") in {
        .Ok(v) then {
            when v in {
                .Number(n) then {
                    if n == 1.0 then println("num_int_ok")
                    else println("FAIL num_int")
                },
                _ then println("FAIL num_int: not Number"),
            }
        },
        .Error(e) then println("FAIL num_int: " + e.message()),
    }

    // negative fraction
    when JsonValue.parse("-2.5") in {
        .Ok(v) then {
            when v in {
                .Number(n) then {
                    if n > (0.0 - 2.6) and n < (0.0 - 2.4) then println("num_neg_frac_ok")
                    else println("FAIL num_neg_frac")
                },
                _ then println("FAIL num_neg_frac: not Number"),
            }
        },
        .Error(e) then println("FAIL num_neg_frac: " + e.message()),
    }

    // scientific notation lowercase
    when JsonValue.parse("3e10") in {
        .Ok(v) then {
            when v in {
                .Number(n) then {
                    if n > 2.9e10 and n < 3.1e10 then println("num_sci_ok")
                    else println("FAIL num_sci")
                },
                _ then println("FAIL num_sci: not Number"),
            }
        },
        .Error(e) then println("FAIL num_sci: " + e.message()),
    }

    // scientific notation uppercase with sign
    when JsonValue.parse("-1.2E+3") in {
        .Ok(v) then {
            when v in {
                .Number(n) then {
                    if n > (0.0 - 1201.0) and n < (0.0 - 1199.0) then println("num_sci_upper_ok")
                    else println("FAIL num_sci_upper")
                },
                _ then println("FAIL num_sci_upper: not Number"),
            }
        },
        .Error(e) then println("FAIL num_sci_upper: " + e.message()),
    }

    // zero
    when JsonValue.parse("0") in {
        .Ok(v) then {
            when v in {
                .Number(n) then {
                    if n == 0.0 then println("num_zero_ok")
                    else println("FAIL num_zero")
                },
                _ then println("FAIL num_zero: not Number"),
            }
        },
        .Error(e) then println("FAIL num_zero: " + e.message()),
    }

    // negative zero
    when JsonValue.parse("-0") in {
        .Ok(v) then {
            when v in {
                .Number(n) then {
                    // -0.0 == 0.0 in floating point
                    if n == 0.0 then println("num_neg_zero_ok")
                    else println("FAIL num_neg_zero")
                },
                _ then println("FAIL num_neg_zero: not Number"),
            }
        },
        .Error(e) then println("FAIL num_neg_zero: " + e.message()),
    }

    // === Invalid input tests ===

    // empty string
    when JsonValue.parse("") in {
        .Ok(_) then println("FAIL err_empty"),
        .Error(e) then println("err_empty_ok"),
    }

    // truncated input
    when JsonValue.parse("[1,") in {
        .Ok(_) then println("FAIL err_truncated"),
        .Error(e) then println("err_truncated_ok"),
    }

    // invalid escape
    when JsonValue.parse("\"\\q\"") in {
        .Ok(_) then println("FAIL err_invalid_escape"),
        .Error(e) then println("err_invalid_escape_ok"),
    }

    // trailing characters
    when JsonValue.parse("true false") in {
        .Ok(_) then println("FAIL err_trailing"),
        .Error(e) then println("err_trailing_ok"),
    }

    // === JsonError.message() and to_string() format ===

    // message() format: "JSON error at position N: msg"
    when JsonValue.parse("") in {
        .Ok(_) then println("FAIL err_message_format"),
        .Error(e) then {
            let msg = e.message()
            if msg == "JSON error at position 0: unexpected end of input" then println("err_message_format_ok")
            else println("FAIL err_message_format: " + msg)
        },
    }

    // to_string() should equal message() — test on JsonError directly
    let test_err = JsonError("test msg", 5)
    let err_msg = test_err.message()
    let err_str = test_err.to_string()
    if err_msg == err_str and err_msg == "JSON error at position 5: test msg" then println("err_tostring_ok")
    else println("FAIL err_tostring: " + err_msg + " vs " + err_str)

    yield 0
}
