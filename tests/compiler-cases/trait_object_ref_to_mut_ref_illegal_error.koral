// EXPECT-ERROR: Type mismatch: expected ref mut CounterOps, got ref CounterOps

trait CounterOps {
    bump(self ref mut) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public bump(self ref mut) Int = {
        self.value += 1
        return self.value
    }
}

let main() Int = {
    let strong ref mut Counter = box(Counter(1))
    let readonly ref CounterOps = strong
    let _ ref mut CounterOps = readonly
    return 0
}