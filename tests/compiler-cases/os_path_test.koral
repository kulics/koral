// EXPECT: is_absolute_ok
// EXPECT: join_path_ok
// EXPECT: base_ok
// EXPECT: dir_ok
// EXPECT: ext_ok
// EXPECT: normalize_idempotent_ok
// EXPECT: relative_path_ok
// EXPECT: starts_with_ok
// EXPECT: ends_with_ok
// EXPECT: stem_name_ok

using Std.Os.*

let main() Void = {
    // ========================================================================
    // is_absolute
    // ========================================================================
    assert("/usr/bin".to_path().is_absolute(), "abs /usr/bin")
    assert(not "relative/path".to_path().is_absolute(), "rel relative/path")
    assert(not "".to_path().is_absolute(), "abs empty")
    assert("\\windows".to_path().is_absolute(), "abs backslash")

    println("is_absolute_ok")

    // ========================================================================
    // join_path
    // ========================================================================
    // join with empty
    assert("".to_path().join("b").to_string() == "b", "join empty base")
    assert("a".to_path().join("").to_string() == "a", "join empty name")

    // join with absolute name returns name
    assert("a".to_path().join("/b").to_string() == "/b", "join absolute name")

    // basic join
    let joined = "a".to_path().join("b")
    assert(joined.to_string().contains("a"), "join contains a")
    assert(joined.to_string().contains("b"), "join contains b")

    println("join_path_ok")

    // ========================================================================
    // base_name
    // ========================================================================
    assert("/path/to/file.txt".to_path().base_name() == "file.txt", "base file")
    assert("file.txt".to_path().base_name() == "file.txt", "base no dir")
    assert("/single".to_path().base_name() == "single", "base single")
    assert("".to_path().base_name() == ".", "base empty")

    println("base_ok")

    // ========================================================================
    // dir_name
    // ========================================================================

    assert("/path/to/file.txt".to_path().dir_name().to_string() == "/path/to", "dir nested")
    assert("/file".to_path().dir_name().to_string() == "/", "dir root")
    assert("file.txt".to_path().dir_name().to_string() == ".", "dir no dir")
    assert("".to_path().dir_name().to_string() == ".", "dir empty")

    println("dir_ok")

    // ========================================================================
    // ext_name
    // ========================================================================
    assert("file.txt".to_path().ext_name() == ".txt", "ext txt")
    assert("archive.tar.gz".to_path().ext_name() == ".gz", "ext double")
    assert("noext".to_path().ext_name().is_empty(), "ext none")
    assert(".hidden".to_path().ext_name().is_empty(), "ext dotfile")

    println("ext_ok")

    // ========================================================================
    // normalize_path idempotency
    // ========================================================================
    let p1 = "/a/b/c".to_path().normalize().to_string()
    let p2 = p1.to_path().normalize().to_string()
    assert(p1 == p2, "normalize idempotent")

    println("normalize_idempotent_ok")

    // ========================================================================
    // relative_path
    // ========================================================================
    // Same path
    let rp_same = "/a/b".to_path().relative_to("/a/b".to_path()).unwrap().to_string()
    assert(rp_same == ".", "relative same")

    // Child path
    let rp_child = "/a/b/c".to_path().relative_to("/a".to_path()).unwrap().to_string()
    assert(rp_child == "b/c", "relative child")

    // Parent path
    let rp_parent = "/a".to_path().relative_to("/a/b/c".to_path()).unwrap().to_string()
    assert(rp_parent == "../..", "relative parent")

    // Sibling path
    let rp_sibling = "/a/c".to_path().relative_to("/a/b".to_path()).unwrap().to_string()
    assert(rp_sibling == "../c", "relative sibling")

    // Error on empty
    assert("/a".to_path().relative_to("".to_path()).is_error(), "relative empty from")
    assert("".to_path().relative_to("/a".to_path()).is_error(), "relative empty to")

    println("relative_path_ok")

    // ========================================================================
    // starts_with
    // ========================================================================
    assert("/usr/bin/gcc".to_path().starts_with("/usr/bin".to_path()), "starts_with prefix")
    assert("/usr/bin/gcc".to_path().starts_with("/usr".to_path()), "starts_with shorter prefix")
    assert(not "/usr/bin".to_path().starts_with("/usr/bin/gcc".to_path()), "starts_with longer fails")
    assert("/usr/bin".to_path().starts_with("/usr/bin".to_path()), "starts_with exact match")
    assert(not "/usr/bin".to_path().starts_with("/etc".to_path()), "starts_with different path")

    println("starts_with_ok")

    // ========================================================================
    // ends_with
    // ========================================================================
    assert("/usr/bin/gcc".to_path().ends_with("bin/gcc".to_path()), "ends_with suffix")
    assert("/usr/bin/gcc".to_path().ends_with("gcc".to_path()), "ends_with single component")
    assert(not "/usr/bin".to_path().ends_with("/usr/bin/gcc".to_path()), "ends_with longer fails")
    assert("/usr/bin".to_path().ends_with("/usr/bin".to_path()), "ends_with exact match")
    assert(not "/usr/bin".to_path().ends_with("etc".to_path()), "ends_with different path")

    println("ends_with_ok")

    // ========================================================================
    // stem_name
    // ========================================================================
    assert("file.txt".to_path().stem_name() == "file", "stem_name basic")
    assert("archive.tar.gz".to_path().stem_name() == "archive.tar", "stem_name double ext")
    assert("noext".to_path().stem_name() == "noext", "stem_name no ext")
    assert(".hidden".to_path().stem_name() == ".hidden", "stem_name dotfile")
    assert("/path/to/file.txt".to_path().stem_name() == "file", "stem_name with dir")

    println("stem_name_ok")

}
