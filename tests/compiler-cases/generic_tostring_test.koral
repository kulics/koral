// EXPECT: Some(42)
// EXPECT: None
// EXPECT: [1, 2, 3]
// EXPECT: []
// EXPECT: []
// EXPECT: []

let main() Int = {
    let some_int = Option[Int].Some(42)
    let none_int = Option[Int].None()
    println(some_int)
    println(none_int)

    let mut list = List[Int].new()
    list.push(1)
    list.push(2)
    list.push(3)
    println(list)

    let empty_list = List[Int].new()
    println(empty_list)

    let empty_map = Dict[Int, String].new()
    println(empty_map)

    let empty_set = Set[Int].new()
    println(empty_set)

    return 0
}

