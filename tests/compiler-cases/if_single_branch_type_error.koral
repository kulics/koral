// Test that single-branch if (without else) rejects non-Void/Never then branch
// This prevents misuse of yield to "early return" from a single-branch if,
// since yield does not have early-return semantics.
// EXPECT-ERROR: Single-branch 'if' must have Void or Never type in then branch

let main() Int = {
    let x = true
    // This should fail: yield produces Int, but single-branch if requires Void/Never
    if x then { yield 42 }
    yield 0
}
