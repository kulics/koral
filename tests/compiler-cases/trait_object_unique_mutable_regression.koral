// Regression: trait object uniqueness/lifetime balance for lvalue/rvalue paths
// EXPECT: before call unique: false
// EXPECT: after call unique: false
// EXPECT: rvalue convert released

trait Ping {
    ping(self ref) Int
}

type Box(value Int)

given Box as Ping {

    public ping(self ref) Int = self.value
}

let main() Int = {
    // Lvalue conversion should retain once.
    let concrete = box(Box(7))
    let obj ref Ping = concrete

    print("before call unique: ")
    println(is_unique_mutable(concrete.ptr))

    // Dynamic dispatch with lvalue receiver should retain/release the trait ref receiver, net zero.
    let _ = obj.ping()

    print("after call unique: ")
    println(is_unique_mutable(concrete.ptr))

    // Rvalue conversion should transfer ownership (no extra retain), so object is released at scope end.
    let weakObj = make_weak_object()

    let upgraded = weakObj.to_ref()
    when upgraded in {
        .Some(_) then println("rvalue convert leaked"),
        .None then println("rvalue convert released"),
    }

    return 0
}

let make_weak_object() weakref Ping = {
    let tmp ref Ping = box(Box(1))
    return tmp.weakref
}
