// EXPECT: ok

type Kind {
    A(),
    B(),
}

given Kind not Deref

type Expr(kind Kind ref)

let wrap(expr Expr) [Kind ref]Option = [Kind ref]Option.Some(expr.kind)

let classify(kind Kind ref) Int = when kind in {
    .A() then 1,
    .B() then 2,
}

let main() Void = {
    let kind_a Kind mut ref = box(Kind.A())
    let expr = Expr(kind_a)
    assert(classify(wrap(expr).unwrap()) == 1, "constructor arg should widen field ref")
    println("ok")
}
