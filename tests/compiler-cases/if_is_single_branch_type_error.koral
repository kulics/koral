// Test that single-branch if...is bodies are statement-only, so yield is rejected.
// EXPECT-ERROR: yield outside of branch expression body

type MyOption {
    Some(value Int),
    None(),
}

let main() Int = {
    let opt = MyOption.Some(10)
    // This should fail: single-branch if...is body is statement-context only.
    if opt is .Some(v) then { yield v }
    return 0
}
