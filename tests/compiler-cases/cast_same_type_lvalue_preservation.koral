// EXPECT: cast-copy-unique: false

type Holder(value ref Int)

let main() Int = {
    let mut v = 1
    let r = v.ref
    let a = Holder(r)
    let b Holder = a(Holder)

    assert(b.value.val == 1, "copied holder value")
    print("cast-copy-unique: ")
    println(is_unique_mutable(r))
    return 0
}
