// EXPECT: Status.describe called
// EXPECT: Status dropped
// EXPECT: --- Scope 1 ---
// EXPECT: Status dropped
// EXPECT: --- Scope 1 End ---
// EXPECT: Box.is_empty called
// EXPECT: Box dropped
// EXPECT: --- Scope 2 ---
// EXPECT: Box dropped
// EXPECT: --- Scope 2 End ---
// EXPECT: Box dropped
// EXPECT: Status dropped

type Status {
    Active(),
    Inactive(value Int),
}

given Status {

    describe(self) Int = {
        println("Status.describe called")
        return 0
    }
}

given Status as Drop {

    drop(source ptr mut Self) Void = {
        println("Status dropped")
    }
}

type Box[T Any] {
    Full(value T),
    Empty(),
}

given[T Any] Box[T] {
    is_empty(self) Bool = {
        println("Box.is_empty called")
        return true
    }
}

given[T Any] Box[T] as Drop {
    drop(source ptr mut Self) Void = {
        println("Box dropped")
    }
}

let main() Int = {
    let s = Status.Active()
    s.describe()
    
    println("--- Scope 1 ---")
    {
        let s2 = Status.Inactive(10)
        // s2 drops here -> "Status dropped"
    }
    println("--- Scope 1 End ---")
    
    let b = Box[Int].Full(42)
    b.is_empty()
    
    println("--- Scope 2 ---")
    {
        let b2 = Box[Int].Empty()
        // b2 drops here -> "Box dropped"
    }
    println("--- Scope 2 End ---")
    
    // s and b drop here at end of main
    return 0
}
