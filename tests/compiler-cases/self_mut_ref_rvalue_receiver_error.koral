// EXPECT-ERROR: Cannot call 'self ref mut' method 'increment' on an rvalue; store the value in a 'let mut' variable first

type Counter(mut value Int)

given Counter {

    increment(self ref mut) Void = {
        self.value = self.value + 1
    }
}

let main() Int = {
    Counter(1).increment()
    return 0
}