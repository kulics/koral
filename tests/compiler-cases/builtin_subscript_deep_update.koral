// EXPECT: builtin subscript deep update ok

using std { .. }

type Point(mut x Int, mut y Int)

let main() Void = {
    let mut points = List[Point].new()
    points.push(Point(1, 2))
    points[0].y = 77
    assert(points[0].x == 1, "list field update keeps x")
    assert(points[0].y == 77, "list field update stores new y")

    let mut row = List[Int].new()
    row.push(10)
    row.push(20)

    let mut nested = List[List[Int]].new()
    nested.push(row)

    let mut nested_copy = nested
    nested_copy[0][1] = 99
    assert(nested[0][1] == 20, "outer copy-on-write keeps original nested value")
    assert(nested_copy[0][1] == 99, "nested subscript write updates copy")

    let mut dq = Deque[Point].new()
    dq.push_back(Point(5, 6))
    dq.push_front(Point(7, 8))
    dq[1].x = 42
    assert(dq[0].x == 7, "deque front survives wrap-around setup")
    assert(dq[1].x == 42, "deque deep update writes through builtin subscript")

    println("builtin subscript deep update ok")
}
