// Test: Generic enum type inference from return type context
// EXPECT: 42
// EXPECT: hello

// Test Option inference
let get_some() Option[Int] = Option.Some(42)
let get_none() Option[Int] = Option.None()

// Test Result inference  
let get_ok() Result[String] = Result.Ok("hello")
let get_err() Result[String] = Result.Error(box("oops"))

public let main() Void = {
    when get_some() in {
        .Some(x) then println(x.to_string()),
        .None then println("none"),
    }
    when get_ok() in {
        .Ok(x) then println(x),
        .Error(_) then println("error"),
    }
}
