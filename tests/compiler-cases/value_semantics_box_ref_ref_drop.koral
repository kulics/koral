// EXPECT: start
// EXPECT: ref_ref_box_ok
// EXPECT: end
// EXPECT: Drop Tracker

type Tracker(id Int)

given Tracker as Drop {

    drop(source mut ptr Self) Void = {
        println("Drop Tracker")
    }
}

let main() Int = {
    println("start")

    let mut t = Tracker(9)
    let r ref Tracker = t.ref
    let rr ref ref Tracker = box(r)

    if rr.val.id == 9 then {
        println("ref_ref_box_ok")
    } else {}

    println("end")
    return 0
}
