// EXPECT: start
// EXPECT: ref_ref_box_ok
// EXPECT: end
// EXPECT: Drop Tracker

type Tracker(id Int)

given Tracker as Drop {

    drop(self mut ref) Void = {
        println("Drop Tracker")
    }
}

let main() Int = {
    println("start")

    let mut t = Tracker(9)
    let r ref Tracker = t.ref
    let rr ref ref Tracker = box(r)

    if ref_count(rr.val) > 0 then {
        println("ref_ref_box_ok")
    } else {}

    println("end")
    return 0
}
