// EXPECT: some-some: 7
// EXPECT: some-none: -1
// EXPECT: none: -2

type Wrap[T Any] {
    Some(value T),
    None(),
}

let unwrap_nested(value Wrap[Wrap[Int]]) Int = when value in {
    .Some(inner) then when inner in {
        .Some(v) then v,
        .None() then -1,
    },
    .None() then -2,
}

let main() Int = {
    println("some-some: " + unwrap_nested(Wrap[Wrap[Int]].Some(Wrap[Int].Some(7))).to_string())
    println("some-none: " + unwrap_nested(Wrap[Wrap[Int]].Some(Wrap[Int].None())).to_string())
    println("none: " + unwrap_nested(Wrap[Wrap[Int]].None()).to_string())
    return 0
}
