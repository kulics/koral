// EXPECT: some-some: 7
// EXPECT: some-none: -1
// EXPECT: none: -2

type [T Any]Wrap {
    Some(value T),
    None(),
}

let unwrap_nested(value [[Int]Wrap]Wrap) Int = when value in {
    .Some(inner) then when inner in {
        .Some(v) then v,
        .None() then -1,
    },
    .None() then -2,
}

let main() Int = {
    println("some-some: " + unwrap_nested([[Int]Wrap]Wrap.Some([Int]Wrap.Some(7))).to_string())
    println("some-none: " + unwrap_nested([[Int]Wrap]Wrap.Some([Int]Wrap.None())).to_string())
    println("none: " + unwrap_nested([[Int]Wrap]Wrap.None()).to_string())
    yield 0
}
