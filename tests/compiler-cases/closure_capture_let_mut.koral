// EXPECT: PASS

// Positive test: closures should be able to capture 'let mut' variables.

let main() Int = {
    let mut counter = 0
    let increment = () -> {
        counter = counter + 1
    }
    increment()
    increment()
    increment()
    if counter <> 3 then {
        eprintln("FAIL: expected 3, got \(counter)")
        return 1
    }
    println("PASS")
    return 0
}
