// Test and then smart flattening
// EXPECT: Option flatten Some-Some: 10
// EXPECT: Option flatten Some-None: None
// EXPECT: Option flatten None: None
// EXPECT: Option wrap Some: 20
// EXPECT: Option wrap None: None
// EXPECT: Result flatten Ok-Ok: 50
// EXPECT: Result flatten Ok-Error: div by zero
// EXPECT: Result flatten Error: err_outer
// EXPECT: Result wrap Ok: 99
// EXPECT: Result wrap Error: err_wrap

let safe_div(x Int, y Int) Option[Int] = {
    return if y == 0 then {
        yield Option[Int].None()
    } else {
        yield Option[Int].Some(x / y)
    }
}

let safe_result_div(x Int, y Int) Result[Int] = {
    return if y == 0 then {
        yield Result[Int].Error(box("div by zero"))
    } else {
        yield Result[Int].Ok(x / y)
    }
}

let print_option(label String, opt Option[Int]) Void = {
    print(label)
    when opt in {
        .Some(v) then println(v.to_string()),
        .None then println("None"),
    }
}

let print_result(label String, res Result[Int]) Void = {
    print(label)
    when res in {
        .Ok(v) then println(v.to_string()),
        .Error(e) then println(e.message()),
    }
}

let main() Int = {
    // Option: transform returns Option -> flatten
    let opt_some = Option[Int].Some(100)
    let flat1 = opt_some and then safe_div(it, 10)
    print_option("Option flatten Some-Some: ", flat1)

    let flat2 = opt_some and then safe_div(it, 0)
    print_option("Option flatten Some-None: ", flat2)

    let opt_none = Option[Int].None()
    let flat3 = opt_none and then safe_div(it, 10)
    print_option("Option flatten None: ", flat3)

    // Option: transform returns non-Option -> wrap
    let wrap1 = opt_some and then it / 5
    print_option("Option wrap Some: ", wrap1)

    let wrap2 = opt_none and then it / 5
    print_option("Option wrap None: ", wrap2)

    // Result: transform returns Result (same error type) -> flatten
    let res_ok = Result[Int].Ok(100)
    let rflat1 = res_ok and then safe_result_div(it, 2)
    print_result("Result flatten Ok-Ok: ", rflat1)

    let rflat2 = res_ok and then safe_result_div(it, 0)
    print_result("Result flatten Ok-Error: ", rflat2)

    let res_err = Result[Int].Error(box("err_outer"))
    let rflat3 = res_err and then safe_result_div(it, 2)
    print_result("Result flatten Error: ", rflat3)

    // Result: transform returns non-Result -> wrap
    let rwrap1 = res_ok and then it - 1
    print_result("Result wrap Ok: ", rwrap1)

    let res_err2 = Result[Int].Error(box("err_wrap"))
    let rwrap2 = res_err2 and then it - 1
    print_result("Result wrap Error: ", rwrap2)

    return 0
}
