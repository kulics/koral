// EXPECT: All double-quoted string literal tests passed!

type StringIter(mut index Int)

given StringIter {
  next(self mut ref) [String]Option = {
    yield if self.index == 0 then {
      self.index = 1
      yield .Some("hello")
    } else if self.index == 1 then {
      self.index = 2
      yield .Some("world")
    } else {
      yield .None()
    }
  }
}

let main() Int = {
  // Expression context
  let s = "hello"
  assert(s == "hello", "double-quoted literal should be String")

  // when-pattern context
  let when_result = when s in {
    "hello" then 1,
    _ then 0,
  }
  assert(when_result == 1, "when-pattern string literal should match")

  // if-pattern context
  let if_result = if s is "hello" then 1 else 0
  assert(if_result == 1, "if-pattern string literal should match")

  // while-pattern context
  let mut iter = StringIter(0)
  let mut world_hits = 0
  while iter.next() is .Some(v) then {
    if v is "world" then {
      world_hits = world_hits + 1
    }
  }
  assert(world_hits == 1, "while-pattern string literal should match exactly once")

  println("All double-quoted string literal tests passed!")
  yield 0
}
