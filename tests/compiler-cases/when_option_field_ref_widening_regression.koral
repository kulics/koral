// EXPECT: ok

type Big(value Int)
given Big not Deref

type Expr(kind ref Big)

let select(flag Bool, expr Expr, fallback ref Big) ref Big = when if flag then Option[Expr].Some(expr) else Option[Expr].None() in {
    .Some(lowered_expr) then lowered_expr.kind,
    .None() then fallback,
}

let main() Void = {
    let big1 ref mut Big = box(Big(7))
    let big2 ref mut Big = box(Big(9))
    let expr = Expr(big1)
    let selected_true ref Big = select(true, expr, big2)
    let selected_false ref Big = select(false, expr, big2)
    assert(selected_true.value == 7, "some branch should return field ref")
    assert(selected_false.value == 9, "none branch should return fallback")
    println("ok")
}
