// EXPECT: ok

type Big(value Int)
given Big not Deref

type Expr(kind Big ref)

let select(flag Bool, expr Expr, fallback Big ref) Big ref = when if flag then [Expr]Option.Some(expr) else [Expr]Option.None() in {
    .Some(lowered_expr) then lowered_expr.kind,
    .None() then fallback,
}

let main() Void = {
    let big1 Big mut ref = box(Big(7))
    let big2 Big mut ref = box(Big(9))
    let expr = Expr(big1)
    let selected_true Big ref = select(true, expr, big2)
    let selected_false Big ref = select(false, expr, big2)
    assert(selected_true.value == 7, "some branch should return field ref")
    assert(selected_false.value == 9, "none branch should return fallback")
    println("ok")
}
