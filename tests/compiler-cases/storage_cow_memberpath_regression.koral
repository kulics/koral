// EXPECT: true
// EXPECT: true
// EXPECT: 2
// EXPECT: true
// EXPECT: true
// EXPECT: 2

type ListOwner(mut values List[Int])
type ListHolder(mut storage mut ref ListOwner)

type DictOwner(mut values Dict[Int, Int])
type DictHolder(mut storage mut ref DictOwner)

given ListHolder {
    public new() Self = ListHolder(box(ListOwner(List[Int].new())))

    public add(self mut ref, value Int) Bool = {
        let before = self.storage.values.borrow_ptr()
        self.storage.values.push(value)
        let after = self.storage.values.borrow_ptr()
        return before == after
    }
}

given DictHolder {
    public new() Self = DictHolder(box(DictOwner(Dict[Int, Int].with_capacity(8))))

    public add(self mut ref, key Int, value Int) Bool = {
        let before = self.storage.values.borrow_ptr()
        self.storage.values.insert(key, value)
        let after = self.storage.values.borrow_ptr()
        return before == after
    }
}

let main() Int = {
    let mut holder = ListHolder.new()
    println(holder.add(1))
    println(holder.add(2))
    println(holder.storage.values.count())
    let mut dict_holder = DictHolder.new()
    println(dict_holder.add(1, 10))
    println(dict_holder.add(2, 20))
    println(dict_holder.storage.values.count())
    return 0
}
