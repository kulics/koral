// EXPECT: 10

trait CounterOps {
    peek(self ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let choose(flag Bool, strong mut ref Counter, obj ref CounterOps) ref CounterOps =
    if flag then strong else obj

let main() Int = {
    let strong mut ref Counter = box(Counter(10))
    let obj ref CounterOps = strong
    let chosen = choose(true, strong, obj)
    println(chosen.peek().to_string())
    return 0
}