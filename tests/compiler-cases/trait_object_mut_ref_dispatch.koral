// Windows runner note: keep this as a build-only regression case.

trait CounterOps {
    peek(self ref) Int
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value

    public bump(self mut ref) Int = {
        self.value += 1
        return self.peek()
    }
}

let main() Int = {
    let strong mut ref Counter = box(Counter(4))
    let obj mut ref CounterOps = strong
    println(obj.bump().to_string())
    println(obj.peek().to_string())
    return 0
}
