// Windows runner note: keep this as a build-only regression case.
// EXPECT: 5
// EXPECT: 5
// EXIT: 0

trait CounterOps {
    peek(self ref) Int
    bump(self ref mut) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value

    public bump(self ref mut) Int = {
        self.value += 1
        return self.peek()
    }
}

let main() Int = {
    let strong ref mut Counter = box(Counter(4))
    let obj ref mut CounterOps = strong
    println(obj.bump().to_string())
    println(obj.peek().to_string())
    return 0
}
