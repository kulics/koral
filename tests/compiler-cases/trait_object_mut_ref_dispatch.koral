// EXPECT: 5
// EXPECT: 5

trait CounterOps {
    peek(self ref) Int
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter CounterOps {
    public peek(self ref) Int = self.value

    public bump(self mut ref) Int = {
        self.value += 1
        return self.peek()
    }
}

let main() Int = {
    let strong Counter mut ref = box(Counter(4))
    let obj CounterOps mut ref = strong
    println(obj.bump().to_string())
    println(obj.peek().to_string())
    yield 0
}