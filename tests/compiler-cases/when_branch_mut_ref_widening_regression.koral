// EXPECT: ok

type Big(value Int)
given Big not Deref

type Wrapped(mut kind ref Big)

let pick(flag Bool, wrapped ref mut Wrapped, fallback ref Big) ref Big = when flag in {
    true then wrapped.kind,
    false then fallback,
}

let main() Void = {
    let big1 ref mut Big = box(Big(7))
    let big2 ref mut Big = box(Big(9))
    let wrapped ref mut Wrapped = box(Wrapped(big1))
    let picked_true ref Big = pick(true, wrapped, big2)
    let picked_false ref Big = pick(false, wrapped, big2)
    assert(picked_true.value == 7, "true branch should read wrapped kind")
    assert(picked_false.value == 9, "false branch should use fallback")
    println("ok")
}
