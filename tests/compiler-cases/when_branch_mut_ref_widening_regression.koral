// EXPECT: ok

type Big(value Int)
given Big not Deref

type Wrapped(mut kind Big ref)

let pick(flag Bool, wrapped Wrapped mut ref, fallback Big ref) Big ref = when flag in {
    true then wrapped.kind,
    false then fallback,
}

let main() Void = {
    let big1 Big mut ref = box(Big(7))
    let big2 Big mut ref = box(Big(9))
    let wrapped Wrapped mut ref = box(Wrapped(big1))
    let picked_true Big ref = pick(true, wrapped, big2)
    let picked_false Big ref = pick(false, wrapped, big2)
    assert(picked_true.value == 7, "true branch should read wrapped kind")
    assert(picked_false.value == 9, "false branch should use fallback")
    println("ok")
}
