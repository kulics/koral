// EXPECT: 5
// EXPECT: 6

trait CounterOps {
    peek(self ref) Int
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value

    public bump(self mut ref) Int = {
        self.value += 1
        return self.value
    }
}

let main() Int = {
    let strong mut ref CounterOps = box(Counter(5))
    let weak mut weakref CounterOps = strong.weakref

    when weak.to_ref() in {
        .Some(counter) then {
            println(counter.peek().to_string())
            println(counter.bump().to_string())
        },
        .None then println("upgrade failed"),
    }

    return 0
}