// Test: method call on ref type inside nested when+if returns wrong value
// EXPECT: flag before: false
// EXPECT: flag inside when: false
// EXPECT: flag inside when: false
// EXPECT: done

using std::sync { .. }
using std::async { .. }
using std::time { .. }

type ResultStatus {
    Ok(exit_code Int),
    Err(msg String),
}

let main() Void = {
    let flag = AtomicBool.new(false)

    // Create a thread that does NOT set the flag
    let finished = AtomicBool.new(false)
    let watchdog = run_task(() -> {
        while not finished.load() then {
            sleep(5ms)
        }
    })

    finished.store(true)
    let _ = watchdog.wait()

    let status = ResultStatus.Ok(0)

    // This pattern matches the test runner:
    // when result in {
    //     .Ok(status) then if timed_out.load() then { ... } else { ... },
    //     .Error(msg) then if timed_out.load() then { ... } else { ... },
    // }

    print("flag before: ")
    println(flag.load().to_string())

    let result = when status in {
        .Ok(code) then {
            let inner = flag.load()
            print("flag inside when: ")
            println(inner.to_string())
            if inner then {
                1
            } else {
                print("flag inside when: ")
                println(flag.load().to_string())
                0
            }
        },
        .Err(msg) then {
            if flag.load() then {
                -1
            } else {
                -2
            }
        },
    }

    println("done")
}
