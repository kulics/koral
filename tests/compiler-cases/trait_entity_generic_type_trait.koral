// EXPECT: true
// EXPECT: false

trait MyEq[T Any] {
    equals(self, other T) Bool
}

given[T Any] MyEq[T] {
    neq(self, other T) Bool = not self.equals(other)
}

type Box[T Eq](value T)

given[T Eq] Box[T] as MyEq[Box[T]] {
    equals(self, other Box[T]) Bool = self.value == other.value
}

let main() Int = {
    let a = Box[Int](1)
    let b = Box[Int](2)
    println(a.(MyEq)neq(b))
    println(a.neq(a))
    return 0
}
