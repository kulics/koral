// EXPECT-EXACT: result 9
// EXPECT-EXACT: Drop 9

type Tracker(id Int)

given Tracker as Drop {

    drop(source mut ptr Self) Void = {
        println("Drop \(source.id)")
    }
}

let identity(x Tracker) Tracker = x

let main() Int = {
    let result = identity(Tracker(9))
    println("result \(result.id)")
    return 0
}

