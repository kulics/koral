// EXPECT-ERROR: Type mismatch: expected Int, got ref '_ Int

// Negative test: auto-deref (ref T → T) is NOT allowed for regular function arguments.
// Auto-deref only applies to method receivers (self).

let takes_value(x Int) Int = x

let main() Int = {
    let x = 42
    let r = takes_value(x.ref)
    return r
}
