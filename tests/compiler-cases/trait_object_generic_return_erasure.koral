// EXPECT: 11

trait CounterOps {
    peek(self ref) Int
}

type Counter(value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let erase[T CounterOps](x ref T) ref CounterOps = x

let main() Int = {
    let strong mut ref Counter = box(Counter(11))
    let readonly ref Counter = strong
    let erased = erase(readonly)
    println(erased.peek().to_string())
    return 0
}