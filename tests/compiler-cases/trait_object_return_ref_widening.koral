// EXPECT: 8

trait CounterOps {
    peek(self ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let expose_readonly(counter mut ref CounterOps) ref CounterOps = counter

let main() Int = {
    let strong mut ref Counter = box(Counter(8))
    let readonly = expose_readonly(strong)
    println(readonly.peek().to_string())
    return 0
}