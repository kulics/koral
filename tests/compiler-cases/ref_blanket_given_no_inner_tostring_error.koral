// Tests that T ref does NOT satisfy ToString when T does not implement ToString.
// Feature: type-modifier-trait-conformance
// EXPECT-ERROR: does not satisfy trait

type NoToString(x Int)

let [T ToString] render(x T) String = x.to_string()

let main() Void = {
    let mut value = NoToString(1)
    let r = value.ref
    println(render(r))
}