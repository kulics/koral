// Test trait object weakref support (downgrade and upgrade)
// EXPECT: hello
// EXPECT: upgrade succeeded

trait Greet {
    greet(self ref) String
}

type Greeter(name String)

given Greeter as Greet {

    public greet(self ref) String = self.name
}

let main() Int = {
    let g1 = box(Greeter("hello"))
    let g Greet ref = g1
    println(g.greet())

    // Downgrade to weakref
    let w Greet weakref = g.weakref

    // Upgrade back to strong ref
    let upgraded = w.to_ref()
    when upgraded in {
        .Some(s) then println("upgrade succeeded"),
        .None then println("upgrade failed"),
    }

    yield 0
}
