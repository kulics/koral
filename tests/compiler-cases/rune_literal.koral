// Test Rune literal syntax (single-quoted)
// EXPECT: All Rune literal tests passed!

type RuneIter(mut index Int)

given RuneIter {

    next(self mut ref) Option[Rune] = {
        return if self.index == 0 then {
            self.index = 1
            yield .Some(Rune.from_uint32_unchecked(65(UInt32)))
        } else if self.index == 1 then {
            self.index = 2
            yield .Some(Rune.from_uint32_unchecked(66(UInt32)))
        } else if self.index == 2 then {
            self.index = 3
            yield .Some(Rune.from_uint32_unchecked(67(UInt32)))
        } else {
            yield .None()
        }
    }
}

let main() Int = {
    // Test 1: ASCII character literal to Rune
    let r1 Rune = 'A'
    assert(r1.to_uint32() == 65(UInt32), "ASCII 'A' should be 65")
    
    // Test 2: Another ASCII character
    let r2 Rune = '0'
    assert(r2.to_uint32() == 48(UInt32), "ASCII '0' should be 48")
    
    // Test 3: Space character
    let r3 Rune = ' '
    assert(r3.to_uint32() == 32(UInt32), "Space should be 32")
    
    // Test 4: Escape sequence - newline
    let r4 Rune = '\n'
    assert(r4.to_uint32() == 10(UInt32), "Newline should be 10")
    
    // Test 5: Escape sequence - tab
    let r5 Rune = '\t'
    assert(r5.to_uint32() == 9(UInt32), "Tab should be 9")
    
    // Test 6: Rune comparison with literal
    let r6 Rune = 'B'
    assert(r6 == 'B', "Rune should equal its literal")
    assert(r6 > 'A', "B should be greater than A")
    assert(r6 < 'C', "B should be less than C")
    
    // Test 7: Rune in function parameter
    let result = test_rune_param('X')
    assert(result == 88, "X should be 88")
    
    // Test 8: Rune character classification with literal
    assert(is_vowel('a'), "'a' should be vowel")
    assert(is_vowel('E'), "'E' should be vowel")
    assert(not is_vowel('b'), "'b' should not be vowel")

    // Test 9: Rune literal in if-pattern
    let key Rune = 'K'
    assert((if key is 'K' then 1 else 0) == 1, "if-pattern rune literal should match")

    // Test 10: Rune literal in while-pattern
    let mut iter = RuneIter(0)
    let mut seen_b = 0
    while iter.next() is .Some(r) then {
        if r is 'B' then {
            seen_b = seen_b + 1
        }
    }
    assert(seen_b == 1, "while-pattern rune literal should match exactly once")
    
    println("All Rune literal tests passed!")
    return 0
}

let test_rune_param(r Rune) Int = r.to_uint32()(Int)

let is_vowel(r Rune) Bool = {
    return r == 'a' or r == 'e' or r == 'i' or r == 'o' or r == 'u' or
    r == 'A' or r == 'E' or r == 'I' or r == 'O' or r == 'U'
}
