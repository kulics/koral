// Test generic methods defined in traits and implemented in given blocks
// This tests that a trait can declare a generic method and types can implement it
// EXPECT: 84
// EXPECT: hello_world
// EXPECT: 42
// EXPECT: 100

// Define a trait with a generic method
trait Transformable {
    transform[U Any](self, f Func[Self, U]) U
}

// A simple wrapper type
public type Box[T Any] {
    Value(inner T),
}

// Implement Transformable for Box (explicit nominal conformance)
given[T Any] Box[T] as Transformable {
    public transform[U Any](self, f Func[Box[T], U]) U = f(self)
}

// Test using the trait as a constraint in a generic function
let get_value[T Transformable](x T) Int = {
    return x.transform[Int]((v) -> 42)
}

// Test using the trait as a constraint with a function parameter
let apply_transform[T Transformable](x T, f Func[T, Int]) Int = {
    return x.transform[Int](f)
}

let main() Int = {
    // Test calling the generic method directly on Box[Int]
    let box1 = Box[Int].Value(42)
    let result1 = box1.transform[Int]((b) -> {
        return when b in {
            .Value(v) then v * 2,
        }
    })
    println(result1.to_string())
    
    // Test transforming to a different type (Int -> String)
    let box2 = Box[Int].Value(42)
    let result2 = box2.transform[String]((b) -> {
        return when b in {
            .Value(v) then {
                let mut s = "hello_"
                s.push_string("world")
                yield s
            },
        }
    })
    println(result2)
    
    // Test using the trait as a constraint (simple version)
    let box3 = Box[Int].Value(50)
    let result3 = get_value(box3)
    println(result3.to_string())
    
    // Test using the trait as a constraint with a function parameter
    let box4 = Box[Int].Value(50)
    let result4 = apply_transform(box4, (b Box[Int]) -> {
        return when b in {
            .Value(v) then v * 2,
        }
    })
    println(result4.to_string())
    
    return 0
}
