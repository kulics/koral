// Test or else early exit (return from block expression)
// EXPECT: Option Some path: 42
// EXPECT: Option None path: -1
// EXPECT: Result Ok path: 100
// EXPECT: Result Error path: -2
// EXPECT: Result error propagation: error_msg

let try_option(opt Option[Int]) Int = {
    let value = opt or else { return -1 }
    return value
}

let try_result(res Result[Int]) Int = {
    let value = res or else { return -2 }
    return value
}

let try_result_propagate(res Result[Int]) Result[Int] = {
    let value = res or else { return Result[Int].Error(it) }
    return Result[Int].Ok(value * 2)
}

let main() Int = {
    // Option: Some path continues
    print("Option Some path: ")
    println(try_option(Option[Int].Some(42)))

    // Option: None path returns early
    print("Option None path: ")
    println(try_option(Option[Int].None()))

    // Result: Ok path continues
    print("Result Ok path: ")
    println(try_result(Result[Int].Ok(100)))

    // Result: Error path returns early
    print("Result Error path: ")
    println(try_result(Result[Int].Error(box("err"))))

    // Result: Error propagation with _ binding
    let propagated = try_result_propagate(Result[Int].Error(box("error_msg")))
    print("Result error propagation: ")
    when propagated in {
        .Ok(v) then println(v.to_string()),
        .Error(e) then println(e.message()),
    }

    return 0
}
