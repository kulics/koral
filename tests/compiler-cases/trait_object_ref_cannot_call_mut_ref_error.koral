// EXPECT-ERROR: expected mut ref CounterOps, got ref CounterOps

trait CounterOps {
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public bump(self mut ref) Int = {
        self.value += 1
        return self.value
    }
}

let main() Int = {
    let strong mut ref Counter = box(Counter(1))
    let obj ref CounterOps = strong
    let _ = obj.bump()
    return 0
}
