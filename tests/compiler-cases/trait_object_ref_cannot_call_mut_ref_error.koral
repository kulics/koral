// EXPECT-ERROR: expected CounterOps mut ref, got CounterOps ref

trait CounterOps {
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public bump(self mut ref) Int = {
        self.value += 1
        return self.value
    }
}

let main() Int = {
    let strong Counter mut ref = box(Counter(1))
    let obj CounterOps ref = strong
    let _ = obj.bump()
    return 0
}
