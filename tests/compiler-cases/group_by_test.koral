// EXPECT: group_by_ok

let main() Void = {
    let mut values = [Int]List.new()
    values.push(1)
    values.push(2)
    values.push(3)
    values.push(4)
    values.push(5)
    values.push(6)

    let groups = values.group_by((x) -> if x % 2 == 0 then "even" else "odd")

    assert(groups.count() == 2, "group count")
    assert(groups.contains_key("even"), "contains even")
    assert(groups.contains_key("odd"), "contains odd")

    let evens = groups.get("even").unwrap()
    assert(evens.count() == 3, "even count")
    assert(evens[0] == 2 and evens[1] == 4 and evens[2] == 6, "even order")

    let odds = groups.get("odd").unwrap()
    assert(odds.count() == 3, "odd count")
    assert(odds[0] == 1 and odds[1] == 3 and odds[2] == 5, "odd order")

    let empty = [Int]List.new()
    let empty_groups = empty.group_by((x) -> x % 2)
    assert(empty_groups.count() == 0, "empty group_by")

    println("group_by_ok")
}
