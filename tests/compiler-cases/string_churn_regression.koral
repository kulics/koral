// EXPECT: String churn regression passed

let build_fragment(seed Int) String = {
    let raw = "  alpha-beta-gamma-delta-epsilon-zeta  "
    let trimmed = raw.trim_ascii()
    let replaced = trimmed.replace_all("-", with: "_")
    let prefix = replaced.substring(..<5)
    let suffix = replaced.substring(6..)
    let mut out = String.zero()
    out.push_string(prefix)
    out.push_byte(':')
    out.push_string(seed.to_string())
    out.push_byte(':')
    out.push_string(suffix)
    yield out
}

let churn_round(seed Int, steps Int) String = {
    let mut acc = String.zero()
    let mut i = 0
    while i < steps then {
        let fragment = build_fragment(seed + i)
        acc.push_string(fragment)
        if acc.count() > (UInt)512 then {
            acc = acc.substring(64..)
        }
        i += 1
    }

    yield if acc.count() > (UInt)96 then {
        yield acc.substring(..<96)
    } else {
        yield acc
    }
}

let main() Int = {
    let mut carry = String.zero()
    let mut round = 0

    while round < 12 then {
        let payload = churn_round(round * 100, 200)
        let mut tagged = "xy".repeat((UInt)4)
        tagged.push_byte(':')
        tagged.push_string(payload)
        carry = if tagged.count() > (UInt)48 then {
            yield tagged.substring(..<48)
        } else {
            yield tagged
        }
        round += 1
    }

    assert(carry.contains("alpha"), "carry should preserve payload content")
    assert(carry.starts_with("xyxyxyxy:"), "carry should preserve repeated prefix")
    assert(carry.find(":").is_some(), "carry should contain separator")
    println("String churn regression passed")
    yield 0
}