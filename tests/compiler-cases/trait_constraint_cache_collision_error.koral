// EXPECT-ERROR: does not explicitly implement trait Beta

trait Alpha {
    keep(self) Self
}

trait Beta {
    keep(self) Self
}

type Box(v Int)

given Box as Alpha {

    keep(self) Self = self
}

let id[T Alpha](x T) T = x
let need_beta[T Beta](x T) T = x

let main() Int = {
    let b = Box(1)
    let x = id(b)
    let _ = need_beta(x)
    return 0
}
