// Test case for recursive enum with generic type
// EXPECT: Test passed!

public type Expr {
    Number(value Int),
    BinaryOp(left ref Expr, right ref Expr),
    FunctionCall(name String, args List[ref Expr]),
}

public let parse() Result[ref Expr] = {
    let expr = box(Expr.Number(42))
    return Result[ref Expr].Ok(expr)
}

public let main() Void = {
    when parse() in {
        .Ok(expr) then println("Test passed!"),
        .Error(msg) then println(msg.message()),
    }
}
