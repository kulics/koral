// EXPECT: true

trait MyEq {
    equals(self, other Self) Bool
}

given MyEq {

    neq(self, other Self) Bool = not self.equals(other)
}

type Num(x Int)

given Num as MyEq {

    equals(self, other Num) Bool = self.x == other.x
}

let differs[T MyEq](a T, b T) Bool = a.neq(b)

let main() Int = {
    println(differs(Num(1), Num(2)))
    return 0
}
