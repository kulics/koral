// EXPECT: 7

trait CounterOps {
    peek(self ref) Int
}

type Counter(value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let choose(flag Bool, left ref mut CounterOps, right ref CounterOps) ref CounterOps =
    if flag then left else right

let main() Int = {
    let strong ref mut Counter = box(Counter(7))
    let left ref mut CounterOps = strong
    let right ref CounterOps = left
    let chosen = choose(true, left, right)
    println(chosen.peek().to_string())
    return 0
}