// EXPECT: before: 2
// EXPECT: after replace: 2
// EXPECT: after deinit: 1

let get_shared(v Int ref) Int ref = v

let main() Int = {
    let mut x = 1
    let shared Int ref = x.ref

    let p = [Int ref]alloc_memory(1)
    init_memory(p, shared)

    print("before: ")
    println(ref_count(shared))

    p.val = get_shared(shared)

    print("after replace: ")
    println(ref_count(shared))

    deinit_memory(p)
    print("after deinit: ")
    println(ref_count(shared))

    dealloc_memory(p)
    yield 0
}
