// EXPECT: before: false
// EXPECT: after replace: false
// EXPECT: after deinit: true

let get_shared(v ref Int) ref Int = v

let main() Int = {
    let mut x = 1
    let shared ref Int = x.ref

    let p = alloc_memory[ref Int](1)
    init_memory(p, shared)

    print("before: ")
    println(is_unique_mutable(shared))

    p.val = get_shared(shared)

    print("after replace: ")
    println(is_unique_mutable(shared))

    deinit_memory(p)
    print("after deinit: ")
    println(is_unique_mutable(shared))

    dealloc_memory(p)
    return 0
}
