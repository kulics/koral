// EXPECT: All BufWriter tests passed

using std::io { .. }

let main() Void = {
    // === write + flush ===
    let dst1 = ByteBuffer.new()
    let w1 = BufWriter[ByteBuffer].new(dst1)
    let ws1 = w1.write_string("hello")
    when ws1 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "write_string error"),
    }
    let f1 = w1.flush()
    when f1 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush error"),
    }

    // === write_byte ===
    let dst2 = ByteBuffer.new()
    let w2 = BufWriter[ByteBuffer].new(dst2)
    let wb1 = w2.write_byte(65)
    when wb1 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "write_byte error"),
    }
    let wb2 = w2.write_byte(66)
    when wb2 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "write_byte 2 error"),
    }
    let f2 = w2.flush()
    when f2 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush 2 error"),
    }

    // === write_line ===
    let dst3 = ByteBuffer.new()
    let w3 = BufWriter[ByteBuffer].new(dst3)
    let wl = w3.write_line("line1")
    when wl in {
        .Ok(_) then {},
        .Error(_) then assert(false, "write_line error"),
    }
    let f3 = w3.flush()
    when f3 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush 3 error"),
    }

    // === write_rune (ASCII) ===
    let dst4 = ByteBuffer.new()
    let w4 = BufWriter[ByteBuffer].new(dst4)
    let wr1 = w4.write_rune(Rune.from_uint32_unchecked(65(UInt32)))
    when wr1 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "write_rune error"),
    }
    let f4 = w4.flush()
    when f4 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush 4 error"),
    }

    // === write_rune (2-byte: é = U+00E9) ===
    let dst5 = ByteBuffer.new()
    let w5 = BufWriter[ByteBuffer].new(dst5)
    let wr2 = w5.write_rune(Rune.from_uint32_unchecked(233(UInt32)))
    when wr2 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "write_rune 2-byte error"),
    }
    let f5 = w5.flush()
    when f5 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush 5 error"),
    }

    // === write_rune (3-byte: 中 = U+4E2D) ===
    let dst5b = ByteBuffer.new()
    let w5b = BufWriter[ByteBuffer].new(dst5b)
    let wr2b = w5b.write_rune(Rune.from_uint32_unchecked(20013(UInt32)))
    when wr2b in {
        .Ok(_) then {},
        .Error(_) then assert(false, "write_rune 3-byte error"),
    }
    let f5b = w5b.flush()
    when f5b in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush 5b error"),
    }

    // === auto-flush (small capacity) ===
    let dst6 = ByteBuffer.new()
    let w6 = BufWriter[ByteBuffer].with_capacity(4(UInt), dst6)
    let mut i Int = 0
    while i < 5 then {
        let wr = w6.write_byte((65 + i)(UInt8))
        when wr in {
            .Ok(_) then {},
            .Error(_) then assert(false, "auto-flush write error"),
        }
        i += 1
    }
    let f6 = w6.flush()
    when f6 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush 6 error"),
    }

    // === multiple write_string + flush ===
    let dst7 = ByteBuffer.new()
    let w7 = BufWriter[ByteBuffer].new(dst7)
    let _ = w7.write_string("foo")
    let _ = w7.write_string("bar")
    let _ = w7.write_string("baz")
    let f7 = w7.flush()
    when f7 in {
        .Ok(_) then {},
        .Error(_) then assert(false, "flush 7 error"),
    }

    // === constrained Seeker impl (W: Writer and Seeker) ===
    let dst8 = ByteBuffer.new()
    let w8 = BufWriter[ByteBuffer].with_capacity(16(UInt), dst8)
    w8.write_string("abc").unwrap()
    let pos8 = w8.seek(SeekOrigin.Start(0)).unwrap()
    assert(pos8 == 0(UInt64), "bufwriter seek returns position")
    w8.flush().unwrap()
    dst8.seek(SeekOrigin.Start(0)).unwrap()
    let mut out8 = make_bytes(8)
    let n8 = dst8.read(into: out8.ref, ..).unwrap()
    assert(n8 == 3, "bufwriter seek flushed pending bytes")
    assert(String.from_utf8_ptr(out8.borrow_ptr(), n8).unwrap() == "abc", "bufwriter seek flush content")

    println("All BufWriter tests passed")
}
