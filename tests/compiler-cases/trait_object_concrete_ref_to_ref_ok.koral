// EXPECT: 9

trait CounterOps {
    peek(self ref) Int
}

type Counter(value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let main() Int = {
    let strong mut ref Counter = box(Counter(9))
    let readonly ref Counter = strong
    let obj ref CounterOps = readonly
    println(obj.peek().to_string())
    return 0
}