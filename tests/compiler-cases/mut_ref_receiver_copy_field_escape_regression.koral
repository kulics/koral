// EXPECT: receiver field: start-updated

public type Holder(mut text String)

given Holder {
    public new(text String) Holder = Holder(text)

    public preserve(self mut ref) Void = {
        let saved = self.text
        self.text = "temporary"
        self.text = saved
    }

    public append_suffix(self mut ref, suffix String) Void = {
        self.text = self.text + suffix
    }
}

let main() Void = {
    let mut holder = Holder.new("start")
    holder.preserve()
    holder.append_suffix("-updated")
    println("receiver field: " + holder.text)
}