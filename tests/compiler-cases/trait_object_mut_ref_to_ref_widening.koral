// EXPECT: 4
// EXPECT: 4

trait CounterOps {
    peek(self ref) Int
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value

    public bump(self mut ref) Int = {
        self.value += 1
        return self.value
    }
}

let read_counter(counter ref CounterOps) Int = counter.peek()

let main() Int = {
    let strong mut ref Counter = box(Counter(4))
    let counter mut ref CounterOps = strong
    let readonly ref CounterOps = counter

    println(read_counter(counter).to_string())
    println(readonly.peek().to_string())
    return 0
}