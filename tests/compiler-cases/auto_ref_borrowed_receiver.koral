// EXPECT: PASS

// Positive test: auto-ref should work for borrowed receivers (self ref).

type Counter(mut value Int)

given Counter {
    public get(self ref) Int = self.value
}

let main() Int = {
    let c = Counter(42)
    let v = c.get()
    if v <> 42 then {
        eprintln("FAIL: expected 42, got \(v)")
        return 1
    }
    println("PASS")
    return 0
}
