// EXPECT: 10
// EXPECT: 77

let compute(stop Bool) [Int]Option = {
    if stop then {
        return [Int]Option.None()
    }

    let value = 77
    return [Int]Option.Some(value)
}

let print_option(opt [Int]Option) Void = {
    when opt in {
        .Some(value) then println(value),
        .None then println(10),
    }
}

let main() Int = {
    print_option(compute(true))
    print_option(compute(false))
    yield 0
}