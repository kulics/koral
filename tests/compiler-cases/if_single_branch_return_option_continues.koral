// EXPECT: 10
// EXPECT: 77

let compute(stop Bool) Option[Int] = {
    if stop then {
        return Option[Int].None()
    }

    let value = 77
    return Option[Int].Some(value)
}

let print_option(opt Option[Int]) Void = {
    when opt in {
        .Some(value) then println(value),
        .None then println(10),
    }
}

let main() Int = {
    print_option(compute(true))
    print_option(compute(false))
    return 0
}