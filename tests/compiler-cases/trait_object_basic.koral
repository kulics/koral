// Test trait object creation and explicit Wrapper trait implementation
// EXPECT: hello from Greeter
// EXPECT: wrapped(hello from Greeter)

trait Greet {
    greet(self ref) String
}

type Greeter(name String)

given Greeter as Greet {

    public greet(self ref) String = "hello from " + self.name
}

type Wrapper(inner ref Greet)

given Wrapper as Greet {

    public greet(self ref) String = {
        let mut s = "wrapped("
        s.push_string(self.inner.greet())
        s.push_string(")")
        return s
    }
}

let main() Int = {
    let g1 = box(Greeter("Greeter"))
    let g ref Greet = g1
    println(g.greet())

    let w = box(Wrapper(g))
    let g2 ref Greet = w
    println(g2.greet())

    return 0
}
