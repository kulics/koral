// EXPECT: true
// EXPECT: false

trait MyEq[T Any] {
    equals(self, other T) Bool
}

given[T Any] MyEq[T] {
    neq(self, other T) Bool = not self.equals(other)
}

type Num(x Int)

given Num as MyEq[Num] {

    equals(self, other Num) Bool = self.x == other.x
}

let main() Int = {
    let a = Num(1)
    let b = Num(2)
    println(a.(MyEq)neq(b))
    println(a.neq(a))
    return 0
}
