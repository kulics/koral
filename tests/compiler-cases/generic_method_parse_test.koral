// Test parsing of generic methods
// EXPECT: 42

public type Box[T Any] {
    Value(v T),
}

given[T Any] Box[T] {
    public unwrap(self) T = when self in {
        .Value(v) then v,
    }
    
    // Method with method-level type parameter
    public transform[U Any](self, f Func[T, U]) U = f(self.unwrap())
}

let main() Int = {
    let box = Box[Int].Value(42)
    let result = box.transform[Int]((x) -> x)
    println(result.to_string())
    return 0
}
