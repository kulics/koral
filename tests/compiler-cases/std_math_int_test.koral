// std.math integer unit tests
// EXPECT: abs_ok
// EXPECT: ipow_ok
// EXPECT: gcd_ok
// EXPECT: lcm_ok
// EXPECT: ilog_ok
// EXPECT: wrapping_ok
// EXPECT: zero_ok
// EXPECT: uint_ok
// EXPECT: gcd_all_int_types_ok

using std::math { .. }

let main() Int = {
    // abs
    if (-5).abs() == 5 and 0.abs() == 0 and 5.abs() == 5 then {
        println("abs_ok")
    }

    // pow (member)
    if 2.pow(10) == 1024 and 3.pow(0) == 1 then {
        println("ipow_ok")
    }

    // gcd
    if gcd(12, 8) == 4 and gcd(7, 13) == 1 and gcd(-12, 8) == 4 then {
        println("gcd_ok")
    }

    // lcm
    if lcm(4, 6) == 12 and lcm(3, 5) == 15 and lcm(-4, 6) == 12 then {
        println("lcm_ok")
    }

    // ilog2, ilog10
    if ilog2(8) == 3 and ilog2(1) == 0 and ilog2(15) == 3 and ilog10(1000) == 3 and ilog10(1) == 0 and ilog10(999) == 2 then {
        println("ilog_ok")
    }

    // wrapping_abs, wrapping_pow
    let wa = Int8.min_value().wrapping_abs()
    let wp = 2.wrapping_pow(64)
    // wrapping_abs of Int8.min_value() wraps to Int8.min_value() (-128)
    // wrapping_pow(2, 64) wraps to 0
    if wa == Int8.min_value() and wp == 0 then {
        println("wrapping_ok")
    }

    // zero edge cases
    if gcd(0, 5) == 5 and gcd(5, 0) == 5 and gcd(0, 0) == 0 and lcm(0, 5) == 0 and lcm(0, 0) == 0 then {
        println("zero_ok")
    }

    // UInt operations (through Integer trait)
    let up = (2(UInt)).pow(10)
    let ug = gcd(12(UInt), 8(UInt))
    let ul = lcm(4(UInt), 6(UInt))
    let ui2 = ilog2(8(UInt))
    let ui10 = ilog10(1000(UInt))
    if up == 1024 and ug == 4 and ul == 12 and ui2 == 3 and ui10 == 3 then {
        println("uint_ok")
    }

    // gcd across all integer primitive types (enforces Integer conformance)
    if gcd(12(Int8), 8(Int8)) == 4(Int8)
        and gcd(12(Int16), 8(Int16)) == 4(Int16)
        and gcd(12(Int32), 8(Int32)) == 4(Int32)
        and gcd(12(Int64), 8(Int64)) == 4(Int64)
        and gcd(12(UInt8), 8(UInt8)) == 4(UInt8)
        and gcd(12(UInt16), 8(UInt16)) == 4(UInt16)
        and gcd(12(UInt32), 8(UInt32)) == 4(UInt32)
        and gcd(12(UInt64), 8(UInt64)) == 4(UInt64) then {
        println("gcd_all_int_types_ok")
    }

    return 0
}
