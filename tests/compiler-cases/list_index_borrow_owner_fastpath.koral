// EXPECT: ref_at borrow before: 1
// EXPECT: ref_at borrow after: 1
// EXPECT: mut_ref_at borrow before: 1
// EXPECT: mut_ref_at borrow after: 1
// EXPECT: list_index_borrow_owner_fastpath ok

type FastListStorage[T Any](mut source mut ptr T, mut len UInt, cap UInt)

given[T Deref] FastListStorage[T] as Drop {

    drop(self mut ref) Void = {
        if ref_is_borrow(self) then {
            return
        }
        let mut i UInt = 0
        while i < self.len then {
            deinit_memory(self.source + i)
            i += 1
        }
        dealloc_memory(self.source)
    }
}

type FastList[T Any](mut storage mut ref FastListStorage[T])

given[T Deref] FastList[T] {

    new(cap UInt) Self = {
        let real_cap = if cap == 0 then 1 else cap
        let source = alloc_memory[T](real_cap)
        let storage = box(FastListStorage[T](source, 0, real_cap))
        return FastList[T](storage)
    }

    push(self mut ref, value T) Void = {
        if self.storage.len >= self.storage.cap then {
            panic("FastList capacity exceeded")
        }
        init_memory(self.storage.source + self.storage.len, value)
        self.storage.len += 1
    }

}

given[T Deref] FastList[T] as Index[UInt, T] {

    ref_at(self ref, key UInt) ref T = {
        if key >= self.storage.len then {
            panic("FastList index out of bounds")
        }

        if ref_is_borrow(self) then {
            print("ref_at borrow before: ")
            println(ref_count(self.storage))
            let out = make_ref[T, FastList[T]](self.storage.source + key, self)
            print("ref_at borrow after: ")
            println(ref_count(self.storage))
            return out
        }
        return make_ref[T, FastListStorage[T]](self.storage.source + key, self.storage)
    }
}

given[T Deref] FastList[T] as MutIndex[UInt, T] {

    mut_ref_at(self mut ref, key UInt) mut ref T = {
        if key >= self.storage.len then {
            panic("FastList index out of bounds")
        }

        if ref_is_borrow(self) then {
            print("mut_ref_at borrow before: ")
            println(ref_count(self.storage))
            let out = make_mut_ref[T, FastList[T]](self.storage.source + key, self)
            print("mut_ref_at borrow after: ")
            println(ref_count(self.storage))
            return out
        }
        return make_mut_ref[T, FastListStorage[T]](self.storage.source + key, self.storage)
    }
}

let test_single_read() Void = {
    let mut a = 11
    let mut b = 22

    let mut xs = FastList[ref Int].new(4)
    xs.push(a.ref)
    xs.push(b.ref)

    let r = xs[1]
    assert(r.val == 22, "index read value")
}

let test_single_write() Void = {
    let mut a = 1
    let mut b = 2
    let mut c = 3

    let mut xs = FastList[ref Int].new(4)
    xs.push(a.ref)
    xs.push(b.ref)

    xs[0] = c.ref
    let r = xs[0]
    assert(r.val == 3, "index write value")
}

let main() Void = {
    test_single_read()
    test_single_write()
    println("list_index_borrow_owner_fastpath ok")
}
