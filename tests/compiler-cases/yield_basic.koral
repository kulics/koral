// Test basic branch-yield functionality
// EXPECT: 42
// EXPECT: 7
// EXPECT: hello
// EXPECT: 10
// EXPECT: 20
// EXPECT: 99
// EXPECT: void_block_ok
// EXPECT: empty_block_ok
// EXPECT: nested_branch_yield_ok
// EXPECT: All yield basic tests passed

// Test 1: return in function body
let get_value() Int = {
    return 42
}

// Test 2: return with computation
let compute() Int = {
    let a = 3
    let b = 4
    return a + b
}

// Test 3: return with String
let get_greeting() String = {
    let name = "hello"
    return name
}

// Test 4: yield in if/else branches
let pick(flag Bool) Int = {
    return if flag then {
        yield 10
    } else {
        yield 20
    }
}

// Test 5: yield in when branches
type Color {
    Red(),
    Blue(),
}

let color_value(c Color) Int = {
    return when c in {
        .Red then 99,
        .Blue then 0,
    }
}

// Test 6: block without yield produces Void (used as statement)
let void_block_test() Void = {
    let x = 1
    let y = 2
    let _ = x + y
    // no yield — block type is Void
}

// Test 7: empty block produces Void
let empty_block_test() Void = {
}

// Test 8: nested branch yield
let nested_branch_yield(flag Bool) Int = {
    return if flag then {
        let a = 50
        yield a + 49
    } else {
        yield 0
    }
}

let main() Int = {
    println(get_value())
    println(compute())
    println(get_greeting())
    println(pick(true))
    println(pick(false))
    println(color_value(Color.Red()))

    void_block_test()
    println("void_block_ok")

    empty_block_test()
    println("empty_block_ok")

    // Nested branch yield
    if nested_branch_yield(true) == 99 then {
        println("nested_branch_yield_ok")
    }

    println("All yield basic tests passed")
    return 0
}
