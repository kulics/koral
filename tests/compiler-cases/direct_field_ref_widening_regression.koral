// EXPECT: ok

type Kind {
    A(),
    B(),
}

given Kind not Deref

type Expr(kind ref Kind)

let read(expr Expr) ref Kind = expr.kind

let classify(kind ref Kind) Int = when kind in {
    .A() then 1,
    .B() then 2,
}

let main() Void = {
    let kind_a mut ref Kind = box(Kind.A())
    let expr = Expr(kind_a)
    assert(classify(read(expr)) == 1, "field ref should remain readonly")
    println("ok")
}
