// EXPECT: ok

type Kind {
    A(),
    B(),
}

given Kind not Deref

type Expr(kind Kind ref)

let read(expr Expr) Kind ref = expr.kind

let classify(kind Kind ref) Int = when kind in {
    .A() then 1,
    .B() then 2,
}

let main() Void = {
    let kind_a Kind mut ref = box(Kind.A())
    let expr = Expr(kind_a)
    assert(classify(read(expr)) == 1, "field ref should remain readonly")
    println("ok")
}
