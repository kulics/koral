// Test that valid single-branch if patterns still compile and run correctly
// Valid: Void body (println, assignment), Never body (return, break, continue, panic)
// EXPECT: void_body_ok
// EXPECT: return_body_ok:1
// EXPECT: return_body_ok:2
// EXPECT: break_body_ok
// EXPECT: continue_body_ok:12
// EXPECT: pattern_void_ok

type MyOption {
    Some(value Int),
    None(),
}

let early(x Int) Int = {
    if x > 0 then {
        return 1
    }
    yield 2
}

let main() Int = {
    // Void body: println returns Void
    let x = true
    if x then { println("void_body_ok") }

    // Never body via return
    print("return_body_ok:")
    println(early(1))
    print("return_body_ok:")
    println(early(0 - 1))

    // Never body via break
    let mut sum = 0
    let mut i = 0
    while i < 10 then {
        i = i + 1
        if i == 5 then { break }
        sum = sum + i
    }
    println("break_body_ok")

    // Never body via continue
    let mut total = 0
    let mut j = 0
    while j < 5 then {
        j = j + 1
        if j == 3 then { continue }
        total = total + j
    }
    print("continue_body_ok:")
    println(total)

    // Void body in if...is pattern
    let opt = MyOption.Some(42)
    let mut result = 0
    if opt is .Some(v) then {
        result = v
    }
    if result == 42 then { println("pattern_void_ok") }

    yield 0
}
