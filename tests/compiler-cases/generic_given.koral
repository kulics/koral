type Box[T Any](mut value T)

given[T Any] Box[T] {
    get_val(self ref) T = self.value
    
    set_val(self mut ref, v T) Void = {
        self.value = v
    }
}

let main() Void = {
    let mut b = Box[Int](10)
    println(b.get_val())
    b.set_val(20)
    println(b.get_val())
}
// EXPECT: 10
// EXPECT: 20
