// EXPECT: ok

type Cell(value Int)

let read(cell Cell ref) Int = cell.value

let main() Void = {
    let mutable Cell mut ref = box(Cell(2))
    let fallback Cell ref = mutable
    let selected = when true in {
        true then {
            yield box(Cell(1))
        },
        false then fallback,
    }

    assert(read(selected) == 1, "selected value")
    println("ok")
}
