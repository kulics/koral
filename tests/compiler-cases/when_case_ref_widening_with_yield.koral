// EXPECT: ok

type Cell(value Int)

let read(cell ref Cell) Int = cell.value

let main() Void = {
    let mutable mut ref Cell = box(Cell(2))
    let fallback ref Cell = mutable
    let selected = when true in {
        true then {
            yield box(Cell(1))
        },
        false then fallback,
    }

    assert(read(selected) == 1, "selected value")
    println("ok")
}
