// EXPECT-ERROR: Type mismatch: expected ref mut Counter, got Counter

// This test verifies that passing a value to a function expecting ref mut
// produces a type mismatch error. Implicit ref promotion is not allowed;
// use explicit .ref syntax instead.

type Counter(mut value Int)

let increment(c ref mut Counter) Void = {
    c.value += 1
}

let main() Int = {
    let x = Counter(0)
    increment(x)
    return 0
}
