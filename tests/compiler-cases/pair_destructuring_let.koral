// Test let pair destructuring
// EXPECT: basic: 1 2
// EXPECT: typed: 3 hello
// EXPECT: discard_first: 20
// EXPECT: discard_second: 10
// EXPECT: mutable: 99 200
// EXPECT: nested_pair: 5 6
// EXPECT: from_function: 42 ok
// EXPECT: generic_pair: 7 true
// EXPECT: mixed: 50 world

using Std.*

let make_pair() [Int, String]Pair = (42, "ok")

let main() Int = {
    // Basic pair destructuring
    let (a, b) = (1, 2)
    println("basic: \(a) \(b)")

    // With type annotations
    let (c Int, d String) = (3, "hello")
    println("typed: \(c) \(d)")

    // Discard first element
    let (_, e) = (10, 20)
    println("discard_first: \(e)")

    // Discard second element
    let (f, _) = (10, 20)
    println("discard_second: \(f)")

    // Mutable bindings
    let (mut g, mut h) = (1, 2)
    g = 99
    h = 200
    println("mutable: \(g) \(h)")

    // From a variable holding a pair
    let p = (5, 6)
    let (i, j) = p
    println("nested_pair: \(i) \(j)")

    // From a function returning a pair
    let (k, l) = make_pair()
    println("from_function: \(k) \(l)")

    // Generic pair
    let gp = [Int, Bool]Pair(7, true)
    let (m, n) = gp
    println("generic_pair: \(m) \(n)")

    // Mixed: mut with type, discard
    let (mut o Int, q String) = (50, "world")
    println("mixed: \(o) \(q)")

    yield 0
}
