// Test or return diagnostics inside finally expression
// EXPECT-ERROR: control flow statement 'return' is not allowed in finally expression

let invalid_finally() [Int]Result = {
    finally {
        let value = [Int]Result.Error(box("boom")) or return
        println(value.to_string())
    }
    return [Int]Result.Ok(0)
}

let main() Int = {
    let _ = invalid_finally()
    return 0
}