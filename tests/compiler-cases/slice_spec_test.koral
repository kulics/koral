// EXPECT: list_slice_spec_closed_open_ok
// EXPECT: list_slice_spec_from_ok
// EXPECT: string_slice_spec_full_ok
// EXPECT: string_slice_spec_slice_ok

let main() Void = {
    let mut values = [Int]List.new()
    values.push(10)
    values.push(20)
    values.push(30)
    values.push(40)

    let list_span = values.slice_spec(1..<3)
    assert(list_span.start() == 1, "list start")
    assert(list_span.end() == 3, "list end")
    assert(list_span.offset() == 1, "list offset")
    assert(list_span.len() == 2, "list len")
    println("list_slice_spec_closed_open_ok")

    let from_span = values.slice_spec(2..)
    assert(from_span.start() == 2, "from start")
    assert(from_span.end() == 4, "from end")
    assert(from_span.offset() == 2, "from offset")
    assert(from_span.len() == 2, "from len")
    println("list_slice_spec_from_ok")

    let text = "hello"
    let full_span = text.slice_spec(..)
    assert(full_span.start() == 0, "string full start")
    assert(full_span.end() == 5, "string full end")
    assert(full_span.offset() == 0, "string full offset")
    assert(full_span.len() == 5, "string full len")
    println("string_slice_spec_full_ok")

    let slice_span = text.slice_spec(1..<(text.count() - 1))
    assert(slice_span.start() == 1, "string slice start")
    assert(slice_span.end() == 4, "string slice end")
    assert(slice_span.offset() == 1, "string slice offset")
    assert(slice_span.len() == 3, "string slice len")
    println("string_slice_spec_slice_ok")
}