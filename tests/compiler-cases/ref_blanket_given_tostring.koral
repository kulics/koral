// Tests that T ref satisfies ToString when T implements ToString (blanket given)
// Feature: type-modifier-trait-conformance

type Wrapper(value Int)

given Wrapper as ToString {

    public to_string(self ref) String = "Wrapper(" + self.value.to_string() + ")"
}

let print_it[T ToString](x T) Void = println(x.to_string())

let main() Void = {
    let mut w = Wrapper(42)
    let r = w.ref
    print_it(r)
}
// EXPECT: Wrapper(42)
