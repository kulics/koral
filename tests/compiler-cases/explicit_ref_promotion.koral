// EXPECT: PASS

// Positive test: explicit .ref promotion should work for function arguments.

let takes_ref(x ref Int) Int = x

let main() Int = {
    let x = 42
    let r = takes_ref(x.ref)
    if r <> 42 then {
        eprintln("FAIL: expected 42, got \(r)")
        return 1
    }
    println("PASS")
    return 0
}
