// EXPECT: block expression break regression passed

let main() Void = {
    let mut iterations = 0
    let mut values = List[Int].new()
    let mut iter = values.iterator()

    while true then {
        when iter.next() in {
            .Some(_) then {
                iterations += 1
            },
            .None then {
                {
                    break
                }
            },
        }
    }

    assert(iterations == 0, "break inside nested block should exit enclosing loop")
    println("block expression break regression passed")
}
