// EXPECT: sub-slot-after-read: 1
// EXPECT: sub-slot-after-once: 1
// EXPECT: sub-slot-after-loop: 1
// EXPECT: sub-slot-values: 20 20
// EXPECT: sub-before: 2
// EXPECT: sub-after-once: 4
// EXPECT: sub-after-loop: 4
// EXPECT: sub-values: 20 20
