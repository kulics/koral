// Test generic methods with method-level type parameters
// EXPECT: 84

public type MyOption[T Any] {
    None(),
    Some(value T),
}

given[T Any] MyOption[T] {
    public is_some(self) Bool = when self in {
        .Some(_) then true,
        .None then false,
    }

    public unwrap(self) T = when self in {
        .Some(v) then v,
        .None then panic("unwrap failed"),
    }

    // Generic method with method-level type parameter
    // Return type is just U, not [U]MyOption
    public transform[U Any](self, f Func[T, U]) U = when self in {
        .Some(v) then f(v),
        .None then panic("transform on None"),
    }
}

let main() Int = {
    let opt = MyOption[Int].Some(42)
    let doubled = opt.transform[Int]((x) -> x * 2)
    println(doubled.to_string())
    return 0
}
