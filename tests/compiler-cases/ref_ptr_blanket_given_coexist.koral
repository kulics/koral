// Tests that blanket given for T ref Eq and T ptr Eq coexist without conflict
// Feature: type-modifier-trait-conformance

type Item(id Int)

given Item as Eq {

    public equals(self, other Item) Bool = self.id == other.id
}

let ref_equal[T Eq and Deref](a ref T, b ref T) Bool = a == b

let main() Void = {
    let mut i1 = Item(1)
    let mut i2 = Item(1)
    let mut i3 = Item(2)
    let a = i1.ref
    let b = i2.ref
    let c = i3.ref
    println(ref_equal(a, b))
    println(ref_equal(a, c))
}
// EXPECT: true
// EXPECT: false
