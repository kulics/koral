// Tests that T ref ref satisfies ToString when T implements ToString.
// This exercises recursive blanket given lookup for ref-like receivers.
// EXPECT: Wrapper(42)

type Wrapper(value Int)

given Wrapper as ToString {

    public to_string(self ref) String = "Wrapper(" + self.value.to_string() + ")"
}

let [T ToString] print_it(x T) Void = println(x.to_string())

let main() Void = {
    let mut w = Wrapper(42)
    let inner = w.ref
    let mut outer_base = inner
    let outer = outer_base.ref
    print_it(outer)
}
