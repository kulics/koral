// EXPECT: start
// EXPECT: Holder dropped
// EXPECT: Holder dropped
// EXPECT: end

type Holder[T Any](value T)

given[T Any] Holder[T] as Drop {
    drop(self mut ref) Void = {
        println("Holder dropped")
    }
}

let main() Int = {
    println("start")
    {
        let a = Holder[Int](1)
        let b = Holder[String]("ok")
    }
    println("end")
    return 0
}
