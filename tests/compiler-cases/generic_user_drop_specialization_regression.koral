// EXPECT: start
// EXPECT: Holder dropped
// EXPECT: Holder dropped
// EXPECT: end

type [T Any]Holder(value T)

given [T Any] [T]Holder Drop {
    drop(self mut ref) Void = {
        println("Holder dropped")
    }
}

let main() Int = {
    println("start")
    {
        let a = [Int]Holder(1)
        let b = [String]Holder("ok")
    }
    println("end")
    yield 0
}
