// EXPECT: start
// EXPECT: Holder dropped
// EXPECT: Holder dropped
// EXPECT: end

type Holder[T Any](raw mut ptr T)

given[T Any] Holder[T] as Drop {
    drop(source mut ptr Self) Void = {
        println("Holder dropped")
    }
}

let main() Int = {
    println("start")
    {
        let a = Holder[Int](null_ptr[Int]())
        let b = Holder[UInt8](null_ptr[UInt8]())
    }
    println("end")
    return 0
}
