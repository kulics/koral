// EXPECT: for-range literal inference regression ok

let sum_digits(s String) UInt = {
    let mut total UInt = 0
    for i in 0..<s.count() then {
        total += (s[i] - '0')(UInt)
    }
    return total
}

let main() Void = {
    let mut seen UInt = 0
    for i in 0..<"123".count() then {
        seen += i
    }

    assert(seen == 3, "range literal should infer UInt from count()")
    assert(sum_digits("123") == 6, "string index should accept inferred loop variable type")
    println("for-range literal inference regression ok")
}
