// EXPECT: ok

type Kind {
    A(),
    B(),
}

given Kind not Deref

type Expr(kind ref Kind)

let classify(expr ref Expr) Int = when expr.kind in {
    .A() then 1,
    .B() then 2,
}

let main() Void = {
    let kind_a ref mut Kind = box(Kind.A())
    let kind_b ref mut Kind = box(Kind.B())
    let expr_a = Expr(kind_a)
    let expr_b = Expr(kind_b)
    assert(classify(expr_a.ref) == 1, "A branch should match")
    assert(classify(expr_b.ref) == 2, "B branch should match")
    println("ok")
}
