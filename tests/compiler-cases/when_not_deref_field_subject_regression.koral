// EXPECT: ok

type Kind {
    A(),
    B(),
}

given Kind not Deref

type Expr(kind Kind ref)

let classify(expr Expr ref) Int = when expr.kind in {
    .A() then 1,
    .B() then 2,
}

let main() Void = {
    let kind_a Kind mut ref = box(Kind.A())
    let kind_b Kind mut ref = box(Kind.B())
    let expr_a = Expr(kind_a)
    let expr_b = Expr(kind_b)
    assert(classify(expr_a) == 1, "A branch should match")
    assert(classify(expr_b) == 2, "B branch should match")
    println("ok")
}
