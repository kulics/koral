// Test or return propagation for Option and Result
// EXPECT: Option Some path: 14
// EXPECT: Option None path: None
// EXPECT: Result Ok path: 18
// EXPECT: Result Error path: err
// EXPECT: Precedence Ok path: 11
// EXPECT: Precedence Error path: boom

let print_option(label String, value Option[Int]) Void = {
    print(label)
    when value in {
        .Some(v) then println(v.to_string()),
        .None then println("None"),
    }
}

let print_result(label String, value Result[Int]) Void = {
    print(label)
    when value in {
        .Ok(v) then println(v.to_string()),
        .Error(e) then println(e.message()),
    }
}

let double_option(opt Option[Int]) Option[Int] = {
    let value = opt or return
    return Option[Int].Some(value * 2)
}

let double_result(res Result[Int]) Result[Int] = {
    let value = res or return
    return Result[Int].Ok(value * 2)
}

let double_then_increment(res Result[Int]) Result[Int] = {
    let value = res and then it * 2 or return
    return Result[Int].Ok(value + 1)
}

let main() Int = {
    print_option("Option Some path: ", double_option(Option[Int].Some(7)))
    print_option("Option None path: ", double_option(Option[Int].None()))
    print_result("Result Ok path: ", double_result(Result[Int].Ok(9)))
    print_result("Result Error path: ", double_result(Result[Int].Error(box("err"))))
    print_result("Precedence Ok path: ", double_then_increment(Result[Int].Ok(5)))
    print_result("Precedence Error path: ", double_then_increment(Result[Int].Error(box("boom"))))
    return 0
}