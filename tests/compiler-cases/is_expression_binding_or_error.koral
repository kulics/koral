// EXPECT-ERROR: Variable bindings in 'is' expression are not allowed in 'or' branches

type MyOption {
    None(),
    Some(value Int),
}

let main() Int = {
    let left = MyOption.Some(1)
    let right = MyOption.None()
    if left is .Some(value) or right is .Some(other) then {
        println("unexpected")
    }
    yield 0
}