// Tests for generic types and functions
// Combines: basic generic types, generic functions, pairs, and copy semantics

// === Basic Generic Type Tests ===
// EXPECT: 1
// EXPECT: hello
// EXPECT: 42

// === Generic Function Tests ===
// EXPECT: 42
// EXPECT: hello
// EXPECT: 10
// EXPECT: 20

// === Generic Pair Tests ===
// EXPECT: 1
// EXPECT: hello
// EXPECT: world
// EXPECT: 2

// === Generic Copy Tests ===
// EXPECT: 100
// EXPECT: 100
// EXPECT: 10
// EXPECT: 20
// EXPECT: 123
// EXPECT: 123

// ============================================================
// Generic Types
// ============================================================

// Simple generic box type
type Box[T Any](value T)

// Generic pair with two type parameters
type TestPair[T Any, U Any](first T, second U)

// Point type for copy testing
type Point(x Int, y Int)

// ============================================================
// Generic Functions
// ============================================================

// Identity function
let identity[T Any](x T) T = x

// Create a pair from two values of the same type
let makePair[T Any](a T, b T) TestPair[T, T] = {
    return TestPair[T, T](a, b)
}

// Duplicate a value into a pair
let duplicate[T Any](x T) TestPair[T, T] = {
    return TestPair[T, T](x, x)
}

// ============================================================
// Main function - runs all tests
// ============================================================

let main() Void = {
    // --- Basic Generic Type Tests ---
    
    // Box with Int
    let b1 = Box[Int](1)
    println(b1.value)
    
    // Box with String
    let b2 = Box[String]("hello")
    println(b2.value)
    
    // Box with reference type
    let r = box(42)
    let b3 = Box[ref Int](r)
    println(b3.value.val)
    
    // --- Generic Function Tests ---
    
    // Identity with Int
    println(identity(42))
    
    // Identity with String
    println(identity("hello"))
    
    // makePair function
    let p = makePair(10, 20)
    println(p.first)
    println(p.second)
    
    // --- Generic Pair Tests ---
    
    // Pair with Int and String
    let pair1 = TestPair[Int, String](1, "hello")
    println(pair1.first)
    println(pair1.second)
    
    // Pair with String and Int (reversed)
    let pair2 = TestPair[String, Int]("world", 2)
    println(pair2.first)
    println(pair2.second)
    
    // --- Generic Copy Tests ---
    
    // Duplicate primitive
    let dup1 = duplicate(100)
    println(dup1.first)
    println(dup1.second)
    
    // Duplicate struct
    let pt = Point(10, 20)
    let dup2 = duplicate(pt)
    println(dup2.first.x)
    println(dup2.second.y)
    
    // Duplicate reference
    let r2 = box(123)
    let dup3 = duplicate(r2)
    println(dup3.first.val)
    println(dup3.second.val)
}
