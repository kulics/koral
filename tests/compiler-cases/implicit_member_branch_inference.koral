// EXPECT: kw_let
// EXPECT: kw_mut

type Token {
    KwLet(),
    KwMut(),
}

let render(token Token) String = when token in {
    .KwLet() then "kw_let",
    .KwMut() then "kw_mut",
}

let main() Void = {
    let from_if = if true then Token.KwLet() else .KwMut()
    println(render(from_if))

    let from_when = when false in {
        true then Token.KwLet(),
        false then .KwMut(),
    }
    println(render(from_when))
}
