// EXPECT: nested_mut_ok
// EXPECT: ref_chain_break_ok
// EXPECT: ref_on_mut_lvalue_ok
// EXPECT: ref_on_mut_chain_ok

type Vec(mut x Int, mut y Int)
type Nest(mut vec Vec)
type Holder(link ref mut Vec)

let main() Int = {
    let mut n = Nest(Vec(1, 2))
    n.vec.x = 10
    if n.vec.x == 10 then {
        println("nested_mut_ok")
    }

    let h = Holder(box(Vec(3, 4)))
    h.link.x = 30
    if h.link.x == 30 then {
        println("ref_chain_break_ok")
    }

    let mut v = Vec(5, 6)
    let rv ref mut Vec = v.ref
    rv.x = 50
    if v.x == 50 then {
        println("ref_on_mut_lvalue_ok")
    }

    let mut n2 = Nest(Vec(7, 8))
    let rv2 ref mut Vec = n2.vec.ref
    rv2.x = 70
    if n2.vec.x == 70 then {
        println("ref_on_mut_chain_ok")
    }

    return 0
}
