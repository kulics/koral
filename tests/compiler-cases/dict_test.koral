// EXPECT: All Dict tests passed

let main() Int = {
    // === Basic Operations ===
    let mut m = Dict[Int, String].new()
    assert(m.count() == 0, "new dict count 0")
    assert(m.is_empty(), "new dict is_empty")

    // === insert ===
    m.insert(1, "one")
    assert(m.count() == 1, "count after insert")

    m.insert(2, "two")
    m.insert(3, "three")
    assert(m.count() == 3, "count 3")

    // Overwrite existing key
    m.insert(1, "ONE")
    assert(m.count() == 3, "count unchanged after overwrite")

    // === try_insert ===
    assert(not m.try_insert(1, "uno"), "try_insert existing returns false")
    assert(m.get(1).unwrap() == "ONE", "try_insert existing does not overwrite")
    assert(m.try_insert(4, "four"), "try_insert new returns true")
    assert(m.get(4).unwrap() == "four", "try_insert inserts new key")
    assert(m.count() == 4, "count after try_insert")

    // === get ===
    assert(m.get(1).unwrap() == "ONE", "get(1)")
    assert(m.get(2).unwrap() == "two", "get(2)")
    let get_missing = m.get(999)
    assert(get_missing.is_none(), "get missing key")

    // === get ===
    assert(m.get(1).unwrap() == "ONE", "get after overwrite")
    m.insert(2, "TWO")
    assert(m.get(2).unwrap() == "TWO", "insert overwrite")

    // === contains_key ===
    assert(m.contains_key(1), "contains_key existing")
    assert(not m.contains_key(999), "not contains_key missing")

    // === get_or_insert ===
    let got_existing = m.get_or_insert(2, "dos")
    assert(got_existing == "TWO", "get_or_insert existing")
    assert(m.get(2).unwrap() == "TWO", "get_or_insert existing unchanged")

    let got_new = m.get_or_insert(5, "five")
    assert(got_new == "five", "get_or_insert new")
    assert(m.get(5).unwrap() == "five", "get_or_insert inserted")

    // === remove ===
    let removed = m.take(1)
    assert(removed.unwrap() == "ONE", "take returns value")
    assert(m.count() == 3, "count after take")
    assert(not m.contains_key(1), "not contains_key after remove")
    let remove_missing = m.take(999)
    assert(remove_missing.is_none(), "take missing")
    assert(m.try_remove(2), "try_remove existing")
    assert(not m.try_remove(999), "try_remove missing")
    m.remove(3)
    m.remove(999)
    assert(not m.contains_key(3), "remove existing key")
    assert(m.count() == 1, "count after remove and try_remove")

    // === clear ===
    m.clear()
    assert(m.count() == 0, "count after clear")
    assert(m.is_empty(), "is_empty after clear")

    // === Rehash test ===
    let mut m2 = Dict[Int, Int].new()
    let mut i = 0
    while i < 50 then {
        m2.insert(i, i * 10)
        i = i + 1
    }
    assert(m2.count() == 50, "count after 50 inserts")

    i = 0
    while i < 50 then {
        assert(m2.get(i).unwrap() == i * 10, "value after rehash")
        i = i + 1
    }

    // === iterator ===
    let mut m3 = Dict[Int, String].new()
    m3.insert(10, "ten")
    m3.insert(20, "twenty")
    m3.insert(30, "thirty")

    let mut count = 0
    let mut key_sum = 0
    for entry in m3.iterator() then {
        count = count + 1
        key_sum = key_sum + entry.first
    }
    assert(count == 3, "iterator count")
    assert(key_sum == 60, "iterator key sum")

    // === COW ===
    let mut original = Dict[Int, String].new()
    original.insert(1, "a")
    original.insert(2, "b")

    let mut copy = original

    copy.insert(3, "c")
    copy.insert(1, "A")

    assert(original.count() == 2, "original count unchanged")
    assert(original.get(1).unwrap() == "a", "original[1] unchanged")
    assert(not original.contains_key(3), "original not contains_key 3")

    assert(copy.count() == 3, "copy count")
    assert(copy.get(1).unwrap() == "A", "copy[1] modified")
    assert(copy.contains_key(3), "copy contains_key 3")

    // === String keys ===
    let mut sm = Dict[String, Int].new()
    sm.insert("apple", 1)
    sm.insert("banana", 2)
    assert(sm.get("apple").unwrap() == 1, "string key")
    assert(sm.contains_key("banana"), "contains_key string key")

    // === insert_all ===
    let mut ia1 = Dict[String, Int].new()
    ia1.insert("x", 1)
    ia1.insert("y", 2)
    let mut ia2 = Dict[String, Int].new()
    ia2.insert("y", 20)
    ia2.insert("z", 3)
    ia1.insert_dict(ia2)
    assert(ia1.count() == 3, "insert_all count")
    assert(ia1.get("x").unwrap() == 1, "insert_all keeps existing")
    assert(ia1.get("y").unwrap() == 20, "insert_all overwrites duplicate")
    assert(ia1.get("z").unwrap() == 3, "insert_all adds new")

    // insert_all empty dict
    let mut ia3 = Dict[Int, Int].new()
    ia3.insert(1, 10)
    let ia_empty = Dict[Int, Int].new()
    ia3.insert_dict(ia_empty)
    assert(ia3.count() == 1, "insert_all empty no change")

    // === retain ===
    let mut rm = Dict[Int, Int].new()
    rm.insert(1, 10)
    rm.insert(2, 20)
    rm.insert(3, 30)
    rm.insert(4, 40)
    rm.retain((k, v) -> k % 2 == 0)
    assert(rm.count() == 2, "retain count")
    assert(rm.contains_key(2) and rm.contains_key(4), "retain keys")
    assert(not rm.contains_key(1) and not rm.contains_key(3), "retain removed keys")

    let mut rm_none = Dict[Int, Int].new()
    rm_none.insert(1, 1)
    rm_none.insert(2, 2)
    rm_none.retain((k, v) -> false)
    assert(rm_none.is_empty(), "retain none")

    let mut rm_val = Dict[String, Int].new()
    rm_val.insert("a", 1)
    rm_val.insert("b", 100)
    rm_val.insert("c", 5)
    rm_val.retain((k, v) -> v > 10)
    assert(rm_val.count() == 1, "retain by value count")
    assert(rm_val.contains_key("b"), "retain by value key")

    println("All Dict tests passed")
    return 0
}
