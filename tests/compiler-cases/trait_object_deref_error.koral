// Test .val on trait object compile error
// EXPECT-ERROR: Cannot use .val on a trait object ref: concrete type is unknown at compile time

trait Greet {
    greet(self ref) String
}

type Greeter(name String)

given Greeter as Greet {

    public greet(self ref) String = "hello"
}

let main() Int = {
    let g1 = box(Greeter("test"))
    let g ref Greet = g1
    let v = g.val
    return 0
}
