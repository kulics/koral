// EXPECT: true
// EXPECT: false

type Num(x Int)

given Num as Eq {

    equals(self, other Num) Bool = {
        return self.x == other.x
    }
}

let [T Eq] isEqual(a T, b T) Bool = a == b

let main() Int = {
    println(isEqual(Num(1), Num(1)))
    println(isEqual(Num(1), Num(2)))
    return 0
}
