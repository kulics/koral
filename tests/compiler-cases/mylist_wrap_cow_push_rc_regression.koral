// EXPECT: storage count after new: 1
// EXPECT: storage count after wrap.push: 1
// EXPECT: storage count after wrap.list.push: 1
// EXPECT: storage count after nested burst: 1
// EXPECT: storage count after outer burst: 1
// EXPECT: mylist_wrap_cow_push_rc_regression_ok

using std { .. }

type MyListStorage(mut source mut ptr UInt, mut len UInt, mut cap UInt)

given MyListStorage as Drop {

    drop(source mut ptr Self) Void = {
        let mut i UInt = 0
        while i < source.len then {
            deinit_memory(source.source + i)
            i += 1
        }
        dealloc_memory[UInt](source.source)
    }
}

type MyList(mut storage mut ref MyListStorage)

given MyList {

    new() Self = {
        let cap UInt = 64
        let source = alloc_memory[UInt](cap)
        let storage mut ref MyListStorage = box(MyListStorage(source, 0, cap))
        return MyList(storage)
    }

    private ensure_unique(self mut ref) Void = {
        if ref_count(self.storage) > 1 then {
            let old = self.storage
            let new_source = alloc_memory[UInt](old.cap)
            let mut i UInt = 0
            while i < old.len then {
                let v = old.source[i]
                init_memory(new_source + i, v)
                i += 1
            }
            let new_storage = box(MyListStorage(new_source, old.len, old.cap))
            self.storage = new_storage
        }
    }

    private ensure_capacity(self mut ref, min_capacity UInt) Void = {
        if min_capacity > self.storage.cap then {
            let mut new_cap = self.storage.cap * 2
            if new_cap < min_capacity then {
                new_cap = min_capacity
            }
            let new_source = alloc_memory[UInt](new_cap)
            let old_len = self.storage.len
            if ref_count(self.storage) == 1 then {
                let old_source = self.storage.source
                move_memory(new_source, old_source, old_len)
                dealloc_memory[UInt](old_source)
                self.storage.source = new_source
                self.storage.cap = new_cap
            } else {
                let mut i UInt = 0
                while i < old_len then {
                    let v = self.storage.source[i]
                    init_memory(new_source + i, v)
                    i += 1
                }
                let new_storage = box(MyListStorage(new_source, old_len, new_cap))
                self.storage = new_storage
            }
        } else {
            self.ensure_unique()
        }
    }

    push(self mut ref, value UInt) Void = {
        self.ensure_capacity(self.storage.len + 1)
        init_memory(self.storage.source + self.storage.len, value)
        self.storage.len = self.storage.len + 1
    }

    count(self) UInt = self.storage.len

    at(self, index UInt) UInt = {
        if index >= self.storage.len then {
            panic("MyList index out of bounds")
        }
        return self.storage.source[index]
    }
}

given MyList as Index[UInt, UInt] {

    ref_at(self ref, key UInt) ref UInt = {
        if key >= self.storage.len then {
            panic("MyList index out of bounds")
        }
        return make_ref[UInt, MyListStorage](self.storage.source + key, self.storage)
    }
}

type Wrap(mut list MyList)

given Wrap {

    new() Self = Wrap(MyList.new())

    push(self mut ref, value UInt) Void = self.list.push(value)

    count(self) UInt = self.list.count()

    at(self, index UInt) UInt = self.list[index]
}

let push_list_burst(target mut ref Wrap, base UInt, rounds UInt) Void = {
    let mut i UInt = 0
    while i < rounds then {
        target.list.push(base + i)
        i += 1
    }
}

let push_wrap_burst(target mut ref Wrap, base UInt, rounds UInt) Void = {
    let mut i UInt = 0
    while i < rounds then {
        target.push(base + i)
        i += 1
    }
}

let main() Int = {
    let wrap = box(Wrap.new())

    print("storage count after new: ")
    println(ref_count(wrap.list.storage))

    wrap.push(10)
    print("storage count after wrap.push: ")
    println(ref_count(wrap.list.storage))

    wrap.list.push(20)
    print("storage count after wrap.list.push: ")
    println(ref_count(wrap.list.storage))

    let initial_source = wrap.list.storage.source

    push_list_burst(wrap, 100, 8)
    print("storage count after nested burst: ")
    println(ref_count(wrap.list.storage))

    push_wrap_burst(wrap, 200, 8)
    print("storage count after outer burst: ")
    println(ref_count(wrap.list.storage))

    assert(wrap.list.storage.source == initial_source, "source unchanged")
    assert(wrap.count() == 18, "wrap count")
    assert(wrap.at(0) == 10, "wrap first")
    assert(wrap.at(1) == 20, "wrap second")
    assert(wrap.at(2) == 100, "nested first")
    assert(wrap.at(9) == 107, "nested last")
    assert(wrap.at(10) == 200, "outer first")
    assert(wrap.at(17) == 207, "outer last")

    println("mylist_wrap_cow_push_rc_regression_ok")
    return 0
}

