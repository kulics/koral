// EXPECT: 1
// EXPECT: 42

type Holder(mut storage Int ref)

type Outer(mut inner Holder)

let main() Int = {
    let outer = box(Outer(Holder(box(42))))

    println(ref_count(outer.inner.storage))
    println(ref_count(outer.inner.storage))
    println(outer.inner.storage.val)

    yield 0
}