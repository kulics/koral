// Test pair literal and pair pattern
// EXPECT: pair_literal_basic_ok
// EXPECT: pair_literal_nested_ok
// EXPECT: pair_pattern_when_ok
// EXPECT: pair_pattern_if_ok
// EXPECT: pair_pattern_wildcard_ok
// EXPECT: pair_pattern_nested_ok

using Std.*

let main() Int = {
    // Pair literal should lower to Pair(a, b).
    let p = (1, 2)
    assert(p.first == 1, "pair first")
    assert(p.second == 2, "pair second")
    println("pair_literal_basic_ok")

    // Nested pair literal.
    let nested = ((3, 4), 5)
    assert(nested.first.first == 3, "nested first.first")
    assert(nested.first.second == 4, "nested first.second")
    assert(nested.second == 5, "nested second")
    println("pair_literal_nested_ok")

    // Pair pattern in when.
    let sum = when p in {
        (a, b) then a + b,
    }
    assert(sum == 3, "when pair pattern")
    println("pair_pattern_when_ok")

    // Pair pattern in if-is.
    let value = if p is (a, b) then a * 10 + b else 0
    assert(value == 12, "if pair pattern")
    println("pair_pattern_if_ok")

    // Pair pattern with wildcard.
    let right = when (9, 42) in {
        (_, x) then x,
    }
    assert(right == 42, "pair wildcard")
    println("pair_pattern_wildcard_ok")

    // Nested pair pattern.
    let nested_sum = when nested in {
        ((x, y), z) then x + y + z,
    }
    assert(nested_sum == 12, "nested pair pattern")
    println("pair_pattern_nested_ok")

    yield 0
}
