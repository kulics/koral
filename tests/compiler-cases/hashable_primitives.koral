let main() Int = {
    // Int
    let i1 Int = 123
    let i2 Int = 123
    let i3 Int = 124
    println(i1.hash() == i2.hash())
    println(i1.hash() <> i3.hash())

    // Int8
    let s1 Int8 = (0 - 7)(Int8)
    let s2 Int8 = (0 - 7)(Int8)
    let s3 Int8 = (0 - 6)(Int8)
    println(s1.hash() == s2.hash())
    println(s1.hash() <> s3.hash())

    // UInt8
    let u8a UInt8 = 255(UInt8)
    let u8b UInt8 = 255(UInt8)
    let u8c UInt8 = 254(UInt8)
    println(u8a.hash() == u8b.hash())
    println(u8a.hash() <> u8c.hash())

    // UInt64
    let u64a UInt64 = 4294967296(UInt64)// 2^32
    let u64b UInt64 = 4294967296(UInt64)
    let u64c UInt64 = 4294967297(UInt64)
    println(u64a.hash() == u64b.hash())
    println(u64a.hash() <> u64c.hash())

    // Pointer
    let p1 = alloc_memory[Int](1)
    let p2 = alloc_memory[Int](1)
    let p1b = p1
    println(p1.hash() == p1b.hash())
    println(p1.hash() <> p2.hash())
    dealloc_memory[Int](p1)
    dealloc_memory[Int](p2)

    return 0
}
