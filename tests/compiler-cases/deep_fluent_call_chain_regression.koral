using std::proc { .. }

public let main() Int = {
    let program = "git"
    let _ = Command.new(program)
        .arg("a")
        .arg("b")
        .arg("c")
        .arg("d")
        .arg("e")
        .arg("f")
        .arg("g")
        .arg("h")
        .arg("i")
        .set_stdout(IoRedirect.Null())
        .set_stderr(IoRedirect.Null())
        .run() or else {
        return 1
    }
    return 0
}
