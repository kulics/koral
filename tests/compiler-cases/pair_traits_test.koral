// EXPECT: All Pair trait tests passed

let main() Void = {
    // === Pair Eq ===
    let p1 = (1, 2)
    let p2 = (1, 2)
    let p3 = (1, 3)
    let p4 = (2, 2)
    assert(p1 == p2, "pair eq same")
    assert(p1 <> p3, "pair eq diff second")
    assert(p1 <> p4, "pair eq diff first")

    let ps1 = ("hello", "world")
    let ps2 = ("hello", "world")
    let ps3 = ("hello", "koral")
    assert(ps1 == ps2, "pair eq strings same")
    assert(ps1 <> ps3, "pair eq strings diff")

    // === Pair ToString ===
    let pt1 = (42, 99)
    assert(pt1.to_string() == "(42, 99)", "pair tostring ints")

    let pt2 = ("abc", 7)
    assert(pt2.to_string() == "(abc, 7)", "pair tostring mixed")

    let pt3 = (true, false)
    assert(pt3.to_string() == "(true, false)", "pair tostring bools")

    // === Pair Hash ===
    let ph1 = (10, 20)
    let ph2 = (10, 20)
    let ph3 = (10, 21)
    assert(ph1.hash() == ph2.hash(), "pair hash same")
    assert(ph1.hash() <> ph3.hash(), "pair hash diff")

    // === Pair Ord ===
    let po1 = (1, 2)
    let po2 = (1, 3)
    let po3 = (2, 1)
    let po4 = (1, 2)
    assert(po1 < po2, "pair ord less by second")
    assert(po1 < po3, "pair ord less by first")
    assert(po3 > po1, "pair ord greater by first")
    assert(po1 <= po4, "pair ord le equal")
    assert(po1 >= po4, "pair ord ge equal")
    assert(po2 > po1, "pair ord greater by second")

    // Sorting pairs
    let mut pairs = [[Int, Int]Pair]List.new()
    pairs.push((3, 1))
    pairs.push((1, 2))
    pairs.push((1, 1))
    pairs.push((2, 5))
    pairs.sort()
    assert(pairs[0] == (1, 1), "pair sort 0")
    assert(pairs[1] == (1, 2), "pair sort 1")
    assert(pairs[2] == (2, 5), "pair sort 2")
    assert(pairs[3] == (3, 1), "pair sort 3")

    println("All Pair trait tests passed")
}
