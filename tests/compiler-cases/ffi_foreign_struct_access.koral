// EXPECT: ok

foreign type Stat(st_mode UInt32, st_size Int64)

given Stat {

    new() Stat = Stat(0(UInt32), 0(Int64))
}

let main() Void = {
    let mut st = Stat.new()
    st.st_mode = 1(UInt32)
    let st_ptr ptr Stat = st.ptr
    let size = st_ptr.st_size
    if size >= 0(Int64) then { println("ok") } else { println("ok") }
}
