// Test finally block scope semantics
// Finally binds to the block scope where it is declared, not the function scope.

// Test 1: finally in if then/else branches
// EXPECT: test_defer_if_branches:
// EXPECT: entering then
// EXPECT: finally in then
// EXPECT: after if

// Test 2: finally in if-pattern then/else branches
// EXPECT: test_defer_if_pattern:
// EXPECT: matched value 42
// EXPECT: finally in then
// EXPECT: no match
// EXPECT: finally in else
// EXPECT: done

// Test 3: finally in while loop body (executes each iteration)
// EXPECT: test_defer_while:
// EXPECT: iter 1
// EXPECT: finally while 1
// EXPECT: iter 2
// EXPECT: finally while 2
// EXPECT: iter 3
// EXPECT: finally while 3
// EXPECT: after while

// Test 4: finally in while-pattern loop body
// EXPECT: test_defer_while_pattern:
// EXPECT: got 0
// EXPECT: finally wp 0
// EXPECT: got 1
// EXPECT: finally wp 1
// EXPECT: got 2
// EXPECT: finally wp 2
// EXPECT: after while-pattern

// Test 5: finally in for loop body
// EXPECT: test_defer_for:
// EXPECT: item 10
// EXPECT: finally for 10
// EXPECT: item 20
// EXPECT: finally for 20
// EXPECT: item 30
// EXPECT: finally for 30
// EXPECT: after for

// Test 6: finally in when (match) branches
// EXPECT: test_defer_when:
// EXPECT: matched Some 7
// EXPECT: finally when branch
// EXPECT: matched None
// EXPECT: finally when none
// EXPECT: done

// Test 7: finally in blockExpression
// EXPECT: test_defer_block_expr:
// EXPECT: inside block
// EXPECT: finally in block
// EXPECT: after block

// Test 8: nested scopes (inner finally before outer finally)
// EXPECT: test_defer_nested:
// EXPECT: outer start
// EXPECT: inner start
// EXPECT: finally inner
// EXPECT: finally outer

type MyOption {
    None(),
    Some(value Int),
}

type MyIterator(mut current Int, max Int)

given MyIterator {
    next(self mut ref) MyOption = {
        yield if self.current < self.max then {
            let v = self.current
            self.current = self.current + 1
            yield MyOption.Some(v)
        } else {
            yield MyOption.None()
        }
    }
}

// Test 1: finally in if then/else branches
let test_defer_if_branches() Void = {
    println("test_defer_if_branches:")
    let x = 1
    if x > 0 then {
        println("entering then")
        finally println("finally in then")
    }
    println("after if")
}

// Test 2: finally in if-pattern then/else branches
let test_defer_if_pattern() Void = {
    println("test_defer_if_pattern:")
    let a = MyOption.Some(42)
    if a is .Some(v) then {
        print("matched value ")
        println(v)
        finally println("finally in then")
    } else {
        finally println("finally in else")
    }
    let b = MyOption.None()
    if b is .Some(v2) then {
        finally println("finally in then2")
    } else {
        println("no match")
        finally println("finally in else")
    }
    println("done")
}

// Test 3: finally in while loop body (executes each iteration)
let test_defer_while() Void = {
    println("test_defer_while:")
    let mut i = 0
    while i < 3 then {
        i = i + 1
        finally {
            print("finally while ")
            println(i)
        }
        print("iter ")
        println(i)
    }
    println("after while")
}

// Test 4: finally in while-pattern loop body
let test_defer_while_pattern() Void = {
    println("test_defer_while_pattern:")
    let mut iter = MyIterator(0, 3)
    while iter.next() is .Some(v) then {
        finally {
            print("finally wp ")
            println(v)
        }
        print("got ")
        println(v)
    }
    println("after while-pattern")
}

// Test 5: finally in for loop body
let test_defer_for() Void = {
    println("test_defer_for:")
    let mut list = [Int]List.new()
    list.push(10)
    list.push(20)
    list.push(30)

    for x in list then {
        finally {
            print("finally for ")
            println(x)
        }
        print("item ")
        println(x)
    }
    println("after for")
}

// Test 6: finally in when (match) branches
let test_defer_when() Void = {
    println("test_defer_when:")
    let opt1 = MyOption.Some(7)
    when opt1 in {
        .Some(v) then {
            print("matched Some ")
            println(v)
            finally println("finally when branch")
        },
        .None then {
            finally println("finally when none")
        },
    }
    let opt2 = MyOption.None()
    when opt2 in {
        .Some(v2) then {
            finally println("finally when some2")
        },
        .None then {
            println("matched None")
            finally println("finally when none")
        },
    }
    println("done")
}

// Test 7: finally in blockExpression
let test_defer_block_expr() Void = {
    println("test_defer_block_expr:")
    {
        println("inside block")
        finally println("finally in block")
    }
    println("after block")
}

// Test 8: nested scopes (inner finally before outer finally)
let test_defer_nested() Void = {
    println("test_defer_nested:")
    println("outer start")
    finally println("finally outer")
    {
        println("inner start")
        finally println("finally inner")
    }
}

public let main() Int = {
    test_defer_if_branches()
    test_defer_if_pattern()
    test_defer_while()
    test_defer_while_pattern()
    test_defer_for()
    test_defer_when()
    test_defer_block_expr()
    test_defer_nested()
    yield 0
}
