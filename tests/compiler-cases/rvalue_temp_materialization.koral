// EXPECT: Rvalue temporary materialization tests passed

// Rvalue receivers may call `self ref` methods. The compiler materializes a
// stable temporary for the duration of the call, but this exception is limited
// to receiver adjustment only.

type Counter(value Int)

given Counter {
    public new(value Int) Counter = Counter(value)

    public read(self ref) Int = self.value

    public add(self ref, n Int) Int = self.value + n

    public duplicate(self) Counter = Counter(self.value)
}

type SumPair(left Int, right Int)

given SumPair {
    public sum(self ref) Int = self.left + self.right
}

let test_direct_rvalue_self_ref() Void = {
    assert(Counter.new(3).read() == 3, "direct rvalue self ref call")
    assert(Counter.new(4).add(5) == 9, "rvalue self ref call with argument")
}

let test_chained_rvalue_self_ref() Void = {
    assert(Counter.new(7).duplicate().read() == 7, "chain preserves temporary")
}

let test_aggregate_rvalue_self_ref() Void = {
    assert(SumPair(2, 5).sum() == 7, "aggregate rvalue self ref call")
}

let main() Void = {
    test_direct_rvalue_self_ref()
    test_chained_rvalue_self_ref()
    test_aggregate_rvalue_self_ref()
    println("Rvalue temporary materialization tests passed")
}
