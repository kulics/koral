// EXPECT-ERROR: Cannot take 'ref' of immutable value: c. Only 'let mut' lvalues (and lvalues reached through ref/pointer links) can use 'ref'.

type Counter(mut value Int)

given Counter {
    increment(self mut ref) Void = {
        self.value = self.value + 1
    }
}

let main() Int = {
    let c = Counter(1)
    c.increment()
    yield 0
}
