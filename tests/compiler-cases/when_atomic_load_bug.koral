// Test that AtomicBool.load() returns correct value inside when branches
// Previously, load() called inside a when branch returned wrong values
// due to a codegen bug with method calls on ref types inside when expressions.
// EXPECT: before when: false
// EXPECT: inside when Ok: false
// EXPECT: inside when Ok: false
// EXPECT: done

using std::sync { .. }

type MyResult {
    Ok(value Int),
    Err(),
}

let main() Void = {
    let flag = AtomicBool.new(false)
    let r = MyResult.Ok(1)

    // This works correctly
    print("before when: ")
    println(flag.load().to_string())

    // This used to return wrong value
    when r in {
        .Ok(v) then {
            print("inside when Ok: ")
            println(flag.load().to_string())
            print("inside when Ok: ")
            println(flag.load().to_string())
        },
        .Err then {},
    }

    println("done")
}
