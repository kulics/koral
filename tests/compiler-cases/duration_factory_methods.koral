// EXPECT: nanos_ok
// EXPECT: micros_ok
// EXPECT: millis_ok
// EXPECT: secs_ok
// EXPECT: mins_ok
// EXPECT: hours_ok
// EXPECT: nanos_normalized
// EXPECT: roundtrip_nanos
// EXPECT: roundtrip_micros
// EXPECT: roundtrip_millis
// EXPECT: roundtrip_secs
// EXPECT: roundtrip_mins
// EXPECT: roundtrip_hours

let main() Int = {
    // Test from_nanoseconds: 1_500_000_000 ns = 1s 500_000_000ns
    let d1 = 1_500_000_000ns
    assert(d1.as_seconds() == 1(Int64), "nanos secs")
    assert(d1.as_nanoseconds() == 1_500_000_000(Int64), "nanos total")
    println("nanos_ok")

    // Test from_microseconds: 2_500_000 us = 2s 500_000_000ns
    let d2 = 2_500_000us
    assert(d2.as_seconds() == 2(Int64), "micros secs")
    assert(d2.as_nanoseconds() == 2_500_000_000(Int64), "micros total")
    println("micros_ok")

    // Test from_milliseconds: 3_500 ms = 3s 500_000_000ns
    let d3 = 3_500ms
    assert(d3.as_seconds() == 3(Int64), "millis secs")
    assert(d3.as_nanoseconds() == 3_500_000_000(Int64), "millis total")
    println("millis_ok")

    // Test from_seconds
    let d4 = 42s
    assert(d4.as_seconds() == 42(Int64), "secs secs")
    assert(d4.as_nanoseconds() == 42_000_000_000(Int64), "secs nanos")
    println("secs_ok")

    // Test from_minutes: 5 min = 300s
    let d5 = 5min
    assert(d5.as_seconds() == 300(Int64), "mins secs")
    assert(d5.as_nanoseconds() == 300_000_000_000(Int64), "mins nanos")
    println("mins_ok")

    // Test from_hours: 2 h = 7200s
    let d6 = 2h
    assert(d6.as_seconds() == 7200(Int64), "hours secs")
    assert(d6.as_nanoseconds() == 7_200_000_000_000(Int64), "hours nanos")
    println("hours_ok")

    // Property 2: Normalization invariant - nanos always in [0, 1_000_000_000)
    let d7 = Duration.new(seconds: 1(Int64), nanoseconds: 1_500_000_000(Int64)).unwrap()
    assert(d7.as_nanoseconds() == 2_500_000_000(Int64), "norm total")
    let d8 = Duration.new(seconds: 0(Int64), nanoseconds: 0(Int64) - 1(Int64))
    assert(d8.is_error(), "norm negative nanos error")
    println("nanos_normalized")

    // Property 1: Round-trip consistency
    assert(500_000_000ns.as_nanoseconds() == 500_000_000(Int64), "rt nanos")
    println("roundtrip_nanos")

    assert(1_500us.as_microseconds() == 1_500(Int64), "rt micros")
    println("roundtrip_micros")

    assert(500ms.as_milliseconds() == 500(Int64), "rt millis")
    println("roundtrip_millis")

    assert(60s.as_seconds() == 60(Int64), "rt secs")
    println("roundtrip_secs")

    assert(30min.as_minutes() == 30(Int64), "rt mins")
    println("roundtrip_mins")

    assert(24h.as_hours() == 24(Int64), "rt hours")
    println("roundtrip_hours")

    return 0
}
