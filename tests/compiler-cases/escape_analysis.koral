// EXPECT: Escape analysis tests passed

// Test 1: Direct reference to local variable in struct constructor
// The reference expression is directly in the constructor call
type IntBox(value Int ref)

let return_direct_ref() IntBox = {
    let mut x Int = 42
    yield IntBox(x.ref)  // x.ref is directly passed, x should be heap allocated
}

let test_return_direct_ref() Void = {
    let box = return_direct_ref()
    let value = box.value.val
    assert(value == 42, "return direct ref value")
}

// Test 2: Return parameter reference (should NOT escape - parameter outlives function)
let identity_ref(x Int ref) Int ref = {
    yield x  // Just return the parameter reference
}

let test_return_param_ref() Void = {
    let mut x Int = 100
    let r = identity_ref(x.ref)
    let value = r.val
    assert(value == 100, "return param ref value")
}

// Test 3: Direct reference in struct field (should use heap allocation)
type RefHolder(data Int ref)

let create_ref_holder_direct() RefHolder = {
    let mut local Int = 999
    yield RefHolder(local.ref)  // local.ref is directly passed
}

let test_store_ref_to_field() Void = {
    let holder = create_ref_holder_direct()
    let value = holder.data.val
    assert(value == 999, "store ref to field value")
}

// Test 4: Non-escaping reference (should use stack allocation)
let use_local_ref() Int = {
    let mut x Int = 50
    let r Int ref = x.ref  // x does NOT escape - r is only used locally
    let value = r.val
    yield value + 10
}

let test_non_escaping_ref() Void = {
    let result = use_local_ref()
    assert(result == 60, "non-escaping ref result")
}

// Test 5: Multiple non-escaping references
let mixed_non_escape() Int = {
    let mut a Int = 10
    let mut b Int = 20
    
    // r1 doesn't escape - only used locally
    let r1 Int ref = a.ref
    let val1 = r1.val
    
    // r2 doesn't escape either - only used locally
    let r2 Int ref = b.ref
    let val2 = r2.val
    
    yield val1 + val2
}

let test_mixed_non_escape() Void = {
    let result = mixed_non_escape()
    assert(result == 30, "mixed non-escape result")
}

// Test 6: Reference in conditional branch - non-escaping
let conditional_ref_simple(flag Bool) Int = {
    let mut x Int = 1
    let mut y Int = 2
    yield if flag then {
        let r Int ref = x.ref  // x doesn't escape - r is only used locally
        yield r.val
    } else {
        let r Int ref = y.ref  // y doesn't escape - r is only used locally
        yield r.val
    }
}

let test_conditional_ref() Void = {
    let val1 = conditional_ref_simple(true)
    let val2 = conditional_ref_simple(false)
    assert(val1 == 1, "conditional ref true")
    assert(val2 == 2, "conditional ref false")
}


// Test 7: Reference passed to function but not stored
let read_ref(r Int ref) Int = {
    yield r.val
}

let test_ref_passed_not_stored() Void = {
    let mut x Int = 77
    let r Int ref = x.ref  // x doesn't escape - r is only read
    let value = read_ref(r)
    assert(value == 77, "ref passed not stored")
}

// Test 8: Reference to rvalue (always heap allocated)
let test_rvalue_ref() Void = {
    // ref 100 creates a reference to an rvalue, which must be heap allocated
    let r Int ref = box(100)
    let value = r.val
    assert(value == 100, "rvalue ref value")
}

// Test 9: Direct reference in chained call
let create_box_direct(v Int) IntBox = {
    let mut x Int = v
    yield IntBox(x.ref)  // x.ref is directly passed
}

let get_box_value(box IntBox) Int = {
    yield box.value.val
}

let test_chained_direct() Void = {
    let value = get_box_value(create_box_direct(42))
    assert(value == 42, "chained direct value")
}

// Test 10: Existing struct_with_ref pattern (from existing test)
type Box(value Int ref)

type NestedRefBox(data Int ref)
type NestedOuter(inner NestedRefBox)
type NestedUnion {
    None(),
    Some(value NestedOuter),
}

let getBox() Box = {
    let r Int ref = box(100)  // 100 is rvalue, so heap allocated
    yield Box(r)
}

let test_existing_pattern() Void = {
    let b = getBox()
    let value = b.value.val
    assert(value == 100, "existing pattern value")
}

// Test 11: ref alias nested in multi-level type + enum construction
let build_nested_enum_alias() NestedUnion = {
    let mut x Int = 314
    let r Int ref = x.ref
    yield NestedUnion.Some(NestedOuter(NestedRefBox(r)))
}

let test_nested_enum_alias_escape() Void = {
    let v = build_nested_enum_alias()
    when v in {
        .Some(outer) then assert(outer.inner.data.val == 314, "nested enum alias value"),
        _ then assert(false, "nested enum alias should be Some"),
    }
}

let main() Void = {
    test_return_direct_ref()
    test_return_param_ref()
    test_store_ref_to_field()
    test_non_escaping_ref()
    test_mixed_non_escape()
    test_conditional_ref()
    test_ref_passed_not_stored()
    test_rvalue_ref()
    test_chained_direct()
    test_existing_pattern()
    test_nested_enum_alias_escape()
    println("Escape analysis tests passed")
}
