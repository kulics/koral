// EXPECT: ok

let unwrap_or_zero(opt [Int]Option mut ref) Int = when opt in {
    .Some(value) then value,
    .None() then 0,
}

let main() Void = {
    let opt [Int]Option mut ref = box([Int]Option.Some(7))
    assert(unwrap_or_zero(opt) == 7, "when should auto-match mut ref subjects")
    println("ok")
}
