// EXPECT: ok

let unwrap_or_zero(opt ref mut Option[Int]) Int = when opt in {
    .Some(value) then value,
    .None() then 0,
}

let main() Void = {
    let opt ref mut Option[Int] = box(Option[Int].Some(7))
    assert(unwrap_or_zero(opt) == 7, "when should auto-match ref mut subjects")
    println("ok")
}
