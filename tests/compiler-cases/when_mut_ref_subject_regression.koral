// EXPECT: ok

let unwrap_or_zero(opt mut ref Option[Int]) Int = when opt in {
    .Some(value) then value,
    .None() then 0,
}

let main() Void = {
    let opt mut ref Option[Int] = box(Option[Int].Some(7))
    assert(unwrap_or_zero(opt) == 7, "when should auto-match mut ref subjects")
    println("ok")
}
