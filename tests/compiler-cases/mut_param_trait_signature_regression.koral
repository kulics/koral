// EXPECT: 2
// EXPECT: 4

trait PlainParam {
    inc(self, value Int) Int
}

trait MutParamRequirement {
    inc(self, mut value Int) Int
}

type A()

given A as PlainParam {
    inc(self, mut value Int) Int = {
        value = value + 1
        return value
    }
}

type B()

given B as MutParamRequirement {
    inc(self, value Int) Int = value + 1
}

let call_plain[T PlainParam](target T) Int = target.inc(1)

let call_mut_requirement[T MutParamRequirement](target T) Int = target.inc(3)

let main() Int = {
    println(call_plain(A()).to_string())
    println(call_mut_requirement(B()).to_string())
    return 0
}
