// EXPECT: mut weakref upgrade: 7
// EXPECT: mut weakref released
// EXPECT: trait mut weakref upgrade

trait Bump {
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter as Bump {

    public bump(self mut ref) Int = {
        self.value += 1
        return self.value
    }
}

let main() Int = {
    let weak = make_weak_counter()

    when weak.to_ref() in {
        .Some(_) then println("mut weakref leaked"),
        .None then println("mut weakref released"),
    }

    let strong_trait mut ref Counter = box(Counter(0))
    let obj mut ref Bump = strong_trait
    let traitWeak mut weakref Bump = obj.weakref

    when traitWeak.to_ref() in {
        .Some(_) then println("trait mut weakref upgrade"),
        .None then println("trait mut weakref failed"),
    }

    return 0
}

let make_weak_counter() mut weakref Counter = {
    let strong mut ref Counter = box(Counter(6))
    let upgraded = strong.weakref.to_ref().unwrap()
    print("mut weakref upgrade: ")
    println(upgraded.bump())
    return strong.weakref
}
