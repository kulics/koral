// EXPECT: weakref mut upgrade: 7
// EXPECT: weakref mut released
// EXPECT: trait weakref mut upgrade

trait Bump {
    bump(self ref mut) Int
}

type Counter(mut value Int)

given Counter as Bump {

    public bump(self ref mut) Int = {
        self.value += 1
        return self.value
    }
}

let main() Int = {
    let weak = make_weak_counter()

    when weak.to_ref() in {
        .Some(_) then println("weakref mut leaked"),
        .None then println("weakref mut released"),
    }

    let strong_trait ref mut Counter = box(Counter(0))
    let obj ref mut Bump = strong_trait
    let traitWeak weakref mut Bump = obj.weakref

    when traitWeak.to_ref() in {
        .Some(_) then println("trait weakref mut upgrade"),
        .None then println("trait weakref mut failed"),
    }

    return 0
}

let make_weak_counter() weakref mut Counter = {
    let strong ref mut Counter = box(Counter(6))
    let upgraded = strong.weakref.to_ref().unwrap()
    print("weakref mut upgrade: ")
    println(upgraded.bump())
    return strong.weakref
}
