// Test case for [Void]Result type
// EXPECT: Success!
// EXPECT: Something went wrong

public let do_something(success Bool) Result[Void] = {
    return if success then {
        yield Result[Void].Ok({})
    } else {
        return Result[Void].Error(box("Something went wrong"))
    }
}

public let main() Void = {
    when do_something(true) in {
        .Ok(_) then println("Success!"),
        .Error(msg) then println(msg.message()),
    }
    
    when do_something(false) in {
        .Ok(_) then println("Success!"),
        .Error(msg) then println(msg.message()),
    }
}
