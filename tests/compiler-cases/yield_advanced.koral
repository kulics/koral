// Advanced branch-yield coverage
// EXPECT: early_if=11
// EXPECT: early_when=21
// EXPECT: nested_if_tt=1
// EXPECT: nested_if_tf=2
// EXPECT: nested_when=200
// EXPECT: loop_hit=4
// EXPECT: loop_miss=-1
// EXPECT: for_hit=5
// EXPECT: for_miss=-1
// EXPECT: lambda_local=8
// EXPECT: lambda_nested=42
// EXPECT: yield_advanced_ok

type InnerTag {
    Small(),
    Large(),
}

type OuterTag {
    First(inner InnerTag),
    Second(),
}

let early_if(flag Bool) Int = {
    return if flag then {
        if flag then {
            yield 11
        }
        yield 12
    } else {
        yield 13
    }
}

let early_when(flag Bool) Int = {
    return when flag in {
        true then {
            let marker = if flag then 1 else 0
            when marker in {
                1 then {
                    yield 21
                },
                _ then {
                },
            }
            yield 23
        },
        false then 24,
    }
}

let nested_if(outer Bool, inner Bool) Int = {
    return if outer then {
        if inner then {
            yield 1
        } else {
            yield 2
        }
    } else {
        if inner then {
            yield 3
        } else {
            yield 4
        }
    }
}

let nested_when(value OuterTag) Int = {
    return when value in {
        .First(inner) then when inner in {
            .Small then 100,
            .Large then {
                yield 200
            },
        },
        .Second then 300,
    }
}

let loop_search(limit Int) Int = {
    return if limit > 0 then {
        let mut i = 1
        while i <= limit then {
            if i % 4 == 0 then {
                yield i
            }
            i += 1
        }
        yield -1
    } else {
        yield 0
    }
}

let for_search(limit Int) Int = {
    return if limit > 0 then {
        for value in 1..(limit + 1) then {
            if value % 5 == 0 then {
                yield value
            }
        }
        yield -1
    } else {
        yield 0
    }
}

let lambda_local(flag Bool) Int = {
    let chooser Func[Int] = () -> if flag then {
        yield 8
    } else {
        yield 9
    }
    return chooser()
}

let lambda_nested(flag Bool) Int = {
    let chooser Func[Int] = () -> when flag in {
        true then if flag then {
            yield 42
        } else {
            yield 0
        },
        false then 7,
    }
    return chooser()
}

let main() Int = {
    println("early_if=\(early_if(true))")
    println("early_when=\(early_when(true))")
    println("nested_if_tt=\(nested_if(true, true))")
    println("nested_if_tf=\(nested_if(true, false))")
    println("nested_when=\(nested_when(OuterTag.First(InnerTag.Large())))")
    println("loop_hit=\(loop_search(7))")
    println("loop_miss=\(loop_search(3))")
    println("for_hit=\(for_search(7))")
    println("for_miss=\(for_search(3))")
    println("lambda_local=\(lambda_local(true))")
    println("lambda_nested=\(lambda_nested(true))")
    println("yield_advanced_ok")
    return 0
}
