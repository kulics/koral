// EXPECT: 12

trait CounterOps {
    peek(self ref) Int
}

type Counter(value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

type Holder(item ref CounterOps)

let main() Int = {
    let strong mut ref Counter = box(Counter(12))
    let readonly ref Counter = strong
    let holder = Holder(readonly)
    println(holder.item.peek().to_string())
    return 0
}