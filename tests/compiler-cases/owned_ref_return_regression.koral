// EXPECT: owned ref return ok
// EXPECT: owned trait ref return ok

trait OwnedRefReturnReader {
    read(self ref) Int
}

type OwnedRefReturnBox(value Int)

given OwnedRefReturnBox as OwnedRefReturnReader {

    public read(self ref) Int = self.value
}

let make_box() ref OwnedRefReturnBox = {
    let value = OwnedRefReturnBox(7)
    return value.ref
}

let identity_box_ref(box ref OwnedRefReturnBox) ref OwnedRefReturnBox = box

let identity_reader_ref(reader ref OwnedRefReturnReader) ref OwnedRefReturnReader = reader

let main() Int = {
    let strong = identity_box_ref(make_box())
    assert(strong.value == 7, "owned ref return should preserve heap object")
    println("owned ref return ok")

    let reader ref OwnedRefReturnReader = strong
    let alias = identity_reader_ref(reader)
    assert(alias.read() == 7, "owned trait ref return should preserve heap object")
    println("owned trait ref return ok")
    return 0
}
