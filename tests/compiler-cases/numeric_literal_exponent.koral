// EXPECT: true
// EXPECT: true

let main() Int = {
    // Basic exponent
    let a = 1e3
    println(a == 1000.0)

    // Negative exponent
    let b = 1e-3
    println(b == 0.001)

    // Explicit positive exponent
    let c = 2.5e+2
    println(c == 250.0)

    // Uppercase E
    let d = 1e6
    println(d == 1000000.0)

    // Combined with decimal
    let e_val = 1.5e2
    println(e_val == 150.0)

    // Underscore separator in exponent base
    let f = 1_000e2
    println(f == 100000.0)

    yield 0
}
