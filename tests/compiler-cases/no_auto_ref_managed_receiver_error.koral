// EXPECT-ERROR: Type mismatch: expected ref Counter, got Counter

// Negative test: calling a self ref Self (managed receiver) method
// on a value should fail. Must use explicit .ref syntax.

type Counter(mut value Int)

given Counter {
    public increment(self ref Self) Void = {
        self.value += 1
    }
}

let main() Int = {
    let mut c = Counter(0)
    c.increment()
    return c.value
}
