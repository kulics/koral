// EXPECT: builtin subscript dict ok

using std { .. }

type Point(mut x Int, mut y Int)

let main() Void = {
    // === Subscript write: update only (insert via insert()) ===
    let mut d = Dict[Int, Int].new()
    d.insert(1, 10)
    d.insert(2, 20)
    d.insert(3, 30)
    assert(d.count() == 3, "insert count")

    d[2] = 99
    assert(d.count() == 3, "subscript update count unchanged")
    assert(d.get(2).unwrap() == 99, "subscript update d[2]")

    // === Subscript read ===
    let v1 = d[1]
    assert(v1 == 10, "subscript read d[1]")
    let v2 = d[2]
    assert(v2 == 99, "subscript read d[2]")

    // === String keys ===
    let mut sd = Dict[String, Int].new()
    sd.insert("hello", 42)
    sd.insert("world", 100)
    assert(sd["hello"] == 42, "string key read hello")
    assert(sd["world"] == 100, "string key read world")
    sd["hello"] = 999
    assert(sd["hello"] == 999, "string key update hello")

    // === COW: copy dict, write to copy, original unchanged ===
    let mut original = Dict[Int, String].new()
    original.insert(1, "a")
    original.insert(2, "b")

    let mut copy = original
    copy.insert(3, "c")
    copy[1] = "A"

    assert(original.count() == 2, "original count unchanged after copy write")
    assert(original.get(1).unwrap() == "a", "original[1] unchanged")
    assert(not original.contains_key(3), "original not contains_key 3")
    assert(copy.count() == 3, "copy count after write")
    assert(copy.get(1).unwrap() == "A", "copy[1] modified")
    assert(copy.contains_key(3), "copy contains_key 3")

    // === Compound assignment ===
    let mut ca = Dict[Int, Int].new()
    ca.insert(1, 10)
    ca[1] += 5
    assert(ca[1] == 15, "compound add assignment")
    ca[1] -= 3
    assert(ca[1] == 12, "compound sub assignment")
    ca[1] *= 2
    assert(ca[1] == 24, "compound mul assignment")

    // === Deep update: struct field via subscript ===
    let mut points = Dict[Int, Point].new()
    points.insert(1, Point(10, 20))
    points[1].y = 77
    assert(points[1].x == 10, "deep update keeps x")
    assert(points[1].y == 77, "deep update stores new y")

    // === Ref escape: reference survives dict mutation ===
    let mut m = Dict[Int, Int].new()
    m.insert(0, 41)
    let r = m[0].ref
    m = Dict[Int, Int].new()
    m.insert(0, 2)
    assert(r.val == 41, "ref escape keeps old value")
    assert(m[0] == 2, "new dict has new value")

    println("builtin subscript dict ok")
}
