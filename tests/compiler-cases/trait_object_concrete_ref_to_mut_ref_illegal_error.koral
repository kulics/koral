// EXPECT-ERROR: Type mismatch: expected mut ref CounterOps, got ref Counter

trait CounterOps {
    bump(self mut ref) Int
}

type Counter(mut value Int)

given Counter as CounterOps {

    public bump(self mut ref) Int = {
        self.value += 1
        return self.value
    }
}

let main() Int = {
    let strong mut ref Counter = box(Counter(1))
    let readonly ref Counter = strong
    let _ mut ref CounterOps = readonly
    return 0
}