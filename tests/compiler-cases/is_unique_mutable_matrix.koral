// EXPECT: borrow unique: false
// EXPECT: boxed unique: true
// EXPECT: shared unique: false

let main() Int = {
    let mut local = 1
    let borrow ref Int = local.ref
    print("borrow unique: ")
    println(is_unique_mutable(borrow.ptr))

    let strong ref mut Int = box(2)
    print("boxed unique: ")
    println(is_unique_mutable(strong.ptr))

    let alias ref Int = strong
    print("shared unique: ")
    println(is_unique_mutable(strong.ptr))

    return 0
}
