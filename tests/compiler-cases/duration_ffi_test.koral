// EXPECT-ERROR: Invalid argument count for function expression
// EXPECT-ERROR: Invalid argument count for function expression

foreign type Timespec(tv_sec Int64, tv_nsec Int64)

let test_ffi_struct() Bool = {
    let ts = Timespec(1(Int64), 500_000_000(Int64))
    assert(ts.tv_sec == 1(Int64))
    assert(ts.tv_nsec == 500_000_000(Int64))

    let p = ts.ptr
    assert(p.tv_sec == 1(Int64))

    return true
}

let main() Int = {
    assert(test_ffi_struct())
    return 0
}
