// EXPECT: 10
// EXPECT: 42
// EXPECT: 100

// Tests for Never type and Option/Result usage

let test_never_flow() Void = {
    // This should compile because panic returns Never, which matches any type (here Int)
    let x Int = if true then {
        yield 10
    } else {
        panic("Should not happen")
    }
    println(x)
}

let test_option_unwrap() Void = {
    let some = [Int]Option.Some(42)
    let value = some.unwrap()
    println(value)
}

let test_result_unwrap() Void = {
    let ok = [Int]Result.Ok(100)
    println(ok.unwrap())
}

let main() Void = {
    test_never_flow()
    test_option_unwrap()
    test_result_unwrap()
}
