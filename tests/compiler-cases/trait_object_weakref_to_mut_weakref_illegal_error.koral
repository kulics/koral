// EXPECT-ERROR: Type mismatch: expected mut weakref CounterOps, got weakref CounterOps

trait CounterOps {
    peek(self ref) Int
}

type Counter(value Int)

given Counter as CounterOps {

    public peek(self ref) Int = self.value
}

let main() Int = {
    let strong mut ref CounterOps = box(Counter(3))
    let readonly ref CounterOps = strong
    let weak weakref CounterOps = readonly.weakref
    let _ mut weakref CounterOps = weak
    return 0
}