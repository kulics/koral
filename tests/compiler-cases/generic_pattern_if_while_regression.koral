// EXPECT: first: 3
// EXPECT: sum: 9

type Item(value Int)

type Maybe[T Any] {
    Some(value T),
    None(),
}

type Counter(mut current Int, stop Int)

given Counter {

    next(self ref mut) Maybe[Item] = {
        return if self.current < self.stop then {
            let value = self.current
            self.current = self.current + 1
            yield Maybe[Item].Some(Item(value))
        } else {
            yield Maybe[Item].None()
        }
    }
}

let main() Int = {
    let mut first_counter = Counter(3, 4)
    if first_counter.next() is .Some(item) then {
        println("first: " + item.value.to_string())
    } else {
        return 1
    }

    let mut sum_counter = Counter(2, 5)
    let mut sum = 0
    while sum_counter.next() is .Some(item) then {
        sum = sum + item.value
    }
    println("sum: " + sum.to_string())
    return 0
}
