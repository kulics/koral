// EXPECT: String advanced tests passed

let expect_some_uint(opt [UInt]Option, v UInt, msg String) Void = {
    when opt in {
        .Some(x) then assert(x == v, msg),
        .None then panic(msg),
    }
}

let test_capacity_and_empty() Void = {
    let s = "abc"
    assert(s.capacity() >= s.count(), "capacity")
    let e = String.zero()
    assert(e.count() == 0, "empty count")
    assert(e.is_empty(), "empty flag")
}

let test_new_constructor() Void = {
    let s = String.new()
    assert(s.count() == 0, "new count")
    assert(s.capacity() > 0, "new has capacity")
    assert(s.is_empty(), "new is empty")
}

let test_prefix_suffix() Void = {
    let s = "abcab"
    assert(s.starts_with("ab"), "starts_with")
    assert(s.ends_with("ab"), "ends_with")
    // find_index and find_last_index now take String
    expect_some_uint(s.find("b"), 1, "first index b")
    expect_some_uint(s.find_last("b"), 4, "last index b")
}

let test_trim_and_case() Void = {
    let s = "  HeLLo  "
    let trimmed = s.trim_ascii()
    assert(trimmed == "HeLLo", "trim both")
    assert(trimmed.trim_ascii_start() == "HeLLo", "trim start")
    assert(trimmed.trim_ascii_end() == "HeLLo", "trim end")
    assert(trimmed.to_ascii_lowercase() == "hello", "lowercase")
    assert(trimmed.to_ascii_uppercase() == "HELLO", "uppercase")
    assert("hELlo  woRLD".to_ascii_titlecase() == "Hello  World", "title")
}

let test_find_contains_replace_repeat() Void = {
    let s = "ababa"
    expect_some_uint(s.find("aba"), 0, "find aba")
    assert(s.contains("ba"), "contains ba")
    let r = "abcabc".replace_all("ab", with: "X")
    assert(r == "XcXc", "replace")
    let rep = "ab".repeat(3)
    assert(rep == "ababab", "repeat")
}

let test_ascii_checks() Void = {
    let s = "azAZ09"
    assert(s.is_ascii(), "ascii")
    let mut ws = " \t"// space and tab
    assert(ws.is_ascii_whitespace(), "blank yes")
    let a UInt8 = 97// 'a'
    ws.push_byte(a)
    assert(not ws.is_ascii_whitespace(), "blank no")
}

let test_slice_and_trim_prefix_suffix() Void = {
    let s = "abcdef"
    assert(s.substring(2..4) == "cde", "slice closed")
    assert(s.substring(2..<5) == "cde", "slice closed-open")
    assert(s.trim_prefix("ab") == "cdef", "trim prefix")
    assert(s.trim_suffix("ef") == "abcd", "trim suffix")

    assert(s.strip_prefix("ab").unwrap() == "cdef", "strip prefix")
    assert(s.strip_suffix("ef").unwrap() == "abcd", "strip suffix")
    assert(s.strip_prefix("zz").is_none(), "strip prefix none")
    assert(s.strip_suffix("zz").is_none(), "strip suffix none")
}

let test_split_whitespace() Void = {
    let s = "  a  bc d  "
    let mut acc = String.zero()
    let mut first = true
    for part in s.split_ascii_whitespace() then {
        if not first then { acc.push_byte(',') } // comma
        first = false
        acc.push_string(part)
    }
    assert(acc == "a,bc,d", "split ascii whitespace")
}

let test_split_sep_and_lines() Void = {
    let s = "a--b--"
    let mut parts = String.zero()
    let mut first = true
    for p in s.split("--") then {
        if not first then { parts.push_byte(':') } // ':'
        first = false
        parts.push_string(p)
    }
    assert(parts == "a:b:", "split sep includes trailing empty")

    let l = "x\ny\n"
    let mut out = String.zero()
    let mut firstLine = true
    for line in l.lines() then {
        if not firstLine then { out.push_byte(';') } // ';'
        firstLine = false
        out.push_string(line)
    }
    assert(out == "x;y", "lines split")
}

let test_split_once() Void = {
    // basic split
    when "key=value" .split_once("=") in {
        .Some(Pair(k, v)) then {
            assert(k == "key", "split_once key")
            assert(v == "value", "split_once value")
        },
        .None then panic("split_once should find ="),
    }
    // only first occurrence is used
    when "a=b=c" .split_once("=") in {
        .Some(Pair(k, v)) then {
            assert(k == "a", "split_once first only left")
            assert(v == "b=c", "split_once first only right")
        },
        .None then panic("split_once a=b=c"),
    }
    // not found
    assert("hello" .split_once("=").is_none(), "split_once none")
    // sep at start
    when "=val" .split_once("=") in {
        .Some(Pair(k, v)) then {
            assert(k == "", "split_once empty left")
            assert(v == "val", "split_once sep at start right")
        },
        .None then panic("split_once sep at start"),
    }
    // sep at end
    when "val=" .split_once("=") in {
        .Some(Pair(k, v)) then {
            assert(k == "val", "split_once sep at end left")
            assert(v == "", "split_once empty right")
        },
        .None then panic("split_once sep at end"),
    }
}

let test_rsplit_once() Void = {
    // basic rsplit
    when "a/b/c" .split_last_once("/") in {
        .Some(Pair(l, r)) then {
            assert(l == "a/b", "split_last_once left")
            assert(r == "c", "split_last_once right")
        },
        .None then panic("split_last_once should find /"),
    }
    // single occurrence same as split_once
    when "host:port" .split_last_once(":") in {
        .Some(Pair(l, r)) then {
            assert(l == "host", "split_last_once single left")
            assert(r == "port", "split_last_once single right")
        },
        .None then panic("split_last_once host:port"),
    }
    // not found
    assert("hello" .split_last_once("/").is_none(), "split_last_once none")
}

let test_replace_n() Void = {
    // replace first 2 only
    let r = "aXaXaX" .replace_n("X", 2, with: "Y")
    assert(r == "aYaYaX", "replace_n 2")
    // replace 0 = no change
    let r0 = "abc" .replace_n("b", 0, with: "Z")
    assert(r0 == "abc", "replace_n 0")
    // replace 1
    let r1 = "abab" .replace_n("ab", 1, with: "X")
    assert(r1 == "Xab", "replace_n 1")
    // n larger than occurrences = replace all
    let rall = "aaa" .replace_n("a", 10, with: "b")
    assert(rall == "bbb", "replace_n exceeds count")
    // no match
    let rnone = "abc" .replace_n("z", 5, with: "!")
    assert(rnone == "abc", "replace_n no match")
}

let test_join_to_string() Void = {
    let mut names = [String]List.new()
    names.push("a")
    names.push("b")
    names.push("c")
    assert(names.join_to_string(", ") == "a, b, c", "join_to_string basic")

    let mut single = [String]List.new()
    single.push("only")
    assert(single.join_to_string(", ") == "only", "join_to_string single")

    let empty = [String]List.new()
    assert(empty.join_to_string(", ") == "", "join_to_string empty")

    assert(names.join_to_string("") == "abc", "join_to_string no separator")
    assert(names.iterator().join_to_string(", ") == "a, b, c", "iterator join_to_string basic")
    assert(names.iterator().join_to_string("") == "abc", "iterator join_to_string no separator")
}

let main() Void = {
    test_capacity_and_empty()
    test_new_constructor()
    test_prefix_suffix()
    test_trim_and_case()
    test_find_contains_replace_repeat()
    test_ascii_checks()
    test_slice_and_trim_prefix_suffix()
    test_split_whitespace()
    test_split_sep_and_lines()
    test_split_once()
    test_rsplit_once()
    test_replace_n()
    test_join_to_string()
    println("String advanced tests passed")
}
