using std { .. }
// ============================================================================
// std.json - JsonValue Type
// ============================================================================
// JSON value enum with six variants representing all JSON types.
// Provides type-checking, value extraction, and indexed access methods.
// ============================================================================

// ============================================================================
// JsonValue Type Definition
// ============================================================================
public type JsonValue {
    Null(),
    Bool(value Bool),
    Number(value Float64),
    String(value String),
    Array(elements List[ref JsonValue]),
    Object(entries Dict[String, ref JsonValue]),
}

// ============================================================================
// JSON string/number formatting and pretty-print helpers
// ============================================================================
private let hex_char(nibble UInt) UInt8 = {
    if nibble < 10 then {
        return nibble(UInt8) + '0'
    }
    return (nibble - 10)(UInt8) + 'a'
}

let escape_json_string(s String) String = {
    let mut result = String.with_capacity(s.count() + 2)
    result.push_byte('"')
    for i in 0..<s.count() then {
        let b = s[i]
        if b == '"' then {
            result.push_byte('\\')
            result.push_byte('"')
        } else if b == '\\' then {
            result.push_byte('\\')
            result.push_byte('\\')
        } else if b == '/' then {
            result.push_byte('\\')
            result.push_byte('/')
        } else if b == 8(UInt8) then {
            result.push_byte('\\')
            result.push_byte('b')
        } else if b == 12(UInt8) then {
            result.push_byte('\\')
            result.push_byte('f')
        } else if b == '\n' then {
            result.push_byte('\\')
            result.push_byte('n')
        } else if b == '\r' then {
            result.push_byte('\\')
            result.push_byte('r')
        } else if b == '\t' then {
            result.push_byte('\\')
            result.push_byte('t')
        } else if b < 32(UInt8) then {
            result.push_byte('\\')
            result.push_byte('u')
            result.push_byte('0')
            result.push_byte('0')
            let hi = (b >> 4)(UInt)
            let lo = (b & 0x0F(UInt8))(UInt)
            result.push_byte(hex_char(hi))
            result.push_byte(hex_char(lo))
        } else {
            result.push_byte(b)
        }
    }
    result.push_byte('"')
    return result
}

let format_json_number(f Float64) String = {
    if f.is_nan() then {
        return "null"
    }
    if f.is_inf() then {
        return "null"
    }

    let is_negative = f.is_sign_negative() and f <> 0.0
    let abs_val = if is_negative then 0.0 - f else f

    let truncated = abs_val.trunc()
    if abs_val == truncated then {
        let int_val = abs_val(Int)
        let mut result = String.new()
        if is_negative then {
            result.push_byte('-')
        }
        result.push_string(int_val.to_string())
        return result
    }

    let mut result = String.new()
    if is_negative then {
        result.push_byte('-')
    }

    let int_part = truncated(Int)
    result.push_string(int_part.to_string())
    result.push_byte('.')

    let frac_part = abs_val - truncated
    let mut frac = frac_part
    let mut digits List[UInt8] = []
    let max_digits UInt = 15
    for _ in 0..<max_digits then {
        frac = frac * 10.0
        let digit = frac(Int)
        digits.push(digit(UInt8) + '0')
        frac = frac - digit(Float64)
    }

    let mut end = digits.count()
    while end > 1 and digits[end - 1] == '0' then {
        end -= 1
    }

    for j in 0..<end then {
        result.push_byte(digits[j])
    }

    return result
}

private let make_indent(level UInt) String = {
    let mut out = String.new()
    for _ in 0..<level then {
        out.push_string("  ")
    }
    return out
}

private let to_string_pretty_array(elements List[ref JsonValue], level UInt) String = {
    let count = elements.count()
    if count == 0 then {
        return "[]"
    }

    let mut result = String.new()
    result.push_string("[\n")
    let child_indent = make_indent(level + 1)
    for i in 0..<count then {
        if i > 0 then {
            result.push_string(",\n")
        }
        result.push_string(child_indent)
        result.push_string(to_string_pretty_impl(elements[i].val, level + 1))
    }
    result.push_byte('\n')
    result.push_string(make_indent(level))
    result.push_byte(']')
    return result
}

private let to_string_pretty_object(entries Dict[String, ref JsonValue], level UInt) String = {
    if entries.count() == 0 then {
        return "{}"
    }

    let mut result = String.new()
    result.push_string("{\n")
    let child_indent = make_indent(level + 1)
    let mut first = true
    for entry in entries then {
        if not first then {
            result.push_string(",\n")
        }
        first = false
        result.push_string(child_indent)
        result.push_string(escape_json_string(entry.first))
        result.push_string(": ")
        result.push_string(to_string_pretty_impl(entry.second.val, level + 1))
    }
    result.push_byte('\n')
    result.push_string(make_indent(level))
    result.push_byte('}')
    return result
}

private let to_string_pretty_impl(value JsonValue, level UInt) String = {
    return when value in {
        .Null then "null",
        .Bool(v) then if v then "true" else "false",
        .Number(v) then format_json_number(v),
        .String(v) then escape_json_string(v),
        .Array(elements) then to_string_pretty_array(elements, level),
        .Object(entries) then to_string_pretty_object(entries, level),
    }
}

// ============================================================================
// JsonValue Methods
// ============================================================================
given JsonValue {

    // --- Type checking methods ---

    public is_null(self ref) Bool = self is .Null

    public is_bool(self ref) Bool = self is .Bool(_)

    public is_number(self ref) Bool = self is .Number(_)

    public is_string(self ref) Bool = self is .String(_)

    public is_array(self ref) Bool = self is .Array(_)

    public is_object(self ref) Bool = self is .Object(_)

    // --- Value extraction methods ---

    public as_bool(self ref) Option[Bool] = when self in {
        .Bool(v) then Option[Bool].Some(v),
        _ then Option[Bool].None(),
    }

    public as_number(self ref) Option[Float64] = when self in {
        .Number(v) then Option[Float64].Some(v),
        _ then Option[Float64].None(),
    }

    public as_string(self ref) Option[String] = when self in {
        .String(v) then Option[String].Some(v),
        _ then Option[String].None(),
    }

    public as_array(self ref) Option[List[ref JsonValue]] = when self in {
        .Array(v) then Option[List[ref JsonValue]].Some(v),
        _ then Option[List[ref JsonValue]].None(),
    }

    public as_object(self ref) Option[Dict[String, ref JsonValue]] = when self in {
        .Object(v) then Option[Dict[String, ref JsonValue]].Some(v),
        _ then Option[Dict[String, ref JsonValue]].None(),
    }

    // --- Indexed access methods ---

    public get_field(self ref, key String) Option[ref JsonValue] = when self in {
        .Object(entries) then entries.get(key),
        _ then Option[ref JsonValue].None(),
    }

    public get_element(self ref, index UInt) Option[ref JsonValue] = when self in {
        .Array(elements) then elements.get(index),
        _ then Option[ref JsonValue].None(),
    }

    public to_string_pretty(self ref) String = to_string_pretty_impl(self, 0)
}

// ============================================================================
// JsonValue Eq Implementation
// ============================================================================
given JsonValue as Eq {

    public equals(self, other JsonValue) Bool = when self in {
        .Null then when other in {
            .Null then true,
            _ then false,
        },
        .Bool(a) then when other in {
            .Bool(b) then a == b,
            _ then false,
        },
        .Number(a) then when other in {
            .Number(b) then a == b,
            _ then false,
        },
        .String(a) then when other in {
            .String(b) then a == b,
            _ then false,
        },
        .Array(a) then when other in {
            .Array(b) then {
                if a.count() <> b.count() then {
                    return false
                }
                for i in 0..<a.count() then {
                    if a[i].val <> b[i].val then {
                        return false
                    }
                }
                return true
            },
            _ then false,
        },
        .Object(a) then when other in {
            .Object(b) then {
                if a.count() <> b.count() then {
                    return false
                }
                for entry in a then {
                    when b.get(entry.first) in {
                        .None then { return false },
                        .Some(bval) then {
                            if entry.second.val <> bval.val then {
                                return false
                            }
                        },
                    }
                }
                return true
            },
            _ then false,
        },
    }
}
