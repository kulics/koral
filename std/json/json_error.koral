// ============================================================================
// std.json - JsonError Type
// ============================================================================
// JSON error type with position information.
// Implements the Error and ToString traits for use with Result.
// ============================================================================

public type JsonError(msg String, position UInt)

given JsonError as Error {

    public message(self ref) String = {
        let mut result = String.new()
        result.push_string("JSON error at position ")
        result.push_string(self.position.to_string())
        result.push_string(": ")
        result.push_string(self.msg)
        return result
    }
}

given JsonError as ToString {

    public to_string(self ref) String = self.message()
}
