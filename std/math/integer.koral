given Int as Numeric {

    abs(self) Self =
    if self == Int.min_value() then panic("integer overflow: abs of min value")
    else if self < 0 then -self
        else self
}

given Int as Integer {

    wrapping_abs(self) Self =
        if self < 0 then self.wrapping_neg()
        else self

    pow(self, exp UInt) Self =
        pow_nonwrap(self, exp, 1(Int))

    wrapping_pow(self, exp UInt) Self = {
        let mut result = 1
        let mut b = self
        let mut e = exp
        while e > 0 then {
            if e % 2 == 1 then { result = result.wrapping_mul(b) }
            b = b.wrapping_mul(b)
            e = e / 2
        }
        return result
    }

    gcd(a Self, b Self) Self = {
        let x = if a < 0 then -a else a
        let y = if b < 0 then -b else b
        return gcd_nonneg(x, y, 0(Int))
    }

    lcm(a Self, b Self) Self = {
        if a == 0 or b == 0 then {
            return 0
        }
        let g = gcd_nonneg(
            if a < 0 then -a else a,
            if b < 0 then -b else b,
            0(Int)
        )
        let result = (a / g) * b
        return if result < 0 then -result else result
    }

    ilog2(x Self) UInt = {
        if x == 0 then panic("ilog2: argument is zero")
        let v = if x < 0 then -x else x
        return ilog_nonneg(v, 0(Int), 2(Int), "ilog2: argument is zero")
    }

    ilog10(x Self) UInt = {
        if x == 0 then panic("ilog10: argument is zero")
        let v = if x < 0 then -x else x
        return ilog_nonneg(v, 0(Int), 10(Int), "ilog10: argument is zero")
    }
}

