using std { .. }
// ============================================================================
// std.math - Signed Integer Module
// ============================================================================

// ============================================================================
// Shared Helpers
// ============================================================================

private let pow_nonwrap[T Mul[T]](base T, exp UInt, one T) T = {
    let mut result = one
    let mut b = base
    let mut e = exp
    while e > 0 then {
        if e % 2 == 1 then { result = result * b }
        b = b * b
        e = e / 2
    }
    return result
}

private let gcd_nonneg[T Rem[T] and Ord](a T, b T, zero T) T = {
    let mut x = a
    let mut y = b
    while y <> zero then {
        let t = y
        y = x % y
        x = t
    }
    return x
}

private let ilog_nonneg[T Div[T] and Ord](x T, zero T, radix T, name String) UInt = {
    if x == zero then panic(name)
    let mut result UInt = 0
    let mut n = x
    while n >= radix then {
        n = n / radix
        result = result + 1
    }
    return result
}

private let lcm_nonneg[T Div[T] and Mul[T] and Rem[T] and Ord](a T, b T, zero T) T =
    if a == zero or b == zero then zero
    else (a / gcd_nonneg(a, b, zero)) * b

given Int8 as Numeric {

    abs(self) Self =
        if self == Int8.min_value() then panic("integer overflow: abs of min value")
        else if self < 0 then -self
        else self
}

given Int8 as Integer {

    wrapping_abs(self) Self =
        if self < 0 then self.wrapping_neg()
        else self

    pow(self, exp UInt) Self =
        pow_nonwrap(self, exp, 1(Int8))

    wrapping_pow(self, exp UInt) Self = {
        let mut result Int8 = 1
        let mut b = self
        let mut e = exp
        while e > 0 then {
            if e % 2 == 1 then { result = result.wrapping_mul(b) }
            b = b.wrapping_mul(b)
            e = e / 2
        }
        return result
    }

    gcd(a Self, b Self) Self = {
        let x = if a < 0 then -a else a
        let y = if b < 0 then -b else b
        return gcd_nonneg(x, y, 0(Int8))
    }

    lcm(a Self, b Self) Self = {
        if a == 0 or b == 0 then {
            return 0
        }
        let g = gcd_nonneg(
            if a < 0 then -a else a,
            if b < 0 then -b else b,
            0(Int8)
        )
        let result = (a / g) * b
        return if result < 0 then -result else result
    }

    ilog2(x Self) UInt = {
        if x == 0 then panic("ilog2: argument is zero")
        let v = if x < 0 then -x else x
        return ilog_nonneg(v, 0(Int8), 2(Int8), "ilog2: argument is zero")
    }

    ilog10(x Self) UInt = {
        if x == 0 then panic("ilog10: argument is zero")
        let v = if x < 0 then -x else x
        return ilog_nonneg(v, 0(Int8), 10(Int8), "ilog10: argument is zero")
    }
}

