given UInt as Numeric {

    abs(self) Self = self
}

// ============================================================================
// Integer Generic Free Functions
// ============================================================================
public let gcd[T Integer](a T, b T) T = T.gcd(a, b)
public let lcm[T Integer](a T, b T) T = T.lcm(a, b)
public let ilog2[T Integer](x T) UInt = T.ilog2(x)
public let ilog10[T Integer](x T) UInt = T.ilog10(x)

