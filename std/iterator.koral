// ============================================================================
// Koral Standard Library - Iterator API
// ============================================================================
// Provides lazy, chainable operations on iterators similar to Java Streams.
// ============================================================================

// Generic Iterator trait for for-loop support
public trait Iterator[T Any] {
    next(self ref mut) Option[T]
}

// Iterable trait - types that can produce an iterator
public trait Iterable[T Any, R Iterator[T]] {
    iterator(self ref) R
}

// ============================================================================
// Intermediate Iterator Types
// ============================================================================

// FilterIterator - filters elements based on predicate
public type FilterIterator[T Any, R Iterator[T]](
    protected mut iter R,
    protected predicate Func[T, Bool],
)

given[T Any, R Iterator[T]] FilterIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        while self.iter.next() is .Some(v) then {
            if self.predicate(v) then {
                return Option[T].Some(v)
            }
        }
        return Option[T].None()
    }
}

// MapIterator - transforms elements using mapper function
public type MapIterator[T Any, U Any, R Iterator[T]](protected mut iter R, protected mapper Func[T, U])

given[T Any, U Any, R Iterator[T]] MapIterator[T, U, R] as Iterator[U] {

    public next(self ref mut) Option[U] = self.iter.next() and then self.mapper(it)
}

// FilterMapIterator - filters and transforms in one operation
public type FilterMapIterator[T Any, U Any, R Iterator[T]](
    protected mut iter R,
    protected mapper Func[T, Option[U]],
)

given[T Any, U Any, R Iterator[T]] FilterMapIterator[T, U, R] as Iterator[U] {

    public next(self ref mut) Option[U] = {
        while self.iter.next() is .Some(v) then {
            when self.mapper(v) in {
                .Some(u) then {
                    return Option[U].Some(u)
                },
                .None then {},
            }
        }
        return Option[U].None()
    }
}

// TakeIterator - takes first n elements
public type TakeIterator[T Any, R Iterator[T]](protected mut iter R, protected mut remaining UInt)

given[T Any, R Iterator[T]] TakeIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        if self.remaining == 0 then {
            return Option[T].None()
        }
        self.remaining -= 1
        return self.iter.next()
    }
}

// SkipIterator - skips first n elements
public type SkipIterator[T Any, R Iterator[T]](protected mut iter R, protected mut to_skip UInt)

given[T Any, R Iterator[T]] SkipIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        while self.to_skip > 0 then {
            self.iter.next() or else {
                return Option[T].None()
            }
            self.to_skip -= 1
        }
        return self.iter.next()
    }
}

// StepIterator - takes every nth element
public type StepIterator[T Any, R Iterator[T]](
    protected mut iter R,
    protected step_size UInt,
    protected mut first Bool,
)

given[T Any, R Iterator[T]] StepIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        if self.first then {
            self.first = false
            return self.iter.next()
        }
        // Skip step_size - 1 elements
        let mut i UInt = 1
        while i < self.step_size then {
            self.iter.next() or else {
                return Option[T].None()
            }
            i += 1
        }
        return self.iter.next()
    }
}

// EnumerateIterator - pairs each element with its index
public type EnumerateIterator[T Any, R Iterator[T]](protected mut iter R, protected mut index UInt)

given[T Any, R Iterator[T]] EnumerateIterator[T, R] as Iterator[Pair[UInt, T]] {

    public next(self ref mut) Option[Pair[UInt, T]] = {
        return self.iter.next() and then {
            let idx = self.index
            self.index += 1
            yield Pair[UInt, T](idx, it)
        }
    }
}

// InspectIterator - executes side effect without modifying elements
public type InspectIterator[T Any, R Iterator[T]](protected mut iter R, protected action Func[T, Void])

given[T Any, R Iterator[T]] InspectIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        return self.iter.next() and then {
            self.action(it);
            yield it
        }
    }
}

// IntersperseIterator - inserts separator between elements
public type IntersperseIterator[T Any, R Iterator[T]](
    protected mut iter R,
    protected separator T,
    protected mut next_is_separator Bool,
    protected mut pending Option[T],
)

given[T Any, R Iterator[T]] IntersperseIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        // If we need to return separator
        if self.next_is_separator then {
            when self.pending in {
                .Some(_) then {
                    self.next_is_separator = false
                    return Option[T].Some(self.separator)
                },
                .None then {},
            }
        }
        // Return pending value
        when self.pending in {
            .Some(v) then {
                self.pending = Option[T].None()
                // Prefetch next element
                when self.iter.next() in {
                    .Some(next_v) then {
                        self.pending = Option[T].Some(next_v)
                        self.next_is_separator = true
                    },
                    .None then {},
                }
                return Option[T].Some(v)
            },
            .None then {
                // First call, get first element
                when self.iter.next() in {
                    .Some(v) then {
                        // Prefetch next
                        when self.iter.next() in {
                            .Some(next_v) then {
                                self.pending = Option[T].Some(next_v)
                                self.next_is_separator = true
                            },
                            .None then {},
                        }
                        return Option[T].Some(v)
                    },
                    .None then {
                        return Option[T].None()
                    },
                }
            },
        }
    }
}

// TakeWhileIterator - takes elements while predicate is true
public type TakeWhileIterator[T Any, R Iterator[T]](
    protected mut iter R,
    protected predicate Func[T, Bool],
    protected mut done Bool,
)

given[T Any, R Iterator[T]] TakeWhileIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        if self.done then {
            return Option[T].None()
        }
        when self.iter.next() in {
            .Some(v) then {
                if self.predicate(v) then {
                    return Option[T].Some(v)
                } else {
                    self.done = true
                    return Option[T].None()
                }
            },
            .None then {
                return Option[T].None()
            },
        }
    }
}

// SkipWhileIterator - skips elements while predicate is true
public type SkipWhileIterator[T Any, R Iterator[T]](
    protected mut iter R,
    protected predicate Func[T, Bool],
    protected mut skipping Bool,
)

given[T Any, R Iterator[T]] SkipWhileIterator[T, R] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        if not self.skipping then {
            return self.iter.next()
        }
        while self.iter.next() is .Some(v) then {
            if not self.predicate(v) then {
                self.skipping = false
                return Option[T].Some(v)
            }
        }
        return Option[T].None()
    }
}

// ChainIterator - chains two iterators of the same element type
public type ChainIterator[T Any, R1 Iterator[T], R2 Iterator[T]](
    protected mut first R1,
    protected mut second R2,
    protected mut use_second Bool,
)

given[T Any, R1 Iterator[T], R2 Iterator[T]] ChainIterator[T, R1, R2] as Iterator[T] {

    public next(self ref mut) Option[T] = {
        if not self.use_second then {
            when self.first.next() in {
                .Some(v) then {
                    return Option[T].Some(v)
                },
                .None then {
                    self.use_second = true
                },
            }
        }
        return self.second.next()
    }
}

// ZipIterator - zips two iterators into pairs
public type ZipIterator[A Any, B Any, R1 Iterator[A], R2 Iterator[B]](
    protected mut first R1,
    protected mut second R2,
)

given[A Any, B Any, R1 Iterator[A], R2 Iterator[B]] ZipIterator[A, B, R1, R2] as Iterator[Pair[A, B]] {

    public next(self ref mut) Option[Pair[A, B]] = {
        return self.first.next() and then {
            let a = it
            yield self.second.next() and then Pair[A, B](a, it)
        }
    }
}

// FlatMapIterator - flattens nested iterators (fully lazy)
public type FlatMapIterator[T Any, U Any, R Iterator[T], InnerR Iterator[U]](
    protected mut outer R,
    protected mapper Func[T, InnerR],
    protected mut current_inner Option[InnerR],
)

given[T Any, U Any, R Iterator[T], InnerR Iterator[U]] FlatMapIterator[T, U, R, InnerR] as Iterator[U] {

    public next(self ref mut) Option[U] = {
        while true then {
            when self.current_inner in {
                .Some(inner) then {
                    // Copy out the inner iterator
                    let mut inner_copy = inner
                    when inner_copy.next() in {
                        .Some(v) then {
                            // Write modified iterator back
                            self.current_inner = Option[InnerR].Some(inner_copy)
                            return Option[U].Some(v)
                        },
                        .None then {
                            // Inner exhausted, clear it
                            self.current_inner = Option[InnerR].None()
                        },
                    }
                },
                .None then {
                    // Get next from outer iterator
                    when self.outer.next() in {
                        .None then {
                            return Option[U].None()
                        },
                        .Some(outer_val) then {
                            self.current_inner = Option[InnerR].Some(self.mapper(outer_val))
                        },
                    }
                },
            }
        }
        return Option[U].None()
    }
}

// ============================================================================
// Iterator Intermediate Operations
// ============================================================================
given[T Any] Iterator[T] {

    // Filter - returns iterator with elements matching predicate
    public filter(self, fn Func[T, Bool]) FilterIterator[T, Self] =
        FilterIterator[T, Self](self, fn)

    // Map - transforms each element
    public map[U Any](self, fn Func[T, U]) MapIterator[T, U, Self] =
        MapIterator[T, U, Self](self, fn)

    // FilterMap - filter and transform in one operation
    public filter_map[U Any](self, fn Func[T, Option[U]]) FilterMapIterator[T, U, Self] =
        FilterMapIterator[T, U, Self](self, fn)

    // Take - take first n elements
    public take(self, n UInt) TakeIterator[T, Self] =
        TakeIterator[T, Self](self, n)

    // Skip - skip first n elements
    public skip(self, n UInt) SkipIterator[T, Self] =
        SkipIterator[T, Self](self, n)

    // StepBy - take every nth element
    public step_by(self, n UInt) StepIterator[T, Self] = {
        if n < 1 then {
            panic("step size must be at least 1");
        }
        return StepIterator[T, Self](self, n, true)
    }

    // Enumerate - pair each element with its index
    public enumerate(self) EnumerateIterator[T, Self] =
        EnumerateIterator[T, Self](self, 0)

    // Inspect - execute side effect without modifying elements
    public inspect(self, fn Func[T, Void]) InspectIterator[T, Self] =
        InspectIterator[T, Self](self, fn)

    // Intersperse - insert separator between elements
    public intersperse(self, v T) IntersperseIterator[T, Self] =
        IntersperseIterator[T, Self](self, v, false, Option[T].None())

    // TakeWhile - take elements while predicate is true
    public take_while(self, fn Func[T, Bool]) TakeWhileIterator[T, Self] =
        TakeWhileIterator[T, Self](self, fn, false)

    // SkipWhile - skip elements while predicate is true
    public skip_while(self, fn Func[T, Bool]) SkipWhileIterator[T, Self] =
        SkipWhileIterator[T, Self](self, fn, true)

    // Chain - chain with another iterator of the same element type
    public chain[R2 Iterator[T]](self, other R2) ChainIterator[T, Self, R2] =
        ChainIterator[T, Self, R2](self, other, false)

    // Zip - zip with another iterator into pairs
    public zip[U Any, R2 Iterator[U]](self, other R2) ZipIterator[T, U, Self, R2] =
        ZipIterator[T, U, Self, R2](self, other)

    // FlatMap - map each element to an iterator and flatten results
    public flat_map[U Any, InnerR Iterator[U]](self, fn Func[T, InnerR]) FlatMapIterator[T, U, Self, InnerR] =
        FlatMapIterator[T, U, Self, InnerR](self, fn, Option[InnerR].None())
}

// ============================================================================
// Iterator Terminal Operations
// ============================================================================
given[T Any] Iterator[T] {

    // Fold - reduce with initial value
    public fold[U Any](self, initial U, fn Func[U, T, U]) U = {
        let mut acc = initial
        let mut iter = self
        while iter.next() is .Some(v) then {
            acc = fn(acc, v)
        }
        return acc
    }

    // Reduce - reduce without initial value
    public reduce(self, fn Func[T, T, T]) Option[T] = {
        let mut iter = self
        when iter.next() in {
            .None then {
                return Option[T].None()
            },
            .Some(first) then {
                let mut acc = first
                while iter.next() is .Some(v) then {
                    acc = fn(acc, v)
                }
                return Option[T].Some(acc)
            },
        }
    }

    // ToList - collect into List
    public into_list(self) List[T] = {
        let mut result List[T] = []
        let mut iter = self
        while iter.next() is .Some(v) then {
            result.push(v)
        }
        return result
    }

    // ForEach - execute side effect for each element
    public for_each(self, fn Func[T, Void]) Void = {
        let mut iter = self
        while iter.next() is .Some(v) then {
            fn(v);
        }
    }

    // Count - count elements
    public count(self) UInt = {
        let mut n UInt = 0
        let mut iter = self
        while iter.next() is .Some(_) then {
            n += 1
        }
        return n
    }

    // First - get first element
    public first(self) Option[T] = {
        let mut iter = self
        return iter.next()
    }

    // Last - get last element
    public last(self) Option[T] = {
        let mut result = Option[T].None()
        let mut iter = self
        while iter.next() is .Some(v) then {
            result = Option[T].Some(v)
        }
        return result
    }

    // Nth - get element at index
    public nth(self, n UInt) Option[T] = {
        let mut iter = self
        let mut i UInt = 0
        while iter.next() is .Some(v) then {
            if i == n then {
                return Option[T].Some(v)
            }
            i += 1
        }
        return Option[T].None()
    }

    // Position - find index of first element matching predicate
    public position(self, fn Func[T, Bool]) Option[UInt] = {
        let mut iter = self
        let mut i UInt = 0
        while iter.next() is .Some(v) then {
            if fn(v) then {
                return Option[UInt].Some(i)
            }
            i += 1
        }
        return Option[UInt].None()
    }

    // Find - find first element matching predicate
    public find(self, fn Func[T, Bool]) Option[T] = {
        let mut iter = self
        while iter.next() is .Some(v) then {
            if fn(v) then {
                return Option[T].Some(v)
            }
        }
        return Option[T].None()
    }

    // FindMap - find first element that maps to Some
    public find_map[U Any](self, fn Func[T, Option[U]]) Option[U] = {
        let mut iter = self
        while iter.next() is .Some(v) then {
            when fn(v) in {
                .Some(u) then {
                    return Option[U].Some(u)
                },
                .None then {},
            }
        }
        return Option[U].None()
    }

    // Any - check if any element matches predicate
    public any(self, fn Func[T, Bool]) Bool = {
        let mut iter = self
        while iter.next() is .Some(v) then {
            if fn(v) then {
                return true
            }
        }
        return false
    }

    // All - check if all elements match predicate
    public all(self, fn Func[T, Bool]) Bool = {
        let mut iter = self
        while iter.next() is .Some(v) then {
            if not fn(v) then {
                return false
            }
        }
        return true
    }

    // IsEmpty - check if iterator has no elements
    public is_empty(self) Bool = {
        let mut iter = self
        return iter.next().is_none()
    }

    // MaxBy - find element with maximum key
    public max_by[K Ord](self, fn Func[T, K]) Option[T] = {
        let mut iter = self
        when iter.next() in {
            .None then {
                return Option[T].None()
            },
            .Some(first) then {
                let mut result = first
                let mut result_key = fn(first)
                while iter.next() is .Some(v) then {
                    let key = fn(v)
                    if key > result_key then {
                        result = v
                        result_key = key
                    }
                }
                return Option[T].Some(result)
            },
        }
    }

    // MinBy - find element with minimum key
    public min_by[K Ord](self, fn Func[T, K]) Option[T] = {
        let mut iter = self
        when iter.next() in {
            .None then {
                return Option[T].None()
            },
            .Some(first) then {
                let mut result = first
                let mut result_key = fn(first)
                while iter.next() is .Some(v) then {
                    let key = fn(v)
                    if key < result_key then {
                        result = v
                        result_key = key
                    }
                }
                return Option[T].Some(result)
            },
        }
    }
}

// ============================================================================
// Iterator Terminal Operations with Eq constraint
// ============================================================================
given[T Eq] Iterator[T] {

    // Contains - check if iterator contains a value
    public contains(self, value T) Bool = {
        let mut iter = self
        while iter.next() is .Some(v) then {
            if v == value then {
                return true
            }
        }
        return false
    }
}

// ============================================================================
// Iterator Terminal Operations with Ord constraint
// ============================================================================
given[T Ord] Iterator[T] {

    // Max - find maximum element
    public max(self) Option[T] = {
        let mut iter = self
        when iter.next() in {
            .None then {
                return Option[T].None()
            },
            .Some(first) then {
                let mut result = first
                while iter.next() is .Some(v) then {
                    if v > result then {
                        result = v
                    }
                }
                return Option[T].Some(result)
            },
        }
    }

    // Min - find minimum element
    public min(self) Option[T] = {
        let mut iter = self
        when iter.next() in {
            .None then {
                return Option[T].None()
            },
            .Some(first) then {
                let mut result = first
                while iter.next() is .Some(v) then {
                    if v < result then {
                        result = v
                    }
                }
                return Option[T].Some(result)
            },
        }
    }
}

// ============================================================================
// Iterator Terminal Operations with Hash constraint
// ============================================================================
given[T Hash] Iterator[T] {

    // ToSet - collect into Set
    public into_set(self) Set[T] = {
        let mut result = Set[T].new()
        let mut iter = self
        while iter.next() is .Some(v) then {
            result.insert(v);
        }
        return result
    }
}

// ============================================================================
// Iterator Numeric Aggregations
// ============================================================================
given[T Add[T] and Zero] Iterator[T] {

    // Sum - sums elements using Zero.zero/Add.add
    public sum(self) T = {
        let mut acc = T.zero()
        let mut iter = self
        while iter.next() is .Some(v) then {
            acc = acc.add(v)
        }
        return acc
    }
}

given[T Mul[T] and One] Iterator[T] {

    // Product - multiplies elements using One.one/Mul.mul
    public product(self) T = {
        let mut acc = T.one()
        let mut iter = self
        while iter.next() is .Some(v) then {
            acc = acc.mul(v)
        }
        return acc
    }
}

given[T Add[T] and Div[T] and Zero and One] Iterator[T] {

    // Average - returns None for empty iterators to avoid division by zero.
    public average(self) Option[T] = {
        let mut acc = T.zero()
        let mut count = 0
        let mut count_t = T.zero()
        let mut iter = self
        while iter.next() is .Some(v) then {
            acc = acc.add(v)
            count += 1
            count_t = count_t.add(T.one())
        }
        return if count == 0 then Option[T].None()
        else Option[T].Some(acc.div(count_t))
    }
}
