using std { .. }
// ============================================================================
// std.Container.Stack
// ============================================================================

public type Stack[T Any](protected mut list List[T])

public type StackIterator[T Any](protected mut list List[T], protected mut remaining UInt)

given[T Deref] Stack[T] {

    public new() Self = Stack[T](List[T].new())

    public with_capacity(capacity UInt) Self = Stack[T](List[T].with_capacity(capacity))

    public count(self ref) UInt = self.list.count()

    public is_empty(self ref) Bool = self.list.is_empty()

    public clear(self mut ref) Void = {
        self.list.clear()
    }

    public push(self mut ref, value T) Void = {
        self.list.push(value)
    }

    public pop(self mut ref) Option[T] = self.list.pop()

    public peek(self ref) Option[T] = self.list.last()
}

given[T Deref] Stack[T] as Iterable[T, StackIterator[T]] {

    public iterator(self ref) StackIterator[T] = StackIterator[T](self.list, self.list.count())
}

given[T Deref] StackIterator[T] as Iterator[T] {

    public next(self mut ref) Option[T] = {
        if self.remaining == 0 then {
            return Option[T].None()
        }
        self.remaining = self.remaining - 1
        return self.list.get(self.remaining)
    }
}
