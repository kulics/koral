using std { .. }
// ============================================================================
// std.Container.Deque
// ============================================================================

protected type DequeStorage[T Any](mut source mut ptr T, mut len UInt, mut cap UInt, mut head UInt)

given[T Deref] DequeStorage[T] as Drop {

    drop(source mut ptr Self) Void = {
        for i in 0..<source.len then {
            let index = (source.head + i) % source.cap
            deinit_memory(source.source + index)
        }
        dealloc_memory(source.source)
    }
}

public type Deque[T Any](protected mut storage mut ref DequeStorage[T])

public type DequeIterator[T Any](protected storage mut ref DequeStorage[T], protected mut index UInt)

given[T Deref] Deque[T] {

    public new() Self = {
        let cap UInt = 10
        let source = alloc_memory[T](cap)
        let storage = box(DequeStorage[T](source, 0, cap, 0))
        return Deque[T](storage)
    }

    public with_capacity(capacity UInt) Self = {
        let cap = if capacity < 1 then 1 else capacity
        let source = alloc_memory[T](cap)
        let storage = box(DequeStorage[T](source, 0, cap, 0))
        return Deque[T](storage)
    }

    public count(self ref) UInt = self.storage.len

    public reserve(self mut ref, additional UInt) Void = {
        self.ensure_capacity(self.storage.len + additional)
    }

    public is_empty(self ref) Bool = self.storage.len == 0

    private physical_index(self ref, logical_index UInt) UInt = (self.storage.head + logical_index) % self.storage.cap

    private ensure_unique(self mut ref) Void = {
        if ref_count(self.storage) > 1 then {
            let old = self.storage
            let new_source = alloc_memory[T](old.cap)
            for i in 0..<old.len then {
                let old_index = (old.head + i) % old.cap
                init_memory(new_source + i, old.source[old_index])
            }
            let new_storage = box(DequeStorage[T](new_source, old.len, old.cap, 0))
            self.storage = new_storage
        }
    }

    private ensure_capacity(self mut ref, min_capacity UInt) Void = {
        if min_capacity > self.storage.cap then {
            let mut new_cap = self.storage.cap * 2
            if new_cap < min_capacity then {
                new_cap = min_capacity
            }
            let old = self.storage
            let new_source = alloc_memory[T](new_cap)
            if ref_count(old) == 1 then {
                for i in 0..<old.len then {
                    let old_index = (old.head + i) % old.cap
                    init_memory(new_source + i, take_memory(old.source + old_index))
                }
                dealloc_memory(old.source)
                self.storage.source = new_source
                self.storage.cap = new_cap
                self.storage.head = 0
            } else {
                for i in 0..<old.len then {
                    let old_index = (old.head + i) % old.cap
                    init_memory(new_source + i, old.source[old_index])
                }
                let new_storage = box(DequeStorage[T](new_source, old.len, new_cap, 0))
                self.storage = new_storage
            }
        } else {
            self.ensure_unique()
        }
    }

    public push_back(self mut ref, value T) Void = {
        self.ensure_capacity(self.storage.len + 1)
        let index = self.physical_index(self.storage.len)
        init_memory(self.storage.source + index, value)
        self.storage.len = self.storage.len + 1
    }

    public push_front(self mut ref, value T) Void = {
        self.ensure_capacity(self.storage.len + 1)
        self.storage.head = (self.storage.head + self.storage.cap - 1) % self.storage.cap
        init_memory(self.storage.source + self.storage.head, value)
        self.storage.len = self.storage.len + 1
    }

    public pop_front(self mut ref) Option[T] = {
        if self.storage.len == 0 then {
            return Option[T].None()
        }
        self.ensure_unique()
        let value = take_memory(self.storage.source + self.storage.head)
        self.storage.head = (self.storage.head + 1) % self.storage.cap
        self.storage.len = self.storage.len - 1
        if self.storage.len == 0 then {
            self.storage.head = 0
        }
        return Option[T].Some(value)
    }

    public pop_back(self mut ref) Option[T] = {
        if self.storage.len == 0 then {
            return Option[T].None()
        }
        self.ensure_unique()
        let index = self.physical_index(self.storage.len - 1)
        let value = take_memory(self.storage.source + index)
        self.storage.len = self.storage.len - 1
        if self.storage.len == 0 then {
            self.storage.head = 0
        }
        return Option[T].Some(value)
    }

    public first(self ref) Option[T] = self.get(0)

    public last(self ref) Option[T] = {
        if self.storage.len == 0 then {
            return Option[T].None()
        }
        return self.get(self.storage.len - 1)
    }

    public get(self ref, index UInt) Option[T] = {
        if index >= self.storage.len then {
            return Option[T].None()
        }
        let physical = self.physical_index(index)
        return Option[T].Some(self.storage.source[physical])
    }

    public clear(self mut ref) Void = {
        self.ensure_unique()
        for i in 0..<self.storage.len then {
            let index = self.physical_index(i)
            deinit_memory(self.storage.source + index)
        }
        self.storage.len = 0
        self.storage.head = 0
    }

    // Reverses the order of elements in-place. O(n).
    public reverse(self mut ref) Void = {
        if self.storage.len <= 1 then {
            return
        }
        self.ensure_unique()
        let mut left UInt = 0
        let mut right = self.storage.len - 1
        while left < right then {
            let lp = self.physical_index(left)
            let rp = self.physical_index(right)
            let tmp = self.storage.source[lp]
            self.storage.source[lp] = self.storage.source[rp]
            self.storage.source[rp] = tmp
            left += 1
            right -= 1
        }
    }

    // Retains only elements satisfying the predicate, preserving order. O(n).
    public retain(self mut ref, predicate Func[T, Bool]) Void = {
        if self.storage.len == 0 then {
            return
        }
        self.ensure_unique()
        let mut write UInt = 0
        let mut read UInt = 0
        while read < self.storage.len then {
            let rp = self.physical_index(read)
            let v = self.storage.source[rp]
            if predicate(v) then {
                let wp = self.physical_index(write)
                if write <> read then {
                    init_memory(self.storage.source + wp, take_memory(self.storage.source + rp))
                }
                write += 1
            } else {
                deinit_memory(self.storage.source + rp)
            }
            read += 1
        }
        self.storage.len = write
    }
}

given[T Eq and Deref] Deque[T] {

    public contains(self ref, value T) Bool = {
        for i in 0..<self.storage.len then {
            let physical = self.physical_index(i)
            if self.storage.source[physical] == value then {
                return true
            }
        }
        return false
    }
}

given[T Deref] Deque[T] as Iterable[T, DequeIterator[T]] {

    public iterator(self ref) DequeIterator[T] = DequeIterator[T](self.storage, 0)
}

given[T Deref] DequeIterator[T] as Iterator[T] {

    public next(self mut ref) Option[T] = {
        if self.index >= self.storage.len then {
            return Option[T].None()
        }
        let index = (self.storage.head + self.index) % self.storage.cap
        let value = self.storage.source[index]
        self.index += 1
        return Option[T].Some(value)
    }
}

given[T Deref] Deque[T] as Index[UInt, T] {

    public ref_at(self ref, key UInt) ref T = {
        if key >= self.storage.len then {
            panic("Deque index out of bounds")
        }
        let physical = self.physical_index(key)
        if ref_is_borrow(self) then {
            return make_ref[T, Deque[T]](self.storage.source + physical, self)
        }
        return make_ref[T, DequeStorage[T]](self.storage.source + physical, self.storage)
    }
}

given[T Deref] Deque[T] as MutIndex[UInt, T] {

    public mut_ref_at(self mut ref, key UInt) mut ref T = {
        if key >= self.storage.len then {
            panic("Deque index out of bounds")
        }
        self.ensure_unique()
        let physical = self.physical_index(key)
        if ref_is_borrow(self) then {
            return make_mut_ref[T, Deque[T]](self.storage.source + physical, self)
        }
        return make_mut_ref[T, DequeStorage[T]](self.storage.source + physical, self.storage)
    }
}
