// ---------------------------------------------------------------------------
// given UInt Parseable, UInt RadixParseable
// ---------------------------------------------------------------------------

given UInt as Parseable {

    public parse(s String) Result[Self] = UInt.parse_radix(s, 10)
}

given UInt as RadixParseable {

    public parse_radix(s String, radix UInt) Result[Self] = {
        if radix < 2 or radix > 36 then {
            return Result[UInt].Error(box("radix must be in range 2..36"))
        }

        let trimmed = s.trim_ascii()
        if trimmed.is_empty() then {
            return Result[UInt].Error(box("empty string"))
        }

        let mut i UInt = 0
        let len = trimmed.count()

        // Unsigned types reject negative sign
        if trimmed[0] == '-' then {
            return Result[UInt].Error(box("negative value for unsigned type"))
        }
        if trimmed[0] == '+' then {
            i += 1
        }

        // Skip optional radix prefix
        if i + 1 < len then {
            let c0 = trimmed[i]
            let c1 = trimmed[i + 1]
            if c0 == '0' then {
                if radix == 2 and (c1 == 'b' or c1 == 'B') then { i += 2 }
                else if radix == 8 and (c1 == 'o' or c1 == 'O') then { i += 2 }
                else if radix == 16 and (c1 == 'x' or c1 == 'X') then { i += 2 }
            }
        }

        if i >= len then {
            return Result[UInt].Error(box("no digits found"))
        }

        let base = radix
        let mut result UInt = 0
        let mut has_digit = false

        while i < len then {
            let ch = trimmed[i]
            if ch == '_' then {
                if not has_digit then {
                    return Result[UInt].Error(box("unexpected underscore"))
                }
                i += 1
                continue
            }
            if not is_digit_for_radix(ch, radix) then {
                return Result[UInt].Error(box("invalid character"))
            }
            let d = digit_value(ch, radix)
            if result > (UInt.max_value() - d) / base then {
                return Result[UInt].Error(box("overflow"))
            }
            result = result * base + d
            has_digit = true
            i += 1
        }

        if not has_digit then {
            return Result[UInt].Error(box("no digits found"))
        }

        return Result[UInt].Ok(result)
    }
}

// ---------------------------------------------------------------------------
// given UInt8 Parseable, UInt8 RadixParseable
// ---------------------------------------------------------------------------

given UInt8 as Parseable {

    public parse(s String) Result[Self] = UInt8.parse_radix(s, 10)
}

given UInt8 as RadixParseable {

    public parse_radix(s String, radix UInt) Result[Self] =
        when UInt.parse_radix(s, radix) in {
            .Ok(n) then 
                if n > UInt8.max_value()(UInt) then
                    Result[UInt8].Error(box("overflow"))
                else
                    Result[UInt8].Ok(n(UInt8)),
            .Error(e) then Result[UInt8].Error(e),
        }
}

