using std { .. }
// ============================================================================
// std.text - Parse Implementation
// ============================================================================
// Provides string-to-number parsing for all numeric types.
// Signed integers: Int, Int8, Int16, Int32, Int64
// Unsigned integers: UInt, UInt8, UInt16, UInt32, UInt64 (task 4.2)
// Floating point: Float32, Float64 (task 5.1)
//
// All parse functions return Result — never panic on any input.
// ============================================================================

// ---------------------------------------------------------------------------
// Helper functions
// ---------------------------------------------------------------------------

// Check whether a character is a valid digit for the given radix (2..36).
private let is_digit_for_radix(ch UInt8, radix UInt) Bool =
    if radix <= 10 then
        ch >= '0' and ch < '0' + radix(UInt8)
    else
        (ch >= '0' and ch <= '9') or
        (ch >= 'a' and ch < 'a' + (radix - 10)(UInt8)) or
        (ch >= 'A' and ch < 'A' + (radix - 10)(UInt8))

// Convert a digit character to its numeric value.
private let digit_value(ch UInt8, radix UInt) UInt =
    if ch >= '0' and ch <= '9' then (ch - '0')(UInt)
    else if ch >= 'a' and ch <= 'z' then (ch - 'a')(UInt) + 10
    else if ch >= 'A' and ch <= 'Z' then (ch - 'A')(UInt) + 10
    else panic("invalid digit")

// ---------------------------------------------------------------------------
// given Int Parseable, Int RadixParseable
// ---------------------------------------------------------------------------

given Int as Parseable {

    public parse(s String) Result[Self] = Int.parse_radix(s, 10)
}

given Int as RadixParseable {

    public parse_radix(s String, radix UInt) Result[Self] = {
        if radix < 2 or radix > 36 then {
            return Result[Int].Error(box("radix must be in range 2..36"))
        }

        let trimmed = s.trim_ascii()
        if trimmed.is_empty() then {
            return Result[Int].Error(box("empty string"))
        }

        let mut i UInt = 0
        let len = trimmed.count()

        // Check sign
        let is_negative = trimmed[0] == '-'
        let has_sign = is_negative or trimmed[0] == '+'
        if has_sign then {
            i += 1
        }

        // Skip optional radix prefix
        if i + 1 < len then {
            let c0 = trimmed[i]
            let c1 = trimmed[i + 1]
            if c0 == '0' then {
                if radix == 2 and (c1 == 'b' or c1 == 'B') then { i += 2 }
                else if radix == 8 and (c1 == 'o' or c1 == 'O') then { i += 2 }
                else if radix == 16 and (c1 == 'x' or c1 == 'X') then { i += 2 }
            }
        }

        if i >= len then {
            return Result[Int].Error(box("no digits found"))
        }

        // Parse digits with overflow check
        let base = radix(Int)
        let mut result Int = 0
        let mut has_digit = false

        while i < len then {
            let ch = trimmed[i]

            if ch == '_' then {
                if not has_digit then {
                    return Result[Int].Error(box("unexpected underscore"))
                }
                i += 1
                continue
            }

            if not is_digit_for_radix(ch, radix) then {
                return Result[Int].Error(box("invalid character"))
            }

            let d = digit_value(ch, radix)(Int)

            if result > (Int.max_value() - d) / base then {
                return Result[Int].Error(box("overflow"))
            }

            result = result * base + d
            has_digit = true
            i += 1
        }

        if not has_digit then {
            return Result[Int].Error(box("no digits found"))
        }

        if is_negative then {
            result = 0 - result
        }

        return Result[Int].Ok(result)
    }
}

// ---------------------------------------------------------------------------
// given Int8 Parseable, Int8 RadixParseable
// ---------------------------------------------------------------------------

given Int8 as Parseable {

    public parse(s String) Result[Self] = Int8.parse_radix(s, 10)
}

given Int8 as RadixParseable {

    public parse_radix(s String, radix UInt) Result[Self] =
        when Int.parse_radix(s, radix) in {
            .Ok(n) then 
                if n < Int8.min_value()(Int) or n > Int8.max_value()(Int) then
                    Result[Int8].Error(box("overflow"))
                else
                    Result[Int8].Ok(n(Int8)),
            .Error(e) then Result[Int8].Error(e),
        }
}

