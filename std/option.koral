// ============================================================================
// Koral Standard Library - Option Type
// ============================================================================
// NOTE: This file is merged into core.koral, so primitives and traits are already available.
// ============================================================================

// ============================================================================
// Option Type Definition
// ============================================================================
public type Option[T Any] {
    None(),
    Some(value T),
}

// ============================================================================
// Option Methods
// ============================================================================
given[T Any] Option[T] {

    public is_some(self ref) Bool = when self in {
        .Some(_) then true,
        .None then false,
    }
    public is_none(self ref) Bool = when self in {
        .None then true,
        .Some(_) then false,
    }
    public unwrap(self) T = when self in {
        .Some(v) then v,
        .None then panic("Option.unwrap failed: value is None"),
    }
    public expect(self, message String) T = when self in {
        .Some(v) then v,
        .None then panic("Option.expect failed: " + message),
    }
    public unwrap_or(self, default T) T = self or else default

    // Generic method: transforms the contained value using the provided function
    // Returns Some(f(value)) if self is Some(value), otherwise returns None
    public map[U Any](self, f Func[T, U]) Option[U] = self and then f(it)

    // Returns Some(value) if self is Some and predicate returns true, otherwise None
    public filter(self, predicate Func[T, Bool]) Option[T] = when self in {
        .None then Option[T].None(),
        .Some(v) then if predicate(v) then .Some(v) else .None(),
    }
}

// Eq implementation for Option when T is Eq
given[T Eq] Option[T] as Eq {

    public equals(self, other Option[T]) Bool = when self in {
        .None then other.is_none(),
        .Some(a) then when other in {
            .None then false,
            .Some(b) then a == b,
        },
    }
}
