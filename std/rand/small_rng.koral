using std { .. }
// ============================================================================
// std.rand - DefaultRandomSource (xoshiro256**)
// ============================================================================
// A fast, high-quality PRNG with 256-bit state and period 2^256-1.
// Not cryptographically secure.
//
// State is stored behind a ref so that copying DefaultRandomSource by value
// shares the same underlying state while `generate(self ref)` advances that
// shared state through the interior mutable handle.
// ============================================================================

// FFI declaration for system entropy
foreign let __koral_random_fill(buf ptr UInt8, len Int32) Int32

// Internal mutable state behind a ref
type SimpleRandomState(mut s0 UInt64, mut s1 UInt64, mut s2 UInt64, mut s3 UInt64)

// DefaultRandomSource — xoshiro256** PRNG (value-semantic handle to shared state)
public type DefaultRandomSource(private state mut ref SimpleRandomState)

// Helper: rotate left for UInt64
let rotate_left(x UInt64, k UInt64) UInt64 = (x << k) | (x >> (64 - k))

// Helper: read a little-endian UInt64 from a byte buffer at offset
let read_u64_le(buf ptr UInt8, offset UInt) UInt64 = {
    let b0 = buf[offset](UInt64)
    let b1 = buf[offset + 1](UInt64)
    let b2 = buf[offset + 2](UInt64)
    let b3 = buf[offset + 3](UInt64)
    let b4 = buf[offset + 4](UInt64)
    let b5 = buf[offset + 5](UInt64)
    let b6 = buf[offset + 6](UInt64)
    let b7 = buf[offset + 7](UInt64)
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56)
}

given DefaultRandomSource {

    // Create from explicit seed values. Panics if all zeros.
    public from_seed(s0 UInt64, s1 UInt64, s2 UInt64, s3 UInt64) DefaultRandomSource = {
        if s0 == 0 and s1 == 0 and s2 == 0 and s3 == 0 then {
            panic("DefaultRandomSource: seed must not be all zeros")
        }
        return DefaultRandomSource(box(SimpleRandomState(s0, s1, s2, s3)))
    }

    // Create with system entropy. Panics if entropy source fails.
    public new() DefaultRandomSource = {
        let buf = alloc_memory[UInt8](32)
        let result = __koral_random_fill(buf, 32)
        if result <> 0 then {
            dealloc_memory(buf)
            panic("DefaultRandomSource: failed to obtain system entropy")
        }
        let s0 = read_u64_le(buf, 0)
        let s1 = read_u64_le(buf, 8)
        let s2 = read_u64_le(buf, 16)
        let s3 = read_u64_le(buf, 24)
        dealloc_memory(buf)
        if s0 == 0 and s1 == 0 and s2 == 0 and s3 == 0 then {
            panic("DefaultRandomSource: seed must not be all zeros")
        }
        return DefaultRandomSource(box(SimpleRandomState(s0, s1, s2, s3)))
    }
}

given DefaultRandomSource as RandomSource {

    // xoshiro256** generate: produces the next UInt64 and advances state.
    // Uses `self ref` — state mutation goes through the internal ref.
    public generate(self ref) UInt64 = {
        let s = self.state
        let result = rotate_left(s.s1.wrapping_mul(5), 7).wrapping_mul(9)

        let t = s.s1 << 17

        s.s2 = s.s2 ^ s.s0
        s.s3 = s.s3 ^ s.s1
        s.s1 = s.s1 ^ s.s2
        s.s0 = s.s0 ^ s.s3

        s.s2 = s.s2 ^ t
        s.s3 = rotate_left(s.s3, 45)

        return result
    }
}
