// ============================================================================
// std.rand - Randomizable Implementations
// ============================================================================
// Randomizable: implemented for all 11 basic types
// ============================================================================

// UInt64 — direct return from generate()
given UInt64 as Randomizable {

    public random[R RandomSource](source R) UInt64 = source.generate()
}

// UInt32 — take high 32 bits
given UInt32 as Randomizable {

    public random[R RandomSource](source R) UInt32 = (source.generate() >> 32)(UInt32)
}

// UInt16 — take high 16 bits
given UInt16 as Randomizable {

    public random[R RandomSource](source R) UInt16 = (source.generate() >> 48)(UInt16)
}

// UInt8 — take high 8 bits
given UInt8 as Randomizable {

    public random[R RandomSource](source R) UInt8 = (source.generate() >> 56)(UInt8)
}

// Int64 — bitwise reinterpret of UInt64
given Int64 as Randomizable {

    public random[R RandomSource](source R) Int64 = source.generate()(Int64)
}

// Int32 — bitwise reinterpret of UInt32
given Int32 as Randomizable {

    public random[R RandomSource](source R) Int32 = UInt32.random(source)(Int32)
}

// Int16 — bitwise reinterpret of UInt16
given Int16 as Randomizable {

    public random[R RandomSource](source R) Int16 = UInt16.random(source)(Int16)
}

// Int8 — bitwise reinterpret of UInt8
given Int8 as Randomizable {

    public random[R RandomSource](source R) Int8 = UInt8.random(source)(Int8)
}

// Float64 — high 53 bits / 2^53, produces [0.0, 1.0)
given Float64 as Randomizable {

    public random[R RandomSource](source R) Float64 = {
        let bits = source.generate() >> 11
        return bits(Float64) / 9007199254740992.0
    }
}

// Float32 — high 24 bits / 2^24, produces [0.0, 1.0)
given Float32 as Randomizable {

    public random[R RandomSource](source R) Float32 = {
        let bits = source.generate() >> 40
        return bits(Float32) / 16777216.0
    }
}

// Bool — highest bit
given Bool as Randomizable {

    public random[R RandomSource](source R) Bool = (source.generate() >> 63) == 1
}

// UInt — same as UInt64 on 64-bit platforms (pointer-sized)
given UInt as Randomizable {

    public random[R RandomSource](source R) UInt = source.generate()(UInt)
}

// Int — same as Int64 on 64-bit platforms (pointer-sized)
given Int as Randomizable {

    public random[R RandomSource](source R) Int = source.generate()(Int)
}
