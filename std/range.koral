// ============================================================================
// Range Iterator
// ============================================================================

// RangeIterator type for iterating over ranges
public type RangeIterator[T Step](protected mut current Option[T], protected end T, protected include_end Bool)

// RangeIterator next method
given[T Step] RangeIterator[T] as Iterator[T] {

    public next(self mut ref) Option[T] = when self.current in {
        .None then Option[T].None(),
        .Some(c) then {
            // Check if we've reached or passed the end
            let at_end = if self.include_end then c > self.end else c >= self.end

            if at_end then {
                self.current = Option[T].None()
                return Option[T].None()
            } else {
                self.current = c.succ()
                return Option[T].Some(c)
            }
        },
    }
}

// Range iterator method - only available when T is Step
given[T Step] Range[T] as Iterable[T, RangeIterator[T]] {

    public iterator(self ref) RangeIterator[T] = when self in {
        .Closed(start, end) then RangeIterator[T](Option[T].Some(start), end, true),
        .ClosedOpen(start, end) then RangeIterator[T](Option[T].Some(start), end, false),
        .OpenClosed(start, end) then RangeIterator[T](start.succ(), end, true),
        .Open(start, end) then RangeIterator[T](start.succ(), end, false),
        .From(start) then RangeIterator[T](Option[T].Some(start), T.max_value(), true),
        .After(start) then RangeIterator[T](start.succ(), T.max_value(), true),
        .To(end) then RangeIterator[T](Option[T].Some(T.min_value()), end, true),
        .Until(end) then RangeIterator[T](Option[T].Some(T.min_value()), end, false),
        .Full then RangeIterator[T](Option[T].Some(T.min_value()), T.max_value(), true),
    }
}
