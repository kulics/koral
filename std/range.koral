// Koral Standard Library - Range Type
// ============================================================================
// NOTE: This file is merged into core.koral, so all previous types are already available.
// ============================================================================

// ============================================================================
// Range Type Definition
// ============================================================================

// Range enum type representing different kinds of intervals
public type Range[T Ord] {
    // Bound ranges (4 kinds)
    Closed(start T, end T), // a..b   : start <= x <= end
    ClosedOpen(start T, end T), // a..<b  : start <= x < end
    OpenClosed(start T, end T), // a<..b  : start < x <= end
    Open(start T, end T), // a<..<b : start < x < end

    // From ranges (2 kinds)
    From(start T), // a..    : start <= x <= max
    After(start T), // a<..   : start < x <= max

    // To ranges (2 kinds)
    To(end T), // ..b    : min <= x <= end
    Until(end T), // ..<b   : min <= x < end

    // Full range (1 kind)
    Full(), // ..     : min <= x <= max
}

public type SliceSpec(private slice_offset UInt, private slice_len UInt)

given SliceSpec {

    public new(offset: UInt, len: UInt) SliceSpec = SliceSpec(offset, len)

    public start(self) UInt = self.slice_offset

    public end(self) UInt = self.slice_offset + self.slice_len

    public len(self) UInt = self.slice_len
}

// Range contains method - checks if a value is within the range
given[T Ord] Range[T] {

    public contains(self ref, value T) Bool = when self in {
        .Closed(start, end) then start <= value and value <= end,
        .ClosedOpen(start, end) then start <= value and value < end,
        .OpenClosed(start, end) then start < value and value <= end,
        .Open(start, end) then start < value and value < end,
        .From(start) then start <= value,
        .After(start) then start < value,
        .To(end) then value <= end,
        .Until(end) then value < end,
        .Full then true,
    }

    public is_empty(self ref) Bool = when self in {
        .Closed(start, end) then start > end,
        .ClosedOpen(start, end) then start >= end,
        .OpenClosed(start, end) then start >= end,
        .Open(start, end) then start >= end,
        .From(_) then false,
        .After(_) then false,
        .To(_) then false,
        .Until(_) then false,
        .Full then false,
    }
}

// ============================================================================
// Step Trait
// ============================================================================

// Step trait for types that can be stepped through sequentially
public trait Step Bounded {
    succ(self) Option[Self]
    pred(self) Option[Self]
}

// Step implementation for Int
given Int as Step {

    public succ(self) Option[Self] =
        if self == Int.max_value() then Option[Self].None() else Option[Self].Some(self + 1)

    public pred(self) Option[Self] =
        if self == Int.min_value() then Option[Self].None() else Option[Self].Some(self - 1)
}

// Step implementation for Int8
given Int8 as Step {

    public succ(self) Option[Self] =
        if self == Int8.max_value() then Option[Self].None() else Option[Self].Some(self + 1)

    public pred(self) Option[Self] =
        if self == Int8.min_value() then Option[Self].None() else Option[Self].Some(self - 1)
}

