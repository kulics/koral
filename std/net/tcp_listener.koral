// ============================================================================
// std.net - TcpListener Type
// ============================================================================
// Provides: TcpListener
// Access via: using Std.Net
// ============================================================================

// ============================================================================
// TcpListenerStorage Type (internal)
// ============================================================================

/// Internal storage holding the socket file descriptor.
/// Responsible for closing the fd via drop when the last reference is released.
private type TcpListenerStorage(fd Int64)

given TcpListenerStorage as Drop {

    /// Automatically close the socket when TcpListenerStorage is dropped.
    drop(self mut ref) Void = {
        if ref_is_borrow(self) then {
            return
        }
        if self.fd >= 0 then {
            __koral_socket_close(self.fd)
        }
    }
}

// ============================================================================
// TcpListener Type
// ============================================================================

/// TCP listener type.
/// Internally holds a TcpListenerStorage ref, shared via reference counting.
/// The socket is automatically closed when the last reference is released.
public type TcpListener(private storage ref TcpListenerStorage)

// ============================================================================
// TcpListener Methods
// ============================================================================
given TcpListener {

    /// Returns the underlying OS socket file descriptor.
    public fd(self ref) Int = self.storage.fd(Int)

    /// Bind to a socket address and start listening.
    /// Flow: create socket → set SO_REUSEADDR → bind → listen(128)
    /// On any failure, closes the fd and returns Error.
    public bind[T IntoSocketAddr](addr T) Result[TcpListener] = {
        let addr = when addr.into_socket_addr() in {
            .Ok(value) then value,
            .Error(_) then {
                return Result[TcpListener].Error(box("invalid socket address"))
            },
        }
        // Determine address family from SocketAddr
        let domain Int32 = if addr.is_ipv4() then __koral_const_AF_INET() else __koral_const_AF_INET6()
        let sock_type Int32 = __koral_const_SOCK_STREAM()
        let protocol Int32 = 0

        // Create socket
        let fd = __koral_socket_create(domain, sock_type, protocol)
        if fd < 0 then {
              return Result[TcpListener].Error(box(last_error_message()))
        }

        // Set SO_REUSEADDR: level=1 (SOL_SOCKET), optname=2 (SO_REUSEADDR)
        // Value is a 4-byte integer with value 1
        let opt_buf = alloc_memory[UInt8](4)
        init_memory(opt_buf + 0, 1(UInt8))
        init_memory(opt_buf + 1, 0(UInt8))
        init_memory(opt_buf + 2, 0(UInt8))
        init_memory(opt_buf + 3, 0(UInt8))
        let setsock_result = __koral_socket_setsockopt(fd, __koral_const_SOL_SOCKET(), __koral_const_SO_REUSEADDR(), opt_buf, 4(UInt32))
        dealloc_memory(opt_buf)
        if setsock_result <> 0 then {
            __koral_socket_close(fd)
              return Result[TcpListener].Error(box(last_error_message()))
        }

        // Bind to address
        let addr_bytes = addr.to_sockaddr_bytes()
        let addr_len = addr_bytes.count()(UInt32)
        let bind_result = __koral_socket_bind(fd, addr_bytes.borrow_ptr(), addr_len)
        if bind_result <> 0 then {
            __koral_socket_close(fd)
              return Result[TcpListener].Error(box(last_error_message()))
        }

        // Listen with backlog=128
        let listen_result = __koral_socket_listen(fd, 128(Int32))
        if listen_result <> 0 then {
            __koral_socket_close(fd)
              return Result[TcpListener].Error(box(last_error_message()))
        }

        let storage = box(TcpListenerStorage(fd))
        return Result[TcpListener].Ok(TcpListener(storage))
    }

    /// Accept a connection. Blocks until a client connects.
    /// Returns a Pair of (TcpSocket, SocketAddr) on success.
    public accept(self ref) Result[Pair[TcpSocket, SocketAddr]] = {
        // Allocate a 128-byte buffer for the peer address
        let addr_buf = alloc_memory[UInt8](128)
        let mut i UInt = 0
        while i < 128 then {
            init_memory(addr_buf + i, 0(UInt8))
            i += 1
        }
        let mut addr_len UInt32 = 128(UInt32)

        let new_fd = __koral_socket_accept(self.storage.fd, addr_buf, addr_len.ptr)
        if new_fd < 0 then {
            dealloc_memory(addr_buf)
                return Result[Pair[TcpSocket, SocketAddr]].Error(box(last_error_message()))
        }

        // Parse the sockaddr bytes into a SocketAddr
        let actual_len = addr_len(UInt)
        let mut addr_list = List[UInt8].with_capacity(actual_len)
        let mut j UInt = 0
        while j < actual_len then {
            addr_list.push(addr_buf[j])
            j += 1
        }
        dealloc_memory(addr_buf)

        let sa_result = SocketAddr.from_sockaddr_bytes(addr_list)
        when sa_result in {
            .Error(e) then {
                __koral_socket_close(new_fd)
                return Result[Pair[TcpSocket, SocketAddr]].Error(e)
            },
            .Ok(peer_addr) then {
                let sock = TcpSocket(box(TcpSocketStorage(new_fd)))
                return Result[Pair[TcpSocket, SocketAddr]].Ok(Pair[TcpSocket, SocketAddr](sock, peer_addr))
            },
        }
    }

    /// Get the local address this listener is bound to.
    public local_addr(self ref) Result[SocketAddr] = {
        let addr_buf = alloc_memory[UInt8](128)
        let mut i UInt = 0
        while i < 128 then {
            init_memory(addr_buf + i, 0(UInt8))
            i += 1
        }
        let mut addr_len UInt32 = 128(UInt32)

        let result = __koral_socket_getsockname(self.storage.fd, addr_buf, addr_len.ptr)
        if result <> 0 then {
            dealloc_memory(addr_buf)
              return Result[SocketAddr].Error(box(last_error_message()))
        }

        // Parse the sockaddr bytes into a SocketAddr
        let actual_len = addr_len(UInt)
        let mut addr_list = List[UInt8].with_capacity(actual_len)
        let mut j UInt = 0
        while j < actual_len then {
            addr_list.push(addr_buf[j])
            j += 1
        }
        dealloc_memory(addr_buf)

        return SocketAddr.from_sockaddr_bytes(addr_list)
    }
}
