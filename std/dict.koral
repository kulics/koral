// ============================================================================
// Koral Standard Library - Dict Type
// ============================================================================
// NOTE: This file is merged into core.koral, so all previous types are already available.
// ============================================================================

// ============================================================================
// Dict Storage and Type Definition
// ============================================================================
// DictBucket uses a struct+tag layout (not enum) so that key/value fields are
// directly addressable by pointer — enabling ref/ptr subscript helpers.
// Only Occupied buckets have initialized key/value. Empty and Deleted buckets
// have raw (uninitialized) key/value memory; only the tag is valid.
protected type DictBucket[K Hash, V Any](
    mut tag UInt,
    mut key K,
    mut value V,
)

// Bucket tag constants (inlined as 0(UInt), 1(UInt), 2(UInt))

protected type DictStorage[K Hash, V Any](
    mut buckets ptr mut DictBucket[K, V],
    mut count UInt,
    mut capacity UInt,
)

given[K Hash, V Any] DictStorage[K, V] as Drop {

    drop(source ptr mut Self) Void = {
        for i in 0..<source.capacity then {
            if (source.buckets + i).tag == 1(UInt) then {
                deinit_memory(source.buckets + i)
            }
        }
        dealloc_memory(source.buckets)
    }
}

public type Dict[K Hash, V Any](protected mut storage ref mut DictStorage[K, V])

public type DictIterator[K Hash, V Any](protected storage ref mut DictStorage[K, V], protected mut index UInt)

// ============================================================================
// Dict Methods
// ============================================================================
given[K Hash, V Any] Dict[K, V] {

    public new() Self = {
        let capacity UInt = 16
        let buckets = alloc_memory[DictBucket[K, V]](capacity)
        for i in 0..<capacity then {
            (buckets + i).tag = 0(UInt)
        }
        let storage = box(DictStorage[K, V](buckets, 0, capacity))
        return Dict[K, V](storage)
    }

    public with_capacity(capacity UInt) Self = {
        // Hash tables need extra space for efficiency (load factor ~0.5)
        let cap = if capacity < 4 then 4 else capacity * 2
        let buckets = alloc_memory[DictBucket[K, V]](cap)
        for i in 0..<cap then {
            (buckets + i).tag = 0(UInt)
        }
        let storage = box(DictStorage[K, V](buckets, 0, cap))
        return Dict[K, V](storage)
    }

    public count(self ref) UInt = self.storage.count

    public borrow_ptr(self ref) ptr DictBucket[K, V] = self.storage.buckets

    private ensure_unique(self ref mut) Void = {
        if not is_unique_mutable(self.storage.ptr) then {
            let old = self.storage
            let new_buckets = alloc_memory[DictBucket[K, V]](old.capacity)
            for i in 0..<old.capacity then {
                if (old.buckets + i).tag == 1(UInt) then {
                    let moved = take_memory(old.buckets + i)
                    init_memory(new_buckets + i, moved)
                } else {
                    (new_buckets + i).tag = (old.buckets + i).tag
                }
            }
            let new_storage = box(DictStorage[K, V](new_buckets, old.count, old.capacity))
            self.storage = new_storage
        }
    }

    // Using when for bucket handling
    private find_slot(self ref, key K) Option[UInt] = {
        let h = key.hash()
        let mut idx = h % self.storage.capacity
        let mut first_deleted = Option[UInt].None()
        let mut probes UInt = 0
        while probes < self.storage.capacity then {
            let bucket_tag = (self.storage.buckets + idx).tag
            if bucket_tag == 0(UInt) then {
                when first_deleted in {
                    .Some(_) then {
                        return first_deleted
                    },
                    .None then {
                        return Option[UInt].Some(idx)
                    },
                }
            } else if bucket_tag == 2(UInt) then {
                when first_deleted in {
                    .None then {
                        first_deleted = Option[UInt].Some(idx)
                    },
                    _ then {},
                }
            } else {
                // Occupied
                if (self.storage.buckets + idx).key == key then {
                    return Option[UInt].Some(idx)
                }
            }
            idx = (idx + 1) % self.storage.capacity
            probes += 1
        }
        return first_deleted
    }

    private rehash(self ref mut) Void = {
        let old_cap = self.storage.capacity
        let old_buckets = self.storage.buckets
        let new_cap = old_cap * 2
        let new_buckets = alloc_memory[DictBucket[K, V]](new_cap)
        for i in 0..<new_cap then {
            (new_buckets + i).tag = 0(UInt)
        }
        self.storage.buckets = new_buckets
        self.storage.capacity = new_cap
        self.storage.count = 0
        for i in 0..<old_cap then {
            let old_tag = (old_buckets + i).tag
            if old_tag == 1(UInt) then {
                let moved = take_memory(old_buckets + i)
                self.insert_internal(moved.key, moved.value)
            } else if old_tag == 2(UInt) then {
                // Drop the key/value that were stored in this deleted bucket
                deinit_memory(old_buckets + i)
            }
        }
        dealloc_memory(old_buckets)
    }

    // Internal insert used by rehash - doesn't return old value
    private insert_internal(self ref mut, key K, value V) Void = {
        when self.find_slot(key) in {
            .None then {
                panic("Dict insert failed");
            },
            .Some(idx) then {
                let bucket_ptr = self.storage.buckets + idx
                let was_occupied = bucket_ptr.tag == 1(UInt)
                if was_occupied then {
                    deinit_memory(bucket_ptr)
                }
                init_memory(bucket_ptr, DictBucket[K, V](1(UInt), key, value))
                if not was_occupied then {
                    self.storage.count = self.storage.count + 1
                }
            },
        }
    }

    public insert(self ref mut, key K, value V) Void = {
        self.ensure_unique()
        if self.storage.count * 2 >= self.storage.capacity then {
            self.rehash();
        }
        when self.find_slot(key) in {
            .None then {
                panic("Dict insert failed")
            },
            .Some(idx) then {
                let bucket_ptr = self.storage.buckets + idx
                let was_occupied = bucket_ptr.tag == 1(UInt)
                if was_occupied then {
                    deinit_memory(bucket_ptr)
                }
                init_memory(bucket_ptr, DictBucket[K, V](1(UInt), key, value))
                if not was_occupied then {
                    self.storage.count = self.storage.count + 1
                }
            },
        }
    }

    public try_insert(self ref mut, key K, value V) Bool = {
        self.ensure_unique()
        if self.storage.count * 2 >= self.storage.capacity then {
            self.rehash();
        }
        when self.find_slot(key) in {
            .None then {
                panic("Dict try_insert failed")
            },
            .Some(idx) then {
                let bucket_ptr = self.storage.buckets + idx
                if bucket_ptr.tag == 1(UInt) then {
                    return false
                } else {
                    init_memory(bucket_ptr, DictBucket[K, V](1(UInt), key, value))
                    self.storage.count = self.storage.count + 1
                    return true
                }
            },
        }
    }

    public insert_dict(self ref mut, other Dict[K, V]) Void = {
        for entry in other then {
            self.insert(entry.first, entry.second)
        }
    }

    public get(self ref, key K) Option[V] = {
        when self.find_slot(key) in {
            .None then {
                return Option[V].None()
            },
            .Some(idx) then {
                let bucket_ptr = self.storage.buckets + idx
                if bucket_ptr.tag == 1(UInt) then {
                    return Option[V].Some(bucket_ptr.value)
                } else {
                    return Option[V].None()
                }
            },
        }
    }

    public get_or_insert(self ref mut, key K, value V) V = {
        when self.get(key) in {
            .Some(v) then {
                return v
            },
            .None then {
                self.insert(key, value)
                return value
            },
        }
    }

    public contains_key(self ref, key K) Bool = when self.get(key) in {
        .Some(_) then true,
        .None then false,
    }

    public remove(self ref mut, key K) Void = {
        let _ = self.take(key)
    }

    public try_remove(self ref mut, key K) Bool = when self.take(key) in {
        .Some(_) then true,
        .None then false,
    }

    public take(self ref mut, key K) Option[V] = {
        self.ensure_unique()
        when self.find_slot(key) in {
            .None then {
                return Option[V].None()
            },
            .Some(idx) then {
                let bucket_ptr = self.storage.buckets + idx
                if bucket_ptr.tag == 1(UInt) then {
                    let v = bucket_ptr.value
                    deinit_memory(bucket_ptr)
                    bucket_ptr.tag = 2(UInt)
                    self.storage.count = self.storage.count - 1
                    return Option[V].Some(v)
                } else {
                    return Option[V].None()
                }
            },
        }
    }

    public is_empty(self ref) Bool = self.storage.count == 0

    public clear(self ref mut) Void = {
        self.ensure_unique()
        for i in 0..<self.storage.capacity then {
            let bucket_ptr = self.storage.buckets + i
            if bucket_ptr.tag == 1(UInt) then {
                deinit_memory(bucket_ptr)
            }
            bucket_ptr.tag = 0(UInt)
        }
        self.storage.count = 0
    }

    // Retains only entries satisfying the predicate. O(n).
    public retain(self ref mut, predicate Func[K, V, Bool]) Void = {
        self.ensure_unique()
        for i in 0..<self.storage.capacity then {
            let bucket_ptr = self.storage.buckets + i
            if bucket_ptr.tag == 1(UInt) then {
                if not predicate(bucket_ptr.key, bucket_ptr.value) then {
                    deinit_memory(bucket_ptr)
                    bucket_ptr.tag = 2(UInt)
                    self.storage.count = self.storage.count - 1
                }
            }
        }
    }

    // Builtin subscript helpers for d[key] syntax
    private __index_get(self ref, key K) V = {
        when self.get(key) in {
            .Some(v) then { return v },
            .None then { panic("Dict key not found") },
        }
    }

    private __index_set(self ref mut, key K, value V) Void = {
        when self.get(key) in {
            .None then { panic("Dict key not found") },
            .Some(_) then {},
        }
        self.ensure_unique()
        let final_idx = when self.find_slot(key) in {
            .None then { panic("Dict key not found") },
            .Some(i) then i,
        }
        let bucket_ptr = self.storage.buckets + final_idx
        deinit_memory(bucket_ptr)
        init_memory(bucket_ptr, DictBucket[K, V](1(UInt), key, value))
    }

    private __index_ptr(self ref, key K) ptr V = {
        let idx = when self.find_slot(key) in {
            .None then { panic("Dict key not found") },
            .Some(i) then i,
        }
        // self.storage.buckets is ptr mut DictBucket; +idx gives ptr to bucket[idx]
        let bucket_ptr = self.storage.buckets + idx
        // .val dereferences to the DictBucket, .value accesses the field, .ptr takes address
        return bucket_ptr.val.value.ptr
    }

    private __index_mut_ptr(self ref mut, key K) ptr mut V = {
        let idx = when self.find_slot(key) in {
            .None then { panic("Dict key not found") },
            .Some(i) then i,
        }
        self.ensure_unique()
        let final_idx = when self.find_slot(key) in {
            .None then { panic("Dict key not found") },
            .Some(i) then i,
        }
        let bucket_ptr = self.storage.buckets + final_idx
        return bucket_ptr.val.value.ptr
    }

    private __index_ref(self ref, key K) ref V = {
        let idx = when self.find_slot(key) in {
            .None then { panic("Dict key not found") },
            .Some(i) then i,
        }
        let bucket_ptr = self.storage.buckets + idx
        return make_ref[V, DictStorage[K, V]](bucket_ptr.val.value.ptr, self.storage)
    }

    private __index_mut_ref(self ref mut, key K) ref mut V = {
        let idx = when self.find_slot(key) in {
            .None then { panic("Dict key not found") },
            .Some(i) then i,
        }
        self.ensure_unique()
        let final_idx = when self.find_slot(key) in {
            .None then { panic("Dict key not found") },
            .Some(i) then i,
        }
        let bucket_ptr = self.storage.buckets + final_idx
        return make_mut_ref[V, DictStorage[K, V]](bucket_ptr.val.value.ptr, self.storage)
    }
}

// ============================================================================
// Dict Iterator
// ============================================================================
given[K Hash, V Any] DictIterator[K, V] as Iterator[Pair[K, V]] {

    public next(self ref mut) Option[Pair[K, V]] = {
        while self.index < self.storage.capacity then {
            let bucket_ptr = self.storage.buckets + self.index
            self.index = self.index + 1
            if bucket_ptr.tag == 1(UInt) then {
                return Option[Pair[K, V]].Some(Pair[K, V](bucket_ptr.key, bucket_ptr.value))
            }
        }
        return Option[Pair[K, V]].None()
    }
}

// ============================================================================
// Dict Keys and Values Types with Iterators
// ============================================================================

// DictKeysIterator - iterates over keys only
public type DictKeysIterator[K Hash, V Any](
    protected storage ref DictStorage[K, V],
    protected mut index UInt,
)

given[K Hash, V Any] DictKeysIterator[K, V] as Iterator[K] {

    public next(self ref mut) Option[K] = {
        while self.index < self.storage.capacity then {
            let bucket_ptr = self.storage.buckets + self.index
            self.index = self.index + 1
            if bucket_ptr.tag == 1(UInt) then {
                return Option[K].Some(bucket_ptr.key)
            }
        }
        return Option[K].None()
    }
}

// DictValuesIterator - iterates over values only
public type DictValuesIterator[K Hash, V Any](
    protected storage ref DictStorage[K, V],
    protected mut index UInt,
)

given[K Hash, V Any] DictValuesIterator[K, V] as Iterator[V] {

    public next(self ref mut) Option[V] = {
        while self.index < self.storage.capacity then {
            let bucket_ptr = self.storage.buckets + self.index
            self.index = self.index + 1
            if bucket_ptr.tag == 1(UInt) then {
                return Option[V].Some(bucket_ptr.value)
            }
        }
        return Option[V].None()
    }
}

// Add keys() and values() methods to Dict
given[K Hash, V Any] Dict[K, V] {

    public keys(self ref) DictKeysIterator[K, V] = DictKeysIterator[K, V](self.storage, 0)
    public values(self ref) DictValuesIterator[K, V] = DictValuesIterator[K, V](self.storage, 0)
}

given[K Hash, V Any] Dict[K, V] as Iterable[Pair[K, V], DictIterator[K, V]] {

    public iterator(self ref) DictIterator[K, V] = DictIterator[K, V](self.storage, 0)
}

given[T Deref] List[T] {

    public group_by[K Hash](self ref, key Func[T, K]) Dict[K, List[T]] = {
        let mut groups = Dict[K, List[T]].new()
        for i in 0..<self.count() then {
            let value = self[i]
            let k = key(value)

            when groups.get(k) in {
                .Some(existing) then {
                    let mut bucket = existing
                    bucket.push(value)
                    groups.insert(k, bucket)
                },
                .None then {
                    let mut bucket = List[T].new()
                    bucket.push(value)
                    groups.insert(k, bucket)
                },
            }
        }

        return groups
    }
}
