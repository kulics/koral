// ============================================================================
// std.os - Directory Operations
// ============================================================================
// Provides: DirEntry type, directory iteration and manipulation functions
// Access via: using Std.Os
// ============================================================================

// ============================================================================
// FFI Declarations
// ============================================================================

// Opaque types for directory operations
foreign type CDirHandle
foreign type CDirEntry

// Directory I/O
foreign let __koral_opendir(path UInt8 ptr) CDirHandle ptr
foreign let __koral_readdir(dir CDirHandle ptr) CDirEntry ptr
foreign let __koral_closedir(dir CDirHandle ptr) Int32
foreign let __koral_dirent_name(entry CDirEntry ptr) UInt8 ptr
foreign let __koral_dirent_type(entry CDirEntry ptr) Int32

// Directory manipulation
foreign let __koral_mkdir(path UInt8 ptr, mode UInt32) Int32
foreign let __koral_rmdir(path UInt8 ptr) Int32
foreign let __koral_mkdtemp(template UInt8 ptr) UInt8 ptr

// ============================================================================
// Helpers
// ============================================================================

/// Convert a dirent type code to FileType
private let dir_entry_type(entry CDirEntry ptr) FileType = {
    let t = __koral_dirent_type(entry)
    when t in {
        0 then {
            return FileType.RegularFile()
        },
        1 then {
            return FileType.Directory()
        },
        2 then {
            return FileType.Symlink()
        },
        _ then {
            return FileType.Other()
        },
    }
}


// ============================================================================
// DirEntry Type
// ============================================================================

/// Directory entry with type information
public type DirEntry(
    private _name String,
    private _path Path,
    private _file_type FileType,
)

given DirEntry {
    /// File/directory name
    public name(self) String = self._name

    /// Full path
    public path(self) Path = self._path

    /// File type
    public file_type(self) FileType = self._file_type

    public is_file(self) Bool = self._file_type.is_file()
    public is_dir(self) Bool = self._file_type.is_dir()
    public is_symlink(self) Bool = self._file_type.is_symlink()

    /// Get full file metadata (triggers stat system call)
    public info(self) [FileInfo]Result = file_info(self._path)

}

given DirEntry ToString {
    public to_string(self) String = {
        let mut s = String.new()
        s.push_string("DirEntry(")
        s.push_string(self._name)
        s.push_string(", ")
        s.push_string(self._file_type.to_string())
        s.push_string(")")
        return s
    }
}

private type DirIteratorStorage(handle CDirHandle ptr, base Path)

given DirIteratorStorage Drop {
    drop(self ref) Void = {
        if ref_is_borrow(self) then {
            return
        }
        if self.handle <> [CDirHandle]null_ptr() then {
            __koral_closedir(self.handle)
        }
    }
}

public type DirIterator(protected storage DirIteratorStorage ref)

private type WalkDirStorage(mut stack [DirIterator]List)

public type WalkDirIterator(protected mut storage WalkDirStorage ref)

given DirIterator [DirEntry]Iterator {
    public next(self ref) [DirEntry]Option = {
        let entry = __koral_readdir(self.storage.handle)
        if entry == [CDirEntry]null_ptr() then {
            return [DirEntry]Option.None()
        }

        let name = String.from_cstring_unchecked(__koral_dirent_name(entry))
        if name == "." or name == ".." then {
            return self.next()
        }

        let full_path = self.storage.base.join(name)
        let ft = dir_entry_type(entry)
        return [DirEntry]Option.Some(DirEntry(name, full_path, ft))
    }
}

given WalkDirIterator [DirEntry]Iterator {
    public next(self ref) [DirEntry]Option = {
        while true then {
            let top_opt = self.storage.stack.pop()
            if top_opt is .None then {
                return [DirEntry]Option.None()
            }

            let mut top = top_opt.unwrap()
            when top.next() in {
                .Some(entry) then {
                    self.storage.stack.push(top)
                    if entry.is_dir() then {
                        when read_dir(entry.path()) in {
                            .Ok(child) then {
                                self.storage.stack.push(child)
                            },
                            .Error(_) then {},
                        }
                    }
                    return [DirEntry]Option.Some(entry)
                },
                .None then {
                    // Current iterator is exhausted. Not pushing it back ensures
                    // storage drop runs and closes the OS directory handle.
                    continue
                },
            }
        }
        return [DirEntry]Option.None()
    }
}


// ============================================================================
// Directory Operations
// ============================================================================

/// Create single directory (parent must exist)
public let [T ToPath]create_dir(path T) [Void]Result = {
    let s = path.to_path().to_string()
    return if __koral_mkdir(s.storage.data, 493) == 0 then
        [Void]Result.Ok({})
    else
        [Void]Result.Error(box(last_error_message()))
}

/// Create directory recursively (creates all missing parent directories)
public let [T ToPath]create_dir_all(path T) [Void]Result = {
    let mut normalized = path.to_path().to_string().replace_all("\\", with: "/")
    if normalized.is_empty() then {
        return [Void]Result.Ok({})
    }

    // Keep root and drive-root forms intact while trimming trailing separators.
    while normalized.ends_with("/")
        and normalized.count() > 1
        and not (normalized.count() == 3 and normalized[1] == ':' and normalized[2] == '/') then {
        normalized = normalized.substring(0..<(normalized.count() - 1))
    }

    let target = normalized.to_path()
    if path_exist(target) then {
        return [Void]Result.Ok({})
    }

    let mut current = String.new()
    let mut i UInt = 0
    let n = normalized.count()

    if normalized.starts_with("//") then {
        current.push_string("//")
        i = 2
    } else if normalized.starts_with("/") then {
        current.push_byte('/')
        i = 1
    } else if n >= 2 and normalized[1] == ':' then {
        current.push_byte(normalized[0])
        current.push_byte(':')
        i = 2
        if n >= 3 and normalized[2] == '/' then {
            current.push_byte('/')
            i = 3
        }
    }

    while i < n then {
        while i < n and normalized[i] == '/' then {
            i += 1
        }
        if i >= n then {
            break
        }

        let start = i
        while i < n and normalized[i] <> '/' then {
            i += 1
        }

        let part = normalized.substring(start..<i)
        if current.is_empty() then {
            current.push_string(part)
        } else {
            if not current.ends_with("/") then {
                current.push_byte('/')
            }
            current.push_string(part)
        }

        // Skip mkdir on bare Windows drive prefixes like "C:".
        if current.count() == 2 and current[1] == ':' then {
            continue
        }

        let current_path = current.to_path()
        if not path_exist(current_path) then {
            if __koral_mkdir(current.storage.data, 493) <> 0 then {
                // Another process/thread may have created the directory concurrently.
                if not path_exist(current_path) then {
                    return [Void]Result.Error(box(last_error_message()))
                }
            }
        }
    }

    return [Void]Result.Ok({})
}

/// Remove empty directory
public let [T ToPath]remove_dir(path T) [Void]Result = {
    let s = path.to_path().to_string()
    return if __koral_rmdir(s.storage.data) == 0 then
        [Void]Result.Ok({})
    else
        [Void]Result.Error(box(last_error_message()))
}

/// Remove directory recursively (removes all contents first)
public let [T ToPath]remove_dir_all(path T) [Void]Result = {
    let p = path.to_path()
    let mut dirs = [Path]List.new()
    let mut entries = walk_dir(p) or else {
        return [Void]Result.Error(it)
    }

    while entries.next() is .Some(entry) then {
        let full_path = entry.path()
        if entry.is_dir() then {
            dirs.push(full_path)
        } else {
            if __koral_remove(full_path.to_string().storage.data) <> 0 then {
                return [Void]Result.Error(box(last_error_message()))
            }
        }
    }

    while dirs.pop() is .Some(dir_path) then {
        if __koral_rmdir(dir_path.to_string().storage.data) <> 0 then {
            return [Void]Result.Error(box(last_error_message()))
        }
    }

    return remove_dir(p)
}


/// Open a directory iterator.
/// Handle is released in iterator drop logic.
public let [T ToPath]read_dir(path T) [DirIterator]Result = {
    let p = path.to_path()
    let s = p.to_string()
    let dir = __koral_opendir(s.storage.data)
    if dir == [CDirHandle]null_ptr() then {
        return [DirIterator]Result.Error(box(last_error_message()))
    }

    return [DirIterator]Result.Ok(DirIterator(box(DirIteratorStorage(dir, p))))
}

/// Recursively walk a directory tree (depth-first).
/// Returned entries include both files and directories under `path`.
/// The root path itself is not yielded.
public let [T ToPath]walk_dir(path T) [WalkDirIterator]Result = {
    let mut stack = [DirIterator]List.new()
    let root_iter = read_dir(path) or else {
        return [WalkDirIterator]Result.Error(it)
    }
    stack.push(root_iter)
    return [WalkDirIterator]Result.Ok(WalkDirIterator(box(WalkDirStorage(stack))))
}


// ============================================================================
// create_temp_dir — Create a temporary directory
// ============================================================================

/// Create a temporary directory.
/// When dir is empty path, uses the system temp directory.
/// Returns the full path of the created temporary directory.
public let [T ToPath]create_temp_dir(dir T, prefix: String) [Path]Result = {
    let dir_path = dir.to_path()
    let base = if dir_path.is_empty() then temp_dir() else dir_path
    let base_str = base.to_string()
    let mut template = String.new()
    template.push_string(base_str)
    if not base_str.ends_with("/") and not base_str.ends_with("\\") then {
        template.push_byte('/')
    }
    template.push_string(prefix)
    template.push_string("XXXXXX")
    // __koral_mkdtemp modifies the template in-place, replacing XXXXXX with random chars
    let result = __koral_mkdtemp(template.storage.data)
    if result == [UInt8]null_ptr() then {
        return [Path]Result.Error(box(last_error_message()))
    }
    return [Path]Result.Ok(String.from_cstring_unchecked(result).to_path())
}
