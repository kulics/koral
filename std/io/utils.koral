// ============================================================================
// std.io - Utility Functions
// ============================================================================
// Reader extensions: read_all
// Writer extensions: write_all
// Reader extensions: read_all, copy_all_to
// ============================================================================

// ============================================================================
// Reader extensions
// ============================================================================

given Reader {
    // Read all bytes from self until EOF. Returns all bytes as a list.
    public read_all(self) [[UInt8]List]Result = {
        let mut out = [UInt8]List.new()
        let mut chunk = make_bytes(4096)
        while true then {
            when self.read(into: chunk.ref, ..) in {
                .Ok(n) then {
                    if n == 0 then {
                        return [[UInt8]List]Result.Ok(out)
                    }
                    out.push_sublist(chunk, 0..<n)
                },
                .Error(e) then {
                    return [[UInt8]List]Result.Error(e)
                },
            }
        }
        return [[UInt8]List]Result.Ok(out)
    }

    // Copy all bytes from self to dst. Returns total bytes copied.
    public [W Writer]copy_all_to(self, dst W) [UInt]Result = {
        let mut chunk = make_bytes(4096)
        let mut total UInt = 0
        while true then {
            when self.read(into: chunk.ref, ..) in {
                .Ok(n) then {
                    if n == 0 then {
                        return [UInt]Result.Ok(total)
                    }
                    when dst.write_all(from: chunk, 0..<n) in {
                        .Ok(_) then {
                            total += n
                        },
                        .Error(e) then {
                            return [UInt]Result.Error(e)
                        },
                    }
                },
                .Error(e) then {
                    return [UInt]Result.Error(e)
                },
            }
        }
        return [UInt]Result.Ok(total)
    }
}

// ============================================================================
// Writer extensions
// ============================================================================

given Writer {
    // Write all bytes in src[range] to self, looping on short writes.
    public write_all(self, from: [UInt8]List, range [UInt]Range) [Void]Result = {
        let span = from.slice_spec(range)
        let mut start = span.start()
        let end = span.end()
        if end <= start then {
            return [Void]Result.Ok({})
        }
        while start < end then {
            when self.write(from: from, start..<end) in {
                .Ok(n) then {
                    if n == 0 then {
                        return [Void]Result.Error(box(IoError.WriteZero()))
                    }
                    start += n
                },
                .Error(e) then {
                    return [Void]Result.Error(e)
                },
            }
        }
        return [Void]Result.Ok({})
    }
}
