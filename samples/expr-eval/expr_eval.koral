// 表达式求值器 - 入口文件

using std { .. }
using "types/types"
using "frontend/frontend"
using "backend/backend"

// REPL 类型
public type REPL(mut evaluator Evaluator)

given REPL {
    public new() Self = REPL(Evaluator.new())

    private report_error(self ref, prefix String, err ref Error) Void = {
        println("\(prefix): \(err.message())")
    }

    // 显示欢迎信息
    private show_welcome(self ref) Void =
        println("""
            Expression Evaluator v1.0
            Type 'help' for available commands, 'quit' to exit.
            
            """)

    // 显示帮助信息
    private show_help(self ref) Void =
        println("""
            Commands:
              help   - Show this help message
              vars   - List all defined variables
              clear  - Clear all variables
              quit   - Exit the program
              exit   - Exit the program

            Operators: + - * / % ^ (power)
            Functions: abs, sqrt, min, max, floor, ceil, round,
                      sin, cos, tan, ln, log2, log10, exp
            Variables: x = 10 (assignment), x (reference)
            """)

    private eval_input(self ref mut, line String) Bool = {
        if line.is_empty() then {
            return true
        }

        let mut lexer = Lexer.new(line)
        let tokens = lexer.tokenize() or else {
            self.report_error("Lexer error", it)
            return true
        }

        let mut parser = Parser.new(tokens)
        let expr = parser.parse() or else {
            self.report_error("Parse error", it)
            return true
        }

        let value = self.evaluator.eval(expr) or else {
            self.report_error("Error", it)
            return true
        }

        println(value.to_string())
        return true
    }

    // 处理单行输入
    private process_line(self ref mut, line String) Bool = when line in {
        "quit" then {
            println("Goodbye!")
            yield false
        },
        "exit" then {
            println("Goodbye!")
            yield false
        },
        "help" then {
            self.show_help()
            yield true
        },
        "vars" then {
            self.evaluator.list_vars()
            yield true
        },
        "clear" then {
            self.evaluator.clear_env()
            println("Variables cleared.")
            yield true
        },
        _ then self.eval_input(line),
    }

    // 运行 REPL 主循环
    public run(self ref mut) Void = {
        self.show_welcome()
        
        let mut running = true
        while running then {
            print("> ")
            when scanln() in {
                .Some(line) then {
                    running = self.process_line(line)
                },
                .None() then {
                    // EOF
                    println("")
                    println("Goodbye!")
                    running = false
                },
            }
        }
    }
}

public let main() Int = {
    let mut repl = REPL.new()
    repl.run()
    return 0
}
