// 表达式求值器 - Evaluator 核心功能
using std::math { .. }

public type Evaluator(mut env Environment)

given Evaluator {
    public new() Self = Evaluator(Environment.new())

    public eval(self ref mut, expr ref Expr) Result[Value] = when expr.val in {
        .Number(v) then Result.Ok(v),
        .Variable(name) then self.eval_variable(name),
        .BinaryOp(op, left, right) then self.eval_binary(op, left, right),
        .UnaryOp(op, operand) then self.eval_unary(op, operand),
        .FunctionCall(name, args) then self.eval_call(name, args),
        .Assignment(name, value) then self.eval_assignment(name, value),
    }

    private eval_variable(self ref, name String) Result[Value] = when self.env.get(name) in {
        .Some(v) then Result.Ok(v),
        .None then Result.Error(box("Undefined variable: \(name)")),
    }

    private eval_binary(self ref mut, op BinaryOperator, left ref Expr, right ref Expr) Result[Value] = {
        let lv = self.eval(left) or return
        let rv = self.eval(right) or return
        return self.apply_binary_op(op, lv, rv)
    }

    private apply_binary_op(self ref, op BinaryOperator, left Value, right Value) Result[Value] = {
        return when op in {
            .Add then self.value_add(left, right),
            .Sub then self.value_sub(left, right),
            .Mul then self.value_mul(left, right),
            .Div then self.value_div(left, right),
            .Mod then self.value_mod(left, right),
            .Pow then self.value_pow(left, right),
        }
    }

    // 加法
    private value_add(self ref, left Value, right Value) Result[Value] =
        Result.Ok(left.numeric_binary(right, (a, b) -> Value.IntVal(a + b), (a, b) -> Value.FloatVal(a + b)))

    // 减法
    private value_sub(self ref, left Value, right Value) Result[Value] =
        Result.Ok(left.numeric_binary(right, (a, b) -> Value.IntVal(a - b), (a, b) -> Value.FloatVal(a - b)))

    // 乘法
    private value_mul(self ref, left Value, right Value) Result[Value] =
        Result.Ok(left.numeric_binary(right, (a, b) -> Value.IntVal(a * b), (a, b) -> Value.FloatVal(a * b)))

    // 除法
    private value_div(self ref, left Value, right Value) Result[Value] = {
        if right.to_float() == 0.0 then {
            return .Error(box("Division by zero"))
        }
        if left.int_pair(right) is .Some(pair) then {
            if pair.first % pair.second == 0 then {
                return .Ok(Value.IntVal(pair.first / pair.second))
            }
            return .Ok(Value.FloatVal(pair.first(Float64) / pair.second(Float64)))
        }
        return .Ok(Value.FloatVal(left.to_float() / right.to_float()))
    }

    // 取模
    private value_mod(self ref, left Value, right Value) Result[Value] = {
        if right.to_float() == 0.0 then {
            return .Error(box("Modulo by zero"))
        }
        if left.int_pair(right) is .Some(pair) then {
            return .Ok(Value.IntVal(pair.first % pair.second))
        }
        return .Ok(Value.FloatVal(left.to_float().fmod(right.to_float())))
    }

    // 幂运算
    private value_pow(self ref, left Value, right Value) Result[Value] = {
        let base = left.to_float()
        let exponent = right.to_float()
        let result = base.pow(exponent)
        if left.int_pair(right) is .Some(pair) and pair.second >= 0 then {
            let int_result = result(Int)
            if int_result(Float64) == result then {
                return .Ok(Value.IntVal(int_result))
            }
        }
        return .Ok(Value.FloatVal(result))
    }

    // 一元运算
    private eval_unary(self ref mut, op UnaryOperator, operand ref Expr) Result[Value] = {
        let v = self.eval(operand) or return
        return when op in {
            .Neg then Result.Ok(v.unary_numeric((x) -> Value.IntVal(0 - x), (x) -> Value.FloatVal(0.0 - x))),
        }
    }

    // 函数调用
    private eval_call(self ref mut, name String, args List[ref Expr]) Result[Value] = {
        let mut evaluated_args = List[Value].new()
        for arg in args then {
            let v = self.eval(arg) or return
            evaluated_args.push(v)
        }
        return call_builtin(name, evaluated_args)
    }

    // 赋值
    private eval_assignment(self ref mut, name String, value ref Expr) Result[Value] = {
        let v = self.eval(value) or return
        self.env.set(name, v)
        return .Ok(v)
    }

    public get_env(self ref) ref Environment = self.env.ref
    public clear_env(self ref mut) Void = self.env.clear()
    public list_vars(self ref) Void = self.env.list_vars()
}
