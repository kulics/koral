// 表达式求值器 - Environment 组件
// 用于存储变量名到值的映射
// Note: Value type is imported via the main module


public type Environment(mut vars Dict[String, Value])

given Environment {
    public new() Self = Environment(Dict[String, Value].new())

    public get(self ref, name String) Option[Value] = self.vars.get(name)

    public set(self mut ref, name String, value Value) Void = {
        self.vars.insert(name, value)
    }

    public clear(self mut ref) Void = self.vars.clear()

    public list_vars(self ref) Void = {
        if self.vars.is_empty() then {
            println("No variables defined.")
        } else {
            println("Variables:")
            for entry in self.vars then {
                println("  \(entry.first) = \(entry.second.to_string())")
            }
        }
    }
}
