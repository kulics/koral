// 表达式求值器 - Environment 组件
// 用于存储变量名到值的映射
// Note: Value type is imported via the main module


public type Environment(mut vars [String, Types.Value]Dict)

given Environment {
    public new() Self = Environment([String, Types.Value]Dict.new())

    public get(self, name String) [Types.Value]Option = self.vars.get(name)

    public set(self mut ref, name String, value Types.Value) Void = {
        self.vars.insert(name, value);
    }

    public clear(self mut ref) Void = self.vars.clear()

    public list_vars(self) Void = {
        if self.vars.is_empty() then {
            println("No variables defined.")
        } else {
            println("Variables:")
            for entry in self.vars then {
                let mut s = String.zero()
                s.push_string("  ")
                s.push_string(entry.first)
                s.push_string(" = ")
                s.push_string(entry.second.to_string())
                println(s)
            }
        }
    }
}
