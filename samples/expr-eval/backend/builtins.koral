// 表达式求值器 - 内置函数
using std::math { .. }

private let expect_arity(name String, args List[Value], expected UInt) Result[Void] = {
    if args.count() == expected then {
        return .Ok({})
    }
    let suffix = if expected == 1 then "" else "s"
    return .Error(box("\(name)() takes exactly \(expected) argument\(suffix)"))
}

private let with_one_arg(name String, args List[Value], action Func[Value, Result[Value]]) Result[Value] = {
    expect_arity(name, args, 1) or return
    return action(args[0])
}

private let with_two_args(name String, args List[Value], action Func[Value, Value, Result[Value]]) Result[Value] = {
    expect_arity(name, args, 2) or return
    return action(args[0], args[1])
}

// 内置函数：abs - 绝对值
public let builtin_abs(args List[Value]) Result[Value] =
    with_one_arg("abs", args, (value) -> .Ok(value.unary_numeric((x) -> .IntVal(x.abs()), (x) -> .FloatVal(x.abs()))))

// 内置函数：sqrt - 平方根
public let builtin_sqrt(args List[Value]) Result[Value] =
    with_one_arg("sqrt", args, (value) -> {
        let x = value.to_float()
        if x < 0.0 then {
            return .Error(box("sqrt() argument must be non-negative"))
        }
        return .Ok(.FloatVal(sqrt(x)))
    })

// 内置函数：min - 最小值
public let builtin_min(args List[Value]) Result[Value] =
    with_two_args("min", args, (a, b) -> .Ok(a.numeric_binary(b, (x, y) -> .IntVal(min(x, y)), (x, y) -> .FloatVal(min(x, y)))))

// 内置函数：max - 最大值
public let builtin_max(args List[Value]) Result[Value] =
    with_two_args("max", args, (a, b) -> .Ok(a.numeric_binary(b, (x, y) -> .IntVal(max(x, y)), (x, y) -> .FloatVal(max(x, y)))))

// 内置函数：floor - 向下取整
public let builtin_floor(args List[Value]) Result[Value] =
    with_one_arg("floor", args, (value) -> .Ok(.IntVal(value.to_float().floor()(Int))))

// 内置函数：ceil - 向上取整
public let builtin_ceil(args List[Value]) Result[Value] =
    with_one_arg("ceil", args, (value) -> .Ok(.IntVal(value.to_float().ceil()(Int))))

// 内置函数：round - 四舍五入
public let builtin_round(args List[Value]) Result[Value] =
    with_one_arg("round", args, (value) -> .Ok(.IntVal(value.to_float().round()(Int))))

// 内置函数：sin
public let builtin_sin(args List[Value]) Result[Value] =
    with_one_arg("sin", args, (value) -> .Ok(.FloatVal(sin(value.to_float()))))

// 内置函数：cos
public let builtin_cos(args List[Value]) Result[Value] =
    with_one_arg("cos", args, (value) -> .Ok(.FloatVal(cos(value.to_float()))))

// 内置函数：tan
public let builtin_tan(args List[Value]) Result[Value] =
    with_one_arg("tan", args, (value) -> .Ok(.FloatVal(tan(value.to_float()))))

// 内置函数：ln
public let builtin_ln(args List[Value]) Result[Value] =
    with_one_arg("ln", args, (value) -> {
        let x = value.to_float()
        if x <= 0.0 then {
            return .Error(box("ln() argument must be positive"))
        }
        return .Ok(.FloatVal(ln(x)))
    })

// 内置函数：log2
public let builtin_log2(args List[Value]) Result[Value] =
    with_one_arg("log2", args, (value) -> {
        let x = value.to_float()
        if x <= 0.0 then {
            return .Error(box("log2() argument must be positive"))
        }
        return .Ok(.FloatVal(log2(x)))
    })

// 内置函数：log10
public let builtin_log10(args List[Value]) Result[Value] =
    with_one_arg("log10", args, (value) -> {
        let x = value.to_float()
        if x <= 0.0 then {
            return .Error(box("log10() argument must be positive"))
        }
        return .Ok(.FloatVal(log10(x)))
    })

// 内置函数：exp
public let builtin_exp(args List[Value]) Result[Value] =
    with_one_arg("exp", args, (value) -> .Ok(.FloatVal(exp(value.to_float()))))

// 调用内置函数的分发器
public let call_builtin(name String, args List[Value]) Result[Value] = when name in {
    "abs" then builtin_abs(args),
    "sqrt" then builtin_sqrt(args),
    "min" then builtin_min(args),
    "max" then builtin_max(args),
    "floor" then builtin_floor(args),
    "ceil" then builtin_ceil(args),
    "round" then builtin_round(args),
    "sin" then builtin_sin(args),
    "cos" then builtin_cos(args),
    "tan" then builtin_tan(args),
    "ln" then builtin_ln(args),
    "log2" then builtin_log2(args),
    "log10" then builtin_log10(args),
    "exp" then builtin_exp(args),
    _ then .Error(box("Unknown function: \(name)")),
}
