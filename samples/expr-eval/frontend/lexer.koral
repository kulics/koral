// 表达式求值器 - 词法分析器

public type Lexer(
    source String,
    mut pos UInt,
)

given Lexer {
    public new(source String) Lexer = Lexer(source, 0)

    private is_at_end(self ref) Bool = self.pos >= self.source.count()

    private peek_next(self ref) Option[UInt8] = {
        if self.pos + 1 >= self.source.count() then {
            return Option[UInt8].None()
        }
        return Option[UInt8].Some(self.source[self.pos + 1])
    }

    private advance(self ref mut) UInt8 = {
        let c = self.source[self.pos]
        self.pos += 1
        return c
    }

    private skip_whitespace(self ref mut) Void = {
        while not self.is_at_end() then {
            let c = self.source[self.pos]
            if c == ' ' or c == '\t' or c == '\n' or c == '\r' then { self.pos += 1 }
            else { break }
        }
    }

    private is_digit(c UInt8) Bool = c >= '0' and c <= '9'
    private is_alpha(c UInt8) Bool = (c >= 'a' and c <= 'z') or (c >= 'A' and c <= 'Z') or c == '_'
    private is_alphanumeric(c UInt8) Bool = Lexer.is_digit(c) or Lexer.is_alpha(c)

    private scan_number(self ref mut) Token = {
        let start = self.pos
        let mut has_dot = false

        while not self.is_at_end() and Lexer.is_digit(self.source[self.pos]) then {
            self.pos += 1
        }

        if (not self.is_at_end()) and self.source[self.pos] == '.' then {
            when self.peek_next() in {
                .Some(next) then {
                    if Lexer.is_digit(next) then {
                        has_dot = true
                        self.pos += 1
                        while not self.is_at_end() and Lexer.is_digit(self.source[self.pos]) then {
                            self.pos += 1
                        }
                    }
                },
                .None then {},
            }
        }

        let num_str = self.source.substring(start..<self.pos)
        if has_dot then {
            return Token.FloatLiteral(parse_float64_str(num_str))
        }
        return Token.IntLiteral(parse_int_str(num_str))
    }

    private scan_identifier(self ref mut) Token = {
        let start = self.pos
        while not self.is_at_end() and Lexer.is_alphanumeric(self.source[self.pos]) then {
            self.pos += 1
        }
        return Token.Identifier(self.source.substring(start..<self.pos))
    }

    public next_token(self ref mut) Result[Token] = {
        self.skip_whitespace()

        if self.is_at_end() then {
            return Result.Ok(Token.EOF())
        }

        let c = self.advance()

        if Lexer.is_digit(c) then {
            self.pos -= 1
            return Result.Ok(self.scan_number())
        }

        if Lexer.is_alpha(c) then {
            self.pos -= 1
            return Result.Ok(self.scan_identifier())
        }

        return when c in {
            '+' then .Ok(Token.Plus()),
            '-' then .Ok(Token.Minus()),
            '*' then .Ok(Token.Star()),
            '^' then .Ok(Token.Power()),
            '/' then .Ok(Token.Slash()),
            '%' then .Ok(Token.Percent()),
            '=' then .Ok(Token.Equals()),
            '(' then .Ok(Token.LeftParen()),
            ')' then .Ok(Token.RightParen()),
            ',' then .Ok(Token.Comma()),
            _ then .Error(box("Lexer error at position \(self.pos(Int) - 1): unexpected character '\(c)'")),
        }
    }

    public tokenize(self ref mut) Result[List[Token]] = {
        let mut tokens = List[Token].new()
        let mut done = false
        while not done then {
            let token = self.next_token() or return
            when token in {
                .EOF then {
                    tokens.push(token)
                    done = true
                },
                _ then tokens.push(token),
            }
        }
        return Result.Ok(tokens)
    }
}

let parse_int_str(s String) Int = {
    let mut result = 0
    for i in 0..<s.count() then {
        result = result * 10 + (s[i] - '0')(Int)
    }
    return result
}

let parse_float64_str(s String) Float64 = {
    let mut result = 0.0
    let mut after_dot = false
    let mut decimal_place = 0.1

    for i in 0..<s.count() then {
        let c = s[i]
        if c == '.' then {
            after_dot = true
        } else {
            let digit = (c - '0')(Int)(Float64)
            if after_dot then {
                result = result + digit * decimal_place
                decimal_place = decimal_place * 0.1
            } else {
                result = result * 10.0 + digit
            }
        }
    }
    return result
}
