// 表达式求值器 - 语法分析器

// 导入 types 模块
using Super.Types

public type Parser(
    tokens [Types.Token]List,
    mut pos UInt,
)

given Parser {
    public new(tokens [Types.Token]List) Parser = Parser(tokens, 0)

    private peek(self) Types.Token = {
        if self.pos >= self.tokens.count() then {
            return Types.Token.EOF()
        }
        return self.tokens[self.pos]
    }

    private peek_next(self) Types.Token = {
        if self.pos + 1 >= self.tokens.count() then {
            return Types.Token.EOF()
        }
        return self.tokens[self.pos + 1]
    }

    private advance(self mut ref) Types.Token = {
        let token = self.peek()
        self.pos += 1
        return token
    }

    private check_plus(self) Bool = when self.peek() in { .Plus then true, _ then false }
    private check_minus(self) Bool = when self.peek() in { .Minus then true, _ then false }
    private check_star(self) Bool = when self.peek() in { .Star then true, _ then false }
    private check_slash(self) Bool = when self.peek() in { .Slash then true, _ then false }
    private check_percent(self) Bool = when self.peek() in { .Percent then true, _ then false }
    private check_power(self) Bool = when self.peek() in { .Power then true, _ then false }
    private check_left_paren(self) Bool = when self.peek() in { .LeftParen then true, _ then false }
    private check_right_paren(self) Bool = when self.peek() in { .RightParen then true, _ then false }
    private check_comma(self) Bool = when self.peek() in { .Comma then true, _ then false }
    private check_eof(self) Bool = when self.peek() in { .EOF then true, _ then false }

    private expect_right_paren(self mut ref) [Void]Result = {
        if self.check_right_paren() then {
            self.advance()
            return Result.Ok({})
        }

        let mut msg = String.zero()
        msg.push_string("Parse error: expected ')', found ")
        msg.push_string(self.peek().to_string())
        return Result.Error(box(msg))
    }

    public parse(self mut ref) [Expr mut ref]Result = {
        let expr = self.parse_expression() or return
        if not self.check_eof() then {
            let mut msg = String.zero()
            msg.push_string("Parse error: unexpected token ")
            msg.push_string(self.peek().to_string())
            return Result.Error(box(msg))
        }
        return Result.Ok(expr)
    }

    private parse_expression(self mut ref) [Expr mut ref]Result = self.parse_assignment()

    private parse_assignment(self mut ref) [Expr mut ref]Result = {
        when self.peek() in {
            .Identifier(name) then {
                if self.peek_next() is .Equals then {
                    self.advance()
                    self.advance()
                    let value = self.parse_assignment() or return
                    return Result.Ok(box(Expr.Assignment(name, value)))
                }
            },
            _ then {},
        }
        return self.parse_additive()
    }

    private parse_additive(self mut ref) [Expr mut ref]Result = {
        let mut left = self.parse_multiplicative() or return
        while self.check_plus() or self.check_minus() then {
            let op = if self.check_plus() then BinaryOperator.Add() else BinaryOperator.Sub()
            self.advance()
            let right = self.parse_multiplicative() or return
            left = box(Expr.BinaryOp(op, left, right))
        }
        return Result.Ok(left)
    }

    private parse_multiplicative(self mut ref) [Expr mut ref]Result = {
        let mut left = self.parse_power() or return
        while self.check_star() or self.check_slash() or self.check_percent() then {
            let op = if self.check_star() then BinaryOperator.Mul()
                     else if self.check_slash() then BinaryOperator.Div()
                     else BinaryOperator.Mod()
            self.advance()
            let right = self.parse_power() or return
            left = box(Expr.BinaryOp(op, left, right))
        }
        return Result.Ok(left)
    }
    

    private parse_power(self mut ref) [Expr mut ref]Result = {
        let left = self.parse_unary() or return
        if self.check_power() then {
            self.advance()
            let right = self.parse_power() or return
            return Result.Ok(box(Expr.BinaryOp(BinaryOperator.Pow(), left, right)))
        }
        return Result.Ok(left)
    }

    private parse_unary(self mut ref) [Expr mut ref]Result = {
        if self.check_minus() then {
            self.advance()
            let operand = self.parse_unary() or return
            return Result.Ok(box(Expr.UnaryOp(UnaryOperator.Neg(), operand)))
        }
        return self.parse_call()
    }

    private parse_call(self mut ref) [Expr mut ref]Result = {
        let primary = self.parse_primary() or return
        when primary.val in {
            .Variable(name) then {
                if self.check_left_paren() then {
                    self.advance()
                    let args = self.parse_arguments() or return
                    let _ = self.expect_right_paren() or return
                    return Result.Ok(box(Expr.FunctionCall(name, args)))
                }

                return Result.Ok(primary)
            },
            _ then {
                return Result.Ok(primary)
            },
        }
    }

    private parse_arguments(self mut ref) [[Expr mut ref]List]Result = {
        let mut args = [Expr mut ref]List.new()
        
        if self.check_right_paren() then {
            return Result.Ok(args)
        }

        let first = self.parse_expression() or return
        args.push(first)
        while self.check_comma() then {
            self.advance()
            let arg = self.parse_expression() or return
            args.push(arg)
        }
        return Result.Ok(args)
    }

    private parse_primary(self mut ref) [Expr mut ref]Result = {
        when self.peek() in {
            .IntLiteral(v) then {
                self.advance()
                return Result.Ok(box(Expr.Number(Types.Value.IntVal(v))))
            },
            .FloatLiteral(v) then {
                self.advance()
                return Result.Ok(box(Expr.Number(Types.Value.FloatVal(v))))
            },
            .Identifier(name) then {
                self.advance()
                return Result.Ok(box(Expr.Variable(name)))
            },
            .LeftParen then {
                self.advance()
                let expr = self.parse_expression() or return
                let _ = self.expect_right_paren() or return
                return Result.Ok(expr)
            },
            _ then {
                let mut msg = String.zero()
                msg.push_string("Parse error: unexpected token ")
                msg.push_string(self.peek().to_string())
                return Result.Error(box(msg))
            },
        }
    }
}
