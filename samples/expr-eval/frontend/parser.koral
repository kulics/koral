// 表达式求值器 - 语法分析器

public type Parser(
    tokens List[Token],
    mut pos UInt,
)

given Parser {
    public new(tokens List[Token]) Parser = Parser(tokens, 0)

    private peek(self ref) Token = {
        if self.pos >= self.tokens.count() then {
            return Token.EOF()
        }
        return self.tokens[self.pos]
    }

    private peek_next(self ref) Token = {
        if self.pos + 1 >= self.tokens.count() then {
            return Token.EOF()
        }
        return self.tokens[self.pos + 1]
    }

    private advance(self ref mut) Token = {
        let token = self.peek()
        self.pos += 1
        return token
    }

    private check_plus(self ref) Bool = self.peek() is .Plus
    private check_minus(self ref) Bool = self.peek() is .Minus
    private check_star(self ref) Bool = self.peek() is .Star
    private check_slash(self ref) Bool = self.peek() is .Slash
    private check_percent(self ref) Bool = self.peek() is .Percent
    private check_power(self ref) Bool = self.peek() is .Power
    private check_left_paren(self ref) Bool = self.peek() is .LeftParen
    private check_right_paren(self ref) Bool = self.peek() is .RightParen
    private check_comma(self ref) Bool = self.peek() is .Comma
    private check_eof(self ref) Bool = self.peek() is .EOF

    private expect_right_paren(self ref mut) Result[Void] =
        if self.check_right_paren() then {
            self.advance()
            yield .Ok({})
        } else .Error(box("Parse error: expected ')', found \(self.peek().to_string())"))

    public parse(self ref mut) Result[ref Expr] = {
        let expr = self.parse_expression() or return
        return if self.check_eof() then .Ok(expr)
               else .Error(box("Parse error: unexpected token \(self.peek().to_string())"))
    }

    private parse_expression(self ref mut) Result[ref Expr] = self.parse_assignment()

    private parse_assignment(self ref mut) Result[ref Expr] = {
        if self.peek() is .Identifier(name) and self.peek_next() is .Equals then {
            self.advance()
            self.advance()
            let value = self.parse_assignment() or return
            return .Ok(box(Expr.Assignment(name, value)))
        }
        return self.parse_additive()
    }

    private parse_additive(self ref mut) Result[ref Expr] = {
        let mut left = self.parse_multiplicative() or return
        while self.check_plus() or self.check_minus() then {
            let op = if self.check_plus() then BinaryOperator.Add() else BinaryOperator.Sub()
            self.advance()
            let right = self.parse_multiplicative() or return
            left = box(Expr.BinaryOp(op, left, right))
        }
        return .Ok(left)
    }

    private parse_multiplicative(self ref mut) Result[ref Expr] = {
        let mut left = self.parse_power() or return
        while self.check_star() or self.check_slash() or self.check_percent() then {
            let op = if self.check_star() then BinaryOperator.Mul()
                     else if self.check_slash() then BinaryOperator.Div()
                     else BinaryOperator.Mod()
            self.advance()
            let right = self.parse_power() or return
            left = box(Expr.BinaryOp(op, left, right))
        }
        return .Ok(left)
    }
    

    private parse_power(self ref mut) Result[ref Expr] = {
        let left = self.parse_unary() or return
        if self.check_power() then {
            self.advance()
            let right = self.parse_power() or return
            return .Ok(box(Expr.BinaryOp(BinaryOperator.Pow(), left, right)))
        }
        return .Ok(left)
    }

    private parse_unary(self ref mut) Result[ref Expr] = {
        if self.check_minus() then {
            self.advance()
            let operand = self.parse_unary() or return
            return .Ok(box(Expr.UnaryOp(UnaryOperator.Neg(), operand)))
        }
        return self.parse_call()
    }

    private parse_call(self ref mut) Result[ref Expr] = {
        let primary = self.parse_primary() or return
        if primary.val is .Variable(name) and self.check_left_paren() then {
            self.advance()
            let args = self.parse_arguments() or return
            let _ = self.expect_right_paren() or return
            return .Ok(box(Expr.FunctionCall(name, args)))
        }
        return .Ok(primary)
    }

    private parse_arguments(self ref mut) Result[List[ref Expr]] = {
        let mut args = List[ref Expr].new()
        
        if self.check_right_paren() then {
            return .Ok(args)
        }

        let first = self.parse_expression() or return
        args.push(first)
        while self.check_comma() then {
            self.advance()
            let arg = self.parse_expression() or return
            args.push(arg)
        }
        return .Ok(args)
    }

    private parse_primary(self ref mut) Result[ref Expr] =
        when self.peek() in {
            .IntLiteral(v) then {
                self.advance()
                yield .Ok(box(Expr.Number(Value.IntVal(v))))
            },
            .FloatLiteral(v) then {
                self.advance()
                yield .Ok(box(Expr.Number(Value.FloatVal(v))))
            },
            .Identifier(name) then {
                self.advance()
                yield .Ok(box(Expr.Variable(name)))
            },
            .LeftParen then {
                self.advance()
                let expr = self.parse_expression() or return
                let _ = self.expect_right_paren() or return
                yield .Ok(expr)
            },
            _ then .Error(box("Parse error: unexpected token \(self.peek().to_string())")),
        }
}
