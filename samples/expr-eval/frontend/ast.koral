// 表达式求值器 - AST 类型定义

public type BinaryOperator {
    Add(),
    Sub(),
    Mul(),
    Div(),
    Mod(),
    Pow(),
}

given BinaryOperator {
    public to_string(self ref) String = when self in {
        .Add then "+",
        .Sub then "-",
        .Mul then "*",
        .Div then "/",
        .Mod then "%",
        .Pow then "**",
    }
}

public type UnaryOperator {
    Neg(),
}

given UnaryOperator {
    public to_string(self ref) String = when self in {
        .Neg then "-",
    }
}

public type Expr {
    Number(value Value),
    Variable(name String),
    BinaryOp(op BinaryOperator, left ref Expr, right ref Expr),
    UnaryOp(op UnaryOperator, operand ref Expr),
    FunctionCall(name String, args List[ref Expr]),
    Assignment(name String, value ref Expr),
}

given Expr {
    public to_string(self ref) String = 
        when self in {
            .Number(v) then v.to_string(),
            .Variable(name) then name,
            .BinaryOp(op, left, right) then "(\(left.to_string()) \(op.to_string()) \(right.to_string()))",
            .UnaryOp(op, operand) then "(\(op.to_string())\(operand.to_string()))",
            .FunctionCall(name, args) then {
                let mut rendered = List[String].new()
                for arg in args then {
                    rendered.push(arg.to_string())
                }
                yield name + "(" + rendered.join_to_string(", ") + ")"
            },
            .Assignment(name, value) then "\(name) = \(value.to_string())",
        }
}
