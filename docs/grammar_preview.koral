// 无参无返回值
let do_nothing() Void = {}

// 有参有返回值
let add(x Int, y Int) Int = x + y

// 显式返回类型
let mul(x Int, y Int) Int = x * y

// 可变参数
let inc(mut x Int) Int = {
    x += 1
    return x
}

// 泛型函数（单约束）
let contains[T Eq](list List[T], item T) Bool = todo()

// 泛型函数（多约束）
let max[T Eq and Ord](a T, b T) T =
    if a.compare(b) >= 0 then a else b

// 函数类型
let fn_types() Void = {
    let f Func[Int, Int, Int] = (x Int, y Int) Int -> x + y
    let g Func[Int, Int]      = (x) -> x * 2
    let h Func[Void]          = () -> {}

    // 柯里化
    let add = (x Int) -> (y Int) -> x + y
    let v = add(1)(2)

    // 作为参数传递
    let apply = (f Func[Int, Int], x Int) Int -> f(x)
    apply((x) -> x + 1, 5)
    apply((x Int) Int -> x * 2, 5)

    // 链式调用（lambda 作为参数）
    some_list.filter((x) -> x % 2 == 0).map((x) -> x * x)
}

