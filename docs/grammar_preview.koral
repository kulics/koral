// 函数类型
let fn_types() = {
    let f [Int, Int, Int]Func = (x Int, y Int) Int -> x + y
    let g [Int, Int]Func      = (x) -> x * 2
    let h [Void]Func          = () -> {}

    // 柯里化
    let add = (x Int) -> (y Int) -> x + y
    let v = add(1)(2)

    // 作为参数传递
    let apply = (f [Int, Int]Func, x Int) Int -> f(x)
    apply((x) -> x + 1, 5)
    apply((x Int) Int -> x * 2, 5)

    // 链式调用（lambda 作为参数）
    some_list.filter((x) -> x % 2 == 0).map((x) -> x * x)
}

