// ============================================================
// 访问修饰符 (Access Modifiers)
// ============================================================

// public：所有模块可见
// protected：当前模块及子模块可见（默认）
// private：仅当前文件可见

public  let public_fn()    Void = {}
private let private_fn()   Void = {}
        let protected_fn() Void = {}  // 默认 protected

public type PublicType(
    public  x Int,   // 所有模块可见
    private y Int,   // 仅当前文件可见
            z Int,   // 默认 protected
)

given PublicType {
    public  get_x(self) Int = self.x
    private helper(self) Int = self.y
            internal_op(self) Int = self.z
}


