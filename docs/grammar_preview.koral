// ============================================================
// yield（仅用于 if / when 分支表达式的分支 body）
// ============================================================

let value = if ready() then {
    yield 42
} else {
    yield 0
}

// early yield：在分支 body 内提前产出当前分支表达式的值
let classify(score Int) String =
    if score >= 90 then {
        if score == 100 then { yield "perfect" }
        yield "A"
    } else {
        yield "other"
    }

// 嵌套 when 表达式拥有自己的 yield 目标
let nested(flag Bool) Int =
    if flag then {
        yield when input() in {
            .Some(v) then { yield v },
            .None then { yield 0 },
        }
    } else {
        yield -1
    }


// ============================================================
// 控制流 (Control Flow)
// ============================================================

let control_flow() Void = {
    // if-then（单分支）
    if a < b then {
        todo()
    }

    // if-then-else（双分支）
    let v = if true then 0 else 1
    if a then {
        todo()
    } else if b then {
        todo()
    } else {
        todo()
    }

    // 条件逻辑组合（左到右短路；前面绑定可供后续 and 子句使用）
    if ready() and has_permission() and feature_enabled() then run() else deny()
    if input is .Some(x) and x > 0 and validate(x) then accept(x) else reject()

    // while-then（语句）
    while a < b then {
        todo()
    }

    // while 条件逻辑组合
    while iter.next() is .Some(v) and v < 10 then println(v)

    // for-in-then（语句）
    for item in list then println(item)
    for i in 0..10 then println(i)
    for i in 0..10 then if i % 2 == 0 then println(i)

    // 解构迭代（需要 enumerate 返回的元素用 pattern 解构）
    for (first, second) in list.enumerate() then {
        println(first)
        println(second)
    }

    // return / break / continue
    let early Func[Int, Int] = (x Int) Int ->
        if x > 0 then 1 else 2

    while i < 10 then {
        i += 1
        if i == 5 then { continue }
        if i == 8 then { break }
    }

    // loop 里的 yield：指向外层 if / when 分支表达式
    let first_even = when list.count() in {
        0 then { yield -1 },
        _ then {
            let mut i = 0
            while i < list.count() then {
                if list[i] % 2 == 0 then { yield list[i] }
                i += 1
            }
            yield -1
        },
    }

    // finally（LIFO 顺序，作用域退出前执行）
    let with_defer Func[Void] = () -> {
        finally println("C")  // 最后执行
        finally println("B")
        finally println("A")  // 最先执行
        println("working")
        // 输出: working -> A -> B -> C
    }
}


// ============================================================
// 模式匹配 (Pattern Matching)
// ============================================================

let pattern_matching() Void = {
    // when 表达式（穷举匹配）
    when x in {
        1       then "one",
        2       then "two",
        _       then "other",
    }

    // 所有模式类型
    when value in {
        1           then todo(),  // 整数字面量
        -5          then todo(),  // 负整数字面量
        'a'         then todo(),  // rune 字面量
        "abc"       then todo(),  // 字符串字面量
        true        then todo(),  // 布尔字面量
        (a, b)      then todo(),  // Pair 解构模式
        ((a, b), c) then todo(),  // 嵌套 Pair 解构模式
        _           then todo(),  // 通配符
        x           then todo(),  // 变量绑定
        mut x       then todo(),  // 可变变量绑定
        Foo(x, y)   then todo(),  // 结构体解构
        .Some(x)    then todo(),  // enum case 解构
        > 5         then todo(),  // 比较模式（大于）
        < 10        then todo(),  // 比较模式（小于）
        >= 0        then todo(),  // 比较模式（大于等于）
        <= 100      then todo(),  // 比较模式（小于等于）
        > -5        then todo(),  // 比较模式（负数）
        1 or 2      then todo(),  // or 组合
        x and > 0   then todo(),  // and 组合（绑定 + 比较）
        not 0       then todo(),  // not 组合
    }

    // 数值范围匹配（and 组合比较模式）
    when num in {
        0 or 1 or 2 or 3 or 4 or 5 or 6 or 7 or 8 or 9 then
            println("single digit"),
        n and >= 10 and <= 99 then
            println("double digits"),
        n and >= 100 and <= 999 then
            println("triple digits"),
        _ then
            println("four or more digits"),
    }

    // if is（条件模式匹配）
    if op is .Some(v) then println(v)
    if a is 1 or a is 2 then todo()
    if a is n and n < 2 then todo()
    if a is not 2 then todo()

    // while is（循环模式匹配）
    let iter = list.iterator()
    while iter.next() is .Some(v) then println(v)

    // Pair pattern（if / when）
    if (1, 2) is (a, b) then println(a + b)
    when ((1, 2), 3) in {
        ((x, y), z) then println(x + y + z),
    }

    // 链式条件匹配（前一段绑定供后一段使用）
    if foo() is A(x) and bar(x) is B(y) then {
        do_stuff_with(x, y)
    }
}

// ============================================================
// 结构体解构模式 (Struct Destructuring Pattern)
// ============================================================

type Point(x Int, y Int)
type Rect(origin Point, width Int, height Int)

let struct_destructuring() Void = {
    let r = Rect(Point(1, 2), 30, 40)

    // when 中解构
    when r in {
        Rect(Point(x, y), w, h) then println(x + y + w + h),
    }

    // if is 中解构
    if r is Rect(Point(x, y), _, _) then println(x + y)

    // 字段通配符
    when r in {
        Rect(_, w, h) then println(w * h),
    }

    // 字段字面量匹配
    when r in {
        Rect(Point(0, _), _, _) then println("origin at x=0"),
        Rect(Point(x, _), _, _) then println(x),
    }
}


