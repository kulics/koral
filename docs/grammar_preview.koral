// 可变字段
type Counter(mut count Int)

// 带注解的结构体
@Table("user")
type User(
    @Column("id") @Key
    id String,
    @Column("nick_name")
    nick_name String,
)

// union（和类型 / 枚举）
type TreeNode {
    Empty(),
    Node(val Int, left TreeNode ref, right TreeNode ref),
}

// 泛型 union（ADT）
type [T Any]Option {
    Some(value T),
    None(),
}

// GADT（广义代数数据类型）
type [T Any]Expr {
    IntExpr(value Int)                                    [Int]Expr,
    BoolExpr(value Bool)                                  [Bool]Expr,
    EqualExpr(left [T]Expr ref, right [T]Expr ref)        [Bool]Expr,
    AddExpr(left [Int]Expr ref, right [Int]Expr ref)      [Int]Expr,
}

// 类型别名
type Byte    = UInt8
type Meters  = Int
type Coord   = Point

// 不透明类型（opaque type，用于 FFI）
type C_Opaque

// 泛型结构体
type [T Any]Table(mut data T)


// ============================================================
// 类型修饰符：ref / ptr / weakref
// ============================================================

let type_modifiers() = {
    // ref：引用计数堆引用
    let a Int ref = box(42)
    println(deref a)        // 显式解引用
    println(a)              // 成员访问时自动解引用（对结构体）

    // ptr：原始指针
    let b Int ptr = ptr a

    // weakref：弱引用（不增加引用计数）
    let c Int weakref = downgrade_ref(a)

    // 类型注解中使用
    let f [Int ref, Void]Func = (x) -> println(deref x)
}

// ============================================================
// 堆分配 (Heap Allocation)
// ============================================================

let heap_allocation() = {
    // box() 将值分配到堆上，返回 ref
    let r Int ref = box(42)
    let p Point ref = box(Point(10, 20))
    println(p.x)            // 成员访问自动解引用
    println(p.getX())       // 方法调用自动解引用
}

// ============================================================
// weakref 弱引用
// ============================================================

let weakref_example() = {
    let strong Int ref = box(42)

    // 降级为弱引用
    let weak Int weakref = downgrade_ref(strong)

    // 升级回强引用（返回 Option）
    when upgrade_ref(weak) in {
        .Some(r) then println(deref r),
        .None    then println("expired"),
    }
}

// ============================================================
// 指针操作 (Raw Pointer Operations)
// ============================================================

let pointer_ops() = {
    let p Int ptr = [Int]alloc_memory(2)  // 分配 2 个 Int 的内存

    init_memory(p, 100)           // 初始化
    let val = deptr p             // 解引用读取

    let p2 = p + 1                // 指针偏移
    init_memory(p2, 200)

    deptr p = 999                 // 解引用赋值

    dealloc_memory(p)             // 释放内存

    let np = null_ptr()           // null 指针
    println(p == null_ptr())
}


// ============================================================
// trait（特征 / 接口）
// ============================================================

// 基本 trait
trait Equatable {
    equals(self, other Self) Bool
}

// trait 继承（单继承）
trait Comparable Equatable {
    compare(self, other Self) Int
}

// trait 继承（多继承，and 连接）
trait Printable {
    to_string(self) String
}

trait PrettyPrint Printable and Equatable {
    pretty(self) String
}

// 泛型 trait
trait [T Any]Iterator {
    next(self ref) [T]Option
}

// ============================================================
// given（实现 trait 或扩展方法）
// ============================================================

type Foo(value Int)

// 扩展方法（不实现 trait）
given Foo {
    double(self) Int = self.value * 2
    // 自定义析构
    __drop(self ref) Void = println("Foo dropped")
}

// 实现 trait
given Foo Equatable {
    equals(self, other Foo) Bool = self.value == other.value
}

given Foo Comparable {
    compare(self, other Foo) Int = self.value - other.value
}

// 泛型 given
type [T Any]Table(mut data T)

given [T Any] [T]Table {
    set_data(self ref, d T) Void = {
        self.data = d
    }
}

// 泛型 given 实现 trait
given [T Equatable] [T]Table Equatable {
    equals(self, other [T]Table) Bool = self.data.equals(other.data)
}

// ============================================================
// trait object（特征对象，动态分发）
// ============================================================

trait Shape {
    area(self) Float64
}

type Circle(radius Float64)
given Circle Shape {
    area(self) Float64 = 3.14159 * self.radius * self.radius
}

let trait_object_example() = {
    // box() + trait ref = 动态分发
    let s Shape ref = box(Circle(5.0))
    println(s.area())

    // 接受 trait ref 参数
    let print_area(shape Shape ref) Void = println(shape.area())
    print_area(s)
}


