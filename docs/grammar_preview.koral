// ============================================================
// 类型修饰符：ref / mut ref / ptr / mut ptr / weakref / mut weakref / val
// ============================================================

let type_modifiers() Void = {
    // ref：只读受管理引用
    // - 可通过不可变左值上的 .ref 形成（产出 ref T）
    // - 也可通过 box() 创建（返回 mut ref T，可隐式宽化为 ref T）
    // - 成员访问自动解引用（对结构体/枚举类型）
    // - .val 读取值，但不支持 .val 赋值（ref 是只读引用）
    let local Int = 7
    let borrowed ref Int = local.ref    // let 绑定 → ref T
    let a ref Int = box(42)             // box() 返回 mut ref T，隐式宽化为 ref T
    println(a.val)          // 显式解引用读取
    let point_ref ref Point = box(Point(10, 20))
    println(point_ref.x)    // 对结构体做成员访问时自动解引用
    // a.val = 99           // 错误：ref 不支持 .val 赋值

    // mut ref：可变受管理引用
    // - 可通过可变左值上的 .ref 形成（产出 mut ref T）
    // - box() 返回 mut ref T
    // - 支持 .val 读取和 .val = expr 赋值
    // - mut ref T 可隐式转换为 ref T（丢弃写权限），反向不允许
    let mut local2 Int = 7
    let mut_borrowed mut ref Int = local2.ref  // let mut 绑定 → mut ref T
    let owned mut ref Int = box(42)            // box() 返回 mut ref T
    println(owned.val)      // .val 读取
    owned.val = 99          // .val 赋值（mut ref 支持）

    // ptr：只读原始指针
    // - 支持 .val 读取，但不支持 .val 赋值
    // - 支持下标读取 p[i]，但不支持下标赋值
    // - 支持指针算术（+ / -）
    let b ptr Int = a.ptr
    let value = b.val       // .val 读取
    // b.val = 99           // 错误：ptr 不支持 .val 赋值
    let v0 = b[0]           // 下标读取（等价于 (b + 0).val）
    // b[1] = 200           // 错误：ptr 不支持下标赋值

    // mut ptr：可变原始指针
    // - 支持 .val 读取和 .val 赋值
    // - 支持下标读取和下标赋值（指针偏移语义）
    // - 支持指针算术（+ / -）
    let mp mut ptr Int = alloc_memory[Int](2)
    mp.val = 99             // .val 赋值
    mp[0] = 111             // 下标赋值（等价于 (mp + 0).val = 111）
    mp[1] = 222             // 下标赋值（等价于 (mp + 1).val = 222）

    // weakref / mut weakref：弱引用（不增加引用计数）
    // weakref T 是只读弱引用，mut weakref T 是可变弱引用
    let c weakref Int = a.weakref                  // ref T → weakref T
    let d mut weakref Int = owned.weakref          // mut ref T → mut weakref T

    // 类型注解中使用
    let f Func[ref Int, Void] = (x) -> println(x.val)
}

// ============================================================
// 堆分配 (Heap Allocation)
// ============================================================

let heap_allocation() Void = {
    // box() 将值分配到堆上，返回 mut ref
    let r mut ref Int = box(42)
    let p mut ref Point = box(Point(10, 20))
    println(p.x)            // 成员访问自动解引用
    println(p.y)            // 另一侧字段同样可直接访问
    r.val = 100             // mut ref 支持 .val 赋值
}

// ============================================================
// weakref 弱引用
// ============================================================

let weakref_example() Void = {
    let strong mut ref Int = box(42)

    // 降级为可变弱引用（mut ref → mut weakref）
    let weak mut weakref Int = strong.weakref

    // 升级回可变强引用（mut weakref T → Option[mut ref T]）
    when weak.to_ref() in {
        .Some(r) then {
            println(r.val)
            r.val = 100       // mut ref 支持赋值
        },
        .None then println("expired"),
    }

    // 只读版本：ref T → weakref T → Option[ref T]
    let ro ref Int = strong           // mut ref 隐式宽化为 ref
    let ro_weak weakref Int = ro.weakref
    when ro_weak.to_ref() in {
        .Some(r) then println(r.val),
        .None    then println("expired"),
    }
}

// ============================================================
// 指针操作 (Raw Pointer Operations)
// ============================================================

let pointer_ops() Void = {
    let p mut ptr Int = alloc_memory[Int](2)  // 分配 2 个 Int 的内存，返回 mut ptr

    init_memory(p, 100)           // 初始化（要求 mut ptr）
    let value = p.val             // 解引用读取

    let p2 = p + 1                // 指针偏移
    init_memory(p2, 200)

    p.val = 999                   // 解引用赋值（mut ptr 支持）

    // 下标访问（指针偏移 + 解引用）
    let v0 = p[0]                 // 等价于 (p + 0).val
    let v1 = p[1]                 // 等价于 (p + 1).val
    p[0] = 111                    // 下标赋值（mut ptr 支持）
    p[1] = 222

    deinit_memory(p)              // 析构（要求 mut ptr）
    deinit_memory(p2)
    dealloc_memory(p)             // 释放内存

    let np ptr Int = null_ptr()   // null 指针（返回 ptr T）
    println(p == null_ptr())
}


// ============================================================
// trait（特征 / 接口）
// ============================================================

// 基本 trait
trait Eq {
    equals(self, other Self) Bool
}

// trait 继承（单继承）
trait Ord Eq {
    compare(self, other Self) Int
}

// trait 继承（多继承，and 连接）
trait ToString {
    to_string(self ref) String
}

trait PrettyPrint ToString and Eq {
    pretty(self) String
}

// 泛型 trait
trait Iterator[T Any] {
    next(self mut ref) Option[T]
}

// ============================================================
// given（实现 trait 或扩展方法）
// ============================================================

type Foo(value Int)

// 扩展方法（不实现 trait）
given Foo {
    double(self) Int = self.value * 2
}

// 实现 trait
given Foo as Eq {
    equals(self, other Foo) Bool = self.value == other.value
}

given Foo as Ord {
    compare(self, other Foo) Int = self.value - other.value
}

// 泛型 given
type Table[T Any](mut data T)

given[T Any] Table[T] {
    set_data(self mut ref, d T) Void = {
        self.data = d
    }
}

// 泛型 given 实现 trait
given[T Eq] Table[T] as Eq {
    equals(self, other Table[T]) Bool = self.data.equals(other.data)
}

// ============================================================
// 操作符重载 (Operator Overloading)
// ============================================================

// Koral 通过 Trait 实现算术/比较类操作符重载。
// 常见映射：
// +  -> Add[R]
// -  -> Sub[R] / Neg
// *  -> Mul[R]
// /  -> Div[R]
// %  -> Rem[R]
// == / <> -> Eq
// < / > / <= / >= -> Ord
// [] / []= 是内建语义，仅支持 String / List / Deque / pointer
// 位运算与移位目前仍是内建操作，不通过公开 Trait 自定义。

type Vec2(x Int, y Int)

given Vec2 as Add[Vec2] {
    add(self, other Vec2) Vec2 = Vec2(self.x + other.x, self.y + other.y)
}

given Vec2 as Neg {
    neg(self) Vec2 = Vec2(-self.x, -self.y)
}

given Vec2 as Eq {
    equals(self, other Vec2) Bool = self.x == other.x and self.y == other.y
}

given Vec2 as Ord {
    compare(self, other Vec2) Int =
        if self.x <> other.x then self.x.compare(other.x) else self.y.compare(other.y)
}

let operator_overloading() Void = {
    let a = Vec2(1, 2)
    let b = Vec2(3, 4)

    let sum = a + b
    let flipped = -sum

    if a == b then println("same")
    if a < b then println("ordered")

    println(sum.x)
    println(flipped.y)
}

// 内建下标访问与下标赋值
let builtin_subscript() Void = {
    let mut list = [10, 20, 30]
    println(list[0])
    list[1] = 99

    let text = "abc"
    let b UInt8 = text[1]
    println(b)

    let p mut ptr Int = alloc_memory[Int](2)
    p[0] = list[0]
    p[1] = list[1]
    println(p[1])
    dealloc_memory(p)
}

// ============================================================
// trait object（特征对象，动态分发）
// ============================================================

trait Shape {
    area(self ref) Float64
    reset(self mut ref) Void
}

type Circle(mut radius Float64)
given Circle as Shape {
    area(self ref) Float64 = 3.14159 * self.radius * self.radius
    reset(self mut ref) Void = {
        self.radius = 0.0
    }
}

let trait_object_example() Void = {
    // ref TraitName / mut ref TraitName 类型 + box() = 动态分发
    let s ref Shape = box(Circle(5.0))
    let ms mut ref Shape = box(Circle(6.0))
    println(s.area())
    ms.reset()
    println(ms.area())

    // 接受 trait ref 参数的函数值
    let print_area Func[ref Shape, Void] = (shape ref Shape) -> println(shape.area())
    print_area(s)
}


