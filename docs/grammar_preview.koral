// 泛型类型实例化
let generics_usage() = {
    let t = [Int]Table(42)      // 显式类型参数
    let t2 = Table(42)          // 推断类型参数

    [Int]add(1, 2)              // 显式泛型函数调用
    add(1, 2)                   // 推断泛型函数调用
}

// ============================================================
// 泛型方法（方法级类型参数）
// ============================================================

type [T Any]MyBox(value T)

given [T Any] [T]MyBox {
    // [U Any] 是方法自己的类型参数
    public [U Any]transform(self, f [T, U]Func) U = f(self.value)
}

let generic_method_call() = {
    let b = [Int]MyBox(21)
    // 显式指定方法类型参数
    let result = b.[Int]transform((x) -> x * 2)
    println(result)
}

// ============================================================
// 限定方法调用（消歧义，指定 trait）
// ============================================================

trait Tag {
    value(self) Int
}

given Tag {
    // given 扩展方法（为所有实现了 Tag 的类型提供默认方法）
    plus_ten(self) Int = self.value() + 10
}

type Num(x Int)
given Num Tag {
    value(self) Int = self.x
}

let qualified_call_example() = {
    let n = Num(7)
    // obj.(TraitName)method() — 实例限定调用
    println(n.(Tag)plus_ten())
    // 对类型名同样可以使用限定调用形式
    println(Num.(Tag)plus_ten(n))
}


// ============================================================
// or else / and then / or return（Option/Result 链式操作）
// ============================================================

let option_chaining() = {
    let opt = [Int]Option.Some(42)
    let none = [Int]Option.None()

    // or else：解包，None 时使用默认值
    let value  = opt  or else 0   // 42
    let value2 = none or else 0   // 0

    // or else + 提前返回（自定义错误处理）
    let default_option [[Int]Option, Int]Func = (o [Int]Option) Int -> {
        let v = o or else { return -1 }
        return v * 2
    }

    // and then：值变换（Some 时执行，None 时透传）
    let doubled = opt and then it * 2              // Some(84)
    let chained = opt and then it + 1 and then it * 3  // Some(129)

    // and then + 自动 flatten（monadic bind）
    let safe_div [Int, Int, [Int]Option]Func = (x Int, y Int) [Int]Option ->
        if y == 0 then .None() else .Some(x / y)
    let result = opt and then safe_div(it, 10)     // Option[Option[T]] -> Option[T]

    // Result 的 or else 错误传播
    let double_result [[Int]Result, [Int]Result]Func = (res [Int]Result) [Int]Result -> {
        let value = res or else { return .Error(it) }
        return .Ok(value * 2)
    }
}

// ============================================================
// or return（错误传播语法糖）
// ============================================================

// or return 是 or else + 提前返回的简写形式：
//   对 Result：expr or return  等价于  expr or else { return .Error(it) }
//   对 Option：expr or return  等价于  expr or else { return .None() }
//
// 约束：
//   - Result 传播只能用在返回 Result 的函数中
//   - Option 传播只能用在返回 Option 的函数中

let read_config(path String) [Config]Result = {
    let text = read_text_file(path) or return         // Result 传播
    let parsed = parse_json(text) or return
    return .Ok(parsed)
}

let find_user(id Int) [User]Option = {
    let entry = lookup_table(id) or return            // Option 传播
    let user = entry.to_user() or return
    return .Some(user)
}

// or return + and then 组合
let doubled_value(res [Int]Result) [Int]Result = {
    let value = (res and then it * 2) or return          // 先 transform，再传播
    return .Ok(value + 1)
}

// 对比：or return vs or else
let format_file_with_or_return(path String) [Void]Result = {
    let source = read_text_file(path) or return
    let formatted = format_source(source) or return
    return write_text_file(path, content: formatted)
}

let format_file_with_or_else(path String) [Void]Result = {
    let source = read_text_file(path) or else { return [Void]Result.Error(it) }
    let formatted = format_source(source) or else { return [Void]Result.Error(it) }
    return write_text_file(path, content: formatted)
}

// or else 仍然用于需要自定义处理的场景
let with_custom_handling(path String) [String]Result = {
    let source = read_text_file(path) or else {
        eprintln("Warning: failed to read \(path)")
        return .Error(it)
    }
    return .Ok(source)
}

// ============================================================
// 模块限定类型 (Module-Qualified Types)
// ============================================================

// using "models" as Models
let module_qualified_types() = {
    // 模块前缀访问类型和构造函数
    let user Models.User = Models.User(1, "Alice")
    let id   Models.UserId = Models.UserId(42)

    // 模块前缀访问泛型类型
    let list Models.[Int]List = Models.[Int]List.new()
}

// ============================================================
// 访问修饰符 (Access Modifiers)
// ============================================================

// public：所有模块可见
// protected：当前模块及子模块可见（默认）
// private：仅当前文件可见

public  let public_fn()    Void = {}
private let private_fn()   Void = {}
        let protected_fn() Void = {}  // 默认 protected

public type PublicType(
    public  x Int,   // 所有模块可见
    private y Int,   // 仅当前文件可见
            z Int,   // 默认 protected
)

given PublicType {
    public  get_x(self) Int = self.x
    private helper(self) Int = self.y
            internal_op(self) Int = self.z
}


// ============================================================
// 集合字面量 (Collection Literals)
// ============================================================

let collections() = {
    // List（动态数组）
    let list [Int]List = [1, 2, 3, 4, 5]
    println(list[0])        // 下标访问

    // Dict（键值对）
    let dict [String, Bool]Dict = ["a": true, "b": false]
    println(dict["a"])       // key 访问
}

// ============================================================
// 自定义析构 (drop)
// ============================================================

type Resource(id Int)

given Resource Drop {
    drop(self mut ref) Void = {
        print("dropping resource ")
        println(self.id)
    }
}

let drop_example() = {
    let r = Resource(1)
    // r 在作用域结束时自动调用 drop
    // finally 在 drop 之前执行
    finally println("deferred cleanup")
}
