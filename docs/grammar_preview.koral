// ============================================================
// 字面量 (Literals)
// ============================================================

let literals() = {
    // 字符串
    let s String = "hello, world!"
    let escaped = "tab:\t newline:\n quote:\""
    let hex_byte = "\xAB"
    let unicode = "\u{1F600}"

    // 多行字符串（三引号，缩进以 closing """ 为基准自动剥离）
    let multi = """
        hello
        world
        """
    // multi == "hello\nworld"

    // 字符串插值
    let name = "Koral"
    let greeting = "Hello \(name), 1 + 1 = \(1 + 1)"

    // 多行字符串中的插值
    let doc = """
        Dear \(name),
        Welcome.
        """

    // Rune（字符）字面量
    let r Rune = 'a'
    let newline_rune = '\n'
    let unicode_rune = '\u{1F600}'

    // 整数
    let decimal Int = 123
    let binary  Int = 0b1010          // value: 10
    let octal   Int = 0o755           // value: 493
    let hex     Int = 0xFF            // value: 255
    let sep     Int = 1_000_000       // 下划线分隔符
    let hex_sep Int = 0xFF_FF         // value: 65535

    // 浮点数
    let f64 Float64 = 1.23
    let sci1 Float64 = 1e10
    let sci2 Float64 = 2.5e-3
    let sci3 Float64 = 1e+6

    // Duration 后缀字面量
    let d1 Duration = 10s
    let d2 Duration = 250ms
    let d3 Duration = 30min
    let d4 Duration = 2h
    let d5 Duration = 150us
    let d6 Duration = 42ns
    let d_neg Duration = -5s

    // Pair 字面量（等价于 Pair(a, b)）
    let p1 = (1, 2)
    let p2 = (true, "ok")
    let p3 = ((1, 2), 3)   // 嵌套 Pair

    // 布尔
    let t Bool = true
    let f Bool = false

    // 类型转换（cast）
    let i32 = (Int32)42
    let f32 Float32 = (Float32)f64
}


