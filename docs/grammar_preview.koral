// ============================================================
// 自定义析构 (__drop)
// ============================================================

type Resource(id Int)

given Resource {
    __drop(self ref) Void = {
        print("dropping resource ")
        println(self.id)
    }
}

let drop_example() = {
    let r = Resource(1)
    // r 在作用域结束时自动调用 __drop
    // defer 在 __drop 之前执行
    defer println("deferred cleanup")
}

// ============================================================
// 综合示例：完整的类型定义与使用
// ============================================================

trait Animation {
    move(self ref, speed Int) Void
    stop(self ref) Void
}

type Image(
    private width  Int,
    private height Int,
    private source String,
)

type Button(width Int, height Int, label String)

type ImageButton(image Image, button Button)

given ImageButton Animation {
    move(self ref, speed Int) Void = {
        let t = 5000 / speed
        play(speed + t)
    }
    stop(self ref) Void = {}
}

let animation_example() = {
    let img = Image(100, 200, "icon.png")
    let btn = Button(80, 30, "OK")
    let ib  = ImageButton(img, btn)

    // 方法调用
    ib.move(60)
    ib.stop()

    // 通过 trait ref 使用（动态分发）
    let play_animation(a Animation ref) Void = {
        a.move(1000)
        a.stop()
    }
    play_animation(ref ib)
}

