// ============================================================
// 字面量 (Literals)
// ============================================================

let literals() Void = {
    // 字符串
    let s String = "hello, world!"
    let escaped = "tab:\t newline:\n quote:\""
    let hex_byte = "\xAB"
    let unicode = "\u{1F600}"

    // 多行字符串（三引号，缩进以 closing """ 为基准自动剥离）
    let multi = """
        hello
        world
        """
    // multi == "hello\nworld"

    // 字符串插值
    let name = "Koral"
    let greeting = "Hello \(name), 1 + 1 = \(1 + 1)"

    // 多行字符串中的插值
    let doc = """
        Dear \(name),
        Welcome.
        """

    // Rune（字符）字面量
    let r Rune = 'a'
    let newline_rune = '\n'
    let unicode_rune = '\u{1F600}'

    // 整数
    let decimal Int = 123
    let binary  Int = 0b1010          // value: 10
    let octal   Int = 0o755           // value: 493
    let hex     Int = 0xFF            // value: 255
    let sep     Int = 1_000_000       // 下划线分隔符
    let hex_sep Int = 0xFF_FF         // value: 65535

    // 浮点数
    let f64 Float64 = 1.23
    let sci1 Float64 = 1e10
    let sci2 Float64 = 2.5e-3
    let sci3 Float64 = 1e+6

    // Duration 后缀字面量
    let d1 Duration = 10s
    let d2 Duration = 250ms
    let d3 Duration = 30min
    let d4 Duration = 2h
    let d5 Duration = 150us
    let d6 Duration = 42ns
    let d_neg Duration = -5s

    // Pair 字面量（等价于 Pair(a, b)）
    let p1 = (1, 2)
    let p2 = (true, "ok")
    let p3 = ((1, 2), 3)   // 嵌套 Pair

    // 布尔
    let t Bool = true
    let f Bool = false

    // 类型转换（cast）
    let i32 = 42(Int32)
    let f32 Float32 = f64(Float32)
}


// ============================================================
// 变量与常量 (Variables & Constants)
// ============================================================

let variables() Void = {
    // 不可变绑定（类型推断）
    let x = 42
    // 不可变绑定（显式类型）
    let y Int = 42
    // 可变绑定
    let mut z Int = 0
    z = 10
    z += 1

    // Pair 解构绑定
    let (a, b) = (1, 2)                  // 类型推断
    let (c Int, d String) = (3, "hello")  // 显式类型标注
    let (mut e, f) = (10, 20)             // 可变绑定
    let (_, g) = (1, 2)                   // 丢弃第一个元素

    // 丢弃返回值
    _ = some_fn()
}

// ============================================================
// 运算符 (Operators)
// ============================================================

let operators() Void = {
    // 逻辑运算符
    x and y
    x or y
    not x

    // 比较运算符
    x == y  // eq
    x <> y  // ne
    x > y   // gt
    x < y   // lt
    x >= y  // ge
    x <= y  // le

    // 算术运算符
    x + y   // add
    x - y   // sub
    x * y   // mul
    x / y   // div
    x % y   // mod
    -x      // unary minus

    // 位运算符
    x & y   // bitwise and
    x | y   // bitwise or
    x ^ y   // bitwise xor
    ~x      // bitwise not
    x << y  // left shift
    x >> y  // right shift

    // 复合赋值运算符
    x += y;  x -= y;  x *= y;  x /= y;  x %= y
    x &= y;  x |= y;  x ^= y;  x <<= y; x >>= y

    // 范围运算符
    let a = 1..5    // 1 <= x <= 5  (closed)
    let b = 1..<5   // 1 <= x < 5   (closed-open)
    let c = 1<..5   // 1 < x <= 5   (open-closed)
    let d = 1<..<5  // 1 < x < 5    (open)
    let e = 1..     // 1 <= x <= max (from)
    let f = 1<..    // 1 < x <= max  (from-open)
    let g = ..5     // min <= x <= 5 (to)
    let h = ..<5    // min <= x < 5  (to-open)
    let i = ..      // min <= x <= max (full)
}


