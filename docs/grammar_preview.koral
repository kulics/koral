// 泛型 (Generics)
// ============================================================

// 泛型函数（单约束）
let find[T Eq](list List[T], item T) Bool = todo()

// 泛型函数（多约束）
let sort_and_dedup[T Eq and Ord](list List[T]) List[T] = todo()

// 泛型类型实例化
let generics_usage() Void = {
    let t = Table[Int](42)      // 显式类型参数
    let t2 = Table(42)          // 推断类型参数

    add[Int](1, 2)              // 显式泛型函数调用
    add(1, 2)                   // 推断泛型函数调用
}

// ============================================================
// 泛型方法（方法级类型参数）
// ============================================================

type MyBox[T Any](value T)

given[T Any] MyBox[T] {
    // [U Any] 是方法自己的类型参数
    public transform[U Any](self, f Func[T, U]) U = f(self.value)
}

let generic_method_call() Void = {
    let b = MyBox[Int](21)
    // 显式指定方法类型参数
    let result = b.transform[Int]((x) -> x * 2)
    println(result)
}

// ============================================================
// 限定方法调用（消歧义，指定 trait）
// ============================================================

trait Tag {
    value(self) Int
}

given Tag {
    // given 扩展方法（为所有实现了 Tag 的类型提供默认方法）
    plus_ten(self) Int = self.value() + 10
}

type Num(x Int)
given Num as Tag {
    value(self) Int = self.x
}

let qualified_call_example() Void = {
    let n = Num(7)
    // obj.(TraitName)method() — 实例限定调用
    println(n.(Tag)plus_ten())
    // 对类型名同样可以使用限定调用形式
    println(Num.(Tag)plus_ten(n))
}


// ============================================================
// or else / and then / or return（Option/Result 链式操作）
// ============================================================

let option_chaining() Void = {
    let opt = Option[Int].Some(42)
    let none = Option[Int].None()

    // or else：解包，None 时使用默认值
    let value  = opt  or else 0   // 42
    let value2 = none or else 0   // 0

    // or else + 提前返回（自定义错误处理）
    let default_option Func[Option[Int], Int] = (o Option[Int]) Int -> {
        let v = o or else { return -1 }
        return v * 2
    }

    // and then：值变换（Some 时执行，None 时透传）
    let doubled = opt and then it * 2              // Some(84)
    let chained = opt and then it + 1 and then it * 3  // Some(129)

    // and then + 自动 flatten（monadic bind）
    let safe_div Func[Int, Int, Option[Int]] = (x Int, y Int) Option[Int] ->
        if y == 0 then .None() else .Some(x / y)
    let result = opt and then safe_div(it, 10)     // Option[Option[T]] -> Option[T]

    // Result 的 or else 错误传播
    let double_result Func[Result[Int], Result[Int]] = (res Result[Int]) Result[Int] -> {
        let value = res or else { return .Error(it) }
        return .Ok(value * 2)
    }
}

// ============================================================
// or return（错误传播语法糖）
// ============================================================

// or return 是 or else + 提前返回的简写形式：
//   对 Result：expr or return  等价于  expr or else { return .Error(it) }
//   对 Option：expr or return  等价于  expr or else { return .None() }
//
// 约束：
//   - Result 传播只能用在返回 Result 的函数中
//   - Option 传播只能用在返回 Option 的函数中

let read_config(path String) Result[Config] = {
    let text = read_text_file(path) or return         // Result 传播
    let parsed = parse_json(text) or return
    return .Ok(parsed)
}

let find_user(id Int) Option[User] = {
    let entry = lookup_table(id) or return            // Option 传播
    let user = entry.to_user() or return
    return .Some(user)
}

// or return + and then 组合
let doubled_value(res Result[Int]) Result[Int] = {
    let value = (res and then it * 2) or return          // 先 transform，再传播
    return .Ok(value + 1)
}

// 对比：or return vs or else
let format_file_with_or_return(path String) Result[Void] = {
    let source = read_text_file(path) or return
    let formatted = format_source(source) or return
    return write_text_file(path, content: formatted)
}

let format_file_with_or_else(path String) Result[Void] = {
    let source = read_text_file(path) or else { return Result[Void].Error(it) }
    let formatted = format_source(source) or else { return Result[Void].Error(it) }
    return write_text_file(path, content: formatted)
}

// or else 仍然用于需要自定义处理的场景
let with_custom_handling(path String) Result[String] = {
    let source = read_text_file(path) or else {
        eprintln("Warning: failed to read \(path)")
        return .Error(it)
    }
    return .Ok(source)
}

// ============================================================
// 访问修饰符 (Access Modifiers)
// ============================================================

// public：所有 package / module 可见
// protected public：同一 package 内可见
// protected：仅当前逻辑 module 内可见（顶层默认）
// private：仅当前文件可见

public  let public_fn()    Void = {}
protected public let package_fn() Void = {}
private let private_fn()   Void = {}
        let protected_fn() Void = {}  // 默认 protected

public type PublicType(
    public           x Int,   // 所有 package / module 可见
    protected public y Int,   // 同一 package 内各 module 可见
    protected        z Int,   // 仅当前 module 可见
    private          w Int,   // 仅当前文件可见
                     k Int,   // 字段默认 public
)

given PublicType {
    public           get_x(self) Int = self.x
    protected public package_helper(self) Int = self.y
    private          helper(self) Int = self.w
                     internal_op(self) Int = self.z
}


// ============================================================
// 集合字面量 (Collection Literals)
// ============================================================

let collections() Void = {
    // List（动态数组）
    let list List[Int] = [1, 2, 3, 4, 5]
    println(list[0])        // 下标访问

    // Dict（键值对）
    let dict Dict[String, Bool] = ["a": true, "b": false]
    println(dict)
}

// ============================================================
// 自定义析构 (drop)
// ============================================================

type Resource(id Int)

given Resource as Drop {
    drop(source mut ptr Self) Void = {
        print("dropping resource ")
        println(self.id)
    }
}

let drop_example() Void = {
    let r = Resource(1)
    // r 在作用域结束时自动调用 drop
    // finally 在 drop 之前执行
    finally println("deferred cleanup")
}
