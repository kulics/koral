// ============================================================
// 泛型方法（方法级类型参数）
// ============================================================

type [T Any]MyBox(value T)

given [T Any] [T]MyBox {
    // [U Any] 是方法自己的类型参数
    public [U Any]transform(self, f [T, U]Func) U = f(self.value)
}

let generic_method_call() = {
    let b = [Int]MyBox(21)
    // 显式指定方法类型参数
    let result = b.[Int]transform((x) -> x * 2)
    println(result)
}

// ============================================================
// 限定方法调用（消歧义，指定 trait）
// ============================================================

trait Tag {
    value(self) Int
}

given Tag {
    // given 扩展方法（为所有实现了 Tag 的类型提供默认方法）
    plus_ten(self) Int = self.value() + 10
}

type Num(x Int)
given Num Tag {
    value(self) Int = self.x
}

let qualified_call_example() = {
    let n = Num(7)
    // obj.(TraitName)method() — 实例限定调用
    println(n.(Tag)plus_ten())
    // Type.(TraitName)method(obj) — 静态限定调用
    println(Num.(Tag)plus_ten(n))
}


// ============================================================
// or else / and then（Option/Result 链式操作）
// ============================================================

let option_chaining() = {
    let opt = [Int]Option.Some(42)
    let none = [Int]Option.None()

    // or else：解包，None 时使用默认值
    let val  = opt  or else 0   // 42
    let val2 = none or else 0   // 0

    // or else + 提前返回（错误传播）
    let try_option(o [Int]Option) Int = {
        let v = o or else { return -1 }
        v * 2
    }

    // and then：值变换（Some 时执行，None 时透传）
    let doubled = opt and then _ * 2              // Some(84)
    let chained = opt and then _ + 1 and then _ * 3  // Some(129)

    // and then + 自动 flatten（monadic bind）
    let safe_div(x Int, y Int) [Int]Option =
        if y == 0 then .None() else .Some(x / y)
    let result = opt and then safe_div(_, 10)     // Option[Option[T]] -> Option[T]

    // Result 的 or else 错误传播
    let try_result(res [Int, String]Result) [Int, String]Result = {
        let val = res or else { return .Error(_) }
        .Ok(val * 2)
    }
}

