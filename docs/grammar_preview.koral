let variables() = {
    // 不可变绑定（类型推断）
    let x = 42
    // 不可变绑定（显式类型）
    let y Int = 42
    // 可变绑定
    let mut z Int = 0
    z = 10
    z += 1

    // Pair 解构绑定
    let (a, b) = (1, 2)                  // 类型推断
    let (c Int, d String) = (3, "hello")  // 显式类型标注
    let (mut e, f) = (10, 20)             // 可变绑定
    let (_, g) = (1, 2)                   // 丢弃第一个元素

    // 丢弃返回值
    _ = some_fn()
}

// ============================================================
// 运算符 (Operators)
// ============================================================

let operators() = {
    // 逻辑运算符
    x and y
    x or y
    not x

    // 比较运算符
    x == y  // eq
    x <> y  // ne
    x > y   // gt
    x < y   // lt
    x >= y  // ge
    x <= y  // le

    // 算术运算符
    x + y   // add
    x - y   // sub
    x * y   // mul
    x / y   // div
    x % y   // mod
    -x      // unary minus

    // 位运算符
    x & y   // bitwise and
    x | y   // bitwise or
    x ^ y   // bitwise xor
    ~x      // bitwise not
    x << y  // left shift
    x >> y  // right shift

    // 复合赋值运算符
    x += y;  x -= y;  x *= y;  x /= y;  x %= y
    x &= y;  x |= y;  x ^= y;  x <<= y; x >>= y

    // 范围运算符
    let a = 1..5    // 1 <= x <= 5  (closed)
    let b = 1..<5   // 1 <= x < 5   (closed-open)
    let c = 1<..5   // 1 < x <= 5   (open-closed)
    let d = 1<..<5  // 1 < x < 5    (open)
    let e = 1..     // 1 <= x <= max (from)
    let f = 1<..    // 1 < x <= max  (from-open)
    let g = ..5     // min <= x <= 5 (to)
    let h = ..<5    // min <= x < 5  (to-open)
    let i = ..      // min <= x <= max (full)
}


