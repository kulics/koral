// ============================================================
// 运算符 (Operators)
// ============================================================

let operators() = {
    // 逻辑运算符
    x and y
    x or y
    not x

    // 比较运算符
    x == y  // eq
    x <> y  // ne
    x > y   // gt
    x < y   // lt
    x >= y  // ge
    x <= y  // le

    // 算术运算符
    x + y   // add
    x - y   // sub
    x * y   // mul
    x / y   // div
    x % y   // mod
    -x      // unary minus

    // 位运算符
    x & y   // bitwise and
    x | y   // bitwise or
    x ^ y   // bitwise xor
    ~x      // bitwise not
    x << y  // left shift
    x >> y  // right shift

    // 复合赋值运算符
    x += y;  x -= y;  x *= y;  x /= y;  x %= y
    x &= y;  x |= y;  x ^= y;  x <<= y; x >>= y

    // 范围运算符
    let a = 1..5    // 1 <= x <= 5  (closed)
    let b = 1..<5   // 1 <= x < 5   (closed-open)
    let c = 1<..5   // 1 < x <= 5   (open-closed)
    let d = 1<..<5  // 1 < x < 5    (open)
    let e = 1...    // 1 <= x <= max (from)
    let f = 1<...   // 1 < x <= max  (from-open)
    let g = ...5    // min <= x <= 5 (to)
    let h = ...<5   // min <= x < 5  (to-open)
    let i = ....    // min <= x <= max (full)
}


// ============================================================
// 函数 (Functions)
// ============================================================

// 无参无返回值
let do_nothing() Void = {}

// 有参有返回值
let add(x Int, y Int) Int = x + y

// 推断返回类型
let mul(x Int, y Int) = x * y

// 可变参数
let inc(mut x Int) Int = {
    x += 1
    yield x
}

// 泛型函数（单约束）
let [T Equatable] contains(list [T]List, item T) Bool = todo()

// 泛型函数（多约束）
let [T Equatable and Comparable] max(a T, b T) T =
    if a.compare(b) >= 0 then a else b

// 函数类型
let fn_types() = {
    let f [Int, Int, Int]Func = (x Int, y Int) Int -> x + y
    let g [Int, Int]Func      = (x) -> x * 2
    let h [Void]Func          = () -> {}

    // 柯里化
    let add = (x Int) -> (y Int) -> x + y
    let v = add(1)(2)

    // 作为参数传递
    let apply(f [Int, Int]Func, x Int) Int = f(x)
    apply((x) -> x + 1, 5)
    apply((x Int) Int -> x * 2, 5)

    // 链式调用（lambda 作为参数）
    some_list.filter((x) -> x % 2 == 0).map((x) -> x * x)
}

// ============================================================
// yield（块表达式的显式返回值）
// ============================================================

let get_value() Int = {
    yield 42
}

let pick(flag Bool) Int = {
    yield if flag then {
        yield 10
    } else {
        yield 20
    }
}

// 嵌套 yield
let nested() Int = {
    let x = {
        yield 99
    }
    yield x
}


// ============================================================
// 控制流 (Control Flow)
// ============================================================

let control_flow() = {
    // if-then（单分支）
    if a < b then {
        todo()
    }

    // if-then-else（双分支）
    let v = if true then 0 else 1
    if a then {
        todo()
    } else if b then {
        todo()
    } else {
        todo()
    }

    // let-then（with-init，绑定后立即使用）
    let a = 1 then if a > 0 then println(a)
    let mut i = 0 then while i < 10 then {
        println(i)
        i += 1
    }

    // while-then（单分支）
    while a < b then {
        todo()
    }

    // while-then-else（双分支，break 可携带值）
    let v = while true then break 1 else 2

    // for-in-then
    for item in list then println(item)
    for i in 0..10 then println(i)
    for i in 0..10 then if i % 2 == 0 then println(i)

    // 解构迭代
    for (index, value) in list.enumerate() then {
        println(index)
        println(value)
    }

    // return / break / continue
    let early(x Int) Int = {
        if x > 0 then { return 1 }
        2
    }

    while i < 10 then {
        i += 1
        if i == 5 then { continue }
        if i == 8 then { break }
    }

    // defer（LIFO 顺序，作用域退出前执行）
    let with_defer() Void = {
        defer println("C")  // 最后执行
        defer println("B")
        defer println("A")  // 最先执行
        println("working")
        // 输出: working -> A -> B -> C
    }
}


// ============================================================
// 模式匹配 (Pattern Matching)
// ============================================================

let pattern_matching() = {
    // when 表达式（穷举匹配）
    when x in {
        1       then "one",
        2       then "two",
        _       then "other",
    }

    // 所有模式类型
    when val in {
        1           then todo(),  // 整数字面量
        -5          then todo(),  // 负整数字面量
        'a'         then todo(),  // rune 字面量
        "abc"       then todo(),  // 字符串字面量
        true        then todo(),  // 布尔字面量
        _           then todo(),  // 通配符
        x           then todo(),  // 变量绑定
        mut x       then todo(),  // 可变变量绑定
        Foo(x, y)   then todo(),  // 结构体解构
        .Some(x)    then todo(),  // union case 解构
        > 5         then todo(),  // 比较模式（大于）
        < 10        then todo(),  // 比较模式（小于）
        >= 0        then todo(),  // 比较模式（大于等于）
        <= 100      then todo(),  // 比较模式（小于等于）
        > -5        then todo(),  // 比较模式（负数）
        1 or 2      then todo(),  // or 组合
        x and > 0   then todo(),  // and 组合（绑定 + 比较）
        not 0       then todo(),  // not 组合
    }

    // 数值范围匹配（and 组合比较模式）
    when num in {
        0 or 1 or 2 or 3 or 4 or 5 or 6 or 7 or 8 or 9 then
            println("single digit"),
        n and >= 10 and <= 99 then
            println("double digits"),
        n and >= 100 and <= 999 then
            println("triple digits"),
        _ then
            println("four or more digits"),
    }

    // if is（条件模式匹配）
    if op is .Some(v) then println(v)
    if a is 1 or 2 then todo()
    if a is n and < 2 then todo()
    if a is not 2 then todo()

    // while is（循环模式匹配）
    let iter = list.iterator()
    while iter.next() is .Some(v) then println(v)

    // 链式 if is（嵌套解构）
    if foo() is A(x) then
    if bar(x) is B(y) then {
        do_stuff_with(x, y)
    }
}

// ============================================================
// 结构体解构模式 (Struct Destructuring Pattern)
// ============================================================

type Point(x Int, y Int)
type Rect(origin Point, width Int, height Int)

let struct_destructuring() = {
    let r = Rect(Point(1, 2), 30, 40)

    // when 中解构
    when r in {
        Rect(Point(x, y), w, h) then println(x + y + w + h),
    }

    // if is 中解构
    if r is Rect(Point(x, y), _, _) then println(x + y)

    // 字段通配符
    when r in {
        Rect(_, w, h) then println(w * h),
    }

    // 字段字面量匹配
    when r in {
        Rect(Point(0, _), _, _) then println("origin at x=0"),
        Rect(Point(x, _), _, _) then println(x),
    }
}


