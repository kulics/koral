// ============================================================================
// Koral Build System - build Command
// ============================================================================

using std::os { .. }
using std::proc { .. }

private let target_module_for_build(config ProjectConfig, flags Dict[String, String]) Result[String] = {
    return when flags.get("--module") in {
        .Some(module_name) then {
            if config.modules.contains(module_name) then {
                yield Result[String].Ok(module_name)
            }
            yield Result[String].Error(box("error: module '\(module_name)' not found in koral.json"))
        },
        .None() then default_target_module(config),
    }
}

private let artifact_stem(module_name String) String = {
    return module_name.replace_all("::", with: "__")
}

/// Find koralc executable by searching PATH and KORAL_HOME
public let find_koralc() Option[String] = {
    // Check KORAL_HOME first (root and bin/ subdirectory)
    if env("KORAL_HOME") is .Some(home) then {
        let is_windows = if env("OS") is .Some(os) then os.contains("Windows") else false
        let exts = if is_windows then [".exe", ".cmd", ".bat", ""] else [""]
        let dirs = [home, home + "/bin"]
        for dir in dirs then {
            for ext in exts then {
                let candidate = dir + "/koralc" + ext
                if path_exist(candidate.into_path()) then {
                    return Option[String].Some(candidate)
                }
            }
        }
    }

    // Search PATH
    let path_env = if env("PATH") is .Some(path) then path
        else if env("Path") is .Some(path) then path
        else { return Option[String].None() }

    let is_windows = if env("OS") is .Some(os) then os.contains("Windows") else false
    let sep = if is_windows then ";" else ":"
    let exts = if is_windows then [".exe", ".cmd", ".bat", ""] else [""]
    for dir in path_env.split(sep) then {
        for ext in exts then {
            let candidate = dir + "/koralc" + ext
            if path_exist(candidate.into_path()) then {
                return Option[String].Some(candidate)
            }
        }
    }

    return Option[String].None()
}

/// Build the project
/// koral build [--release]
public let cmd_build(args List[String], flags Dict[String, String]) Int = {
    let config = load_config(".") or else {
        error_msg(it.message())
        return 1
    }
    let target_module = target_module_for_build(config, flags) or else {
        error_msg(it.message())
        return 1
    }

    // Find koralc
    let koralc = find_koralc() or else {
        error_msg("koralc not found. Ensure koralc is in your PATH or set KORAL_HOME")
        return 1
    }

    let stem = artifact_stem(target_module)
    status_msg("Compiling", "\(config.name) v\(config.version) [\(target_module)]")

    // Ensure .build/ directory exists
    create_dir_all(".build".into_path()) or else {
        error_msg("failed to create .build directory: \(it.message())")
        return 1
    }

    // Call koralc build --package-config ./koral.json --target-module <module> -o .build/
    let status = Command.new(koralc)
        .arg("build")
        .arg("--package-config")
        .arg("koral.json")
        .arg("--target-module")
        .arg(target_module)
        .arg("--deps-root")
        .arg(".deps")
        .arg("-o")
        .arg(".build/")
        .set_stdout(IoRedirect.Inherit())
        .set_stderr(IoRedirect.Inherit())
        .run() or else {
        error_msg("failed to run koralc: \(it.message())")
        return 1
    }

    if status.is_success() then {
        let is_windows = if env("OS") is .Some(os) then os.contains("Windows") else false
        let exe_ext = if is_windows then ".exe" else ""
        status_msg("Finished", ".build/\(stem)\(exe_ext)")
        return 0
    }

    // Return koralc's exit code
    return status.code() or else 1
}
