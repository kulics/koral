// ============================================================================
// Koral Build System - check Command
// ============================================================================

using Std.Os.*
using Std.Proc.*

/// Type-check the project without generating an executable
/// koral check
public let cmd_check(args [String]List, flags [String, String]Dict) Int = {
    let config = load_config(".") or else {
        error_msg(it.message())
        return 1
    }

    let koralc = find_koralc() or else {
        error_msg("koralc not found. Ensure koralc is in your PATH or set KORAL_HOME")
        return 1
    }

    status_msg("Checking", "\(config.name) v\(config.version)")

    let status = Command.new(koralc)
        .arg("check")
        .arg(config.entry)
        .set_stdout(IoRedirect.Inherit())
        .set_stderr(IoRedirect.Inherit())
        .run() or else {
        error_msg("failed to run koralc: \(it.message())")
        return 1
    }

    if status.is_success() then {
        status_msg("Finished", "no errors found")
    }

    return status.code() or else 1
}
