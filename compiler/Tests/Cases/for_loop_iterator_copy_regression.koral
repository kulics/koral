// EXPECT: for_loop_iterator_copy_regression_ok

using Std.*

let main() Void = {
    // This shape matches the for-desugaring ownership path:
    // let __koral_iter = normalized.split("/")
    // while ... __koral_iter.next()
    let normalized = "/tmp/a/b/c".replace_all("\\", "/")
    let parts = normalized.split("/")

    let mut seen = [String]List.new()
    for part in parts then {
        if not part.is_empty() then {
            seen.push(part)
        }
    }

    assert(seen.count() == 4, "split count")
    assert(seen.at(0) == "tmp", "first")
    assert(seen.at(1) == "a", "second")
    assert(seen.at(2) == "b", "third")
    assert(seen.at(3) == "c", "fourth")

    println("for_loop_iterator_copy_regression_ok")
}
