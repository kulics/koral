// EXPECT: start
// EXPECT: ref_ref_box_ok
// EXPECT: end
// EXPECT: Drop Tracker

type Tracker(id Int)

given Tracker {
    __drop(self ref) Void = {
        println("Drop Tracker")
    }
}

let main() Int = {
    println("start")

    let mut t = Tracker(9)
    let r Tracker ref = ref t
    let rr Tracker ref ref = box(r)

    if ref_count(deref rr) > 0 then {
        println("ref_ref_box_ok")
    } else {}

    println("end")
    yield 0
}
