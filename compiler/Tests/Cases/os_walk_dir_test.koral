// EXPECT: walk_dir_ok

using std.os.*

let main() Void = {
    let base = create_temp_dir(temp_dir(), "os_walk_dir_test_").unwrap()

    create_dir_all(base.join("a/b")).unwrap()
    create_dir_all(base.join("c")).unwrap()

    write_text_file(base.join("root.txt"), "root").unwrap()
    write_text_file(base.join("a/a.txt"), "a").unwrap()
    write_text_file(base.join("a/b/b.txt"), "b").unwrap()
    write_text_file(base.join("c/c.txt"), "c").unwrap()

    let mut seen = [String]Set.new()
    let mut dir_count UInt = 0
    let mut file_count UInt = 0

    let mut it = walk_dir(base).unwrap()
    while it.next() is .Some(entry) then {
        let normalized = entry.path().to_string().replace_all("\\", "/")
        seen.insert(normalized)

        if entry.is_dir() then {
            dir_count += 1
        } else if entry.is_file() then {
            file_count += 1
        }
    }

    assert(dir_count == 3, "dir count")
    assert(file_count == 4, "file count")

    let root = base.to_string().replace_all("\\", "/")
    assert(seen.contains(root + "/a"), "contains a")
    assert(seen.contains(root + "/a/b"), "contains a/b")
    assert(seen.contains(root + "/c"), "contains c")
    assert(seen.contains(root + "/root.txt"), "contains root.txt")
    assert(seen.contains(root + "/a/a.txt"), "contains a/a.txt")
    assert(seen.contains(root + "/a/b/b.txt"), "contains a/b/b.txt")
    assert(seen.contains(root + "/c/c.txt"), "contains c/c.txt")

    remove_dir_all(base).unwrap()
    println("walk_dir_ok")
}
