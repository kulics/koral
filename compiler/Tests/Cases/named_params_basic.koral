// EXPECT: connected

let create_rect(x Int, y Int, width: Int, height: Int) Int = width * height

let connect(host: String, port: Int) String = "connected"

let main() Int = {
    println(create_rect(10, 20, width: 100, height: 3))
    println(connect(host: "localhost", port: 8080))
    return 0
}
