// Comprehensive test for std.text module
// EXPECT: All regex tests passed

using Std.Text.*

let main() Void = {
    // =========================================================================
    // 1. Regex.compile — compilation success and failure
    // =========================================================================

    // Successful compilation
    when Regex.compile("\\d+") in {
        .Ok(r) then assert(true, "compile ok"),
        .Error(_) then assert(false, "should compile"),
    }

    // Failed compilation — invalid syntax
    when Regex.compile("(") in {
        .Ok(_) then assert(false, "should fail"),
        .Error(_) then assert(true, "invalid syntax detected"),
    }
    when Regex.compile("[") in {
        .Ok(_) then assert(false, "should fail"),
        .Error(_) then assert(true, "invalid bracket"),
    }
    when Regex.compile("*") in {
        .Ok(_) then assert(false, "should fail"),
        .Error(_) then assert(true, "invalid quantifier"),
    }

    // =========================================================================
    // 2. pattern() and group_count()
    // =========================================================================

    let r2 = Regex.compile("(\\w+)@(\\w+)").expect("r2 compile")
    assert(r2.pattern() == "(\\w+)@(\\w+)", "pattern preserved")
    assert(r2.group_count() == 2, "group count")

    // =========================================================================
    // 3. matches
    // =========================================================================

    let r3 = Regex.compile("\\d+").expect("r3 compile")
    assert(r3.matches("abc123") == true, "matches true")
    assert(r3.matches("abcdef") == false, "matches false")

    // =========================================================================
    // 4. find
    // =========================================================================

    let r4 = Regex.compile("\\d+").expect("r4 compile")
    when r4.find("abc123def") in {
        .Some(m) then {
            assert(m.start() == 3, "find start")
            assert(m.end() == 6, "find end")
            assert(m.text() == "123", "find text")
        },
        .None then assert(false, "should find"),
    }

    // =========================================================================
    // 5. find_all — count matches
    // =========================================================================

    let r5 = Regex.compile("a").expect("r5 compile")
    let mut count5 UInt = 0
    for m5 in r5.find_all("aaa") then {
        count5 += 1
    }
    assert(count5 == 3, "find_all count")

    // =========================================================================
    // 6. captures and group()
    // =========================================================================

    let r6 = Regex.compile("(\\w+)@(\\w+)").expect("r6 compile")
    when r6.captures("user@host") in {
        .Some(c) then {
            assert(c.text() == "user@host", "captures text")
            when c.group(1) in {
                .Some(g) then assert(g == "user", "group 1"),
                .None then assert(false, "group 1 missing"),
            }
            when c.group(2) in {
                .Some(g) then assert(g == "host", "group 2"),
                .None then assert(false, "group 2 missing"),
            }
        },
        .None then assert(false, "should capture"),
    }

    // =========================================================================
    // 7. replace and replace_all
    // =========================================================================

    let r7 = Regex.compile("\\d+").expect("r7 compile")
    assert(r7.replace("a1b2c3", "X") == "aXb2c3", "replace first")
    assert(r7.replace_all("a1b2c3", "X") == "aXbXcX", "replace all")

    // =========================================================================
    // 8. replace with $N back-references
    // =========================================================================

    let r8 = Regex.compile("(\\w+) (\\w+)").expect("r8 compile")
    assert(r8.replace("hello world", "$2 $1") == "world hello", "replace backrefs")

    // =========================================================================
    // 9. replace with $$ escape
    // =========================================================================

    let r9 = Regex.compile("x").expect("r9 compile")
    assert(r9.replace("x", "$$100") == "$100", "dollar escape")

    // =========================================================================
    // 10. split
    // =========================================================================

    let r10 = Regex.compile(",").expect("r10 compile")
    let mut parts10 = r10.split("a,b,,c")
    when parts10.next() in {
        .Some(p) then assert(p == "a", "split 0"),
        .None then assert(false, "split 0 missing"),
    }
    when parts10.next() in {
        .Some(p) then assert(p == "b", "split 1"),
        .None then assert(false, "split 1 missing"),
    }
    when parts10.next() in {
        .Some(p) then assert(p == "", "split 2 empty"),
        .None then assert(false, "split 2 missing"),
    }
    when parts10.next() in {
        .Some(p) then assert(p == "c", "split 3"),
        .None then assert(false, "split 3 missing"),
    }
    when parts10.next() in {
        .Some(_) then assert(false, "split count"),
        .None then assert(true, "split count"),
    }

    // =========================================================================
    // 11. RegexFlag.ignore_case()
    // =========================================================================

    let r11 = Regex.compile_with_flags("hello", RegexFlag.ignore_case()).expect("r11 compile")
    assert(r11.matches("HELLO") == true, "ignore case")

    // =========================================================================
    // 12. RegexFlag.multiline()
    // =========================================================================

    let r12 = Regex.compile_with_flags("^line", RegexFlag.multiline()).expect("r12 compile")
    assert(r12.matches("first\nline two") == true, "multiline")

    // =========================================================================
    // 13. Combined flags
    // =========================================================================

    let flags13 = RegexFlag.ignore_case().combine(RegexFlag.multiline())
    let r13 = Regex.compile_with_flags("^hello", flags13).expect("r13 compile")
    assert(r13.matches("first\nHELLO world") == true, "combined flags")

    // =========================================================================
    // 14. Empty pattern
    // =========================================================================

    let r14 = Regex.compile("").expect("r14 compile")
    assert(r14.matches("anything") == true, "empty pattern matches")
    assert(r14.matches("") == true, "empty pattern matches empty")

    // =========================================================================
    // 15. Zero-length match doesn't infinite loop
    // =========================================================================

    let r15 = Regex.compile("").expect("r15 compile")
    let mut count15 UInt = 0
    for m15 in r15.find_all("ab") then {
        count15 += 1
        if count15 > 10 then { break }
    }
    assert(count15 <= 10, "zero-length no infinite loop")

    // =========================================================================
    // 16. No match cases
    // =========================================================================

    let r16 = Regex.compile("xyz").expect("r16 compile")
    assert(r16.replace("hello", "X") == "hello", "replace no match")
    let mut parts16 = r16.split("hello")
    when parts16.next() in {
        .Some(p) then assert(p == "hello", "split no match value"),
        .None then assert(false, "split no match missing"),
    }
    when parts16.next() in {
        .Some(_) then assert(false, "split no match count"),
        .None then assert(true, "split no match count"),
    }

    // =========================================================================
    // 17. group_count consistency
    // =========================================================================

    let r17 = Regex.compile("(a)(b)(c)").expect("r17 compile")
    when r17.captures("abc") in {
        .Some(c) then {
            assert(c.group_count() == r17.group_count() + 1, "group count consistency")
        },
        .None then assert(false, "should capture"),
    }

    // =========================================================================
    // 18. group(0) equals text()
    // =========================================================================

    let r18 = Regex.compile("\\d+").expect("r18 compile")
    when r18.captures("abc123def") in {
        .Some(c) then {
            when c.group(0) in {
                .Some(g) then assert(g == c.text(), "group 0 == text"),
                .None then assert(false, "group 0 missing"),
            }
        },
        .None then assert(false, "should capture"),
    }

    println("All regex tests passed")
}
