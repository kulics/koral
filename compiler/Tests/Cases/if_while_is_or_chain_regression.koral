// EXPECT: if_or_chain: PASS
// EXPECT: while_or_chain: PASS
// EXPECT: or-is lowering regression: PASS

type Mode {
    Ref(),
    Ptr(),
    Val(),
    Other(),
}

type Matcher(mode Mode)

given Matcher {
    matches_storage(self) Bool = {
        if self.mode is .Ref() or self.mode is .Ptr() or self.mode is .Val() then {
            return true
        }
        return false
    }

    loop_once(self) Int = {
        let mut count = 0
        while count == 0 or self.mode is .Ref() or self.mode is .Ptr() then {
            count += 1
            if count >= 1 then {
                break
            }
        }
        return count
    }
}

let main() Int = {
    let storage = Matcher(.Ptr())
    let other = Matcher(.Other())

    if storage.matches_storage() then {
        println("if_or_chain: PASS")
    } else {
        println("if_or_chain: FAIL")
        return 1
    }

    if other.loop_once() == 1 then {
        println("while_or_chain: PASS")
    } else {
        println("while_or_chain: FAIL")
        return 1
    }

    println("or-is lowering regression: PASS")
    yield 0
}
