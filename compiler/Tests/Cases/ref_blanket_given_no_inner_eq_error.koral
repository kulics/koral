// Tests that T ref does NOT satisfy Eq when T does not implement Eq
// Feature: type-modifier-trait-conformance
// EXPECT-ERROR: does not satisfy trait

type NoEq(x Int)

let [T Eq] are_equal(a T, b T) Bool = a == b

let main() Void = {
    let mut a = NoEq(1)
    let mut b = NoEq(1)
    let ra = a.ref
    let rb = b.ref
    println(are_equal(ra, rb))
}
