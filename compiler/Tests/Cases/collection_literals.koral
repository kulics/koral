// EXPECT: collection literals ok

let sum3(values [Int]List) Int = values[0] + values[1] + values[2]

let mk_empty_map() [String, Int]Map = []

let main() Int = {
    let list = [1, 2, 3,]
    assert(list.count() == 3, "list count")
    assert(list[0] == 1 and list[2] == 3, "list values")
    assert(sum3([1, 2, 3]) == 6, "parameter context")
    let list_no_trailing = [4, 5, 6]
    assert(list_no_trailing.count() == 3, "list no trailing count")
    assert(list_no_trailing[0] == 4 and list_no_trailing[2] == 6, "list no trailing values")

    let s [Int]Set = [1, 2, 2, 3,]
    assert(s.count() == 3, "set dedup")
    assert(s.contains(1), "set has 1")
    let s_no_trailing [Int]Set = [7, 8, 7]
    assert(s_no_trailing.count() == 2, "set no trailing dedup")

    let m = ["a": 1, "b": 2, "a": 3,]
    assert(m.count() == 2, "map count")
    assert(m.get("a").unwrap() == 3, "map overwrite")
    assert(m.get("b").unwrap() == 2, "map value")
    let m_no_trailing = ["x": 10, "y": 20]
    assert(m_no_trailing.count() == 2, "map no trailing count")
    assert(m_no_trailing.get("x").unwrap() == 10 and m_no_trailing.get("y").unwrap() == 20, "map no trailing values")

    let empty_list [Int]List = []
    let empty_set [Int]Set = []
    let empty_map = mk_empty_map()
    assert(empty_list.count() == 0, "empty list")
    assert(empty_set.count() == 0, "empty set")
    assert(empty_map.count() == 0, "empty map")

    println("collection literals ok")
    yield 0
}
