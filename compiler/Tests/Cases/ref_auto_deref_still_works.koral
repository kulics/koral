// EXPECT-ERROR: Cannot assign to immutable variable: val

// Tests that auto-deref for method calls on T ref still works alongside blanket given
// Feature: type-modifier-trait-conformance

type Counter(val Int)

given Counter {
    public increment(self ref) Void = {
        self.val = self.val + 1
    }
    public get(self) Int = self.val
}

let main() Void = {
    let c = ref Counter(0)
    c.increment()
    c.increment()
    println(c.get())
}
