// Test semicolon-separated condition-clause chains for if/while.
// EXPECT: test_if_clause_chain_else: PASS
// EXPECT: test_if_clause_chain_pattern_binding: PASS
// EXPECT: test_if_clause_chain_all_true: PASS
// EXPECT: test_while_clause_chain_break_continue: PASS
// EXPECT: All condition clause chain tests passed!

type MyOption {
    None(),
    Some(value Int),
}

type MyIterator(mut current Int, max Int)

given MyIterator {
    next(self ref) MyOption = {
        yield if self.current < self.max then {
            let value = self.current
            self.current += 1
            yield MyOption.Some(value)
        } else {
            yield MyOption.None()
        }
    }
}

let wrap_positive(x Int) MyOption =
    if x > 0 then MyOption.Some(x * 2) else MyOption.None()

let test_if_clause_chain_else() Int =
    if true; false; true then 1 else 9

let test_if_clause_chain_pattern_binding() Int = {
    let opt = MyOption.Some(6)
    yield if opt is .Some(x); x > 5; wrap_positive(x) is .Some(y) then y else 0
}

let test_if_clause_chain_all_true() Int =
    if true; 3 < 4; 10 == 10 then 7 else 0

let test_while_clause_chain_break_continue() Int = {
    let mut iter = MyIterator(0, 6)
    let mut sum = 0

    while iter.next() is .Some(v); v < 5 then {
        if v == 1 then { continue }
        if v == 4 then { break }
        sum += v
    }

    yield sum
}

let main() Int = {
    if test_if_clause_chain_else() == 9 then {
        println("test_if_clause_chain_else: PASS")
    } else {
        println("test_if_clause_chain_else: FAIL")
        return 1
    }

    if test_if_clause_chain_pattern_binding() == 12 then {
        println("test_if_clause_chain_pattern_binding: PASS")
    } else {
        println("test_if_clause_chain_pattern_binding: FAIL")
        return 1
    }

    if test_if_clause_chain_all_true() == 7 then {
        println("test_if_clause_chain_all_true: PASS")
    } else {
        println("test_if_clause_chain_all_true: FAIL")
        return 1
    }

    if test_while_clause_chain_break_continue() == 5 then {
        println("test_while_clause_chain_break_continue: PASS")
    } else {
        println("test_while_clause_chain_break_continue: FAIL")
        return 1
    }

    println("All condition clause chain tests passed!")
    yield 0
}