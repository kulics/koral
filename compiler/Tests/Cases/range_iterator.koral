// EXPECT: All range iterator tests passed!

// Test Range iterator functionality

let main() = {
    // Test iterating over Closed
    let mut sum = 0
    for i in 1..5 then {
        sum = sum + i
    }
    assert(sum == 15, "Closed iteration: 1+2+3+4+5 should be 15")
    
    // Test iterating over ClosedOpen
    sum = 0
    for i in 1..<5 then {
        sum = sum + i
    }
    assert(sum == 10, "ClosedOpen iteration: 1+2+3+4 should be 10")
    
    // Test iterating over OpenClosed
    sum = 0
    for i in 0<..5 then {
        sum = sum + i
    }
    assert(sum == 15, "OpenClosed iteration: 1+2+3+4+5 should be 15")
    
    // Test iterating over Open
    sum = 0
    for i in 0<..<5 then {
        sum = sum + i
    }
    assert(sum == 10, "Open iteration: 1+2+3+4 should be 10")
    
    // Test empty range iteration
    sum = 0
    for i in 5..4 then {
        sum = sum + i
    }
    assert(sum == 0, "Empty range should not iterate")
    
    // Test single element range
    sum = 0
    for i in 5..5 then {
        sum = sum + i
    }
    assert(sum == 5, "Single element range should iterate once")
    
    println("All range iterator tests passed!")
}
