// EXPECT: alpha after initial push: 2
// EXPECT: beta after initial push: 2
// EXPECT: alpha after snapshot share: 2
// EXPECT: beta after snapshot share: 2
// EXPECT: alpha after cow detach: 3
// EXPECT: beta after cow detach: 3
// EXPECT: gamma after insert: 2
// EXPECT: delta after insert: 2
// EXPECT: alpha final count: 3
// EXPECT: beta final count: 3
// EXPECT: mylist_wrap_cow_push_rc_regression_ok

using Std.*

type Item(label String)

type MyList(mut items [Item ref]List)

given MyList {
    new() Self = MyList([Item ref]List.new())

    push(self ref, value Item ref) Void = self.items.push(value)

    count(self) UInt = self.items.count()

    at(self, index UInt) Item ref = self.items.at(index)
}

type Wrap(mut list MyList)

given Wrap {
    new() Self = Wrap(MyList.new())

    push(self ref, value Item ref) Void = self.list.push(value)

    count(self) UInt = self.list.count()

    at(self, index UInt) Item ref = self.list.at(index)
}

let push_burst(target Wrap ref, rounds UInt) Void = {
    let mut i UInt = 0
    while i < rounds then {
        target.push(box(Item("loop")))
        target.list.push(box(Item("mid")))
        target.list.items.push(box(Item("deep")))
        i += 1
    }
}

let main() Int = {
    let alpha = box(Item("alpha"))
    let beta = box(Item("beta"))
    let gamma = box(Item("gamma"))
    let delta = box(Item("delta"))

    let mut wrap = Wrap.new()
    wrap.push(alpha)
    wrap.list.push(beta)

    print("alpha after initial push: ")
    println(ref_count(alpha))
    print("beta after initial push: ")
    println(ref_count(beta))

    let snapshot = wrap

    print("alpha after snapshot share: ")
    println(ref_count(alpha))
    print("beta after snapshot share: ")
    println(ref_count(beta))

    wrap.list.items.push(gamma)
    wrap.push(delta)

    print("alpha after cow detach: ")
    println(ref_count(alpha))
    print("beta after cow detach: ")
    println(ref_count(beta))
    print("gamma after insert: ")
    println(ref_count(gamma))
    print("delta after insert: ")
    println(ref_count(delta))

    push_burst(wrap.ref, 8)

    print("alpha final count: ")
    println(ref_count(alpha))
    print("beta final count: ")
    println(ref_count(beta))

    assert(snapshot.count() == 2, "snapshot count")
    assert(snapshot.at(0).label == "alpha", "snapshot first")
    assert(snapshot.at(1).label == "beta", "snapshot second")

    assert(wrap.count() == 28, "wrap count")
    assert(wrap.at(0).label == "alpha", "wrap first")
    assert(wrap.at(1).label == "beta", "wrap second")
    assert(wrap.at(2).label == "gamma", "wrap third")
    assert(wrap.at(3).label == "delta", "wrap fourth")
    assert(wrap.at(4).label == "loop", "wrap fifth")
    assert(wrap.at(5).label == "mid", "wrap sixth")
    assert(wrap.at(6).label == "deep", "wrap seventh")
    assert(wrap.at(27).label == "deep", "wrap last")

    println("mylist_wrap_cow_push_rc_regression_ok")
    yield 0
}