// EXPECT: alias store true: 41
// EXPECT: alias store false: 73
// EXPECT: alias local read: 8

public type IntStore(
    mut items [Int ref]List,
)

given IntStore {
    public new() IntStore = IntStore([Int ref]List.new())

    public remember(self mut ref, value Int ref) Void = {
        self.items.push(value)
    }

    public first(self) Int = {
        yield self.items[0].val
    }
}

let build_store(flag Bool) IntStore = {
    let mut first = 41
    let mut second = 73
    let alias0 = if flag then first.ref else second.ref
    let alias1 = {
        let alias2 = alias0
        yield alias2
    }
    let mut store = IntStore.new()
    store.remember(alias1)
    yield store
}

let local_alias_read() Int = {
    let mut first = 5
    let mut second = 8
    let alias0 = second.ref
    let alias1 = {
        let alias2 = alias0
        yield alias2
    }
    yield alias1.val
}

let main() Void = {
    let store_true = build_store(true)
    println("alias store true: " + store_true.first().to_string())

    let store_false = build_store(false)
    println("alias store false: " + store_false.first().to_string())

    println("alias local read: " + local_alias_read().to_string())
}
