// EXPECT: All Deque tests passed

using std.container.*

let main() Void = {
    let mut d = [Int]Deque.new()
    assert(d.is_empty(), "new deque is empty")

    d.push_back(2)
    d.push_back(3)
    d.push_front(1)

    assert(d.count() == 3, "count after pushes")
    assert(d.first().unwrap() == 1, "first value")
    assert(d.last().unwrap() == 3, "last value")
    assert(d.get(1).unwrap() == 2, "get middle")

    d[1] = 20
    assert(d[1] == 20, "subscript set/read")

    let p1 = d.pop_front()
    assert(p1.unwrap() == 1, "pop_front")
    let p2 = d.pop_back()
    assert(p2.unwrap() == 3, "pop_back")
    assert(d.count() == 1 and d.first().unwrap() == 20, "remaining value")

    let mut sum = 0
    for v in d then {
        sum = sum + v
    }
    assert(sum == 20, "iterator sum")

    let mut original = [Int]Deque.new()
    original.push_back(10)
    original.push_back(20)

    let mut copy = original
    copy.push_front(5)
    copy[1] = 99

    assert(original.count() == 2, "original count unchanged")
    assert(original[0] == 10 and original[1] == 20, "original values unchanged")
    assert(copy.count() == 3, "copy count")
    assert(copy[0] == 5 and copy[1] == 99 and copy[2] == 20, "copy modified")

    copy.clear()
    assert(copy.is_empty(), "clear works")
    assert(copy.pop_front().is_none(), "pop_front empty")
    assert(copy.pop_back().is_none(), "pop_back empty")

    // === reverse ===
    let mut dr = [Int]Deque.new()
    dr.push_back(1)
    dr.push_back(2)
    dr.push_back(3)
    dr.reverse()
    assert(dr[0] == 3 and dr[1] == 2 and dr[2] == 1, "reverse values")
    assert(dr.count() == 3, "reverse count unchanged")

    let mut dr_single = [Int]Deque.new()
    dr_single.push_back(42)
    dr_single.reverse()
    assert(dr_single[0] == 42, "reverse single element")

    let mut dr_empty = [Int]Deque.new()
    dr_empty.reverse()
    assert(dr_empty.is_empty(), "reverse empty")

    // reverse after push_front to exercise ring buffer physical layout
    let mut dr_ring = [Int]Deque.new()
    dr_ring.push_back(2)
    dr_ring.push_back(3)
    dr_ring.push_front(1)
    dr_ring.reverse()
    assert(dr_ring[0] == 3 and dr_ring[1] == 2 and dr_ring[2] == 1, "reverse ring buffer")

    // === contains ===
    let mut dc = [Int]Deque.new()
    dc.push_back(10)
    dc.push_back(20)
    dc.push_back(30)
    assert(dc.contains(20), "contains found")
    assert(not dc.contains(99), "contains not found")

    // === retain ===
    let mut dret = [Int]Deque.new()
    dret.push_back(1)
    dret.push_back(2)
    dret.push_back(3)
    dret.push_back(4)
    dret.push_back(5)
    dret.retain((x) -> x % 2 == 0)
    assert(dret.count() == 2, "retain count")
    assert(dret[0] == 2 and dret[1] == 4, "retain values")

    let mut dret_none = [Int]Deque.new()
    dret_none.push_back(1)
    dret_none.push_back(2)
    dret_none.retain((x) -> false)
    assert(dret_none.is_empty(), "retain none")

    // === dedup ===
    let mut dd = [Int]Deque.new()
    dd.push_back(1)
    dd.push_back(1)
    dd.push_back(2)
    dd.push_back(3)
    dd.push_back(3)
    dd.push_back(2)
    dd.dedup()
    assert(dd.count() == 4, "dedup count")
    assert(dd[0] == 1 and dd[1] == 2 and dd[2] == 3 and dd[3] == 2, "dedup values")

    // dedup single element
    let mut dd_single = [Int]Deque.new()
    dd_single.push_back(7)
    dd_single.dedup()
    assert(dd_single.count() == 1 and dd_single[0] == 7, "dedup single")

    // === binary_search ===
    let mut bs = [Int]Deque.new()
    bs.push_back(1)
    bs.push_back(3)
    bs.push_back(5)
    bs.push_back(7)
    bs.push_back(9)

    let r_found = bs.binary_search(5)
    assert(r_found.second, "binary_search found")
    assert(r_found.first == 2, "binary_search found index")

    let r_miss = bs.binary_search(4)
    assert(not r_miss.second, "binary_search not found")
    assert(r_miss.first == 2, "binary_search insertion point")

    let r_before = bs.binary_search(0)
    assert(not r_before.second, "binary_search before all")
    assert(r_before.first == 0, "binary_search insertion point 0")

    let r_after = bs.binary_search(10)
    assert(not r_after.second, "binary_search after all")
    assert(r_after.first == 5, "binary_search insertion point end")

    // binary_search with push_front to exercise ring buffer layout
    let mut bs_ring = [Int]Deque.new()
    bs_ring.push_back(3)
    bs_ring.push_back(5)
    bs_ring.push_back(7)
    bs_ring.push_front(1)
    let rr = bs_ring.binary_search(5)
    assert(rr.second, "binary_search ring found")
    assert(rr.first == 2, "binary_search ring index")

    // === binary_search_by ===
    let mut bsb = [Int]Deque.new()
    bsb.push_back(10)
    bsb.push_back(30)
    bsb.push_back(50)
    bsb.push_back(70)
    bsb.push_back(90)

    // search by value / 10: keys are [1, 3, 5, 7, 9]
    let rb_found = bsb.binary_search_by((x) -> x / 10, 5)
    assert(rb_found.second, "binary_search_by found")
    assert(rb_found.first == 2, "binary_search_by found index")

    let rb_miss = bsb.binary_search_by((x) -> x / 10, 4)
    assert(not rb_miss.second, "binary_search_by not found")
    assert(rb_miss.first == 2, "binary_search_by insertion point")

    println("All Deque tests passed")
}
