// Test Result methods: map, unwrap_or
// EXPECT: map Ok: 84
// EXPECT: map Error: original error
// EXPECT: unwrap_or Ok: 42
// EXPECT: unwrap_or Error: 99

let print_res(label String, r [Int]Result) Void = {
    print(label)
    when r in {
        .Ok(v) then println(v.to_string()),
        .Error(e) then println(e.message()),
    }
}

let main() Int = {
    let ok = [Int]Result.Ok(42)
    let err = [Int]Result.Error(box("original error"))

    // map
    print_res("map Ok: ",    ok.[Int]map((x) -> x * 2))
    print_res("map Error: ", err.[Int]map((x) -> x * 2))

    // unwrap_or
    println("unwrap_or Ok: "    + ok.unwrap_or(99).to_string())
    println("unwrap_or Error: " + err.unwrap_or(99).to_string())

    yield 0
}
