// EXPECT-ERROR: Cannot take 'ref' of immutable value: x

// This test verifies that passing an immutable variable to a function
// expecting T ref produces an error. Only 'let mut' variables can be
// implicitly converted to ref.

type Counter(mut value Int)

let increment(c Counter ref) Void = {
    c.value += 1
}

let main() Int = {
    let x = Counter(0)
    increment(x)
    yield 0
}
