// EXPECT: before overwrite
// EXPECT: Drop Tracker
// EXPECT: 1
// EXPECT: after overwrite
// EXPECT: Drop Tracker
// EXPECT: 2

type Tracker(id Int)

given Tracker {
    __drop(self ref) Void = {
        println("Drop Tracker")
        println(self.id)
    }
}

let main() Int = {
    let mut x = Tracker(1)
    let r = ref x

    println("before overwrite")
    deref r = Tracker(2)
    println("after overwrite")

    yield 0
}
