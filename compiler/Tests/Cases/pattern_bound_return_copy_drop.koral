// EXPECT: Drop 7
// EXPECT: result some 7
// EXPECT: Drop 7
// EXPECT: result none 0
// EXPECT: Drop 0

type Tracker(id Int)

type MaybeTracker {
    Some(value Tracker),
    None(),
}

given Tracker Drop {
    drop(self ref) = {
        println("Drop \(self.id)")
    }
}

let unwrap(opt MaybeTracker) Tracker = when opt in {
    .Some(value) then value,
    .None then Tracker(0),
}

let run_some() Void = {
    let result = unwrap(MaybeTracker.Some(Tracker(7)))
    println("result some \(result.id)")
}

let run_none() Void = {
    let result = unwrap(MaybeTracker.None())
    println("result none \(result.id)")
}

let main() Int = {
    run_some()
    run_none()
    yield 0
}