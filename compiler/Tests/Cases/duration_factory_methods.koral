// EXPECT: nanos_ok
// EXPECT: micros_ok
// EXPECT: millis_ok
// EXPECT: secs_ok
// EXPECT: mins_ok
// EXPECT: hours_ok
// EXPECT: nanos_normalized
// EXPECT: roundtrip_nanos
// EXPECT: roundtrip_micros
// EXPECT: roundtrip_millis
// EXPECT: roundtrip_secs
// EXPECT: roundtrip_mins
// EXPECT: roundtrip_hours

let main() Int = {
    // Test from_nanoseconds: 1_500_000_000 ns = 1s 500_000_000ns
    let d1 = 1_500_000_000ns
    assert(d1.as_seconds() == (Int64)1, "nanos secs")
    assert(d1.as_nanoseconds() == (Int64)1_500_000_000, "nanos total")
    println("nanos_ok")

    // Test from_microseconds: 2_500_000 us = 2s 500_000_000ns
    let d2 = 2_500_000us
    assert(d2.as_seconds() == (Int64)2, "micros secs")
    assert(d2.as_nanoseconds() == (Int64)2_500_000_000, "micros total")
    println("micros_ok")

    // Test from_milliseconds: 3_500 ms = 3s 500_000_000ns
    let d3 = 3_500ms
    assert(d3.as_seconds() == (Int64)3, "millis secs")
    assert(d3.as_nanoseconds() == (Int64)3_500_000_000, "millis total")
    println("millis_ok")

    // Test from_seconds
    let d4 = 42s
    assert(d4.as_seconds() == (Int64)42, "secs secs")
    assert(d4.as_nanoseconds() == (Int64)42_000_000_000, "secs nanos")
    println("secs_ok")

    // Test from_minutes: 5 min = 300s
    let d5 = 5min
    assert(d5.as_seconds() == (Int64)300, "mins secs")
    assert(d5.as_nanoseconds() == (Int64)300_000_000_000, "mins nanos")
    println("mins_ok")

    // Test from_hours: 2 h = 7200s
    let d6 = 2h
    assert(d6.as_seconds() == (Int64)7200, "hours secs")
    assert(d6.as_nanoseconds() == (Int64)7_200_000_000_000, "hours nanos")
    println("hours_ok")

    // Property 2: Normalization invariant - nanos always in [0, 1_000_000_000)
    let d7 = Duration.from_secs_and_nanos((Int64)1, (Int64)1_500_000_000).unwrap()
    assert(d7.as_nanoseconds() == (Int64)2_500_000_000, "norm total")
    let d8 = Duration.from_secs_and_nanos((Int64)0, (Int64)-1)
    assert(d8.is_error(), "norm negative nanos error")
    println("nanos_normalized")

    // Property 1: Round-trip consistency
    assert(500_000_000ns.as_nanoseconds() == (Int64)500_000_000, "rt nanos")
    println("roundtrip_nanos")

    assert(1_500us.as_microseconds() == (Int64)1_500, "rt micros")
    println("roundtrip_micros")

    assert(500ms.as_milliseconds() == (Int64)500, "rt millis")
    println("roundtrip_millis")

    assert(60s.as_seconds() == (Int64)60, "rt secs")
    println("roundtrip_secs")

    assert(30min.as_minutes() == (Int64)30, "rt mins")
    println("roundtrip_mins")

    assert(24h.as_hours() == (Int64)24, "rt hours")
    println("roundtrip_hours")

    yield 0
}
