// EXPECT-EXACT: result 9
// EXPECT-EXACT: Drop 9

type Tracker(id Int)

given Tracker Drop {
    drop(self mut ref) = {
        println("Drop \(self.id)")
    }
}

let identity(x Tracker) Tracker = x

let main() Int = {
    let result = identity(Tracker(9))
    println("result \(result.id)")
    yield 0
}
