// Test .val on trait object compile error
// EXPECT-ERROR: Cannot use .val on a trait object reference

trait Greet {
    greet(self) String
}

type Greeter(name String)

given Greeter Greet {
    public greet(self) String = "hello"
}

let main() Int = {
    let g1 = box(Greeter("test"))
    let g Greet ref = g1
    let v = g.val
    yield 0
}
