// EXPECT: utc_format_ok
// EXPECT: fixed_format_ok
// EXPECT: nanos_format_ok
// EXPECT: parse_roundtrip_ok
// EXPECT: parse_invalid_ok
// EXPECT: parse_empty_ok

using Std.Time.*

let main() Int = {
    // UTC format ends with Z
    let epoch = DateTime.epoch()
    let s1 = epoch.to_string()
    // 1970-01-01T00:00:00Z
    assert(s1 == "1970-01-01T00:00:00Z", "utc format")
    println("utc_format_ok")

    // Fixed offset format
    let r1 = TimeZone.from_offset(28800s)
    if r1 is .Ok(tz) then {
        // 1970-01-01T00:00:00Z in +08:00 = 1970-01-01T08:00:00+08:00
        let dt = epoch.in_timezone(tz)
        let s = dt.to_string()
        assert(s == "1970-01-01T08:00:00+08:00", "fixed format")
    } else {
        assert(false, "tz err")
    }
    println("fixed_format_ok")

    // Nanos format: trailing zeros trimmed
    let rd2 = Date.new(2024, 1, 15)
    let rt2 = ClockTime.new_with_nanos(10, 30, 0, 123_000_000)
    if rd2 is .Ok(d) then {
        if rt2 is .Ok(t) then {
            let dt = DateTime.from_parts(d, t, TimeZone.utc())
            let s = dt.to_string()
            assert(s == "2024-01-15T10:30:00.123Z", "nanos format")
        } else {
            assert(false, "time nanos err")
        }
    } else {
        assert(false, "date nanos err")
    }
    println("nanos_format_ok")

    // parse roundtrip: parse(dt.to_string()) preserves unix_seconds
    let rd3 = Date.new(2024, 6, 15)
    let rt3 = ClockTime.new(14, 30, 45)
    if rd3 is .Ok(d) then {
        if rt3 is .Ok(t) then {
            let dt = DateTime.from_parts(d, t, TimeZone.utc())
            let iso = dt.to_string()
            let parsed = DateTime.parse(iso)
            if parsed is .Ok(dt2) then {
                assert(dt2.to_unix_seconds() == dt.to_unix_seconds(), "parse rt secs")
            } else {
                assert(false, "parse should be Ok")
            }
        } else {
            assert(false, "time rt err")
        }
    } else {
        assert(false, "date rt err")
    }
    println("parse_roundtrip_ok")

    // parse invalid string - should return Error
    let r4 = DateTime.parse("not-a-date")
    assert(r4.is_error(), "invalid should be Error")
    println("parse_invalid_ok")

    // parse empty string - should return Error
    let r5 = DateTime.parse("")
    assert(r5.is_error(), "empty should be Error")
    println("parse_empty_ok")

    yield 0
}
