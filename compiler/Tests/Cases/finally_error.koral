// Test finally error diagnostics
// Tests that the compiler correctly rejects return inside finally expression
// Also verifies that Lambda inside finally can contain control flow/finally (independent scope)
// EXPECT-ERROR: control flow statement 'return' is not allowed in finally expression

// Valid: Lambda inside finally can contain return and finally
// Lambda creates an independent scope, so insideDefer is reset
let valid_lambda_in_defer() Int = {
    finally {
        let f [Int]Func = () -> {
            finally println("lambda finally ok")
            return 1
        }
        f()
    }
    yield 0
}

// Error: return directly inside finally is not allowed
let error_return_in_defer() Int = {
    finally {
        return
    }
    yield 0
}

public let main() Int = {
    yield 0
}
