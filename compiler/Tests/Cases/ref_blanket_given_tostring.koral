// Tests that T ref satisfies ToString when T implements ToString (blanket given)
// Feature: type-modifier-trait-conformance

type Wrapper(val Int)

given Wrapper ToString {
    public to_string(self) String = "Wrapper(" + self.val.to_string() + ")"
}

let [T ToString] print_it(x T) Void = println(x.to_string())

let main() Void = {
    let mut w = Wrapper(42)
    let r = ref w
    print_it(r)
}
// EXPECT: Wrapper(42)
