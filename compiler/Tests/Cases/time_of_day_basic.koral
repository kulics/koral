// EXPECT: midnight_ok
// EXPECT: new_ok
// EXPECT: new_with_nanos_ok
// EXPECT: invalid_ok
// EXPECT: fields_ok
// EXPECT: add_vector_ok
// EXPECT: sub_vector_ok
// EXPECT: wrap_around_ok
// EXPECT: sub_point_ok
// EXPECT: eq_ord_ok
// EXPECT: to_string_ok
// EXPECT: parse_ok
// EXPECT: parse_invalid_ok

using Std.Time.*

let main() Int = {
    // midnight
    let m = ClockTime.midnight()
    assert(m.hour() == 0, "midnight hour")
    assert(m.minute() == 0, "midnight min")
    assert(m.second() == 0, "midnight sec")
    assert(m.nanosecond() == 0, "midnight nanos")
    println("midnight_ok")

    // new
    let r1 = ClockTime.new(10, 30, 45)
    if r1 is .Ok(t) then {
        assert(t.hour() == 10, "hour")
        assert(t.minute() == 30, "min")
        assert(t.second() == 45, "sec")
        assert(t.nanosecond() == 0, "nanos zero")
    } else {
        assert(false, "new should be Ok")
    }
    println("new_ok")

    // new_with_nanos
    let r2 = ClockTime.new_with_nanos(10, 30, 45, 123_456_789)
    if r2 is .Ok(t) then {
        assert(t.hour() == 10, "hour nanos")
        assert(t.minute() == 30, "min nanos")
        assert(t.second() == 45, "sec nanos")
        assert(t.nanosecond() == 123_456_789, "nanos")
    } else {
        assert(false, "new_with_nanos should be Ok")
    }
    println("new_with_nanos_ok")

    // invalid
    assert(ClockTime.new(24, 0, 0).is_error(), "hour 24")
    assert(ClockTime.new(-1, 0, 0).is_error(), "hour -1")
    assert(ClockTime.new(0, 60, 0).is_error(), "min 60")
    assert(ClockTime.new(0, 0, 60).is_error(), "sec 60")
    assert(ClockTime.new_with_nanos(0, 0, 0, 1_000_000_000).is_error(), "nanos overflow")
    println("invalid_ok")

    // fields
    let t = ClockTime.new(14, 5, 9).unwrap()
    assert(t.hour() == 14, "hour 14")
    assert(t.minute() == 5, "min 5")
    assert(t.second() == 9, "sec 9")
    println("fields_ok")

    // add_vector
    let t1 = ClockTime.new(10, 0, 0).unwrap()
    let t2 = t1 + 3600s
    assert(t2.hour() == 11, "add 1h")
    assert(t2.minute() == 0, "add 1h min")
    println("add_vector_ok")

    // sub_vector
    let t3 = t1 - 1800s
    assert(t3.hour() == 9, "sub 30min hour")
    assert(t3.minute() == 30, "sub 30min min")
    println("sub_vector_ok")

    // wrap around: 23:00 + 2h = 01:00
    let t4 = ClockTime.new(23, 0, 0).unwrap()
    let t5 = t4 + 2h
    assert(t5.hour() == 1, "wrap hour")
    assert(t5.minute() == 0, "wrap min")
    // 00:30 - 1h = 23:30
    let t6 = ClockTime.new(0, 30, 0).unwrap()
    let t7 = t6 - 1h
    assert(t7.hour() == 23, "wrap back hour")
    assert(t7.minute() == 30, "wrap back min")
    println("wrap_around_ok")

    // sub_point: duration from other to self (forward)
    let ta = ClockTime.new(10, 0, 0).unwrap()
    let tb = ClockTime.new(12, 0, 0).unwrap()
    let diff = tb - ta
    assert(diff.as_seconds() == (Int64)7200, "sub_point 2h")
    println("sub_point_ok")

    // eq and ord
    let x = ClockTime.new(10, 30, 0).unwrap()
    let y = ClockTime.new(10, 30, 0).unwrap()
    let z = ClockTime.new(11, 0, 0).unwrap()
    assert(x.equals(y), "eq")
    assert(x.compare(z) == -1, "lt")
    assert(z.compare(x) == 1, "gt")
    println("eq_ord_ok")

    // to_string
    let ts1 = ClockTime.new(10, 30, 45).unwrap()
    assert(ts1.to_string() == "10:30:45", "to_string basic")
    let ts2 = ClockTime.new_with_nanos(10, 30, 45, 123_000_000).unwrap()
    assert(ts2.to_string() == "10:30:45.123", "to_string nanos")
    println("to_string_ok")

    // parse
    let p1 = ClockTime.parse("10:30:45")
    if p1 is .Ok(pt) then {
        assert(pt.equals(ts1), "parse basic")
    } else {
        assert(false, "parse basic should be Ok")
    }
    let p2 = ClockTime.parse("10:30:45.123")
    if p2 is .Ok(pt) then {
        assert(pt.equals(ts2), "parse nanos")
    } else {
        assert(false, "parse nanos should be Ok")
    }
    println("parse_ok")

    // parse invalid
    assert(ClockTime.parse("not-a-time").is_error(), "invalid")
    assert(ClockTime.parse("24:00:00").is_error(), "hour 24")
    assert(ClockTime.parse("10:60:00").is_error(), "min 60")
    println("parse_invalid_ok")

    yield 0
}
