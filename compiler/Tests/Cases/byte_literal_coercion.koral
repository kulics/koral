// EXPECT: 65
// EXPECT: 66
// EXPECT: 10
// EXPECT: 67
// EXPECT: true
// EXPECT: true
// EXPECT: true
// EXPECT: false
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1
// EXPECT: 1

type ByteIter(mut current UInt8, end UInt8)

given ByteIter {
    next(self ref) [UInt8]Option = {
        yield if self.current < self.end then {
            let v = self.current
            self.current = self.current + (UInt8)1
            yield .Some(v)
        } else {
            yield .None()
        }
    }
}

let id_u8(x UInt8) UInt8 = x

let test_if_pattern_byte() Int = {
    let b UInt8 = 'A'
    yield if b is 'A' then 1 else 0
}

let test_while_pattern_byte() Int = {
    let mut iter = ByteIter('A', 'D')
    let mut hits = 0
    while iter.next() is .Some(v) then {
        if v is 'B' then {
            hits = hits + 1
        }
    }
    yield hits
}

let main() Int = {
    let a UInt8 = 'A'
    let b UInt8 = 'B'
    let nl UInt8 = '\n'

    println(a)
    println(b)
    println(nl)

    let c = id_u8('C')
    println(c)

    println(a == 'A')
    println('B' == b)
    println(a <> b)
    println(a <> 'A')

    when a in {
        'A' then println(1),
        _ then println(0),
    }

    when b in {
        'C' then println(0),
        'B' then println(1),
        _ then println(2),
    }

    println(test_if_pattern_byte())
    println(test_while_pattern_byte())

    yield 0
}
