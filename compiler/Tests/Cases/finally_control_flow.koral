// Test finally with control flow: return, break, continue

// Test 1: finally executes before early return
// EXPECT: test_defer_return:
// EXPECT: before return
// EXPECT: finally A
// EXPECT: returned early

// Test 2: finally executes only those declared before return
// EXPECT: test_defer_partial_return:
// EXPECT: start
// EXPECT: finally B
// EXPECT: finally A
// EXPECT: got early

// Test 3: finally executes when break exits a while loop
// EXPECT: test_defer_break_while:
// EXPECT: i=1
// EXPECT: finally cleanup 1
// EXPECT: i=2
// EXPECT: finally cleanup 2
// EXPECT: i=3
// EXPECT: finally cleanup 3
// EXPECT: after loop

// Test 4: finally executes on continue iterations in a while loop
// EXPECT: test_defer_continue_while:
// EXPECT: i=1 process
// EXPECT: finally iter 1
// EXPECT: i=2 skip
// EXPECT: finally iter 2
// EXPECT: i=3 process
// EXPECT: finally iter 3
// EXPECT: after loop

// Test 5: finally with break in a for loop
// EXPECT: test_defer_break_for:
// EXPECT: item=10
// EXPECT: finally for 10
// EXPECT: item=20
// EXPECT: finally for 20
// EXPECT: done

// Test 6: finally with continue in a for loop
// EXPECT: test_defer_continue_for:
// EXPECT: process 10
// EXPECT: finally for 10
// EXPECT: skip 20
// EXPECT: finally for 20
// EXPECT: process 30
// EXPECT: finally for 30
// EXPECT: done

let test_defer_return() Int = {
    println("test_defer_return:")
    println("before return")
    finally println("finally A")
    return 1
}

let test_defer_partial_return(x Int) Int = {
    println("start")
    finally println("finally A")
    if x > 0 then {
        finally println("finally B")
        return 42
    }
    yield 0
}

let test_defer_break_while() Void = {
    println("test_defer_break_while:")
    let mut i = 0
    while i < 10 then {
        i = i + 1
        finally {
            print("finally cleanup ")
            println(i)
        }
        print("i=")
        println(i)
        if i == 3 then {
            break
        }
    }
    println("after loop")
}

let test_defer_continue_while() Void = {
    println("test_defer_continue_while:")
    let mut i = 0
    while i < 3 then {
        i = i + 1
        finally {
            print("finally iter ")
            println(i)
        }
        if i == 2 then {
            print("i=")
            print(i)
            println(" skip")
            continue
        }
        print("i=")
        print(i)
        println(" process")
    }
    println("after loop")
}

let test_defer_break_for() Void = {
    println("test_defer_break_for:")
    let mut list = [Int]List.new()
    list.push(10)
    list.push(20)
    list.push(30)

    for x in list then {
        finally {
            print("finally for ")
            println(x)
        }
        print("item=")
        println(x)
        if x == 20 then {
            break
        }
    }
    println("done")
}

let test_defer_continue_for() Void = {
    println("test_defer_continue_for:")
    let mut list = [Int]List.new()
    list.push(10)
    list.push(20)
    list.push(30)

    for x in list then {
        finally {
            print("finally for ")
            println(x)
        }
        if x == 20 then {
            print("skip ")
            println(x)
            continue
        }
        print("process ")
        println(x)
    }
    println("done")
}

public let main() Int = {
    let r = test_defer_return()
    println("returned early")

    println("test_defer_partial_return:")
    let r2 = test_defer_partial_return(5)
    print("got ")
    println("early")

    test_defer_break_while()
    test_defer_continue_while()
    test_defer_break_for()
    test_defer_continue_for()
    yield 0
}
