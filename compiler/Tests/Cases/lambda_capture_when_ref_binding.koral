// Lambda captures pattern binding from when expression on ref-type subject.
// This tests that codegen correctly captures variables bound by when destructuring
// when the subject is accessed through a ref (deref pointer pattern).
// EXPECT: then_value=hello
// EXPECT: else_value=world
// EXPECT: enum_value=hello
// EXPECT: nested_capture=hello:world
// EXPECT: ref_field_via_lambda=pushed
// EXPECT: when_return=matched_a

type Expr {
    Literal(value String),
    Binary(left Expr ref, right Expr ref),
}

// Test 1: Lambda captures when-destructured binding from ref subject (enum)
let test_when_ref_capture() Void = {
    let expr = box(Expr.Literal("hello"))
    let expr_ref Expr ref = expr

    let result = when expr_ref in {
        .Literal(value) then {
            let f [String]Func = () -> value
            yield f()
        },
        .Binary(_, _) then "binary",
    }
    println("enum_value=\(result)")
}

// Test 2: Lambda captures when-destructured binding inside if branch
type IfNode(
    condition String,
    then_branch String,
    else_branch String,
)

let test_if_ref_capture() Void = {
    let node = box(IfNode("cond", "hello", "world"))
    let node_ref IfNode ref = node

    // Capture then_branch through a lambda
    let then_fn [String]Func = () -> node_ref.then_branch
    println("then_value=\(then_fn())")

    // Capture else_branch through a lambda
    let else_fn [String]Func = () -> node_ref.else_branch
    println("else_value=\(else_fn())")
}

// Test 3: Nested lambda captures from when on ref
let test_nested_capture() Void = {
    let expr = box(Expr.Binary(
        box(Expr.Literal("hello")),
        box(Expr.Literal("world")),
    ))
    let expr_ref Expr ref = expr

    let result = when expr_ref in {
        .Binary(left, right) then {
            let left_val = when left in {
                .Literal(v) then v,
                _ then "?",
            }
            let right_val = when right in {
                .Literal(v) then v,
                _ then "?",
            }
            let f [String]Func = () -> "\(left_val):\(right_val)"
            yield f()
        },
        _ then "other",
    }
    println("nested_capture=\(result)")
}

// Test 4: Lambda captures ref variable and accesses its field (build_ref_components path)
// This tests that codegen uses captured_var_aliases when building ref component paths
// inside lambda closures, not just for direct variable references.
type Container(mut items [String]List)

let test_ref_field_access_in_lambda() Void = {
    let mut c = Container([String]List.new())
    let c_ref Container ref = c.ref
    let push_fn [Void]Func = () -> {
        c_ref.items.push("pushed")
    }
    push_fn()
    println("ref_field_via_lambda=\(c.items.at(0))")
}

// Test 5: when expression result variable in return statement
// Tests that the when result variable is declared in the correct scope
// when used directly in a return expression.
type Tag {
    A(),
    B(value Int),
    C(),
}

let classify_tag(tag Tag) String = {
    return when tag in {
        .A() then "matched_a",
        .B(v) then "matched_b_\(v)",
        .C() then "matched_c",
    }
}

let test_when_return() Void = {
    let result = classify_tag(Tag.A())
    println("when_return=\(result)")
}

let main() Int = {
    test_if_ref_capture()
    test_when_ref_capture()
    test_nested_capture()
    test_ref_field_access_in_lambda()
    test_when_return()
    return 0
}
