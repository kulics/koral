// Test Option methods: map, unwrap_or_else, and_then, or_else, filter
// EXPECT: map Some: 84
// EXPECT: map None: None
// EXPECT: unwrap_or_else Some: 42
// EXPECT: unwrap_or_else None: 99
// EXPECT: and_then Some-Some: 5
// EXPECT: and_then Some-None: None
// EXPECT: and_then None: None
// EXPECT: or_else Some: 42
// EXPECT: or_else None: 7
// EXPECT: filter pass: 42
// EXPECT: filter fail: None
// EXPECT: filter None: None

let safe_div(x Int, y Int) [Int]Option = {
    if y == 0 then { return [Int]Option.None() }
    return [Int]Option.Some(x / y)
}

let print_opt(label String, opt [Int]Option) Void = {
    print(label)
    when opt in {
        .Some(v) then println(v.to_string()),
        .None then println("None"),
    }
}

let main() Int = {
    // map
    let opt = [Int]Option.Some(42)
    let none = [Int]Option.None()
    print_opt("map Some: ", opt.[Int]map((x) -> x * 2))
    print_opt("map None: ", none.[Int]map((x) -> x * 2))

    // unwrap_or_else
    println("unwrap_or_else Some: " + opt.unwrap_or_else(() -> 99).to_string())
    println("unwrap_or_else None: " + none.unwrap_or_else(() -> 99).to_string())

    // and_then
    print_opt("and_then Some-Some: ", opt.[Int]and_then((x) -> safe_div(x, 8)))
    print_opt("and_then Some-None: ", opt.[Int]and_then((x) -> safe_div(x, 0)))
    print_opt("and_then None: ",      none.[Int]and_then((x) -> safe_div(x, 8)))

    // or_else
    print_opt("or_else Some: ", opt.or_else(() -> [Int]Option.Some(7)))
    print_opt("or_else None: ", none.or_else(() -> [Int]Option.Some(7)))

    // filter
    print_opt("filter pass: ", opt.filter((x) -> x > 10))
    print_opt("filter fail: ", opt.filter((x) -> x > 100))
    print_opt("filter None: ", none.filter((x) -> x > 10))

    yield 0
}
