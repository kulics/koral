// EXPECT: epoch_ok
// EXPECT: new_ok
// EXPECT: invalid_month_ok
// EXPECT: invalid_day_ok
// EXPECT: leap_ok
// EXPECT: fields_ok
// EXPECT: weekday_ok
// EXPECT: day_of_year_ok
// EXPECT: is_leap_year_ok
// EXPECT: days_in_month_ok
// EXPECT: add_days_ok
// EXPECT: days_until_ok
// EXPECT: add_months_ok
// EXPECT: add_years_ok
// EXPECT: eq_ord_ok
// EXPECT: to_string_ok
// EXPECT: parse_ok
// EXPECT: parse_invalid_ok

using Std.Time.*

let main() Int = {
    // epoch
    let e = Date.epoch()
    assert(e.year() == 1970, "epoch year")
    assert(e.month() == 1, "epoch month")
    assert(e.day() == 1, "epoch day")
    println("epoch_ok")

    // new valid
    let r1 = Date.new(2024, 6, 15)
    if r1 is .Ok(d) then {
        assert(d.year() == 2024, "year")
        assert(d.month() == 6, "month")
        assert(d.day() == 15, "day")
    } else {
        assert(false, "new should be Ok")
    }
    println("new_ok")

    // invalid month
    let r2 = Date.new(2024, 0, 1)
    assert(r2.is_error(), "month 0")
    let r3 = Date.new(2024, 13, 1)
    assert(r3.is_error(), "month 13")
    println("invalid_month_ok")

    // invalid day
    let r4 = Date.new(2024, 2, 30)
    assert(r4.is_error(), "feb 30")
    let r5 = Date.new(2024, 4, 31)
    assert(r5.is_error(), "apr 31")
    println("invalid_day_ok")

    // leap year: 2024-02-29 valid, 2023-02-29 invalid
    let r6 = Date.new(2024, 2, 29)
    assert(r6.is_ok(), "leap 2024")
    let r7 = Date.new(2023, 2, 29)
    assert(r7.is_error(), "non-leap 2023")
    println("leap_ok")

    // fields
    let d = Date.new(2024, 6, 15).unwrap()
    assert(d.year() == 2024, "year")
    assert(d.month() == 6, "month")
    assert(d.day() == 15, "day")
    println("fields_ok")

    // weekday: 2024-06-15 is Saturday (ISO 8601 = 6)
    assert(d.weekday() == 6, "weekday sat")
    // 1970-01-01 is Thursday (ISO 8601 = 4)
    assert(Date.epoch().weekday() == 4, "epoch thursday")
    println("weekday_ok")

    // day_of_year: 2024-01-01 = 1, 2024-06-15 = 167
    let jan1 = Date.new(2024, 1, 1).unwrap()
    assert(jan1.day_of_year() == 1, "jan1 doy")
    assert(d.day_of_year() == 167, "jun15 doy")
    println("day_of_year_ok")

    // is_leap_year
    assert(d.is_leap_year(), "2024 leap")
    let d2023 = Date.new(2023, 6, 15).unwrap()
    assert(d2023.is_leap_year() == false, "2023 not leap")
    println("is_leap_year_ok")

    // days_in_month
    assert(d.days_in_month() == 30, "june 30")
    let jan = Date.new(2024, 1, 1).unwrap()
    assert(jan.days_in_month() == 31, "jan 31")
    let feb_leap = Date.new(2024, 2, 1).unwrap()
    assert(feb_leap.days_in_month() == 29, "feb leap 29")
    println("days_in_month_ok")

    // add_days
    let d3 = d.add_days(10)
    assert(d3.day() == 25, "add 10 days")
    let d4 = d.add_days(-15)
    assert(d4.day() == 31, "sub 15 days -> may 31")
    assert(d4.month() == 5, "sub 15 days -> may")
    println("add_days_ok")

    // days_until
    let a = Date.new(2024, 1, 1).unwrap()
    let b = Date.new(2024, 1, 11).unwrap()
    assert(a.days_until(b) == 10, "days_until 10")
    assert(b.days_until(a) == -10, "days_until -10")
    println("days_until_ok")

    // add_months
    let m1 = Date.new(2024, 1, 31).unwrap()
    let m2 = m1.add_months(1)
    assert(m2.month() == 2, "add month -> feb")
    assert(m2.day() == 29, "clamped to feb 29 leap")
    let m3 = m1.add_months(12)
    assert(m3.year() == 2025, "add 12 months year")
    assert(m3.month() == 1, "add 12 months month")
    println("add_months_ok")

    // add_years
    let y1 = Date.new(2024, 2, 29).unwrap()
    let y2 = y1.add_years(1)
    assert(y2.year() == 2025, "add year")
    assert(y2.month() == 2, "add year month")
    assert(y2.day() == 28, "clamped feb 28")
    println("add_years_ok")

    // eq and ord
    let x = Date.new(2024, 6, 15).unwrap()
    let y = Date.new(2024, 6, 15).unwrap()
    let z = Date.new(2024, 6, 16).unwrap()
    assert(x.equals(y), "eq")
    assert(x.compare(z) == -1, "lt")
    assert(z.compare(x) == 1, "gt")
    println("eq_ord_ok")

    // to_string
    let s = d.to_string()
    assert(s == "2024-06-15", "to_string")
    println("to_string_ok")

    // parse
    let p = Date.parse("2024-06-15")
    if p is .Ok(pd) then {
        assert(pd.equals(d), "parse eq")
    } else {
        assert(false, "parse should be Ok")
    }
    println("parse_ok")

    // parse invalid
    assert(Date.parse("not-a-date").is_error(), "invalid")
    assert(Date.parse("2024-13-01").is_error(), "invalid month")
    assert(Date.parse("2024-02-30").is_error(), "invalid day")
    println("parse_invalid_ok")

    yield 0
}
