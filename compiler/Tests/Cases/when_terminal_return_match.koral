// EXPECT: 11
// EXPECT: 22

type Choice {
    Left(),
    Right(),
}

let choose(choice Choice) Int = {
    return when choice in {
        .Left then {
            return 11
        },
        .Right then {
            return 22
        },
    }
}

let main() Int = {
    println(choose(Choice.Left()))
    println(choose(Choice.Right()))
    yield 0
}