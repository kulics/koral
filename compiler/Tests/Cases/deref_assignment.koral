// EXPECT: 2
// EXPECT: 7
// EXPECT: 11
// EXPECT: 13

let [T Deref]set_ref(r T ref, v T) Void = {
    deref r = v
}

type [T Any] RefHolder(mut slot T ref)

given[T Any] [T]RefHolder {
    get_ref(self ref) T ref = self.slot
}

let [T Deref]set_by_field(h [T]RefHolder ref, v T) Void = {
    deref h.slot = v
}

let [T Deref]set_by_return(h [T]RefHolder ref, v T) Void = {
    deref h.get_ref() = v
}

public let main() Void = {
    let mut x = 1
    let r = ref x

    deref r = 2
    println(x)

    [Int]set_ref(r, 7)
    println(x)

    let mut y = 9
    let mut holder = [Int]RefHolder(ref y)
    [Int]set_by_field(ref holder, 11)
    println(deref holder.slot)

    [Int]set_by_return(ref holder, 13)
    println(deref holder.slot)
}
