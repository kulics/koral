// EXPECT: before replace
// EXPECT: Drop 1
// EXPECT: after replace
// EXPECT: result 2
// EXPECT: Drop 2

type Tracker(id Int)

given Tracker Drop {
    drop(self ref) = {
        println("Drop \(self.id)")
    }
}

let make_tracker(id Int) Tracker = {
    let value = Tracker(id)
    return value
}

let replace_and_return() Tracker = {
    let mut current = Tracker(1)
    println("before replace")
    current = make_tracker(2)
    println("after replace")
    return current
}

let main() Int = {
    let result = replace_and_return()
    println("result \(result.id)")
    yield 0
}