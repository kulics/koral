// Test trailing commas in function calls, type construction, and union construction
// EXPECT: === Function Call Trailing Comma ===
// EXPECT: 3
// EXPECT: 10
// EXPECT: === Type Construction Trailing Comma ===
// EXPECT: 42
// EXPECT: hello
// EXPECT: === Union Construction Trailing Comma ===
// EXPECT: Some(1)
// EXPECT: None
// EXPECT: === Implicit Member Expression Trailing Comma ===
// EXPECT: Some(99)
// EXPECT: === Static Method Call Trailing Comma ===
// EXPECT: 7
// EXPECT: === Generic Method Call Trailing Comma ===
// EXPECT: 84
// EXPECT: === Qualified Method Call Trailing Comma ===
// EXPECT: 17
// EXPECT: All trailing comma tests passed

// --- Types ---

type Point(x Int, y Int)

type [T Any] Box {
    Some(val T),
    None(),
}

// --- Traits ---

trait Adder {
    add(self, other Int) Int
}

given Adder {
    add_ten(self) Int = self.add(10,)
}

type Counter(val Int)

given Counter Adder {
    add(self, other Int) Int = self.val + other
}

given Counter {
    public new(v Int) Self = Counter(v,)

    public [U Any]map(self, f [Int, U]Func) U = f(self.val,)
}

// --- Helpers ---

let sum3(a Int, b Int, c Int) Int = a + b + c

let print_box(b [Int]Box) Void = when b in {
    .Some(v) then println("Some(" + v.to_string() + ")"),
    .None then println("None"),
}

let main() Void = {
    println("=== Function Call Trailing Comma ===")

    // trailing comma with single arg
    let r1 = sum3(1, 2, 0,)
    println(r1.to_string())

    // trailing comma with multiple args
    let r2 = sum3(1, 2, 7,)
    println(r2.to_string())

    println("=== Type Construction Trailing Comma ===")

    // struct construction trailing comma
    let p = Point(42, 0,)
    println(p.x.to_string())

    // generic type construction trailing comma
    let b1 = [String]Box.Some("hello",)
    when b1 in {
        .Some(v) then println(v),
        .None then println("None"),
    }

    println("=== Union Construction Trailing Comma ===")

    // union construction trailing comma
    let b2 = [Int]Box.Some(1,)
    print_box(b2)

    let b3 = [Int]Box.None()
    print_box(b3)

    println("=== Implicit Member Expression Trailing Comma ===")

    // implicit member expression trailing comma
    let b4 [Int]Box = .Some(99,)
    print_box(b4)

    println("=== Static Method Call Trailing Comma ===")

    // static method call trailing comma
    let c = Counter.new(7,)
    println(c.val.to_string())

    println("=== Generic Method Call Trailing Comma ===")

    // generic method call trailing comma
    let c2 = Counter(42,)
    let doubled = c2.[Int]map((x) -> x * 2,)
    println(doubled.to_string())

    println("=== Qualified Method Call Trailing Comma ===")

    // qualified method call trailing comma
    let c3 = Counter(7,)
    let result = c3.(Adder)add(10,)
    println(result.to_string())

    println("All trailing comma tests passed")
}
